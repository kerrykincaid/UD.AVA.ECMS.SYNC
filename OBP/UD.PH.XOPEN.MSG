build.email.to:
    
    to.email        =   xf.list<3,br.ctr>:"<":xf.list<4,br.ctr>:">;"
    writer.em       =   each.sm (xf.list<10,br.ctr>, writer.ctr) {
        to.email   :=   xf.list<9,br.ctr,writer.ctr>:"<":writer.em:">;"
    }
    
return
