initialize:
***
* Start up
***
    buffer.clear ()
* Status Monitor
    status.monitor = new (status.monitor)
    with status.monitor {
        ::set.name ("XF.STATUS")
        ::set.title ("Xfer Processing Status")
    }
* log variables
    phst.msg~~~
    run.msg~~~
    prt.msg~~~
    
    today   =   date()
    start_date~~~
    stop_date~~~
    now     =   time()
    last.run.rec~~~
    last.date~~~
    last.time~~~
    run.count~
    verf.br~~~

    em.writer~~~
    
    *Aging bucket settings
    aod~~~
    agd =   today
    inq.brs~~~
    lme~~~
    xtype~~~
    
* last run
    * read last date and time of last sync.
    sub::read.last.action (last.date, program.name,@false,1)
    sub::read.last.action (last.time, program.name,0,2)
    sub::read.last.action (run.count, program.name,0,3)
    *Reformat for internal use.
    if last.date {
        last.date = iconv (last.date, "D4/")
        last.time = iconv (last.time, "MTHS")
    }
    
    if last.date != today {
        run.count   =   0
    }

    err.msg~~~
    phst.msg~~~
    run.msg~~~
    prt.msg~~~
    
    lock.ledger~~
    wait.for.locks~~
    time.out.time   =   5
    ledger.sleep    =   .5
    
    
* objects
    setting     =   new (setting, "XFER.UTILS.SETUP")
    manager     =   new (file.manager)
    ledger      =   new (ledger)
    entity      =   new (entity)
    cust.class  =   new (cust.class)
    thread      =   new (thread) 
    xfer.email  =   new (email)
    
    with ledger {
        ::locks (lock.ledger)
        ::wait.for.locks (wait.for.locks, time.out.time, ledger.sleep)
    }

*  Variables
    
    with setting {
        ::set.tag ("xfer.open.msg")
    
        with ::enabled {
            enabled         = :: ("Enabled", @false)
            is_debug        = :: ("debug",@false)
            auto.logoff     = :: ("auto.logoff", @true)
            always.bm.em    = :: ("always.notify.mgr", @false)
        }
        with ::get {
            log_user        = :: ("log_user")
            reason$         = :: ("reason_msg")
            u_name          = :: ("u_name")
            auto.off.time   = :: ("auto.off.time", "21:00"); * 9pm default.
            sleep_time      = :: ("SleepTime", 1800); * 30 minute default.
            select_1        = :: ("select_1", 'SELECT ORDER.QUEUE WITH TYPE = 5 AND XFER.SHIP.RECV = "SX" AND SHIP_BR = "$$dc$$"')
            cutoff.date     = :: ("cutoff.date", 'MO/DA/YR')
            cutoff.date = realdate (cutoff.date)
            cutoff.date = oconv(cutoff.date,'D4/')
            email_from      = :: ("FromEmailAddress","wizard@morsco.com")
            email_subj_txt  = :: ("EmailSubject","Xfer Open Status Notification")
            email_body_txt  = :: ("OpenStatusEmailBody")
            change (email_body_txt, "\", @am)
            override_email  = :: ("override.email")
            use.override.email = set.if (override_email)
            
            pn.header       = :: ("pn.header")
            change (pn.header, "\", char(9))
            change (email_body_txt, "$$pnheader$$", pn.header)
        }
        with ::get.comma.list {
            enabled.brs     = :: ("enabled.brs")
            phantom.users   = :: ("phantom.users")
            email.CC        = :: ("EmailCC")
            email.BCC       = :: ("EmailBCC")
            **  For now these must be a literal email.  Future dev could be to accomodate
            ** the @WRITER, @SLSMAN, @Customer, @AUTO from triggers to determine emails.

        }
    }
    
    * enabled =   (enabled_unrec | enabled_recno | enabled_freight | enabled_closed)
    ifnot enabled {
        run.msg = u_name:" is not enabled!"
        log.msg
        finish
    }
    
    run.msg =   "Auto off time:  ":auto.off.time
    log.msg
    iconv (auto.off.time, "MTH")
    
    *run.count++
        
    prt.msg = (oconv(today,"D4/"))
    log.msg
    prt.msg = (oconv(now,"MTHS"))
    log.msg
    * prt.msg = (run.count)
    * log.msg
    
    * register this phantom
    with thread {

        ::set.name (program.name, program.title)
        ::add.register

        ::set.status ("Starting Up")
        sleep 3

    * if there's another instance of this phantom running we don't want to start up another
        phantom.count = ::get.pid.count
        cases {
            case phantom.count = 2
                bad.text = "Another instance of this phantom is currently running"
            case phantom.count > 2
                bad.text = phantom.count:" instances of this phantom is currently running"
            other
                bad.text = ""
        }

        ifnotnull bad.text {
            phst.msg = "Cannot initialize: ":bad.text
            log.msg
            finish
        }
    }
    sleep 5
    
* files
    with manager::open {
        
        run.msg     =   "Open Order Queue file"
        log.msg
        oqfile    =   :: ("ORDER.QUEUE")
      
        if have.error {
            run.msg = "Error opening ":oqfile:".  ":vm:err.msg
            log.msg
            finish
        }
    }
    
    log_user = fetch (inifile,log_user,0)
    if (!log_user) | (user.id[1,3] =   "WIZ") {
        log_user    =   user.id
    }

    * last.run.rec<1> = oconv (today, 'D4/')
    * last.run.rec<2> = oconv (now, 'MTHS')
    * sub::write.last.action last.run.rec, dvr.name

 return
