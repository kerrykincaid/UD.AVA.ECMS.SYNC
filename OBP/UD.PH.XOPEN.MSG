build.email.message:

    email_body      =   email_body_txt
    email_subject   =   email_subj_txt

    change (email_subject,'$$dc_br$$',dc.br)
    * change (email_body,'$$transfernumber$$',xfer.number)
    * change (email_body,'$$shipbr$$',jq.fr.br)
    * change (email_body,'$$tobr$$',jq.to.br)
    * change (email_body,'$$writer$$',jq.writer)
    table.data~~~
    table.row~~~
    xfer.line =   each.am (br.xfer.list, line.idx) {
        *run.msg = xfer.line
        *log.msg
        table.row   =   '<tr><td  style="text-align: center">':change(xfer.line,@svm,'</td><td style="text-align: center">'):'</td></tr>':@am
        table.data :=   table.row
    }
    *run.msg =   table.data
    *log.msg
    *change (email_body,'$$pnlist$$',change(change(jq.pns,svm,char(9)),vm,am))
    * run.msg =   email_body
    * log.msg
    change (email_body,'$$xferlist$$',table.data)
    *run.msg =   email_body
    *log.msg

    return
