section logging:     **********************************************************
***************************************************************************
log.msg: * log message to all locations.
    
    * PHST.MSG = PHANTOM MESSAGE, STATUS MONITOR, BUFFER LOG
    if phst.msg {
        text = (phst.msg)
        status.monitor::add.status (text)
        
        if phantom.proc {
            with thread {
                *write phst.msg on phstfile, pid$
                thread::set.status (phst.msg)
            }
        }{
            print phst.msg "L#70"
        }
        buffer (text)        
    }
    * RUN.MSG = STATUS.MONITOR, BUFFER LOG
    if run.msg {
        z.ct = dcount(run.msg,@am)
        prt = each.am (run.msg) {
            if not (phantom.proc) {
                print run.msg<prt> "L#70"
            }
        }
        change (run.msg,@am,', ')
        text = (run.msg)
        status.monitor::add.status (text)
        buffer (text)
    }
    * PRT.MSG = BUFFER LOG
    if prt.msg {
        text = (prt.msg)
        buffer (text)
        if is_debug {
            status.monitor::add.status (text)
        }
    }
    phst.msg~~~
    run.msg~~~
    prt.msg~~~
    
    return
   
