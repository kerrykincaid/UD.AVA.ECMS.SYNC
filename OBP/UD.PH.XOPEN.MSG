select.and.deliver: 
    ***  select open status transfers for DC.
    *** Evaluate transfer for whom to send notification.
    
    run.msg =   " Stage 1:  Select, filter on minimum criteria."
    log.msg 

    xf.list~~~
    xf.list.ct~
    xfer.oid.ct~
    
    dc.br = each.am (enabled.brs, ebr.idx) {
        ** Select only OPEN transfers.
        cmd         =   select_1
        change (cmd,'$$dc$$',dc.br)
        change (cmd,'$$cutoff$$',cutoff.date)
        
        phst.msg =  " Selecting open transfer records from ":dc.br:"..."
        log.msg
        run.msg =   cmd
        log.msg
        sleep 3
        *msg         =   exec (cmd)
        execute cmd capturing msg
        selected.ids,xfcount  =   build.active.list ()
        
        *-----------
        ** Select statement selects and validates.  Any returned record will send message.
        run.msg = xfcount:" transfers selected."
        log.msg
        *-----------
        
        xf.rec~~~
        xf.writer~~~
        xf.writer.email~~~
        xf.manager~~~
        xf.id~~~
        xf.curr.br      =   '@@@'
        xf.rbr.ct~

        xf.id = each.am (selected.ids, xf.idx) {
            run.msg =   xf.id
            log.msg
            
            xf.rec      =   fetch (oqfile,xf.id)
            xfer.oid    =   field(xf.id,'.',1)
            xfer.date   =   field(xf.id,'.',2)
            xfer.gid    =   field(xf.id,'.',3)
            
            xfer.writer =   xf.rec<9>
            xfer.30     =   fetch (ledfile,xfer.oid,30)
            xfer.brs    =   fetch (ledfile,xfer.oid,2)
            xfer.rcvbr  =   xlate.vm ('RX',xfer.30,xfer.brs)
            xfer.rcvbr  =   xfer.rcvbr<1,1,2>
            
            if xfer.rcvbr <> xf.curr.br {
                * New Receive Branch
                xf.curr.br = xfer.rcvbr
                * Already sorted by Receive Branch, just drop on end and use count.
                xf.list<1>              =   add.unique.vm (xfer.rcvbr,xf.list.ct)
                xfer.manager            =   fetch (terrfile,xfer.rcvbr,33)
                to.br.mgr.nm            =   fetch(inifile,xfer.manager,3)
                to.br.mgr.em            =   fetch(inifile,xfer.manager,55)
                * Branch Manager
                xf.list<2,xf.list.ct>   =   xfer.manager
                xf.list<3,xf.list.ct>   =   to.br.mgr.nm
                xf.list<4,xf.list.ct>   =   to.br.mgr.em
            }
            * Added to current branch and new branch.
            ** Setting ptr just in case the add.sorted does NOT set it.
            add.unique.ptr  =   1
                * Order/Ship Date
            xfer.shipdt             =   xf.list<6,xf.list.ct>
            xfer.shipdt             =   add.sorted.sm (xfer.date, xfer.oid.ct)
            xf.list<6,xf.list.ct>   =   xfer.shipdt
                * Transfer ID
            *xf.list<5,xf.list.ct>    =   xfer.date:" ":xfer.oid
            ins xfer.oid before xf.list<5,xf.list.ct,add.unique.ptr>
                * From Br
            xf.list<7,xf.list.ct>   =   dc.br
                * Writer
            *xf.list<8,xf.list.ct,add.unique.ptr>    =   xfer.oid:" ":xfer.writer
            ins xfer.oid:" ":xfer.writer before xf.list<8,xf.list.ct,add.unique.ptr>
            em.writer       =   set.ifnot.in (xfer.writer,phantom.users)
            writer.em       =   fetch(inifile,xfer.writer,55)
            writer.nm       =   fetch(inifile,xfer.writer,3)
            em.writer       =   set.if (em.writer & (writer.em))
            if em.writer {
                *xf.list<9,xf.list.ct,add.unique.ptr>     =   writer.nm
                ins writer.nm before xf.list<9,xf.list.ct,add.unique.ptr>
                *xf.list<10,xf.list.ct,add.unique.ptr>    =   writer.em
                ins writer.em before xf.list<10,xf.list.ct,add.unique.ptr>
            }{
                *xf.list<9,xf.list.ct,add.unique.ptr>~~~
                ins "" before xf.list<9,xf.list.ct,add.unique.ptr>
                *xf.list<10,xf.list.ct,add.unique.ptr>~~~
                ins "" before xf.list<10,xf.list.ct,add.unique.ptr>
            }
        }
    }

    run.msg =   " *** Stage 1 complete"
    log.msg

    if xf.list.ct > 0 {
        send.emails.from.list
    }
    run.msg =   " *** Stage 2 complete"
    log.msg

return
