    ph.args drpt

**************************************************************************
* Subroutine to EMAIL users when transfers are left open.
*   Using TRACKING.LOG file.
**************************************************************************
    program.name    =   "UD.PH.XOPEN.MSG"
    program.title   =   "Xfer Open Notification"

    if not (phantom.proc) {
        sub::window ("", "", 78, 21, 3, "", "Xfer OOS Messaging")
    }

    initialize
****
    *check.for.logoff
    *forever {
        
        select.and.deliver
        *  Short circuit to finish.  Scheduled task rather
        * than long running phantom.
        finish

        *check.for.logoff
        if sleep_time > 120 {
            till.time = time() + sleep_time
            till.time = oconv(till.time,'MTH')
            message = "Waiting till ":till.time:"..."
            status.monitor::add.status (message)
        }{
            message = "Waiting..."
        }
        thread::set.status (message)
        sub::write.last.action (output.buffer, program.name)
        
        sleep = each (1, sleep_time, 2) {
            sleep 2
            check.for.logoff
        }
        with setting {
            ::set.tag ("xfer.oos")
            ::refresh
        }
    *}
    
**************************************************************************    
finish: 
    ledger::locks.off
    thread::delete.register
    phst.msg = thread::thread.pid:" Phantom terminating"

    log.msg
    sub::write.last.action (output.buffer, program.name)

    sleep 3
    
    if phantom.proc {
        sub::send.message ("Phantom", user.id, phst.msg)
    }{
        print "Press <Return> to continue."
        inp a
        sub::window.close
    }
    exit.sub

**************************************************************************   
 check.for.logoff: ********************************************************
* check for a logoff request; UD.CONTROL program.name.THREAD.REGISTER 21 *
**************************************************************************
    logoff.requested = thread::request.logoff
    logoff.requested = logoff.requested | (!enabled)

    cases {

* check for end of day log off
        case auto.logoff & time() >= auto.off.time
            message = "Stopping ":program.name:" for end of day"

* check for a request to log off
        case logoff.requested
            message = "Stopping ":program.name:" as requested"
            
* no message
        other 
            message = ""
    }
    return.ifnull message

    phst.msg = message
    log.msg
    sleep 3
    
    if phantom.proc {
        thread::delete.register
    }

    sleep 3

    goto finish
    
    return

