send.emails.from.list:
    run.msg =   " Stage 2: Send email to Branch Manager or Writer."
    log.msg
    
    *  A single email is sent to each receiving branch containing every Transfer
    * plus details that matches the criteria.
    rcv.br  =   each.vm (xf.list<1>, br.ctr) {
        br.xfer.list~~~
        email.sent~
        xfer.number =   each.sm (xf.list<5,br.ctr>, xfer.ctr) {
            dc.br       =   xf.list<7,br.ctr,xfer.ctr>
            xfer.date   =   xf.list<6,br.ctr,xfer.ctr>
            xfer.writer =   xf.list<9,br.ctr,xfer.ctr>
            xfer.line   =   (dc.br:@svm:xfer.number:@svm:xfer.date:@svm:xfer.writer)
        
            ifnot br.xfer.list {
                br.xfer.list        =   xfer.line
            }{
                br.xfer.list<-1>    =   xfer.line
            }
            build.email.to
        }
        
        build.email.message
        
        with xfer.email {

            if use.override.email {
                email_to    =   override_email
            }{
                email_to    =   to.email
            }
            
            ::set.email.type ("HTML")
            
            ::set.to.address (email_to)
            
            ::add.cc (email.CC)
            
            ::add.bcc (email.BCC)
            
            ::set.from.address (email_from)

            ::set.subject (email_subject)

            ::set.message (email_body)

            ::send

            if have.error {
                run.msg =   "    Error sending email to ":'"':email_to:'"':": Error: ":'"':error.message:'"'
                log.msg
                clear.error
            }{
                run.msg =   "  Email sent for Xfer: ":xfer.number:" ":to.email
                log.msg
                email.sent~~
            }
            
            jq.id~~~
            
            if email.sent {
                * Do somethinng if emaill is sent... follow  up action.
                null
            }{
                run.msg =   "  Email NOT sent for Xfer: ":xfer.number:" ":to.email
                log.msg
            }
        }
    }
return    
