    subroutine ud.ava.cert.json (json,cn,cert.id)

* subroutine - ud.ava.cert.json

*---------------------------program description---------------------------*
* builds json document required to update a certificate via the Avalara
* AvaTax API. 
*--------------------------parameter definition---------------------------*
* json - json record for new customer, customer, or Cert.          [out]
* cn   - Customer number to process.                                [in]
* cert.id - avatax cert.id being processed or RegionExemption num.  [in]
*----------------------------common variables-----------------------------*
***************************************************************************

    init
    prep.files
    
*** Lookup cert id in UD.AVALARA file.
***   Else, get cert data from AVATAX API.  Match data to CN and Exempt 
***   Cert data on customer record.  
***      Else, No JSON.  Return.
***   Build JSON from cert data in Eclipse.
*** From @ID of UD.AVALARA record, match to CN.
*** If matched, then get state and exemption number from @ID. 
***   Else, No JSON.  
*** If matched, then build JSON from cert data in Eclipse.  
***   Else, no JSON.    
    
    proc.cert
    json = certrec.json
    
finish:
    sub::write.last.action (output.buffer, pgm.name)
    * Write new log entry.
    avalogid    =   pgm.name:'~':begin.date:'~':begin.time
    unfetch (output.buffer, avalogfile, avalogid)
    
    sub::ut.tempfile.delete (temp.name, tempfile)
    exit.sub

***************************************************************************
***************************************************************************
init: * initialize
    begin.date = date()
    begin.time = int(time())
    buffer.clear ()
    buffer (oconv(date(),"D4/"):"  ":oconv(time(),"MT"))
    pgm.name    =   "UD.AVA.CERT.JSON"
    
* objects
    setting = new (setting, "AVATAX.ECMS.SETUP")
    with setting::get {
        enabled         = :: ("Enabled", 0, 1)
        var.eff.date    = :: ("var.eff.date", "MO/DA/YR")
        var.exp.date    = :: ("var.exp.days", "MO/31/YR")
        avadateformat   = :: ("AvalaraDateFormat","D-YMD[Z4,2,2]")
    }
    if !enabled {
        buffer ("Interface not enabled!" )
        finish
    }
    
    sub::realdate (def.eff.date, var.eff.date)
    ifnot def.eff.date {
        buffer ("  Bad Default Effective Date!  ")
        def.eff.date = date()
    }
    
* customer record
    read cus.rec from cusfile,cn }{
        buffer ("Unable to read customer record.  CN: ":cn)
        return to finish
    }
    
* variables    
    phst.msg~~~
    run.msg~~~
    resp~~~
    c.cert.cnt~
    envelp      =  char (34)
    
* New customer and cert JSON.
    certrec.json~~~
    nrj.level   =  0
    cur.cust~~~

    cert.head~~~
* build item portion of cert certrec.json.
    cert.head<1>      =  "id"
    cert.head<2>      =  "signedDate"
    cert.head<3>      =  "expirationDate"
    cert.head<4>      =  "filename"
    cert.head<5>      =  "valid"
    cert.head<6>      =  "exemptionNumber"
    cert.head<7>      =  "exemptionReason"
    cert.head<7, 2>   =  "name"
    cert.head<8>      =  "taxNumberType"
    cert.head<9>      =  "businessNumberType"
    cert.head<10>     =  "exposureZone"
    cert.head<10, 2>  =  "name"    
    
    cefd~~~
    cexd~~~
    bus.num.type~~~

* pricing type to business type mapping variables.
    read xref.types from ctrlfile, "UD.AVA.XREF.TYPES" }{
        xref.types = ""
    }
    ava.bus.types = fetch (ctrlfile, 'UD.AVALARA.BUS.TYPE')
    bus.num.type~~~
    prc.type    =  cus.rec<35,1>
    
    locate prc.type in xref.types<1> setting type.pos }{
        type.pos = ''
    }
    bus.type    =   xref.types<2,type.pos>
    if !bus.type {
        *bus.num.type    =   trim (prc.type)
        bus.num.type    =   "Other"
    }{
        type.name =   xlate.vm (bus.type, ava.bus.types<1>, ava.bus.types<2>)
        if type.name {
            change (type.name, '-', ' ')
            trim (type.name)
            bus.num.type    =   type.name
        }
    }

* variables for api calls and caching.
    gl.br          =  cus.rec<53>
    if !gl.br {
        gl.br = "1000"
    }
    sub::ud.ava.get.company.id (gl.br, comp.id)
    sub::ud.ava.ezones (exp.zones)
    e.reg       =  exp.zones<1>
    e.names     =  exp.zones<2>
    ezone.ct =  dcount (e.reg, vm)

 return

***************************************************************************
prep.files:
**          read vst from statfile,'valid.us.states' else vst = ''
    read vst from ctrlfile, "VALID.US.STATES" }{
        vst = ""
    }

    sub::ut.open.file ("UD.AVALARA", avaifile, error.message, yes)
    if have.error {
        buffer ("Unable to open UD.AVALARA.")
        goto finish
    }
    
    sub::ut.open.file ("UD.AVALOG", avalogfile, error.message, yes)
    if have.error {
        buffer ("Error opening UD.AVALOG.  ":vm:error.message)
        goto finish
    }

 return
