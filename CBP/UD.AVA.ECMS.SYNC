    RUN.MSG = "Prep files"
    GOSUB LOG.MSG
    
* tempfile
    TEMP.HANDLE = "" ; TEMP.HANDLE<3> = "FILE;FILE,SEQ.FILE;SEQ.FILE,FILE::UNDO;UNDO,SEQ.FILE::FILE;FILE,SEQ.FILE::FILE::UNDO;UNDO" ; UD.MTH.TEMP.FILE.NEW TEMP.HANDLE, ERROR.MESSAGE, REGISTRY.SOURCE.ID, TEMP.CHILD.CHILD.TEMPFILEOBJ.FILE, TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE, TEMP.CHILD.CHILD.TEMPFILEOBJ.FILE.UNDO, TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE.FILE, TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE.FILE.UNDO ; TEMPFILEOBJ = TEMP.HANDLE ; CHILD.TEMPFILEOBJ.FILE = TEMP.CHILD.CHILD.TEMPFILEOBJ.FILE ; CHILD.TEMPFILEOBJ.SEQ.FILE = TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE ; CHILD.TEMPFILEOBJ.FILE.UNDO = TEMP.CHILD.CHILD.TEMPFILEOBJ.FILE.UNDO ; CHILD.TEMPFILEOBJ.SEQ.FILE.FILE = TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE.FILE ; CHILD.TEMPFILEOBJ.SEQ.FILE.FILE.UNDO = TEMP.CHILD.CHILD.TEMPFILEOBJ.SEQ.FILE.FILE.UNDO ; * new TEMP.FILE object
    CALL.TEMP.OBJECT.HANDLE = TEMPFILEOBJ ; UD.MTH.TEMP.FILE.CREATE CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, TEMP.NAME, TEMPFILE ; TEMPFILEOBJ = CALL.TEMP.OBJECT.HANDLE

    
    LPATH =  FILEINFO (TEMPFILE, 2)
    RUN.MSG = "Temporary file path:  ":LPATH
    GOSUB LOG.MSG
    RUN.MSG = " - Tempfile name:  ":TEMP.NAME
    GOSUB LOG.MSG
    

* files
*   WITH MANAGER::OPEN
        
        RUN.MSG = "Open data file"
        GOSUB LOG.MSG
        CALL.TEMP.OBJECT.HANDLE = MANAGER ; UD.MTH.FILE.MANAGER.OPEN CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, AVAIDFILE, "", "UD.AVALARA" ; MANAGER = CALL.TEMP.OBJECT.HANDLE
        IF (ERROR.MESSAGE <> '') THEN 
            RUN.MSG = "Error opening UD.AVALARA.  ":VM:ERR.MSG
