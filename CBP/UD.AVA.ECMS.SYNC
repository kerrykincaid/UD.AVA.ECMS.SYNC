        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, PARTSYNCDAYS, "PartSyncDayofWeek" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, PARTSYNCWINDOW, "PartialWindow", 0 ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, RUNCTRLREC, "RunCtrlRec" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, CUSTMAX, "MaxCustSelected", 100 ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, VAR.EXP.DATE, "var.exp.date", "+1/FE/YR" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, AVADATEFORMAT, "AvalaraDateFormat", "D-YMD[Z4,2,2]" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        * Record field tracking to determine if changes are to customer data, or certificate data.    
        REC.FIELDS = ''
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, TEMP.VAR.1, "CustomerFields" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        REC.FIELDS<1> = TEMP.VAR.1
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, TEMP.VAR.1, "CertificateFields" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        REC.FIELDS<2> = TEMP.VAR.1
        REC.FIELDS<1> = CHANGE(REC.FIELDS<1>, ',', @VM)
        REC.FIELDS<2> = CHANGE(REC.FIELDS<2>, ',', @VM)
*   END.WITH
    
    TEMP.HANDLE = "" ; UD.MTH.FILE.MANAGER.NEW TEMP.HANDLE, ERROR.MESSAGE, REGISTRY.SOURCE.ID ; MANAGER = TEMP.HANDLE ; * new FILE.MANAGER object
        
    * Get my process id for tracking.
    UNIX.PID.GET MYPID
    
    * Run one at a time.  Do not let another Sync begin while one is running.
    READV RUN.PID FROM CTRLFILE, (RUNCTRLREC), (1) ELSE RUN.PID = ''
    
    IF RUN.PID THEN 
        * Check that the Process is still active.  This could result in a false positive.
        * Better safe than sorry... If we track our own PID, it'll get cleaned up on exit.
        UT.PIDS.GET RUNNING.PIDS
        LOCATE RUN.PID IN RUNNING.PIDS SETTING IS.RUNNING ELSE IS.RUNNING = @FALSE
        IF IS.RUNNING AND (RUN.PID # MYPID) THEN 
            PHST.MSG = "Sync already running!  ":RUN.PID
            CALL.TEMP.2 = USER.ID ; SEND.MESSAGE 'Phantom', CALL.TEMP.2, PHST.MSG ; USER.ID = CALL.TEMP.2
            GOSUB LOG.MSG
            SLEEP 12
            *  Exit immediately without writing last action record.  Keep previous entry.
            GOSUB EXIT.TO.CALLING.PROGRAM
        END 
        * Not actually running... clean up the Ctrl Rec.
        WRITEV ("") ON CTRLFILE, (RUNCTRLREC), (1)
    END 
    *  This process is running... write control record with PID.
    WRITEV (MYPID) ON CTRLFILE, (RUNCTRLREC), (1)
    
    IF NOT( ENABLED ) THEN 
        RUN.MSG = "Interface not enabled!" 
        GOSUB LOG.MSG
        GOSUB FINISH
    END 

* last run
    * read last date and time of last sync.
    READ.LAST.ACTION LAST.DATE, PGM.NAME, @FALSE, 1
    READ.LAST.ACTION LAST.TIME, PGM.NAME, 0, 2
    
    IF LAST.DATE AND LAST.TIME THEN 
        LAST.DATE = ICONV (LAST.DATE, "D4/")
        LAST.TIME = ICONV (LAST.TIME, "MTHS")
    END 
    
* variables    
    READ VALID.US.STATES FROM CTRLFILE, ('VALID.US.STATES') ELSE VALID.US.STATES = ''
    FULL.SYNC = @FALSE
    PARTIAL.SYNC = @FALSE
    
    RESP = ''
    CUSTOMERLIST = ''
    PORTALCUSTOMERLIST = ''
    PROC_DELLIST = ''
    CN = ''
    CN.CNT = @FALSE
    SELECT.CNT = @FALSE
    OVERMAX = @FALSE
    DEL.CNT = @FALSE
    DEL.CERT.CNT = @FALSE
    PORTAL.CUST.LST = ''
    PORTAL.CUID.LST = ''
    PORTAL.CERT.LST = ''
    CUS.POS = @FALSE
    PCN = ''
    PCN.ID = ''
    PROCD.CNS = ''
    PREV.CN = ''
    EXPIRED.CNT = @FALSE
    REC.CT = @FALSE
    RECORD.IDS = ''
    RECORDS = ''
    PCN.CERT.LST = ''
* Keep a list of customers that need to be deleted.  Remove customers from delete list
* if a new certificate is encountered later in the process.
    DEL.CUS.LST = ''
    
* New customer and cert JSON.
    SINGLEBATCH = @FALSE
    COMP.LIST = ''
    NEWCUST.CT = @FALSE
    NEWCUS.J.COMP = ''
    NEWCUS.BATCH = ''
    NEWCUS.J.H  =  " ["
    JSON.OUT = ''

* variables for api calls and caching.
    GL.BR = ''
    COMPID = @FALSE

    RUN.MSG = "Initialized  ":MYPID
    GOSUB LOG.MSG
    RUN.MSG = ""
    GOSUB LOG.MSG
    IF TROUBLESHOOTING THEN 
        RUN.MSG = "Troubleshooting!"
        GOSUB LOG.MSG
    END  
    
* files
    GOSUB PREP.FILES

    LAST.RUN.REC<1> = OCONV (DATE(), 'D4/')
    LAST.RUN.REC<2> = OCONV (TIME(), 'MTHS')
    WRITE (LAST.RUN.REC) ON AVAIDFILE, ('LAST.RUN')
    
  RETURN
