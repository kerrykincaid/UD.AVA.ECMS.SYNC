*---------------------------program description---------------------------*
*  Processes the Data records from the ECMS Build routine, using API
* to transmit the data. 
* One way sync from Eclipse to Avalara Portal.  
* *** OLD Notes on ECMS.
*  https://help.avalara.com/001_avalara_avatax/000_avatax_update/manage__
* exempt_customers_using_avatax_exemptions
*
*** Ultimately this is a temporary routine.  Next step is to replace the export portions of
*** the AVA.ECMS.BUILD routine with API calls.  Following would be to use the API calls 
*** instead of building AVALARA_DATA records, or at the same time.  
*--------------------------parameter definition---------------------------*
* err.msg -                                                         [out]
*----------------------------common variables-----------------------------*
***************************************************************************
 
    GOSUB LOAD.OBJECT.SUBROUTINE.VARIABLES
 
    BEGIN.DATE      = DATE()
    BEGIN.TIME      = INT(TIME())

    IF NOT (PHANTOM.PROC) THEN 
        WINDOW "", "", 78, 21, 3, "", "ECMS to API Sync"
    END 

    GOSUB INITIALIZE

    PHST.MSG = "Processing CUSTOMER records..."
    IF NOT( (LAST.DATE = DATE()) ) THEN 
        LAST.DATE = DATE()
        LAST.TIME = 1
    END 
    TODAYOFWEEK = OCONV(DATE(), "DWB")
    LOCATE TODAYOFWEEK IN CHANGE(FULLSYNCDAYS, ',', @AM) SETTING TODAYOFWEEK.PTR ELSE TODAYOFWEEK.PTR = @FALSE
    IF TODAYOFWEEK.PTR THEN 
        IF LAST.TIME < FULLSYNCTIME THEN 
            * Perform a full sync.
            FULL.SYNC = @TRUE
        END ELSE 
            * After set time of day, perform a sync on customers edited today, since the last run.
            FULL.SYNC = @FALSE
        END 
    END ELSE 
        FULL.SYNC = @FALSE
        * NOT a Full Sync Day.  Is it a Partial Sync Day...
        LOCATE TODAYOFWEEK IN CHANGE(PARTSYNCDAYS, ',', @AM) SETTING TODAYOFWEEK.PTR ELSE TODAYOFWEEK.PTR = @FALSE
        IF TODAYOFWEEK.PTR THEN 
            IF LAST.TIME < FULLSYNCTIME THEN 
                * Perform a PartialSync
                PARTIAL.SYNC = @TRUE
            END ELSE 
                * Do NOT perform a partial sync.
                PARTIAL.SYNC = @FALSE
            END 
        END 
    END 
*** Come back here if there is a condition that requires a different sync type.
FORCED.PARTIAL:        
    IF FULL.SYNC THEN 
        RUN.LIMIT   =   FULL.RUN.LIMIT
        RUN.TYPE    =   "Full"
        RUN.MSG     =   "Full sync indicated."
        GOSUB LOG.MSG
    END ELSE 
        IF PARTIAL.SYNC THEN 
            RUN.LIMIT   =   PART.RUN.LIMIT
            RUN.TYPE    =   "Partial"
            RUN.MSG     =   "Partial sync indicated."
            GOSUB LOG.MSG
        END 
    END 

    IF FULL.SYNC OR PARTIAL.SYNC THEN 
        GOSUB FETCH.PORTAL.DATA
    END ELSE 
        RUN.LIMIT = @FALSE
        RUN.TYPE    =   "Quick"
        RUN.MSG     = "Quick Sync is indicated."
        GOSUB LOG.MSG
    END 
    *  Select, process, and update customer records.
    GOSUB PROC.CUSTS

    RUN.MSG    =  "END:   " : OCONV (DATE(), 'D4/'):"  ":OCONV (TIME() , "MTHS")
    GOSUB LOG.MSG
    ELAPSED = ''
    ELAPSED = (DATE() - (BEGIN.DATE)) * 24 * 60 * 60 + INT(TIME() - (BEGIN.TIME) + .5)
    RUN.MSG    =  "Total Run Time : " : ELAPSED
    GOSUB LOG.MSG
    TIME_ID = PGM.NAME:'.TIME'
    READ.LAST.ACTION TIME.REC, TIME_ID, ''
    TIMELOG.ENTRIES = DCOUNT(TIME.REC, @AM)
    
    IF TIMELOG.ENTRIES <> 0 THEN 
        * Newest to oldest by Attribute
        OLDEST.TIMELOG.DATE     =   TIME.REC<TIMELOG.ENTRIES,2>
        CUTOFF.TIMELOG.DATE     =   DATE() - TIMELOGDAYS
        * Cleanup old timelog entries before adding new entry.
        LOOP WHILE (OLDEST.TIMELOG.DATE < CUTOFF.TIMELOG.DATE) AND (TIMELOG.ENTRIES) 
            EMPTY.TIMELOG.DATE:
            TIME.REC    =   DELETE (TIME.REC, TIMELOG.ENTRIES)
            TIMELOG.ENTRIES = DCOUNT(TIME.REC, @AM)
            IF TIMELOG.ENTRIES <> 0 THEN 
                OLDEST.TIMELOG.DATE     =   TIME.REC<TIMELOG.ENTRIES,2>
                IF OLDEST.TIMELOG.DATE = '' THEN 
                    *   We know we have entries due to count.  Null date could be an errant AM.
                    * Try again.
                    GOTO EMPTY.TIMELOG.DATE
                END 
            END 
        REPEAT 
    END 
    
    * Add current timelog entry to top of timelog
    INS (UPCASE(RUN.TYPE):VM:BEGIN.DATE:VM:BEGIN.TIME:VM:ELAPSED) BEFORE TIME.REC<(1)>
    WRITE.LAST.ACTION TIME.REC, TIME_ID

***************************************************************************
* SECTION CLEANUP:    *******************************************************
***************************************************************************
FINISH:

    WRITE.LAST.ACTION OUTPUT.BUFFER, PGM.NAME
    PGM.NAME = PGM.NAME:".":UPCASE(RUN.TYPE)
    WRITE.LAST.ACTION OUTPUT.BUFFER, PGM.NAME
    IF PHANTOM.PROC THEN 
        PHST.MSG = "Build complete."
        CALL.TEMP.2 = USER.ID ; SEND.MESSAGE "Phantom", CALL.TEMP.2, PHST.MSG ; USER.ID = CALL.TEMP.2
        GOSUB LOG.MSG
    END ELSE 
        WRITE.LAST.ACTION OUTPUT.BUFFER, PGM.NAME
        PRINT "Press <Return> to continue."
IN$$1:    INP A
        WINDOW.CLOSE 
    END 
    * Remove currently running flag from control file.
    IF RUN.PID THEN 
        * If run.pid is my PID, then set run.pid false for next ifnot.
        RUN.PID = (RUN.PID # MYPID)
    END 
    IF NOT( RUN.PID ) THEN 
        WRITEV ("") ON CTRLFILE, (RUNCTRLREC), (1)
    END 
    
    *sub::ut.tempfile.delete (temp.name, tempfile)
    CALL.TEMP.OBJECT.HANDLE = TEMPFILEOBJ ; UD.MTH.TEMP.FILE.DELETE.FILE CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE ; TEMPFILEOBJ = CALL.TEMP.OBJECT.HANDLE
    RUN.MSG = "Tempfile deleted."
    GOSUB LOG.MSG
    
    *Clean up old Logs. All programs using UD.AVALOG.
    CUTOFF.LOG.DATE =   BEGIN.DATE - RUNLOGDAYS
    SELECT AVALOGFILE
    LOOP WHILE READNEXT LOG.ID DO 
        OLD.LOG.DATE    =   FIELD (LOG.ID, '~',2)
        IF OLD.LOG.DATE <   CUTOFF.LOG.DATE THEN 
            RUN.MSG = "Old log ":LOG.ID:" deleted."
            GOSUB LOG.MSG
            DELETE AVALOGFILE, LOG.ID
        END 
    REPEAT 
    
    * Write new log entry.
    AVALOGID    =   PGM.NAME:'~':BEGIN.DATE:'~':BEGIN.TIME
    WRITE (OUTPUT.BUFFER) ON AVALOGFILE, (AVALOGID)

    
    GOSUB EXIT.TO.CALLING.PROGRAM

***************************************************************************
* SECTION LOGGING: **********************************************************
***************************************************************************
LOG.MSG: * LOG MESSAGE TO ALL LOCATIONS.

    IF PHST.MSG THEN 
        ADD.OUTPUT.TEXT = (PHST.MSG) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        IF PHANTOM.PROC THEN 
            WRITE PHST.MSG ON PHSTFILE, PID$
        END ELSE 
            PRINT PHST.MSG "L#70"
        END 
        
    END 
    IF RUN.MSG THEN 
        ADD.OUTPUT.TEXT = (RUN.MSG) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        IF NOT (PHANTOM.PROC) THEN 
            PRINT RUN.MSG "L#70"
        END 
    END 
    PHST.MSG = ''
    RUN.MSG = ''

    RETURN
