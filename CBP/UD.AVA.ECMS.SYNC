        END 
        
        RUN.MSG = "Open log file"
        GOSUB LOG.MSG
        CALL.TEMP.OBJECT.HANDLE = MANAGER ; UD.MTH.FILE.MANAGER.OPEN CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, AVALOGFILE, "", "UD.AVALOG" ; MANAGER = CALL.TEMP.OBJECT.HANDLE
        IF (ERROR.MESSAGE <> '') THEN 
            RUN.MSG = "Error opening UD.AVALOG.  ":VM:ERR.MSG
            GOSUB LOG.MSG
            GOTO FINISH
        END 

        IF TROUBLESHOOTING THEN 
            
            CALL.TEMP.OBJECT.HANDLE = MANAGER ; UD.MTH.FILE.MANAGER.OPEN CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, CDFILE, "", "CONV.DATA" ; MANAGER = CALL.TEMP.OBJECT.HANDLE
            IF (ERROR.MESSAGE <> '') THEN 
                RUN.MSG = "Unable to open CONV.DATA for troubleshooting."
                RUN.MSG := VM:"  Disabling troubleshooting."
                GOSUB LOG.MSG
                TROUBLESHOOTING = @FALSE
            END 
