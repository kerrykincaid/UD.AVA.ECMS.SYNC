    CURRENT.METHOD.NAME = "MAIN"
    CURRENT.COMPLETE.NAME = "UD.AVA.LINK.ST.TO.BT"
    CURRENT.SUBROUTINE.NAME = "UD.AVA.LINK.ST.TO.BT"
 
