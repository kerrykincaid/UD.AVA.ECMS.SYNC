***************************************************************************
***************************************************************************
GET.CUS.COUNTRY:
    POSTAL.LEN  = LEN(CUS.POSTAL)
    BEGIN CASE 
        CASE POSTAL.LEN = 7
         POSTAL.LKUP = CUS.POSTAL[1,7]
        CASE POSTAL.LEN = 6 AND CUS.POSTAL[6,1] = "."
         POSTAL.LKUP = CUS.POSTAL[1,6]
        CASE OTHERWISE
         POSTAL.LKUP = CUS.POSTAL[1,5]
    END CASE 

    READV CUS.COUNTRY FROM ZIPFILE,POSTAL.LKUP,5 ELSE CUS.COUNTRY = 'US'
    IF NOT(CUS.COUNTRY) THEN CUS.COUNTRY = 'US'
    
  RETURN
***************************************************************************
***************************************************************************
PROC.CUST:
    CERT.CT = @FALSE
    CERTS = ''

    C.CERT.CNT = DCOUNT(CUS.REC<33>,VM)
    IF C.CERT.CNT = 0 THEN 
        RETURN
    END 
    
    * As we process certs, the customer will be setup first time through.
    CUR.CUST<1>   =  CN
    * Name.
    CUR.CUST<2>   =  CONVERT(CHAR(34),CHAR(39),TRIM(CUS.REC<1>))
    * Line 1
    CUR.CUST<3>   =  CONVERT(CHAR(34),CHAR(39),TRIM(CUS.REC<2,1>))
    * Line 2
    CUR.CUST<4>   =  CONVERT(CHAR(34),CHAR(39),TRIM(CUS.REC<2,2>))
    * Line 3
    CUR.CUST<5>   =  CONVERT(CHAR(34),CHAR(39),TRIM(CUS.REC<2,3>))
    * City
    CUR.CUST<6>   =  TRIM(CUS.REC<3>)
    * Postal
    CUS.POSTAL    =  TRIM(CUS.REC<5>)
    IF CUS.POSTAL = "." THEN 
        ADD.OUTPUT.TEXT = ("Invalid Zip code for customer: ":CN) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RETURN
    END 
    CUR.CUST<7>   =  CUS.POSTAL
    * Country
    GOSUB GET.CUS.COUNTRY
    CUR.CUST<8>   =  CUS.COUNTRY
    * Region (State)
    CUR.CUST<9>   =  TRIM(CUS.REC<4>)
    * IsBill
    CUR.CUST<10>  =  "true"
    * IsShip
    CUR.CUST<11>  =  "false"
    
    IF NOT( (ISNEW) ) THEN 
        GOTO START.JSON
    END 
    
    * get all certificates for customer.
    FOR CERT.NO =   1 TO C.CERT.CNT    
* build certificate portion of new customer data.
        * Skip any deleted or expired certificates.  (Not likely with a new customer, but possible).
        CERT.REGION       =  CUS.REC<33,CERT.NO>
        CERT.NUMBER       =  CUS.REC<34,CERT.NO>
        AVAD_ID =   CN:"~":CERT.REGION:CERT.NUMBER
        IF ISNEW THEN 
            EFF.DATE    =   DEF.EFF.DATE
        END ELSE 
            READV EFF.DATE FROM AVAIFILE, (AVAD_ID), (2) ELSE EFF.DATE = ''
            IF NOT( EFF.DATE ) THEN 
                EFF.DATE    =   DEF.EFF.DATE
            END 
        END 
        
        *exp.date    =   cus.rec<172,cert.no>
        * Expiring all certificates
        EXP.DATE   =  20821
        EXP.DATE  +=  0
        IF NOT( EXP.DATE ) THEN 
            REALDATE DEFAULTEXPIRE, VAR.EXP.DATE
            READV EXP.DATE FROM AVAIFILE, (AVAD_ID), (3) ELSE EXP.DATE = (DEFAULTEXPIRE)
        END 
        IF INDEX(EFF.DATE,"/",1) THEN 
            CEFD        =   ICONV(EFF.DATE,"D4/")
        END ELSE 
            CEFD        =   EFF.DATE
        END 
        IF INDEX(EXP.DATE,"/",1) THEN 
            CEXD        =   ICONV(EXP.DATE,"D4/")
        END ELSE 
            CEXD        =   EXP.DATE
        END 
        
        IF (CEXD <DATE()) OR (CEFD >CEXD) THEN 
            ADD.OUTPUT.TEXT = ("Expired or invalid effective date on cert.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
            CONTINUE
        END 
        
        CERT.CT += 1
        CUR.CERT = ''
        
        CUR.CERT<1>       =  OCONV(CEFD,AVADATEFORMAT):"T00:00:00"
        CUR.CERT<2>       =  OCONV(CEXD,AVADATEFORMAT):"T00:00:00"
        
        * Is cert blank?  Use for future checking.
        CERT.BLANK        =  LEN(TRIM(CERT.NUMBER)) = 0
        UD.AVA.TAXCERT.IMG CN, CERT.NUMBER, CERT.FILENAME
        CUR.CERT<3>       =  CERT.FILENAME
        CERT.FILENAME     =  ""
        CUR.CERT<4>       =  "true"
        CUR.CERT<5>       =  CERT.NUMBER
        EXEMPT.REASON     =  FIELD(CUS.REC<105,CERT.NO>,'=',1)
        *Test for a Type other than G or I, Resale or Inducstrial/mfg
        WRNG.REAS = (EXEMPT.REASON # "G") AND (EXEMPT.REASON # "I")
        *Test for DEN Type.  DEN is allowed here.
        WRNG.REAS = (WRNG.REAS) AND (EXEMPT.REASON # "DEN")
        *Skip if Blank, NOT G, NOT I, NOT DEN.
        SKIP.CERT = (CERT.BLANK OR WRNG.REAS)
        IF CERT.REGION = "CO" AND EXEMPT.REASON = "DEN" THEN 
        *Skip if DEN, but a City of Denver exemption exists.
            SKIP.CERT = SKIP.CERT AND (CUS.REC<175,CERT.NO,1> = "DENVER")
        END 
        IF SKIP.CERT THEN 
            CONTINUE
        END 
        
        BEGIN CASE 
            CASE EXEMPT.REASON    =  "I"
                CERT.REASON = "INDUSTRIAL PROD/MANUFACTURERS"

            CASE EXEMPT.REASON    =  "G"
                CERT.REASON = "RESALE"
        END CASE 
        CUR.CERT<6, 2> =  CERT.REASON
      
        CUR.CERT<7>      =  "TIN"
        CUR.CERT<8>      =  BUS.NUM.TYPE
        
        * exposure zones.
        LOCATE CERT.REGION IN E.REG<1> SETTING POS THEN 
        END 
        EXP.ZONE.NAME        =  E.NAMES<1, POS>
        
        CUR.CERT<9, 2> =  EXP.ZONE.NAME
        
        CERTS< -1>       =  LOWER (CUR.CERT)
    NEXT CERT.NO 
        
*   now we have a customer and all of their certificates.
* create the newrec.j document to create the customer with certs.
    CERT.CT  =  DCOUNT (CERTS, AM)

* no certs, no data to update.
    IF ISNEW AND NOT( (CERT.CT) ) THEN 
        ADD.OUTPUT.TEXT = ("No new certificates to add for customer.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RETURN
    END 
START.JSON:

    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 1
    
    CX.COUNT = DCOUNT (CUR.CUST, AM)

    FOR CX   =  1 TO CX.COUNT 
        MV.CT = DCOUNT (CUR.CUST<CX>, VM)
        IF MV.CT = 2 THEN 
            IF (CUR.CUST<CX, 2>) THEN 
                UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 1
                UT.ADD.JSON NRJ.LEVEL, NEWREC.J, CUST.HEAD<CX, 2>, CUR.CUST<CX, 2>, "", YES
                UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 2
            END 
        END ELSE 
            IF (CUR.CUST<CX>) THEN 
                UT.ADD.JSON NRJ.LEVEL, NEWREC.J, CUST.HEAD<CX>, CUR.CUST<CX>
            END 
        END 
    NEXT CX 
* Only process certificates for a new customer.
    IF NOT( ISNEW ) THEN 
        ADD.OUTPUT.TEXT = ("Not a new customer!") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        GOTO END.JSON
    END 
    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "certificates", "", 3

    FOR CERT = 1 TO CERT.CT 
        CUR.CERT =  RAISE (CERTS<CERT>)
        CC.ID = CN : "~" : CUR.CERT<4>

        UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 1
        CERT.AM.COUNT = DCOUNT (CUR.CERT, AM)
        FOR CERT.AM   =  1 TO CERT.AM.COUNT 
            LAST.AM =   (CERT.AM = CERT.AM.COUNT)
            MV.CT = DCOUNT (CUR.CERT<CERT.AM>, VM)
            IF MV.CT = 2 THEN 
                IF (CUR.CERT<CERT.AM, 2>) THEN 
                    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, CERT.HEAD<CERT.AM, 1>, "", 6
                    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, CERT.HEAD<CERT.AM, 2>, CUR.CERT<CERT.AM, 2>, "", YES
                    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 2, LAST.AM
                END 
            END ELSE 
                IF (CUR.CERT<CERT.AM>) THEN 
                    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, CERT.HEAD<CERT.AM>, CUR.CERT<CERT.AM>, "", LAST.AM
                END 
            END 
        NEXT CERT.AM 
        LAST.CERT = (CERT=CERT.CT)
        UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 2, LAST.CERT
    NEXT CERT 

    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 4, YES
END.JSON:
    UT.ADD.JSON NRJ.LEVEL, NEWREC.J, "", "", 2, YES
*    sub::ut.add.json (nrj.level, newrec.j, "", "", 4, yes)
    IF NEWREC.J THEN 
        MSG.OUT = LOWER(NEWREC.J)
        ADD.OUTPUT.TEXT = (MSG.OUT) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    END ELSE 
        ADD.OUTPUT.TEXT = ("No JSON Created.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    END 

    RETURN
