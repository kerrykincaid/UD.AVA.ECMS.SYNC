***************************************************************************
* SECTION RECORD PROCESSING: ************************************************
***************************************************************************
PROC.ONE:
* setup certificate constants.  keep here with certificate processing in
* the event these become more dynamic values.
    EXEMPT.NUM.TYPE         =  "TIN"

* get customer data.
    CN  =   FIELD(RECORD.ID,'~',1)
    ADD.OUTPUT.TEXT = ("cn: ":CN) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    REC.REGION = FIELD(RECORD.ID,'~',2)[1,2]
    REC.NUMBER = TRIM (FIELD(RECORD.ID,'~',2)[3,99])
    
    READ CUS.REC FROM CUSFILE, (CN) ELSE CUS.REC = ''
    IF CUS.REC = '' THEN 
        ADD.OUTPUT.TEXT = ("Customer record null.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    END 
    IF CUS.REC = '' THEN RETURN
    
    HOME.BR                 =  CUS.REC<53>
    ADD.OUTPUT.TEXT = (("Home Branch:":SPACE(2)):HOME.BR) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    IF (SV.HBR = HOME.BR) AND (SV.COMP.CODE) THEN 
        COMP.CODE = SV.COMP.CODE
    END ELSE 
        LOCATE HOME.BR IN BR.COMP.XREF<1> SETTING POS ELSE 
            BR.COMP.XREF = INSERT (BR.COMP.XREF, 1, POS;HOME.BR)
            UD.AVA.GET.COMPANY.ID HOME.BR, COMP.CODE
            BR.COMP.XREF = INSERT (BR.COMP.XREF, 2, POS;COMP.CODE)
        END 
        COMP.CODE = BR.COMP.XREF<2, POS>
    END 
    SV.HBR                  =  HOME.BR
    SV.COMP.CODE            =  COMP.CODE
    IF NOT (COMP.CODE) THEN 
        COMP.CODE               =  "851125"
    END 
    CERT.TYPE               =  "BLANKET"
    INV.PO.NUM              =  ""

* pricing type to business type mapping.
* first pricing type only.
    PRC.TYPE                =  CUS.REC<35, 1>
    IF NOT (PRC.TYPE) THEN 

* class for fallback.
        PRC.TYPE             =  CUS.REC<13>
    END 
    BUS.TYPE                =  ""
    BUS.TYPE.DESC           =  ""
    LOCATE PRC.TYPE IN XREF.TYPES<1> SETTING TPOS THEN 
        BUS.TYPE             =  XREF.TYPES<2, TPOS>
    END ELSE 
        BUS.TYPE             =  "20"
    END 

    IF BUS.TYPE = "20" THEN 
        IF PRC.TYPE THEN 
            BUS.TYPE.DESC     =  PRC.TYPE
        END ELSE 
            BUS.TYPE.DESC     =  "Unknown"
        END 
    END 

* convert double quotes to apostrophe to avoid data errors.
    CUS.NAME                =  CONVERT (CHAR (34) , CHAR (39) , TRIM (CUS.REC<1>))
    CUS.ADDR1               =  CONVERT (CHAR (34) , CHAR (39) , TRIM (CUS.REC<2, 1>))
    CUS.ADDR2               =  CONVERT (CHAR (34) , CHAR (39) , TRIM (CUS.REC<2, 2>))
    CUS.ADDR3               =  CONVERT (CHAR (34) , CHAR (39) , TRIM (CUS.REC<2, 3>))
    CUS.CITY                =  TRIM (CUS.REC<3>)
    CUS.REGION              =  TRIM (CUS.REC<4>)
    CUS.POSTAL              =  TRIM (CUS.REC<5>)

* bad data in country attribute of customer record.  look up country
* in zip file.  if blank, assume us.
*cus.country             =  cus.rec<6>
*if not(cus.country) then cus.country = "us"
    IF CUS.POSTAL = "." THEN 
        RETURN
    END 
    POSTAL.LEN  = LEN (CUS.POSTAL)

    BEGIN CASE 

        CASE POSTAL.LEN = 7
            POSTAL.LKUP = CUS.POSTAL [1, 7]

        CASE POSTAL.LEN = 6 AND CUS.POSTAL [6, 1] = "."
            POSTAL.LKUP = CUS.POSTAL [1, 6]

        CASE OTHERWISE
            POSTAL.LKUP = CUS.POSTAL [1, 5]

    END CASE 

    READV CUS.COUNTRY FROM ZIPFILE, POSTAL.LKUP, 5 ELSE 
        CUS.COUNTRY = "US"
    END 

    IF NOT (CUS.COUNTRY) THEN 
        CUS.COUNTRY = "US"
    END 

* do not skip non-us customers.  they can have us exemptions!!!
* if cus.country ne 'us' then goto skipit

    C.CERT.REGS =   CUS.REC<33>
    C.CERT.NUMS =   CUS.REC<34>
    C.CERT.RSNS =   CUS.REC<105>
    CERT.NO = @FALSE
    
    C.CERT.REGS.VM.COUNT = DCOUNT((C.CERT.REGS), @VM) ; FOR CUR.REG.PTR = 1 TO (C.CERT.REGS.VM.COUNT) ; CUR.REG = (C.CERT.REGS)<1, (CUR.REG.PTR)> 
        IF (REC.REGION = CUR.REG) THEN 
            IF C.CERT.NUMS<1,CUR.REG.PTR> = REC.NUMBER THEN 
                CERT.NO = CUR.REG.PTR
                EXIT
            END 
        END 
    NEXT CUR.REG.PTR 
    IF NOT( CERT.NO ) THEN 
        ADD.OUTPUT.TEXT = (" No cert number.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    END 
    IF NOT( CERT.NO ) THEN RETURN
    
*cert effective date
    CEFD = ''
    CERT.EFF.DATE = ''

*ecms and avalara cert ids.  unique for each cert.
    AVA.CERT.ID = ''
    AVA.CUST.ID = ''

*cert state.  must be valid or we don't send it.
    CERT.REGION          =  REC.REGION
    CERT.NUMBER          =  REC.NUMBER
    EXEMPT.REASON        =  CUS.REC<105, CERT.NO> [1, 1]

* ids assigned to record before calling subroutine.
    RECID_CERTID = ''
    IF INDEX (RECORD.ID, '~', 2) THEN 
        RECID_CERTID = FIELD (RECORD.ID,'~',3)
        AVAID_ID = FIELD (RECORD.ID, '~',1):"~":FIELD (RECORD.ID,'~',2)
    END ELSE 
        AVAID_ID = RECORD.ID
    END 
    AVA.CERT.ID          =  ECMS.DATA<1>
    IF AVA.CERT.ID # RECID_CERTID THEN 
        ADD.OUTPUT.TEXT = (("ID Mismatch!":SPACE(2):"Record.ID: "):RECID_CERTID:(SPACE(2):"Ava.Cert.ID: "):AVA.CERT.ID) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RECORD.ID = @FALSE
        RETURN TO FINISH
    END 
    

* assume certs are us certs.  customer can be foreign with us exemption.
*ecms.data<3>         =  cus.country
    ECMS.DATA<3>         =  "US"

    ECMS.DATA<4>         =  CERT.REGION

    ECMS.DATA<5>         =  CERT.NUMBER
    ECMS.DATA<6>         =  EXEMPT.NUM.TYPE

* read cert effective date from avalara_ID.
    READV CEFD FROM AVAIDFILE, (AVAID_ID), (2) ELSE CEFD = ''
    IF CEFD = '' THEN 
        REALDATE CEFD, DEFAULTEFFECT
        WRITEV (CEFD) ON AVAIDFILE, (AVAID_ID), (2)
    END 
    * For portal comparison we need a YYYY-MM-DD format.
    *ecms.data<7>         =  oconv (cefd, "D4/")
    ECMS.DATA<7>         =  OCONV (CEFD, "D-YMD[4,2,2]")

*       process cert expiration date.  set for export if blank.
    *cexd                 =  cus.rec<172, cert.no>
    * Expiring all certificates
    EXP.DATE   =  20821
    EXP.DATE  +=  0
    SV.CEXD              =  CEXD
    IF INDEX (CEXD, '/',1) THEN 
        CEXD    =   ICONV (CEXD,'D4/')
    END 
    IF NOT( (CEXD) ) THEN 
        READ CEXD FROM AVAIDFILE, (AVAID_ID) ELSE CEXD = ''
        IF NOT( (CEXD) ) THEN 
            REALDATE NEWEXPIRE, DEFAULTEXPIRE
            IF (NEWEXPIRE - DATE()) < 30 THEN 
                * If within 30 days, extend date by 1 year.
                NEXTEXPIRE = FIELD(DEFAULTEXPIRE,'/',1):'/':FIELD(DEFAULTEXPIRE,'/',2):'/+1'
                REALDATE NEWEXPIRE, NEXTEXPIRE
            END 
            CEXD = NEWEXPIRE
        END 
    END 
    IF NOT( (SV.CEXD) ) THEN 
        READVU CEXD.TEMP.RECORD FROM CUSFILE, (CN), (172) THEN CEXD.TEMP.RECORD<1,CERT.NO> = (CEXD) ; WRITEV CEXD.TEMP.RECORD ON CUSFILE, (CN), (172) ELSE CEXD.TEMP.RECORD = '' ; CEXD.TEMP.RECORD<1,(CERT.NO)> = (CEXD) ; WRITEV CEXD.TEMP.RECORD ON CUSFILE, (CN), (172)
    END 
    * Verify recorded expiration date for portal.  Expiration required.  Recorded to keep one on record. 
    READ UDAVA_CEXD FROM AVAIDFILE, (AVAID_ID) ELSE UDAVA_CEXD = ''
    IF ( NOT( UDAVA_CEXD ) ) OR (UDAVA_CEXD NE CEXD) THEN 
        WRITEV (CEXD) ON AVAIDFILE, (AVAID_ID), (3)
    END 
    
    * For portal comparison we need a YYYY-MM-DD format.
    *ecms.data<8>         =  oconv (cexd, "D4/")
    ECMS.DATA<8>         =  OCONV (CEXD, "D-YMD[4,2,2]")

* not skipping this record.

    CERT.STATUS          =  "Active"
    ECMS.DATA<9>         =  COMP.CODE
    ECMS.DATA<10>        =  CN
    ECMS.DATA<11>        =  CERT.TYPE
    ECMS.DATA<12>        =  INV.PO.NUM
    ECMS.DATA<13>        =  BUS.TYPE
    ECMS.DATA<14>        =  BUS.TYPE.DESC
    ECMS.DATA<15>        =  EXEMPT.REASON
    IF EXEMPT.REASON = "L" THEN 
        EXEMPT.REASON.DESC = CUS.REC<105, CERT.NO> [3, 10]
    END ELSE 
        EXEMPT.REASON.DESC = ""
    END 
    ECMS.DATA<16>        =  EXEMPT.REASON.DESC
    ECMS.DATA<17>        =  CUS.NAME
    ECMS.DATA<18>        =  CUS.ADDR1
    ECMS.DATA<19>        =  CUS.ADDR2
    ECMS.DATA<20>        =  CUS.ADDR3
    ECMS.DATA<21>        =  CUS.CITY
    ECMS.DATA<22>        =  CUS.REGION
    ECMS.DATA<23>        =  CUS.POSTAL
    ECMS.DATA<24>        =  CUS.COUNTRY
    ECMS.DATA<25>        =  CERT.STATUS

    ECMS.DATA<26>        =  "Accepted"
    
    TMP.BUFFER.TXT = ''
    ECMS.DATA.AM.COUNT = DCOUNT((ECMS.DATA), @AM) ; FOR EDATA.CTR = 1 TO (ECMS.DATA.AM.COUNT) 
        IF TMP.BUFFER.TXT = '' THEN TMP.BUFFER.TXT = (EDATA.CTR:(":":SPACE(2)):ECMS.DATA<EDATA.CTR>) ELSE TMP.BUFFER.TXT := @VM : (EDATA.CTR:(":":SPACE(2)):ECMS.DATA<EDATA.CTR>)
    NEXT EDATA.CTR 
    IF TMP.BUFFER.TXT <> '' THEN 
        ADD.OUTPUT.TEXT = (TMP.BUFFER.TXT) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    END 
    
    RETURN

