    CN = ''
    ECMS.DATA = ''
    SV.COMP.CODE = @FALSE
    SV.HBR = @FALSE
    BR.COMP.XREF = ''
    
* valid states.
    READ VST FROM CTRLFILE, "VALID.US.STATES" ELSE 
        VST = ""
    END 
* pricing type to business type mapping variables.
    READ XREF.TYPES FROM CTRLFILE, "UD.AVA.XREF.TYPES" ELSE 
        XREF.TYPES = ''
    END 
    BUS.TYPE = ''
    PRC.TYPE = ''
    
* variables for api calls and caching.
    GL.BR = ''
    COMPID = @FALSE

    ADD.OUTPUT.TEXT = ("Initialized") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    
