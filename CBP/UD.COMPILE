**************************************************************************
    TAG = "PropertyWrapping."

* wrapping property calls
    ALLOW.WRAPPED.PROPERTY.CALLS = UD.GET.SETTING(TAG:"AllowWrappedPropertyCalls", 0, 1)

    GET.WRAPPED.PROPERTY.PREFIX = UD.GET.SETTING(TAG:"GetWrappedPropertyPrefix", "GET.PROPERTY.")
    PUT.WRAPPED.PROPERTY.PREFIX = UD.GET.SETTING(TAG:"PutWrappedPropertyPrefix", "PUT.PROPERTY.")

    GET.WRAPPED.DIM.PREFIX = UD.GET.SETTING(TAG:"GetWrappedDimPrefix", "GET.DIM.")
    PUT.WRAPPED.DIM.PREFIX = UD.GET.SETTING(TAG:"PutWrappedDimPrefix", "PUT.DIM.")

