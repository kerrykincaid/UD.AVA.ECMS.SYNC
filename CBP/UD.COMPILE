**************************************************************************
    TAG = "UnaryFunctions."

* enable unary functions?  ie, convert "trim(var)" to "var = trim(var)"
    ENABLE.UNARY.FUNCTIONS = UD.GET.SETTING(TAG:"EnableUnaryFunctions")

    RETURN

