GET.ALIASCHECKING.SETTINGS: **********************************************
* load alias checking settings                                           *
**************************************************************************
    TAG = "AliasChecking."

* list of eclipse cc routines to use to build the list of eclipse common
* variables and constants
    ECLIPSE.CC.LIST = UD.GET.SETTING(TAG:"EclipseCCList")
    ECLIPSE.CC.LIST = CHANGE(ECLIPSE.CC.LIST, ",", @AM)
    ECLIPSE.CC.COUNT = DCOUNT(ECLIPSE.CC.LIST, @AM)

    ECLIPSE.CC.FILE = UD.GET.SETTING(TAG:"EclipseCCFile")

* these flags control checking parameters in method calls and property
* assignment calls (get and put) to see if they're property variables
* or not.  since property variables are common it can be a good idea to
* not use them as parameters in method and property assignment calls as
* aliasing can be a problem
    CHECK.METHOD.PARAMETER.PROPERTY = UD.GET.SETTING(TAG:"CheckMethodParameterProperty", 1, 1)
    CHECK.ASSIGNMENT.PROPERTY = UD.GET.SETTING(TAG:"CheckAssignmentProperty", 1, 1)

* check byref variables in method calls against eclipse's common variables
* to make sure that no eclipse variables are used in byref calls
    CHECK.ECLIPSE.COMMON.VARIABLES = UD.GET.SETTING(TAG:"CheckEclipseCommonVariables", 1, 1)

* if we find a property parameter do we show a warning?
    SHOW.PROPERTY.PARAMETERS = UD.GET.SETTING(TAG:"ShowPropertyParameters", 1, 1)

* if we find a property in a called parameter's parameter list do we fix
* the call?
    FIX.PROPERTY.PARAMETERS = UD.GET.SETTING(TAG:"FixPropertyParameters", 1, 1)
    PARAMETER.TEMP.VARIABLE = UD.GET.SETTING(TAG:"ParameterTempVariable", "CALL.TEMP."

    RETURN

GET.INSTANCECHECKING.SETTINGS: *******************************************
* load instance checking settings                                        *
**************************************************************************
    TAG = "InstanceChecking."

* handling situations where an object is calling another instance of the
* same object.  when the other instance returns the wrong object instance
* will be loaded into the current property common variables.  the correct
* current instance needs to be loaded.
    ALWAYS.LOAD.INSTANCE = UD.GET.SETTING(TAG:"AlwaysLoadInstance", 0, 1)
    ALWAYS.CHECK.INSTANCE = UD.GET.SETTING(TAG:"AlwaysCheckInstance", 0, 1)

    NON.LOCAL.ALWAYS.LOADS.INSTANCE = UD.GET.SETTING(TAG:"NonLocalAlwaysLoadsInstance", 0, 1)
    NON.LOCAL.ALWAYS.CHECKS.INSTANCE = UD.GET.SETTING(TAG:"NonLocalAlwaysChecksInstance", 1, 1)

    SAME.OBJECT.CALL.LOADS.INSTANCE = UD.GET.SETTING(TAG:"SameObjectCallLoadsInstance", 0, 1)
    SAME.OBJECT.CALL.CHECKS.INSTANCE = UD.GET.SETTING(TAG:"SameObjectCallChecksInstance", 1, 1)

    SUB.CALL.LOADS.INSTANCE = UD.GET.SETTING(TAG:"SubCallLoadsInstance", 0, 1)
    SUB.CALL.CHECKS.INSTANCE = UD.GET.SETTING(TAG:"SubCallChecksInstance", 1, 1)

    RETURN

GET.SHORTGOSUB.SETTINGS: *************************************************
* load short gosub settings                                              *
**************************************************************************
    TAG = "ShortGosubs."

* enable short gosubs?  ie, if there's a single word on a program line
* and it's a statement label convert it to a gosub?
