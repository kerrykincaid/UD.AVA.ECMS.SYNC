PRINT.STARTUP.MESSAGE: ***************************************************
* if we have startup message print it out.  for some compiler modes      *
* we'll skip it even if we have the startup message                      *
**************************************************************************
    BEGIN CASE
        CASE LIST.METHODS
            SPLASH = @FALSE
        CASE SHORTCUT.LIST
            SPLASH = @FALSE
        CASE OBJECT.COUNT = 0
            SPLASH = @FALSE
        CASE STARTUP.MESSAGE = ""
            SPLASH = @FALSE
        CASE LIST.OBJECTS.ONLY
            SPLASH = @FALSE
        CASE 1
            SPLASH = @TRUE
    END CASE

    IF SPLASH THEN

* print the startup splash with the version and last change date
        PRINT
        PRINT STARTUP.MESSAGE:

        IF PRECOMPILER.VERSION <> "" THEN

            BEGIN CASE
                CASE DOT.NET.ENABLED AND OBJ.NET.EXISTS AND JAVA.ENABLED AND OBJ.JAVA.EXISTS
                    PRINT " with DotNet+Java":
                CASE DOT.NET.ENABLED AND OBJ.NET.EXISTS
                    PRINT " with DotNet":
                CASE JAVA.ENABLED AND OBJ.JAVA.EXISTS
                    PRINT " with Java":
            END CASE

            PRINT ", Version ":PRECOMPILER.VERSION:

            IF PRECOMPILER.VERSION.DATE <> "" THEN
                PRINT ", ":OCONV(PRECOMPILER.VERSION.DATE, "D4/")
            END

        END

* display if we're running in a special mode
        BEGIN CASE
            CASE BRIEF
                NULL
            CASE REPAIR.MODE AND CHECK.MODE
                PRINT
                PRINT "Compiling in Repair/Check Mode"
            CASE REPAIR.MODE
                PRINT
                PRINT "Compiling in Repair Mode"
            CASE CHECK.MODE
                PRINT
                PRINT "Compiling in Check Mode"
        END CASE
            
        IF NOT(BRIEF) THEN
            PRINT
        END

* if we have any startup notes print them out as well
        IF STARTUP.NOTES <> "" THEN

            CALL !FOLD (USE.STARTUP.NOTES, STARTUP.NOTES, 79)
            NOTES.COUNT = DCOUNT(USE.STARTUP.NOTES, @AM)
            FOR NOTES.LOOP = 1 TO NOTES.COUNT
                PRINT USE.STARTUP.NOTES<NOTES.LOOP>
            NEXT NOTES

            IF NOT(BRIEF) THEN
                PRINT
            END

        END

    END

    RETURN

NO.OBJECTS.SPECIFIED: ****************************************************
* do whatever processing is needed, based on command line paramters,     *
* when there are no object specified in the command line                 *
**************************************************************************
    BEGIN CASE

* if "list objects" was required without specifying a program list
* out the common and constant variable tables from eclipse
        CASE LIST.OBJECTS.ONLY
            GOSUB LIST.ECLIPSE.COMMON.VARIABLES

* display the compiler overview
        CASE DISPLAY.OVERVIEW
            GOSUB PRINT.OVERVIEW

* print syntax help
        CASE 1
            GOSUB PRINT.HELP

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** initialization / setting / loading                                   **
**************************************************************************
**************************************************************************

LOAD.COMPILE.SETTINGS: ***************************************************
* fetch program settings from control record                             *
**************************************************************************

* load up our settings record
    SETTING.NAME = "COMPILE.SETUP"
    GOSUB LOAD.SETTING.RECORD

* target file, where converted methods and subroutines should be stored
    TAG = "ProgramFiles."

    TARGET.FILENAME = UD.GET.SETTING(TAG:"TargetFile", "CBP")

* always ask for compilation settings?  we'll load these here because
* they're only valid for the first compile.  after the first compile they'll
* be set false
    TAG = "Compile."

    ASK.FOR.OBJ.OPTIONS = UD.GET.SETTING(TAG:"AskForOBJCompileOptions", 0, 1)
    ASK.FOR.OBP.OPTIONS = UD.GET.SETTING(TAG:"AskForOBPCompileOptions", 0, 1)
    ASK.FOR.OPTIONS = UD.GET.SETTING(TAG:"AskForCompileOptions", 0, 1)

    OPEN TARGET.FILENAME TO TARGETFILE ELSE
        PRINT
        PRINT "Can't open ":TARGET.FILENAME:"!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    GOSUB RELOAD.SETTINGS

    RETURN

LOAD.SHORTCUT.SETTINGS: **************************************************
* load shortcuts, macros and debugging settings.  load.compile.settings  *
* should have already been called                                        *
**************************************************************************
    SHORTCUT.LOAD.START.DATE = DATE()
    SHORTCUT.LOAD.START.TIME = TIME()

* get debugging settings
    GOSUB GET.DEBUG.SETTINGS

* if shortcuts have already been loaded we may have temporary macros in the
* macro table from the previous compile.  remove them.  otherwise build the
* shortcut and macro tables from the setting records
    IF SHORTCUTS.LOADED AND NOT(FORCE.SHORTCUT.RELOAD) AND NOT(ALWAYS.RELOAD.SHORTCUTS) THEN

        GOSUB REMOVE.TEMPORARY.MACROS

    END ELSE

* build a table of programming shortcuts
        SHORTCUTS.IN.ORDER = @FALSE
        GOSUB GET.SHORTCUT.SETTINGS

* build a table of macros
        GOSUB GET.MACRO.SETTINGS

        SHORTCUTS.LOADED = @TRUE
        SHORTCUTS.LOADED.FOR.LISTING = @FALSE

    END

    SHORTCUT.LOAD.END.DATE = DATE()
    SHORTCUT.LOAD.END.TIME = TIME()
    SHORTCUT.LOAD.ELAPSED.TIME += TIME.ELAPSED (SHORTCUT.LOAD.START.DATE, SHORTCUT.LOAD.START.TIME)

    RETURN

RELOAD.IF.CHANGED: *******************************************************
* if a setting was changed by a routine's code reload the original       *
* setting values from the control record                                 *
**************************************************************************
    IF SETTINGS.MODIFIED THEN
        GOSUB GET.DEBUG.SETTINGS
        GOSUB RELOAD.SETTINGS
        GOSUB RELOAD.COMMAND.LINE.OPTIONS
    END

    RETURN

RELOAD.SETTINGS: *********************************************************
* reload all compilation settings                                        *
**************************************************************************

* load up our settings record
    SETTING.NAME = "COMPILE.SETUP"
    GOSUB LOAD.SETTING.RECORD

* if any settings are changed in the code this flag will be set
    SETTINGS.MODIFIED = @FALSE

* precompile startup messages
    STARTUP.MESSAGE = UD.GET.SETTING("StartupMessage", "")
    STARTUP.NOTES = UD.GET.SETTING("StartupNotes", "")

* version and version date
    PRECOMPILER.VERSION = UD.GET.SETTING("Version")
    PRECOMPILER.VERSION.DATE = UD.GET.SETTING("VersionDate")
    PRECOMPILER.VERSION.DATE = ICONV(PRECOMPILER.VERSION.DATE, "D")

    GOSUB GET.INSTANCE.SETTINGS
    GOSUB GET.SOURCECODE.SETTINGS
    GOSUB GET.PROPERTY.SETTINGS
    GOSUB GET.INHERITING.SETTINGS
    GOSUB GET.SPACESCANNING.SETTINGS
    GOSUB GET.PARAMETERPASSING.SETTINGS
    GOSUB GET.CHILD.OBJECT.SETTINGS
    GOSUB GET.SUBROUTINE.SETTINGS
    GOSUB GET.WRAPPER.SETTINGS
    GOSUB GET.ERRORTHROW.SETTINGS
    GOSUB GET.REFERENCE.SETTINGS
    GOSUB GET.KEYWORD.SETTINGS
    GOSUB GET.DAISYCHAIN.SETTINGS
    GOSUB GET.COMPILE.SETTINGS
    GOSUB GET.SINGLE.OBJECT.SETTINGS
    GOSUB GET.RESIDENT.OBJECT.SETTINGS
    GOSUB GET.SAVINGCODE.SETTINGS
    GOSUB GET.DYNAMICARRAY.SETTINGS
    GOSUB GET.PROGRAMFILE.SETTINGS
    GOSUB GET.INLINED.SETTINGS
    GOSUB GET.UNIVERSE.SETTINGS
    GOSUB GET.LINEWRAPPING.SETTINGS
    GOSUB GET.PROPERTYWRAPPING.SETTINGS
    GOSUB GET.ALIASCHECKING.SETTINGS
    GOSUB GET.INSTANCECHECKING.SETTINGS
    GOSUB GET.SHORTGOSUB.SETTINGS
    GOSUB GET.UNARY.SETTINGS
    GOSUB GET.ASSOCIATED.SETTINGS
    GOSUB GET.DEBUGGING.SETTINGS
    GOSUB GET.INSTALLER.SETTINGS
    GOSUB GET.REGISTRY.SETTINGS
    GOSUB GET.FORKING.SETTINGS
    GOSUB GET.COMPILE.TABLE.SETTINGS
    GOSUB GET.LISTING.SETTINGS
    GOSUB GET.ECLIPSE.SETTINGS
    GOSUB GET.INSTANCE.ERROR.SETTINGS
    GOSUB GET.EDITOR.SETTINGS
    GOSUB GET.NOTEPAD.SETTINGS
    GOSUB GET.PERMISSIONS.SETTINGS
    GOSUB GET.CODE.SPLITTING.SETTINGS
    GOSUB GET.DOT.NET.SETTINGS
    GOSUB GET.JAVA.SETTINGS
    GOSUB GET.FUNCTION.SETTINGS

* build a table of default methods and the parameter list for those methods.
* in the default parameter.list table add a list of parameter names delimited
* by commas.  if no parameters are separated by a semi-colon it's assumed that
* all parameters are returned values and they will be passed by reference.  if
* there is a semi-colon parameters before the semi-colon are assumed to be
* returned values (passed by reference) and parameters after the semi-colon are
* assumed to be passed values (passed by value).  if all parameters are passed by
* value start the list off with a semi-colon.  if all parameters are returned
* no semi-colon is needed
    DEFAULT.METHOD.LIST = ""
    DEFAULT.PARAMETER.LIST = ""

    DEFAULT.METHOD.LIST<1> = RESET.KEYWORD
    DEFAULT.PARAMETER.LIST<1> = ""

    DEFAULT.METHOD.LIST<2> = NEW.KEYWORD
    DEFAULT.PARAMETER.LIST<2> = ""

    DEFAULT.METHOD.LIST<3> = NEW.SHORT.KEYWORD
    DEFAULT.PARAMETER.LIST<3> = ""

    DEFAULT.METHOD.LIST<4> = DESTROY.KEYWORD
    DEFAULT.PARAMETER.LIST<4> = ""

    DEFAULT.METHOD.LIST<5> = GET.KEYWORD
    DEFAULT.PARAMETER.LIST<5> = ""

    DEFAULT.METHOD.LIST<6> = PUT.KEYWORD
    DEFAULT.PARAMETER.LIST<6> = ""

    DEFAULT.METHOD.LIST<7> = COPY.OBJECT.KEYWORD
    DEFAULT.PARAMETER.LIST<7> = ";TARGET.OBJECT.HANDLE"

    DEFAULT.METHOD.LIST<8> = GET.PROPERTY.LIST.KEYWORD
    DEFAULT.PARAMETER.LIST<8> = "PARAMETER.LIST,PARAMETER.COUNT;INCLUDE.LOCAL,INCLUDE.HANDLES,INCLUDE.DIM"

    DEFAULT.METHOD.LIST<9> = GET.METHOD.LIST.KEYWORD
    DEFAULT.PARAMETER.LIST<9> = "OBJECT.METHOD.LIST,OBJECT.METHOD.COUNT;INCLUDE.LOCAL"

    DEFAULT.METHOD.LIST<10> = GET.PROPERTY.BY.NAME.KEYWORD
    DEFAULT.PARAMETER.LIST<10> = "PROPERTY.VALUE;PROPERTY.NAME"

    DEFAULT.METHOD.LIST<11> = PUT.PROPERTY.BY.NAME.KEYWORD
    DEFAULT.PARAMETER.LIST<11> = ";PROPERTY.NAME,PROPERTY.VALUE"

    IF USE.EXTERNAL.REDIM THEN
        DEFAULT.METHOD.LIST<12> = REDIM.KEYWORD
        DEFAULT.PARAMETER.LIST<12> = ""
    END

    DEFAULT.METHOD.COUNT = DCOUNT(DEFAULT.METHOD.LIST,@AM)

    RETURN


**************************************************************************
**************************************************************************
** initialization / setting / loading / setting groups                  **
**************************************************************************
**************************************************************************

GET.INSTANCE.SETTINGS: ***************************************************
* load instance settings                                                 *
**************************************************************************
    TAG = "Instance."

* default maximum instances value
    DEFAULT.MAX.INSTANCES = UD.GET.SETTING(TAG:"MaxInstances", 10)
    MAX.INSTANCES = DEFAULT.MAX.INSTANCES

* absolute maximum instances.  if an instance count hits this a message
* will be printed and the process will logoff / terminate.  this is to
* prevent runaway processes (ie, an infinite loop) from creating more
* and more instances until uniVerse crashes
    ABSOLUTE.MAX.INSTANCES = UD.GET.SETTING(TAG:"AbsoluteMaxInstances", 10000)

* allow redimensioning of multi-instance common variables?  this
* can avoid the "Out of Instances" error
    DEFAULT.ALLOW.EXPANDING.INSTANCES = UD.GET.SETTING(TAG:"AllowExpandingInstances", 0, 1)
    ALLOW.EXPANDING.INSTANCES = DEFAULT.ALLOW.EXPANDING.INSTANCES
    DEFAULT.ALLOW.REDUCING.INSTANCES = UD.GET.SETTING(TAG:"AllowReducingInstances", 0, 1)
    ALLOW.REDUCING.INSTANCES = DEFAULT.ALLOW.REDUCING.INSTANCES

    RETURN

GET.SOURCECODE.SETTINGS: *************************************************
* load sourcecode settings                                               *
**************************************************************************
    TAG = "SourceCode."

* upcase program code when converting from OBJ / OBP to CBP?
    UPCASE.CODE = UD.GET.SETTING(TAG:"UpCaseCode", 0, 1)

* shortcuts and macros can generate code with two dynamic array references
* in a row, ie, "my.variable<2><1,vm.ptr>".  should the compiler simplify
* these references?
    SIMPLIFY.MULTIPLE.DYNAMICS = UD.GET.SETTING(TAG:"SimplifyMultipleDynamics", 0, 1)

* when compiling multiple methods for the same object the object usage
* table build for the object's child objects can be buffered and reused
* to speed compile time
    BUFFER.OBJECT.USAGE.TABLE = UD.GET.SETTING(TAG:"BufferObjectUsageTable", 0, 1)

* when scanning an object's source code to determine the object's usage,
* should the compiler always rescan the source code, even if it had
* already scanned the source code before?
    ALWAYS.SCAN.OBJECT.SOURCE = UD.GET.SETTING(TAG:"AlwaysScanObjectSource", 1, 1)

* when cleaning up program lines should the "clean line index" be used?
* this can speed up compilation if there are many similar code lines in
* the same program
    USE.CLEAN.LINE.INDEX.OBJECTS = UD.GET.SETTING(TAG:"UseCleanLineIndexObjects", 0, 1)
    USE.CLEAN.LINE.INDEX.SUBROUTINES = UD.GET.SETTING(TAG:"UseCleanLineIndexSubroutines", 0, 1)

* should object build a method table for the object registry?
    BUILD.METHOD.TABLES = UD.GET.SETTING(TAG:"BuildMethodTables", 1, 1)
    BUILD.METHOD.TABLE.METHOD = UD.GET.SETTING(TAG:"MethodTableBuildMethod", "Slow")

* validate the object handle for calls other than the "new" method
    VALIDATE.OBJECT.HANDLE = UD.GET.SETTING("SourceCode.ValidateObjectHandle", 0, 1)

    RETURN

GET.PROPERTY.SETTINGS: ***************************************************
* load property settings                                                 *
**************************************************************************
    TAG = "Properties."

* should the get and put routines allow changing constants?
    ALLOW.GET.CONSTANTS = UD.GET.SETTING(TAG:"AllowGetConstants", 0, 1)
    ALLOW.PUT.CONSTANTS = UD.GET.SETTING(TAG:"AllowPutConstants", 0, 1)
    ALLOW.GET.CHILD.HANDLES = UD.GET.SETTING(TAG:"AllowGetChildHandles", 0, 1)

* put code in the get.property and put.property routines for multivalues?
* allows getting and pushing multivalues but makes the routines kind of
* large
    MULTIVALUE.PROPERTIES = UD.GET.SETTING(TAG:"MultivalueProperties", 0, 1)

* when building common lines defining properties, how many properties should
* be put on a program line?
    PROPS.PER.LINE = UD.GET.SETTING(TAG:"PropertiesPerLine", 4)

* for properties that aren't dimensioned we can use "real" variables that
* get their assignment from the dimensioned instance variables or we can
* equate the property to the dimensioned instance.  equating would be
* faster and use less code but it's a new option and we don't want to use
* it in production code until it's been wrung out
    USE.EQUATED.PROPERTIES = UD.GET.SETTING(TAG:"UseEquatedProperties", 0, 1)
    USE.EQUATED.CHILD.OBJECTS = UD.GET.SETTING(TAG:"UseEquatedChildObjects", 0, 1)

* the code to redim the object arrays as the instance count grows / reduces
* can be done in a local subroutine (fast, but programs are larger) or in
* an external subroutine (not so fast but programs are smaller)
    USE.EXTERNAL.REDIM = UD.GET.SETTING(TAG:"UseExternalRedim", 0, 1)
    REDIM.KEYWORD = UD.GET.SETTING(TAG:"RedimKeyword", "REDIM")

* if inline "ALL" methods for an object should we also inline the
* redim subroutine if it's created as an external subroutine?
    INLINE.REDIM.WITH.ALL = UD.GET.SETTING(TAG:"InlineRedimWithAll", 0, 1)

    RETURN

GET.INHERITING.SETTINGS: *************************************************
* load inherited settings                                                *
**************************************************************************
    TAG = "Inheriting."

* allow inheriting methods from child objects?
    ALLOW.INHERITS = UD.GET.SETTING(TAG:"AllowInherits", 0, 1)

    RETURN

GET.SPACESCANNING.SETTINGS: **********************************************
* load space scanning settings                                           *
**************************************************************************
    TAG = "SpaceScanning."

* Eclipse's precompiler does a trim() on program lines before it
* converts to if there are multiple spaces inside of quotes Eclipse's
* precompiler removes all but one of these spaces.  very annoying.  if this
* setting is set the object compiler scans all the parameters and, if there
* is more than one space in a row it replaces the duplicate spaces with a
* space() function
    SCAN.PARAMETER.SPACES = UD.GET.SETTING(TAG:"ScanParameterSpaces", 1, 1)

* scan debug space conversions?
    SCAN.DEBUG.SPACES = UD.GET.SETTING(TAG:"ScanDebugSpaces", 1, 1)

* and for macros?
    SCAN.MACRO.SPACES = UD.GET.SETTING(TAG:"ScanMacroSpaces", 1, 1)

* and shortcuts?
    SCAN.SHORTCUT.SPACES = UD.GET.SETTING(TAG:"ScanShortcutSpaces", 1, 1)

* or, we can just scan every literal text expression in the program and
* replace literal spaces with a space(n) expression.  this would also
* take care of "standard" Eclipse subroutine calls with literal spaces
* in them
    SCAN.ALL.LITERAL.TEXT = UD.GET.SETTING(TAG:"ScanAllLiteralText", 1, 1)

    RETURN

GET.PARAMETERPASSING.SETTINGS: *******************************************
* load parameter passing settings                                        *
**************************************************************************
    TAG = "ParameterPassing."

* nulling value for optional parameters.  if an optional parameter is
* passed with this value it will be changed to an empty string.  since an
* empty string indicates an optional parameter should use its default
* value we have no way to send an empty string for an optional parameter.
* sending this value gets us the empty string
    OPTIONAL.NULL.VALUE = UD.GET.SETTING(TAG:"OptionalNullValue", "@NULL")

* enable byval parameter passing?
    ENABLE.BYVAL = UD.GET.SETTING(TAG:"EnableByVal", 1, 1)
    ONLY.BYVAL.NON.EXPRESSIONS = UD.GET.SETTING(TAG:"OnlyByValNonExpressions", 1, 1)

* enable parameter passing by name
    ENABLE.BY.NAME = UD.GET.SETTING(TAG:"EnableByName", 1, 1)

* pad undefined method parameters to ""?  if this is set then
* enable.by.name must also be set or individual parameters will not
* be processed
    PAD.NULL.PARAMETERS = UD.GET.SETTING(TAG:"PadNullParameters", 1, 1)
    IF PAD.NULL.PARAMETERS THEN
        ENABLE.BY.NAME = @TRUE
    END

* when method calls are converted to external subroutine calls, should
* they be left in a format compatible with Eclipse's precompiler or
* should they be converted to CALL statements?
    CONVERT.METHODS.TO.CALLS = UD.GET.SETTING(TAG:"ConvertMethodsToCalls", 0, 1)
    IF CONVERT.METHODS.TO.CALLS THEN
        ENABLE.BY.NAME = @TRUE
        PAD.NULL.PARAMETERS = @TRUE
    END

* in case eclipse's precompiler can only handle a limited number of parameters
* when it converts subroutine calls.  if a call results in more parameters
* than this an error will be generated
    MAX.CALL.PARAMETERS = UD.GET.SETTING(TAG:"MaxCallParameters", 14)

* when a method has output parameters (a semi-colon was used in the
* parameter list to define input vs output) and the expression
* calling the method uses output parameters (parameters to the left
* of the equals sign) should the output parameters be padded with
* null parameters so that the output parameters of the expression
* matches the output parameters of the method?
    PAD.OUTPUT.PARAMETERS = UD.GET.SETTING(TAG:"PadOutputParameters", 0, 1)

* allow all parameters, including returned parameters, on the right side
* of the equals sign?  this allows for Eclipse-style method and subroutine
* calls where both returned parameters and passed parameters are on the
* right side of the equals sign.  the downside to this is if you're calling
* a method or subroutine and you don't want to capture the returned
* variables you still need at least one variable to the left of the equals
* sign or the compiler interprets the call as an Eclipse-style call and
* the parameters are converted to an Eclipse-style call in the CBP 
* incorrectly.  this can be tricky to find as everything compiles
* properly.  WarnAllParametersOnRight is an intermediate step.  it shows
* a warning when all parameters are on the right (an Eclipse-style call)
* but still compiles it as an Eclipse-style call
    WARN.ALL.PARAMETERS.ON.RIGHT = UD.GET.SETTING(TAG:"WarnAllParametersOnRight", 0, 1)
    ALLOW.ALL.PARAMETERS.ON.RIGHT = UD.GET.SETTING(TAG:"AllowAllParametersOnRight", 1, 1)

* check parameter lists to make sure the semi-colon is used properly
* to separate input from output parameters?  IE, throw an error if there
* is more than one semi-colon in a parameter list?
    CHECK.IO.PARAMETERS = UD.GET.SETTING(TAG:"CheckIOParameters", 1, 1)
    CHECK.SUB.IO.PARAMETERS = UD.GET.SETTING(TAG:"CheckSubIOParameters", 1, 1)

* is it mandatory to have a semi-colon to check input from output
* parameters?
    MANDATORY.IO.PARAMETERS = UD.GET.SETTING(TAG:"MandatoryIOParameters", 0, 1)
    MANDATORY.SUB.IO.PARAMETERS = UD.GET.SETTING(TAG:"MandatorySubIOParameters", 0, 1)
    MANDATORY.WRAPPER.IO.PARAMETERS = UD.GET.SETTING(TAG:"MandatoryWrapperIOParameters", 0, 1)

* allow partial name matches for named parameters in a method call's
* parameter list?
    ALLOW.PARTIAL.NAMED = UD.GET.SETTING(TAG:"AllowPartialNamed", 0, 1)
    ALLOW.PARTIAL.NAMED.FIELDS = UD.GET.SETTING(TAG:"AllowPartialNamedFields", 0, 1)

* are initializing parameters allowed in "new" method calls?  are they allowed
* in child object definitions?
    ALLOW.NEW.PARAMETERS = UD.GET.SETTING(TAG:"AllowNewParameters", 0, 1)
    ALLOW.NEW.CHILD.PARAMETERS = UD.GET.SETTING(TAG:"AllowNewChildParameters", 0, 1)

    OPTIONAL.KEYWORD = UD.GET.SETTING(TAG:"OptionalKeyword", "OPTIONAL")
    BYVAL.KEYWORD = UD.GET.SETTING(TAG:"ByValKeyword", "BYVAL")
    BYVAL.SPECIAL.KEYWORD = UD.GET.SETTING(TAG:"ByValSpecialKeyword", "HANDLE")
    BYREF.KEYWORD = UD.GET.SETTING(TAG:"ByRefKeyword", "BYREF")

    RETURN

GET.CHILD.OBJECT.SETTINGS: ***********************************************
* load child object settings                                             *
**************************************************************************
    TAG = "ChildObjects."

* when passing child objects back from a "new" method the original method
* was to pass back a separate variable for each child object.  this generated
* very long parameter lists.  if dimensioned child handles are used each
* child object is passed back as an element in a dimensioned array to make
* things a bit tidier
    USE.DIMENSIONED.CHILD.HANDLES = UD.GET.SETTING(TAG:"UseDimensionedChildHandles", 0, 1)
    CHILD.HANDLE.ARRAY.SIZE = UD.GET.SETTING(TAG:"ChildHandleArraySize", 100)
    CHILD.HANDLE.ARRAY.NAME = UD.GET.SETTING(TAG:"ChildHandleArrayName", "CHILD.HANDLE.ARRAY")

* maximum number of child objects.  this is used to keep the parameter count
* in the "NEW" statements the same even if new objects are added.  set to 0
* to not pad at all
    MAX.CHILD.OBJECTS = UD.GET.SETTING(TAG:"MaxChildObjects", 10)

* maximum depth for child handles in compiled code.  child objects can
* be nested deeper than this but they can only be referenced this
* deeply
    MAX.CHILD.DEPTH = UD.GET.SETTING(TAG:"MaxChildDepth", 5)

* child depth for child object builds
    BUILD.CHILD.DEPTH = UD.GET.SETTING(TAG:"BuildChildDepth", 1)

* objects can delete their own child objects or, if AutoDestroyObjects is
* set, they can leave them for the auto destroy to do it
    OBJECT.DELETES.CHILD = UD.GET.SETTING(TAG:"ObjectDeletesChild", 1, 1)

* when calling "New" methods (from objects or object-enabled suborutines)
* should code to included to check the child object list to make sure a new
* child object wasn't added or removed from the "New" object after the
* calling routine was compiled.  if this happens it's possible that
* the wrong child object handles may be returned to the calling program
* without this check
    CHECK.MISMATCHED.CHILD.OBJECTS = UD.GET.SETTING(TAG:"CheckMismatchedChildObjects", 1, 1)

* when the "new" method of an object creates child objects it's possible
* (thought not preferred) that the child object's "new" method may use
* another instance of the original object.  this is a Bad Thing and can
* confuse things as the wrong instance's property values in the common
* variables will be loaded after the child object is created

* the "new" method can check for the object instance changing and reload
* the correct values if the child object did this.  however, a better
* solution is to not do this in the first place

* this check may be done in two places, before assigning the object's
* handle or after.  assigning the object's handle after creating the child
* object is preferred.  this work UNLESS there's an object using instance
* matching.  as of this writing the "setting" object is using instance
* matching so if you want to check the object after assignment you'll have
* turn turn instance matching off in "setting"

* doing the check before works most of the time.  it's not as good a solution
* as checking after but it doesn't interfere with instance matching
    CHECK.OBJECT.HANDLE.BEFORE.CHILD = UD.GET.SETTING(TAG:"CheckObjectHandleBeforeChild", 0, 1)
    CHECK.OBJECT.HANDLE.AFTER.CHILD = UD.GET.SETTING(TAG:"CheckObjectHandleAfterChild", 0, 1)

    INTIME.CHILD.OBJECTS.LOCAL = UD.GET.SETTING(TAG:"IntimeChildObjectsLocal", 1, 1)

    RETURN

GET.SUBROUTINE.SETTINGS: *************************************************
* load subroutine settings                                               *
**************************************************************************
    TAG = "Subroutines."

* subroutine name for loading "special" variables for subroutines
    SUBROUTINE.SPECIAL.ROUTINE.NAME = UD.GET.SETTING(TAG:"SubroutineSpecialRoutineName", "LOAD.OBJECT.SUBROUTINE.VARIABLES")

* add a final "end" to converted subroutines and methods?
    ADD.FINAL.END = UD.GET.SETTING(TAG:"AddFinalEnd", 0, 1)

* subroutine prefix to use when building subroutines to create intime
* objects
    INTIME.OBJECT.SUBROUTINE.PREFIX = UD.GET.SETTING(TAG:"IntimeObjectSubroutinePrefix", "BUILD.INTIME.OBJECT.")

    RETURN

GET.WRAPPER.SETTINGS: ****************************************************    
* load wrapper settings                                                  *
**************************************************************************
    TAG = "Wrappers."

* create wrappers for "wrapper" methods?
    ENABLE.WRAPPER.SUBROUTINES = UD.GET.SETTING(TAG:"EnableWrapperSubroutines", 1, 1)

* should subroutines from the "common method" be added to wrappers?
    ADD.COMMON.ROUTINES.TO.WRAPPERS = UD.GET.SETTING(TAG:"AddCommonRoutinesToWrappers", 1, 1)

    RETURN

GET.ERRORTHROW.SETTINGS: *************************************************
* load error throw settings                                              *
**************************************************************************
    TAG = "ErrorThrows."

* gosub names for utility subroutines
    EXIT.OUT.GOSUB.NAME = UD.GET.SETTING(TAG:"ExitOutGosubName", "EXIT.TO.CALLING.PROGRAM")
    EXIT.ON.ERROR.GOSUB.NAME = UD.GET.SETTING(TAG:"ExitOnErrorGosubName", "EXIT.IF.ERROR.MESSAGE")
    LABEL.GOSUB.NAME = UD.GET.SETTING(TAG:"LabelGosubName", "LABEL.GOSUB.ROUTINE")

* if we're checking mismatched child objects this is the subroutine name
* used in the "new" method
    CHECK.MISMATCHED.CHILD.NAME = UD.GET.SETTING(TAG:"CheckMismatchedChildGosubName", "CHECK.MISMATCHED.CHILD.OBJECTS")

* variable name for the error message variable
    ERROR.MESSAGE.VARIABLE = UD.GET.SETTING(TAG:"ErrorMessageVariable", "ERROR.MESSAGE")

* automatically add a "catch error" subroutine to every method subroutine
* and object-enabled subroutine?  this subroutine will display the error in
* a window, destroy objects created by the program and then exit
    ADD.CATCH.ERROR.ROUTINE = UD.GET.SETTING(TAG:"AddCatchErrorRoutine", 0, 1)
    CATCH.ERROR.GOSUB.NAME = UD.GET.SETTING(TAG:"CatchErrorGosubName", "CATCH.OBJECT.ERROR")

    AUTO.DESTROY.OBJECTS = UD.GET.SETTING(TAG:"AutoDestroyObjects", 0, 1)
    AUTO.DESTROY.METHOD.OBJECTS = UD.GET.SETTING(TAG:"AutoDestroyMethodObjects", 0, 1)
    AUTO.DESTROY.IF.NO.OBJECTS = UD.GET.SETTING(TAG:"AutoDestroyIfNoObjects", 0, 1)

* enable error message throwing / catching?
    ENABLE.ERROR.THROWS = UD.GET.SETTING(TAG:"EnableThrownErrors", 0, 1)
    MASTER.ENABLE.ERROR.THROWS = ENABLE.ERROR.THROWS

* if the error throw variable isn't found in the code should we turn the error
* throws off to save some code?
    DISABLE.THROWN.IF.UNUSED = UD.GET.SETTING(TAG:"DisableThrownIfUnused", 1, 1)

    THROWN.KEYWORDS = UD.GET.SETTING(TAG:"ThrownKeywords", "ERROR.THROW")
    THROWN.KEYWORDS = CHANGE(THROWN.KEYWORDS, ",", @AM)
    THROWN.KEYWORD.COUNT = DCOUNT(THROWN.KEYWORDS, @AM)

* variable to set for error throws?
    ERROR.THROW.VARIABLE = UD.GET.SETTING(TAG:"ErrorThrowVariable", "ERROR.THROW")

* update the ud.object.log file with object errors?  don't turn this on
* if ud.object.log hasn't been created or it will be a bit slow
    UPDATE.OBJECT.ERROR.LOG = UD.GET.SETTING(TAG:"UpdateObjectErrorLog", 0, 1)

    ERROR.LOG.ROUTINE = UD.GET.SETTING(TAG:"ErrorLogRoutine", "UD.LOG.OBJECT.ERROR")
    ERROR.LOG.GOSUB.NAME = UD.GET.SETTING(TAG:"ErrorLogGosubName", "OBJECT.ERROR.LOGGING")

* if ud.show.object.error is called to show an error (usually because
* throw.to.exit was set) should additional options ("more detail", etc)
* be made available to the user?
    SHOW.OBJECT.ERROR.DETAILS = UD.GET.SETTING(TAG:"ShowObjectErrorDetails", 0, 1)

    RETURN

GET.REFERENCE.SETTINGS: **************************************************
* load reference settings                                                *
**************************************************************************
    TAG = "References."

* delimiters for forming object method / property / whatever calls
*     delimiter used between object handle and method in code
    METHOD.DELIMITER = UD.GET.SETTING(TAG:"MethodDelimiter", "::")

*     delimiter used between object handle and property in code
    PROPERTY.DELIMITER = UD.GET.SETTING(TAG:"PropertyDelimiter", "::")

*     delimiter used between object handle and constant in code
    CONSTANT.DELIMITER = UD.GET.SETTING(TAG:"ConstantDelimiter", "::")

*     delimiter between object handles when indicating a child
*     object
    CHILD.DELIMITER = UD.GET.SETTING(TAG:"ChildDelimiter", "::")

    METHOD.DEL.LENGTH = LEN(METHOD.DELIMITER)
    PROPERTY.DEL.LENGTH = LEN(PROPERTY.DELIMITER)
    CONSTANT.DEL.LENGTH = LEN(CONSTANT.DELIMITER)
    CHILD.DEL.LENGTH = LEN(CHILD.DELIMITER)

* keyword to use for replacing "WITH" references
    REPLACE.WITH.KEYWORD = UD.GET.SETTING(TAG:"WithReplaceKeyword", "::")

* delimiter to use between object type and method/property/constant when
* building the eclipse subroutine name
    ECLIPSE.DELIMITER = UD.GET.SETTING(TAG:"EclipseDelimiter", ".")

* in a method subroutine call should the object handle be passed byval or
* byref?  byval is safer as it protects the object handle.  byref allows
* the object handle to be changed by the called subroutine

* normally this should be set to "Yes".  however, if instance matching
* is going to be used this value must be set to "No" for local handles so
* that the object handle is passed byref and can be changed
    PASS.OBJECT.HANDLES.BYVAL = UD.GET.SETTING(TAG:"PassObjectHandlesByVal", 1, 1)
    PASS.SUB.HANDLES.BYVAL = UD.GET.SETTING(TAG:"PassSubHandlesByVal", 1, 1)
    PASS.LOCAL.HANDLES.BYVAL = UD.GET.SETTING(TAG:"PassLocalHandlesByVal", 1, 1)
    PASS.REGISTRY.HANDLES.BYVAL = UD.GET.SETTING(TAG:"PassRegistryHandlesByVal", 1, 1)
    PASS.DESTROY.HANDLES.BYVAL = UD.GET.SETTING(TAG:"PassDestroyHandlesByVal", 1, 1)

* process $define, $undefine, $ifdef, $ifndef, $else, $endif in the object
* compiler or leave them for the regular compiler?
    PROCESS.DEFINES = UD.GET.SETTING(TAG:"ProcessDefines", 1, 1)

* variable prefix to use for temporary variable when exploding complex
* object statements
    TEMP.VARIABLE.PREFIX = UD.GET.SETTING(TAG:"TemporaryVariablePrefix", "TEMP.VAR.")
    TEMP.MACRO.VARIABLE.PREFIX = UD.GET.SETTING(TAG:"TemporaryMacroVariablePrefix", "MACRO.TEMP.VAR.")

* variable prefix to use for building a variable name for the handle
* for a child oject
    CHILD.VARIABLE.PREFIX = UD.GET.SETTING(TAG:"ChildVariablePrefix", "CHILD.")

* suffix to use for the array tables that will hold property values for
* all object instances
    INSTANCE.SUFFIX = UD.GET.SETTING(TAG:"InstancePropertySuffix", ".PROP.TABLE")

* suffix to use for the named common area holding multiple instance property
* values.  the named common space name will be ObjectName.CommonSuffix
    INSTANCE.COMMON.SUFFIX = UD.GET.SETTING(TAG:"InstanceCommonSuffix", ".PROP")

* suffix to use for the named common area holding current property values
    CURRENT.COMMON.SUFFIX = UD.GET.SETTING(TAG:"CurrentCommonSuffix", ".PROP")

* named common area name for object debugging common block
    OBJECT.COMMON.NAME = UD.GET.SETTING(TAG:"ObjectCommonName", "OBJECT.DEBUG.COMMON")

* if references cannot be resolved, usually because we have a program
* line more complicated than what eclipse can handle (ie, more than one
* reference on a line or a function on a line with other code) should
* we try to convert the code?  this allows more complicated
* statements that have object references in them but can add additional
* lines to the final CBP program
    FIX.UNRESOLVED.REFERENCES = UD.GET.SETTING(TAG:"FixUnresolvedReferences", 1, 1)

* should we validate the objects of "with" statements"?
    VALIDATE.WITH.OBJECTS = UD.GET.SETTING(TAG:"ValidateWithObjects", 1, 1)

* allow creating new objects in a "with" statement?
    ALLOW.OBJECT.CREATION.IN.WITH = UD.GET.SETTING(TAG:"AllowObjectCreationInWith", 1)

* if we add program lines to fix unresolved issues should we keep them
* on the same program line so we don't add new lines to the program and
* change the program line numbers?  or, do we add them as new program
* lines even though the program line numbers will change?
    ALL.ON.ONE.LINE = UD.GET.SETTING(TAG:"AllOnOneLine", 0, 1)

* the named common block for storing properties can be at the top of the
* program, where most programmers put them, or in a subroutine later in
* the program, which is easier to read
    PROPERTY.COMMON.CODE.AT.END = UD.GET.SETTING(TAG:"PropertyCommonCodeAtEnd", 0, 1)
    PROPERTY.COMMON.CODE.SUBROUTINE.NAME = UD.GET.SETTING(TAG:"PropertyCommonCodeSubroutine", "SET.PROPERTY.COMMON")

    RETURN

GET.KEYWORD.SETTINGS: ****************************************************
* load keyword settings                                                  *
**************************************************************************
    TAG = "Keywords."

* default keywords and settings
    PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"PropertyKeyword", "PROPERTY")
    LOCAL.PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"LocalPropertyKeyword", "LOCAL.PROPERTY")
    FILE.PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"FilePropertyKeyword", "FILE.PROPERTY")
    LIST.PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"ListPropertyKeyword", "LIST.PROPERTY")
    LOCAL.FILE.PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"LocalFilePropertyKeyword", "FILE.PROPERTY")
    LOCAL.LIST.PROPERTY.KEYWORD = UD.GET.SETTING(TAG:"LocalListPropertyKeyword", "LIST.PROPERTY")    

    STATIC.KEYWORD = UD.GET.SETTING(TAG:"StaticKeyword", "STATIC")
    LOCAL.STATIC.KEYWORD = UD.GET.SETTING(TAG:"LocalStaticKeyword", "LOCAL.STATIC")
    FILE.STATIC.KEYWORD = UD.GET.SETTING(TAG:"FileStaticKeyword", "FILE.STATIC")
    LIST.STATIC.KEYWORD = UD.GET.SETTING(TAG:"ListStaticKeyword", "LIST.STATIC")
    LOCAL.FILE.STATIC.KEYWORD = UD.GET.SETTING(TAG:"LocalFileStaticKeyword", "FILE.STATIC")
    LOCAL.LIST.STATIC.KEYWORD = UD.GET.SETTING(TAG:"LocalListStaticKeyword", "LIST.STATIC")

    CONSTANT.KEYWORD = UD.GET.SETTING(TAG:"ConstantKeyword", "CONSTANT")
    LOCAL.CONSTANT.KEYWORD = UD.GET.SETTING(TAG:"LocalConstantKeyword", "LOCAL.CONSTANT")

    CHILD.KEYWORD = UD.GET.SETTING(TAG:"ChildKeyword", "CHILD")
    LOCAL.CHILD.KEYWORD = UD.GET.SETTING(TAG:"LocalChildKeyword", "LOCAL.CHILD")
    INTIME.CHILD.KEYWORD = UD.GET.SETTING(TAG:"IntimeChildKeyword", "INTIME.CHILD")
    LOCAL.INTIME.CHILD.KEYWORD = UD.GET.SETTING(TAG:"LocalIntimeChildKeyword", "LOCAL.INTIME.CHILD")

    SECTION.KEYWORD = UD.GET.SETTING(TAG:"SectionKeyword", "SECTION")

    METHOD.KEYWORD = UD.GET.SETTING(TAG:"MethodKeyword", "METHOD")
    LOCAL.METHOD.KEYWORD = UD.GET.SETTING(TAG:"LocalMethodKeyword", "LOCAL.METHOD")
    INLINE.METHOD.KEYWORD = UD.GET.SETTING(TAG:"InlineMethodKeyword", "INLINE.METHOD")
    LOCAL.INLINE.METHOD.KEYWORD = UD.GET.SETTING(TAG:"LocalInlineMethodKeyword", "LOCAL.INLINE.METHOD")

    WRAPPER.METHOD.KEYWORD = UD.GET.SETTING(TAG:"WrapperMethodKeyword", "WRAPPER")
    TCL.WRAPPER.METHOD.KEYWORD = UD.GET.SETTING(TAG:"TclWrapperMethodKeyword", "TCL.WRAPPER")
    DRIVER.WRAPPER.METHOD.KEYWORD = UD.GET.SETTING(TAG:"DriverWrapperMethodKeyword", "DRIVER.WRAPPER")
    PHANTOM.WRAPPER.METHOD.KEYWORD = UD.GET.SETTING(TAG:"PhantomWrapperMethodKeyword", "PHANTOM.WRAPPER")
    ROUTINE.WRAPPER.METHOD.KEYWORD  = UD.GET.SETTING(TAG:"RoutineWrapperMethodKeyword", "ROUTINE")

    INHERIT.FROM.KEYWORD = UD.GET.SETTING(TAG:"InheritFromKeyword", "INHERIT.FROM")
    INHERIT.KEYWORD = UD.GET.SETTING(TAG:"InheritKeyword", "INHERITED")

    WITH.KEYWORD = UD.GET.SETTING(TAG:"WithKeyword", "WITH")
    END.WITH.KEYWORD = UD.GET.SETTING(TAG:"EndWithKeyword", "END.WITH")
    DEFAULT.WITH.OBJECT = UD.GET.SETTING(TAG:"DefaultWithObject", "")

* structure depth keyword.  this keyword will be replaced with the
* current "structure depth", a number from 0+ indiciating how many
* structures deep the current code is.  if/then is a structure,
* begincase/endcase is a structure, for/loop is a structure, etc.
* this allows creating variable names in shortcuts and macros with
* a name that's unique to the current structure
    CONVERT.STRUCTURE.KEYWORDS = UD.GET.SETTING(TAG:"ConvertStructureKeywords", 1, 1)
    STRUCTURE.DEPTH.KEYWORD = UD.GET.SETTING(TAG:"StructureDepthKeyword", "$STRUCT.DEPTH$")
    STRUCTURE.NEXT.DEPTH.KEYWORD = UD.GET.SETTING(TAG:"StructureNextDepthKeyword", "$STRUCT.NEXT.DEPTH$")
    STRUCTURE.PREV.DEPTH.KEYWORD = UD.GET.SETTING(TAG:"StructurePrevDepthKeyword", "$STRUCT.PREV.DEPTH$")

* structure start / else / end keywords.  these keywords indicate the
* beginning of the struture, "else" if one exists, and structure end
    STRUCTURE.START.KEYWORD = UD.GET.SETTING(TAG:"StructureStartKeyword", "$STRUCT.START$")
    STRUCTURE.ALT.START.KEYWORD = UD.GET.SETTING(TAG:"StructureAltStartKeyword", "$STRUCT.ALT.START$")
    STRUCTURE.ELSE.KEYWORD = UD.GET.SETTING(TAG:"StructureElseKeyword", "$STRUCT.ELSE$")
    STRUCTURE.END.KEYWORD = UD.GET.SETTING(TAG:"StructureEndKeyword", "$STRUCT.END$")

* keyword for "local" methods call, calls from inside an object to another
* method in the same object
    LOCAL.KEYWORD = UD.GET.SETTING(TAG:"LocalKeyword", "LOCAL")
    LOCAL.OBJECT.HANDLE = UD.GET.SETTING(TAG:"LocalObjectHandle", "LOCAL")
    LOCAL.OBJECT.VARIABLE = UD.GET.SETTING(TAG:"LocalObjectVariable", "LOCAL.OBJECT.HANDLE")

* keyword for the pseudo-object for subroutine calls.  this allows subroutine
* calls to be treated like object calls, with byvals and optional
* parameters, etc
    SUBROUTINE.CALL.KEYWORD = UD.GET.SETTING(TAG:"SubroutineCallKeyword", "SUB")

* keyword for exit method
    EXIT.METHOD.KEYWORD = UD.GET.SETTING(TAG:"ExitMethodKeyword", "RETURN")

* object / object-enabled subroutine object keyword
    OPTION.KEYWORD = UD.GET.SETTING(TAG:"CompileOptionKeyword", "$OBJ.OPTION")

* inline routines keyword
    INLINE.KEYWORD = UD.GET.SETTING(TAG:"InlineKeyword", "$INLINE")

    INLINE.ALL.OBJECTS.KEYWORD = UD.GET.SETTING(TAG:"InlineAllObjectsKeyword", "ALL")
    INLINE.ALL.METHODS.KEYWORD = UD.GET.SETTING(TAG:"InlineAllMethodsKeyword", "ALL")

    INLINE.PROPERTIES.KEYWORD = UD.GET.SETTING(TAG:"InlinePropertiesKeyword", "PROPERTIES")
    INLINE.EVERYTHING.KEYWORD = UD.GET.SETTING(TAG:"InlineEverythingKeyword", "EVERYTHING")

* "object" line option keywords
    INSTANCE.KEYWORD = UD.GET.SETTING(TAG:"InstancesKeyword", "INSTANCES")
    ALL.SUBROUTINES.KEYWORD = UD.GET.SETTING(TAG:"AllSubroutinesKeyword", "ALL.SUBS")
    FIXED.DIM.KEYWORD = UD.GET.SETTING(TAG:"FixedDimKeyword", "FIXED")
    EXPAND.DIM.KEYWORD = UD.GET.SETTING(TAG:"ExpandDimKeyword", "EXPAND")
    RESIDENT.KEYWORD = UD.GET.SETTING(TAG:"ResidentKeyword", "RESIDENT")
    OBJECT.TYPE.KEYWORD = UD.GET.SETTING(TAG:"ObjectTypeKeyword", "TYPE")
    STATUS.KEYWORD = UD.GET.SETTING(TAG:"StatusKeyword", "STATUS")
    ASSIGN.KEYWORD = UD.GET.SETTING(TAG:"AssignKeyword", "ASSIGN")
    NO.OBJECT.DEBUG.KEYWORD = UD.GET.SETTING(TAG:"NoObjectDebugKeyword", "NO.DEBUG")
    EXTERNAL.OBJECT.KEYWORD = UD.GET.SETTING(TAG:"ExternalObjectKeyword", "EXTERNAL")

* object creation / destruction keywords
    NEW.KEYWORD = UD.GET.SETTING(TAG:"NewKeyword", "NEW")
    NEW.SHORT.KEYWORD = UD.GET.SETTING(TAG:"NewShortKeyword", "NEW.SHORT")
    NEW.MULTI.THREAD.KEYWORD = UD.GET.SETTING(TAG:"NewMultiThreadKeyword", "NEW.THREAD")
    NEW.RESIDENT.KEYWORD = UD.GET.SETTING(TAG:"NewResidentKeyword", "NEW.RESIDENT")
    NEW.NOW.KEYWORD = UD.GET.SETTING(TAG:"NewNowKeyword", "NEW.NOW")

    OLD.KEYWORD = UD.GET.SETTING(TAG:"OldKeyword", "OLD")
    OLD.MULTI.THREAD.KEYWORD = UD.GET.SETTING(TAG:"OldMultiThreadKeyword", "OLD.THREAD")

    DESTROY.KEYWORD = UD.GET.SETTING(TAG:"DestroyKeyword", "DESTROY")
    RESET.KEYWORD = UD.GET.SETTING(TAG:"ResetKeyword", "RESET")

* keywords to get and put properties
    GET.KEYWORD = UD.GET.SETTING(TAG:"GetPropertyKeyword", "GET.PROPERTY")
    PUT.KEYWORD = UD.GET.SETTING(TAG:"PutPropertyKeyword", "PUT.PROPERTY")

* keyword for the "copy object" routine
    COPY.OBJECT.KEYWORD = UD.GET.SETTING(TAG:"CopyPropertyKeyword", "COPY.OBJECT")

* keywords for getting property and method lists
    GET.PROPERTY.LIST.KEYWORD = UD.GET.SETTING(TAG:"GetPropertyListKeyword", "GET.PROPERTY.NAME.LIST")
    GET.METHOD.LIST.KEYWORD = UD.GET.SETTING(TAG:"GetMethodListKeyword", "GET.METHOD.NAME.LIST")

* keywords for getting and setting properties by name
    GET.PROPERTY.BY.NAME.KEYWORD = UD.GET.SETTING(TAG:"GetPropertyByNameKeyword", "GET.PROPERTY.BY.NAME")
    PUT.PROPERTY.BY.NAME.KEYWORD = UD.GET.SETTING(TAG:"PutPropertyByNameKeyword", "PUT.PROPERTY.BY.NAME")

* common "method" name
    COMMON.ROUTINE.METHOD = UD.GET.SETTING(TAG:"CommonMethodName", "COMMON")

* what statement should be used to return from a wrapper?
    WRAPPER.RETURN.KEYWORD = UD.GET.SETTING(TAG:"WrapperReturnKeyword", "RETURN")

    RETURN

GET.DAISYCHAIN.SETTINGS: *************************************************
* load daisy chain settings                                              *
**************************************************************************
    TAG = "DaisyChainCalls."

* object name for pseudo-object calls from individual variables
    ENABLE.STRING.OBJECT.CALLS = UD.GET.SETTING(TAG:"EnableStringObjectCalls", 0, 1)
    AUTO.ADD.STRING.OBJECT = UD.GET.SETTING(TAG:"AutoAddStringObject", 0, 1)
    STRING.OBJECT.HANDLE = UD.GET.SETTING(TAG:"StringObjectHandle", "STRING.OBJECT")
    STRING.OBJECT.NAME = UD.GET.SETTING(TAG:"StringObjectName", "STRING")

    RETURN

GET.COMPILE.SETTINGS: ****************************************************
* load compile settings                                                  *
**************************************************************************
    TAG = "Compile."

* should we always recompile all methods or only the ones that have
* changed?
    ALWAYS.RECOMPILE.METHODS = UD.GET.SETTING(TAG:"AlwaysRecompileMethods", 0, 1)

* compile in brief mode as default?
    BRIEF = UD.GET.SETTING(TAG:"CompileInBriefMode", 0, 1)

* should we list objects created by a program / object when compiling?
    LIST.OBJECTS.WITH.COMPILE = UD.GET.SETTING(TAG:"ListObjectsWithCompile", 1, 1)

* should we show objects being saved?
    SHOW.SAVING.ITEMS = UD.GET.SETTING(TAG:"ShowSavingItems", 1, 1)

* show line counts when saving items?
    SHOW.LINE.COUNTS = UD.GET.SETTING(TAG:"ShowLineCounts", 1, 1)

* show subroutines that weren't called?
    SHOW.UNCALLED.SUBROUTINES = UD.GET.SETTING(TAG:"ShowUncalledSubroutines", 1, 1)

* show "cataloged" messages when compiling?
    SHOW.CATALOGED.MESSAGE = UD.GET.SETTING(TAG:"ShowCatalogedMessage", 1, 1)

* if structures are open at the end of the program show a warning?
    SHOW.OPEN.STRUCTURE.ERRORS = UD.GET.SETTING(TAG:"ShowOpenStructureErrors", 0, 1)

* when creating cbp subroutines the compile normally puts a space after the
* comma in the parameter list.  this can cause problems with some Eclipse / 
* Solar routines that look at the subroutine statement before calling.  this
* setting allows suppressing those spaces
    NO.SPACES.IN.SUB.DEFINITION = UD.GET.SETTING(TAG:"NoSpacesInSubDefinition", 0, 1)

* if there are compile errors should they always be sent to a view-only
* editor window or should the editor window only be used if the "WIN"
* option is specified in the command line?
    ALWAYS.WIN.COMPILE.ERRORS = UD.GET.SETTING(TAG:"AlwaysWinCompileErrors", 0, 1)

* always display time required for compilation?
    DISPLAY.COMPILE.TIMES = UD.GET.SETTING(TAG:"DisplayCompileTimes", 0, 1)

    ADD.SOURCE.COMMENTS = UD.GET.SETTING(TAG:"AddSourceComments", 0, 1)
    VIEW.CONVERTED.CODE = UD.GET.SETTING(TAG:"ViewConvertedCode", 0, 1)

* automatically compile?
    DO.COMPILE = UD.GET.SETTING(TAG:"DoCompile", 1, 1)

* compile CBP programs?
    COMPILE.CBP.PROGRAMS = UD.GET.SETTING(TAG:"CompileCBPPrograms", 1, 1)

* compile core programs?
    COMPILE.CORE.PROGRAMS = UD.GET.SETTING(TAG:"CompileCorePrograms", 1, 1)

* always reload shortcuts from the setting record?
    ALWAYS.RELOAD.SHORTCUTS = UD.GET.SETTING(TAG:"ReloadShortcuts", 0, 1)

* when displaying object methods / subroutines being compiled should the cbp
* program name also be displayed?
    DISPLAY.COMPILE.CBP.NAME = UD.GET.SETTING(TAG:"DisplayCompileCBPName", 1, 1)

* if a write error is encountered should the compiler exit or keep going?
    EXIT.ON.WRITE.ERROR = UD.GET.SETTING(TAG:"ExitOnWriteError", 1, 1)

* some warnings may be returned from the eclipse precompiler that should
* just be ignored--not checked and not displayed.  separate multiple ignored
* warnings with a bar ("|")
    IGNORED.COMPILE.WARNINGS = UD.GET.SETTING (TAG:"IgnoredCompileWarnings")
    IGNORED.COMPILE.WARNINGS = CHANGE (IGNORED.COMPILE.WARNINGS, "|", @AM)

    RETURN

GET.SINGLE.OBJECT.SETTINGS: **********************************************
* load "single" instance object settings                                 *
**************************************************************************
    TAG = "SingleObjects."

* compile single-instance objects as if they were resident
    COMPILE.SINGLE.AS.RESIDENT = UD.GET.SETTING(TAG:"CompileSingleAsResident", 0, 1)

* for single instance objects we keep a counter that we increment with
* each create and decrement with each destroy.  this ensures that the
* object isn't deleted until the last object that "created" it calls for
* a "destroy."  this is the name of the common variables used as a counter
    SINGLE.INSTANCE.COUNT.VARIABLE = UD.GET.SETTING(TAG:"SingleInstanceCreateVariable", "SINGLE.INSTANCE.CREATE.COUNT")
    SINGLE.INSTANCE.LIST.VARIABLE = UD.GET.SETTING(TAG:"SingleInstanceCreateList", "SINGLE.INSTANCE.CREATE.LIST")

    RETURN

GET.RESIDENT.OBJECT.SETTINGS: ********************************************
* load resident object settings                                          *
**************************************************************************
    TAG = "ResidentObjects."

* for resident object we keep a common flag for whether the object has
* been initialized or not.  for resident objects we want to initialize it
* once when it's first created but not when later programs "create" the
* resident instance again
    RESIDENT.INITIALIZE.VARIABLE = UD.GET.SETTING(TAG:"ResidentInitializeVariable", "RESIDENT.OBJECT.INITIALIZED")

    RETURN

GET.SAVINGCODE.SETTINGS: *************************************************
* load code saving settings                                              *
**************************************************************************
    TAG = "SavingCode."

* save cbp routines built from objects and object-enabled subroutines?
    SAVE.CBPS = UD.GET.SETTING(TAG:"SaveCBPs", 1, 1)

* break up all compound lines into single lines?  this can be a bit slow
* but it can be helpful for debugging
    REFORMAT.COMPOUND.LINES = UD.GET.SETTING(TAG:"ReformatCompoundLines", 0, 1)

* remove uncalled subroutines?
    REMOVE.UNCALLED.SUBROUTINES = UD.GET.SETTING(TAG:"RemoveUncalledSubroutines", 0, 1)
    REMOVE.UNCALLED.IN.WRAPPERS = UD.GET.SETTING(TAG:"RemoveUncalledInWrappers", 0, 1)

    UNCALLED.EXCEPTION.LIST = UD.GET.SETTING(TAG:"UncalledExceptionList")
    UNCALLED.EXCEPTION.LIST = CHANGE(UNCALLED.EXCEPTION.LIST, ",", @AM)

    RETURN

GET.DYNAMICARRAY.SETTINGS: ***********************************************
* load dynamic array settings                                            *
**************************************************************************
    TAG = "DynamicArrays."

    CONVERT.DYNAMIC.INITIALIZING = UD.GET.SETTING(TAG:"ConvertDynamicInitializing", 1)

* c-sytle braces settings
    TAG = "Braces."

    ENABLE.BRACES = UD.GET.SETTING(TAG:"Enabled", 1, 1)
    OPEN.BRACE = UD.GET.SETTING(TAG:"Open", "{")
    ELSE.BRACE = UD.GET.SETTING(TAG:"Else", "}{")
    CLOSE.BRACE = UD.GET.SETTING(TAG:"Close", "}")
    NULL.BRACE = UD.GET.SETTING(TAG:"Null", "{}")

    RETURN

GET.PROGRAMFILE.SETTINGS: ************************************************
* load program file settings                                             *
**************************************************************************
    TAG = "ProgramFiles."

* partial match program files.  if a program can't be found in any of
* the normal program files these files will be searched for partial
* matches
    PARTIAL.MATCH.FILE.LIST = UD.GET.SETTING(TAG:"PartialMatchFiles")
    PARTIAL.MATCH.FILE.LIST = CHANGE(PARTIAL.MATCH.FILE.LIST, ",", @AM)
    PARTIAL.MATCH.FILE.COUNT = DCOUNT(PARTIAL.MATCH.FILE.LIST, @AM)

    RETURN

GET.INLINED.SETTINGS: ****************************************************
* load inlined code settings                                             *
**************************************************************************
    TAG = "InlinedMethods."

* for inline code which command do we use?  $include or $insert?
    INLINE.INCLUDE.KEYWORD = UD.GET.SETTING(TAG:"InlineIncludeKeyword", "$INCLUDE")

* filename to use when including inlined code
    INLINE.CODE.FILE = UD.GET.SETTING(TAG:"InlineCodeFile", "OC")

* when inlining a routine should we used "END"s to end the previous code?
* all converted routines are written without an "END" statement as the last
* line.  according to the basic documentation everything should work fine
* when inlined routines are included in the main program without an "END"
* to end the previous code but some routines appear to be crashing universe
* when they're included yet they run fine when not included.  setting this
* true will put an "END" before each included subroutine to "end" the
* previous code. there still will NOT be an "END" at the end of the program,
* like before.  will this help?  still waiting to see
    END.BEFORE.INLINE.CODE = UD.GET.SETTING(TAG:"EndBeforeInlineCode", 0, 1)

* if the "ALL" object and / or method is used should we inline all method
* subroutines or only those actually called by the program?
    ONLY.INLINE.IF.CALLED = UD.GET.SETTING(TAG:"OnlyInlineIfCalled", 0, 1)

* allow inline in object methods?  subroutines?
    ALLOW.INLINE.IN.SUBROUTINES = UD.GET.SETTING(TAG:"AllowInlineInSubroutines", 1, 1)
    ALLOW.INLINE.IN.METHODS = UD.GET.SETTING(TAG:"AllowInlineInMethods", 0, 1)
    ALLOW.NESTED.INLINE.ROUTINES = UD.GET.SETTING(TAG:"AllowNestedInlineRoutines", 0, 1)
    ALLOW.INLINE.OWN.METHODS = UD.GET.SETTING(TAG:"AllowInlineOwnMethods", 0, 1)
    ALLOW.INLINE.DAISY.CHAINED = UD.GET.SETTING(TAG:"AllowInlineDaisyChained", 0, 1)

* inline methods by adding an "include" statement or by merging code?
    INLINE.BY.MERGING.CODE = UD.GET.SETTING(TAG:"InlineByMergingCode", 1, 0)

    RETURN

GET.UNIVERSE.SETTINGS: ***************************************************
* load universe settings                                                 *
**************************************************************************
    TAG = "Universe."

* default pick flavor for objects.  if AllowExpandingInstances or
* AllowReducingInstances is true this should be either "DEFAULT" (for the
* "IDEAL uniVerse" flavor), "INFORMATION", or "PIOPEN".  These are the only
* flavors that allow arrays to be redimensioned at runtime.  Set this to
* "NONE" to use the default pick flavor for the account
    OBJECT.PICK.FLAVOR = UD.GET.SETTING(TAG:"ObjectPickFlavor", "DEFAULT")
    OBJECT.PICK.OPTIONS = UD.GET.SETTING(TAG:"ObjectPickOptions", "NONE")

* default pick flavor for object-enabled subroutines.  "NONE" will use
* the accounts default pick flavor
    OBSUB.PICK.FLAVOR = UD.GET.SETTING(TAG:"ObsubPickFlavor", "NONE")
    OBSUB.PICK.OPTIONS = UD.GET.SETTING(TAG:"ObsubPickOptions", "NONE")

* the compiler will build a lot of variables using names and things all
* squashed together.  in some cases it's possible for these "constructed"
* variables to be longer that the limit of what uniVerse basic would like.
* these settings allow us to declare a "longest allowed" variable length
* and turn on and off a variable-shortening algorithm to keep these
* variable within limits
    MAXIMUM.VARIABLE.LENGTH = UD.GET.SETTING(TAG:"MaximumVariableLength", 60)
    SHORTEN.LONG.VARIABLE.NAMES = UD.GET.SETTING(TAG:"ShortenLongVariableNames", 0, 1)

    RETURN

GET.LINEWRAPPING.SETTINGS: ***********************************************
* load line wrapping settings                                            *
**************************************************************************
    TAG = "LineWrapping."

* allow line wrapping?
    LINE.WRAPPING = UD.GET.SETTING("LineWrapping.LineWrapping", 1, 1)

    LINE.WRAP.CHARACTERS = UD.GET.SETTING(TAG:"LineWrapCharacters", ",=_")
    LINE.WRAP.KEYWORDS = UD.GET.SETTING(TAG:"LineWrapKeywords", "")
    LINE.WRAP.KEYWORDS = CHANGE(LINE.WRAP.KEYWORDS, ",", @AM)

    LINE.WRAP.NEXT.CHARACTERS = UD.GET.SETTING(TAG:"LineWrapNextCharacters", "=_")
    LINE.WRAP.NEXT.KEYWORDS = UD.GET.SETTING(TAG:"LineWrapNextKeywords", "")
    LINE.WRAP.NEXT.KEYWORDS = CHANGE(LINE.WRAP.NEXT.KEYWORDS, ",", @AM)

    LINE.WRAP.REMOVE.CHARACTERS = UD.GET.SETTING(TAG:"LineWrapRemoveCharacters", "_")

    RETURN

