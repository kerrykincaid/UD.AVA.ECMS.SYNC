* load associated table settings                                         *
**************************************************************************
    TAG = "AssociatedTables."

* associated (table) keyword
    ENABLE.ASSOCIATED.TABLES = UD.GET.SETTING(TAG:"EnableAssociatedTables", 1, 1)
    ASSOCIATED.KEYWORD = UD.GET.SETTING(TAG:"AssociatedKeyword", "ASSOCIATE")
    ASSOCIATED.OCONV.DELIMITER = UD.GET.SETTING(TAG:"AssociatedOconvDelimiter", "|")

    RETURN

GET.DEBUGGING.SETTINGS: **************************************************
* load debugging settings                                                *
**************************************************************************
    TAG = "Debugging."

* this prefix is added to variables used to build the object debugging
* variable in ::get.property to avoid any naming conficts
    DEBUG.PREFIX = UD.GET.SETTING(TAG:"DebugVariablePrefix", "OBJECT.DEBUG.")

    RETURN

GET.INSTALLER.SETTINGS: **************************************************
* load installer settings                                                *
**************************************************************************
    TAG = "Installer."

* the installer uses $define first.install and $ifdef and $ifndef to
* skip code that would cause problems during the initial install into a
* new environment.  set this yes for the compiler to do the same for
* some code that it generates
    USE.FIRST.INSTALL = UD.GET.SETTING(TAG:"UseFirstInstall", 1, 1)

    RETURN

GET.REGISTRY.SETTINGS: ***************************************************
* load registry settings                                                 *
**************************************************************************
    TAG = "Registry."

* update the object registry?
    UPDATE.OBJECT.REGISTRY = UD.GET.SETTING(TAG:"UpdateObjectRegistry", 0, 1)

