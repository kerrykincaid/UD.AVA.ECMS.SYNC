    SHORT.GOSUB.EXEMPT.LIST = UD.GET.SETTING(TAG:"ShortGosubExemptList")
    SHORT.GOSUB.EXEMPT.LIST = CHANGE(SHORT.GOSUB.EXEMPT.LIST, ",", @AM)

    RETURN

GET.UNARY.SETTINGS: ******************************************************
