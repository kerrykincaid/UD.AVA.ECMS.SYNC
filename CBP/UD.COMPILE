    CHILD.REGISTRY.SOURCE.VARIABLE = UD.GET.SETTING(TAG:"ChildRegistrySourceVariable", "CHILD.REGISTRY.SOURCE.ID")
    REGISTRY.SOURCE.VARIABLE = UD.GET.SETTING(TAG:"RegistrySourceVariable", "REGISTRY.SOURCE.ID")

    RETURN

GET.FORKING.SETTINGS: ****************************************************
* load forking settings                                                  *
**************************************************************************
    TAG = "Forking."

* process forking (multi-threaded objects)
    ENABLE.MULTI.THREADING = UD.GET.SETTING(TAG:"EnableMultiThreading", 0, 1)

    MULTI.THREAD.PHANTOM = UD.GET.SETTING(TAG:"MultiThreadPhantom", "UD.PHR.MULTI.THREAD.OBJECT")

    MULTI.THREAD.OBJECT.NAME = UD.GET.SETTING(TAG:"MultiThreadObjectName", "MULTI.THREAD")

    MULTI.NEW.METHOD.NAME = UD.GET.SETTING(TAG:"MultiNewMethodName", "NEW")

    SEND.AND.GET.METHOD.NAME = UD.GET.SETTING(TAG:"SendAndGetMethodName", "PROCESS.METHOD.CALL")

    MAX.MULTI.THREAD.PARAMETERS = UD.GET.SETTING(TAG:"MaxMultiThreadParameters", 30)

    FORK.KEYWORD = UD.GET.SETTING(TAG:"ForkKeyword", "FORK")
    MAXIMUM.FORK.PARAMETERS = UD.GET.SETTING(TAG:"MaximumForkParameters", 30)

    BLIND.KEYWORD = UD.GET.SETTING(TAG:"BlindKeyword", "BLIND")
    BLIND.PASSED.VALUE = UD.GET.SETTING(TAG:"BlindPassedValue", "Blind")

    FORK.START.KEYWORD = UD.GET.SETTING(TAG:"ForkStartKeyword", "REQUEST")
    FORK.START.METHOD.NAME = UD.GET.SETTING(TAG:"ForkStartMethodName", "SEND.REQUEST")
    FORK.START.PARAMETERS = UD.GET.SETTING(TAG:"ForkStartParameters", 0)

    FORK.RESPONSE.KEYWORD = UD.GET.SETTING(TAG:"ForkResponseKeyword", "RESPONSE")
    FORK.RESPONSE.METHOD.NAME = UD.GET.SETTING(TAG:"ForkResponseMethodName", "GET.RESPONSE")
    FORK.RESPONSE.PARAMETERS = UD.GET.SETTING(TAG:"ForkResponseParameters", 30)

    FORK.BUSY.KEYWORD = UD.GET.SETTING(TAG:"ForkBusyKeyword", "BUSY")
    FORK.BUSY.METHOD.NAME = UD.GET.SETTING(TAG:"ForkBusyMethodName", "RESPONSE.BUSY")
    FORK.BUSY.PARAMETERS = UD.GET.SETTING(TAG:"ForkBusyParameters", 1)

    FORK.READY.KEYWORD = UD.GET.SETTING(TAG:"ForkReadyKeyword", "FINISHED")
    FORK.READY.METHOD.NAME = UD.GET.SETTING(TAG:"ForkReadyMethodName", "RESPONSE.READY")
    FORK.READY.PARAMETERS = UD.GET.SETTING(TAG:"ForkReadyParameters", 1)

    FORK.PID.KEYWORD = UD.GET.SETTING(TAG:"ForkPidKeyword", "PID")
    FORK.PID.METHOD.NAME = UD.GET.SETTING(TAG:"ForkPidMethodName", "")
    FORK.PID.PARAMETERS = UD.GET.SETTING(TAG:"ForkPidParameters", 1)

    FORK.FLUSH.KEYWORD = UD.GET.SETTING(TAG:"ForkFlushKeyword", "FLUSH")
    FORK.FLUSH.METHOD.NAME = UD.GET.SETTING(TAG:"ForkFlushMethodName", "CLEAR.MESSAGES")
    FORK.FLUSH.PARAMETERS = UD.GET.SETTING(TAG:"ForkFlushParameters", 0)

    TEST.FLUSH.KEYWORD = UPCASE(FORK.KEYWORD:METHOD.DELIMITER:FORK.FLUSH.KEYWORD)
    LEN.TEST.FLUSH.KEYWORD = LEN(TEST.FLUSH.KEYWORD)

    RETURN

GET.COMPILE.TABLE.SETTINGS: **********************************************
* load compile table settings                                            *
**************************************************************************
    TAG = "CompileTable."

    UPDATE.COMPILE.TABLE.IN.CODE = UD.GET.SETTING(TAG:"UpdateInCode", 1, 1)
    UPDATE.COMPILE.TABLE.IN.FILE = UD.GET.SETTING(TAG:"UpdateInFile", 1, 1)

    USE.COMPILE.TABLE.IN.FILE = UD.GET.SETTING(TAG:"UseCompileTableInFile", 0, 1)

* the ud.compile.dates file has three record types; an "ALL" record for
* all objects, a "master" record for each object, and a "detail" record
* for each object / method.  the "all" and "master" records have tables
* for each object as well as a list of methods, properties, etc that
* echo the data from the detail records.  this can make the "all" and
* "master" records pretty huge.  these detail fields in the "all" and
* "master" records can be turned off here
    DETAIL.IN.ALL.COMPILE.DATES = UD.GET.SETTING(TAG:"DetailInAllCompileDates", 0, 1)

* comment line prefix for saving the checksum in an eclipse program
    CHECKSUM.PREFIX = UD.GET.SETTING(TAG:"ChecksumPrefix", "* checksum: ")

* last change and last compile prefixes for the object code
    LAST.CHANGE.PREFIX = UD.GET.SETTING(TAG:"LastChangePrefix")
    LAST.COMPILE.PREFIX = UD.GET.SETTING(TAG:"LastCompilePrefix")
    LAST.VERSION.PREFIX = UD.GET.SETTING(TAG:"LastVersionPrefix")

    COMPILER.VERSION.PREFIX = UD.GET.SETTING(TAG:"CompilerVersionPrefix")
    COMPILER.DATE.PREFIX = UD.GET.SETTING(TAG:"CompilerDatePrefix")

* update the last change date and time in time stamps?  typically this is
* turned on for dev environment and turned off for other environments.
* this will keep the last change dates and times from dev fixed through the
* test and prod environments
    UPDATE.LAST.CHANGE.STAMP = UD.GET.SETTING(TAG:"UpdateLastChangeStamp")

    RETURN

GET.LISTING.SETTINGS: ****************************************************
* load listing settings                                                  *
**************************************************************************
    TAG = "Listings."

* if the compiler is run with "details" on should we list out each
* eclipse subroutine we build?
    LIST.WITH.DETAILS = UD.GET.SETTING(TAG:"ListWithDetails", 0, 1)

* list properties by type or by line number with comments?
    LIST.PROPERTIES.BY.TYPE = UD.GET.SETTING(TAG:"ListPropertiesByType", 0, 1)

* when listing methods, show the entire method statement (with
* optional keywords and values) or just the variables?
    LONG.PARAMETER.LIST = UD.GET.SETTING(TAG:"LongParameterList", 1, 1)

* banner section names?
    BANNER.NAMES = UD.GET.SETTING(TAG:"BannerNames", 1, 1)

* when listing methods should we convert asterisk boxes to line
* boxes?
    DRAW.BOXES = UD.GET.SETTING(TAG:"DrawBoxes", 0)

* box widths
    SCREEN.BOX.WIDTH = UD.GET.SETTING(TAG:"ScreenBoxWidth", 79)
    WINDOW.BOX.WIDTH = UD.GET.SETTING(TAG:"WindowBoxWidth", 90)

* line lengths for folded lines, where the line is folded on spaces
    MAX.LINE.WIDTH.SCREEN = UD.GET.SETTING(TAG:"ScreenMaxLineWidth", 79)
    MAX.LINE.WIDTH.WINDOW = UD.GET.SETTING(TAG:"WindowMaxLineWidth", 110)

* width for the left column, that displays the method names, in the listings
    SCREEN.NAME.WIDTH = UD.GET.SETTING(TAG:"ScreenNamewidth", 25)
    WINDOW.NAME.WIDTH = UD.GET.SETTING(TAG:"WindowNamewidth", 30)

* downcase method names and variable names and things when listing
* methods?
    DOWNCASE.METHODS = UD.GET.SETTING(TAG:"DowncaseMethods", 1, 1)

    RETURN

GET.ECLIPSE.SETTINGS: ****************************************************
* load eclipse settings                                                  *
**************************************************************************
    TAG = "Eclipse."

* get compile command. this command will be used to compile the converted
* code or when compiling CBP or Core programs
    COMPILE.COMMAND = UD.GET.SETTING(TAG:"CompileCommand", "PRECOMPILE")

* default prefix to put before subroutines generated from methods.  all
