CREATE.REDIM.METHOD: *****************************************************
* create an external subroutine for redimensioning the object arrays     *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    IS.SPLIT = @FALSE

    METHOD = REDIM.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating REDIM Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME:" (ADD.INSTANCE.COUNT)"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* increase /decrease instance array for Object ":OBJECT.NAME "L#24":"  *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* ADD.INSTANCE.COUNT        number of instances to increase by (if       *"
    GOSUB ADD.CODE
    CODE = "*                           positive) or decrease by (if negative)       *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE
    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    GOSUB REDIM.PROPERTY.ARRAYS"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

    GOSUB ADD.REDIM.CODE
    GOSUB ADD.FINAL.END

    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN

ADD.REDIMENSIONING.CODE: *************************************************
* Add the code to the destroy routine that redimensions the instance if  *
* deleting the current instance has left a lot of open instances at the  *
* end of the instance arrays                                             *
**************************************************************************
    GOSUB BEFORE.ADD

* find the pointer to the highest active instance.  we can't reduce the
* instance count any lower than this or we'll lose information for active
* instances
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* check to see if we can reduce the number of instances.  we'll"
    GOSUB ADD.CODE
    CODE = "* add or reduce instances in blocks of ":MAX.INSTANCES
    GOSUB ADD.CODE
    CODE = "    HIGHEST.INSTANCE = 0"
    GOSUB ADD.CODE
    CODE = "    FOR INSTANCE.LOOP = MAX.INSTANCES TO 1 STEP -1 UNTIL HIGHEST.INSTANCE <> 0"
    GOSUB ADD.CODE
    CODE = "        IF ACTIVE.OBJECT.HANDLE<INSTANCE.LOOP> THEN"
    GOSUB ADD.CODE
    CODE = "            HIGHEST.INSTANCE = INSTANCE.LOOP"
    GOSUB ADD.CODE
    CODE = "        END"
    GOSUB ADD.CODE
    CODE = "    NEXT INSTANCE.LOOP"
    GOSUB ADD.CODE

* round highest.instance up to the next multiple of the initial max.instances.
* this is the minimum we can reduce max.instances to
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    INSTANCE.BLOCK.SIZE = ":MAX.INSTANCES
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    HIGHEST.INSTANCE = INT((HIGHEST.INSTANCE - 1) / INSTANCE.BLOCK.SIZE"
    CODE := " + 1) * INSTANCE.BLOCK.SIZE"
    GOSUB ADD.CODE
    CODE = "    IF HIGHEST.INSTANCE < INSTANCE.BLOCK.SIZE THEN"
    GOSUB ADD.CODE
    CODE = "        HIGHEST.INSTANCE = INSTANCE.BLOCK.SIZE"
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

* calculate how many instances will are open above highest.instance.  these
* instances are all empty and can be removed without losing any information.
* if the count of open.instances is twice the initial max.instances value or
* more then we can remove a block of empty instances.

* we only want to remove blocks of instances.  if we redim every time we have
* open instances at the end of the instance array we'll be redimming over and
* over and things get slow
    CODE = "    OPEN.INSTANCES = MAX.INSTANCES - HIGHEST.INSTANCE"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    IF OPEN.INSTANCES >= INSTANCE.BLOCK.SIZE * 2 THEN"
    GOSUB ADD.CODE

* we can reduce the number of object instances.  if we're using an external
* redim routine set up a call to reduce the instance count.  if we're using
* an internal redim routine set up a gosub.
    IF USE.EXTERNAL.REDIM THEN
        CODE = "        ":ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER
        CODE := REDIM.KEYWORD:" -OPEN.INSTANCES"
        GOSUB ADD.CODE
    END ELSE
        CODE = "        ADD.INSTANCE.COUNT = -OPEN.INSTANCES"
        GOSUB ADD.CODE
        CODE = "        GOSUB REDIM.PROPERTY.ARRAYS"
        GOSUB ADD.CODE
    END

    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / destroy method        **
**************************************************************************
**************************************************************************

CREATE.DESTROY.METHOD: ***************************************************
* create destroying method for an object instance                        *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = DESTROY.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating DESTROY Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME:" (OBJECT.HANDLE)"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* destroy an instance for ":OBJECT.NAME "L#30":"                 *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB BEFORE.ADD

* if there are no properties we can skip a lot of this
    IF PROPERTIES.EXIST THEN

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
        IF PROPERTY.COMMON.CODE.AT.END THEN
            
            CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
            GOSUB ADD.CODE

        END ELSE
            GOSUB ADD.COMMON.CODE
        END

    END

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    GOSUB AFTER.ADD

* define object variables
    GOSUB ADD.SPECIAL.CODE

    IF PROPERTIES.EXIST THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* initialize error return variable"
        GOSUB ADD.CODE
        CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

* if this isn't a valid object handle skip out
        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* if this isn't a valid object handle exit"
        GOSUB ADD.CODE
        CODE = "    IF UNASSIGNED(OBJECT.HANDLE) THEN"
        GOSUB ADD.CODE
        CODE = '        OBJECT.HANDLE = ""'
        GOSUB ADD.CODE
        CODE = "        ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE
        CODE = " "

* the object pointer has to be defined and must be numeric or there's
* something off with the object pointer
        GOSUB ADD.CODE
        CODE = "    TEST.OBJECT.PTR = OBJECT.HANDLE<1>"
        GOSUB ADD.CODE
        CODE = '    IF TEST.OBJECT.PTR = "" OR NOT(NUM(TEST.OBJECT.PTR)) THEN'
        GOSUB ADD.CODE
        CODE = '        OBJECT.HANDLE = ""'
        GOSUB ADD.CODE
        CODE = "        ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE

* if the object pointer is outside of the range of instances dimensioned
* something is off.  for single objects, however, there will only be one
* instance of the object and each calling process will have its own object
* pointer that's greater than one.  for single objects, then, we won't check
* the object pointer against max.instances
        BEGIN CASE

            CASE SINGLE.OBJECT
                CODE = '    IF TEST.OBJECT.PTR < 1 THEN'
                GOSUB ADD.CODE
                CODE = '        OBJECT.HANDLE = ""'
                GOSUB ADD.CODE
                CODE = "        ":EXIT.METHOD.KEYWORD
                GOSUB ADD.CODE
                CODE = "    END"
                GOSUB ADD.CODE

            CASE 1
                CODE = '    IF TEST.OBJECT.PTR < 1 OR TEST.OBJECT.PTR > MAX.INSTANCES THEN'
                GOSUB ADD.CODE
                CODE = '        OBJECT.HANDLE = ""'
                GOSUB ADD.CODE
                CODE = "        ":EXIT.METHOD.KEYWORD
                GOSUB ADD.CODE
                CODE = "    END"
                GOSUB ADD.CODE

        END CASE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* set properties for the correct object instance"
        GOSUB ADD.CODE
        CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    DESTROYED.OBJECT.HANDLE = OBJECT.HANDLE"
        GOSUB ADD.CODE
        CODE = "    RESIDENT.OBJECT = OBJECT.HANDLE<6>"
        GOSUB ADD.CODE
        CODE = "    SINGLE.INSTANCE.OBJECT = OBJECT.HANDLE<7>"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

        GOSUB ADD.AUTO.STRING.DEFINITION

        GOSUB ADD.AUTO.DEBUG.CODE

        GOSUB ADD.DESTROY.METHOD.USER.CODE

* add special code for other object types and object destroying
* code for objects that need it
        BEGIN CASE

            CASE RESIDENT.OBJECT
                GOSUB ADD.RESIDENT.INSTANCE.DESTROY.CODE

            CASE SINGLE.OBJECT
                GOSUB ADD.SINGLE.INSTANCE.DESTROY.CODE
                GOSUB ADD.OBJECT.DESTROYING.CODE

            CASE 1
                GOSUB ADD.NORMAL.INSTANCE.DESTROY.CODE
                GOSUB ADD.OBJECT.DESTROYING.CODE

        END CASE

* if the routine didn't end with a return add one
        IF NOT(ENDS.WITH.RETURN) THEN

            GOSUB BEFORE.ADD

            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE

            GOSUB AFTER.ADD

        END

        GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
        IF PROPERTY.COMMON.CODE.AT.END THEN
            GOSUB ADD.COMMON.CODE.SUBROUTINE
        END

* rebuild the instance code specifically for this method
        GOSUB BUILD.INSTANCE.CODE

    END ELSE

* this object has no properties
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* this object has no properties.  it's just a parking place"
        GOSUB ADD.CODE
        CODE = "* for subroutines"
        GOSUB ADD.CODE

        GOSUB ADD.DESTROY.METHOD.USER.CODE

        GOSUB BEFORE.ADD

* wrap up the "new" method with a return to the calling program
        IF NOT(ENDS.WITH.RETURN) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE
        END

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.UTILITY.ROUTINES

    GOSUB ADD.INSTANCE.CODE

    IF PROPERTIES.EXIST THEN

* add in redimensioning code of allowed and we have more than one
* object instance
        IF NOT(USE.EXTERNAL.REDIM) AND ALLOW.REDUCING.INSTANCES AND MAX.INSTANCES > 1 THEN
            GOSUB ADD.REDIM.CODE
        END

    END ELSE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    RETURN"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

    GOSUB ADD.FINAL.END

    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN

ADD.DESTROY.METHOD.USER.CODE: ********************************************
* add any user code that goes in the destroy method                      *
**************************************************************************
    GOSUB GET.METHOD.CODE.LINES

    IF METHOD.CODE.LINES > 0 THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = BEFORE.USER.CODE
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE

        USER.CODE.START.PTR = PROGRAM.CODE.LINES

        GOSUB AFTER.ADD

        ADD.RETURN = @FALSE
        ADD.FINAL.ERROR.CHECK = @TRUE
        INDENT = ""
        GOSUB ADD.METHOD.CODE

        USER.CODE.END.PTR = PROGRAM.CODE.LINES

        GOSUB BEFORE.ADD

        CODE = AFTER.USER.CODE
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = NO.USER.CODE
        GOSUB ADD.CODE

        USER.CODE.START.PTR = PROGRAM.CODE.LINES
        USER.CODE.END.PTR = PROGRAM.CODE.LINES

        GOSUB AFTER.ADD

    END

    RETURN

ADD.RESIDENT.INSTANCE.DESTROY.CODE: **************************************
* add code to take care of resident destroys.  resident objects are      *
* never destroyed                                                        *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* resident objects are never destroyed"
    GOSUB ADD.CODE
    CODE = "    ":EXIT.METHOD.KEYWORD
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.SINGLE.INSTANCE.DESTROY.CODE: ****************************************
* add code to take care of single instance destroys.  takes care         *
* of keeping a counter for how many net creates (less destroys) are      *
* active and updates things as the instances are destroyed               *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if this object instance exists in our object instance list we'll remove it"
    GOSUB ADD.CODE
    CODE = "* and recalculate the number of remaining open instances.  if greater than zero"
    GOSUB ADD.CODE
    CODE = "* there are still objects that need this object so we can't destroy it yet."
    GOSUB ADD.CODE
    CODE = "* if we can't locate the object pointer in the object instance list then this"
    GOSUB ADD.CODE
    CODE = "* a second request to delete an instance we've already deleted, ie, by the"
    GOSUB ADD.CODE
    CODE = "* auto destroy.  exit without doing anything"
    GOSUB ADD.CODE
    CODE = "    LOCATE OBJECT.PTR IN ":SINGLE.INSTANCE.LIST.VARIABLE:" SETTING DESTROY.OBJECT.INDEX.PTR THEN"
    GOSUB ADD.CODE
    CODE = "        DEL ":SINGLE.INSTANCE.LIST.VARIABLE:"<DESTROY.OBJECT.INDEX.PTR>"
    GOSUB ADD.CODE
    CODE = "        ACTIVE.OBJECT.HANDLE<OBJECT.PTR> = @FALSE"
    GOSUB ADD.CODE
    CODE = "        ":SINGLE.INSTANCE.COUNT.VARIABLE:" = SUM(ACTIVE.OBJECT.HANDLE)"
    GOSUB ADD.CODE
    CODE = "    END ELSE"
    GOSUB ADD.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* remove from the object registry"
    GOSUB ADD.CODE

* do a "delete" to remove this 'object' from the object registry
    IF UPDATE.OBJECT.REGISTRY THEN

        CODE = '    REGISTRY.RESPONSE = UD.OBJECT.REGISTRY('
        CODE := '"DELETE", '

        IF PASS.REGISTRY.HANDLES.BYVAL THEN
            CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
        END ELSE
            CODE := "OBJECT.HANDLE, "
        END

        CODE := '"':ECLIPSE.PREFIX:'", '
        CODE := '"", '
        CODE := '"", '
        CODE := "REGISTRY.ERROR)"
        GOSUB ADD.CODE

    END

* null out the object handles
    CODE = '    OBJECT.HANDLE = ""'
    GOSUB ADD.CODE

    IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
        CODE = '    ':LOCAL.OBJECT.VARIABLE:' = ""'
        GOSUB ADD.CODE
    END

* if there are still objects that are using this instance exit without
* deleting anything
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if other object are still using this instance exit without deleting anything"
    GOSUB ADD.CODE
    CODE = "    IF ":SINGLE.INSTANCE.COUNT.VARIABLE:" > 0 THEN"
    GOSUB ADD.CODE
    CODE = "        ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

* for nonresident single-instance object instances if we get here then
* all object instances that were created are accounted for
* and have been destroyed.  time to actually delete the instance
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* every 'instance' of this single-instance object that was"
    GOSUB ADD.CODE
    CODE = "* created has been destroyed.  destroy the instance"
    GOSUB ADD.CODE
    CODE = "    ":SINGLE.INSTANCE.COUNT.VARIABLE:" = 0"
    GOSUB ADD.CODE
    CODE = "    ":SINGLE.INSTANCE.LIST.VARIABLE:' = ""'
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    IF ":SINGLE.INSTANCE.COUNT.VARIABLE:" > 0 THEN"
    GOSUB ADD.CODE
    CODE = "        ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.NORMAL.INSTANCE.DESTROY.CODE: ****************************************
* add in object instance destroy code that's only for normal objects     *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if this object instance has been flagged as resident it shouldn't"
    GOSUB ADD.CODE
    CODE = "* be deleted"
    GOSUB ADD.CODE
    CODE = "    IF RESIDENT.OBJECT THEN"
    GOSUB ADD.CODE
    CODE = "        ":EXIT.METHOD.KEYWORD
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.OBJECT.DESTROYING.CODE: **********************************************
* add in the code for the destroy object that destroys everything for    *
* the object                                                             *
**************************************************************************
    GOSUB BEFORE.ADD

* destroy any child objects
    IF OBJECT.DELETES.CHILD AND CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* destroy child objects"
        GOSUB ADD.CODE
    END

* loop through the child object list and destroy each one
    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.CHILD.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.CHILD.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.CHILD.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.CHILD.DIM,VM)
        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>

        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        GOSUB DECODE.PROPERTY

        GOSUB GET.CHILD.MAX.INSTANCES

        BEGIN CASE

* if ObjectDeletesChild is not set we won't destroy any of these child
* objects
            CASE NOT(OBJECT.DELETES.CHILD)
                NULL

* child.depth is deeper than we want to worry about
            CASE THIS.CHILD.DEPTH > BUILD.CHILD.DEPTH
                NULL

* if this is a child of a child we don't need to worry about it.  the senior
* child will take care of it
            CASE INDEX(THIS.CHILD.HANDLE, CHILD.DELIMITER, 1) > 0
                NULL

* if the child depth is more than 1 let the parent object destroy
* it.  just null out the handle
            CASE THIS.CHILD.DEPTH > 1 AND THIS.DIMENSIONS = 0
                CODE = "    ":THIS.CHILD.HANDLE:' = ""'

            CASE THIS.CHILD.DEPTH > 1
                CODE = "    MAT ":THIS.CHILD.HANDLE:' = ""'

* if the child depth is 1 it was created by this object so destroy it
            CASE THIS.DIMENSIONS = 0
                CODE = "    IF ":THIS.CHILD.HANDLE:' <> "" AND ':THIS.CHILD.HANDLE:' <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "        ":THIS.CHILD.HANDLE:METHOD.DELIMITER:DESTROY.KEYWORD
                GOSUB ADD.CODE
                CODE = "    END"
                GOSUB ADD.CODE

            CASE THIS.DIMENSIONS = 1
                CODE = "    FOR CHILD.LOOP = 1 TO ":THIS.CHILD.DIM<1,1>
                GOSUB ADD.CODE
                CODE = "        IF ":THIS.CHILD.HANDLE:'(CHILD.LOOP) <> "" AND ':THIS.CHILD.HANDLE:'(CHILD.LOOP) <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "            ":THIS.CHILD.HANDLE:"(CHILD.LOOP)":METHOD.DELIMITER:DESTROY.KEYWORD
                GOSUB ADD.CODE 
                CODE = "        END"
                GOSUB ADD.CODE
                CODE = "    NEXT CHILD.LOOP"
                GOSUB ADD.CODE

            CASE THIS.DIMENSIONS = 2
                CODE = "    FOR CHILD.LOOP1 = 1 TO ":THIS.CHILD.DIM<1,1>
                GOSUB ADD.CODE
                CODE = "        FOR CHILD.LOOP2 = 1 TO ":THIS.CHILD.DIM<1,2>
                GOSUB ADD.CODE
                CODE = "            IF ":THIS.CHILD.HANDLE:'(CHILD.LOOP1,CHILD.LOOP2) <> "" AND ':THIS.CHILD.HANDLE:'(CHILD.LOOP1,CHILD.LOOP2) <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "                ":THIS.CHILD.HANDLE:"(CHILD.LOOP1,CHILD.LOOP2)":METHOD.DELIMITER:DESTROY.KEYWORD
                GOSUB ADD.CODE
                CODE = "            END"
                GOSUB ADD.CODE
                CODE = "        NEXT CHILD.LOOP2"
                GOSUB ADD.CODE
                CODE = "    NEXT CHILD.LOOP1"
                GOSUB ADD.CODE

        END CASE

    NEXT CHILD.LOOP

* destroy this object
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* destroy this object instance"
    GOSUB ADD.CODE
    CODE = "    GOSUB DESTROY.CURRENT.OBJECT.INSTANCE"
    GOSUB ADD.CODE

* do a "delete" to remove this object from the object registry
    IF UPDATE.OBJECT.REGISTRY THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* remove from object registry"
        GOSUB ADD.CODE
        CODE = '    REGISTRY.RESPONSE = UD.OBJECT.REGISTRY('
        CODE := '"DELETE", '

        IF PASS.REGISTRY.HANDLES.BYVAL THEN
            CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
        END ELSE
            CODE := "OBJECT.HANDLE, "
        END

        CODE := '"':ECLIPSE.PREFIX:'", '
        CODE := '"", '
        CODE := '"", '
        CODE := "REGISTRY.ERROR)"
        GOSUB ADD.CODE

    END

* null out the object handles
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* this object is no longer a valid object"
    GOSUB ADD.CODE
    CODE = '    OBJECT.HANDLE = ""'
    GOSUB ADD.CODE

    IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
        CODE = '    ':LOCAL.OBJECT.VARIABLE:' = ""'
        GOSUB ADD.CODE
    END

    GOSUB AFTER.ADD

* if we're allowing expanding instances check to see how many unused
* instances are left above the last instance used.  if there are
* more than twice max.instances then redim everything down to return
* some memory to the system
    IF ALLOW.REDUCING.INSTANCES AND MAX.INSTANCES > 1 THEN
        GOSUB ADD.REDIMENSIONING.CODE
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / wrappers / create                        **
**************************************************************************
**************************************************************************

CREATE.WRAPPER: **********************************************************
* create a wrapper subroutine for a method with a wrapper name in the    *
* obp file.  wrapper.type defines the type of wrapper to create:         *
*     wrapper          a callable subroutine to call the wrapper         *
*     tcl.wrapper      a tcl-callable subroutine to call the wrapper     *
*     driver.wrapper   a driver routine, callable from eclipse menus     *
*     phantom.wrapper  a phantom wrapper                                 *
*     routine          a subroutine wrapper, callable by "normal"        *
*                      programs                                          *
**************************************************************************
    GOSUB START.CREATE.TIME

* start building subroutine.
    WRAPPER.CREATED = @TRUE
    WRAPPER.CODE = ""
    WRAPPER.CODE.LINES = 0

    FILTER.BLANK.LINES = @TRUE

* show that we're creating a wrapper
    IF NOT(BRIEF) AND NOT(LIST.OBJECTS.ONLY) THEN

* if this method created a wrapper display it as well
        DISPLAY.WRAPPER = WRAPPER.SUBROUTINE.NAME
        IF UPCASE.CODE THEN
            DISPLAY.WRAPPER = DOWNCASE(DISPLAY.WRAPPER)
        END

        PRINT "        Creating wrapper obp ":DISPLAY.WRAPPER

    END

    PARAMETER.LIST = WRAPPER.PARAMETER.LIST

    OPTIONAL.LIST = WRAPPER.OPTIONAL.LIST
    DEFAULT.LIST = WRAPPER.DEFAULT.LIST

    BYREF.LIST = WRAPPER.BYREF.LIST
    SPECIAL.LIST = WRAPPER.SPECIAL.LIST

    PARAMETER.BYREF.LIST = WRAPPER.BYREF.LIST
    PARAMETER.SPECIAL.LIST = WRAPPER.SPECIAL.LIST

    PARAMETER.COUNT = WRAPPER.PARAMETER.COUNT

    CREATE.WRAPPER.OBJECT = @TRUE

    GOSUB CREATE.WRAPPER.DEFINITION
    GOSUB ADD.WRAPPER.COMMENT.CODE
    GOSUB ADD.WRAPPER.STAMP

* build the wrapper code
    IF CREATE.WRAPPER.OBJECT THEN

        GOSUB CREATE.WRAPPER.OBJECT.CODE

    END ELSE

        CODE = " "
        GOSUB ADD.WRAPPER.CODE
        CODE = "* method code"
        GOSUB ADD.WRAPPER.CODE

        ADD.RETURN = @FALSE
        INDENT = ""
        GOSUB ADD.WRAPPER.METHOD.CODE

    END

    GOSUB ADD.WRAPPER.ERROR.HANDLING

* if auto object destruction is not on add a destroy statement
    IF NOT(AUTO.DESTROY.OBJECTS) AND CREATE.WRAPPER.OBJECT THEN

        CODE = "    ":OBJECT.NAME:METHOD.DELIMITER:DESTROY.KEYWORD
        CODE = DOWNCASE(CODE)
        GOSUB ADD.WRAPPER.CODE

        CODE = " "
        GOSUB ADD.WRAPPER.CODE

    END

* return
    CODE = "    ":WRAPPER.RETURN.KEYWORD
    CODE = DOWNCASE(CODE)
    GOSUB ADD.WRAPPER.CODE

* add any common routines
    IF ADD.COMMON.ROUTINES.TO.WRAPPERS THEN
        GOSUB ADD.COMMON.WRAPPER.CODE
    END

* remove any unused subroutines
    GOSUB REMOVE.UNUSED.WRAPPER.SUBROUTINES

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.WRAPPER
    END

    GOSUB END.CREATE.TIME

    RETURN

CREATE.WRAPPER.DEFINITION: ***********************************************
* create the definition line for the wrapper                             *
**************************************************************************

* build the "subroutine" statement.  for "wrapper" types the first parameter
* is our object handle. the second is the error message return variable.  
* then the parameters from the method definition.  for "tcl wrapper" types
* the first line is just the subroutine name
    BEGIN CASE

* for generic wrappers build a subroutine with the same parameters as the method.
* wrappers don't use optional parameters in the subroutine statement or in the
* subroutine statement as they call the wrapped method which does use the
* optional parameters
        CASE WRAPPER.TYPE = "WRAPPER"

            CODE = "    subroutine ":WRAPPER.SUBROUTINE.NAME:" ("
            CODE := ERROR.MESSAGE.VARIABLE

            CREATE.WRAPPER.OBJECT = @TRUE

            USE.PREN = @FALSE
            USE.FIRST.COMMA = @TRUE
            USE.SEMI.COLON = @TRUE
            USE.OPTIONAL = @FALSE
            ONLY.OUTPUT.PARAMETERS = @FALSE
            ONLY.INPUT.PARAMETERS = @FALSE
            GOSUB ADD.WRAPPER.PARAMETERS

            CODE := ")"

* a tcl wrapper is a subroutine with no parameters so that it can be executed
* from tcl
        CASE WRAPPER.TYPE = "TCL.WRAPPER"

            CODE = "    subroutine ":WRAPPER.SUBROUTINE.NAME

            CREATE.WRAPPER.OBJECT = @TRUE

* for a driver wrapper create a subroutine with one parameter--passer
        CASE WRAPPER.TYPE = "DRIVER.WRAPPER"

            CODE = "    subroutine ":WRAPPER.SUBROUTINE.NAME:" (passer)"

            CREATE.WRAPPER.OBJECT = @TRUE

* for a phantom wrapper build a record beginning with ph.args.  phantom
* arguments don't allow optional parameters and don't have any distinction
* between input and output parameters
        CASE WRAPPER.TYPE = "PHANTOM.WRAPPER"

            CODE = "    ph.args drpt"

            CREATE.WRAPPER.OBJECT = @TRUE

            USE.PREN = @FALSE
            USE.FIRST.COMMA = @TRUE
            USE.SEMI.COLON = @FALSE
            USE.OPTIONAL = @FALSE
            ONLY.OUTPUT.PARAMETERS = @FALSE
            ONLY.INPUT.PARAMETERS = @FALSE
            GOSUB ADD.WRAPPER.PARAMETERS

* for a "routine" wrapper (really just an external subroutine we can park
* in the method definition) build a record beginning with only the parameters
* stated in the routine definition.  a "routine" wrapper is the only wrapper
* (so far, anyway) that doesn't create an instance of the object.  "routine"
* wrappers use optional parameters since they don't call a method that would
* use the optional parameters
        CASE WRAPPER.TYPE = "ROUTINE"

            CODE = "    subroutine ":WRAPPER.SUBROUTINE.NAME

            CREATE.WRAPPER.OBJECT = @FALSE

            IF PARAMETER.COUNT > 0 THEN

                USE.PREN = @TRUE
                USE.FIRST.COMMA = @FALSE
                USE.SEMI.COLON = @TRUE
                USE.OPTIONAL = @TRUE
                ONLY.OUTPUT.PARAMETERS = @FALSE
                ONLY.INPUT.PARAMETERS = @FALSE
                GOSUB ADD.WRAPPER.PARAMETERS

            END

    END CASE

    CODE = DOWNCASE.QUOTE(CODE)
    GOSUB ADD.WRAPPER.CODE
    CODE = " "
    GOSUB ADD.WRAPPER.CODE

    RETURN

CREATE.WRAPPER.OBJECT.CODE: **********************************************
* add code to the wrapper to create the object associated with the       *
* wrapper and call the associated method                                 *
**************************************************************************
    CODE = "* create object associated with this wrapper"
    GOSUB ADD.WRAPPER.CODE

    CODE = "    ":OBJECT.NAME:" = ":NEW.KEYWORD:"(":OBJECT.NAME:")"
    GOSUB ADD.WRAPPER.CODE

    CODE = " "
    GOSUB ADD.WRAPPER.CODE

* if we created the object in the wrapper we're going to call the method
* associated with this wrapper rather than put the user code in the wrapper.
* build the call to the wrapper method.  for most wrappers this will be
* a method call.  for "routine" wrappers we won't create the object and
* we'll add the method code to this subroutine
    CODE = "* call the method associated with this wrapper"
    GOSUB ADD.WRAPPER.CODE

    CODE = "    "

* add output parameters if there are any
    IF ENABLE.BYVAL THEN

        USE.PREN = @FALSE
        USE.FIRST.COMMA = @FALSE
        USE.SEMI.COLON = @FALSE
        USE.OPTIONAL = @FALSE
        ONLY.OUTPUT.PARAMETERS = @TRUE
        ONLY.INPUT.PARAMETERS = @FALSE
        GOSUB ADD.WRAPPER.PARAMETERS

        IF PARAMETERS.ADDED THEN
            CODE := " = "
        END

    END

* add the object and method being called.   if the the call has gotten too
* long wrap this line and start the next one
    WRAPPER.CALL.CODE = OBJECT.NAME:METHOD.DELIMITER:METHOD

    IF LINE.WRAPPING AND LEN(CODE) + LEN(WRAPPER.CALL.CODE) > 79 THEN
        GOSUB ADD.WRAPPER.CODE
        CODE = "        "
    END

    CODE := WRAPPER.CALL.CODE

* add parameters after the object and method.  if byvals are enabled add just
* the input parameters to the call.  otherwise add all parameters
    IF PARAMETER.COUNT > 0 THEN

        IF ENABLE.BYVAL THEN

            USE.PREN = @TRUE
            USE.FIRST.COMMA = @FALSE
            USE.SEMI.COLON = @FALSE
            USE.OPTIONAL = @FALSE
            ONLY.OUTPUT.PARAMETERS = @FALSE
            ONLY.INPUT.PARAMETERS = @TRUE
            GOSUB ADD.WRAPPER.PARAMETERS

        END ELSE

            USE.PREN = @TRUE
            USE.FIRST.COMMA = @FALSE
            USE.SEMI.COLON = @FALSE
            USE.OPTIONAL = @FALSE
            ONLY.OUTPUT.PARAMETERS = @FALSE
            ONLY.INPUT.PARAMETERS = @FALSE
            GOSUB ADD.WRAPPER.PARAMETERS

        END

    END

    GOSUB ADD.WRAPPER.CODE

    RETURN

ADD.WRAPPER.PARAMETERS: **************************************************
* add wrapper parameters to code.  code should already have the          *
* beginning part of the line                                             *
*                                                                        *
* uses these flags:                                                      *
*                                                                        *
* use.pren                add parenthis before and after any added       *
*                         parameters                                     *
* use.first.comma:        set true if a comma should be added before the *
*                         first parameter.  ie, there are already        *
*                         parameters in the code line and we're just     *
*                         adding more                                    *
* use.semi.colon:         set true if a semi-colon should be placed      *
*                         between input and output parameters.           *
*                         otherwise all parameters will be separated by  *
*                         commas only                                    *
* use.optional:           set if these parameters are being added to a   *
*                         method / subroutine call can have optional     *
*                         parameters and/or byval parameters             *
* only.input.parameters:  set true to add only input parameters          *
* only.output.parameters: set true to add only output parameters         *
**************************************************************************
    PARAMETERS.ADDED = @FALSE

    IF PARAMETER.COUNT = 0 THEN
        RETURN
    END

* figure out where the break between output and input parameters should
* be
    BEGIN CASE

* if the first parameter is byval then we have no output parameters.  the 
* break should be before the first parameter
        CASE BYREF.LIST<1> = @FALSE
            PARAMETER.BREAK = 1

* if all parameters are byref then we have no input parameters.  there should
* be a break at the end
        CASE SUM(BYREF.LIST) = PARAMETER.COUNT
            PARAMETER.BREAK = 0

* we have a mix of byref and byvals so we have both input and output 
* parameters.  the break should be before the first byval
        CASE 1
            PARAMETER.BREAK = 0
            FOR CHECK.LOOP = 1 TO PARAMETER.COUNT UNTIL PARAMETER.BREAK <> 0
                IF BYREF.LIST<CHECK.LOOP> = @FALSE THEN
                    PARAMETER.BREAK = CHECK.LOOP
                END
            NEXT CHECK.LOOP

    END CASE

* decide which parameters in the parameter list to add to the code
    BEGIN CASE

* we're only adding output parameters but we don't have any
        CASE ONLY.OUTPUT.PARAMETERS AND PARAMETER.BREAK = 1
            RETURN

* adding only input parameters and we don't have any
        CASE ONLY.INPUT.PARAMETERS AND PARAMETER.BREAK = 0
            RETURN

* we're only adding output parameters
        CASE ONLY.OUTPUT.PARAMETERS AND PARAMETER.BREAK = 0
            START.PARAMETER.LOOP = 1
            END.PARAMETER.LOOP = PARAMETER.COUNT

        CASE ONLY.OUTPUT.PARAMETERS
            START.PARAMETER.LOOP = 1
            END.PARAMETER.LOOP = PARAMETER.BREAK - 1

* we're only adding input parameters
        CASE ONLY.INPUT.PARAMETERS
            START.PARAMETER.LOOP = PARAMETER.BREAK
            END.PARAMETER.LOOP = PARAMETER.COUNT

* we're adding all parameters
        CASE 1
            START.PARAMETER.LOOP = 1
            END.PARAMETER.LOOP = PARAMETER.COUNT

    END CASE

* add the selected parameters to the code
    FIRST.PARAMETER = @TRUE

    FOR PARAMETER.LOOP = START.PARAMETER.LOOP TO END.PARAMETER.LOOP

        THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>

        THIS.DEFAULT = DEFAULT.LIST<PARAMETER.LOOP>
        THIS.OPTIONAL = OPTIONAL.LIST<PARAMETER.LOOP>

        THIS.BYREF = BYREF.LIST<PARAMETER.LOOP>
        THIS.SPECIAL = SPECIAL.LIST<PARAMETER.LOOP>

* decide on the parameter separator to go before this parameter.  if byvals
* are enabled and this is the first byval we want to use a semi-colon to
* separate input and output parameters
        IF USE.SEMI.COLON AND ENABLE.BYVAL AND PARAMETER.LOOP = PARAMETER.BREAK THEN
            PARAMETER.SEPARATOR = ";"
        END ELSE
            PARAMETER.SEPARATOR = ","
        END

* if we haven't added a parameter yet and we're adding parenthesis add the
* "open" pren
        IF FIRST.PARAMETER AND USE.PREN THEN
            CODE := " ("
        END

* this is the first parameter and we aren't putting a comma or semi-colon
* before the first parameter skip adding the parameter
        IF NOT(FIRST.PARAMETER) OR USE.FIRST.COMMA THEN
            CODE := PARAMETER.SEPARATOR:" "
        END

* if the the call has gotten too long.  wrap this line and start the next one.
* however, don't split the line unless we've added at least one parameter.  we
* need the line to end with a comma or semi-colon for the to be unwrapped
* properly during compilation
        IF NOT(FIRST.PARAMETER) THEN
            IF LINE.WRAPPING AND LEN(CODE) + LEN(THIS.PARAMETER) + 2 > 79 THEN
                GOSUB ADD.WRAPPER.CODE
                CODE = "        "
            END
        END

* add the parameter to the subroutine line
        BEGIN CASE 

* this is an optional byval special parameter
            CASE THIS.OPTIONAL AND NOT(THIS.BYREF) AND THIS.SPECIAL AND USE.OPTIONAL
                CODE := OPTIONAL.KEYWORD:" ":BYVAL.SPECIAL.KEYWORD:" ":THIS.PARAMETER:" = ":THIS.DEFAULT

* this is an optional byval parameter
            CASE THIS.OPTIONAL AND NOT(THIS.BYREF) AND USE.OPTIONAL
                CODE := OPTIONAL.KEYWORD:" ":BYVAL.KEYWORD:" ":THIS.PARAMETER:" = ":THIS.DEFAULT

* this is an optional parameter
            CASE THIS.OPTIONAL AND USE.OPTIONAL
                CODE := OPTIONAL.KEYWORD:" ":THIS.PARAMETER:" = ":THIS.DEFAULT

* this is a byval special parameter
            CASE NOT(THIS.BYREF) AND THIS.SPECIAL AND USE.OPTIONAL
                CODE := BYVAL.SPECIAL.KEYWORD:" ":THIS.PARAMETER

* this is a byval parameter
            CASE NOT(THIS.BYREF) AND USE.OPTIONAL
                CODE := BYVAL.KEYWORD:" ":THIS.PARAMETER

* this is a normal parameter or we aren't using optional / byval options
            CASE 1
                CODE := THIS.PARAMETER

        END CASE

        PARAMETERS.ADDED = @TRUE
        FIRST.PARAMETER = @FALSE

    NEXT PARAMETER.LOOP

* if all parameters were byref add a semi-colon to the end of the
* parameter list
    IF USE.SEMI.COLON AND ENABLE.BYVAL AND PARAMETER.BREAK = 0 THEN
        CODE := ";"
    END

    IF USE.PREN THEN
        CODE := ")"
    END

    RETURN

ADD.WRAPPER.METHOD.CODE: *************************************************
* add code for method to wrapper.code.  if add.return is set and the     *
* last method code line doesn't have a return a return will be added.    *
* set "INDENT" for additional indenting                                  *
**************************************************************************
    METHOD.CODE.ADDED = @FALSE
    ENDS.WITH.RETURN = @FALSE

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = ""

* find method in the method table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add the method's programming code into the external subroutine.  we'll
* start with the first programming code line and go to the end of the
* method.
    START.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

* update the starting line of the source code (in the object definition)
* and the starting line of the target code (the eclipse subroutine).  we'll
* use this later to convert program error lines from ba into associated
* lines in the object source
    SOURCE.START = START.LINE
    TARGET.START = PROGRAM.CODE.LINES + 1
    SOURCE.LINE.COUNT = END.LINE - START.LINE + 1

* find the location of the character after the delimter before
* start.line
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

* copy method code to the wrapper subroutine.
    FILTER.BLANK.LINES = @FALSE
    SETREM START.PTR ON OBJECT.CODE

    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
        CODE = INDENT:CODE
        GOSUB ADD.WRAPPER.CODE

    NEXT LINE.LOOP

    FILTER.BLANKS = FILTER.BLANK.DEFAULT

* add a return.  the return isn't mandatory in the programming code so
* we'll add one to make sure we have it
    IF ADD.RETURN AND NOT(ENDS.WITH.RETURN) THEN
        CODE = " "
        GOSUB ADD.WRAPPER.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.WRAPPER.CODE
    END ELSE
        CODE = " "
        GOSUB ADD.WRAPPER.CODE
    END

    METHOD.CODE.ADDED = @TRUE

    RETURN

ADD.WRAPPER.ERROR.HANDLING: **********************************************
* add code to the wrapper to handle error handling                       *
**************************************************************************
    CODE = " "
    GOSUB ADD.WRAPPER.CODE

* handle errors coming back from the wrapped routine
    BEGIN CASE

* for tcl wrappers and driver wrappers if an error comes back from the
* object method call print it out on the screen
        CASE WRAPPER.TYPE = "TCL.WRAPPER" OR WRAPPER.TYPE = "DRIVER.WRAPPER"

            CODE = "    IF HAVE.ERROR {"
            GOSUB ADD.WRAPPER.CODE
            CODE = "        SUB::UD.SHOW.OBJECT.ERROR (ERROR.MESSAGE, 1)"
            GOSUB ADD.WRAPPER.CODE
            CODE = "    }"
            GOSUB ADD.WRAPPER.CODE
            CODE = " "
            GOSUB ADD.WRAPPER.CODE

* for phantom wrappers send a message back to the user
        CASE WRAPPER.TYPE = "PHANTOM.WRAPPER"

            CODE = "    IF HAVE.ERROR {"
            GOSUB ADD.WRAPPER.CODE
            CODE = "        SUB::SEND.MESSAGE (PROGRAM.NAME, USER.ID, ERROR.MESSAGE)"
            GOSUB ADD.WRAPPER.CODE
            CODE = "    }"
            GOSUB ADD.WRAPPER.CODE
            CODE = " "
            GOSUB ADD.WRAPPER.CODE

    END CASE

    RETURN

ADD.WRAPPER.CODE: ********************************************************
* add code to wrapper.code.  if upcase.code is set we'll leave           *
* the code as lower case since we're going to write it to obp.  other-   *
* wise we'll upcase it                                                   *
**************************************************************************
    IF UPCASE.CODE THEN
        CODE = DOWNCASE.QUOTE (CODE)
    END

* if this is a blank line and the previous line is also blank don't add
* it
    IF FILTER.BLANK.LINES THEN
        IF WRAPPER.CODE.LINES > 1 AND TRIM(CODE) = "" THEN
            IF TRIM(WRAPPER.CODE<WRAPPER.CODE.LINES>) = "" THEN
                RETURN
            END
        END
    END

* add code line to program
    WRAPPER.CODE.LINES += 1

    IF WRAPPER.CODE.LINES = 1 THEN
        WRAPPER.CODE = CODE
    END ELSE
        WRAPPER.CODE := @AM:CODE
    END

    RETURN


**************************************************************************
**************************************************************************
** code / stamps                                                        **
**************************************************************************
**************************************************************************

ADD.STAMP: ***************************************************************
* add a time / date / user stamp to a subroutine                         *
**************************************************************************
    TOP.LINE = STR("*", 32):" IMPORTANT ":STR("*", 31)
    BOTTOM.LINE = TOP.LINE
    STAMP.MASK = "L#72"

    IF BUILT.FROM.FILE = "" AND BUILT.FROM.OBJECT = "" THEN
        CODE.SOURCE = OBJECT.FILENAME:" ":OBJECT.NAME
    END ELSE
        CODE.SOURCE = BUILT.FROM.FILE:" ":BUILT.FROM.OBJECT
    END

    BEGIN CASE

        CASE COMPILE.OBJECT

            GOSUB BEFORE.ADD

            CODE = " "
            GOSUB ADD.CODE

* normally we just show the "Created from" filename and object name as being
* the object.filename and object.name we're compiling.  for wrappers, however,
* this puts in the wrapper file and wrapper name and not the object where
* the wrapper resides.  for wrappers we'll override object.filename and
* object.name with built.from.file and built.from.object that are pulled
* from the command line.  the compile fires off a special ud.compile session
* for each wrapper and will use the "from" option to put the built.from.file
* and built.from.object in the command line
            CODE = TOP.LINE
            GOSUB ADD.CODE

            CODE = " Created from Object ":CODE.SOURCE
            CODE := " at ":OCONV(TIME(),"MTH"):" ":OCONV(DATE(),"D4/")
            CODE := " by ":USER.ID
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE

            CODE = " using UD.COMPILE ":PRECOMPILER.VERSION
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE

            CODE = " "
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE

            CODE = " Do not edit this program directly!  Edit the '":METHOD:"' method in "
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE
            CODE = " ":CODE.SOURCE:" and compile using UD.COMPILE."
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE
            CODE = " Enter 'COMPILE HELP WIN' from TCL for help."
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB ADD.CODE

            CODE = BOTTOM.LINE
            GOSUB ADD.CODE

            CODE = " "
            GOSUB ADD.CODE

            GOSUB AFTER.ADD

        CASE COMPILE.SUBROUTINE

            GOSUB FIND.SUBROUTINE.INSERT.LINE

            CODE = " "
            GOSUB INSERT.CODE

            CODE = TOP.LINE
            GOSUB INSERT.CODE

            CODE = " Created from Object ":CODE.SOURCE
            CODE := " at ":OCONV(TIME(),"MTH"):" ":OCONV(DATE(),"D4/")
            CODE := " by ":USER.ID
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE
            CODE = " using UD.COMPILE ":PRECOMPILER.VERSION
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE

            CODE = " "
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE

            CODE = " Do not edit this program directly!  Edit ":CODE.SOURCE
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE
            CODE = " and compile using UD.COMPILE."
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE
            CODE = " Enter 'COMPILE HELP WIN' from TCL for help."
            CODE = "*":CODE STAMP.MASK:"*"
            GOSUB INSERT.CODE

            CODE = BOTTOM.LINE
            GOSUB INSERT.CODE

            CODE = " "
            GOSUB INSERT.CODE

    END CASE

    RETURN

ADD.WRAPPER.STAMP: *******************************************************
* add a comment stamp for a wrapper                                      *
**************************************************************************
    TOP.LINE = STR("*", 32):" IMPORTANT ":STR("*", 31)
    BOTTOM.LINE = TOP.LINE
    STAMP.MASK = "L#72"

    CODE = " "
    GOSUB ADD.WRAPPER.CODE

    CODE = TOP.LINE
    GOSUB ADD.WRAPPER.CODE
    CODE = " Created from Object ":OBJECT.FILENAME:" ":OBJECT.NAME
    CODE := " at ":OCONV(TIME(),"MTH"):" ":OCONV(DATE(),"D4/")
    CODE := " by ":USER.ID
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE
    CODE = " using UD.COMPILE ":PRECOMPILER.VERSION
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE

    CODE = " "
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE

    CODE = " Do not edit this program directly!  Edit the '":METHOD:"' method in "
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE
    CODE = " ":OBJECT.FILENAME:" ":OBJECT.NAME:" and compile using UD.COMPILE."
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE
    CODE = " Enter 'COMPILE HELP WIN' from TCL for help."
    CODE = "*":CODE STAMP.MASK:"*"
    GOSUB ADD.WRAPPER.CODE

    CODE = BOTTOM.LINE
    GOSUB ADD.WRAPPER.CODE

    CODE = " "
    GOSUB ADD.WRAPPER.CODE

    RETURN

ADD.CHECKSUM.STAMP: ******************************************************
* add a comment line with the method's checksum                          *
**************************************************************************
    GOSUB BEFORE.ADD

* get checksum for this method
    LOCATE METHOD IN COMPILE.METHOD.LIST SETTING METHOD.PTR THEN
        THIS.CHECKSUM = COMPILE.METHOD.CHECKSUM.LIST<METHOD.PTR>
    END ELSE
        THIS.CHECKSUM = "NONE"
    END

* get common checksum
    COMMON.NAME = "SHARED.COMMON"
    LOCATE COMMON.NAME IN COMPILE.METHOD.LIST SETTING COMMON.PTR THEN
        THIS.COMMON.CHECKSUM = COMPILE.METHOD.CHECKSUM.LIST<COMMON.PTR>
    END ELSE
        THIS.COMMON.CHECKSUM = "NONE"
    END

    CODE = CHECKSUM.PREFIX:THIS.CHECKSUM:" ":THIS.COMMON.CHECKSUM
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.LAST.STAMP: **********************************************************
* add comment lines with the method's last change date / time and last   *
* compile date / time                                                    *
**************************************************************************
    GOSUB BEFORE.ADD

* get the last change date / time for this method
    LOCATE METHOD IN COMPILE.METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* if this method has changed since the last compile the last change date
* and time will be today.  otherwise use the value from the compile table.
* if updating last date and time is turned off only update if the date and
* time is null.  this allows us to update the last change date and time in
* dev and preserve the last change date and time as the code is pushed to the
* test and production environments
    BEGIN CASE

        CASE COMPILE.CHANGED.LIST<METHOD.PTR> AND UPDATE.LAST.CHANGE.STAMP
            LAST.CHANGE.DATE = DATE()
            LAST.CHANGE.TIME = INT(TIME())

        CASE 1
            LAST.CHANGE.DATE = COMPILE.METHOD.DATE.LIST<METHOD.PTR>
            LAST.CHANGE.TIME = COMPILE.METHOD.TIME.LIST<METHOD.PTR>

    END CASE

    IF LAST.CHANGE.DATE = "" THEN
        LAST.CHANGE.DATE = DATE()
        LAST.CHANGE.TIME = INT(TIME())
    END

* the last compile date / time will always be now
    LAST.COMPILE.DATE = DATE()
    LAST.COMPILE.TIME = INT(TIME())

    LAST.CHANGE.DATE = OCONV(LAST.CHANGE.DATE, "D4/")
    LAST.CHANGE.TIME = OCONV(LAST.CHANGE.TIME, "MTHS")

    LAST.COMPILE.DATE = OCONV(LAST.COMPILE.DATE, "D4/")
    LAST.COMPILE.TIME = OCONV(LAST.COMPILE.TIME, "MTHS")    

* add the stamps to the cbp version of the method
    CODE = LAST.VERSION.PREFIX:OBJECT.VERSION
    GOSUB ADD.CODE
    CODE = LAST.CHANGE.PREFIX:LAST.CHANGE.DATE:" ":LAST.CHANGE.TIME
    GOSUB ADD.CODE
    CODE = LAST.COMPILE.PREFIX:LAST.COMPILE.DATE:" ":LAST.COMPILE.TIME
    GOSUB ADD.CODE
    CODE = COMPILER.VERSION.PREFIX:PRECOMPILER.VERSION
    GOSUB ADD.CODE
    CODE = COMPILER.DATE.PREFIX:OCONV(PRECOMPILER.VERSION.DATE, "D4/")
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.SUBROUTINE.STAMP: ****************************************************
* add a stamp to the cbp version of an object-enabled subroutine         *
**************************************************************************
    GOSUB FIND.SUBROUTINE.INSERT.LINE

* if the subroutine changed since the last compile the last change date
* and time will be today.  otherwise keep the existing last change date and
* time from find.subroutine.checksum
    GOSUB FIND.SUBROUTINE.CHECKSUM

* update the last change date and time.  if we don't have a last change date
* and time use the current date and time.  if the checksum has changed and
* we're updating last change stamps use the current date and time.  otherwise
* we'll preserve the original date and time.  this allows us to update the
* last change date and time in the dev environments and preserve these change
* dates and times as the code is pushed into test and production environments
    BEGIN CASE

        CASE LAST.CHANGE.DATE = ""
            LAST.CHANGE.DATE = DATE()
            LAST.CHANGE.TIME = INT(TIME())

        CASE OLD.CHECKSUM <> NEW.CHECKSUM AND UPDATE.LAST.CHANGE.STAMP
            LAST.CHANGE.DATE = DATE()
            LAST.CHANGE.TIME = INT(TIME())

    END CASE

    IF LAST.COMPILE.DATE = "" THEN
        LAST.COMPILE.DATE = DATE()
        LAST.COMPILE.TIME = INT(TIME())
    END

* the last dates and times will be saved in comments, oconverted
    LAST.CHANGE.DATE = OCONV(LAST.CHANGE.DATE, "D4/")
    LAST.CHANGE.TIME = OCONV(LAST.CHANGE.TIME, "MTHS")

    LAST.COMPILE.DATE = OCONV(LAST.COMPILE.DATE, "D4/")
    LAST.COMPILE.TIME = OCONV(LAST.COMPILE.TIME, "MTHS")    

* add the checksum and last change stamps to the cbp code
    CODE = " "
    GOSUB INSERT.CODE
    CODE = CHECKSUM.PREFIX:NEW.CHECKSUM
    GOSUB INSERT.CODE
    CODE = LAST.CHANGE.PREFIX:LAST.CHANGE.DATE:" ":LAST.CHANGE.TIME
    GOSUB INSERT.CODE
    CODE = LAST.COMPILE.PREFIX:LAST.COMPILE.DATE:" ":LAST.COMPILE.TIME
    GOSUB INSERT.CODE
    CODE = COMPILER.VERSION.PREFIX:PRECOMPILER.VERSION
    GOSUB INSERT.CODE
    CODE = COMPILER.DATE.PREFIX:OCONV(PRECOMPILER.VERSION.DATE, "D4/")
    GOSUB INSERT.CODE

* add the checksum and last change stamps to the end of the obp code
    READ SUB.CODE FROM OBPFILE, SUBROUTINE.NAME THEN

        SUB.LINES = DCOUNT(SUB.CODE,AM)

        GOSUB REMOVE.SUBROUTINE.STAMPS

        IF TRIM (SUB.CODE<SUB.LINES>) = "" THEN
            STAMP.PTR = SUB.LINES + 1
        END ELSE
            STAMP.PTR = SUB.LINES + 2
        END

        CODE = CHECKSUM.PREFIX:NEW.CHECKSUM
        SUB.CODE<STAMP.PTR> = CODE

        STAMP.PTR += 1
        CODE = LAST.CHANGE.PREFIX:LAST.CHANGE.DATE:" ":LAST.CHANGE.TIME
        SUB.CODE<STAMP.PTR> = CODE

        STAMP.PTR += 1
        CODE = LAST.COMPILE.PREFIX:LAST.COMPILE.DATE:" ":LAST.COMPILE.TIME
        SUB.CODE<STAMP.PTR> = CODE

        WRITE.ERROR = @FALSE
        WRITE SUB.CODE ON OBPFILE, SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
        IF WRITE.ERROR THEN
            ERROR.FILE = "OBP"
            ERROR.ITEM = SUBROUTINE.NAME
            GOSUB WRITE.ERROR
        END

    END ELSE

        RELEASE OBPFILE, SUBROUTINE.NAME

    END

    RETURN

ADD.WRAPPER.OBP.STAMP: ***************************************************
* for wrapper code in wrapper.code fetch the last checksum, compile date *
* and time, and change date and time from the existing obp version and   *
* copy into wrapper.code.  assumes that wrapper.code has no stamps       *
**************************************************************************

* get the last checksum, compile date and time, and change date and time
* from the existing obp code
    SUBROUTINE.NAME = UPCASE (WRAPPER.SUBROUTINE.NAME)
    GOSUB FIND.SUBROUTINE.CHECKSUM

    IF LAST.CHANGE.DATE = "" THEN
        LAST.CHANGE.DATE = DATE()
        LAST.CHANGE.TIME = INT(TIME())
    END

    IF LAST.COMPILE.DATE = "" THEN
        LAST.COMPILE.DATE = DATE()
        LAST.COMPILE.TIME = INT(TIME())
    END

* the last dates and times will be saved in comments, oconverted
    LAST.CHANGE.DATE = OCONV(LAST.CHANGE.DATE, "D4/")
    LAST.CHANGE.TIME = OCONV(LAST.CHANGE.TIME, "MTHS")

    LAST.COMPILE.DATE = OCONV(LAST.COMPILE.DATE, "D4/")
    LAST.COMPILE.TIME = OCONV(LAST.COMPILE.TIME, "MTHS")    

* add these stamps to the end of the wrapper obp program
    IF TRIM (WRAPPER.CODE<WRAPPER.CODE.LINES>) = "" THEN
        STAMP.PTR = WRAPPER.CODE.LINES + 1
    END ELSE
        STAMP.PTR = WRAPPER.CODE.LINES + 2
    END

* add the stamps to the wrapper code
    CODE = CHECKSUM.PREFIX:NEW.CHECKSUM
    WRAPPER.CODE<STAMP.PTR> = CODE

    STAMP.PTR += 1
    CODE = LAST.CHANGE.PREFIX:LAST.CHANGE.DATE:" ":LAST.CHANGE.TIME
    WRAPPER.CODE<STAMP.PTR> = CODE

    STAMP.PTR += 1
    CODE = LAST.COMPILE.PREFIX:LAST.COMPILE.DATE:" ":LAST.COMPILE.TIME
    WRAPPER.CODE<STAMP.PTR> = CODE

    WRAPPER.CODE.LINES = STAMP.PTR

    RETURN

FIND.SUBROUTINE.INSERT.LINE: *********************************************
* set insert.line for object-enabled subroutines where a stamp should    *
* be inserted                                                            *
**************************************************************************
    INSERT.LINE = 0

* skip over any blank lines immediately after the subroutine statement
    START.CHECK.LINE = 0
 
    FOR CHECK.LOOP = 2 TO PROGRAM.CODE.LINES UNTIL START.CHECK.LINE <> 0
        THIS.LINE = TRIM (PROGRAM.CODE<CHECK.LOOP>)
        IF THIS.LINE <> "" THEN
            START.CHECK.LINE = CHECK.LOOP
        END
    NEXT CHECK.LOOP

    IF START.CHECK.LINE = 0 THEN
        START.CHECK.LINE = 2
    END

* find first blank or non-version, non-change line after start.check.line
    FOR CHECK.LOOP = START.CHECK.LINE TO PROGRAM.CODE.LINES UNTIL INSERT.LINE > 0
        THIS.LINE = UPCASE(PROGRAM.CODE<CHECK.LOOP>)
        IF THIS.LINE [1, 11] <> "** VERSION#" AND THIS.LINE [1, 5] <> "*** V" THEN
            INSERT.LINE = CHECK.LOOP
        END
    NEXT CHECK.LOOP

    IF INSERT.LINE = 0 THEN
        INSERT.LINE = 2
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / utility routines               **
**************************************************************************
**************************************************************************

ADD.METHOD.COMMENT.CODE: *************************************************
* add code for method comments to program.code                           *
**************************************************************************
    METHOD.COMMENT.ADDED = @FALSE
    ENDS.WITH.RETURN = @FALSE

* find method in the method table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add method comment code into the external subroutine.  we'll start
* with the method's starting line and stop one line before the program
* code starts
    GOSUB ADD.BLANK

    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR> - 1
    THIS.METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.PTR>

* if this is an inherited method fetch the called code from the object
* the method is inherited from
    IF THIS.METHOD.INHERITED THEN

        THIS.INHERIT.OBJECT = METHOD.INHERIT.OBJECT.LIST<METHOD.PTR>

        READ THIS.CALLED.CODE FROM OBJFILE, THIS.INHERIT.OBJECT ELSE
            THIS.CALLED.CODE = ""
        END

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = THIS.CALLED.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = ""
            START.LINE += 1
        REPEAT

* find the location of the character after the delimiter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(THIS.CALLED.CODE, @AM, START.LINE - 1)
        END

        GOSUB BEFORE.ADD

        SETREM START.PTR ON THIS.CALLED.CODE
        FOR LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM THIS.CALLED.CODE SETTING THROWAWAY
            GOSUB ADD.CODE

        NEXT LINE.LOOP

    END ELSE

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = ""
            START.LINE += 1
        REPEAT

* find the location of the character after the delimter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
        END

        GOSUB BEFORE.ADD

        SETREM START.PTR ON OBJECT.CODE
        FOR LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
            GOSUB ADD.CODE

        NEXT LINE.LOOP

    END

    GOSUB AFTER.SOURCE.ADD

    METHOD.COMMENT.ADDED = @TRUE

    RETURN

GET.METHOD.CODE.LINES: ***************************************************
* return the number of lines of user code is in a method                 *
**************************************************************************
    METHOD.CODE.LINES = 0

* find method in the method table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add the method's programming code into the external subroutine.  we'll
* start with the first programming code line and go to the end of the
* method.
    START.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

    METHOD.CODE.LINES = END.LINE - START.LINE + 1

    RETURN

ADD.METHOD.CODE: *********************************************************
* add code for method to program.code.  if add.return is set and the     *
* last method code line doesn't have a return a return will be added.    *
* set "INDENT" for additional indenting                                  *
**************************************************************************

* if program.code.indent was defined the user method code is already
* indented.  save the indent and restore it at the end of the routine
    SAVE.PROGRAM.CODE.INDENT = PROGRAM.CODE.INDENT
    PROGRAM.CODE.INDENT = ""

    METHOD.CODE.ADDED = @FALSE
    ENDS.WITH.RETURN = @FALSE
    METHOD.LINES.ADDED = 0

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = ""

* find method in the method table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add the method's programming code into the external subroutine.  we'll
* start with the first programming code line and go to the end of the
* method.
    START.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

* update the starting line of the source code (in the object definition)
* and the starting line of the target code (the eclipse subroutine).  we'll
* use this later to convert program error lines from ba into associated
* lines in the object source
    SOURCE.START = START.LINE
    TARGET.START = PROGRAM.CODE.LINES + 1
    SOURCE.LINE.COUNT = END.LINE - START.LINE + 1

* find the location of the character after the delimiter before
* start.line
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

* copy method code to the eclipse subroutine.  don't filter blank lines
* so that we get a one-to-one correlation between lines in the object
* and lines in the subroutine
    FILTER.BLANK.LINES = @FALSE

    GOSUB BEFORE.ADD

    SETREM START.PTR ON OBJECT.CODE

    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
        CODE = INDENT:CODE
        GOSUB ADD.CODE

        METHOD.LINES.ADDED += 1

    NEXT LINE.LOOP

    GOSUB AFTER.SOURCE.ADD

    FILTER.BLANKS = FILTER.BLANK.DEFAULT

    PROGRAM.CODE.INDENT = SAVE.PROGRAM.CODE.INDENT

* add a final error message check if requested
    IF ADD.FINAL.ERROR.CHECK THEN
        GOSUB ADD.FINAL.ERROR.CHECK
    END

* add a return.  the return isn't mandatory in the programming code so
* we'll add one to make sure we have it
    GOSUB BEFORE.ADD

    IF ADD.RETURN AND NOT(ENDS.WITH.RETURN) THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE
    END ELSE
        CODE = " "
        GOSUB ADD.CODE
    END

    GOSUB AFTER.ADD

    METHOD.CODE.ADDED = @TRUE

    RETURN

ADD.INHERITED.METHOD.CODE: ***********************************************
* add the "user" code for an inherited method                            *
**************************************************************************
    THIS.INHERITED.HANDLE = METHOD.INHERIT.HANDLE.LIST<METHOD.PTR>
    THIS.INHERITED.METHOD = METHOD.INHERIT.METHOD.LIST<METHOD.PTR>
    INHERITED.CALL.CODE = THIS.INHERITED.HANDLE:METHOD.DELIMITER:THIS.INHERITED.METHOD

    IF NOT(BRIEF) AND NOT(LIST.METHODS) AND NOT(LIST.OBJECTS.ONLY) THEN
        PRINT "        Inherited from ":
        IF UPCASE.CODE THEN
            CRT DOWNCASE (INHERITED.CALL.CODE)
        END ELSE
            CRT INHERITED.CALL.CODE
        END
    END

* figure out where the break between output and input parameters should
* be
    BEGIN CASE

* if the first parameter is byval then we have no output parameters.  the 
* break should be before the first parameter
        CASE PARAMETER.BYREF.LIST<1> = @FALSE
            PARAMETER.BREAK = 1

* if all parameters are byref then we have no input parameters.  there should
* be a break at the end
        CASE SUM(PARAMETER.BYREF.LIST) = PARAMETER.COUNT
            PARAMETER.BREAK = PARAMETER.COUNT + 1

* we have a mix of byref and byvals so we have both input and output 
* parameters.  the break should be before the first byval
        CASE 1
            PARAMETER.BREAK = 0
            FOR CHECK.LOOP = 1 TO PARAMETER.COUNT UNTIL PARAMETER.BREAK <> 0
                IF PARAMETER.BYREF.LIST<CHECK.LOOP> = @FALSE THEN
                    PARAMETER.BREAK = CHECK.LOOP
                END
            NEXT CHECK.LOOP

    END CASE

* add a line of code to call the inherited method
    CODE = INDENT:"    "

* add output (returned) parameters if we have any
    IF PARAMETER.BREAK > 1 THEN

        FOR PARAMETER.LOOP = 1 TO PARAMETER.BREAK - 1

            THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>
            CODE := THIS.PARAMETER

            IF PARAMETER.LOOP < PARAMETER.BREAK - 1 THEN
                CODE := ", "
            END

        NEXT PARAMETER.LOOP

        CODE := " = "

    END

* add the object handle and method
    CODE := INHERITED.CALL.CODE

* add the input parameters if we have any
    IF PARAMETER.BREAK <= PARAMETER.COUNT THEN

        CODE := " ("

        FOR PARAMETER.LOOP = PARAMETER.BREAK TO PARAMETER.COUNT

            THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>
            CODE := THIS.PARAMETER

            IF PARAMETER.LOOP < PARAMETER.COUNT THEN
                CODE := ", "
            END

        NEXT PARAMETER.LOOP

        CODE := ")"

    END

    GOSUB ADD.CODE

* add a return to the end of the inherited method's code
    IF ADD.RETURN THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE
    END ELSE
        CODE = " "
        GOSUB ADD.CODE
    END

    RETURN

ADD.COMMON.METHOD.CODE: **************************************************
* add code for the "common" method to program.code.  the "common"        *
* method isn't really a method.  it's a way to add common subroutines    *
* to all methods compiled for an object                                  *
**************************************************************************
    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0
    METHOD.CODE.ADDED = @FALSE

    LOCATE COMMON.ROUTINE.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* if program.code.indent was defined the common method code is already
* indented.  save the indent and restore it at the end of the routine
    SAVE.PROGRAM.CODE.INDENT = PROGRAM.CODE.INDENT
    PROGRAM.CODE.INDENT = ""

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* Common Subroutines merged from the COMMON Method"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    START.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

* update the starting line of the common code in the source (in the
* object definition) and the starting line of the target code (the
* eclipse subroutine).  we'll use this later to convert program line
* numbers during the compile output
    SOURCE.COMMON.START = START.LINE
    TARGET.COMMON.START = PROGRAM.CODE.LINES + 1
    SOURCE.COMMON.COUNT = END.LINE - START.LINE + 1

* find the location of the character after the delimter before
* start.line
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

* copy method code to the eclipse subroutine.  don't filter blank lines
* so that we get a one-to-one correlation between lines in the object
* and lines in the subroutine
    FILTER.BLANK.LINES = @FALSE

    GOSUB BEFORE.ADD

    SETREM START.PTR ON OBJECT.CODE
    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
        GOSUB ADD.CODE

    NEXT LINE.LOOP

    GOSUB AFTER.SOURCE.ADD

    FILTER.BLANK.LINES = FILTER.BLANK.DEFAULT

    METHOD.CODE.ADDED = @TRUE

    PROGRAM.CODE.INDENT = SAVE.PROGRAM.CODE.INDENT

    RETURN

ADD.COMMON.WRAPPER.CODE: *************************************************
* add code for the "common" method to program.code.  the "common"        *
* method isn't really a method.  it's a way to add common subroutines    *
* to all methods compiled for an object                                  *
**************************************************************************
    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0
    METHOD.CODE.ADDED = @FALSE

    LOCATE COMMON.ROUTINE.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* if program.code.indent was defined the common method code is already
* indented.  save the indent and restore it at the end of the routine
    SAVE.PROGRAM.CODE.INDENT = PROGRAM.CODE.INDENT
    PROGRAM.CODE.INDENT = ""

*   GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.WRAPPER.CODE
    CODE = "* Common Subroutines merged from the COMMON Method"
    GOSUB ADD.WRAPPER.CODE
    CODE = " "
    GOSUB ADD.WRAPPER.CODE

*   GOSUB AFTER.ADD

    START.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

* update the starting line of the common code in the source (in the
* object definition) and the starting line of the target code (the
* eclipse subroutine).  we'll use this later to convert program line
* numbers during the compile output
    SOURCE.COMMON.START = START.LINE
    TARGET.COMMON.START = WRAPPER.CODE.LINES + 1
    SOURCE.COMMON.COUNT = END.LINE - START.LINE + 1

* find the location of the character after the delimter before
* start.line
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

* copy method code to the eclipse subroutine.  don't filter blank lines
* so that we get a one-to-one correlation between lines in the object
* and lines in the subroutine
    FILTER.BLANK.LINES = @FALSE

*   GOSUB BEFORE.ADD

    SETREM START.PTR ON OBJECT.CODE
    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
        GOSUB ADD.WRAPPER.CODE

    NEXT LINE.LOOP

*   GOSUB AFTER.SOURCE.ADD

    FILTER.BLANK.LINES = FILTER.BLANK.DEFAULT

    METHOD.CODE.ADDED = @TRUE

    PROGRAM.CODE.INDENT = SAVE.PROGRAM.CODE.INDENT

    RETURN

ADD.COMMON.CODE.SUBROUTINE: **********************************************
* add all common code to the current program code as a subroutine        *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = PROPERTY.COMMON.CODE.SUBROUTINE.NAME:" "
    CODE = CODE:STR("*", 66 - LEN(CODE))
    GOSUB ADD.CODE
    CODE = "* Named Common area for property values"
    CODE = CODE:SPACE(64 - LEN(CODE)):" *"
    GOSUB ADD.CODE
    CODE = STR("*", 66)
    GOSUB ADD.CODE

    GOSUB ADD.COMMON.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.COMMON.CODE: *********************************************************
* add all common code to the current program code                        *
**************************************************************************
    GOSUB ADD.BLANK

    GOSUB BEFORE.ADD

    START.LINE = 0

    SETREM 0 ON COMMON.CODE
    FOR COMMON.LOOP = 1 TO COMMON.LINE.COUNT

        REMOVE CODE FROM COMMON.CODE SETTING THROWAWAY
        GOSUB ADD.CODE

    NEXT COMMON.LOOP

    GOSUB AFTER.ADD

    RETURN

ADD.WRAPPER.COMMENT.CODE: ************************************************
* add code for method comments to program.code                           *
**************************************************************************
    WRAPPER.COMMENT.ADDED = @FALSE

* find method in the method table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add method comment code into the external subroutine.  we'll start
* with the method's starting line and stop one line before the program
* code starts
    CODE = " "
    GOSUB ADD.WRAPPER.CODE

    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.PROGRAM.START.LINE<METHOD.PTR> - 1

* find the location of the character after the delimter before
* start.line
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

    SETREM START.PTR ON OBJECT.CODE
    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY
        GOSUB ADD.WRAPPER.CODE

    NEXT LINE.LOOP

    WRAPPER.COMMENT.ADDED = @TRUE

    RETURN

ADD.AUTO.DEBUG.CODE: *****************************************************
* add any code for auto debugging                                        *
**************************************************************************
    GOSUB BEFORE.ADD

* start off with a pretty comment
    IF DEBUG.METHOD.TRAIL OR DEBUG.METHOD.PARAMETERS THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* auto debugging"
        GOSUB ADD.CODE

    END

* auto debugging for the method trail.  send a debugging message each
* time a method is started
    IF DEBUG.METHOD.TRAIL THEN

        IF UPCASE.CODE THEN
            DEBUG.COMMENT = '"In ':DOWNCASE(OBJECT.NAME):METHOD.DELIMITER:DOWNCASE(METHOD):':"'
        END ELSE
            DEBUG.COMMENT = '"In ':OBJECT.NAME:METHOD.DELIMITER:METHOD:':"'
        END

        CODE = "    UD.DEBUG ":DEBUG.COMMENT:', "AUTO"'
        GOSUB ADD.CODE

    END

* auto debugging to show the method parameter values in the debugging
* window
    IF DEBUG.METHOD.PARAMETERS AND PARAMETER.COUNT > 0 THEN

        FOR DEBUG.LOOP = 1 TO PARAMETER.COUNT

            THIS.PARAMETER = PARAMETER.LIST<DEBUG.LOOP>

            CODE = "    IF UNASSIGNED(":THIS.PARAMETER:") THEN"
            GOSUB ADD.CODE

            IF UPCASE.CODE THEN
                DEBUG.COMMENT = '"  ':DOWNCASE(THIS.PARAMETER):': ":'
            END ELSE
                DEBUG.COMMENT = '"  ':THIS.PARAMETER:': ":'
            END

            DEBUG.COMMENT := '"<unassigned>"'
            CODE = "        UD.DEBUG ":DEBUG.COMMENT:', "AUTO"'
            GOSUB ADD.CODE

            CODE = "    END ELSE"
            GOSUB ADD.CODE

            IF UPCASE.CODE THEN
                DEBUG.COMMENT = '"  ':DOWNCASE(THIS.PARAMETER):': ":'
            END ELSE
                DEBUG.COMMENT = '"  ':THIS.PARAMETER:': ":'
            END

            DEBUG.COMMENT := THIS.PARAMETER
            CODE = "        UD.DEBUG ":DEBUG.COMMENT:', "AUTO"'
            GOSUB ADD.CODE

            CODE = "    END"
            GOSUB ADD.CODE

        NEXT DEBUG.LOOP

    END

    GOSUB AFTER.ADD

    RETURN

ADD.SPECIAL.CODE: ********************************************************
* add some special code to set some handy variables                      *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* handy object variables"
    GOSUB ADD.CODE

    CODE = '    CURRENT.OBJECT.NAME = "':OBJECT.NAME:'"'
    GOSUB ADD.CODE
    CODE = '    CURRENT.METHOD.NAME = "':METHOD:'"'
    GOSUB ADD.CODE
    CODE = '    CURRENT.COMPLETE.NAME = "':OBJECT.NAME:METHOD.DELIMITER:METHOD:'"'
    GOSUB ADD.CODE
    CODE = '    CURRENT.SUBROUTINE.NAME = "':SUBROUTINE.NAME:'"'
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.SPECIAL.SUBROUTINE.CODE: *********************************************
* add some special code to object-enabled subroutines to get some handy  *
* variables                                                              *
**************************************************************************
    GOSUB BEFORE.ADD

* if this routine has functions we'll insert this code before the first
* function
    GOSUB FIND.CODE.INSERT.LINE

    CODE = " "
    GOSUB INSERT.CODE
    CODE = SUBROUTINE.SPECIAL.ROUTINE.NAME:": " 
    CODE := STR("*", 75 - LEN(CODE))
    GOSUB INSERT.CODE
    CODE = "* handy object-enabled subroutine variables"
    CODE = CODE:SPACE(74 - LEN(CODE)):"*"
    GOSUB INSERT.CODE
    CODE = STR("*", 75)
    GOSUB INSERT.CODE

    CODE = '    ':ERROR.MESSAGE.VARIABLE:' = ""'
    GOSUB INSERT.CODE
    CODE = '    CURRENT.OBJECT.NAME = "':OBJECT.NAME:'"'
    GOSUB INSERT.CODE
    CODE = '    CURRENT.METHOD.NAME = "':"MAIN":'"'
    GOSUB INSERT.CODE
    CODE = '    CURRENT.COMPLETE.NAME = "':OBJECT.NAME:'"'
    GOSUB INSERT.CODE
    CODE = '    CURRENT.SUBROUTINE.NAME = "':OBJECT.NAME:'"'
    GOSUB INSERT.CODE
    CODE = " "
    GOSUB INSERT.CODE
    CODE = "    RETURN"
    GOSUB INSERT.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.SPECIAL.SUBROUTINE.CALL: *********************************************
* add a subroutine call to the "special subroutine code" to load         *
* "special" variables in an object-oriented subroutine                   *
**************************************************************************

* find the first line of code (not blank, not a comment) in the subroutine
    SETREM 0 ON PROGRAM.CODE
    FIRST.CODE.LINE = ""

* skip "subroutine" line
    REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* work through remainder of code to find first line of code
    FOR LINE.LOOP = 2 TO PROGRAM.CODE.LINES UNTIL FIRST.CODE.LINE <> ""

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY
        THIS.LINE = TRIM(THIS.LINE)

        IF THIS.LINE [1, 1] <> "*" AND THIS.LINE [1, 1] <> "!" AND THIS.LINE <> "" THEN
            FIRST.CODE.LINE = LINE.LOOP
        END
            
    NEXT LINE.LOOP

* if we couldn't find a line of code something is way amiss
    IF FIRST.CODE.LINE = "" THEN
        FIRST.CODE.LINE = 2
    END

    INSERT.LINE = FIRST.CODE.LINE
    FILTER.BLANK.LINES = @TRUE

    CODE = " "
    GOSUB INSERT.CODE
    CODE = "    GOSUB ":SUBROUTINE.SPECIAL.ROUTINE.NAME
    GOSUB INSERT.CODE
    CODE = " "
    GOSUB INSERT.CODE

    SPECIAL.CALL.LINE.COUNT = 3

    RETURN

ADD.INSTANCE.CODE: *******************************************************
* add all instance code to the current program code                      *
**************************************************************************
    IF INSTANCE.LINE.COUNT = 0 THEN
        RETURN
    END

    GOSUB BEFORE.ADD

* if the routine has any functions defined we need to insert the instance
* code before the functions
    IF FUNCTION.COUNT > 0 THEN
        GOSUB INSERT.INSTANCE.CODE
    END ELSE
        GOSUB APPEND.INSTANCE.CODE 
    END

    GOSUB AFTER.ADD

    RETURN

ADD.DUMMY.INSTANCE.CODE: *************************************************
* add empty subroutines for set.object.instance,                         *
* save.current.object.instance load.object.instance for objects that     *
* have no properties                                                     *
**************************************************************************
    CODE = " "
    GOSUB ADD.CODE
    CODE = "SET.OBJECT.INSTANCE: *****************************************************"
    GOSUB ADD.CODE
    CODE = "* dummy subroutine for setting the object instance when there are no     *"
    GOSUB ADD.CODE
    CODE = "* properties                                                             *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "     RETURN"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "SAVE.CURRENT.OBJECT.INSTANCE: ********************************************"
    GOSUB ADD.CODE
    CODE = "* dummy subroutine for saving the current object instance when there are *"
    GOSUB ADD.CODE
    CODE = "* no properties                                                          *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "LOAD.CURRENT.OBJECT.INSTANCE: ********************************************"
    GOSUB ADD.CODE
    CODE = "* dummy subroutine for loading the current object instance when there    *"
    GOSUB ADD.CODE
    CODE = "* are no properties                                                      *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    RETURN

INSERT.INSTANCE.CODE: ****************************************************
* insert the instance code before the first function definition          *
**************************************************************************

* find the last code line before the first function
    GOSUB FIND.CODE.INSERT.LINE

* this shouldn't happen but we'll catch it anyway
    IF INSERT.LINE <= 1 THEN
        GOSUB APPEND.INSTANCE.CODE
        RETURN
    END

* insert the instance code
    CODE = " "
    GOSUB INSERT.CODE

    SETREM 0 ON INSTANCE.CODE
    FOR INSTANCE.LOOP = 1 TO INSTANCE.LINE.COUNT

        REMOVE CODE FROM INSTANCE.CODE SETTING THROWAWAY
        GOSUB INSERT.CODE

    NEXT INSTANCE.LOOP

    CODE = " "
    GOSUB INSERT.CODE

    RETURN

APPEND.INSTANCE.CODE: ****************************************************
* add the instance code to the end of the program                        *
**************************************************************************
    CODE = " "
    GOSUB ADD.CODE

    SETREM 0 ON INSTANCE.CODE
    FOR INSTANCE.LOOP = 1 TO INSTANCE.LINE.COUNT

        REMOVE CODE FROM INSTANCE.CODE SETTING THROWAWAY
        GOSUB ADD.CODE

    NEXT INSTANCE.LOOP

    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.INTIME.OBJECT.CODE: **************************************************
* add code for subroutines to check for and possibly create intime       *
* objects                                                                *
**************************************************************************
    INTIME.ROUTINE.ADDED = @FALSE

* we could have the same handle variable in the table twice.  just to be 
* safe we'll keep a list of handles we've already seen
    INTIME.VARIABLE.CHECKED.LIST = ""

* look for intime objects and add a subroutine for each one
    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.CHILD.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.CHILD.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.CHILD.CREATED.WITH = CHILD.CREATED.WITH.LIST<CHILD.LOOP>
        THIS.CHILD.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.CHILD.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.CHILD.DIM = CHILD.DIM.LIST<CHILD.LOOP>

* only build the subroutine for local child objects
        IF THIS.CHILD.HANDLE = THIS.CHILD.VARIABLE THEN

            LOCATE THIS.CHILD.VARIABLE IN INTIME.VARIABLE.CHECKED.LIST SETTING ADD.INTIME.PTR ELSE

                DECODE.KEYWORD = THIS.CHILD.KEYWORD
                GOSUB DECODE.PROPERTY

                IF IS.INTIME THEN
                    GOSUB ADD.THIS.INTIME.OBJECT.CODE
                END

                INTIME.VARIABLE.CHECKED.LIST<-1> = THIS.CHILD.VARIABLE

            END

        END

    NEXT CHILD.LOOP
        
    RETURN

ADD.THIS.INTIME.OBJECT.CODE: *********************************************
* add a subroutine for an intime object                                  *
**************************************************************************

* if no intime objects have been added yet start things off
    IF NOT(INTIME.ROUTINE.ADDED) THEN
        GOSUB BEFORE.ADD
        INTIME.ROUTINE.ADDED = @TRUE
    END

    INTIME.SUB.LABEL = INTIME.OBJECT.SUBROUTINE.PREFIX:THIS.CHILD.NAME:".":THIS.CHILD.VARIABLE

    CODE = " "
    GOSUB ADD.CODE
    CODE = INTIME.SUB.LABEL:": "
    CODE := STR("*", 75 - LEN(CODE))
    GOSUB ADD.CODE
    CODE = "* build intime object ":THIS.CHILD.VARIABLE
    CODE := SPACE(74 - LEN(CODE)):"*"
    GOSUB ADD.CODE
    CODE = STR("*", 75)
    GOSUB ADD.CODE

* if the child variable is dimensioned use child.intime.ptr for the object
* array pointer when calling the routine
    IF THIS.CHILD.DIM <> "" THEN

        CHECK.CHILD.VARIABLE = THIS.CHILD.VARIABLE:"(CHILD.INTIME.PTR)"

        CODE = "    IF UNASSIGNED(CHILD.INTIME.PTR) THEN"
        GOSUB ADD.CODE
        CODE = '        CHILD.INTIME.PTR = ""'
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE
        CODE = '    IF CHILD.INTIME.PTR = "" THEN'
        GOSUB ADD.CODE
        CODE = "        RETURN"
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE

    END ELSE
        CHECK.CHILD.VARIABLE = THIS.CHILD.VARIABLE
    END

    CODE = "    IF ":CHECK.CHILD.VARIABLE:' = "" OR ':CHECK.CHILD.VARIABLE:' = "0" THEN'
    GOSUB ADD.CODE

* is this child object multi-threaded?  if so we'll create it with a "new.thread"
* keyword.  otherwise we'll use "new"
    BEGIN CASE
        CASE THIS.CHILD.KEYWORD = NEW.MULTI.THREAD.KEYWORD
            CREATE.KEYWORD = "NEW.THREAD"
        CASE THIS.CHILD.CREATED.WITH = NEW.MULTI.THREAD.KEYWORD
            CREATE.KEYWORD = "NEW.THREAD"
        CASE 1
            CREATE.KEYWORD = "NEW"
    END CASE

    BEGIN CASE

* if this child object is dimensioned add code to create the intime child
* object using a temporary object handle.  then, copy the temporary handle
* from the create to the child handle used in the call.  if this child is
* a multi-threaded object pass the array ptr in the "new.thread" command
        CASE THIS.CHILD.DIM <> "" AND CREATE.KEYWORD = "NEW.THREAD"

            TEMP.FILE.HANDLE = "TEMP.":CHANGE(THIS.CHILD.HANDLE, "()", ""):".OBJECT.HANDLE"

            CODE = "        ":TEMP.FILE.HANDLE:" = ":CREATE.KEYWORD:"(":THIS.CHILD.NAME
            CODE := ",CHILD.INTIME.PTR)"
            GOSUB ADD.CODE
            CODE = "        ":CHECK.CHILD.VARIABLE:" = ":TEMP.FILE.HANDLE
            GOSUB ADD.CODE

* if this child object is dimensioned add code to create the intime child
* object using a temporary object handle
        CASE THIS.CHILD.DIM <> ""

            TEMP.FILE.HANDLE = "TEMP.":CHANGE(THIS.CHILD.HANDLE, "()", ""):".OBJECT.HANDLE"

            CODE = "        ":TEMP.FILE.HANDLE:" = ":CREATE.KEYWORD:"(":THIS.CHILD.NAME:")"
            GOSUB ADD.CODE
            CODE = "        ":CHECK.CHILD.VARIABLE:" = ":TEMP.FILE.HANDLE
            GOSUB ADD.CODE

* create the child object as a non-dimensioned handle
        CASE 1

            CODE = "        ":CHECK.CHILD.VARIABLE:" = ":CREATE.KEYWORD:"(":THIS.CHILD.NAME:")"
            GOSUB ADD.CODE

    END CASE

    CODE = "    END"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    RETURN

ADD.REDIM.CODE: **********************************************************
* add the redimensioning code to the current program code                *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE

    SETREM 0 ON REDIM.CODE
    FOR REDIM.LOOP = 1 TO REDIM.LINE.COUNT

        REMOVE CODE FROM REDIM.CODE SETTING THROWAWAY
        GOSUB ADD.CODE

    NEXT REDIM.LOOP

    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.FUNCTION.CODE: *******************************************************
* add function code for default functions                                *
**************************************************************************
    IF NOT(ADD.FUNCTIONS) THEN
        RETURN
    END

    IF FUNCTION.DEFINITION.LINES = 0 OR FUNCTION.CODE.LINES = 0 THEN
        RETURN
    END

* find the first executable line in program.code
    INSERT.LINE = 0

    FOR LINE.LOOP = 2 TO PROGRAM.CODE.LINES UNTIL INSERT.LINE <> 0

        THIS.LINE = TRIM(PROGRAM.CODE<LINE.LOOP>)

        IF THIS.LINE <> "" THEN
            IF IS.CODE(THIS.LINE) THEN
                INSERT.LINE = LINE.LOOP
            END
        END

    NEXT LINE.LOOP

    IF INSERT.LINE = 0 THEN
        RETURN
    END

* add the function definitions
    FOR LINE.LOOP = 1 TO FUNCTION.DEFINITION.LINES

        CODE = FUNCTION.DEFINITION.CODE<LINE.LOOP>

        IF CODE [1, 1] <> "*" THEN
            PROGRAM.CODE.INDENT = "    "
        END ELSE
            PROGRAM.CODE.INDENT = ""
        END

        GOSUB INSERT.CODE

    NEXT LINE.LOOP

* add the function code at the end
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE

    FOR LINE.LOOP = 1 TO FUNCTION.CODE.LINES

        CODE = FUNCTION.CODE<LINE.LOOP>

        IF CODE [1, 1] <> "*" AND CODE [" ", 1, 1] <> "FUNCTION" THEN
            PROGRAM.CODE.INDENT = "    "
        END ELSE
            PROGRAM.CODE.INDENT = ""
        END

        GOSUB ADD.CODE

    NEXT LINE.LOOP

    GOSUB AFTER.ADD

    RETURN

ADD.FINAL.ERROR.CHECK: ***************************************************
* the last object method call may have left an error in error.message.   *
* this will pass the error back to the calling routine but it won't      *
* prefix the error with the current method name like an "exit.with"      *
* will.  this can make it difficult to see the call chain through all    *
* the methods that saw the error.  if we have an error in error.message  *
* prefix the error with the method name, update the object error log.    *
*                                                                        *
* set indent to add additional indenting                                 *
**************************************************************************
    GOSUB BEFORE.ADD
    
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* handle any error left from the last method call.  the error should"
    GOSUB ADD.CODE
    CODE = "* be prefixed with the current subroutine nmae but there are cases where"
    GOSUB ADD.CODE
    CODE = "* this doesn't happen"
    GOSUB ADD.CODE
    CODE = INDENT:'    IF ERROR.MESSAGE <> "" THEN'
    GOSUB ADD.CODE
    CODE = INDENT:'        IF ERROR.MESSAGE [1, LEN(CURRENT.COMPLETE.NAME) + 2] <> CURRENT.COMPLETE.NAME:": " THEN'
    GOSUB ADD.CODE
    CODE = INDENT:'            ERROR.MESSAGE = CURRENT.COMPLETE.NAME:": ":ERROR.MESSAGE'
    GOSUB ADD.CODE
    CODE = INDENT:'            GOSUB OBJECT.ERROR.LOGGING'
    GOSUB ADD.CODE
    CODE = INDENT:"        END"
    GOSUB ADD.CODE
    CODE = INDENT:"    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.FINAL.END: ***********************************************************
* add a final "END" to program.code if add.final.end is set.  also adds  *
* wrapup code for handling an error left by the last object method call  *
**************************************************************************
    GOSUB BEFORE.ADD

* add a final "END" to the routine if flagged
    IF ADD.FINAL.END THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE
    END

    GOSUB AFTER.ADD

    RETURN

BEFORE.ADD: **************************************************************
* initialize before adding code that's not from an object's source       *
**************************************************************************
    INSERT.LINE.PTR = PROGRAM.CODE.LINES + 1

    RETURN

AFTER.ADD: ***************************************************************
* update the source and final line xrefs after adding code that's not    *
* from an object's source                                                *
**************************************************************************
    INSERT.LINE.COUNT = (PROGRAM.CODE.LINES + 1) - INSERT.LINE.PTR
    NO.INSERT.SOURCE = @TRUE
    GOSUB INSERT.LINE.XREF

    RETURN

AFTER.SOURCE.ADD: ********************************************************
* update the source and final line xrefs after adding code that is       *
* from an object's source                                                *
**************************************************************************
    INSERT.LINE.COUNT = (PROGRAM.CODE.LINES + 1) - INSERT.LINE.PTR
    NO.INSERT.SOURCE = @FALSE
    GOSUB INSERT.LINE.XREF

    RETURN

ADD.BLANK: ***************************************************************
* add a blank line to program.code                                       *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

INITIALIZE.PROGRAM.CODE: *************************************************
* initialize the program.code array                                      *
**************************************************************************
    PROGRAM.CODE = ""
    PROGRAM.CODE.LINES = 0
    LAST.ADD.CODE = ""

    USER.CODE.START.PTR = 0
    USER.CODE.END.PTR = 0

    RETURN

ADD.CODE: ****************************************************************
* add code to program.code                                               *
**************************************************************************
    TRIM.CODE = TRIM(CODE)

* if this is a blank line and the previous line is also blank don't add
* it
    IF FILTER.BLANK.LINES THEN
        IF PROGRAM.CODE.LINES > 1 AND TRIM.CODE = "" THEN
            IF LAST.ADD.CODE = "" THEN
                RETURN
            END
        END
    END

    LAST.ADD.CODE = TRIM.CODE

* add code line to program
    PROGRAM.CODE.LINES += 1

    IF PROGRAM.CODE.LINES = 1 THEN
        PROGRAM.CODE = PROGRAM.CODE.INDENT:CODE
    END ELSE
        PROGRAM.CODE := @AM:PROGRAM.CODE.INDENT:CODE
    END

* keep a flag so we know if a section of code we're adding ends with a
* return or not
    BEGIN CASE
        CASE TRIM.CODE = ""
            NULL
        CASE TRIM.CODE = "RETURN"
            ENDS.WITH.RETURN = @TRUE
        CASE TRIM.CODE = EXIT.METHOD.KEYWORD
            ENDS.WITH.RETURN = @TRUE
        CASE 1
            ENDS.WITH.RETURN = @FALSE
    END CASE

    RETURN

FIND.CODE.INSERT.LINE: ***************************************************
* if this routine has function definitions find the line where compiler- *
* generated subroutines should be inserted.  compiler-generated          *
* subroutines have to go before the function definitions to compile      *
* correctly                                                              *
**************************************************************************

* if there are no functions the insert point would be after the last
* program line
    IF FUNCTION.COUNT = 0 THEN
        INSERT.LINE = PROGRAM.CODE.LINES + 1
        RETURN
    END

* find the last code line before the first function
    INSERT.LINE = FUNCTION.LINE.LIST<1> - 1

    LOOP
        THIS.LINE = PROGRAM.CODE<INSERT.LINE>
        FIRST.KEYWORD = UPCASE(TRIM(THIS.LINE) [" ", 1, 1])
    UNTIL (IS.CODE (THIS.LINE) AND FIRST.KEYWORD <> SECTION.KEYWORD) OR INSERT.LINE = 0
        INSERT.LINE -= 1
    REPEAT

* we'll insert after the last code line
    INSERT.LINE += 1

    RETURN

INSERT.CODE: *************************************************************
* insert code into program.code before line insert.line.  insert.line is *
* incremented after inserting                                            *
**************************************************************************

* if this is a blank line and the previous line is also blank don't add
* it
    IF FILTER.BLANK.LINES THEN
        IF INSERT.LINE > 1 AND TRIM(CODE) = "" THEN
            IF TRIM(PROGRAM.CODE<INSERT.LINE - 1>) = "" THEN
                RETURN
            END
        END
    END

* if this inserted line is at or before the first function definition
* (if we have any) bump the function definitiion lines down
    IF FUNCTION.COUNT > 0 THEN

        IF INSERT.LINE >= FUNCTION.LINE.LIST<1> THEN

            FOR FUNCTION.LOOP = 1 TO FUNCTION.COUNT
                FUNCTION.LINE.LIST<FUNCTION.LOOP> += 1
            NEXT FUNCTION.LOOP

        END

    END

* add code line to program
    INS PROGRAM.CODE.INDENT:CODE BEFORE PROGRAM.CODE<INSERT.LINE>
    PROGRAM.CODE.LINES += 1

* update line xref
    INSERT.LINE.PTR = INSERT.LINE
    INSERT.LINE.COUNT = 1
    NO.INSERT.SOURCE = @TRUE
    GOSUB INSERT.LINE.XREF

    INSERT.LINE += 1

    RETURN

FIND.CREATED.OBJECT.TYPE: ************************************************
* given check.handle return handle.create.type depending on whether      *
* the object handle was created as a child object of an object or it     *
* was created with an explicit "new" statement in "normal" code.         *
*                                                                        *
* returns:                                                               *
*                                                                        *
* handle.create.type:     "CHILD" object was created as a child          *
*                         "NEW"   object was created in normal code      *
*                         "LOCAL" object is the "local" pseudo-object    *
* handle.create.intime:   true if the object is an "intime" object       *
*                         false otherwise                                *
**************************************************************************
    HANDLE.CREATE.INTIME = @FALSE

* child objects will appear twice in the handle.list table.  it will
* be there once for when the compiler hit the "child" or "local.child"
* statement (with a type of "CHILD") and a second time for the generated
* "new" statement that creates the call to create the object.  the last
* entry will have a type of "NEW"

* objects explicitly created in code (non-child objects) will only have
* one entry in the table with a type of "NEW"

* so, if we find any entry for this object handle in the handle.list
* table with a type of "CHILD" the object was created as a child object.

* if the object is the "LOCAL" pseudo-object return its type as "LOCAL"
    IF CHECK.HANDLE = LOCAL.KEYWORD OR CHECK.HANDLE = LOCAL.OBJECT.HANDLE THEN
        HANDLE.CREATE.TYPE = LOCAL.KEYWORD
        RETURN
    END

* dimensioned objects will be opened to a temporary variable in the form
* "TEMP.objecthandle.OBJECT.HANDLE".  if we see a handle like this convert
* it back to the source dimensioned object handle
    IF CHECK.HANDLE [1, 5] = "TEMP." AND CHECK.HANDLE [14] = ".OBJECT.HANDLE" THEN
        CHECK.HANDLE = CHECK.HANDLE [6, LEN(CHECK.HANDLE) - 19]:"()"
    END

* default the handle.create.type to "new".  if we find any entries for the
* handle with a type of "CHILD" we'll change it
    HANDLE.CREATE.TYPE = "NEW"

    SEARCH.PTR = 1

    LOOP

        LOCATE CHECK.HANDLE IN CREATE.HANDLE.LIST, SEARCH.PTR SETTING CREATE.TEST.PTR THEN

            IF CREATE.TYPE.LIST<CREATE.TEST.PTR> = "CHILD" THEN

                HANDLE.CREATE.TYPE = "CHILD"

* find out if this is an "intime" child
                CHILD.CHECK.HANDLE = CHANGE(CHECK.HANDLE, "()", "")
                LOCATE CHILD.CHECK.HANDLE IN CHILD.HANDLE.LIST SETTING INTIME.PTR THEN
                    DECODE.KEYWORD = CHILD.KEYWORD.LIST<INTIME.PTR>
                    GOSUB IS.CHILD.KEYWORD
                    HANDLE.CREATE.INTIME = IS.INTIME
                END

            END

        END ELSE

            CREATE.TEST.PTR = 0

        END

    UNTIL HANDLE.CREATE.TYPE = "CHILD" OR CREATE.TEST.PTR = 0

        SEARCH.PTR += 1

    REPEAT

    RETURN

START.CREATE.TIME: *******************************************************
* set the start time and date when creating a method                     *
**************************************************************************
    CREATE.START.DATE = DATE()
    CREATE.START.TIME = TIME()

    RETURN

END.CREATE.TIME: *********************************************************
* set the end time and date when creating a method                       *
**************************************************************************
    CREATE.END.DATE = DATE()
    CREATE.END.TIME = TIME()
    CREATE.ELAPSED.TIME += TIME.ELAPSED (CREATE.START.DATE, CREATE.START.TIME)

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / inlined code                   **
**************************************************************************
**************************************************************************

CLEAR.INLINE.TABLE: ******************************************************
* reset the table of inlined objects / methods                           *
**************************************************************************
    INLINE.OBJECT.LIST = ""
    INLINE.METHOD.LIST = ""
    INLINE.SUBROUTINE.LIST = ""

    INLINE.REFERENCE.LIST = ""

    INLINE.LINE.LIST = ""
    INLINE.ALWAYS.LIST = ""

    INLINE.COUNT = 0

    LAST.INLINE.OBJECT = ""

    RETURN

BACKUP.INLINE.TABLE: *****************************************************
* create a backup copy of the inline table                               *
**************************************************************************
    SAVE.INLINE.OBJECT.LIST = INLINE.OBJECT.LIST
    SAVE.INLINE.METHOD.LIST = INLINE.METHOD.LIST
    SAVE.INLINE.SUBROUTINE.LIST = INLINE.SUBROUTINE.LIST

    SAVE.INLINE.REFERENCE.LIST = INLINE.REFERENCE.LIST

    SAVE.INLINE.LINE.LIST = INLINE.LINE.LIST
    SAVE.INLINE.ALWAYS.LIST = INLINE.ALWAYS.LIST

    SAVE.INLINE.COUNT = INLINE.COUNT

    SAVE.LAST.INLINE.OBJECT = LAST.INLINE.OBJECT

    RETURN

RESTORE.INLINE.TABLE: ****************************************************
* restore the inline table from the backup copy                          *
**************************************************************************
    INLINE.OBJECT.LIST = SAVE.INLINE.OBJECT.LIST
    INLINE.METHOD.LIST = SAVE.INLINE.METHOD.LIST
    INLINE.SUBROUTINE.LIST = SAVE.INLINE.SUBROUTINE.LIST

    INLINE.REFERENCE.LIST = SAVE.INLINE.REFERENCE.LIST

    INLINE.LINE.LIST = SAVE.INLINE.LINE.LIST
    INLINE.ALWAYS.LIST = SAVE.INLINE.ALWAYS.LIST

    INLINE.COUNT = SAVE.INLINE.COUNT

    LAST.INLINE.OBJECT = SAVE.LAST.INLINE.OBJECT

    RETURN

BACKUP.INLINE.VARIABLES: *************************************************
* create a backup copy of the current inline variables                   *
**************************************************************************
    SAVE.INLINE.OBJECT = INLINE.OBJECT
    SAVE.INLINE.METHOD = INLINE.METHOD
    SAVE.INLINE.SUBROUTINE = INLINE.SUBROUTINE
    SAVE.INLINE.LINE = INLINE.LINE

    RETURN

RESTORE.INLINE.VARIABLES: ************************************************
* restore the inline variables from the backup copy                      *
**************************************************************************
    INLINE.OBJECT = SAVE.INLINE.OBJECT
    INLINE.METHOD = SAVE.INLINE.METHOD
    INLINE.SUBROUTINE = SAVE.INLINE.SUBROUTINE
    INLINE.LINE = SAVE.INLINE.LINE

    RETURN

ADD.INLINE.CODE: *********************************************************
* add code to $include any inline routines                               *
**************************************************************************

* if we don't have any inline routines dump out
    IF INLINE.COUNT = 0 THEN
        RETURN
    END

* some lines in the inlined objects table indicate more than one
* object and/or more than one method.  explode these lines out so
* that we have a complete listing of everything in the inlined objects
* table
    GOSUB EXPLODE.INLINE.OBJECTS
    GOSUB EXPLODE.INLINE.METHODS

* if flagged in the control record remove any entries for inlined
* routines that are never called
    DELETE.UNCALLED.INLINES = ONLY.INLINE.IF.CALLED
    GOSUB DELETE.INVALID.INLINE.METHODS

* if we removed all inlined methods (none were used) exit
    IF INLINE.COUNT = 0 THEN
        RETURN
    END

    GOSUB BEFORE.ADD

* start a block for inline routines
    CODE = " "
    GOSUB ADD.CODE

    IF END.BEFORE.INLINE.CODE THEN
        CODE = "    END"
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE
    END

    GOSUB ADD.INLINE.CODE.COMMENT

* add code for any inlined routines remaining in the table
    FOR INLINE.LOOP = 1 TO INLINE.COUNT

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>
        INLINE.METHOD = INLINE.METHOD.LIST<INLINE.LOOP>
        INLINE.SUBROUTINE = INLINE.SUBROUTINE.LIST<INLINE.LOOP>

        IF NOT(BRIEF) AND NOT(LIST.METHODS) AND NOT(LIST.OBJECTS.ONLY) THEN

            DISPLAY.METHOD = INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD
            IF UPCASE.CODE THEN
                DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
            END

            COMPILING.TEXT = "        Inlined ":DISPLAY.METHOD
            IF DISPLAY.COMPILE.CBP.NAME THEN
                COMPILING.TEXT := " -> [":INLINE.SUBROUTINE:"]"
            END

            GOSUB DISPLAY.COMPILING

        END

* if end.before.inline.code is set drop an "END" to end the previous
* blob of code
*       IF END.BEFORE.INLINE.CODE AND INLINE.LOOP > 1 THEN
*           CODE = "    END"
*           GOSUB ADD.CODE
*           CODE = " "
*           GOSUB ADD.CODE
*       END

        IF INLINE.BY.MERGING.CODE THEN
            GOSUB ADD.INLINE.CODE.VERBATUM
        END ELSE
            GOSUB ADD.INLINE.CODE.INCLUDE
        END

    NEXT INLINE.LOOP

    CODE = " "
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.INLINE.CODE.COMMENT: *************************************************
* add the inline code comment block                                      *
**************************************************************************
    CODE = " "
    GOSUB ADD.CODE

    CODE = STR("*", 74)
    GOSUB ADD.CODE
    CODE = STR("*", 74)
    GOSUB ADD.CODE

    IF INLINE.BY.MERGING.CODE THEN
        CODE = "** merged code from inlined methods" "L#71":" **"
        GOSUB ADD.CODE
    END ELSE
        CODE = "** merge inline methods" "L#71":" **"
        GOSUB ADD.CODE
    END

    CODE = STR("*", 74)
    GOSUB ADD.CODE
    CODE = STR("*", 74)
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.INLINE.CODE.VERBATUM: ************************************************
* add inline code by copying from the source routine.  needs             *
* inline.code.file, inline.subroutine                                    *
**************************************************************************
* open the program file with the code to merge
    OPEN INLINE.CODE.FILE TO INLINE.HANDLE ELSE

        CODE = "* WARNING:  Can't open ":INLINE.CODE.FILE:" to include ":INLINE.SUBROUTINE
        GOSUB ADD.CODE

        OBJECT.ERROR.DESC = "Can't open ":INLINE.CODE.FILE:" to include ":INLINE.SUBROUTINE
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR

        RETURN

    END

* read the program to merge
    READ INLINE.CODE.TEXT FROM INLINE.HANDLE, INLINE.SUBROUTINE ELSE

        CODE = "* Can't read ":INLINE.CODE.FILE:" ":INLINE.SUBROUTINE
        GOSUB ADD.CODE

        OBJECT.ERROR.DESC = "Can't include ":INLINE.CODE.FILE:" ":INLINE.SUBROUTINE
        OBJECT.ERROR.DESC := ", file does not exist"
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR

        RETURN

    END

* merge the code into our exported program
    MERGE.INLINED.CODE = @TRUE
    INLINE.CODE.LINES = DCOUNT (INLINE.CODE.TEXT, @AM)

* add the "subroutine" statement (the first line of the routine) first and
* then add a comment about inserting the inlined routine.  this way if a
* nested inline routine is NOT merged into another program we won't merge
* the comment about it either
    CODE = INLINE.CODE.TEXT<1>
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    IF INLINE.OBJECT = "SUB" THEN
        CODE = "* inlined subroutine ":INLINE.CODE.FILE:" ":INLINE.SUBROUTINE
        GOSUB ADD.CODE
    END ELSE
        CODE = "* inlined method call ":INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD
        GOSUB ADD.CODE
        CODE = "*     subroutine: ":INLINE.CODE.FILE:" ":INLINE.SUBROUTINE
        GOSUB ADD.CODE
    END

    CODE = " "
    GOSUB ADD.CODE

* insert the rest of the inlined code
    FOR INLINE.CODE.LOOP = 2 TO INLINE.CODE.LINES

        CODE = INLINE.CODE.TEXT<INLINE.CODE.LOOP>
        GOSUB CHECK.INLINE.SUBROUTINE.CALL

* if we're still merging code from this program add it to the exported
* program
        IF MERGE.INLINED.CODE THEN
            GOSUB ADD.CODE
        END

    NEXT 

    RETURN

CHECK.INLINE.SUBROUTINE.CALL: ********************************************
* check inlined code "code" to see if it's a "subroutine" statement.     *
* if it is then there's an inlined subroutine in the inlined code we're  *
* merging.  returns merge.inlined.code set or unset indicating whether   *
* or not inlined code should be copied to the exported program           *
*                                                                        *
* if we've already merged this inlined subroutine or if it's already     *
* scheduled to be merged in the inlining tables we don't want to merge   *
* it now as it will end up being merged twice.                           *
*                                                                        *
* if we haven't already merged the inlined subroutine or if it's not     *
* already scheduled to be merged schedule it to be merged but odn't      *
* merge it now                                                           *
**************************************************************************

* have we hit a "subroutine" statement?  if so we've hit an inlined
* subroutine inside the inlined code we're merging
    FIRST.KEYWORD = TRIM (CODE) [" ", 1, 1]
    IF FIRST.KEYWORD <> "SUBROUTINE" THEN
        RETURN
    END

* as soon as we hit a subroutine statement we want to stop merging code
* from the inlined subroutine.  if the subroutine has already been merged
* or will be merged we'll add its code then.  if it hasn't been merged
* and is not scheduled to be merged we'll add it to the list of code to
* merged and it'll be merged later
    MERGE.INLINED.CODE = @FALSE

* get the inlined subroutine's name
    INLINED.SUBROUTINE.NAME = TRIM (CODE) [" ", 2, 1] ["(", 1, 1]

* has this inlined subroutine already been merged or is scheduled to be
* merged?  if so we don't have to do anything more
    LOCATE INLINED.SUBROUTINE.NAME IN INLINE.SUBROUTINE.LIST SETTING INLINED.PTR THEN
        RETURN
    END

* this subroutine hasn't yet been merged.  add it to the table of subroutines
* to be merged.  first get the object name and method name of the merged code.

* if the subroutine name doesn't start with the object/method prefix this is
* a "normal" subroutine and not an object / method subroutine
    IF ECLIPSE.PREFIX <> "" AND INLINED.SUBROUTINE.NAME [1, LEN (ECLIPSE.PREFIX)] <> ECLIPSE.PREFIX THEN

        INLINED.OBJECT.NAME = "SUB"
        INLINED.METHOD.NAME = INLINED.SUBROUTINE.NAME

    END ELSE

* if we aren't allowed to have nested inlined method calls exit without adding
* this nested call to the inline tables.  this subroutine won't be copied into
* the exported program and an external call will be done when this subroutine is
* called
        IF NOT (ALLOW.NESTED.INLINE.ROUTINES) THEN
            RETURN
        END

* find the name of the object in the object / method subroutine
        INLINED.OBJECT.METHOD = INLINED.SUBROUTINE.NAME [LEN (ECLIPSE.PREFIX) + 1, TO.THE.END]
        INLINED.OBJECT.NAME = ""
        INLINED.METHOD.NAME = ""

        NAME.FIELD.COUNT = DCOUNT (INLINED.OBJECT.METHOD, ECLIPSE.DELIMITER)

        FOR CHECK.FIELD.COUNT = NAME.FIELD.COUNT - 1 TO 1 STEP -1 UNTIL INLINED.OBJECT.NAME <> ""

            CHECK.OBJECT.NAME = INLINED.OBJECT.METHOD [ECLIPSE.DELIMITER, 1, CHECK.FIELD.COUNT]

            READV TEST.OBJECT FROM OBJFILE, CHECK.OBJECT.NAME, 0 THEN
                INLINED.OBJECT.NAME = CHECK.OBJECT.NAME
                INLINED.METHOD.NAME = INLINED.OBJECT.METHOD [LEN (INLINED.OBJECT.NAME) + 2, TO.THE.END]
            END

        NEXT CHECK.FIELD.COUNT

    END

* check for a recursive call.  if for some odd reason there's a recursive
* call to a method that's inlined we don't want to merge the code
    IF COMPILE.OBJECT THEN
        IF INLINED.OBJECT.NAME = OBJECT.NAME AND INLINED.METHOD.NAME = METHOD THEN
            RETURN
        END
    END
    
    IF COMPILE.SUBROUTINE THEN
        IF INLINED.OBJECT.NAME = "SUB" AND INLINED.METHOD.NAME = OBJECT.NAME THEN
            RETURN
        END
    END

* if we didn't find an object name / method name for the subroutine merge
* the code.  not sure what else to do with it
    IF INLINED.OBJECT.NAME = "" AND INLINED.METHOD.NAME = "" THEN
        MERGE.INLINED.CODE = @TRUE
        RETURN
    END

* add this call to the inlined call list.  a calling routine may be using
* the variables passed to add.inline.entry so we'll back them up and restore
* them
    GOSUB BACKUP.INLINE.VARIABLES

    INLINE.OBJECT = INLINED.OBJECT.NAME
    INLINE.METHOD = INLINED.METHOD.NAME
    INLINE.SUBROUTINE = INLINED.SUBROUTINE.NAME
    INLINE.LINE = "???"

    GOSUB ADD.INLINE.ENTRY

    GOSUB RESTORE.INLINE.VARIABLES

    RETURN

ADD.INLINE.CODE.INCLUDE: *************************************************
* add an "include" line to merge inline code.  needs inline.code.file,   *
* inline.subroutine                                                      *
**************************************************************************
    CODE = "    ":INLINE.INCLUDE.KEYWORD:" ":INLINE.CODE.FILE:" ":INLINE.SUBROUTINE
    GOSUB ADD.CODE

    RETURN

EXPLODE.INLINE.OBJECTS: **************************************************
* check for any "all" objects in the inline reference list.  if we have  *
* one add entries for all objects found.  entries will be added with     *
* whatever method is declared in the "$inline all::method" statement.    *
* if the method is "ALL" it will be exploded in explode.inline.methods   *
**************************************************************************
    FOR INLINE.LOOP = 1 TO INLINE.COUNT

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>
        INLINE.METHOD = INLINE.METHOD.LIST<INLINE.LOOP>
        INLINE.ALWAYS = INLINE.ALWAYS.LIST<INLINE.LOOP>
        INLINE.LINE = INLINE.LINE.LIST<INLINE.LOOP>

        IF INLINE.OBJECT = INLINE.ALL.OBJECTS.KEYWORD THEN

* delete the "all" object reference and add new references for each object
* and whatever method is given.  this allows us, if wanted to add the "new"
* methods for all objects by $inline-ing "all::new".  or, we can inline every
* method for every object with "all:all"
            INLINE.PTR = INLINE.LOOP
            GOSUB DELETE.INLINE.ENTRY

            FOR INLINE.OBJECT.LOOP = 1 TO HANDLE.COUNT
                INLINE.OBJECT = HANDLE.OBJECT.LIST<INLINE.OBJECT.LOOP>
                GOSUB ADD.INLINE.ENTRY
            NEXT INLINE.OBJECT.LOOP

            INLINE.LOOP -= 1

        END

    NEXT INLINE.LOOP

    RETURN

EXPLODE.INLINE.METHODS: **************************************************
* go through the list again and look for any methods that are "all"  or  *
* "PROPERTIES".  for "ALL" methods we find add an entry for each method  *
* for that object.  for "PROPERTIES" methods add the get and put         *
* subroutines for that object                                            *
**************************************************************************
    FOR INLINE.LOOP = 1 TO INLINE.COUNT

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>
        INLINE.METHOD = INLINE.METHOD.LIST<INLINE.LOOP>
        INLINE.ALWAYS = INLINE.ALWAYS.LIST<INLINE.LOOP>
        INLINE.LINE = INLINE.LINE.LIST<INLINE.LOOP>

* if the inlined method is "ALL" or "*" fetch the method list from
* the handle table and add them all
        IF INLINE.METHOD = INLINE.ALL.METHODS.KEYWORD THEN

* delete the "all" object reference and add new references for each object
* and whatever method is given.  this allows us, if wanted to add the "new"
* methods for all objects by $inline-ing "all::new".  or, we can inline every
* method for every object with "all:all"
            INLINE.PTR = INLINE.LOOP
            GOSUB DELETE.INLINE.ENTRY
            INLINE.LOOP -= 1

* find the inline method in the handle.object.list so we can get a list
* of the object's methods from handle.method.list
            LOCATE INLINE.OBJECT IN HANDLE.OBJECT.LIST SETTING INLINE.PTR THEN

                ADD.METHOD.LIST = RAISE(HANDLE.METHOD.LIST<INLINE.PTR>)
                ADD.METHOD.CALLED.LIST = RAISE(HANDLE.METHOD.CALLED.LIST<INLINE.PTR>)

                ADD.TYPE.LIST = RAISE(HANDLE.TYPE.LIST<INLINE.PTR>)
                ADD.METHOD.COUNT = DCOUNT(ADD.METHOD.LIST, @AM)

                FOR INLINE.METHOD.LOOP = 1 TO ADD.METHOD.COUNT

                    INLINE.METHOD = ADD.METHOD.LIST<INLINE.METHOD.LOOP>
                    INLINE.TYPE = ADD.TYPE.LIST<INLINE.METHOD.LOOP>

                    IF INLINE.TYPE = "METHOD" THEN
                        GOSUB ADD.INLINE.ENTRY
                    END

                NEXT INLINE.OBJECT.LOOP

            END

        END

* if the inlined method is "properties" inline the put and fetch
* subroutines.
        IF INLINE.METHOD = INLINE.PROPERTIES.KEYWORD THEN

            INLINE.PTR = INLINE.LOOP
            GOSUB DELETE.INLINE.ENTRY
            INLINE.LOOP -= 1

* add the "put property" routine
            INLINE.METHOD = PUT.KEYWORD
            INLINE.TYPE = "METHOD"
            INLINE.ALWAYS = @FALSE
            GOSUB ADD.INLINE.ENTRY

* add the "get property" routine
            INLINE.METHOD = GET.KEYWORD
            INLINE.TYPE = "METHOD"
            INLINE.ALWAYS = @FALSE
            GOSUB ADD.INLINE.ENTRY

        END

    NEXT INLINE.LOOP

    RETURN

DELETE.INVALID.INLINE.METHODS: *******************************************
* loop through the inline objects / methods and remove any that aren't   *
* in the handle table.  if delete.uncalled.inlines is true the object /  *
* method will be deleted if it wasn't called.                            *
*                                                                        *
* also, a method can't be inlined in another method for the same object. *
* things can get really messed up and its easy to get infinite compile   *
* loops from included code                                               *
*                                                                        *
* also, if the method being compiled is an inline routine and            *
* allow.nested.inline.routines is false then the current method is not   *
* allowed to have ANY inline routines                                    *
**************************************************************************
    FOR INLINE.LOOP = INLINE.COUNT TO 1 STEP -1

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>
        INLINE.METHOD = INLINE.METHOD.LIST<INLINE.LOOP>
        INLINE.SUBROUTINE = INLINE.SUBROUTINE.LIST<INLINE.LOOP>
        INLINE.ALWAYS = INLINE.ALWAYS.LIST<INLINE.LOOP>
        INLINE.LINE = INLINE.LINE.LIST<INLINE.LOOP>

* find this object and method in the object handle tables.  if they're
* not found then they aren't valid and we'll skip inline the associated
* subroutine

* if the object and method are found extract whether or not the routine
* was called from the handle table.  
        INLINE.METHOD.VALID = @TRUE
        INLINE.CALLED = @FALSE

        LOCATE INLINE.OBJECT IN HANDLE.OBJECT.LIST SETTING INLINE.PTR THEN

* if the method isn't found in the handle list then an invalid method was
* specified in the $inline command
            LOCATE INLINE.METHOD IN HANDLE.METHOD.LIST<INLINE.PTR> SETTING INLINE.METHOD.PTR THEN

                INLINE.METHOD.VALID = @TRUE

                BEGIN CASE

* the "new" and "destroy" properties are always considered used
                    CASE INLINE.METHOD = NEW.KEYWORD OR INLINE.METHOD = DESTROY.KEYWORD

                        INLINE.CALLED = @TRUE

* if the method is "REDIM" we'll consider it used or not depending on
* the control settings.  if it was added explicitly then inline.called
* will be set and we'll use inline.called
                    CASE INLINE.METHOD = REDIM.KEYWORD

                        INLINE.CALLED = @FALSE

                        FOR CHECK.HANDLE.LOOP = 1 TO HANDLE.COUNT UNTIL INLINE.CALLED
                            IF HANDLE.OBJECT.LIST<CHECK.HANDLE.LOOP> = INLINE.OBJECT THEN
                                LOCATE REDIM.KEYWORD IN HANDLE.METHOD.LIST<CHECK.HANDLE.LOOP> SETTING CHECK.METHOD.PTR THEN
                                    INLINE.CALLED = HANDLE.METHOD.CALLED.LIST<INLINE.PTR, INLINE.METHOD.PTR>
                                END
                            END
                        NEXT CHECK.HANDLE.LOOP

                        IF NOT(INLINE.CALLED) AND INLINE.REDIM.WITH.ALL THEN
                            INLINE.CALLED = @TRUE
                        END

* if the method is the property "get" or "put" routine look through all
* properties for the method and see if any of them are used.  if they are
* then we'll consider the "get" and "put" to be used
                    CASE INLINE.METHOD = PUT.KEYWORD OR INLINE.METHOD = GET.KEYWORD

                        GOSUB CHECK.PROPERTY.USED

* anything else, check the handle table to see if it was called
                    CASE 1

                        INLINE.CALLED = @FALSE

                        FOR CHECK.HANDLE.LOOP = 1 TO HANDLE.COUNT UNTIL INLINE.CALLED
                            IF HANDLE.OBJECT.LIST<CHECK.HANDLE.LOOP> = INLINE.OBJECT THEN
                                LOCATE INLINE.METHOD IN HANDLE.METHOD.LIST<CHECK.HANDLE.LOOP> SETTING CHECK.METHOD.PTR THEN
                                    INLINE.CALLED = HANDLE.METHOD.CALLED.LIST<CHECK.HANDLE.LOOP, CHECK.METHOD.PTR>
                                END
                            END
                        NEXT CHECK.HANDLE.LOOP

                END CASE

            END ELSE

* show an error for the invalid method
                OBJECT.WARNING.DESC = "Can't inline ":'"':INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD:'",'
                OBJECT.WARNING.DESC := " invalid Method.  Ignored."
                OBJECT.WARNING.LINE = INLINE.LINE
                GOSUB PRINT.OBJECT.WARNING

                INLINE.METHOD.VALID = @FALSE

            END

        END ELSE

* show an error for the invalid object
            OBJECT.WARNING.DESC = "Can't inline ":'"':INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD:'",'
            OBJECT.WARNING.DESC := " invalid Object.  Ignored."
            OBJECT.WARNING.LINE = INLINE.LINE
            GOSUB PRINT.OBJECT.WARNING

            INLINE.METHOD.VALID = @FALSE

        END

* decide if we want to delete this inline entry
        DELETE.THIS.ENTRY = @FALSE

        BEGIN CASE

* if inlining daisy-chained calls is enabled this overrides the usual
* inlining flags.  this allows enabling / disabling the daisy-chained
* calls by themselves
            CASE INLINE.OBJECT = "STRING" AND NOT(INLINE.CALLED)
                DELETE.THIS.ENTRY = @TRUE
            CASE INLINE.OBJECT = "STRING" AND ALLOW.INLINE.DAISY.CHAINED
                NULL
            CASE INLINE.OBJECT = "STRING" AND NOT (ALLOW.INLINE.DAISY.CHAINED)
                DELETE.THIS.ENTRY = @TRUE

* if compiling a method and "allow inline own methods" is turned off
* and the current object is the same as the inlined object then inlining this
* call is not allowed
            CASE COMPILE.OBJECT AND NOT(ALLOW.INLINE.OWN.METHODS) AND INLINE.OBJECT = OBJECT.NAME
                DELETE.THIS.ENTRY = @TRUE

* if compiling a method and "allow nested inline routines" is turned off
* and the current method is in inline method then NO inline methods will
* be allowed
            CASE COMPILE.OBJECT AND NOT(ALLOW.NESTED.INLINE.ROUTINES) AND METHOD.TYPE = "INLINE"
                DELETE.THIS.ENTRY = @TRUE

* if the routine was added specifically (not through an "ALL") then
* inline.alway will be true.  add it whether it's used or not
            CASE INLINE.ALWAYS
                NULL

* anything using the "sub" pseudo-object will have been called
            CASE INLINE.METHOD = SUBROUTINE.CALL.KEYWORD
                NULL

* method isn't found in the handle table--it's invalid.  delete this entry
            CASE NOT(INLINE.METHOD.VALID)
                DELETE.THIS.ENTRY = @TRUE

* method may be valid but it wasn't called.  delete it from the list
            CASE DELETE.UNCALLED.INLINES AND NOT(INLINE.CALLED)
                DELETE.THIS.ENTRY = @TRUE

        END CASE

* if we got this far with delete.this.entry false then we have a routine
* we want to inline.  it's possible that this routine may already be $inserted
* or $included with a manual $insert or $include code line.  if so it will
* appear in the code.insert.file.list table.  if the routine does exist in
* code.insert.file.list then it was already be $inserted or $included so
* delete it from the inline routine list
        IF NOT(DELETE.THIS.ENTRY) THEN
            LOCATE INLINE.SUBROUTINE IN CODE.INSERT.ITEM.LIST SETTING SUB.INLINE.PTR THEN
                DELETE.THIS.ENTRY = @TRUE
            END
        END

* delete the inline entry if we didn't survive all the edits
        IF DELETE.THIS.ENTRY THEN

            INLINE.PTR = INLINE.LOOP
            GOSUB DELETE.INLINE.ENTRY
        END

    NEXT INLINE.LOOP

    RETURN

CHECK.PROPERTY.USED: *****************************************************
* check the object handle table to see if any property references for    *
* inline.object are used                                                 *
**************************************************************************

* inline.object could have multiple handles in the handle object table.
* we'll check all of them until we find a property that's used
    INLINE.CALLED = @FALSE

    FOR CHECK.HANDLE.LOOP = 1 TO HANDLE.COUNT UNTIL INLINE.CALLED

        CHECK.OBJECT.NAME = HANDLE.OBJECT.LIST<CHECK.HANDLE.LOOP>

        IF CHECK.OBJECT.NAME = INLINE.OBJECT THEN

            CHECK.METHOD.LIST = RAISE(HANDLE.METHOD.LIST<CHECK.HANDLE.LOOP>)
            CHECK.TYPE.LIST = RAISE(HANDLE.TYPE.LIST<CHECK.HANDLE.LOOP>)
            CHECK.CALLED.LIST = RAISE(HANDLE.METHOD.CALLED.LIST<CHECK.HANDLE.LOOP>)
            CHECK.COUNT = DCOUNT(CHECK.METHOD.LIST, @AM)

            FOR CHECK.LOOP = 1 TO CHECK.COUNT UNTIL INLINE.CALLED

                THIS.TYPE = CHECK.TYPE.LIST<CHECK.LOOP>
                DECODE.KEYWORD = THIS.TYPE
                GOSUB DECODE.PROPERTY

                IF IS.PROPERTY OR IS.STATIC OR IS.CONSTANT OR IS.CHILD THEN
                    INLINE.CALLED = CHECK.CALLED.LIST<CHECK.LOOP>
                END

            NEXT CHECK.LOOP

        END

    NEXT CHECK.HANDLE.LOOP

    RETURN

ADD.INLINE.ENTRY: ********************************************************
* Add a new inline entry using inline.object, inline.method,             *
* inline.always and inline.line                                          *
**************************************************************************                      
    ADD.INLINE.TO.TABLE = @TRUE

* build the subroutine name for the inline object / method
    BEGIN CASE

* for daisy-chained calls (calls to the "string" object) evaluate whether
* or not to inline the routine separately from the other inlining flags
        CASE INLINE.OBJECT = "STRING" AND ALLOW.INLINE.DAISY.CHAINED
            INLINE.SUBROUTINE = ECLIPSE.PREFIX:INLINE.OBJECT:ECLIPSE.DELIMITER:INLINE.METHOD

        CASE INLINE.OBJECT = "STRING" AND NOT(ALLOW.INLINE.DAISY.CHAINED)
            ADD.INLINE.TO.TABLE = @FALSE
            INLINE.SUBROUTINE = ""

* for calls to the "sub" pseudo-object the subroutine name is the method
* name and inline.always should be set.  a method of "sub" will only generate
* a call to add.inline.entry if the "sub" call is hit in the code so we
* know it's being called
        CASE INLINE.OBJECT = SUBROUTINE.CALL.KEYWORD
            INLINE.SUBROUTINE = INLINE.METHOD
            INLINE.ALWAYS = @TRUE

* local calls may not allow inlining
        CASE INLINE.OBJECT = LOCAL.KEYWORD AND NOT(ALLOW.INLINE.OWN.METHODS)
            ADD.INLINE.TO.TABLE = @FALSE
            INLINE.SUBROUTINE = ""

* if we're compiling an object and allow.inline.in.methods is not set then
* don't inline the routine
        CASE COMPILE.OBJECT AND NOT(ALLOW.INLINE.IN.METHODS)
            ADD.INLINE.TO.TABLE = @FALSE
            INLINE.SUBROUTINE = ""

* if we're compiling an object-enabled subroutine and allow.inline.in.subroutines
* is not set then don't inline the routine
        CASE COMPILE.SUBROUTINE AND NOT(ALLOW.INLINE.IN.SUBROUTINES)
            ADD.INLINE.TO.TABLE = @FALSE
            INLINE.SUBROUTINE = ""

* for any other call build the eclipse subroutine name
        CASE 1
            INLINE.SUBROUTINE = ECLIPSE.PREFIX:INLINE.OBJECT:ECLIPSE.DELIMITER:INLINE.METHOD

    END CASE

* if we've already got this object / method in our inline tables don't add
* it again
    INLINE.REFERENCE = INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD
    LOCATE INLINE.REFERENCE IN INLINE.REFERENCE.LIST SETTING INLINE.REFERENCE.PTR THEN
        ADD.INLINE.TO.TABLE = @FALSE
    END ELSE
        INLINE.REFERENCE.PTR = 0
    END

    BEGIN CASE
    
* if everything's good add the object / method to the inline table.
        CASE ADD.INLINE.TO.TABLE
            INLINE.COUNT += 1

            INLINE.OBJECT.LIST<INLINE.COUNT> = INLINE.OBJECT
            INLINE.METHOD.LIST<INLINE.COUNT> = INLINE.METHOD

            INLINE.REFERENCE.LIST<INLINE.COUNT> = INLINE.OBJECT:METHOD.DELIMITER:INLINE.METHOD
            INLINE.SUBROUTINE.LIST<INLINE.COUNT> = INLINE.SUBROUTINE

            INLINE.ALWAYS.LIST<INLINE.COUNT> = INLINE.ALWAYS
            INLINE.LINE.LIST<INLINE.COUNT> = LINE.LOOP

* if we aren't adding to the inline table (it's already there) update
* in.line.always.list if inline.always is set
        CASE INLINE.ALWAYS AND INLINE.REFERENCE.PTR > 0
            INLINE.ALWAYS.LIST<INLINE.REFERENCE.PTR> = @TRUE

    END CASE

    LAST.INLINE.OBJECT = INLINE.OBJECT

    RETURN

DELETE.INLINE.ENTRY: *****************************************************
* delete inline entry at inline.ptr                                      *
**************************************************************************
    DEL INLINE.OBJECT.LIST<INLINE.PTR>
    DEL INLINE.METHOD.LIST<INLINE.PTR>

    DEL INLINE.REFERENCE.LIST<INLINE.PTR>
    DEL INLINE.SUBROUTINE.LIST<INLINE.PTR>

    DEL INLINE.ALWAYS.LIST<INLINE.PTR>
    DEL INLINE.LINE.LIST<INLINE.PTR>

    INLINE.COUNT -= 1
    
    RETURN

LIST.INLINE: *************************************************************
* display inline table for debugging                                     *
**************************************************************************
    PRINT "InlineObject........ InlineMethod........ AlwaysAdd. Line.."

    FOR INLINE.LOOP = INLINE.COUNT TO 1 STEP -1

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>
        INLINE.METHOD = INLINE.METHOD.LIST<INLINE.LOOP>
        INLINE.ALWAYS = INLINE.ALWAYS.LIST<INLINE.LOOP>
        INLINE.LINE = INLINE.LINE.LIST<INLINE.LOOP>

        PRINT INLINE.OBJECT "L#20":" ":
        PRINT INLINE.METHOD "L#20":" ":
        PRINT INLINE.ALWAYS "L#10":" ":
        PRINT INLINE.LINE "R#6"

    NEXT INLINE.LOOP

    PRINT

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / adding source code comments                        **
**************************************************************************
**************************************************************************

ADD.SOURCE.CODE.COMMENTS: ************************************************
* add each source code line as a comment ahead of the source code        *
**************************************************************************
    BEGIN CASE
        CASE OBJECT.CODE.LINES < 1000
            LINE.NUMBER.WIDTH = 3
        CASE OBJECT.CODE.LINES < 10000
            LINE.NUMBER.WIDTH = 4
        CASE OBJECT.CODE.LINES < 100000
            LINE.NUMBER.WIDTH = 5
        CASE 1
            LINE.NUMBER.WIDTH = 6
    END CASE

    LINE.NUMBER.MASK = "R%":LINE.NUMBER.WIDTH
    PROGRAM.CODE.INDENT = SPACE(LINE.NUMBER.WIDTH + 3)

    NEW.OBJECT.CODE = ""
    LAST.IS.CODE.LINE = @TRUE
    LAST.LINE = ""

* determine the code line to start on.  this will usually be the second
* line but if the second line wraps keep moving ahead until we get to
* the first code line that doesn't wrap
    LINE.LOOP = 1
    GOSUB SKIP.OVER.DEFINITIONS
    START.SOURCE.LINE = LINE.LOOP

* beginning with the first line found above add a comment for each code
* line
    FOR LINE.LOOP = START.SOURCE.LINE TO OBJECT.CODE.LINES

        GOSUB SKIP.OVER.DEFINITIONS

* if this line wraps to the next one we want to show the entire unwrapped
* line as one comment block
        IN.METHOD.DEFINITION = @FALSE
        FIRST.LINE.PTR = LINE.LOOP
        NEXT.LINE.PTR = LINE.LOOP + 1
        GOSUB CHECK.LINE.WRAPPING

        IF THIS.LINE.WRAPS THEN
            GOSUB FIND.WRAP.LINES
            THIS.LINE.WRAPS = @TRUE
        END ELSE
            WRAP.LINES = 1
        END

* if this line is a code line add the source code as comments
        THIS.LINE = OBJECT.CODE<LINE.LOOP>
        CHECK.LINE = LINE.WITHOUT.LABEL(THIS.LINE)
        IS.CODE.LINE = IS.CODE(CHECK.LINE)

        IF IS.CODE.LINE THEN

* if the previous line was not a code line and wasn't null add a blank line
* to make things more readable
            IF NOT(LAST.IS.CODE.LINE) AND LAST.LINE <> "" THEN
                NEW.OBJECT.CODE := @AM
            END

* add the first line of code as a comment
            SOURCE.COMMENT = "* ":LINE.LOOP LINE.NUMBER.MASK:" ":THIS.LINE
            NEW.OBJECT.CODE := @AM:SOURCE.COMMENT

* if there are later lines that wrap to this one add them as comments
* as well
            IF THIS.LINE.WRAPS THEN
                FOR WRAP.LOOP = 1 TO WRAP.LINES
                    THIS.LINE = OBJECT.CODE<LINE.LOOP + WRAP.LOOP>
                    SOURCE.COMMENT = "* ":(LINE.LOOP + WRAP.LOOP ) LINE.NUMBER.MASK:" ":THIS.LINE
                    NEW.OBJECT.CODE := @AM:SOURCE.COMMENT
                NEXT WRAP.LOOP
            END

        END

* add the first code line
        THIS.LINE = OBJECT.CODE<LINE.LOOP>
        NEW.OBJECT.CODE := @AM:PROGRAM.CODE.INDENT:THIS.LINE

* if the line wraps add the wrapped lines
        IF THIS.LINE.WRAPS THEN
            FOR WRAP.LOOP = 1 TO WRAP.LINES
                THIS.LINE = OBJECT.CODE<LINE.LOOP + 1>
                NEW.OBJECT.CODE := @AM:PROGRAM.CODE.INDENT:THIS.LINE
                LINE.LOOP += 1
            NEXT WRAP.LOOP
        END

* if the next line isn't a blank line add a blank line to make it easier
* to read
        IF IS.CODE.LINE THEN
            NEXT.LINE = OBJECT.CODE<LINE.LOOP + 1>
            IF TRIM(NEXT.LINE) <> "" THEN
                NEW.OBJECT.CODE := @AM
            END
        END

        LAST.IS.CODE.LINE = IS.CODE.LINE
        LAST.LINE = THIS.LINE

    NEXT LINE.LOOP

    OBJECT.CODE = NEW.OBJECT.CODE
    OBJECT.CODE.LINES = DCOUNT(OBJECT.CODE, @AM)

    RETURN

SKIP.OVER.DEFINITIONS: ***************************************************
* when adding source comments, if the object.code<line.loop> line is     *
* some kind of definition, ie, subroutine, object, method, move          *
* line.loop so that it points to one line past the definition            *
**************************************************************************

* get the first word in this line so we can see if it's some sort of
* definition, ie, an object definition or subroutine or method or whatever
    THIS.SOURCE.LINE = OBJECT.CODE<LINE.LOOP>

    IF TRIM(THIS.SOURCE.LINE) = "" THEN
        RETURN
    END

    CHECK.SOURCE.LINE = LINE.WITHOUT.LABEL(THIS.SOURCE.LINE)

    FIRST.WORD = UPCASE(TRIM(CHECK.SOURCE.LINE) [" ", 1, 1])
    DECODE.KEYWORD = FIRST.WORD
    GOSUB DECODE.METHOD

    IF NOT(IS.SUBROUTINE OR IS.OBJECT OR IS.PH.ARGS OR IS.METHOD) THEN
        RETURN
    END
       
* this line is some sort of object definition.  unwrap any following lines
* and then move line.loop to point after the definition
    DEF.START.LINE = LINE.LOOP
    DEF.END.LINE = LINE.LOOP

    LOOP

        IN.METHOD.DEFINITION = @TRUE
        FIRST.LINE.PTR = DEF.END.LINE
        NEXT.LINE.PTR = DEF.END.LINE + 1
        GOSUB CHECK.LINE.WRAPPING

    UNTIL NOT(THIS.LINE.WRAPS)

        DEF.END.LINE += 1

    REPEAT

* copy the first lines of the object code to the new object code
    FOR COPY.LOOP = DEF.START.LINE TO DEF.END.LINE

        IF NEW.OBJECT.CODE <> "" THEN
            NEW.OBJECT.CODE := @AM
        END

        NEW.OBJECT.CODE := PROGRAM.CODE.INDENT:OBJECT.CODE<COPY.LOOP>

    NEXT LINE.LOOP

    LINE.LOOP = DEF.END.LINE + 1

    RETURN


**************************************************************************
**************************************************************************
** code conversion / line number cross reference                        **
**************************************************************************
**************************************************************************

INIT.LINE.XREF: **********************************************************
* initialize the program.code.source.list and program.code.final.list    *
* tables.  these tables serve as a cross reference between the original  *
* code (program.code.source.list) and the final, converted code          *
* (program.code.final.list)                                              *
**************************************************************************

* we'll build a table here of original program line numbers to new
* program line numbers.  if fix.unresolved.references is turned off
* these numbers will always be the same.  if its turned on additional
* lines could be added in to make it compatible with eclipse's
* precompiler
    PROGRAM.CODE.SOURCE.LIST = ""
    PROGRAM.CODE.FINAL.LIST = ""

    PROGRAM.CODE.ADDED.LINES = 0

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES
        PROGRAM.CODE.SOURCE.LIST := LINE.LOOP:@AM
        PROGRAM.CODE.FINAL.LIST := LINE.LOOP:@AM
    NEXT LINE.LOOP

    RETURN

INSERT.LINE.XREF: ********************************************************
* insert.line.count program lines have been saved at insert.line.ptr.    *
* adjust program.code.source.list and program.code.final.list to take    *
* the inserted lines into account                                        *
**************************************************************************
    IF INSERT.LINE.COUNT = 0 THEN
        RETURN
    END

* get the line number from the source code where we're going to insert
* the new lines.  if this value is null then we're adding new lines to
* the end of the program
    SOURCE.LINE.PTR = PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR>

    BEGIN CASE

        CASE SOURCE.LINE.PTR <> ""
            NULL

        CASE INSERT.LINE.PTR = 1
            PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR> = 1
            PROGRAM.CODE.FINAL.LIST<INSERT.LINE.PTR> = 1
            SOURCE.LINE.PTR = 1

        CASE 1
            PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR> = PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR - 1> + 1
            PROGRAM.CODE.FINAL.LIST<INSERT.LINE.PTR> = PROGRAM.CODE.FINAL.LIST<INSERT.LINE.PTR - 1> + 1
            SOURCE.LINE.PTR = PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR>

    END CASE

* if the inserted code isn't expanded from existing code then it has no
* source line number.  "*" will indicated an inserted line of code with
* no source line
    IF NO.INSERT.SOURCE THEN
        NEW.SOURCE.LINE.PTR = "*"
    END ELSE
        NEW.SOURCE.LINE.PTR = START.LINE
    END

* duplicate the source line number in the source xref for the lines we've
* added
    FOR INSERT.XREF.LOOP = 1 TO INSERT.LINE.COUNT

        PROGRAM.CODE.ADDED.LINES += 1
        PROGRAM.CODE.SOURCE.LIST<INSERT.LINE.PTR + INSERT.XREF.LOOP - 1> = NEW.SOURCE.LINE.PTR:@AM:SOURCE.LINE.PTR

        IF NOT(NO.INSERT.SOURCE) THEN
            NEW.SOURCE.LINE.PTR += 1
        END

    NEXT INSERT.XREF.LOOP

* update empty lines at the end of the final xref
    FOR UPDATE.XREF.LOOP = PROGRAM.CODE.LINES TO 1 STEP -1 UNTIL PROGRAM.CODE.FINAL.LIST<UPDATE.XREF.LOOP> <> ""
        PROGRAM.CODE.FINAL.LIST<UPDATE.XREF.LOOP> = UPDATE.XREF.LOOP
    NEXT UPDATE.XREF.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / main conversion routine                            **
**************************************************************************
**************************************************************************

CONVERT.ROUTINE: *********************************************************
* convert all object statements in program.code to eclipse-type calls.   *
* code comes in program.code<>, is converted, and is the converted       *
* code is returned in program.code<>                                     *
*                                                                        *
* for some special modes (ie, listing objects) load.shortcuts,           *
* load.macros and convert.routines may be false to skip over parts of    *
* the code conversion to speed things up                                 *
**************************************************************************
    IF DETAILS THEN
        PRINT
        PRINT "Converting Calls"
        PRINT
    END

    CONVERT.START.DATE = DATE()
    CONVERT.START.TIME = TIME()

    CHECK.PROGRAM.CODE.LINES = DCOUNT(PROGRAM.CODE, @AM)

* count of objects created in only this routine
    OBJECT.CREATE.COUNT = 0

* object handle stack for "with" statements
    WITH.STACK = ""
    CURRENT.WITH = ""

    IF COMPILE.OBJECT THEN
        CURRENT.WITH = DEFAULT.WITH.OBJECT
    END

* convert array assignments
    IF CONVERT.DYNAMIC.INITIALIZING THEN
        GOSUB CONVERT.ARRAY.ASSIGNMENTS
    END

* convert "other" programming shortcuts
    IF ENABLE.PROGRAM.SHORTCUTS AND LOAD.SHORTCUTS THEN
        GOSUB CONVERT.SHORTCUTS
    END

* convert macross
    IF ENABLE.MACROS AND LOAD.MACROS THEN

        IF ENABLE.TEMPORARY.MACROS THEN
            GOSUB ADD.TEMPORARY.MACROS
        END

        GOSUB CONVERT.MACROS

        IF ENABLE.TEMPORARY.MACROS THEN
            GOSUB REMOVE.TEMPORARY.MACROS
        END

    END

* associated tables
    IF ENABLE.ASSOCIATED.TABLES THEN
        GOSUB CONVERT.ASSOCIATED
    END

* unary functions
    IF ENABLE.UNARY.FUNCTIONS THEN
        GOSUB CONVERT.UNARY.FUNCTIONS
    END

* if brace conversion is enabled convert brace expressions
    IF ENABLE.BRACES THEN
        GOSUB CONVERT.BRACES
    END

* if object creation within a "with" statement is enabled check for and
* convert any found
    IF ALLOW.OBJECT.CREATION.IN.WITH THEN
        GOSUB EXPAND.CREATION.WITH
    END

* find all program lines with object creation / naming / destroying
    GOSUB BUILD.OBJECT.USAGE.TABLE

* convert program lines with new(object.name) and old(object.name)
    IF CONVERT.ROUTINES THEN
        GOSUB CONVERT.OBJECT.CREATION.LINES
    END

* build a complete table of eclipse common variables and common
* constants, including any included code in the current program
    INCLUDE.CODE = PROGRAM.CODE

    COMMON.START.DATE = DATE()
    COMMON.START.TIME = TIME()

    IF CONVERT.ROUTINES THEN
        GOSUB BUILD.INCLUDE.TABLES
        GOSUB GET.COMPLETE.COMMON.VARIABLES
    END

    COMMON.END.DATE = DATE()
    COMMON.END.TIME = TIME()
    COMMON.ELAPSED.TIME += TIME.ELAPSED (COMMON.START.DATE, COMMON.START.TIME)

* we'll print a warning if any debugging code is found and converted
    ROUTINE.HAS.DEBUG.CODE = @FALSE

* convert object calls in the code to eclipse subroutine calls
    IF CONVERT.ROUTINES THEN
        GOSUB CONVERT.OBJECT.CALLS
    END

* convert all literal text expressions with spaces
    IF SCAN.ALL.LITERAL.TEXT AND CONVERT.ROUTINES THEN
        GOSUB CONVERT.ALL.LITERAL.TEXT
    END

* if any debugging code was converted show a warning so that (hopefully)
* debugging code won't make it into production
    IF ROUTINE.HAS.DEBUG.CODE THEN
        PRINT "        WARNING: This routine has debugging code"
    END

    CONVERT.END.DATE = DATE()
    CONVERT.END.TIME = TIME()
    CONVERT.LINE.COUNT += 1
    CONVERT.ELAPSED.TIME += TIME.ELAPSED (CONVERT.START.DATE, CONVERT.START.TIME)

    RETURN

CONVERT.OBJECT.CALLS: ****************************************************
* loop through the program and look at the first keyword in each line.   *
* if this keyword matches any of our object keywords                     *
* (objecthandle.method) then replace the keyword with the approrpriate   *
* subroutine call                                                        *
**************************************************************************
    CONVERT.CALL.START.DATE = DATE()
    CONVERT.CALL.START.TIME = TIME()

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        CHECK.UNRESOLVED.REFERENCES = @TRUE
        ALL.UNRESOLVED.FIXED = @FALSE
        NO.UNRESOLVED.FIXED = @FALSE
        ALLOW.EXTRAS.RIGHT.OF.EQUALS = NOT(FIX.UNRESOLVED.REFERENCES)

        THIS.LINE = PROGRAM.CODE<LINE.LOOP>
        GOSUB CONVERT.THIS.LINE

* if we're fixing unresolved references see if we can fix them
        IF FIX.UNRESOLVED.REFERENCES AND UNRESOLVED.REFERENCE.FOUND THEN
            GOSUB FIX.UNRESOLVED.ENTRIES
        END ELSE
            FIX.CODE.LIST = ""
            FIXED.CODE.COUNT = 0
        END

* if we had an unresolved reference and we couldn't or didn't fix all
* of them show an error
        IF UNRESOLVED.REFERENCE.FOUND AND NOT(ALL.UNRESOLVED.FIXED) THEN
            OBJECT.ERROR.DESC = "Unresolved / unknown object reference"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @TRUE
            GOSUB PRINT.OBJECT.ERROR
        END

* if we converted this line and error throws are turned on add additional
* code to handle the error throwing.  if the program has no labels then
* there can't be any error throwing so we'll skip it if there aren't any.
* if the line was converted to a comment (ie, a "with" or "end with") don't
* add anything
        IF NEW.LINE [1, 1] <> "*" THEN

            IF NEW.LINE <> "" AND NEW.LINE <> THIS.LINE AND LABEL.COUNT > 0 THEN
                GOSUB ADD.ERROR.LOGGING.CODE
            END

            IF NEW.LINE <> "" AND NEW.LINE <> THIS.LINE THEN
                GOSUB ADD.ERROR.THROW.CODE
            END

        END

* if we aren't trying to fix unresolved references or if we didn't
* have any references we couldn't convert normally (without adding
* program code) the final program line will be converted into a single
* program line.  put it back into the program and we're done.  since
* the program line converted to a single program line we'll only have
* one entry in the program code xref
        IF FIXED.CODE.COUNT = 0 THEN

* if the line was converted overwrite the old program line
            IF NEW.LINE <> "" THEN
                PROGRAM.CODE<LINE.LOOP> = NEW.LINE
            END

        END ELSE

* we had to fix some unresolved entries so we have code in fixed.code.
* merge the fixed.code code into program.code.  this will insert new
* program lines into program.code so we need to update our program line
* xref property
            GOSUB MERGE.FIX.CODE

        END

    NEXT LINE.LOOP

    CONVERT.CALL.END.DATE = DATE()
    CONVERT.CALL.END.TIME = TIME()
    CONVERT.CALL.ELAPSED.TIME += TIME.ELAPSED (CONVERT.CALL.START.DATE, CONVERT.CALL.START.TIME)

    RETURN

CHECK.THROWN.ERRORS: *****************************************************
* if disable.thrown.if.unused and enable.error.throws check the code     *
* to see if error throws are being used.  if they are then leave         *
* enable.error.throws set.  if not turn off enable.error.throws          *
**************************************************************************
    ERROR.THROWS.USED = @FALSE

    IF NOT(DISABLE.THROWN.IF.UNUSED) THEN
        RETURN
    END
    IF NOT(ENABLE.ERROR.THROWS) THEN
        RETURN
    END

* error throws are enabled but should be disabled but if not used.  see
* if we can find any strings indicative of using error throws in
* the code
    FOR THROWN.LOOP = 1 TO THROWN.KEYWORD.COUNT UNTIL ERROR.THROWS.USED

        FOR CASE = 0 TO 1

            THIS.KEYWORD = THROWN.KEYWORDS<THROWN.LOOP>
            IF CASE THEN
                THIS.KEYWORD = DOWNCASE(THIS.KEYWORD)
            END

            THROW.PTR = INDEX(PROGRAM.CODE, THIS.KEYWORD, 1)
            IF THROW.PTR > 1 THEN
                ERROR.THROWS.USED = @TRUE
            END

        NEXT CASE

    NEXT THROWN.LOOP

* if error throws are being used set enable.error.throws to the master
* value that was read from the setup record.  otherwise turn it off.
    IF ERROR.THROWS.USED THEN
        ENABLE.ERROR.THROWS = MASTER.ENABLE.ERROR.THROWS
    END ELSE
        ENABLE.ERROR.THROWS = @FALSE
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / create object                                      **
**************************************************************************
**************************************************************************

BUILD.OBJECT.CREATE.LINE: ************************************************
* build object.create.line to build code to create the current object    *
* being compiled                                                         *
**************************************************************************
    OBJECT.CREATE.LINE = ""

* only create if we're processing an object
    IF NOT(COMPILE.OBJECT) THEN
        RETURN
    END

* check this object for child objects.  first build the usage table for
* the object so we can add child objects
    GOSUB BUILD.OBJECT.USAGE.TABLE

* check for child objects
    THIS.OBJECT.HANDLE = "OBJECT.HANDLE"
    THIS.OBJECT.NAME = OBJECT.NAME
    THIS.DIM.VAR = ""

    THIS.ADDITIONAL.PARAMETERS = ""

    THIS.TYPE = NEW.KEYWORD
    THIS.WITH = ""

    THIS.LABEL = ""

    THIS.INDENT = ""

    NEW.LINE = ""

    SEARCH.SUBCHILDREN = @TRUE
    UPDATE.OBJECT.CREATION.LIST = @FALSE
    ADD.LOCAL.CHILD.OBJECTS = @FALSE
    THIS.CHILD.OBJECT.NAME = THIS.OBJECT.NAME
    THIS.CHILD.OBJECT.HANDLE = THIS.OBJECT.HANDLE

    GOSUB CHECK.FOR.CHILD.OBJECTS

* build the object creation code.  temporarily disable error throws so that
* the object creation statement comes back without any "if"s in it
    SAVE.ENABLE.ERROR.THROWS = ENABLE.ERROR.THROWS
    ENABLE.ERROR.THROWS = @FALSE

    CREATE.NEW.HANDLE = @TRUE
    CREATE.COMMENT = ""
    
    GOSUB CONVERT.NEW.STATEMENT

* the first part of the create line is clearing a temporary value that's
* passed to the "new" subroutine.  change the null to object.handle so we
* can set starting values through object.handle
    REPLACE.PTR = INDEX(NEW.LINE, '""', 1)
    NEW.LINE = NEW.LINE [1, REPLACE.PTR - 1]:"OBJECT.HANDLE":NEW.LINE [REPLACE.PTR + 2, TO.THE.END]

    OBJECT.CREATE.LINE = NEW.LINE

    ENABLE.ERROR.THROWS = SAVE.ENABLE.ERROR.THROWS
    
    RETURN

EXPAND.CREATION.WITH: ****************************************************
* expand any "with" statements that also do object creation.  these      *
* statements will be in this form:                                       *
*                                                                        *
*     with object.handle = new (object.name) {                           *
*                                                                        *
* the statement will be converted into two lines.  the first will create *
* the object and the second will be the "with"                           *
**************************************************************************
    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE
    INSERTED.LINE.COUNT = 0

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have shortcuts
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            CLEAN.LINE = THIS.LINE
            GOSUB CLEAN.LINE

* check for the "with" keyword to start the line
            KEYWORD = CLEAN.LINE [" ", 1, 1]
            IF KEYWORD = WITH.KEYWORD THEN

* if this "with" statement creates an object there will be an equals sign
* in the statement somewhere
                IF COUNT(CLEAN.LINE, "=") = 1 THEN

* see how many spaces are to the left of the code
                    INDENT.COUNT = FIND.INDENT.COUNT (CLEAN.LABEL, THIS.LINE)

* remove the object creation from the line
                    ADD.OPEN.BRACE = @FALSE
                    CREATION.LINE = CLEAN.LINE [" ", 2, TO.THE.END]
                    IF CREATION.LINE [1] = OPEN.BRACE THEN
                        CREATION.LINE = CREATION.LINE [1, LEN(CREATION.LINE) - 1]
                        ADD.OPEN.BRACE = @TRUE
                    END

* build the new "with" statement
                    WITH.OBJECT.HANDLE = TRIM(CREATION.LINE [" ", 1, 1] ["=", 1, 1])
                    WITH.LINE = WITH.KEYWORD:" ":WITH.OBJECT.HANDLE
                    IF ADD.OPEN.BRACE THEN
                        WITH.LINE := " ":OPEN.BRACE
                    END

* if the "with" statement creates an object and has a method name with
* the object name remove the method name from the creation line
                    METHOD.PTR = INDEX(CREATION.LINE, METHOD.DELIMITER, 1)
                    IF METHOD.PTR > 0 THEN
                        EQUALS.PTR = INDEX(CREATION.LINE, "=", 1)
                        IF EQUALS.PTR > 0 THEN
                            CREATION.LINE = CREATION.LINE [1, METHOD.PTR - 1]:CREATION.LINE [EQUALS.PTR, TO.THE.END]
                        END
                    END

* update both lines with indentation
                    CREATION.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CREATION.LINE
                    WITH.LINE = SPACE(LEN(CLEAN.LABEL)):SPACE(INDENT.COUNT):WITH.LINE

* add both of these line where the original line was.  this will add a new
* line
                    PROGRAM.CODE<LINE.LOOP + INSERTED.LINE.COUNT> = CREATION.LINE:@AM:WITH.LINE
                    INSERTED.LINE.COUNT += 1

* update the program line xref
                    INSERT.LINE.COUNT = 1
                    GOSUB INSERT.LINE.XREF

                END

            END

        END

    NEXT LINE.LOOP

    PROGRAM.CODE.LINES += INSERT.LINE.COUNT

    RETURN

CONVERT.OBJECT.CREATION.LINES: *******************************************
* convert new / old / destroy statements to eclipse-style calls          *
**************************************************************************
    OBJ.CREATE.START.DATE = DATE()
    OBJ.CREATE.START.TIME = TIME()

    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        PTR = CREATE.LINE.LIST<CREATE.LOOP>

        THIS.OBJECT.HANDLE = CREATE.HANDLE.LIST<CREATE.LOOP>
        THIS.OBJECT.NAME = CREATE.OBJECT.LIST<CREATE.LOOP>
        THIS.DIM.VAR = CREATE.DIM.VAR.LIST<CREATE.LOOP>

        THIS.ADDITIONAL.PARAMETERS = CREATE.ADDITIONAL.LIST<CREATE.LOOP>

        THIS.TYPE = CREATE.TYPE.LIST<CREATE.LOOP>
        THIS.WITH = CREATE.WITH.LIST<CREATE.LOOP>

        THIS.LABEL = CREATE.LABEL.LIST<CREATE.LOOP>

        THIS.INDENT = CREATE.INDENT.LIST<CREATE.LOOP>

        NEW.LINE = ""

* check this object for child objects
        SEARCH.SUBCHILDREN = @TRUE
        UPDATE.OBJECT.CREATION.LIST = @FALSE
        ADD.LOCAL.CHILD.OBJECTS = @FALSE

        THIS.CHILD.OBJECT.NAME = THIS.OBJECT.NAME
        THIS.CHILD.OBJECT.HANDLE = THIS.OBJECT.HANDLE

        GOSUB CHECK.FOR.CHILD.OBJECTS

* create new program line based on type of operation
        BEGIN CASE

* object is created with the "NEW" keyword
            CASE THIS.TYPE = NEW.KEYWORD
                CREATE.NEW.HANDLE = @TRUE
                CREATE.COMMENT = "new ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                GOSUB CONVERT.NEW.STATEMENT

* object is created with the "NEW.THREAD" keyword
            CASE ENABLE.MULTI.THREADING AND THIS.TYPE = NEW.MULTI.THREAD.KEYWORD
                CREATE.NEW.HANDLE = @TRUE
                CREATE.COMMENT = "new multi-thread ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                GOSUB CONVERT.NEW.THREAD.STATEMENT

* object is created with the "NEW.RESIDENT" keyword
            CASE THIS.TYPE = NEW.RESIDENT.KEYWORD
                CREATE.NEW.HANDLE = @TRUE
                CREATE.COMMENT = "new resident ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                GOSUB CONVERT.NEW.RESIDENT.STATEMENT

* object is created with the "OLD" keyword
            CASE THIS.TYPE = OLD.KEYWORD
                CREATE.NEW.HANDLE = @FALSE
                CREATE.COMMENT = "old ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                THIS.ADDITIONAL.PARAMETERS = ""
                GOSUB CONVERT.NEW.STATEMENT

* object is created with the "OLD.THREAD" keyword
            CASE THIS.TYPE = OLD.MULTI.THREAD.KEYWORD
                CREATE.NEW.HANDLE = @FALSE
                CREATE.COMMENT = "old multi-thread ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                THIS.ADDITIONAL.PARAMETERS = ""
                GOSUB CONVERT.NEW.STATEMENT

* object is being created with the "NEW.NOW" keyword
            CASE THIS.TYPE = NEW.NOW.KEYWORD
                CREATE.NEW.HANDLE = @TRUE
                CREATE.COMMENT = "initialize ":THIS.OBJECT.NAME:" object"
                IF THIS.DIM.VAR <> "" THEN
                    CREATE.COMMENT := " array"
                END
                GOSUB CONVERT.NEW.NOW.STATEMENT

* object is being destroyed
            CASE THIS.TYPE = DESTROY.KEYWORD
                CREATE.COMMENT = ""
                THIS.ADDITIONAL.PARAMETERS = ""
                GOSUB CONVERT.DESTROY.STATEMENT

        END CASE

* if we created a new eclipse-style subroutine call overwrite the old
* object call with the new subroutine call
        IF NEW.LINE <> "" AND PTR > 0 THEN
            PROGRAM.CODE<PTR> = NEW.LINE
        END

    NEXT CREATE.LOOP

    OBJ.CREATE.END.DATE = DATE()
    OBJ.CREATE.END.TIME = TIME()
    OBJ.CREATE.ELAPSED.TIME += TIME.ELAPSED (OBJ.CREATE.START.DATE, OBJ.CREATE.START.TIME)

    RETURN

CONVERT.NEW.STATEMENT: ***************************************************
* convert a "NEW" code line that creates an object and return it in      *
* new.line.                                                              *
*                                                                        *
* needs CREATE.NEW.HANDLE true or false to tell if this "NEW"            *
* call should start with a null handle and create a new one or if it     *
* should assume the handle already exists                                *
* needs CREATE.COMMENT to add a comment to the end of the line           *
**************************************************************************

* this is a new object.  call the "new" method to create it.  we'll
* be getting the object handle value from "new" but it's possible that
* the object handle is a common variable.  we don't want to pass common
* variables as we can get aliasing problems.  to work around this we'll
* pass "new" a temporary variable and assign the temporary variable to
* the object handle afterwards

* the "new" call also passes the registry source id variable.  this variable
* is NOT initialized in the program but this is on purpose.  if it's not
* initialized then the object registry will create a new, unique value for
* the source.id.  this source.id will be used every time this program
* creates an object.  this tags all objects created by this program to
* this program.  this allows a cleanup to be done when everything is wrapped
* up . . . ud.object.registry can destroy all objects with a matching source.id
* to destroy any remaining objects created by this program

* the handle variable will be different depending on whether the handle
* is dimensioned or not.  build the object handle to use.  the object handle
* will end in "()" if it's dimensioned so chop off the first part.  then,
* if the handle is dimensioned add the array reference to the end

* the object handle that is created looks like this:

*     OBJECT.HANDLE <1>     instance pointer or thread.id if a phantom object
*                   <2>     object name
*                   <3>     string for validating child objects
*                   <4>     thread.id for multi-threaded objects
*                   <5,n>   additional parameters.  in the new method they
*                           can be accessed from INITIALIZE.VALUE<n>

    GOSUB BUILD.NEW.OBJECT.HANDLE

* start the program line with the label, indention and clearing the temp.handle variable
    NEW.LINE = THIS.LABEL:SPACE(THIS.INDENT)

* we'll build a "child object" string as we create the subroutine statement.
* this "child object" string can be compared to a similar string build in
* the calling program to make sure all child objects are inclued and in
* the correct places.

* if a child object was added here in this object and the calling program
* was not recompiled then we could get a mismatch.  this would result in the
* calling program getting the wrong object handles in the wrong places.

* if CheckMismatchedChildObjects is turned on (which is a good idea) we can
* use the string to test for this condition
    CHILD.OBJECT.STRING = ""

    GOSUB INITIALIZE.NEW.OBJECT.HANDLE
    GOSUB INITIALIZE.NEW.TEMP.OBJECT.HANDLE

* if we have to insert the child.object.string into this line we'll insert
* it into new.line right here
    CHILD.OBJECT.INSERT.PTR = LEN(NEW.LINE)

    GOSUB ADD.CHILD.OBJECT.DIMENSIONS

* find out if this object was created as a child object or a "normally"
* created object in code
    CHECK.HANDLE = THIS.OBJECT.HANDLE
    GOSUB FIND.CREATED.OBJECT.TYPE

* build the eclipse subroutine call name for the "new" method
    CALL.NAME = ECLIPSE.PREFIX:THIS.OBJECT.NAME:ECLIPSE.DELIMITER:NEW.KEYWORD

* add the subroutine call name, temporary object handle and the error.message
* variable
    NEW.LINE := CALL.NAME:" TEMP.HANDLE, ":ERROR.MESSAGE.VARIABLE

* add the registry source.id.  if this object was created as a child object
* we'll use the child registry source variable.  otherwise we'll use the
* "normal" registry source variable.  since child objects are created first
* the child registry source will be less than the registry source variable.
* this allows a "delete.mine" call to the object registry to destroy all the
* "normal" objects without destroying the child objects.

* we need this ability to do an auto-destroy at the end of a method.  this
* auto-destroy needs to delete the "normal" objects without deleting the
* child objects.  the "destroy" method will delete the child objects
    GOSUB ADD.SOURCE.ID.VARIABLE

    GOSUB ADD.NEW.CHILD.OBJECT.HANDLES
    GOSUB CHECK.NEW.MISMATCHED.CHILD.OBJECTS
    GOSUB ADD.ADDITIONAL.PARAMETERS

    IF CHECK.OBJECT.HANDLE.BEFORE.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB COPY.TEMP.OBJECT.HANDLE
    GOSUB COPY.TEMP.CHILD.HANDLES

    IF CHECK.OBJECT.HANDLE.AFTER.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB ADD.ERROR.LOGGING.CODE
    GOSUB ADD.NEW.OBJECT.ERROR.THROW
    GOSUB ADD.NEW.OBJECT.COMMENT

    RETURN

CONVERT.NEW.NOW.STATEMENT: ***********************************************
* convert a "NEW.NOW" code line that creates an object and return it in  *
* new.line.  "NEW.NOW" is used for a child object created with the       *
* "OLD" keyword.        these child objects aren't initialized when the  *
* parent object is initialized.  they're only initialized when the       *
* "NEW.NOW" statement is encountered.  if the old child object has       *
* already been created the "NEW.NOW" statement doesn't do anything.      *
*                                                                        *
* this allows having a child object that's not initialized unless it's   *
* needed.  this is good for child objects that won't be used very often. *
* it allows the parent object to initialize faster and only initialize   *
* the child object when/if it's needed                                   *
*                                                                        *
* needs CREATE.COMMENT to add a comment to the end of the line           *
**************************************************************************

* this is a new object.  call the "new" method to create it.  we'll
* be getting the object handle value from "new" but it's possible that
* the object handle is a common variable.  we don't want to pass common
* variables as we can get aliasing problems.  to work around this we'll
* pass "new" a temporary variable and assign the temporary variable to
* the object handle afterwards

* the "new" call also passes the registry source id variable.  this variable
* is NOT initialized in the program but this is on purpose.  if it's not
* initialized then the object registry will create a new, unique value for
* the source.id.  this source.id will be used every time this program
* creates an object.  this tags all objects created by this program to
* this program.  this allows a cleanup to be done when everything is wrapped
* up . . . ud.object.registry can destroy all objects with a matching source.id
* to destroy any remaining objects created by this program

* the handle variable will be different depending on whether the handle
* is dimensioned or not.  build the object handle to use.  the object handle
* will end in "()" if it's dimensioned so chop off the first part.  then,
* if the handle is dimensioned add the array reference to the end

* the object handle that is created looks like this:

*     OBJECT.HANDLE <1>     instance pointer or thread.id if a phantom object
*                   <2>     object name
*                   <3>     string for validating child objects
*                   <4>     thread.id for multi-threaded objects
*                   <5,n>   additional parameters.  in the new method they
*                           can be accessed from INITIALIZE.VALUE<n>

    GOSUB BUILD.NEW.OBJECT.HANDLE

* start the program line with the label, indention and clearing the temp.handle variable
    NEW.LINE = THIS.LABEL:SPACE(THIS.INDENT)

* add an "if" statement to only create the child object if the object
* handle is a null or "0"
    NEW.LINE := 'IF ':USE.OBJECT.HANDLE:' = "" OR ':USE.OBJECT.HANDLE:' = "0" THEN NULL ; '

* we'll build a "child object" string as we create the subroutine statement.
* this "child object" string can be compared to a similar string build in
* the calling program to make sure all child objects are inclued and in
* the correct places.

* if a child object was added here in this object and the calling program
* was not recompiled then we could get a mismatch.  this would result in the
* calling program getting the wrong object handles in the wrong places.

* if CheckMismatchedChildObjects is turned on (which is a good idea) we can
* use the string to test for this condition
    CHILD.OBJECT.STRING = ""

    GOSUB INITIALIZE.NEW.OBJECT.HANDLE
    GOSUB INITIALIZE.NEW.TEMP.OBJECT.HANDLE

* if we have to insert the child.object.string into this line we'll insert
* it into new.line right here
    CHILD.OBJECT.INSERT.PTR = LEN(NEW.LINE)

    GOSUB ADD.CHILD.OBJECT.DIMENSIONS

* find out if this object was created as a child object or a "normally"
* created object in code
    CHECK.HANDLE = THIS.OBJECT.HANDLE
    GOSUB FIND.CREATED.OBJECT.TYPE

* build the eclipse subroutine call name for the "new" method
    CALL.NAME = ECLIPSE.PREFIX:THIS.OBJECT.NAME:ECLIPSE.DELIMITER:NEW.KEYWORD

* add the subroutine call name, temporary object handle and the error.message
* variable
    NEW.LINE := CALL.NAME:" TEMP.HANDLE, ":ERROR.MESSAGE.VARIABLE

* add the registry source.id.  if this object was created as a child object
* we'll use the child registry source variable.  otherwise we'll use the
* "normal" registry source variable.  since child objects are created first
* the child registry source will be less than the registry source variable.
* this allows a "delete.mine" call to the object registry to destroy all the
* "normal" objects without destroying the child objects.

* we need this ability to do an auto-destroy at the end of a method.  this
* auto-destroy needs to delete the "normal" objects without deleting the
* child objects.  the "destroy" method will delete the child objects
    GOSUB ADD.SOURCE.ID.VARIABLE

    GOSUB ADD.NEW.CHILD.OBJECT.HANDLES
    GOSUB CHECK.NEW.MISMATCHED.CHILD.OBJECTS
    GOSUB ADD.ADDITIONAL.PARAMETERS

    IF CHECK.OBJECT.HANDLE.BEFORE.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB COPY.TEMP.OBJECT.HANDLE
    GOSUB COPY.TEMP.CHILD.HANDLES

    IF CHECK.OBJECT.HANDLE.AFTER.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB ADD.ERROR.LOGGING.CODE
    GOSUB ADD.NEW.OBJECT.ERROR.THROW
    GOSUB ADD.NEW.OBJECT.COMMENT

    RETURN

CONVERT.NEW.THREAD.STATEMENT: ********************************************
* convert a "NEW.THREAD" code line that creates an object and return it  *
* in new.line.                                                           *
*                                                                        *
* needs CREATE.COMMENT to add a comment to the end of the line           *
**************************************************************************

* this is a new.thread object.  create a multi.thread object to handle
* the creation of this option and to start the phantom that drives the
* object

* the handle variable will be different depending on whether the handle
* is dimensioned or not.  build the object handle to use.  the object handle
* will end in "()" if it's dimensioned so chop off the first part.  then,
* if the handle is dimensioned add the array reference to the end

* the object handle that is created looks like this except it will point
* to the new multi.thread handle:
    GOSUB BUILD.NEW.OBJECT.HANDLE

* find out if this object was created as a child object or a "normally"
* created object in code
    CHECK.HANDLE = USE.OBJECT.HANDLE
    GOSUB FIND.CREATED.OBJECT.TYPE

* start the program line with the label, indention and clearing the temp.handle variable
    NEW.LINE = THIS.LABEL:SPACE(THIS.INDENT)

* if this handle is dimensioned add dimensioning and looping so we initialize
* the entire array
    GOSUB INITIALIZE.NEW.OBJECT.HANDLE
    GOSUB INITIALIZE.NEW.TEMP.OBJECT.HANDLE

* if we have to insert the child.object.string into this line we'll insert
* it into new.line right here
    CHILD.OBJECT.INSERT.PTR = LEN(NEW.LINE)

* if this new thread object id dimensioned add the dimension ptr as the
* thread number
    BEGIN CASE

        CASE USE.DIMENSIONS = 1
            NEW.LINE := "PASS.INITIALIZE.VALUE = LOWER(INSTANCE.LOOP) ; "
            NEW.LINE := "TEMP.HANDLE<5> = LOWER(PASS.INITIALIZE.VALUE) ; "

        CASE USE.DIMENSIONS = 2
            NEW.LINE := "PASS.INITIALIZE.VALUE = LOWER(INSTANCE.LOOP1+(INSTANCE.LOOP2-1)*MAX.ARRAY1) ; "
            NEW.LINE := "TEMP.HANDLE<5> = LOWER(PASS.INITIALIZE.VALUE) ; "

    END CASE

* find out if this object was created as a child object or a "normally"
* created object in code
    CHECK.HANDLE = THIS.OBJECT.HANDLE
    GOSUB FIND.CREATED.OBJECT.TYPE

* create a new instance of the multi.thread object to handle this object
    CALL.NAME = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME:ECLIPSE.DELIMITER:NEW.KEYWORD

* add the subroutine call name, temporary object handle and the error.message
* variable
    NEW.LINE := CALL.NAME:" TEMP.HANDLE, ":ERROR.MESSAGE.VARIABLE

* add the registry source.id.  if this object was created as a child object
* we'll use the child registry source variable.  otherwise we'll use the
* "normal" registry source variable.  since child objects are created first
* the child registry source will be less than the registry source variable.
* this allows a "delete.mine" call to the object registry to destroy all the
* "normal" objects without destroying the child objects.

* we need this ability to do an auto-destroy at the end of a method.  this
* auto-destroy needs to delete the "normal" objects without deleting the
* child objects.  the "destroy" method will delete the child objects
    GOSUB ADD.SOURCE.ID.VARIABLE

* see if any thrown error code should be added at the end of this line.
* if fixed.code.count comes back non-zero then the new.line will be in
* fixed.code<1> and the error throw line will be in fixed.code<2>
    FIXED.CODE = ""
    FIXED.CODE.COUNT = 0
    LABEL = ""

    GOSUB ADD.ERROR.LOGGING.CODE
    GOSUB ADD.ERROR.THROW.CODE

    IF FIXED.CODE.COUNT > 0 THEN
        NEW.LINE = FIXED.CODE<1>:" ; ":TRIM(FIXED.CODE<2>, " ", "B")
        NEW.LINE := " ELSE NULL"
    END

* we've created the multi.thread object.  now call launch.phantom method
* to create the phantom and get the thread.id for this multi.thread object
    NEW.LINE := " ; "
    CALL.NAME = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME:ECLIPSE.DELIMITER:MULTI.NEW.METHOD.NAME

* add the subroutine call name
    NEW.LINE := CALL.NAME

* temporary object handle
    NEW.LINE := " TEMP.HANDLE"

* error message
    NEW.LINE := ", ERROR.MESSAGE"

* new thread id
    NEW.LINE := ", TEMP.THREAD.ID"

* object name for the multi.thread object
    NEW.LINE := ', "':THIS.OBJECT.NAME:'"'

* this gets our thread.id and starts the object's phantom.  save the thread
* id in the new (temporary) object handle for the multi.thread object in
* attribute <3>.  this will both identify the object handle as a multi.thread
* object handle and record the thread.id created for it
    NEW.LINE := " ; TEMP.HANDLE<4> = TEMP.THREAD.ID"

    GOSUB ADD.ADDITIONAL.PARAMETERS

    GOSUB COPY.TEMP.OBJECT.HANDLE

    GOSUB ADD.ERROR.LOGGING.CODE
    GOSUB ADD.NEW.OBJECT.ERROR.THROW
    GOSUB ADD.NEW.OBJECT.COMMENT

    RETURN

CONVERT.NEW.RESIDENT.STATEMENT: ******************************************
* convert a "NEW" code line that creates an object as a resident object  *
* and return its in new.line.                                            *
*                                                                        *
* needs CREATE.COMMENT to add a comment to the end of the line           *
**************************************************************************

* this is a new resident object.  call the "new" method to create it with
* a registry source id of -1.  the negative source id will make it impossible
* for auto-destroy statements to destroy this object since the lowest
* source id that can be destroyed this way is 0.

* if the object we're creating has child objects of its own the source id
* of -1 will be passed to those child objects as well.  this ensures that
* any objects created downstream from a resident.new object will be created
* as resident.new objects as well

* we'll be getting the object handle value from "new.resident" but it's
* possible that the object handle is a common variable.  we don't want to
* pass common variables as we can get aliasing problems.  to work around
* this we'll pass "new" a temporary variable and assign the temporary
* variable to the object handle afterwards

* the "new" call also passes the registry source id variable.  normally
* this variable is NOT initialized in the program on purpose so that
* the registry routine will create a new source id.  with resident objects
* we're setting this source.id to -1

* the handle variable will be different depending on whether the handle
* is dimensioned or not.  build the object handle to use.  the object handle
* will end in "()" if it's dimensioned so chop off the first part.  then,
* if the handle is dimensioned add the array reference to the end

* the object handle that is created looks like this:

*     OBJECT.HANDLE <1>     instance pointer or thread.id if a phantom object
*                   <2>     object name
*                   <3>     string for validating child objects
*                   <4>     thread.id for multi-threaded objects
*                   <5,n>   additional parameters.  in the new method they
*                           can be accessed from INITIALIZE.VALUE<n>
    GOSUB BUILD.NEW.OBJECT.HANDLE

* start the program line with the label, indention and clearing the temp.handle variable
    NEW.LINE = THIS.LABEL:SPACE(THIS.INDENT)

* we'll build a "child object" string as we create the subroutine statement.
* this "child object" string can be compared to a similar string build in
* the calling program to make sure all child objects are inclued and in
* the correct places.

* if a child object was added here in this object and the calling program
* was not recompiled then we could get a mismatch.  this would result in the
* calling program getting the wrong object handles in the wrong places.

* if CheckMismatchedChildObjects is turned on (which is a good idea) we can
* use the string to test for this condition
    CHILD.OBJECT.STRING = ""

* if this handle is dimensioned add dimensioning and looping so we initialize
* the entire array
    GOSUB INITIALIZE.NEW.OBJECT.HANDLE
    GOSUB INITIALIZE.NEW.TEMP.OBJECT.HANDLE

* if we have to insert the child.object.string into this line we'll insert
* it into new.line right here
    CHILD.OBJECT.INSERT.PTR = LEN(NEW.LINE)

* if any of the child objects created by the object we're creating are
* dimensioned we need to dimension the child object handle
    GOSUB ADD.CHILD.OBJECT.DIMENSIONS

* find out if this object was created as a child object or a "normally"
* created object in code
    CHECK.HANDLE = THIS.OBJECT.HANDLE
    GOSUB FIND.CREATED.OBJECT.TYPE

* build the eclipse subroutine call name for the "new" method
    CALL.NAME = ECLIPSE.PREFIX:THIS.OBJECT.NAME:ECLIPSE.DELIMITER:NEW.KEYWORD

* add the subroutine call name, temporary object handle and the error.message
* variable
    NEW.LINE := CALL.NAME:" TEMP.HANDLE, ":ERROR.MESSAGE.VARIABLE

* add the registry source.id.  always set to -1 so that this resident
* object cannot be auto-destroyed
    NEW.LINE := ", -1"

    GOSUB ADD.NEW.CHILD.OBJECT.HANDLES
    GOSUB CHECK.NEW.MISMATCHED.CHILD.OBJECTS
    GOSUB ADD.ADDITIONAL.PARAMETERS

    IF CHECK.OBJECT.HANDLE.BEFORE.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB COPY.TEMP.OBJECT.HANDLE
    GOSUB COPY.TEMP.CHILD.HANDLES

    IF CHECK.OBJECT.HANDLE.AFTER.CHILD THEN
        GOSUB ADD.INSTANCE.CHECKING.CODE
    END

    GOSUB ADD.ERROR.LOGGING.CODE
    GOSUB ADD.NEW.OBJECT.ERROR.THROW
    GOSUB ADD.NEW.OBJECT.COMMENT

    RETURN

ADD.SOURCE.ID.VARIABLE: **************************************************
* add the appropriate source id to a subroutine call to create a new     *
* object.  the source id will be a different variable name depending on  *
* the circumstances of the created object:                               *
*                                                                        *
* if the object is an intime child object then the instance source id    *
* from the instance common block is used.  this ensures that the same    *
* source id used to create the parent object is still used to create the *
* child object even when the child isn't created in the "new" method     *
*                                                                        *
* if the object is a child object then the child registry source id      *
* variable will be used.  this ensures that during the auto object       *
* destroy all child objects are destroyed with the parent object         *
*                                                                        *
* if the object isn't a child object then the default registry source    *
* id variable is used                                                    *
**************************************************************************
    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    BEGIN CASE

        CASE HANDLE.CREATE.TYPE = "CHILD" AND HANDLE.CREATE.INTIME
            NEW.LINE := BETWEEN.PARAMETERS:'INSTANCE.REGISTRY.SOURCE.ID:""'

        CASE HANDLE.CREATE.TYPE = "CHILD"
            NEW.LINE := BETWEEN.PARAMETERS:CHILD.REGISTRY.SOURCE.VARIABLE

        CASE 1
            NEW.LINE := BETWEEN.PARAMETERS:REGISTRY.SOURCE.VARIABLE

    END CASE

    RETURN

BUILD.NEW.OBJECT.HANDLE: *************************************************
* build use.object.handle as the object handle for a "new" statement.    *
* sets variables for dimensioned object handles                          *
**************************************************************************
    USE.OBJECT.HANDLE = THIS.OBJECT.HANDLE ["(", 1, 1]

* check this handle to see if it's an eclipse common variable.  this would
* be a Bad Thing
    CHECK.VARIABLE = USE.OBJECT.HANDLE
    CHECK.TYPE = "Object handle"
    CHECK.LINE = LINE.LOOP
    GOSUB CHECK.ECLIPSE.COMMON

* check for dimensioned object handle
    USE.OBJECT.DIM = THIS.DIM.VAR

    IF USE.OBJECT.DIM = "" THEN

        USE.DIMENSIONS = 0

    END ELSE

        IF USE.OBJECT.DIM [1, 1] = "(" AND USE.OBJECT.DIM [1] = ")" THEN
            USE.OBJECT.DIM = USE.OBJECT.DIM [2, LEN(USE.OBJECT.DIM) - 2]
        END

        USE.DIMENSIONS = DCOUNT(USE.OBJECT.DIM, ",")

    END

* if this handle is dimensioned and all array indexes are numeric constants
* we'll add all the looping to initialize the entire array.  otherwise we'll
* assume the routine is doing the initializing and pass the handle through as
* it is
    BEGIN CASE

        CASE USE.DIMENSIONS = 0
            NULL

        CASE USE.DIMENSIONS = 1 AND NOT(NUM(USE.DIMENSIONS))
            USE.DIMENSIONS = 0
            USE.OBJECT.HANDLE := "(":USE.DIMENSIONS:")"

        CASE USE.DIMENSIONS = 2 AND (NOT(NUM(USE.DIMENSIONS [",", 1, 1])) OR NOT(NUM(USE.DIMENSIONS [",", 2, 1])))
            USE.DIMENSIONS = 0
            USE.OBJECT.HANDLE := "(":USE.DIMENSIONS:")"

    END CASE

    RETURN

INITIALIZE.NEW.OBJECT.HANDLE: ********************************************
* if this handle is dimensioned add dimensioning and looping so we       *
* initialize the entire array                                            *
**************************************************************************
    BEGIN CASE

        CASE USE.DIMENSIONS = 0
            NULL

        CASE USE.DIMENSIONS = 1
            NEW.LINE := "DIM ":USE.OBJECT.HANDLE:"(":USE.OBJECT.DIM:") ; "
            NEW.LINE := "FOR INSTANCE.LOOP = 1 TO ":USE.OBJECT.DIM:" ; "

        CASE USE.DIMENSIONS = 2
            NEW.LINE := "DIM ":USE.OBJECT.HANDLE:"(":USE.OBJECT.DIM:") ; "
            NEW.LINE := "FOR INSTANCE1.LOOP = 1 TO ":USE.OBJECT.DIM [",", 1, 1]:" ; "
            NEW.LINE := "FOR INSTANCE2.LOOP = 1 TO ":USE.OBJECT.DIM [",", 2, 1]:" ; "

    END CASE

    RETURN

INITIALIZE.NEW.TEMP.OBJECT.HANDLE: ***************************************
* if we're creating a new object handle (ie, a new(object.name)          *
* statement) set the temporary handle null so that the "new" method will *
* create one.                                                            *
*                                                                        *
* if we aren't creating a new handle (ie, an old(object.name) statement) *
* set the temporary handle equal to the existing handle so that the      *
* "new" method won't create a new handle                                 *
**************************************************************************

* if the handle is dimensioned use the dimensioned value of the handle
    BEGIN CASE

        CASE CREATE.NEW.HANDLE
            NEW.LINE := 'TEMP.HANDLE = "" ; '

        CASE USE.DIMENSIONS = 0
            NEW.LINE := "TEMP.HANDLE = ":USE.OBJECT.HANDLE:" ; "

        CASE USE.DIMENSIONS = 1
            NEW.LINE := "TEMP.HANDLE = ":USE.OBJECT.HANDLE:"(INSTANCE.LOOP) ; "

        CASE USE.DIMENSIONS = 2
            NEW.LINE := "TEMP.HANDLE = ":USE.OBJECT.HANDLE:"(INSTANCE1.LOOP,INSTANCE2.LOOP) ; "

    END CASE

    RETURN

ADD.NEW.CHILD.OBJECT.HANDLES: ********************************************
* if this object has any child objects add the variable for the          *
* temporary child to new.line.  create child.copy.line that has code to  *
* copy the temporary child variable to the child variables               *
**************************************************************************

* object's handle
    CHILD.COPY.LINE = ""
    CHILD.OBJECT.STRING = ""

    FOR CHILD.LOOP = 1 TO CREATE.CHILD.COUNT

        THIS.PARENT = CREATE.CHILD.PARENT.HANDLE.LIST<CHILD.LOOP>
        THIS.PARENT.PTR = INDEX(THIS.PARENT, CHILD.DELIMITER, 1)

        IF THIS.PARENT.PTR > 0 THEN
            THIS.PARENT = THIS.PARENT [1, THIS.PARENT.PTR - 1]
        END

        IF THIS.PARENT = THIS.OBJECT.HANDLE THEN

            THIS.CHILD.NAME = CREATE.CHILD.NAME.LIST<CHILD.LOOP>
            THIS.CHILD.HANDLE = CREATE.CHILD.HANDLE.LIST<CHILD.LOOP>

            THIS.CHILD.VARIABLE = CREATE.CHILD.VARIABLE.LIST<CHILD.LOOP>
            THIS.CHILD.DIM = CREATE.CHILD.DIM.LIST<CHILD.LOOP>

            THIS.CHILD.LOCAL = CREATE.CHILD.LOCAL.LIST<CHILD.LOOP>
            THIS.CHILD.DEFINED.LOCAL = CREATE.CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

* if this child object isn't defined as local in the called object
* add its parameter to the "new" call
            IF NOT(THIS.CHILD.LOCAL)  THEN

* add the child variable name to the call statement
                BEGIN CASE

* if there's a "()" somewhere in this.child.variable then the handle
* points to a dimensioned child that has child objects of its own.
* we can't currently handle that so we'll send a null parameter
                    CASE INDEX(THIS.CHILD.VARIABLE, "()", 1) > 0
                        NEW.LINE := ', ""'

* child object not dimensioned, add as a normal child handle
                    CASE THIS.CHILD.DIM = ""
                        NEW.LINE := ", TEMP.CHILD.":THIS.CHILD.VARIABLE
                        CHILD.COPY.LINE := " ; ":THIS.CHILD.VARIABLE:" = TEMP.CHILD.":THIS.CHILD.VARIABLE

* child object is dimensioned, add as a dimensioned handle
                    CASE 1
                        NEW.LINE := ", MAT TEMP.CHILD.":THIS.CHILD.VARIABLE
                        CHILD.COPY.LINE := " ; MAT ":THIS.CHILD.VARIABLE:" = MAT TEMP.CHILD.":THIS.CHILD.VARIABLE

                END CASE

* update the child object string.  the child handles we have here will start
* with the object name being called.  we'll build the child string using only
* the child objects of the called object
                START.CHILD.PTR = INDEX(THIS.CHILD.HANDLE, METHOD.DELIMITER, 1)
                IF START.CHILD.PTR > 0 THEN

                    THIS.PASSED.CHILD.HANDLE = THIS.CHILD.HANDLE [START.CHILD.PTR + METHOD.DEL.LENGTH, TO.THE.END]
                    IF CHILD.OBJECT.STRING = "" THEN
                        CHILD.OBJECT.STRING = THIS.PASSED.CHILD.HANDLE:";":THIS.CHILD.NAME
                    END ELSE
                        CHILD.OBJECT.STRING := ",":THIS.PASSED.CHILD.HANDLE:";":THIS.CHILD.NAME
                    END

                END


            END

        END

    NEXT CHILD.LOOP

    RETURN

ADD.CHILD.OBJECT.DIMENSIONS: *********************************************
* if any of the child objects created by the object we're creating are   *
* dimensioned we need to dimension the child object handle.  add dim     *
* statements to new.line for these child objects                         *
**************************************************************************
    FOR CHILD.LOOP = 1 TO CREATE.CHILD.COUNT

        THIS.PARENT = CREATE.CHILD.PARENT.HANDLE.LIST<CHILD.LOOP>

        THIS.PARENT.PTR = INDEX(THIS.PARENT, CHILD.DELIMITER, 1)

        IF THIS.PARENT.PTR > 0 THEN
            THIS.PARENT = THIS.PARENT [1, THIS.PARENT.PTR - 1]
        END

        IF THIS.PARENT = THIS.OBJECT.HANDLE THEN

            THIS.CHILD.VARIABLE = CREATE.CHILD.VARIABLE.LIST<CHILD.LOOP>
            THIS.CHILD.DIM = CREATE.CHILD.DIM.LIST<CHILD.LOOP>

            THIS.CHILD.DEFINED.LOCAL = CREATE.CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>
            THIS.CHILD.LOCAL = CREATE.CHILD.LOCAL.LIST<CHILD.LOOP>

* if this child object is an array and it's not local to the called
* object add a dimension statement for the child object handle
            IF THIS.CHILD.DIM <> "" AND NOT(THIS.CHILD.LOCAL) THEN
                NEW.LINE := "DIM ":THIS.CHILD.VARIABLE:"(":CHANGE(THIS.CHILD.DIM, VM, ","):") ; "
                NEW.LINE := "DIM TEMP.CHILD.":THIS.CHILD.VARIABLE:"(":CHANGE(THIS.CHILD.DIM, VM, ","):") ; "
            END

        END

    NEXT CHILD.LOOP

    RETURN

CHECK.NEW.MISMATCHED.CHILD.OBJECTS: **************************************
* if CheckMismatchedChildObjects is turned on pass the child object      *
* definition in temp.handle<3>                                           *
**************************************************************************
    IF CHECK.MISMATCHED.CHILD.OBJECTS AND CHILD.OBJECT.STRING <> "" THEN

        CHILD.CHECK.INSERT = "TEMP.HANDLE<3> = ":'"':CHILD.OBJECT.STRING:'"':" ; "

        NEW.LINE = NEW.LINE [1, CHILD.OBJECT.INSERT.PTR]:CHILD.CHECK.INSERT:NEW.LINE [CHILD.OBJECT.INSERT.PTR + 1, TO.THE.END]

        CHILD.OBJECT.INSERT.PTR += LEN(CHILD.CHECK.INSERT)

    END

    RETURN

ADD.ADDITIONAL.PARAMETERS: ***********************************************
* if there are any additional parameters for the "new" call pass them    *
* in temp.handle<5>.  we'll use the child.object.insert.ptr as the       *
* code line's insertion point                                            *
**************************************************************************
    IF THIS.ADDITIONAL.PARAMETERS <> "" THEN

* if we have initializing values and they aren't allowed throw an error
        IF NOT(ALLOW.NEW.PARAMETERS) THEN

            OBJECT.ERROR.DESC = "Initializing parameters not allowed"
            OBJECT.ERROR.LINE = PTR "R%6":" ":PROGRAM.CODE<PTR>
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

        END

        THIS.ADD.LIST = SPLIT.PARAMETERS (THIS.ADDITIONAL.PARAMETERS)
        THIS.ADD.COUNT = DCOUNT(THIS.ADD.LIST, @AM)

        ADDITIONAL.INSERT = "PASS.INITIALIZE.VALUE = ":'""'

        FOR ADD.LOOP = 1 TO THIS.ADD.COUNT

            IF ADD.LOOP <> 1 THEN
                ADDITIONAL.INSERT := ":@AM"
            END
            ADDITIONAL.INSERT := ":LOWER(":THIS.ADD.LIST<ADD.LOOP>:")"

        NEXT ADD.LOOP

        ADDITIONAL.INSERT := " ; TEMP.HANDLE<5> = LOWER(PASS.INITIALIZE.VALUE) ; "

        NEW.LINE = NEW.LINE [1, CHILD.OBJECT.INSERT.PTR]:ADDITIONAL.INSERT:NEW.LINE [CHILD.OBJECT.INSERT.PTR + 1, TO.THE.END]

        CHILD.OBJECT.INSERT.PTR += LEN(ADDITIONAL.INSERT)

    END

    RETURN

COPY.TEMP.OBJECT.HANDLE: *************************************************
* copy the temporary object handle to its final variable.                *
**************************************************************************

* if the handle is dimensioned copy temp.handle into the appropriate
* array element and finish the loop
    BEGIN CASE

        CASE NOT(CREATE.NEW.HANDLE)
            NULL

        CASE USE.DIMENSIONS = 0
            NEW.LINE := " ; ":USE.OBJECT.HANDLE:" = TEMP.HANDLE"

        CASE USE.DIMENSIONS = 1
            NEW.LINE := " ; ":USE.OBJECT.HANDLE:"(INSTANCE.LOOP) = TEMP.HANDLE"
            NEW.LINE := " ; NEXT INSTANCE.LOOP"

        CASE USE.DIMENSIONS = 2
            NEW.LINE := " ; ":USE.OBJECT.HANDLE:"(INSTANCE1.LOOP,INSTANCE2.LOOP) = TEMP.HANDLE"
            NEW.LINE := " ; NEXT INSTANCE2.LOOP"
            NEW.LINE := " ; NEXT INSTANCE1.LOOP"

    END CASE

    RETURN

COPY.TEMP.CHILD.HANDLES: *************************************************
* add code to copy the temporary object handles to the appropriate       *
* child handles                                                          *
**************************************************************************
    NEW.LINE := CHILD.COPY.LINE

    RETURN

ADD.ERROR.LOGGING.CODE: **************************************************
* if error logging is turned on add a call to the error logging          *
* subroutine                                                             *
**************************************************************************
    IF UPDATE.OBJECT.ERROR.LOG THEN

        IF ERROR.LOG.ROUTINE <> "" AND ERROR.LOG.GOSUB.NAME <> "" THEN

            NEW.LINE := " ; GOSUB ":ERROR.LOG.GOSUB.NAME

        END

    END

    RETURN

ADD.INSTANCE.CHECKING.CODE: **********************************************
* check for a "nested" object call, where the object we're calling (or   *
* creating in this case) is the same object name we're in or the called  *
* (or created) object has a child object that's the same object name     *
* we're in.  if it's a case where the "new" call may change the          *
* instance of the current object add code to new.line to see if the      *
* instance has changed and correct it if so                              *
**************************************************************************
    CHECK.NESTED.OBJECT.HANDLE = USE.OBJECT.HANDLE
    GOSUB CHECK.NESTED.CALL

* if we're compiling and object and this new object is another instance of
* the same object then we need to reload the correct instance of this
* object.  the "new" call will return the property values of the new instance.
    INSTANCE.LOAD = " ; GOSUB SET.OBJECT.INSTANCE"
    INSTANCE.CHECK = " ; GOSUB CHECK.OBJECT.INSTANCE"

    BEGIN CASE

* not compiling an object, don't need to do anything1
        CASE NOT(COMPILE.OBJECT)
            NULL


* if the object has only one instance we don't need to check for the instance
* changing
        CASE MAX.INSTANCES = 1
            NULL

* if the object has no properties we don't need to check for the instance
* changing
        CASE NOT(PROPERTIES.EXIST)
            NULL


* flags for all scenarios:
*     we're set to always load the current instance
        CASE ALWAYS.LOAD.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're set to always check the current instance and reload if necessary
        CASE ALWAYS.CHECK.INSTANCE
            NEW.LINE := INSTANCE.CHECK


* "sub" calls:
*     we're doing a "sub" pseudo-object call and we're set to always load
*     current instances for "sub" calls
        CASE USE.OBJECT.HANDLE = SUBROUTINE.CALL.KEYWORD AND SUB.CALL.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're doing a "sub" pseudo-object call and we're set to always check
*     the current instance
        CASE USE.OBJECT.HANDLE = SUBROUTINE.CALL.KEYWORD AND SUB.CALL.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


* non-local calls:
*     non-local call and we're set to always load the current instance
        CASE USE.OBJECT.HANDLE <> LOCAL.OBJECT.HANDLE AND NON.LOCAL.ALWAYS.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're doing a non-local call and non-local calls are set to check the
*     instance
        CASE USE.OBJECT.HANDLE <> LOCAL.OBJECT.HANDLE AND NON.LOCAL.ALWAYS.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


*     call to another instance of the same object and we're set to load the
*     current instance in this situation.  add a call to set.object.instance
*     to reload the current instance
        CASE NESTED.OBJECT.CALL AND SAME.OBJECT.CALL.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

* "nested" calls:
*     call to another instance of the same object and we're set to check the
*     current instance in this situation.  add a call to set.object.instance
*     to reload the current instance if it changed
        CASE NESTED.OBJECT.CALL AND SAME.OBJECT.CALL.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


    END CASE

    RETURN

ADD.NEW.OBJECT.ERROR.THROW: **********************************************
* see if any thrown error code should be added at the end of this line.  *
* if fixed.code.count comes back non-zero then the new.line will be in   *
* fixed.code<1> and the error throw line will be in fixed.code<2>        *
**************************************************************************
    FIXED.CODE = ""
    FIXED.CODE.COUNT = 0
    LABEL = ""

    LINE.LOOP = PTR

    GOSUB ADD.ERROR.THROW.CODE

    IF FIXED.CODE.COUNT > 0 THEN
        NEW.LINE = FIXED.CODE<1>:" ; ":TRIM(FIXED.CODE<2>, " ", "B")
    END

    RETURN

ADD.NEW.OBJECT.COMMENT: **************************************************
* if there's a creation comment tack it onto the end                     *
**************************************************************************
    IF CREATE.COMMENT <> "" THEN
        NEW.LINE := " ; * ":CREATE.COMMENT
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / destroy object                                     **
**************************************************************************
**************************************************************************

CONVERT.DESTROY.STATEMENT: ***********************************************
* convert a progrm line with a "DESTROY" statement and return it in      *
* new.line                                                               *
**************************************************************************

* on second thought don't do that here.  we'll let the later
* method-conversion code do it
*   CALL.NAME = ECLIPSE.PREFIX:THIS.OBJECT.NAME:ECLIPSE.DELIMITER:DESTROY.KEYWORD
*   NEW.LINE = THIS.LABEL:SPACE(THIS.INDENT):CALL.NAME:" ":THIS.OBJECT.HANDLE

    RETURN

BUILD.OBJECT.DESTROY.LINE: ***********************************************
* build object.destroy.line to build code to destroy the current object  *
* being compiled                                                         *
**************************************************************************
    OBJECT.DESTROY.LINE = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:"DESTROY (OBJECT.HANDLE)"

    RETURN


**************************************************************************
**************************************************************************
** code conversion / convert single code line                           **
**************************************************************************
**************************************************************************

CONVERT.THIS.LINE: *******************************************************
* convert a program line from object calls to eclipse calls.  returns    *
* new.line null if no conversion is done.  convert.this line can handle  *
* compound lines and calls convert.this.single.line that converts non-   *
* compound lines                                                         *
**************************************************************************
    ORIGINAL.THIS.LINE = THIS.LINE
    NEW.LINE = ""

* check for a "section" line.  these won't show up in object methods (the
* "section" comments should (!) be outside of the methods) but it may be
* used in object-enabled subroutines.  if we find a "section" entry turn
* this line into a comment
    FIRST.WORD = TRIM(THIS.LINE) [" ", 1, 1]

    IF FIRST.WORD = SECTION.KEYWORD THEN
        NEW.LINE = "* ":THIS.LINE
        RETURN
    END

* test for mismatched brackets, parenthesis and quotes
    IF IS.CODE (THIS.LINE) THEN

        MISMATCHED.RESPONSE = CHECK.PARENTHESIS (THIS.LINE)

        IF MISMATCHED.RESPONSE <> "" THEN

            OBJECT.ERROR.DESC = MISMATCHED.RESPONSE:" in line ":LINE.LOOP
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

        END

    END

* check for multi (compound) lines
    MULTI.LINE = SPLIT.COMPOUND.LINE(THIS.LINE)
    MULTI.LINE.COUNT = DCOUNT(MULTI.LINE, @AM)

    NEW.MULTI.LINE = ""

* if this line is not a compound line convert.this.single.line can handle 
* it as it is.

* if it's a string pseudo-object reference it will return string.object.call
* true and exploded code in string.convert.line.  copy it to multi.line and
* process it 
    IF MULTI.LINE.COUNT <= 1 THEN

        GOSUB CONVERT.THIS.SINGLE.LINE

        IF STRING.OBJECT.CALL THEN
            MULTI.LINE = STRING.CONVERT.LINE
            MULTI.LINE.COUNT = DCOUNT(MULTI.LINE, @AM)
        END ELSE
            RETURN
        END

    END

* this program line is a compound line.  process each compound piece
* separately.  build new.multi.line with the converted code
    FOR MULTI.LINE.LOOP = 1 TO MULTI.LINE.COUNT

        THIS.LINE = MULTI.LINE<MULTI.LINE.LOOP>
        UNCHANGED.LINE = THIS.LINE

        GOSUB CONVERT.THIS.SINGLE.LINE

* if we're fixing unresolved references see if we can fix them
        IF FIX.UNRESOLVED.REFERENCES AND UNRESOLVED.REFERENCE.FOUND THEN
            GOSUB FIX.UNRESOLVED.ENTRIES
            IF ALL.UNRESOLVED.FIXED THEN
                UNRESOLVED.REFERENCE.FOUND = @FALSE
            END
        END ELSE
            FIX.CODE.LIST = ""
            FIXED.CODE.COUNT = 0
        END

* if we had an unresolved reference and we couldn't or didn't fix all
* of them show an error
        IF UNRESOLVED.REFERENCE.FOUND AND NOT(ALL.UNRESOLVED.FIXED) THEN
            OBJECT.ERROR.DESC = "Unresolved / unknown object reference"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @TRUE
            GOSUB PRINT.OBJECT.ERROR
        END

        BEGIN CASE

* convert.this.single.line found object pseudo-object calls and returned
* them in string.convert.line.  merge them into multi.line and decrement
* the loop index so that all these new lines will be processed
            CASE STRING.OBJECT.CALL
                MULTI.LINE<MULTI.LINE.LOOP> = STRING.CONVERT.LINE
                MULTI.LINE.COUNT = DCOUNT(MULTI.LINE, @AM)
                MULTI.LINE.LOOP -= 1

* convert.this.single.line returned an array of new code in fix.code.list.
* merge the converted fix code into new.multi.line
            CASE FIXED.CODE.COUNT > 0

                COMPOUND.LINE = FIX.CODE.LIST<1>

                FOR COMPOUND.LOOP = 2 TO FIXED.CODE.COUNT

                    IF TRIM(FIX.CODE.LIST<COMPOUND.LOOP>) <> "" THEN
                        COMPOUND.LINE := " ; ":FIX.CODE.LIST<COMPOUND.LOOP>
                    END

                NEXT COMPOUND.LOOP

                IF NEW.LINE <> "" THEN
                    COMPOUND.LINE := " ; ":NEW.LINE
                END

                NEW.MULTI.LINE<MULTI.LINE.LOOP> = COMPOUND.LINE

                FIX.CODE.LIST = ""
                FIXED.CODE.COUNT = 0

* convert.this.single.line returned a single new line of code in new.line.
* replace the old line with this new.line
            CASE NEW.LINE <> ""
                NEW.MULTI.LINE<MULTI.LINE.LOOP> = NEW.LINE

* convert.this.single.line didn't find anything to convert.  copy the
* unchanged line into new.multi.line
            CASE NEW.LINE = ""
                NEW.MULTI.LINE<MULTI.LINE.LOOP> = UNCHANGED.LINE

        END CASE

    NEXT MULTI.LINE.LOOP

* if anything was converted convert new.multi.line back into a compound
* program line.  if not return new.line null to show nothing changed
    IF MULTI.LINE = NEW.MULTI.LINE THEN

        NEW.LINE = ""

    END ELSE

        NEW.LINE = NEW.MULTI.LINE<1>

        FOR COMPOUND.LOOP = 2 TO MULTI.LINE.COUNT
            NEW.LINE := " ; ":TRIM(NEW.MULTI.LINE<COMPOUND.LOOP>, " ", "L")
        NEXT COMPOUND.LOOP

    END

    RETURN

CONVERT.THIS.SINGLE.LINE: ************************************************
* convert a program line from object calls to eclipse calls.  returns    *
* new.line null if no conversion is done                                 *
**************************************************************************

* initializing and validation of the code line
    GOSUB INITIALIZE.CONVERT.LINE
    IF NOT(PROCESS.LINE) THEN RETURN

    GOSUB TAKE.LINE.APART

    IF ENABLE.DEBUG.SHORTCUTS THEN
        GOSUB PROCESS.DEBUGGING.SHORTCUTS
    END

    GOSUB CHECK.FOR.STARTING.FORK
    IF NOT(PROCESS.LINE) THEN RETURN

    GOSUB CHECK.FOR.ENDING.FORK
    IF NOT(PROCESS.LINE) THEN RETURN

    GOSUB GET.CALL.OBJECT.HANDLE
    IF NOT(PROCESS.LINE) THEN RETURN

    GOSUB FIND.CALL.TYPE
    IF NOT(PROCESS.LINE) THEN RETURN

* look for possible translations from "sub" and "string" calls
    GOSUB CHECK.FOR.SUB.METHOD.CALL

    IF ENABLE.STRING.OBJECT.CALLS THEN
        GOSUB CHECK.FOR.STRING.METHOD.CALL
        IF NOT(PROCESS.LINE) THEN RETURN
    END

    GOSUB BUILD.SUBROUTINE.NAME
    IF NOT(PROCESS.LINE) THEN RETURN

* build the new subroutine call from the method / property call
    GOSUB EXTRACT.PARAMETERS

    GOSUB STARTING.SUBROUTINE.CALL
    GOSUB CHECK.NAMED.ASSIGNED.VARIABLES

    IF ASSIGNMENT.VARIABLE.COUNT > 0 AND HANDLE.METHOD.TYPE = "METHOD" THEN
        GOSUB CHECK.ASSIGNED.ALIASING
    END

    IF PAD.OUTPUT.PARAMETERS THEN
        IF HANDLE.METHOD.TYPE = "METHOD" THEN
            GOSUB PAD.OUTPUT.PARAMETERS
        END
    END

    IF CHECK.ASSIGNMENT.PROPERTY THEN
        IF HANDLE.METHOD.TYPE = "PROPERTY" OR HANDLE.METHOD.TYPE = "CONSTANT" THEN
            GOSUB CHECK.PROPERTY.ALIASING
        END
    END

    GOSUB ADD.OBJECT.HANDLE.TO.CALL
    GOSUB ADD.INPUT.PARAMETERS.TO.CALL
    GOSUB BUILD.SUBROUTINE.CALL.END

    IF WARN.ALL.PARAMETERS.ON.RIGHT OR WARN.ECLIPSE.CALLS THEN
        GOSUB CHECK.OUTPUT.PARAMETERS
    END

    GOSUB CHECK.FOR.NESTED.OBJECTS

    GOSUB FINISH.DESTROY.CALL

    GOSUB ADD.TEMPORARY.VARIABLE.CODE

    IF COMPILE.OBJECT THEN
        GOSUB ADD.INTIME.CODE 
    END

    IF COMPILE.OBJECT AND HANDLE.METHOD.TYPE = "METHOD" THEN
        GOSUB ADD.ALL.ARRAY.CODE
    END

    IF HANDLE.METHOD.TYPE = "METHOD" THEN
        GOSUB CHECK.PARAMETER.COUNT
    END

    IF CHECK.UNRESOLVED.REFERENCES THEN
        GOSUB CHECK.CALL.FOR.UNRESOLVED
    END

    RETURN

INITIALIZE.CONVERT.LINE: *************************************************
* initialize everything                                                  *
**************************************************************************

* if any subroutine changes process.line to 0 we'll stop trying to convert
* this line
    PROCESS.LINE = @TRUE

    UNRESOLVED.REFERENCE.FOUND = @FALSE

    FIXED.CODE = ""
    FIXED.CODE.COUNT = 0

    LABEL = ""
    INDENT.COUNT = 0

    NEW.LINE = ""

    STRING.OBJECT.CALL = @FALSE

    HANDLE.METHOD.TYPE = ""

    ASSIGNMENT.VARIABLE.COUNT = 0
    OUTPUT.VARIABLE.COUNT = 0

* skip any obvious lines that won't need conversions
    TRIM.THIS.LINE = TRIM(THIS.LINE)

    BEGIN CASE
        CASE TRIM.THIS.LINE = ""
            PROCESS.LINE = @FALSE
            RETURN
        CASE TRIM.THIS.LINE [1, 1] = "*" OR TRIM.THIS.LINE [1, 1] = "!"
            PROCESS.LINE = @FALSE
            RETURN
    END CASE

    CLEAN.LINE = THIS.LINE
    GOSUB CLEAN.LINE
    LABEL = CLEAN.LABEL
    UNCHANGED.CLEAN.LINE = CLEAN.LINE

* how many spaces are in the program line after the label?
    INDENT.COUNT = FIND.INDENT.COUNT (LABEL, THIS.LINE)

* don't bother with non-code lines
    IF NOT(IS.CODE(CLEAN.LINE)) THEN
        PROCESS.LINE = @FALSE
        RETURN
    END

    RETURN

TAKE.LINE.APART: *********************************************************
* take program line apart for parsing                                    *
**************************************************************************

* find first keywords in the program line
    KEY.WORD = CLEAN.LINE [" ", 1, 1]
    NEXT.WORD = CLEAN.LINE [" ", 2, 1]
    THIRD.WORD = CLEAN.LINE [" ", 3, 1]
    FOURTH.WORD = CLEAN.LINE [" ", 4, 1]

    HANDLE.ARRAY.REF = ""
    KEY.WORD.ARRAY.REF = ""

* convert any "replace with" "with" references
    GOSUB CONVERT.REPLACE.WITH.KEYWORD

* extract our key words again in case convert.other.shortcuts changed
* anything in clean.line
    IF REPLACE.WITH.CONVERTED THEN
        KEY.WORD = CLEAN.LINE [" ", 1, 1]
        NEXT.WORD = CLEAN.LINE [" ", 2, 1]
        THIRD.WORD = CLEAN.LINE [" ", 3, 1]
        FOURTH.WORD = CLEAN.LINE [" ", 4, 1]
    END

    RETURN

PROCESS.DEBUGGING.SHORTCUTS: *********************************************
* process any debugging shortcuts                                        *
**************************************************************************

* if the first word in the line is a debugging shortcut convert it
* and return
    DEBUG.LINE = @FALSE

* the debugging shortcut may be one or two characters.  we'll try to
* locate it in the debug shortcut list with two characters first.  if
* we don't find it then try by one character
    LOCATE KEY.WORD [1, 1] IN DEBUG.SHORTCUT.LIST SETTING KEY.PTR THEN
        DEBUG.LINE = @TRUE
    END ELSE
        LOCATE KEY.WORD [1, 2] IN DEBUG.SHORTCUT.LIST SETTING KEY.PTR THEN
            DEBUG.LINE = @TRUE
        END
    END

* this line is a debugging shortcut.  convert it.
    IF DEBUG.LINE THEN

        GOSUB CONVERT.DEBUG.SHORTCUTS

* extract our key words again in case convert.debug.shortcuts changed
* anything in clean.line
        KEY.WORD = CLEAN.LINE [" ", 1, 1]
        NEXT.WORD = CLEAN.LINE [" ", 2, 1]
        THIRD.WORD = CLEAN.LINE [" ", 3, 1]
        FOURTH.WORD = CLEAN.LINE [" ", 4, 1]

    END

    RETURN

CHECK.FOR.STARTING.FORK: *************************************************
* check to see if this program line has a "starting" forked subroutine   *
* call.  this would be a line like this:                                 *
*                                                                        *
*     fork(request.id) = object.handle::method (parameters)              *
*                                                                        *
* a program line like this would send a request to the multi-threaded    *
* object's phantom but not wait for the response.  the response will     *
* be fetched by the "ending" part of the fork                            *
*                                                                        *
* request.id is returned like this:                                      *
*                                                                        *
*    <1> request messaging id used to communicate with the forked        *
*        phantom process                                                 *
*    <2> instance pointer for the object we're calling                   *
**************************************************************************
    STARTING.FORK.REQUEST.ID = ""
    STARTING.FORK = @FALSE
    STARTING.FORK.PTR = 0
    STARTING.FORK.METHOD = ""
    STARTING.FORK.PARAMETER.COUNT = 0

* special check for "fork::flush" without a request id
    IF KEY.WORD [1, LEN.TEST.FLUSH.KEYWORD] = TEST.FLUSH.KEYWORD THEN
        KEY.WORD = FORK.KEYWORD:'("*")':METHOD.DELIMITER:FORK.FLUSH.KEYWORD
    END

* special check to change "blind" to "fork(blind)"
    IF KEY.WORD = BLIND.KEYWORD THEN
        KEY.WORD = FORK.KEYWORD:"(":BLIND.KEYWORD:")"
    END

* if this program line is starting a fork the first keyword will start
* with "fork(request.id)" or "fork(request.id)::".  if not dump out--it's
* not a starting fork

* first check for "fork("
    FORK.WITH.PREN = UPCASE(FORK.KEYWORD:"(")
    LEN.FORK.WITH.PREN = LEN(FORK.WITH.PREN)

    IF KEY.WORD [1, LEN.FORK.WITH.PREN] <> FORK.WITH.PREN THEN
        RETURN
    END

* now get the request id inside the parenthesis 
    PREN.DEPTH = 1
    FORK.PTR = LEN.FORK.WITH.PREN + 1
    REQUEST.ID.PTR = FORK.PTR
    NOT.CLOSED = @FALSE

    LOOP

        THIS.CHAR = KEY.WORD [FORK.PTR, 1]

        BEGIN CASE
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
            CASE THIS.CHAR = ""
                NOT.CLOSED = @TRUE
        END CASE

    UNTIL PREN.DEPTH = 0 OR NOT.CLOSED

        FORK.PTR += 1

    REPEAT

* if the parenthesis aren't closed dump out.
    IF NOT.CLOSED THEN

        OBJECT.ERROR.DESC = "Fork reference has open parenthesis"
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR

        PROCESS.LINE = @FALSE

        RETURN

    END

* this program line is starting a fork subroutine call.  the field after
* the method delimiter will be a request id.  if there's another field
* after that we're setting a value inside the fork "object"

* get the request id variable from the key.word.  we have to have a
* request.id to use when we get the response later
    STARTING.FORK.REQUEST.ID = KEY.WORD [REQUEST.ID.PTR, FORK.PTR - REQUEST.ID.PTR]

    IF STARTING.FORK.REQUEST.ID = "" THEN

        OBJECT.ERROR.DESC = "Forked reference with no Fork Id"
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR

        PROCESS.LINE = @FALSE

        RETURN

    END

* test for another field after the request.id.  if not assume that the
* fork "method name" is the STARTING.FORK.METHOD

* if the line has an equals sign in it the STARTING.FORK.METHOD will be
* everything up to the equals sign.  if there isn't on STARTING.FORK.METHOD
* will be everything after the method delimiter
    FORK.PTR += 1

    IF KEY.WORD [FORK.PTR, METHOD.DEL.LENGTH] <> METHOD.DELIMITER THEN

        STARTING.FORK.METHOD = FORK.START.KEYWORD

    END ELSE

        FORK.PTR += METHOD.DEL.LENGTH
        EQUALS.PTR = INDEX(KEY.WORD, "=", 1)

        IF EQUALS.PTR > 1 THEN
            STARTING.FORK.METHOD = KEY.WORD [EQUALS.PTR + 1, TO.THE.END]
        END ELSE
            STARTING.FORK.METHOD = KEY.WORD [FORK.PTR, TO.THE.END]
        END

    END

    STARTING.FORK.METHOD = TRIM(STARTING.FORK.METHOD, " ", "B")

    STARTING.FORK = @TRUE

* set the parameter count for this call
    BEGIN CASE

        CASE STARTING.FORK.METHOD = FORK.START.KEYWORD
            STARTING.FORK.PARAMETER.COUNT = FORK.START.PARAMETERS
        CASE STARTING.FORK.METHOD = FORK.FLUSH.KEYWORD
            STARTING.FORK.PARAMETER.COUNT = FORK.FLUSH.PARAMETERS

    END CASE

* remove the "fork::request.id = " from the program line so that we
* end up with only a "subroutine call" type of call to the object's
* method.  since we have starting.fork set we'll know to process this
* line different later

* for most of the "fork methods" with the fork expression left of the
* equals or with no equals there won't be anything left if we do this.
* save a "fork::fork.method" here so that we can find it to convert
* to eclipse code later
    EQUALS.PTR = INDEX(CLEAN.LINE, "=", 1)

    IF EQUALS.PTR > 0 THEN
        CLEAN.LINE = CLEAN.LINE [EQUALS.PTR + 2, TO.THE.END]
    END ELSE
        CLEAN.LINE = FORK.KEYWORD:"::":STARTING.FORK.METHOD
    END

    GOSUB CONVERT.WRAPUP

* extract our key words again since we changed clean.line
    KEY.WORD = CLEAN.LINE [" ", 1, 1]
    NEXT.WORD = CLEAN.LINE [" ", 2, 1]
    THIRD.WORD = CLEAN.LINE [" ", 3, 1]
    FOURTH.WORD = CLEAN.LINE [" ", 4, 1]

    RETURN

CHECK.FOR.ENDING.FORK: ***************************************************
* check to see if this program line has an "ending" forked subroutine    *
* call.  this would be in a line like this:                              *
*                                                                        *
* variable1, variable2, variable3 . . . = fork(request.id)::fork.method  *
*                                                                        *
* fork.method is optional.  if not there it will be assumed to be        *
* "response"                                                             *
*                                                                        *
* a program line like this would call the multi-threaded object to wait  *
* for a previously-sent request to be processed and returned from the    *
* multi-threaded object                                                  *
**************************************************************************
    ENDING.FORK.REQUEST.ID = ""
    ENDING.FORK = @FALSE
    ENDING.FORK.HANDLE = ""
    ENDING.FORK.METHOD = ""
    ENDING.FORK.HANDLE.DIM = ""
    ENDING.FORK.ARRAY.REF = ""
    ENDING.FORK.PARAMETER.COUNT = 0

* look for the "fork(request.id)" reference after the last equals sign
* in the line
    EQUALS.COUNT = DCOUNT(CLEAN.LINE, "=")

    IF EQUALS.COUNT < 2 THEN
        RETURN
    END

* extract the method name from the program line (if there is one)
    LAST.KEY.WORD = TRIM(CLEAN.LINE ["=", EQUALS.COUNT, 1])
    DELIMITER.PTR = INDEX (LAST.KEY.WORD, METHOD.DELIMITER, 1)
    ENDING.FORK.METHOD = TRIM(LAST.KEY.WORD [DELIMITER.PTR + METHOD.DEL.LENGTH, TO.THE.END], " ", "B")

* if the last reference in this program line is ending a fork the method
* of the call will start with "fork(".  if not dump out--it's not an
* ending fork
    FORK.WITH.PREN = UPCASE(FORK.KEYWORD:"(")
    LEN.FORK.WITH.PREN = LEN(FORK.WITH.PREN)

    FORK.WITH.DELIMITER = UPCASE(FORK.KEYWORD:METHOD.DELIMITER)
    LEN.FORK.WITH.DELIMITER = LEN(FORK.WITH.DELIMITER)

    WITH.PREN = @FALSE
    WITH.DELIMITER = @FALSE

    BEGIN CASE
        CASE ENDING.FORK.METHOD [1, LEN.FORK.WITH.PREN] = FORK.WITH.PREN 
            WITH.PREN = @TRUE
        CASE ENDING.FORK.METHOD [1, LEN.FORK.WITH.DELIMITER] = FORK.WITH.DELIMITER
            WITH.DELIMITER = @TRUE
        CASE 1
            RETURN
    END CASE

* we have an ending fork statement
    GOSUB CONVERT.REPLACE.WITH.KEYWORD

    LAST.KEY.WORD = TRIM(CLEAN.LINE ["=", EQUALS.COUNT, 1], " ", "B")

* check for an object handle from a "with" statement
    IF LAST.KEY.WORD [1, METHOD.DEL.LENGTH] = METHOD.DELIMITER THEN
        LAST.KEY.WORD = WITH.OBJECT:LAST.KEY.WORD
    END

* extract the object handle and method
    DELIMITER.PTR = INDEX (LAST.KEY.WORD, METHOD.DELIMITER, 1)
    ENDING.FORK.HANDLE = TRIM(LAST.KEY.WORD [1, DELIMITER.PTR - 1], " ", "B")
    ENDING.FORK.METHOD = TRIM(LAST.KEY.WORD [DELIMITER.PTR + METHOD.DEL.LENGTH, TO.THE.END], " ", "B")

    IF ENDING.FORK.HANDLE = "" THEN

        OBJECT.ERROR.DESC = "Forked reference with no Object"
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR

        PROCESS.LINE = @FALSE

        RETURN

    END

* this program line is ending a fork subroutine call.  the field after
* the method delimiter will be the object handle, a "fork" and the request
* id inside parenthesis:
*
*     var1, var2, var3 . . . = object.handle::fork(request.handle)
*
*                            or
*
*     var1, var2, var3 . . . = object.handle::fork(request.handle)::response
*
* if there's another method name after that, after a method delimiter then
* we're requesting a different thing from the "fork" method:
*
*     var1, var2, var3 . . . = object.handle::fork(request.handle)::method
*
* or sometimes:
*
*     var1, var2, var3 . . . = object.handle::fork::method
*
* test for another field after the request.id.  if there isn't one
* clean up the ending.fork.request.id by removing the closing pren.
* if there is one we still need to clean up the closing pren but we
* want to save the fork "method" after the method delimiter
    FORK.AFTER.PTR = INDEX(ENDING.FORK.METHOD, METHOD.DELIMITER, 1)

    BEGIN CASE

* there is no ending fork method.  assume it's a request for the response
* and set the ending.fork.method to the response keyword
        CASE FORK.AFTER.PTR = 0
            ENDING.FORK.REQUEST.ID = ENDING.FORK.METHOD ["(", 2, TO.THE.END]
            ENDING.FORK.REQUEST.ID = ENDING.FORK.REQUEST.ID [1, LEN(ENDING.FORK.REQUEST.ID) - 1]
            ENDING.FORK.METHOD = UPCASE (FORK.RESPONSE.KEYWORD)

* there's an ending fork method but the "fork" isn't followed by a
* request id in parenthesis.  extract the ending fork method but the
* ending request id will be null
        CASE WITH.DELIMITER
            ENDING.FORK.REQUEST.ID = ""
            ENDING.FORK.METHOD = ENDING.FORK.METHOD [FORK.AFTER.PTR + METHOD.DEL.LENGTH, TO.THE.END]

* there is an ending fork method and a request id in parenthesis.  extract
* the request id and the ending fork method
        CASE WITH.PREN
            ENDING.FORK.REQUEST.ID = ENDING.FORK.METHOD [1, FORK.AFTER.PTR - 1] ["(", 2, TO.THE.END]
            ENDING.FORK.REQUEST.ID = ENDING.FORK.REQUEST.ID [1, LEN(ENDING.FORK.REQUEST.ID) - 1]
            ENDING.FORK.METHOD = ENDING.FORK.METHOD [FORK.AFTER.PTR + METHOD.DEL.LENGTH, TO.THE.END]

* we should never get here but just in case
        CASE 1
            RETURN

    END CASE

    BEGIN CASE

* if we have a request id of "*" (without quotes) change it to "*"
* (with quotes) so that we can have an ending fork parameter of just
* "*"
        CASE ENDING.FORK.REQUEST.ID = "*"
            ENDING.FORK.REQUEST.ID = '"*"'

* we have a request id
        CASE ENDING.FORK.REQUEST.ID <> ""
            NULL

* if the fork method is one of the special fork methods and
* the ending request id is null set it to "*" as well.  this makes
* the request id optional for some fork methods
        CASE ENDING.FORK.METHOD = FORK.BUSY.KEYWORD
            ENDING.FORK.REQUEST.ID = '"*"'
        CASE ENDING.FORK.METHOD = FORK.READY.KEYWORD
            ENDING.FORK.REQUEST.ID = '"*"'
        CASE ENDING.FORK.METHOD = FORK.PID.KEYWORD
            ENDING.FORK.REQUEST.ID = '"*"'
        CASE ENDING.FORK.METHOD = FORK.FLUSH.KEYWORD
            ENDING.FORK.REQUEST.ID = '"*"'

* if we get this far we need a fork request id but don't have one
        CASE ENDING.FORK.REQUEST.ID = ""
            OBJECT.ERROR.DESC = "Forked reference with no Fork Id"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

            PROCESS.LINE = @FALSE

            RETURN

    END CASE

    ENDING.FORK = @TRUE

* set how many parameters this method has
    BEGIN CASE

        CASE ENDING.FORK.METHOD = FORK.RESPONSE.KEYWORD
            ENDING.FORK.PARAMETER.COUNT = FORK.RESPONSE.PARAMETERS

        CASE ENDING.FORK.METHOD = FORK.BUSY.KEYWORD
            ENDING.FORK.PARAMETER.COUNT = FORK.BUSY.PARAMETERS

        CASE ENDING.FORK.METHOD = FORK.READY.KEYWORD
            ENDING.FORK.PARAMETER.COUNT = FORK.READY.PARAMETERS

        CASE ENDING.FORK.METHOD = FORK.PID.KEYWORD
            ENDING.FORK.PARAMETER.COUNT = FORK.PID.PARAMETERS

    END CASE

* convert this line to a "statement" type of call so that it will be converted
* in a single pass by convert.this.line.  the multi-thread object's get.response
* method has "maximum.fork.parameters" parameters so we'll pad these variables
* out with nulls until we get "maximum.fork.parameters" parameters and then add
* the request id
    ASSIGNMENT.VARIABLE.LIST = TRIM(CLEAN.LINE ["=", 1, 1])
    VARIABLE.COUNT = DCOUNT(ASSIGNMENT.VARIABLE.LIST, ",")

    BEGIN CASE

        CASE VARIABLE.COUNT = MAXIMUM.FORK.PARAMETERS
            NULL

        CASE VARIABLE.COUNT > MAXIMUM.FORK.PARAMETERS
            ASSIGNMENT.VARIABLE.LIST = ASSIGNMENT.VARIABLE.LIST [",", 1, MAXIMUM.FORK.PARAMETERS]

        CASE 1
            FOR PAD.LOOP = VARIABLE.COUNT + 1 TO ENDING.FORK.PARAMETER.COUNT
                ASSIGNMENT.VARIABLE.LIST := ',""'
            NEXT PAD.LOOP

    END CASE

* build a method call to retrieve the returned parameters from the multi-threaded
* object phantom
    REQUEST.ID.PARAMETER = "CHECK.REQUEST.ID=":ENDING.FORK.REQUEST.ID
    ASSIGNMENT.VARIABLE.LIST := ",":ENDING.FORK.REQUEST.ID
    CLEAN.LINE = ENDING.FORK.HANDLE:METHOD.DELIMITER:ENDING.FORK.METHOD:"(":ASSIGNMENT.VARIABLE.LIST:")"

    THIS.LINE = "    ":CLEAN.LINE

    GOSUB CONVERT.WRAPUP

* extract our key words again since we changed clean.line
    KEY.WORD = CLEAN.LINE [" ", 1, 1]
    NEXT.WORD = CLEAN.LINE [" ", 2, 1]
    THIRD.WORD = CLEAN.LINE [" ", 3, 1]
    FOURTH.WORD = CLEAN.LINE [" ", 4, 1]

* build key.word so that it can be found in handle.keyword.list.  the method
* name isn't important as build.subroutine.name will use ending.fork.method.
* we'll use "new" as every object has a new method.
*
* if this is a dimensioned object set the dimension values in 
* ending.fork.handle.dim.  build.subroutine.name will use them to build the
* the subroutine call
    KEY.WORD = ENDING.FORK.HANDLE ["(", 1, 1]

    IF COUNT(ENDING.FORK.HANDLE, "(") <> 0 THEN
        KEY.WORD := "()"
        ENDING.FORK.HANDLE.DIM = "(":ENDING.FORK.HANDLE ["(", 2, TO.THE.END]
        ENDING.FORK.ARRAY.REF = ENDING.FORK.HANDLE.DIM [2, LEN(ENDING.FORK.HANDLE.DIM) - 2]
    END

    KEY.WORD := METHOD.DELIMITER:"NEW"

    RETURN

GET.CALL.OBJECT.HANDLE: **************************************************
* get the complete object handle for the method call                     *
**************************************************************************

* handle "with" statements
    BEGIN CASE

* "WITH", start a "with" structure
        CASE KEY.WORD = WITH.KEYWORD
            GOSUB CONVERT.WITH
            PROCESS.LINE = @FALSE
            RETURN

* "ENDWITH", end a "with" structure
        CASE KEY.WORD = END.WITH.KEYWORD
            GOSUB CONVERT.END.WITH
            PROCESS.LINE = @FALSE
            RETURN

    END CASE

* check for multivalued keyword
    GOSUB SPLIT.DYNAMIC.KEY.WORD

* take care of (possibly) dimensioned handles and (possibly) dimensioned
* properties
    GOSUB GET.HANDLE.FROM.KEY.WORD

* if we have a dynamic assignment (of any kind) don't convert here.  the
* put.property routines have the ability to put values into the multi
* value of a property if multivalue.properties is turned on

* if we have a dynamic assignment and we successfully split the assignment
* variable from the multivalue reference we can still convert it.

* if we have a text insert here we can't convert it in this routine
    IF (DYNAMIC.KEY.WORD AND NOT(DYNAMIC.SPLIT)) OR TEXT.INSERT.KEY.WORD THEN
        GOSUB CONVERT.LINE.WRAPUP
        PROCESS.LINE = @FALSE
        RETURN
    END

    RETURN

FIND.CALL.TYPE: **********************************************************
* check for an assignment-type method call.  if one isn't found check    *
* for a non-assignment type call                                         *
**************************************************************************
    ASSIGNMENT.TYPE = @FALSE
    ASSIGNMENT.VARIABLE = ""

* if this line has an ending forked method call we already know it's
* an assignment line.  we don't need to do any checking of the handle
* or anything because we'll be calling the multi-threaded object to
* fetch the returned values from the method call
    IF ENDING.FORK THEN

        ASSIGNMENT.TYPE = @TRUE

        ASSIGNMENT.TEXT = THIS.LINE
        GOSUB FIND.ASSIGNMENT.VARIABLE.AFTER

        RETURN 

    END

* if the second word is an equals sign then we have an assignment
* statement.  the first word isn't an object call, it's the target
* variable for the value pulled from whatever's on the right side
* of the equals sign

* if we're converting unresolved references, however, we don't want to
* convert this type of statement.  the code to the right of the equals
* sign could have other object references after it or have other code
* on the line with it.  without fixing unresolved references this just
* isn't allowed, like with eclipse subroutine / function code.  if
* we're fixing unresolved references leave the object reference here
* and we'll pick it up later

* just because next.work is an equals sign doesn't mean we necessarily
* have an assignment here.  named parameters can have an equals sign
* in them and that can fool the extraction of next.word.  if we have
* a next word of "=" find.assignment.variable will test for valid
* assignments and we can be sure if we have an assignment or not
    IF NEXT.WORD = "=" THEN

        ASSIGNMENT.TEXT = THIS.LINE
        GOSUB FIND.ASSIGNMENT.VARIABLE.AFTER
        IF ASSIGNMENT.VARIABLE = "" THEN
            NEXT.WORD = ""
        END

    END

* if we have an assignment type statement check its validity
    IF NEXT.WORD = "=" THEN

        ASSIGNMENT.TYPE = @TRUE

* in an assignment statement we could have the object method reference
* to the left of the equals sign if it's a property or array reference.
* for anything else it should be on the right side of the equals sign.
* see if the keyword to the left of the equals sign is an object method
* reference.  if so make sure it's a property or array reference

* if we have a property or array reference left of the equals sign
* leave the keyword alone but set the assignment variable to the "method"
* from the table (actually the property name).  later code will know
* what to do with it

* test to see if key.word is a call to the "subroutine" pseudo-object
* and update the usage tables if necessary
        GOSUB CHECK.SUB.OBJECT.KEYWORD

* check for string pseudo-object call if enabled
        IF ENABLE.STRING.OBJECT.CALLS THEN

            GOSUB CHECK.STRING.OBJECT.KEYWORD

            IF STRING.OBJECT.CALL THEN
                GOSUB CONVERT.STRING.OBJECT.CALL
                PROCESS.LINE = @FALSE
                RETURN
            END

        END

* if we can find the key.word in our handle list then we have an object
* reference
        FIND KEY.WORD IN HANDLE.KEYWORD.LIST SETTING HANDLE.PTR, METHOD.PTR THEN

            HANDLE.METHOD.TYPE = HANDLE.TYPE.LIST<HANDLE.PTR,METHOD.PTR>
            IF HANDLE.METHOD.TYPE = "METHOD" THEN
                PRINT "Method Reference left of Equals in Line ":LINE.LOOP
            END

* if the keyword to the left of the equals sign is an object method
* reference.  if it is and the reference is to a property or array clear
* the assignment type flag so we know which way to handle it
            ASSIGNMENT.TEXT = THIS.LINE
            GOSUB FIND.ASSIGNMENT.VARIABLE.AFTER
            ASSIGNMENT.TYPE = @FALSE

        END ELSE

* check for a non-assignment-type method call

* if there's no object method reference to the left of the equals sign
* then the object method reference may be on the right side.  pull off
* the assignment variable from the left of the equals sign and get the
* possible object method reference from the right

* if allow.object.right.of.equals isn't set that means we can only convert
* an object reference to the right of the equals sign if the reference
* is the ONLY thing on the right of the equals sign.  if there's anything
* else then it's a more complex statement, this routine can't convert it,
* so we'll let fix.unresolved.references take care of it

* literal passed parameters may have spaces in them so we can't do a simple
* field extract to see if there's anything after.  take everything from the
* third word onward.  skip ahead to the first space that's not in quotes.
* everything from there forward will be text that's after the (possible)
* object reference
            RIGHT.TEXT = CLEAN.LINE [" ", 3, TO.THE.END]
            ADDITIONAL.PTR = FIRST.SPACE(RIGHT.TEXT)

            IF ADDITIONAL.PTR = 0 THEN
                ADDITIONAL.TEXT = ""
            END ELSE
                ADDITIONAL.TEXT = RIGHT.TEXT [ADDITIONAL.PTR + 1, TO.THE.END]
            END

            IF ALLOW.EXTRAS.RIGHT.OF.EQUALS OR TRIM(ADDITIONAL.TEXT) = "" THEN

* okay, let's look to the right of the equals sign.  save the first
* keyword as a possible target of an assignment.  set the next word after
* the equals sign as a possible keyword
                ASSIGNMENT.VARIABLE = KEY.WORD
                KEY.WORD = THIRD.WORD

* check for multivalued keyword
                GOSUB SPLIT.DYNAMIC.KEY.WORD

* take care of (possibly) dimensioned handles and (possibly) dimensioned
* properties
                GOSUB GET.HANDLE.FROM.KEY.WORD

* if we have a text insert here we can't convert it in this routine
                IF (DYNAMIC.KEY.WORD AND NOT(DYNAMIC.SPLIT)) OR TEXT.INSERT.KEY.WORD THEN
                    GOSUB CONVERT.LINE.WRAPUP
                    PROCESS.LINE = @FALSE
                    RETURN
                END

* test to see if key.word is a call to the "subroutine" pseudo-object
* and update the usage tables if necessary
                GOSUB CHECK.SUB.OBJECT.KEYWORD

* check for string pseudo-object call if enabled
                IF ENABLE.STRING.OBJECT.CALLS THEN

                    GOSUB CHECK.STRING.OBJECT.KEYWORD

                    IF STRING.OBJECT.CALL THEN
                        GOSUB CONVERT.STRING.OBJECT.CALL
                        PROCESS.LINE = @FALSE
                        RETURN
                    END

                END

* if we can find the key.word in our handle list then we have an object
* reference to the right of the equals sign.  if we don't have an object
* reference here there's nothing more this routine can do with this line
                FIND KEY.WORD IN HANDLE.KEYWORD.LIST SETTING HANDLE.PTR, METHOD.PTR ELSE
                    GOSUB CONVERT.LINE.WRAPUP
                    PROCESS.LINE = @FALSE
                    RETURN
                END

            END

        END

    END

* if the resulting key.word isn't an object::method or object::property
* or anything like that dump out
    IF INDEX(KEY.WORD, METHOD.DELIMITER, 1) < 1 THEN
        IF INDEX(KEY.WORD, PROPERTY.DELIMITER, 1) < 1 THEN
            IF INDEX(KEY.WORD, CONSTANT.DELIMITER, 1) < 1 THEN
                IF INDEX(KEY.WORD, CHILD.DELIMITER, 1) < 1 THEN

                    GOSUB CONVERT.LINE.WRAPUP
                    PROCESS.LINE = @FALSE
                    RETURN

                END
            END
        END
    END

    RETURN

CHECK.FOR.SUB.METHOD.CALL: ***********************************************
* check for a "sub::" method call and string pseudo-object calls         *
**************************************************************************

* test to see if key.word is a call to the "subroutine" pseudo-object
* and update the usage tables if necessary
    GOSUB CHECK.SUB.OBJECT.KEYWORD

    RETURN

CHECK.FOR.STRING.METHOD.CALL: ********************************************
* check for string pseudo-object call if enabled                         *
**************************************************************************
    GOSUB CHECK.STRING.OBJECT.KEYWORD

    IF STRING.OBJECT.CALL THEN
        GOSUB CONVERT.STRING.OBJECT.CALL
        PROCESS.LINE = @FALSE
        RETURN
    END

    RETURN

FIND.ASSIGNMENT.VARIABLE.AFTER: ******************************************
* find assignment.variable in assignment.text.  the assignment.variable  *
* will be all text in assignment.text after an equals sign that does     *
* a assignment.  the text in assignment.text that exists after the       *
* equals sign is extracted and checked for opening and closing           *
* parenthesis.  if the parenthesis aren't matching then the equals sign  *
* can't be an assignment equals sign as it's inside another expression.  *
* the same goes for single and double quotes                             *
**************************************************************************
    ASSIGNMENT.VARIABLE = ""
    EQUALS.SIGN.COUNT = COUNT(ASSIGNMENT.TEXT, "=")

    IF EQUALS.SIGN.COUNT = 0 THEN
        RETURN
    END

* check each equals sign in assignment.text.  if one of them turns out
* to be an assignment equals sign we'll return everything to the right
* of it in assignment.variable
    FOR EQUALS.LOOP = 1 TO EQUALS.SIGN.COUNT

        TEST.ASSIGNMENT.PTR = INDEX(ASSIGNMENT.TEXT, "=", EQUALS.LOOP)
        TEST.ASSIGNMENT = ASSIGNMENT.TEXT [TEST.ASSIGNMENT.PTR + 1, TO.THE.END]

* see if test.assignment has matching parenthese, brackets and quotes.
* if not then this can't be an assignment
        BEGIN CASE

            CASE COUNT(TEST.ASSIGNMENT, "(") <> COUNT(TEST.ASSIGNMENT, ")")
                GOOD.ASSIGNMENT = @FALSE
            CASE COUNT(TEST.ASSIGNMENT, "[") <> COUNT(TEST.ASSIGNMENT, "]")
                GOOD.ASSIGNMENT = @FALSE
            CASE MOD(COUNT(TEST.ASSIGNMENT, '"'), 2) <> 0
                GOOD.ASSIGNMENT = @FALSE
            CASE MOD(COUNT(TEST.ASSIGNMENT, "'"), 2) <> 0
                GOOD.ASSIGNMENT = @FALSE

            CASE 1
                GOOD.ASSIGNMENT = @TRUE
                ASSIGNMENT.VARIABLE = TEST.ASSIGNMENT

        END CASE

    NEXT EQUALS.LOOP

    RETURN

FIND.ASSIGNMENT.VARIABLE.BEFORE: *****************************************
* find assignment.variable in assignment.text.  the assignment.variable  *
* will be all text in assignment.text before an equals sign that does    *
* a assignment.  the text in assignment.text that exists after the       *
* equals sign is extracted and checked for opening and closing           *
* parenthesis.  if the parenthesis aren't matching then the equals sign  *
* can't be an assignment equals sign as it's inside another expression.  *
* the same goes for single and double quotes                             *
**************************************************************************
    ASSIGNMENT.VARIABLE = ""
    EQUALS.SIGN.COUNT = COUNT(ASSIGNMENT.TEXT, "=")

    IF EQUALS.SIGN.COUNT = 0 THEN
        RETURN
    END

* check each equals sign in assignment.text.  if one of them turns out
* to be an assignment equals sign we'll return everything to the right
* of it in assignment.variable
    FOR EQUALS.LOOP = 1 TO EQUALS.SIGN.COUNT

        TEST.ASSIGNMENT.PTR = INDEX(ASSIGNMENT.TEXT, "=", EQUALS.LOOP)
        TEST.ASSIGNMENT = ASSIGNMENT.TEXT [1, TEST.ASSIGNMENT.PTR - 1]

* see if test.assignment has matching parenthese, brackets and quotes.
* if not then this can't be an assignment
        BEGIN CASE

            CASE COUNT(TEST.ASSIGNMENT, "(") <> COUNT(TEST.ASSIGNMENT, ")")
                GOOD.ASSIGNMENT = @FALSE
            CASE COUNT(TEST.ASSIGNMENT, "[") <> COUNT(TEST.ASSIGNMENT, "]")
                GOOD.ASSIGNMENT = @FALSE
            CASE MOD(COUNT(TEST.ASSIGNMENT, '"'), 2) <> 0
                GOOD.ASSIGNMENT = @FALSE
            CASE MOD(COUNT(TEST.ASSIGNMENT, "'"), 2) <> 0
                GOOD.ASSIGNMENT = @FALSE

            CASE 1
                GOOD.ASSIGNMENT = @TRUE
                ASSIGNMENT.VARIABLE = TEST.ASSIGNMENT

        END CASE

    NEXT EQUALS.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / build subroutine names                             **
**************************************************************************
**************************************************************************

BUILD.SUBROUTINE.NAME: ***************************************************
* find call in handle tables and build subroutine name                   *
**************************************************************************

* try to find the first word in the object usage table.  if we find
* it then this is a method call.  if we don't find anything check the
* line for unresolved references before returning
    HANDLE.PTR = 0
    METHOD.PTR = 0

    FIND KEY.WORD IN HANDLE.KEYWORD.LIST SETTING HANDLE.PTR, METHOD.PTR ELSE
        GOSUB CONVERT.LINE.WRAPUP
        PROCESS.LINE = 0
        RETURN
    END

* flag this method / property / whatever as having been called
    HANDLE.METHOD.CALLED.LIST<HANDLE.PTR, METHOD.PTR> = @TRUE
 
* get the variable to pass as the object's handle
    HANDLE.PARAMETER = HANDLE.VARIABLE.LIST<HANDLE.PTR>

* build the eclipse subroutine name depending on the type of reference.
* NOTE: statics and properties are both typed as "property" in
* handle.method.type since they both work the same from this end
    HANDLE.OBJECT = HANDLE.OBJECT.LIST<HANDLE.PTR>
    HANDLE.VARIABLE = HANDLE.VARIABLE.LIST<HANDLE.PTR>

    HANDLE.METHOD = HANDLE.METHOD.LIST<HANDLE.PTR, METHOD.PTR>
    HANDLE.METHOD.TYPE = HANDLE.TYPE.LIST<HANDLE.PTR, METHOD.PTR>

    HANDLE.DIMENSIONS = HANDLE.DIMENSIONS.LIST<HANDLE.PTR, METHOD.PTR>

    HANDLE.CALL.PARAMETER = RAISE(RAISE(HANDLE.PARAMETER.LIST<HANDLE.PTR, METHOD.PTR>))
    HANDLE.CALL.PARAMETER.COUNT = DCOUNT(HANDLE.CALL.PARAMETER, @AM)
    HANDLE.CALL.BYVAL = RAISE(RAISE(HANDLE.PARAMETER.BYVAL.LIST<HANDLE.PTR, METHOD.PTR>))
    HANDLE.CALL.SPECIAL = RAISE(RAISE(HANDLE.PARAMETER.SPECIAL.LIST<HANDLE.PTR, METHOD.PTR>))

    HANDLE.OUTPUT.COUNT = HANDLE.OUTPUT.COUNT.LIST<HANDLE.PTR, METHOD.PTR>
    HANDLE.OUTPUT.PARAMETER = RAISE(RAISE(HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.PTR, METHOD.PTR>))

    HANDLE.MULTI.THREADED = HANDLE.MULTI.THREADED.LIST<HANDLE.PTR>

* test to see if this object is a multi-threaded object
    MULTI.THREADED.CALL = HANDLE.MULTI.THREADED

* tweak some things for multi-threaded calls
    BEGIN CASE

        CASE NOT(MULTI.THREADED.CALL)
            NULL

* if we're "starting" a fork request but the fork request is for a "method"
* other than REQUEST it's really a call to a client-side multi-threaded object
* method.  change parameters for the called method
        CASE STARTING.FORK AND STARTING.FORK.METHOD <> FORK.START.KEYWORD
            HANDLE.CALL.PARAMETER.COUNT = STARTING.FORK.PARAMETER.COUNT
            HANDLE.CALL.BYVAL = ""
            HANDLE.CALL.SPECIAL = ""

* we're starting a fork request to a method
        CASE STARTING.FORK
            NULL
    
* if this line is ending a multi-threaded request the number of parameters
* will always be "maximum.fork.parameters" + 1 and the number of output 
* parameters will be will always be "maximum.fork.parameters"

* for ending a forked request there will never be any output parameters as
* we're converting the call to a "statement" type call always
        CASE ENDING.FORK

            HANDLE.CALL.PARAMETER.COUNT = ENDING.FORK.PARAMETER.COUNT + 1
            HANDLE.CALL.BYVAL = ""
            HANDLE.CALL.SPECIAL = ""

* dummy up the "method's" parameters just so everything has a value
            FOR PARM.LOOP = 1 TO HANDLE.CALL.PARAMETER.COUNT
                HANDLE.CALL.PARAMETER<PARM.LOOP> = "PARAMETER":PARM.LOOP
            NEXT PARM.LOOP

* add a final parameter for the fork request id as a byval parameter
            HANDLE.CALL.PARAMETER<HANDLE.CALL.PARAMETER.COUNT> = "CHECK.REQUEST.ID"
            HANDLE.CALL.BYVAL<MAXIMUM.FORK.PARAMETERS + 1> = @TRUE

* there will always be zero output parameters
            HANDLE.OUTPUT.COUNT = 0
            HANDLE.OUTPUT.PARAMETER = ""

    END CASE

* if any of the parameters are properties or eclipse common variables
* and it's a byref call we don't want to pass the property / common
* variable in the call.  this could lead to aliasing problems later.
* if we have a property or common variable we'll use a temporary variable
* in the actual call.  these two variables will hold the property / common
* variable and the temporary variable if we find this situation
    ORIGINAL.PARAMETER.LIST = ""
    TEMP.PARAMETER.LIST = ""

* build a call for this object reference
    BEGIN CASE

* multi-threaded calls:

*     forked method call:
        CASE MULTI.THREADED.CALL AND STARTING.FORK AND HANDLE.METHOD.TYPE = "METHOD"
            GOSUB BUILD.MULTI.THREADED.STARTING.FORK.SUBROUTINE.NAME

        CASE MULTI.THREADED.CALL AND ENDING.FORK AND HANDLE.METHOD.TYPE = "METHOD"
            GOSUB BUILD.MULTI.THREADED.ENDING.FORK.SUBROUTINE.NAME

*     method call:
        CASE MULTI.THREADED.CALL AND HANDLE.METHOD.TYPE = "METHOD"
            GOSUB BUILD.MULTI.THREADED.METHOD.SUBROUTINE.NAME

*     property call:
        CASE MULTI.THREADED.CALL AND HANDLE.METHOD.TYPE = "PROPERTY"
            GOSUB BUILD.MULTI.THREADED.PROPERTY.SUBROUTINE.NAME

*     array property call:
        CASE MULTI.THREADED.CALL AND HANDLE.METHOD.TYPE = "ARRAY"
            GOSUB BUILD.MULTI.THREADED.ARRAY.SUBROUTINE.NAME

*     constant call
        CASE MULTI.THREADED.CALL AND HANDLE.METHOD.TYPE = "CONSTANT"
            GOSUB BUILD.MULTI.THREADED.CONSTANT.SUBROUTINE.NAME


*     bad multi-threaded call:
        CASE MULTI.THREADED.CALL OR STARTING.FORK OR ENDING.FORK 
            GOSUB MULTI.THREADED.ERRORS


* single-threaded calls:

*     method calls:
        CASE HANDLE.METHOD.TYPE = "METHOD"
            GOSUB BUILD.METHOD.SUBROUTINE.NAME

*     property calls:
        CASE HANDLE.METHOD.TYPE = "PROPERTY"
            GOSUB BUILD.PROPERTY.SUBROUTINE.NAME

*     array property calls:
        CASE HANDLE.METHOD.TYPE = "ARRAY"
            GOSUB BUILD.PROPERTY.ARRAY.SUBROUTINE.NAME

*     constant call
        CASE HANDLE.METHOD.TYPE = "CONSTANT"
            GOSUB BUILD.CONSTANT.SUBROUTINE.NAME


    END CASE

    RETURN

BUILD.MULTI.THREADED.STARTING.FORK.SUBROUTINE.NAME: **********************
* build the subroutine name to call for a multi-threaded starting fork   *
* call                                                                   *
**************************************************************************
    BEGIN CASE

* destroy the multi-threaded object.  go to the multi-threaded handler
* object directly
        CASE HANDLE.METHOD = DESTROY.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:DESTROY.KEYWORD

* start a forked method call
        CASE STARTING.FORK.METHOD = FORK.START.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.START.METHOD.NAME

* reference is a method call to the forked flush method.  build a call to
* the multi-threaded object handler to flush requests
        CASE STARTING.FORK.METHOD = FORK.FLUSH.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.FLUSH.METHOD.NAME

* the starting fork method is invalid
        CASE 1
            OBJECT.ERROR.DESC = "Invalid starting fork method: ":STARTING.FORK.METHOD
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

    RETURN

BUILD.MULTI.THREADED.ENDING.FORK.SUBROUTINE.NAME: ************************
* build the subroutine name to call for a multi-threaded ending fork     *
* call                                                                   *
**************************************************************************
    BEGIN CASE

* destroy the multi-threaded object.  go to the multi-threaded handler
* object directly
        CASE HANDLE.METHOD = DESTROY.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:DESTROY.KEYWORD

* reference is a method call to get the response from a forked multi-threaded
* method.  build a call to the multi-threaded object to get the response.
        CASE ENDING.FORK.METHOD = FORK.RESPONSE.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.RESPONSE.METHOD.NAME

* no ending fork method specified.  assume it's a response request
        CASE ENDING.FORK.METHOD = ""
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.RESPONSE.METHOD.NAME
 
* reference is a method call to find out if the response from this multi-threaded
* call is busy.  build a call to the multi-threaded object handler to check if a
* forked method request is still busy
        CASE ENDING.FORK.METHOD = FORK.BUSY.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.BUSY.METHOD.NAME

* reference is a method call to find out if the response from this multi-threaded
* call is ready yet.  build a call to the multi-threaded object handler to
* check if a forked method request has finished
        CASE ENDING.FORK.METHOD = FORK.READY.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.READY.METHOD.NAME

* reference is a method call to get the pid for the phantom process.
* build a call to the multi-threaded object handler to return the phantom
* process' id
        CASE ENDING.FORK.METHOD = FORK.PID.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.PID.METHOD.NAME

* the ending fork method is invalid
        CASE ENDING.FORK.METHOD <> ""
            OBJECT.ERROR.DESC = "Invalid ending fork method: ":ENDING.FORK.METHOD
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

    RETURN

BUILD.MULTI.THREADED.METHOD.SUBROUTINE.NAME: *****************************
* build a call to a non-forked multi-threaded method call                *
**************************************************************************
    BEGIN CASE

* destroy the multi-threaded object.  go to the multi-threaded handler
* object directly
        CASE HANDLE.METHOD = DESTROY.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:DESTROY.KEYWORD

* reference is a method call to the forked flush method.  build a call to
* the multi-threaded object handler to flush requests
        CASE STARTING.FORK.METHOD = FORK.FLUSH.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.FLUSH.METHOD.NAME

* reference is a method call to get the pid for the phantom process.
* build a call to the multi-threaded object handler to return the phantom
* process' id
        CASE ENDING.FORK.METHOD = FORK.PID.KEYWORD
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:FORK.PID.METHOD.NAME

* non-forked method call to a multi-threaded object.  build a call to the
* multi-threaded object to send a request and get the response to/from
* the object's phantom
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME

    END CASE

    RETURN

BUILD.MULTI.THREADED.PROPERTY.SUBROUTINE.NAME: ***************************
* build a subroutine call to get a multi-threaded property               *
**************************************************************************
    BEGIN CASE

* reference is to a property or static that's in a multi-threaded object and a property
* is being set value.  build a call to the multi-threaded object and send a request to
* the object's phantom
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME
            
* reference is to a property or static that's in a multi-threaded object and the property
* value is being set.  build a call to PUT.PROPERTY to save the property value
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME

    END CASE

    RETURN

BUILD.MULTI.THREADED.ARRAY.SUBROUTINE.NAME: ******************************
* build a subroutine call to get a dimensioned multi-threaded property   *
**************************************************************************
    BEGIN CASE

* reference is to a property or static that's in a multi-threaded object and a property
* is being set value.  build a call to the multi-threaded object and send a request to
* the object's phantom
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME
            
* reference is to a property or static that's in a multi-threaded object and the property
* value is being set.  build a call to PUT.PROPERTY to save the property value
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME

    END CASE

    RETURN

BUILD.MULTI.THREADED.CONSTANT.SUBROUTINE.NAME: ***************************
* build a subroutine call to get a multi-threaded constant               *
**************************************************************************
    BEGIN CASE

* reference is to a constant value in a multi-threaded object and it's getting
* a constant value.  build a call to GET.PROPERTY
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:MULTI.THREAD.OBJECT.NAME
            ECLIPSE.SUBROUTINE := ECLIPSE.DELIMITER:SEND.AND.GET.METHOD.NAME

* can't set a constant
        CASE 1
            OBJECT.ERROR.DESC = "Can't set a constant"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

    RETURN

MULTI.THREADED.ERRORS: ***************************************************
* we are supposed to build a multi-threaded subroutine call but there    *
* is something wrong with the multi-threaded parameters                  *
**************************************************************************
    BEGIN CASE

* we have a forked starting call to an object that isn't multi-threaded
        CASE STARTING.FORK AND NOT(MULTI.THREADED.CALL)
            OBJECT.ERROR.DESC = "Forked call on a non-multi-threaded object"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

* we have a forked starting call that's not to a method
        CASE STARTING.FORK AND HANDLE.METHOD.TYPE <> "METHOD"
            OBJECT.ERROR.DESC = "Forked calls can only be to Methods"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

* we have a forked ending call to an object that isn't multi-threaded
        CASE ENDING.FORK AND NOT(MULTI.THREADED.CALL)
            OBJECT.ERROR.DESC = "Forked call on a non-multi-threaded object"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

* we have a forked ending call that's not to a method
        CASE ENDING.FORK AND HANDLE.METHOD.TYPE <> "METHOD"
            OBJECT.ERROR.DESC = "Forked calls can only be to Methods"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

* anything else
        CASE 1
            OBJECT.ERROR.DESC = "Invalid multi-threaded call"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

    RETURN

BUILD.METHOD.SUBROUTINE.NAME: ********************************************
* build the subroutine name for a method call                            *
**************************************************************************
    BEGIN CASE

* reference is to the subroutine call pseudo-object.  build a call
* to the subroutine
        CASE HANDLE.OBJECT = SUBROUTINE.CALL.KEYWORD
            ECLIPSE.SUBROUTINE = HANDLE.METHOD

* reference is to a method.  build a call to an eclipse subroutine
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:HANDLE.METHOD

    END CASE

    RETURN

BUILD.PROPERTY.SUBROUTINE.NAME: ******************************************
* build the subroutine name to set or get a property                     *
**************************************************************************
    BEGIN CASE

* reference is to a property or static and it's getting a property value.
* build a call to GET.PROPERTY to get the property value
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:GET.KEYWORD

* reference is to a property or static and the property value is being set.
* build a call to PUT.PROPERTY to save the property value
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:PUT.KEYWORD

    END CASE

    RETURN

BUILD.PROPERTY.ARRAY.SUBROUTINE.NAME: ************************************
* buld a subroutine name to set or get a property array                  *
**************************************************************************
    BEGIN CASE

* reference is to a property array or static array and it's getting a property value
* build a call to GET.PROPERTY
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:GET.KEYWORD

* reference is to a property array or static array and the property value is being set
* build a call to PUT.PROPERTY
        CASE 1
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:PUT.KEYWORD


    END CASE

    RETURN

BUILD.CONSTANT.SUBROUTINE.NAME: ******************************************
* build the subroutine name to get a constant                            *
**************************************************************************
    BEGIN CASE

* reference is to a constant value and it's getting a constant value.
* build a call to GET.PROPERTY
        CASE ASSIGNMENT.TYPE
            ECLIPSE.SUBROUTINE = ECLIPSE.PREFIX:HANDLE.OBJECT:ECLIPSE.DELIMITER:GET.KEYWORD

* can't set a constant
        CASE 1
            OBJECT.ERROR.DESC = "Can't set a constant"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** code conversion / build subroutine call statement                    **
**************************************************************************
**************************************************************************

EXTRACT.PARAMETERS: ******************************************************
* extract parameters after the keyword                                   *
**************************************************************************

* if we're parsing the ending half of a multi-threaded call we'll dummy
* up raw.key.word to match this.line as built by check.for.ending.fork
    IF MULTI.THREADED.CALL AND ENDING.FORK THEN
        RAW.KEY.WORD = ENDING.FORK.HANDLE:METHOD.DELIMITER:ENDING.FORK.METHOD
    END

* pointers to the keyword in the program line.  we'll use the raw keyword
* since convert.dimensioned.handle may have changed it so that the keyword
* could be found in the tables
    KEYWORD.PTR = INDEX(THIS.LINE, RAW.KEY.WORD, 1)
    KEYWORD.LEN = LEN(RAW.KEY.WORD)

* chop off program line bits before and after the keyword.  if there's anything here
* it will be a list of parameters that are receiving values from the method call
    PART.BEFORE = THIS.LINE [1, KEYWORD.PTR - 1]
    PART.AFTER = TRIM(THIS.LINE [KEYWORD.PTR + KEYWORD.LEN, TO.THE.END], " ", "L")

* do some cleanup of the text that follows the object reference
    BEGIN CASE

* if this is a "statement type" statement, where we have an object
* reference starting the statement, it may be that the object reference
* is being assigned something, ie, object::property = somevalue.  if
* this is the case then part.after will begin with an equals sign followed
* by the rest of the line.  if this is the case we need to remove the
* equals sign so that our statement will come out correctly later on
        CASE PART.AFTER [1, 1] = "="

            PART.AFTER = TRIM(PART.AFTER [2, TO.THE.END], " ", "L")

* if we don't have an equals sign there it's possible we might have a
* statement type of object reference but the programmer still put
* parenthesis around the arguments.  since this can make sense and we
* don't want to punish programmers who think we'll check to see if the
* the part after the keyword starts with an open parenthesis.  if it
* does we'll remove the parenthesis and the associated closing pren
        CASE PART.AFTER [1, 1] = "("

            PART.AFTER = PART.AFTER [2, TO.THE.END]
            REMOVED.PREN = @FALSE
            AFTER.LEN = LEN(PART.AFTER)

            FOR PTR = AFTER.LEN TO 1 STEP -1 UNTIL REMOVED.PREN

                IF PART.AFTER [PTR, 1] = ")" THEN
                    REMOVED.PREN = @TRUE
                    PART.AFTER = PART.AFTER [1, PTR - 1]:PART.AFTER [PTR + 1, TO.THE.END]
                END

            NEXT PTR
            
    END CASE

    RETURN

STARTING.SUBROUTINE.CALL: ************************************************
* start building the subroutine call                                     *
**************************************************************************
    HANDLE.PASSED.BYREF = @TRUE
    ORIGINAL.HANDLE.PARAMETER = ""
    TEMP.HANDLE.PARAMETER = ""

* create the eclipse subroutine call, adding the object handle to the
* command list as the first parameter.

* start the line off with the label (if there was one), the indenting
* and the eclipse subroutine name

* if we're converting methods calls all the way down to external
* CALL statements start the line off with the CALL and open parenthesis
* after the subroutine
    IF CONVERT.METHODS.TO.CALLS THEN
        NEW.LINE = LABEL:SPACE(INDENT.COUNT):"CALL ":ECLIPSE.SUBROUTINE:" ("
    END ELSE
        NEW.LINE = LABEL:SPACE(INDENT.COUNT):ECLIPSE.SUBROUTINE:" "
    END

* if CheckMismatchedChildObjects is turned on (which is a good idea) we can
* use the string to test for this condition
    CHILD.OBJECT.STRING = ""

* add the object handle.  however, if this is a call using the
* pseudo-object for obp and oc subroutine calls the handle isn't
* needed
    IF HANDLE.OBJECT <> SUBROUTINE.CALL.KEYWORD THEN

* first build the object handle in its final form.  we changed array
* references to "()" in the object tables to make it easier to find.
* now that we're building the subroutine call we need the entire object
* handle reference with any array reference intact

* if the handle is dimensioned remove the "()" from the end of the object
* handle and add the array reference in its place
        BEGIN CASE

* call to all objects in a dimensioned object
            CASE ALL.ARRAY.CALL
                PASSED.HANDLE.PARAMETER = CHANGE(HANDLE.PARAMETER, "()", ""):"(DIM.HANDLE.LOOP)"

* call to a dimensioned object that isn't a child object
            CASE HANDLE.PARAMETER [2] = "()" AND HANDLE.ARRAY.REF = ""
                PASSED.HANDLE.PARAMETER = CHANGE(HANDLE.PARAMETER, "()", "")

* call to a dimensioned object
            CASE HANDLE.ARRAY.REF <> ""
                PASSED.HANDLE.PARAMETER = CHANGE(HANDLE.PARAMETER, "()", ""):"(":HANDLE.ARRAY.REF:")"

* call to a "normal" object
            CASE 1
                PASSED.HANDLE.PARAMETER = HANDLE.PARAMETER

        END CASE

* passing the object handle can cause problems if the object is a child object
* and we're in a method.  the object handle will also be in the common area so 
* passing the object handle directly can cause an aliasing problem.  if we're in 
* a subroutine this is okay since the object handle won't be in a common area

* if anything is to use instance matching then the called method must be able to 
* change the object handle.  so, even if the object handle is in the common area
* we need to be able to pass it to the method subroutine and (possibly) receive
* the changed object handle back

* there are settings in compile.setup that control how the object handles are
* passed in different situations.  PassObjectHandlesByVal, PassSubHandlesByVal,
* PassLocalHandlesByVal, PassRegistryHandlesByVal and PassDestroyHandlesByVal
* allow sending the handle by reference (the actual variable is passed) or 
* by value.  We can't pass the object handle by reference if it's in the common 
* area (which happens when it's a child object)!

* sending by value really means "send through a temporary variable so that we 
* don't get an aliasing problem because the object handle is in the common 
* area"
        HANDLE.PASSED.BYREF = @TRUE
        ORIGINAL.HANDLE.PARAMETER = ""
        TEMP.HANDLE.PARAMETER = ""

        BEGIN CASE

            CASE HANDLE.METHOD = DESTROY.KEYWORD AND PASS.DESTROY.HANDLES.BYVAL
                TEMP.HANDLE.PARAMETER = PARAMETER.TEMP.VARIABLE:"OBJECT.HANDLE"
                ORIGINAL.HANDLE.PARAMETER = PASSED.HANDLE.PARAMETER
                NEW.LINE := TEMP.HANDLE.PARAMETER
                HANDLE.PASSED.BYREF = @FALSE

            CASE HANDLE.METHOD = DESTROY.KEYWORD
                NEW.LINE := PASSED.HANDLE.PARAMETER

            CASE HANDLE.VARIABLE = "OBJECT.HANDLE" AND PASS.LOCAL.HANDLES.BYVAL
                TEMP.HANDLE.PARAMETER = PARAMETER.TEMP.VARIABLE:"OBJECT.HANDLE"
                ORIGINAL.HANDLE.PARAMETER = PASSED.HANDLE.PARAMETER
                NEW.LINE := TEMP.HANDLE.PARAMETER
                HANDLE.PASSED.BYREF = @FALSE

            CASE HANDLE.VARIABLE = "OBJECT.HANDLE"
                NEW.LINE := PASSED.HANDLE.PARAMETER

            CASE PASS.OBJECT.HANDLES.BYVAL
                TEMP.HANDLE.PARAMETER = PARAMETER.TEMP.VARIABLE:"OBJECT.HANDLE"
                ORIGINAL.HANDLE.PARAMETER = PASSED.HANDLE.PARAMETER
                NEW.LINE := TEMP.HANDLE.PARAMETER
                HANDLE.PASSED.BYREF = @FALSE

            CASE 1
                NEW.LINE := PASSED.HANDLE.PARAMETER

        END CASE

    END

* if we have an array and we're getting or putting a single array
* element key.word.array.ref will have the reference to that array
* element.  the subroutine call to get or put that element has two
* parameters in case the array reference is two dimensional.  if the
* array is ONE dimensional we need to fill in that second parameter
* when we do our call.  we'll add that reference to key.word.array.ref
* for one dimensional variables
    IF HANDLE.METHOD.TYPE = "ARRAY" THEN
        IF KEY.WORD.ARRAY.REF <> "" AND HANDLE.DIMENSIONS = 1 THEN
            KEY.WORD.ARRAY.REF := ', ""'
        END
    END

* if this is a method call and not the RESET method and not using the
* subroutine pseud-object then add the error message return variable 
* after the object handle

* for multi-threaded method calls add in a dummy error message variable but
* then also the request id, the called routine's error message,  the
* method name and the parameter count
    BEGIN CASE


* multi-threaded calls:

*     starting fork calls
        CASE MULTI.THREADED.CALL AND STARTING.FORK
            GOSUB ADD.STARTING.FORK.PARAMETERS

*     ending forked calls
        CASE MULTI.THREADED.CALL AND ENDING.FORK
            GOSUB ADD.ENDING.FORK.PARAMETERS

*    method call, not forked
        CASE MULTI.THREADED.CALL
            GOSUB ADD.NON.FORKED.PARAMETERS


* single-threaded calls:
        CASE 1
            GOSUB ADD.NORMAL.CALL.PARAMETERS


    END CASE

* check the assignment variables.  the assignment variables could be
* enclosed in parenthesis.  they don't have to be but if they are we'll
* remove them so that it works either way
    IF ASSIGNMENT.VARIABLE <> "" THEN

        ASSIGNMENT.VARIABLE = TRIM(ASSIGNMENT.VARIABLE, " ", "B")

        IF ASSIGNMENT.VARIABLE [1, 1] = "(" AND ASSIGNMENT.VARIABLE [1] = ")" THEN
            ASSIGNMENT.VARIABLE = TRIM(ASSIGNMENT.VARIABLE [2, LEN(ASSIGNMENT.VARIABLE) - 2], " ", "B")
        END   
     
    END

* if this code is ending a forked method call there will be no assignment
* variables
    IF ENDING.FORK THEN
        ASSIGNMENT.VARIABLE = ""
        ASSIGNMENT.TYPE = @FALSE
    END

* check the assignment variables (the "output variables," from before the
* keyword).  these parameters are receiving values from the call.
    IF ASSIGNMENT.VARIABLE = "" THEN
        OUTPUT.VARIABLE.LIST = ""
        OUTPUT.VARIABLE.COUNT = 0
        ASSIGNMENT.VARIABLE.COUNT = 0
    END ELSE
        OUTPUT.VARIABLE.LIST = SPLIT.PARAMETERS(ASSIGNMENT.VARIABLE)
        OUTPUT.VARIABLE.COUNT = DCOUNT(OUTPUT.VARIABLE.LIST, @AM)
        ASSIGNMENT.VARIABLE.COUNT = OUTPUT.VARIABLE.COUNT
    END

* if any of these output variables are associated variable list names
* explode the associated variable out into its list of associated
* variables
    CHECK.PARAMETER.LIST = OUTPUT.VARIABLE.LIST
    GOSUB CONVERT.ASSOCIATED.PARAMETERS

    IF ASSOCIATED.CONVERTED THEN
        OUTPUT.VARIABLE.LIST = CHECK.PARAMETER.LIST
        OUTPUT.VARIABLE.COUNT = DCOUNT(OUTPUT.VARIABLE.LIST, @AM)
        ASSIGNMENT.VARIABLE.COUNT = OUTPUT.VARIABLE.COUNT
    END

    RETURN

ADD.STARTING.FORK.PARAMETERS: ********************************************
* add calling parameters to new.line for starting fork subroutine calls  *
**************************************************************************
    BEGIN CASE

        CASE HANDLE.METHOD.TYPE <> "METHOD"
            NULL

* blind method call, starting a blind forked call.  for blind call the
* first parameter, which usually returns the request id, is passed as
* "blind".  this cues the phantom to execute the call without creating
* a response record in the object message file
        CASE STARTING.FORK.REQUEST.ID = BLIND.KEYWORD
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE
            NEW.LINE := ", ":'"':BLIND.PASSED.VALUE:'"'
            NEW.LINE := ', "':HANDLE.METHOD:'", ':HANDLE.CALL.PARAMETER.COUNT

* since we're sending a fork request we won't have any values for
* output parameters.  add nulls for them in the call
            FOR NULL.LOOP = 1 TO HANDLE.OUTPUT.COUNT
                NEW.LINE := ' ,""'
            NEXT NULL.LOOP

            HANDLE.CALL.PARAMETER.COUNT -= HANDLE.OUTPUT.COUNT
            HANDLE.OUTPUT.COUNT = 0
            ASSIGNMENT.VARIABLE = ""

* method call, starting a forked call
        CASE 1
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE
            NEW.LINE := ", ":STARTING.FORK.REQUEST.ID
            NEW.LINE := ', "':HANDLE.METHOD:'", ':HANDLE.CALL.PARAMETER.COUNT

* since we're sending a fork request we won't have any values for
* output parameters.  add nulls for them in the call
            FOR NULL.LOOP = 1 TO HANDLE.OUTPUT.COUNT
                NEW.LINE := ' ,""'
            NEXT NULL.LOOP

            HANDLE.CALL.PARAMETER.COUNT -= HANDLE.OUTPUT.COUNT
            HANDLE.OUTPUT.COUNT = 0
            ASSIGNMENT.VARIABLE = ""

    END CASE

    RETURN

ADD.ENDING.FORK.PARAMETERS: **********************************************
* add calling parameters to new.line for ending fork subroutine calls    *
**************************************************************************

    BEGIN CASE

* if this isn't a method call don't add any error message variables
        CASE HANDLE.METHOD.TYPE <> "METHOD"
            NULL

* if this is an ending fork that gets a response add a temporary error
* message for multi.thread's error and another for the object's error
        CASE ENDING.FORK.METHOD = FORK.RESPONSE.KEYWORD
            NEW.LINE := ", TEMP.":ERROR.MESSAGE.VARIABLE
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE

* this is some other ending fork call, probably a call to a special method.
* add in error message
        CASE ENDING.FORK.METHOD <> ""
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE

* no ending message specified.  this ending fork is getting a response            
        CASE ENDING.FORK.METHOD = ""
            NEW.LINE := ", TEMP.":ERROR.MESSAGE.VARIABLE
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE

    END CASE

    RETURN

ADD.NON.FORKED.PARAMETERS: ***********************************************
* add calling parameters for a non-forked multi-threaded call            *
**************************************************************************
    BEGIN CASE

* a multi-valued destroy call doesn't need an error message
        CASE HANDLE.METHOD = DESTROY.KEYWORD
            NULL

* normal method call
        CASE HANDLE.METHOD.TYPE = "METHOD"
            NEW.LINE := ", TEMP.":ERROR.MESSAGE.VARIABLE:", TEMP.REQUEST.ID"
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE
            NEW.LINE := ', "':HANDLE.METHOD:'", ':HANDLE.CALL.PARAMETER.COUNT

*    any other call, not forked
        CASE 1
            NEW.LINE := ", TEMP.":ERROR.MESSAGE.VARIABLE:", TEMP.REQUEST.ID"
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE

    END CASE

    RETURN

ADD.NORMAL.CALL.PARAMETERS: **********************************************
* add calling parameters for a single-valued method call                 *
**************************************************************************
    BEGIN CASE

* reset method
        CASE HANDLE.METHOD = RESET.KEYWORD

* check this object for child objects
            SEARCH.SUBCHILDREN = @TRUE
            UPDATE.OBJECT.CREATION.LIST = @FALSE
            ADD.LOCAL.CHILD.OBJECTS = @FALSE
            THIS.CHILD.OBJECT.NAME = HANDLE.OBJECT
            THIS.CHILD.OBJECT.HANDLE = PASSED.HANDLE.PARAMETER

            GOSUB CHECK.FOR.CHILD.OBJECTS

            THIS.OBJECT.HANDLE = PASSED.HANDLE.PARAMETER
            GOSUB ADD.NEW.CHILD.OBJECT.HANDLES

* destroy methods don't need the error message variable
        CASE HANDLE.METHOD = DESTROY.KEYWORD
            NULL

* sub pseudo-object calls also don't need it.  
        CASE HANDLE.OBJECT = SUBROUTINE.CALL.KEYWORD
            NULL

* any other method call needs the error message variable
        CASE HANDLE.METHOD.TYPE = "METHOD"
            NEW.LINE := ", ":ERROR.MESSAGE.VARIABLE

    END CASE

    RETURN

CHECK.NAMED.ASSIGNED.VARIABLES: ******************************************
* check the assigned (output) variables for named parameters             *
**************************************************************************

* this isn't currently working.  resolving the unresovled references
* pulls the assigned variables out into a separate line and this
* routine gets the temporary variables in the output.variable.list.
* if there's time maybe this will get resolved.  for now we'll skip it
    RETURN

* by byname references are enabled check the parameter list for any
* parameters defined by name, ie, "method.var.name=passed.var.name".
* if any are found move the passed parameter to the right position
* in the passed parameters.
    IF NOT(ENABLE.BY.NAME) OR OUTPUT.VARIABLE.COUNT = 0 THEN
        RETURN
    END

* we'll build our new parameter list here
    NEW.OUTPUT.VARIABLE.LIST = ""
    CALL.POSITION.PTR = 0

    FOR PARAMETER.LOOP = 1 TO OUTPUT.VARIABLE.COUNT

* look for an equals sign in this parameter.  the variable name
* that defines the parameter position will be ahead of the equals sign
        THIS.PARAMETER = OUTPUT.VARIABLE.LIST<PARAMETER.LOOP>
        EQUALS.PTR = FIND.CHAR.PTR(THIS.PARAMETER, "=")

* if we found an equals sign extract the method's parameter name and
* the passed parameter's expression.  if we can find the method parameter
* name in the method's parameter list then we have a byname reference
        PARAMETER.PLACED = @FALSE
        IF EQUALS.PTR > 1 THEN

* extract the method's parameter name and the passed expression from this
* parameter
            PARAMETER.PTR = 0
            PASSED.PARAMETER = TRIM(THIS.PARAMETER [1, EQUALS.PTR - 1], " ", "B")
            METHOD.PARAMETER.NAME = TRIM(THIS.PARAMETER [EQUALS.PTR + 1, TO.THE.END], " ", "B")

            IF UPCASE.CODE THEN
                METHOD.PARAMETER.NAME = UPCASE(METHOD.PARAMETER.NAME)
            END

* if we can find the name reference in the method's parameter list then the
* variable name matched up and we have a byname reference.  add it
* to new.part.after using the parameter location from the method
* definition

* if we can't find the reference then the name is invalid.  show a warning
* and leave it alone

* if the parameter "name" is numeric we'll use it as the pointer to the position,
* ie, "4=MYVARIABLE" would put "MYVARIABLE" into the fourth call parameter

* if the parameter "name" is "+nnn" where "nnn" is numeric then "nnn" parameter
* positions will be skipped and the parameter dropped at that position
            MATCHED.PARAMETER.COUNT = 0
            PARAMETER.MATCH.ERROR = ""

            BEGIN CASE

                CASE METHOD.PARAMETER.NAME = ""
                    NULL

                CASE METHOD.PARAMETER.NAME [1, 1] = "+" AND NUM(METHOD.PARAMETER.NAME [2, TO.THE.END])
                    PARAMETER.PTR = CALL.POSITION.PTR + METHOD.PARAMETER.NAME [2, TO.THE.END] + 1

                CASE NUM(METHOD.PARAMETER.NAME)
                    PARAMETER.PTR = METHOD.PARAMETER.NAME

                CASE 1
                    MATCHING.INPUT.PARAMETER = @FALSE
                    GOSUB MATCH.NAMED.PARAMETER

            END CASE


* if we got a good pointer to the parameter position place the expression in
* the calling parameters and set the current calling parameter position pointer
* to this one.  if the next parameter isn't named it will be added right after
* this named parameter's position
            BEGIN CASE

                CASE PARAMETER.MATCH.ERROR <> ""
                    OBJECT.WARNING.DESC = PARAMETER.MATCH.ERROR
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                CASE PARAMETER.PTR = 0 AND MATCHED.PARAMETER.COUNT > 1
                    OBJECT.WARNING.DESC = "Named parameter "
                    OBJECT.WARNING.DESC := '"':METHOD.PARAMETER.NAME:'"'
                    OBJECT.WARNING.DESC := " matches more than one parameter in"
                    OBJECT.WARNING.DESC := HANDLE.METHOD
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                CASE PARAMETER.PTR = 0
                    OBJECT.WARNING.DESC = "Can't identify named parameter "
                    OBJECT.WARNING.DESC := '"':METHOD.PARAMETER.NAME:'"'
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                CASE PARAMETER.PTR < 0
                    OBJECT.WARNING.DESC = "Parameter pointer ":'"':PARAMETER.PTR:'"'
                    OBJECT.WARNING.DESC := " points to an invalid parameter"
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                CASE OUTPUT.VARIABLE.LIST<PARAMETER.PTR> = ""
                    OBJECT.WARNING.DESC = "Parameter pointer ":'"':PARAMETER.PTR:'"'
                    OBJECT.WARNING.DESC := " points to an invalid parameter"
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                CASE 1
                    NEW.OUTPUT.VARIABLE.LIST<PARAMETER.PTR> = PASSED.PARAMETER
                    PARAMETER.PLACED = @TRUE
                    CALL.POSITION.PTR = PARAMETER.PTR

            END CASE

        END

* adding this parameter at parameter.ptr may create some nulls in the output
* parameter list.  sometimes this can confuse the eclipse precompiler.
* we'll fill in any of these parameters, even if pad.null.parameters isn't
* set, with null double quotes
        IF PARAMETER.PLACED THEN

            FOR PAD.OUTPUT.LOOP = 1 TO PARAMETER.PTR - 1

                IF NEW.OUTPUT.VARIABLE.LIST<PAD.OUTPUT.LOOP> = "" THEN
                    NEW.OUTPUT.VARIABLE.LIST<PAD.OUTPUT.LOOP> = '""'
                END

            NEXT PAD.INPUT.LOOP

        END

* if we didn't find the parameter position by name save it by the
* current position pointer.  if there's already a value there (probably
* from a named parameter passed) leave what's already there
        IF NOT(PARAMETER.PLACED) THEN

            CALL.POSITION.PTR += 1

            BEGIN CASE

* this position has a parameter in it but the parameter is '""'.  replace
* this position with the new parameter
                CASE NEW.OUTPUT.VARIABLE.LIST<CALL.POSITION.PTR> = '""'
                    NEW.OUTPUT.VARIABLE.LIST<CALL.POSITION.PTR> = THIS.PARAMETER

* a parameter has already been passed in this position
                CASE NEW.OUTPUT.VARIABLE.LIST<CALL.POSITION.PTR> <> ""
                    OBJECT.WARNING.DESC = HANDLE.OBJECT:"::":HANDLE.METHOD:" call"
                    OBJECT.WARNING.DESC := " has output parameter passed in position ":CALL.POSITION.PTR
                    OBJECT.WARNING.DESC := " when there's already a parameter"
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

* a parameter is passed in a parameter postion that has no associated value
* in the method definition
                CASE HANDLE.CALL.PARAMETER<CALL.POSITION.PTR> = ""

* we won't print a warning here, we'll display it later
*                   OBJECT.WARNING.DESC = "Call to ":HANDLE.OBJECT:"::":HANDLE.METHOD:" has "
*                   OBJECT.WARNING.DESC := CALL.POSITION.PTR:" parameters.  "
*                   OBJECT.WARNING.DESC := "Method ":HANDLE.METHOD:" has "
*                   OBJECT.WARNING.DESC := HANDLE.CALL.PARAMETER.COUNT:" parameters"
*                   OBJECT.WARNING.LINE = LINE.LOOP
*                   GOSUB PRINT.OBJECT.WARNING

                    NEW.OUTPUT.VARIABLE.LIST<CALL.POSITION.PTR> = THIS.PARAMETER

* insert the parameter at this position
                CASE 1
                    NEW.OUTPUT.VARIABLE.LIST<CALL.POSITION.PTR> = THIS.PARAMETER

            END CASE

        END

    NEXT PARAMETER.LOOP

    RETURN

CHECK.ASSIGNED.ALIASING: *************************************************
* check assigned variables for aliasing problems                         *
**************************************************************************

* if this is a method call to the same object name (either a local::method
* call or to another object of the same name) we don't want any properties
* in the output parameter list.  this can cause aliasing problems since,
* in the called routine, the passed value and the common value will have
* different reference pointers even though they're the same variable.

* this is annoying because you won't notice a problem right away.  it can
* cause corruption in uniVerse's variable workspace.  at some time in the
* (random) future uniVerse will have a corruption problem and crash out from
* under you.  better to never have this happen to begin with

* this can also cause problems since the called object is the same object
* type as the current one.  the called object will reset the current
* property variables and return with them set to it's instance and not
* the current instance.  the current instance then receives the other
* instances passed variables into its properties.  a call is done to
* reload the proper instance but the properties returned to the current 
* instance get lost when the correct instance is reestablished.  better
* to just not use properties as variables that will return variables from
* the other instances of the same object

* if this happens give a warning
    IF CHECK.METHOD.PARAMETER.PROPERTY THEN

        FOR OUTPUT.LOOP = 1 TO OUTPUT.VARIABLE.COUNT

* check this parameter to see if it's a property or eclipse common variable
            CHECK.VARIABLE = OUTPUT.VARIABLE.LIST<OUTPUT.LOOP>
            GOSUB CHECK.PROPERTY.PARAMETER

* if parameter fixing is turned on replace the variable in the
* output.variable.list with a temporary variable and update the original
* and temporary variable tables.

* later we'll use these tables to copy all the property values into
* temporary variables, call the method with the temporary variables,
* and then copy the new values from the temporary values into the
* properties.

* if the same property / eclipse common variable is passed multiple times
* this way we may get unexpected values but at least we won't mangle our
* workspace.  and why would anyone be doing this to begin with anyway?
            IF VARIABLE.IS.PROPERTY AND FIX.PROPERTY.PARAMETERS THEN
                TEMP.NAME = PARAMETER.TEMP.VARIABLE:OUTPUT.LOOP
                ORIGINAL.PARAMETER.LIST<OUTPUT.LOOP> = CHECK.VARIABLE
                TEMP.PARAMETER.LIST<OUTPUT.LOOP> = TEMP.NAME
                OUTPUT.VARIABLE.LIST<OUTPUT.LOOP> = TEMP.NAME                    
            END

        NEXT OUTPUT.LOOP

    END

* if the same variable is passed byref in any circumstances we can get
* the same aliasing problem
    FOR OUTPUT.LOOP = 1 TO OUTPUT.VARIABLE.COUNT - 1

        THIS.OUTPUT.VARIABLE = OUTPUT.VARIABLE.LIST<OUTPUT.LOOP>

        IF IS.VARIABLE(THIS.OUTPUT.VARIABLE) THEN

            LOCATE THIS.OUTPUT.VARIABLE IN OUTPUT.VARIABLE.LIST, OUTPUT.LOOP + 1 SETTING DUPE.PTR THEN

* this "variable" could still be a constant due to Eclipse's equates.
* if it's a constant we can pass it as many times as we want and
* no error should be generated
                CHECK.VARIABLE = THIS.OUTPUT.VARIABLE
                GOSUB CHECK.EQUATE.CONSTANT

                IF NOT(EQUATE.CONSTANT) THEN
                    OBJECT.WARNING.DESC = "Variable ":'"':THIS.OUTPUT.VARIABLE:'"'
                    OBJECT.WARNING.DESC := " passed ByRef two or more times in the same call"
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING
                END

            END

        END

    NEXT OUTPUT.LOOP

    RETURN

PAD.OUTPUT.PARAMETERS: ***************************************************
* pad output parameter list                                              *
**************************************************************************

* if the called method has returned variables but the call has none and
* "eclipse-style" calls (all parameters on the right) are not allowed then
* we want to do the call as if we have one throwaway variable left of the
* equals sign.  don't do this for the string object
    IF HANDLE.OBJECT <> STRING.OBJECT.NAME THEN
        IF NOT(ALLOW.ALL.PARAMETERS.ON.RIGHT) OR NO.ECLIPSE.CALLS THEN

            GOSUB PAD.WITH.NO.OUTPUT.PARAMETERS

            IF PADDED THEN
                RETURN

            END
        END
    END

* if the output variable count is zero then all parameters are to the right
* of the equals sign and we have an "eclipse-style" call.  don't pad the
* output parameters
    IF OUTPUT.VARIABLE.COUNT = 0 THEN
        RETURN
    END

* if we're padding the parameter count of "output" parameters to match
* the parameter count of the method definition check it now and add any
* necessary padding.  if we don't have an output parameter count for
* this method (no semicolon was used in the definition, 
* handle.output.parameter returns "?") then skip this check.
    BEGIN CASE

* if there are no parameters to the left of the equals sign this could
* be a "standard" call with all parameters to the right of the equals.  we
* won't do a padding check for these types of calls
        CASE HANDLE.OUTPUT.PARAMETER = "?"
            NULL

* the parameter count to the left of the equals sign is the same as the
* "output" parameters defined.  everything is good
        CASE OUTPUT.VARIABLE.COUNT = HANDLE.OUTPUT.COUNT
            NULL

* the parameter count to the left of the equals sign is less than the
* "output" parameters defined.  add some blank parameters so they're
* equal
        CASE OUTPUT.VARIABLE.COUNT < HANDLE.OUTPUT.COUNT

            FOR PAD.LOOP = OUTPUT.VARIABLE.COUNT + 1 TO HANDLE.OUTPUT.COUNT
                OUTPUT.VARIABLE.LIST := @AM:'""'
            NEXT PAD.LOOP

            OUTPUT.VARIABLE.COUNT = DCOUNT(OUTPUT.VARIABLE.LIST, @AM)

* the parameter count to the left of the equals sign is greater than the
* "output" parameters defined.  chop off the extra

* if handle.output.parameter is "?" then we aren't sure how many output parameters
* there are so skip this check
        CASE OUTPUT.VARIABLE.COUNT > HANDLE.OUTPUT.COUNT AND HANDLE.OUTPUT.PARAMETER <> "?"

            PARAMETERS.REMOVED = OUTPUT.VARIABLE.LIST [@AM, HANDLE.OUTPUT.COUNT + 1, TO.THE.END]
            PARAMETERS.REMOVED = CHANGE(PARAMETERS.REMOVED, @AM, ", ")

            OBJECT.WARNING.DESC = KEY.WORD:" call has ":OUTPUT.VARIABLE.COUNT
            OBJECT.WARNING.DESC := " returned parameters.  "
            OBJECT.WARNING.DESC := " Method only has ":HANDLE.OUTPUT.COUNT:".  Parameters"
            OBJECT.WARNING.DESC := '    "':PARAMETERS.REMOVED:'" ignored.'
            OBJECT.WARNING.LINE = LINE.LOOP
            GOSUB PRINT.OBJECT.WARNING

            OUTPUT.VARIABLE.LIST = OUTPUT.VARIABLE.LIST [@AM, 1, HANDLE.OUTPUT.COUNT]
            OUTPUT.VARIABLE.COUNT = DCOUNT(OUTPUT.VARIABLE.LIST, @AM)

    END CASE

* rebuild assignment.variable with the cleaned up output.variable.list
    ASSIGNMENT.VARIABLE = CHANGE(OUTPUT.VARIABLE.LIST, @AM, ", ")
    ASSIGNMENT.VARIABLE.COUNT = OUTPUT.VARIABLE.COUNT

    RETURN

PAD.WITH.NO.OUTPUT.PARAMETERS: *******************************************
* if a call has no output parameters but the called method does pad      *
* the call with null values so that the returned parameters are thrown   *
* away and the passed parameters are passed properly.  returns padded    *
* true if padding was performed                                          *
**************************************************************************
    PADDED = @FALSE

    IF OUTPUT.VARIABLE.COUNT = 0 THEN

        GOSUB FIND.RETURNED.PARAMETER.COUNT

        IF RETURNED.PARAMETER.COUNT > 0 THEN

            OUTPUT.VARIABLE.LIST = '""'
            FOR PAD.LOOP = 2 TO RETURNED.PARAMETER.COUNT
                OUTPUT.VARIABLE.LIST := @AM:'""'
            NEXT PAD.LOOP

            OUTPUT.VARIABLE.COUNT = RETURNED.PARAMETER.COUNT

* rebuild assignment.variable with the cleaned up output.variable.list
            ASSIGNMENT.VARIABLE = CHANGE(OUTPUT.VARIABLE.LIST, @AM, ", ")
            ASSIGNMENT.VARIABLE.COUNT = OUTPUT.VARIABLE.COUNT

* the call would not have been consider an "assignment" call with nothing
* left of the equals sign.  now that we've added the null parameters it
* should be treated as one
            ASSIGNMENT.TYPE = @TRUE

            PADDED = @TRUE

        END

    END

    RETURN

CHECK.PROPERTY.ALIASING: *************************************************
* check property get / puts for aliasing problems                        *
**************************************************************************

* if this is assigning into or out of a property value of the other
* object check to see if we're passing a property in or out

* check the target of the assignment to see if it's a property or eclipse
* common variable
    CHECK.VARIABLE = ASSIGNMENT.VARIABLE
    GOSUB CHECK.PROPERTY.PARAMETER

* if it is a property / eclipse common variable replace the parameter in the
* call with a "temp" variable and update the original and temp variable
* tables for later

* later we'll use these tables to copy all the property values into
* temporary variables, call the method with the temporary variables,
* and then copy the new values from the temporary values into the
* properties
    IF VARIABLE.IS.PROPERTY AND FIX.PROPERTY.PARAMETERS THEN
        TEMP.NAME = PARAMETER.TEMP.VARIABLE:"1"
        ORIGINAL.PARAMETER.LIST<1> = CHECK.VARIABLE
        TEMP.PARAMETER.LIST<1> = TEMP.NAME
        ASSIGNMENT.VARIABLE = TEMP.NAME                    
    END

    RETURN

ADD.OBJECT.HANDLE.TO.CALL: ***********************************************
* add the object handle and assignment variable(s) to the call           *
**************************************************************************

* the next part of the call depends on the handle type
    AFTER.DELIMITER = ""
    ADD.AFTER = @FALSE
    BEGIN CASE


* this is an object reset.  don't add anything
        CASE HANDLE.METHOD = RESET.KEYWORD
            NULL


* methods:

*     "method" call using the subroutine call pseudo-object and this is an
*     assignment call
        CASE HANDLE.METHOD.TYPE = "METHOD" AND HANDLE.OBJECT = SUBROUTINE.CALL.KEYWORD AND ASSIGNMENT.TYPE
            NEW.LINE := ASSIGNMENT.VARIABLE
            AFTER.DELIMITER = ", "
            ADD.AFTER = @TRUE

*     "method" call using the subroutine call pseudo-object
        CASE HANDLE.METHOD.TYPE = "METHOD" AND HANDLE.OBJECT = SUBROUTINE.CALL.KEYWORD
            ADD.AFTER = @TRUE

*     starting a forked method call
        CASE HANDLE.METHOD.TYPE = "METHOD" AND MULTI.THREADED.CALL AND STARTING.FORK
            ADD.AFTER = @TRUE
            AFTER.DELIMITER = ", "

*     ending a forked method call
        CASE HANDLE.METHOD.TYPE = "METHOD" AND MULTI.THREADED.CALL AND ENDING.FORK
            ADD.AFTER = @TRUE
            AFTER.DELIMITER = ", "

*     if this is an assignment-type call for a method add a comma and the
*     assignment variable
        CASE HANDLE.METHOD.TYPE = "METHOD" AND ASSIGNMENT.TYPE
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE
            AFTER.DELIMITER = ", "
            ADD.AFTER = @TRUE

*     normal method call / subroutine call.  we have the subroutine name and
*     object handle already.  if there are additional parameters add a comma
*     and then the parameters
        CASE HANDLE.METHOD.TYPE = "METHOD"
            AFTER.DELIMITER = ", "
            ADD.AFTER = @TRUE


* normal properties:

*     this is a property assigment for a variable in a multi-threaded object.
*     put in the appropriate property name and assignment variables to pull
*     a value from a property.  this will pass the "get property" request to
*     the multi-threaded object with the property name in parameter1 and
*     receive the property value back in property2
        CASE HANDLE.METHOD.TYPE = "PROPERTY" AND ASSIGNMENT.TYPE AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':GET.KEYWORD:'", 2'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE

*     this is a property assigment. put in the appropriate property name and
*     assignment variables to pull a value from a property
        CASE HANDLE.METHOD.TYPE = "PROPERTY" AND ASSIGNMENT.TYPE
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE:', ""'

*     this is a property assignment for a dynamic, split property in
*     a multi-threaded property to change the value of property.  put in the 
*     appropriate property name, assignment variables, and multivalue reference.
*     this will pass the property name in parameter1, the new value in
*     parameter2, the attribute in parameter7, the value in parameter8 and
*     the subvalue in parameter9
        CASE HANDLE.METHOD.TYPE = "PROPERTY" AND DYNAMIC.SPLIT AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':PUT.KEYWORD:'", 9'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE
            NEW.LINE := ', "", "", "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is a property assignment for a dynamic, split property to change
*     a property.  put in the appropriate property name, assignment variables,
*     and multivalue reference
        CASE HANDLE.METHOD.TYPE = "PROPERTY" AND DYNAMIC.SPLIT
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ', "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is changing a property value for a variable in a multi-threaded
*     object. put in the appropriate property name and assignment variables to set
*     a variable in the multi-threaded object.  this will send the property name
*     to the multi-threaded object in property1 and the new value in property2
        CASE HANDLE.METHOD.TYPE = "PROPERTY" AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':PUT.KEYWORD:'", 2'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE

*     this is changing a property value. put in the appropriate property
*     name and assignment variables
        CASE HANDLE.METHOD.TYPE = "PROPERTY"
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'


* arrays:

*     this is an array assignment where the array pointers have been specified
*     and the multivalued pointers have been specified.  put in the appropriate
*     array name, the assignment variable (NOT an array) and the pointers
        CASE HANDLE.METHOD.TYPE = "ARRAY" AND ASSIGNMENT.TYPE AND KEY.WORD.ARRAY.REF <> "" AND DYNAMIC.SPLIT
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ', ':KEY.WORD.ARRAY.REF
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is an array assignment where the array pointers have been specified.
*     put in the appropriate array name, the assignment variable (NOT an
*     array) and the pointers
        CASE HANDLE.METHOD.TYPE = "ARRAY" AND ASSIGNMENT.TYPE AND KEY.WORD.ARRAY.REF <> ""
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ", ":KEY.WORD.ARRAY.REF

*     this is an array assigment but the elements aren't set. put in the
*     appropriate array name and assignment variables
        CASE HANDLE.METHOD.TYPE = "ARRAY" AND ASSIGNMENT.TYPE
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', "", MAT ':ASSIGNMENT.VARIABLE

*     this is pulling an array value where the array pointers have been specified
*     and the multivalued pointers have been specified.  put in the appropriate
*     array name, the assignment variable (NOT an array) and the pointers
        CASE HANDLE.METHOD.TYPE = "ARRAY" AND KEY.WORD.ARRAY.REF <> "" AND DYNAMIC.SPLIT
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ", ":KEY.WORD.ARRAY.REF
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is pulling an array value where the array pointers have been specified.
*     put in the appropriate array name, the assignment variable (NOT an
*     array) and the pointers
        CASE HANDLE.METHOD.TYPE = "ARRAY" AND KEY.WORD.ARRAY.REF <> ""
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ", ":KEY.WORD.ARRAY.REF

*     if this is pulling an array value put in the appropriate array
*     name and assignment variables
        CASE HANDLE.METHOD.TYPE = "ARRAY"
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', "", MAT ':ASSIGNMENT.VARIABLE


* constants:

*     this is a constant assignment for a constant in a multi-valued object and
*     multivalue pointers have been specified
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND ASSIGNMENT.TYPE AND DYNAMIC.SPLIT AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':PUT.KEYWORD:'", 9'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE
            NEW.LINE := ', "", "", "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is a constant assignment and multivalue pointers have been
*     specified
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND ASSIGNMENT.TYPE AND DYNAMIC.SPLIT
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ', "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     this is a constant assigment put in the appropriate constant name and
*     assignment variables
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND ASSIGNMENT.TYPE AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':PUT.KEYWORD:'", 2'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE

*     this is a constant assigment put in the appropriate constant name and
*     assignment variables
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND ASSIGNMENT.TYPE
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'

*     if this is pulling a constant value from a multi-valued object. put in the
*     appropriate constant name and assignment variables when the multivalues
*     have been defined
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND DYNAMIC.SPLIT AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':GET.KEYWORD:'", 9'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE
            NEW.LINE := ', "", "", "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     if this is pulling a constant value put in the appropriate constant
*     name and assignment variables when the multivalues have been
*     defined
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND DYNAMIC.SPLIT
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'
            NEW.LINE := ', "", ""'
            NEW.LINE := ", ":KEY.WORD.MULTIVALUE

*     if this is pulling a constant value put in the appropriate constant
*     name and assignment variables
        CASE HANDLE.METHOD.TYPE = "CONSTANT" AND MULTI.THREADED.CALL
            NEW.LINE := ", ":'"':GET.KEYWORD:'", 2'
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ', ':ASSIGNMENT.VARIABLE

*     if this is pulling a constant value put in the appropriate constant
*     name and assignment variables
        CASE HANDLE.METHOD.TYPE = "CONSTANT"
            NEW.LINE := ", ":'"':HANDLE.METHOD:'"'
            NEW.LINE := ", ":ASSIGNMENT.VARIABLE:', ""'


    END CASE

    RETURN

ADD.INPUT.PARAMETERS.TO.CALL: ********************************************
* add the parameters that follow the object reference to the call        *
**************************************************************************

* if there are additional parameters add a comma and then the additional
* parameters.  for assigment types we already have everything we need so
* ignore all the after text
    PART.AFTER.COUNT = 0
IN$$4:    INPUT.VARIABLE.COUNT = 0

    IF TRIM(PART.AFTER) <> "" AND ADD.AFTER THEN

* do (optional) conversion of literal spaces to space() functions
        IF SCAN.PARAMETER.SPACES THEN
            PART.AFTER = CONVERT.LITERAL.SPACES (PART.AFTER)
        END

* if byname references are enabled or if the byval references are enabled
* break the part.after into a dynamic array of the passed parameters and
* whatever compound part may be after the parameters of the call
        IF ENABLE.BY.NAME OR ENABLE.BYVAL THEN

* separate parameters from any compound statements that follow
            LINE.END.PTR = END.OF.STATEMENT (PART.AFTER)
            COMPOUND.PART.AFTER = PART.AFTER [LINE.END.PTR, TO.THE.END]
            PART.AFTER = PART.AFTER [1, LINE.END.PTR - 1]

* break up passed parameters into a clean parameter array
            PART.AFTER = SPLIT.PARAMETERS(PART.AFTER)
            PART.AFTER.COUNT = DCOUNT(PART.AFTER, @AM)

        END

* if any of these parameters are associated variables explode them out
* to the associated variables lists
        CHECK.PARAMETER.LIST = PART.AFTER

        GOSUB CONVERT.ASSOCIATED.PARAMETERS

        IF ASSOCIATED.CONVERTED THEN
            PART.AFTER = CHECK.PARAMETER.LIST
            PART.AFTER.COUNT = DCOUNT(PART.AFTER, @AM)
        END

* save the current "input" parameter count before any later parameter padding
* so we can check on it later
IN$$5:    INPUT.VARIABLE.COUNT = PART.AFTER.COUNT

**************************************************************************
* check the parameter list for aliasing problems                         *
**************************************************************************

* if this is a method call to the same object name (either a local::method
* call or to another object of the same name) we don't want any properties
* in the input parameter list if any of them are byref.  this can cause 
* aliasing problems since, in the called routine, the passed value and
* the common value will have different reference pointers even though they're
* the same variable.

* this is annoying because you won't notice a problem right away.  it can
* cause corruption in uniVerse's variable workspace.  at some time in the
* (random) future uniVerse will have a corruption problem and crash out from
* under you.  better to never have this happen to begin with

* if this happens give a warning
        IF PART.AFTER.COUNT > 0 AND HANDLE.METHOD.TYPE = "METHOD" THEN

            IF CHECK.METHOD.PARAMETER.PROPERTY THEN

                FOR INPUT.LOOP = 1 TO PART.AFTER.COUNT

                    THIS.INPUT.VARIABLE = PART.AFTER<INPUT.LOOP>
                    PARAMETER.PTR = ASSIGNMENT.VARIABLE.COUNT + INPUT.LOOP

                    THIS.BYVAL = HANDLE.CALL.BYVAL<PARAMETER.PTR>
                    THIS.SPECIAL = HANDLE.CALL.SPECIAL<PARAMETER.PTR>

                    IF NOT(THIS.BYVAL) OR THIS.SPECIAL THEN

* check this parameter to see if it's a property or eclipse common variable
                        CHECK.VARIABLE = THIS.INPUT.VARIABLE
                        GOSUB CHECK.PROPERTY.PARAMETER

* if parameter fixing is turned on replace the variable in the
* output.variable.list with a temporary variable and update the original and
* temp variable tables

* later we'll use these tables to copy all the property values into temporary
* variables, call the method with the temporary variables, and then copy the
* new values from the temporary values into the properties
                        IF VARIABLE.IS.PROPERTY AND FIX.PROPERTY.PARAMETERS THEN
                            TEMP.NAME = PARAMETER.TEMP.VARIABLE:PARAMETER.PTR
                            ORIGINAL.PARAMETER.LIST<PARAMETER.PTR> = CHECK.VARIABLE
                            TEMP.PARAMETER.LIST<PARAMETER.PTR> = TEMP.NAME
                            PART.AFTER<PARAMETER.PTR> = TEMP.NAME                    
                        END

                    END

                NEXT OUTPUT.LOOP

            END

* if the same variable is passed byref in any circumstances we can get
* the same aliasing problem
            FOR INPUT.LOOP = 1 TO PART.AFTER.COUNT

                THIS.INPUT.VARIABLE = PART.AFTER<INPUT.LOOP>

                THIS.BYVAL = HANDLE.CALL.BYVAL<ASSIGNMENT.VARIABLE.COUNT + INPUT.LOOP>
                THIS.SPECIAL = HANDLE.CALL.SPECIAL<ASSIGNMENT.VARIABLE.COUNT + INPUT.LOOP>

                IF (NOT(THIS.BYVAL) OR THIS.SPECIAL) AND IS.VARIABLE(THIS.INPUT.VARIABLE) THEN

                    IF INPUT.LOOP < PART.AFTER.COUNT THEN

* try to locate this variable name in the other input parameters.  if we find
* a duplicate and it's also byref then show an error
                        LOCATE THIS.INPUT.VARIABLE IN PART.AFTER, INPUT.LOOP + 1 SETTING DUPE.PTR THEN
                            
                            DUPE.BYVAL = HANDLE.CALL.BYVAL<ASSIGNMENT.VARIABLE.COUNT + DUPE.PTR>
                            DUPE.SPECIAL = HANDLE.CALL.SPECIAL<ASSIGNMENT.VARIABLE.COUNT + DUPE.PTR>

                            IF NOT(DUPE.BYVAL) OR DUPE.SPECIAL THEN

* this "variable" could still be a constant due to Eclipse's equates
                                CHECK.VARIABLE = THIS.INPUT.VARIABLE
                                GOSUB CHECK.EQUATE.CONSTANT

                                IF NOT(EQUATE.CONSTANT) THEN
                                    OBJECT.WARNING.DESC = "Variable ":'"':THIS.INPUT.VARIABLE:'"'
                                    OBJECT.WARNING.DESC := " passed ByRef twice in the same call"
                                    OBJECT.WARNING.LINE = LINE.LOOP
                                    GOSUB PRINT.OBJECT.WARNING
                                END

                            END

                        END

* also check in the output variables
                        LOCATE THIS.INPUT.VARIABLE IN OUTPUT.VARIABLE.LIST SETTING DUPE.PTR THEN

                            DUPE.BYVAL = HANDLE.CALL.BYVAL<DUPE.PTR>
                            DUPE.SPECIAL = HANDLE.CALL.SPECIAL<DUPE.PTR>

                            IF NOT(DUPE.BYVAL) OR DUPE.SPECIAL THEN

* this "variable" could still be a constant due to Eclipse's equates
                                CHECK.VARIABLE = THIS.INPUT.VARIABLE
                                GOSUB CHECK.EQUATE.CONSTANT

                                IF NOT(EQUATE.CONSTANT) THEN
                                    OBJECT.WARNING.DESC = "Variable ":'"':THIS.INPUT.VARIABLE:'"'
                                    OBJECT.WARNING.DESC := " passed ByRef twice in the same call"
                                    OBJECT.WARNING.LINE = LINE.LOOP
                                    GOSUB PRINT.OBJECT.WARNING
                                END

                            END

                        END

                    END

* finally, check against the eclipse common table
                    IF CHECK.ECLIPSE.COMMON.VARIABLES THEN
                        CHECK.LINE = PTR
                        CHECK.VARIABLE = THIS.INPUT.VARIABLE
                        CHECK.TYPE = "ByRef Input Parameter"
                        GOSUB CHECK.ECLIPSE.COMMON
                    END

                END

            NEXT OUTPUT.LOOP

        END

**************************************************************************
* check the input parameter list for by-name parameter assignments       *
**************************************************************************

* by byname references are enabled check the parameter list for any
* parameters defined by name, ie, "method.var.name=passed.var.name".
* if any are found move the passed parameter to the right position
* in the passed parameters.
        IF ENABLE.BY.NAME THEN

* we'll build our new parameter list here
            NEW.PART.AFTER = ""
            CALL.POSITION.PTR = 0

            FOR PART.AFTER.LOOP = 1 TO PART.AFTER.COUNT

* look for an equals sign in this parameter.  the variable name
* that defines the parameter position will be ahead of the equals sign
                THIS.PARAMETER = PART.AFTER<PART.AFTER.LOOP>
                EQUALS.PTR = FIND.CHAR.PTR(THIS.PARAMETER, "=")

* if we found an equals sign extract the method's parameter name and
* the passed parameter's expression.  if we can find the method parameter
* name in the method's parameter list then we have a byname reference
                PARAMETER.PLACED = @FALSE
                IF EQUALS.PTR > 1 THEN

* extract the method's parameter name and the passed expression from this
* parameter
                    PARAMETER.PTR = 0
                    METHOD.PARAMETER.NAME = TRIM(THIS.PARAMETER [1, EQUALS.PTR - 1], " ", "B")
                    PASSED.PARAMETER = TRIM(THIS.PARAMETER [EQUALS.PTR + 1, TO.THE.END], " ", "B")

                    IF UPCASE.CODE THEN
                        METHOD.PARAMETER.NAME = UPCASE(METHOD.PARAMETER.NAME)
                    END

* if we can find the name reference in the method's parameter list then the
* variable name matched up and we have a byname reference.  add it
* to new.part.after using the parameter location from the method
* definition

* if we can't find the reference then the name is invalid.  show a warning
* and leave it alone

* if the parameter "name" is numeric we'll use it as the pointer to the position,
* ie, "4=MYVARIABLE" would put "MYVARIABLE" into the fourth call parameter

* if the parameter "name" is "+nnn" where "nnn" is numeric then "nnn" parameter
* positions will be skipped and the parameter dropped at that position
                    MATCHED.PARAMETER.COUNT = 0
                    PARAMETER.MATCH.ERROR = ""

                    BEGIN CASE

                        CASE METHOD.PARAMETER.NAME = ""
                            NULL

                        CASE METHOD.PARAMETER.NAME [1, 1] = "+" AND NUM(METHOD.PARAMETER.NAME [2, TO.THE.END])
                            PARAMETER.PTR = CALL.POSITION.PTR + METHOD.PARAMETER.NAME [2, TO.THE.END] + 1

                        CASE NUM(METHOD.PARAMETER.NAME)
                            PARAMETER.PTR = METHOD.PARAMETER.NAME - OUTPUT.VARIABLE.COUNT

                        CASE 1
                            MATCHING.INPUT.PARAMETER = @TRUE
                            GOSUB MATCH.NAMED.PARAMETER

                    END CASE


* if we got a good pointer to the parameter position place the expression in
* the calling parameters and set the current calling parameter position pointer
* to this one.  if the next parameter isn't named it will be added right after
* this named parameter's position
                    BEGIN CASE

                        CASE PARAMETER.MATCH.ERROR <> ""
                            OBJECT.WARNING.DESC = PARAMETER.MATCH.ERROR
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

                        CASE PARAMETER.PTR = 0 AND MATCHED.PARAMETER.COUNT > 1
                            OBJECT.WARNING.DESC = "Named parameter "
                            OBJECT.WARNING.DESC := '"':METHOD.PARAMETER.NAME:'"'
                            OBJECT.WARNING.DESC := " matches more than one parameter in"
                            OBJECT.WARNING.DESC := HANDLE.METHOD
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

                        CASE PARAMETER.PTR = 0
                            OBJECT.WARNING.DESC = "Can't identify named parameter "
                            OBJECT.WARNING.DESC := '"':METHOD.PARAMETER.NAME:'"'
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

                        CASE PARAMETER.PTR < 0
                            OBJECT.WARNING.DESC = "Parameter pointer ":'"':PARAMETER.PTR:'"'
                            OBJECT.WARNING.DESC := " points to an invalid parameter"
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

                        CASE HANDLE.CALL.PARAMETER<PARAMETER.PTR> = ""
                            OBJECT.WARNING.DESC = "Parameter pointer ":'"':PARAMETER.PTR:'"'
                            OBJECT.WARNING.DESC := " points to an invalid parameter"
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

                        CASE 1
                            NEW.PART.AFTER<PARAMETER.PTR> = PASSED.PARAMETER
                            PARAMETER.PLACED = @TRUE
                            CALL.POSITION.PTR = PARAMETER.PTR

                    END CASE

                END

* adding this parameter at parameter.ptr may create some nulls in the input
* parameter list.  sometimes this can confuse the eclipse precompiler.
* we'll fill in any of these parameters, even if pad.null.parameters isn't
* set, with null double quotes
                IF PARAMETER.PLACED THEN

                    FOR PAD.INPUT.LOOP = 1 TO PARAMETER.PTR - 1

                        IF NEW.PART.AFTER<PAD.INPUT.LOOP> = "" THEN
                            NEW.PART.AFTER<PAD.INPUT.LOOP> = '""'
                        END

                    NEXT PAD.INPUT.LOOP

                END

* if we didn't find the parameter position by name save it by the
* current position pointer.  if there's already a value there (probably
* from a named parameter passed) leave what's already there
                IF NOT(PARAMETER.PLACED) THEN

                    CALL.POSITION.PTR += 1

                    BEGIN CASE

* this position has a parameter in it but the parameter is '""'.  replace
* this position with the new parameter
                        CASE NEW.PART.AFTER<CALL.POSITION.PTR> = '""'
                            NEW.PART.AFTER<CALL.POSITION.PTR> = THIS.PARAMETER

* a parameter has already been passed in this position
                        CASE NEW.PART.AFTER<CALL.POSITION.PTR> <> ""
                            OBJECT.WARNING.DESC = HANDLE.OBJECT:"::":HANDLE.METHOD:" call"
                            OBJECT.WARNING.DESC := " has parameter passed in position ":CALL.POSITION.PTR
                            OBJECT.WARNING.DESC := " when there's already a parameter"
                            OBJECT.WARNING.LINE = LINE.LOOP
                            GOSUB PRINT.OBJECT.WARNING

* a parameter is passed in a parameter postion that has no associated value
* in the method definition.  we won't print a warning here, we'll display it
* later
                        CASE HANDLE.CALL.PARAMETER<CALL.POSITION.PTR> = ""
*                           OBJECT.WARNING.DESC = "Call to ":HANDLE.OBJECT:"::":HANDLE.METHOD:" has "
*                           OBJECT.WARNING.DESC := CALL.POSITION.PTR:" parameters.  "
*                           OBJECT.WARNING.DESC := "Method ":HANDLE.METHOD:" has "
*                           OBJECT.WARNING.DESC := HANDLE.CALL.PARAMETER.COUNT:" parameters"
*                           OBJECT.WARNING.LINE = LINE.LOOP
*                           GOSUB PRINT.OBJECT.WARNING
                            NEW.PART.AFTER<CALL.POSITION.PTR> = THIS.PARAMETER

* insert the parameter at this position
                        CASE 1
                            NEW.PART.AFTER<CALL.POSITION.PTR> = THIS.PARAMETER

                    END CASE

                END

            NEXT PART.AFTER.LOOP

**************************************************************************
* pad output parameter list                                              *
**************************************************************************

* pad any parameters without values to "" if set
            IF PAD.NULL.PARAMETERS THEN
                FOR PARAMETER.LOOP = 1 TO HANDLE.CALL.PARAMETER.COUNT
                    IF NEW.PART.AFTER<PARAMETER.LOOP> = "" THEN
                        NEW.PART.AFTER<PARAMETER.LOOP> = '""'
                    END
                NEXT PARAMETER.LOOP
            END

            PART.AFTER = NEW.PART.AFTER
            PART.AFTER.COUNT = DCOUNT(PART.AFTER, @AM)

        END

**************************************************************************
* convert by-val parameters                                              *
**************************************************************************

* if byval references aren't enabled just concatenate part.after on the
* end of what we've built so far.  if byval references are enabled check
* each parameter to see if it's passed byval and add depending on whether
* it's byval or not
        IF ENABLE.BYVAL THEN

* check each parameter against the method's parameter list.  if it's a
* byval reference pass it as byval.  if it's a "special" byval we'll treat
* it as a byval reference everywhere else but we'll pass it as byref here
            FOR PART.AFTER.LOOP = 1 TO PART.AFTER.COUNT

                THIS.BYVAL = HANDLE.CALL.BYVAL<ASSIGNMENT.VARIABLE.COUNT + PART.AFTER.LOOP>
                THIS.SPECIAL = HANDLE.CALL.SPECIAL<ASSIGNMENT.VARIABLE.COUNT + PART.AFTER.LOOP>

                THIS.PART.AFTER = PART.AFTER<PART.AFTER.LOOP>

                IF THIS.BYVAL AND NOT(THIS.SPECIAL) THEN
                    PART.AFTER<PART.AFTER.LOOP> = CONVERT.BYVAL(THIS.PART.AFTER, ONLY.BYVAL.NON.EXPRESSIONS)
                END

            NEXT PART.AFTER.LOOP

        END

* if byname references are enabled or byval references are enabled
* restore the ams to commas, add the parameter list to the call and add
* any compound statements that might have been there.  if neither are
* enabled just tack part.after onto new.line
        IF ENABLE.BY.NAME OR ENABLE.BYVAL THEN
            NEW.LINE := AFTER.DELIMITER:CHANGE(PART.AFTER, @AM, ", "):COMPOUND.PART.AFTER
        END ELSE
            NEW.LINE := AFTER.DELIMITER:PART.AFTER
        END

    END

    RETURN

MATCH.NAMED.PARAMETER: ***************************************************
* match method.parameter.name to a parameter in handle.call.parameter    *
* returning parameter.ptr pointing to the parameter where this parameter *
* belongs in the call.                                                   *
**************************************************************************
    PARAMETER.PTR = 0
    PARAMETER.MATCH.ERROR = ""

* look for an exact match of the named parameter to the method's parameter
* list.  this is the best match so if we find it we'll take that match and
* return
    LOCATE METHOD.PARAMETER.NAME IN HANDLE.CALL.PARAMETER SETTING PARAMETER.PTR THEN
        IF MATCHING.INPUT.PARAMETER THEN
            PARAMETER.PTR -= OUTPUT.VARIABLE.COUNT
        END
        RETURN
    END

* if we couldn't find a match and allow.partial.named is set look for
* partial match.  for a partial match we'll look at the fields between
* dots in the parameter name and the method's parameter list.  if the
* named parameter matches more dot-delimited-fields in one method parameter
* than any others we'll take that parameter
    TEST.PARAMETER = CHANGE(METHOD.PARAMETER.NAME, ".", @AM)
    TEST.FIELD.COUNT = DCOUNT(TEST.PARAMETER, @AM)

    BEST.PARAMETER.PTR = 0
    BEST.MATCH.COUNT = 0
    MATCHED.PARAMETER.COUNT = 0

    FOR MATCH.LOOP = 1 TO HANDLE.CALL.PARAMETER.COUNT

        TEST.CALL.PARAMETER = CHANGE(HANDLE.CALL.PARAMETER<MATCH.LOOP>, ".", @AM)

* test to see how many fields (delimited by dots) in the parameter have
* matching fields in the called method's parameter.  if allow.partial.named.fields
* is set only the leading characters in the field have to match for it to
* be considered a match
        MATCH.COUNT = 0
        FOR TEST.LOOP = 1 TO TEST.FIELD.COUNT

            THIS.FIELD.MATCHES = @FALSE
            THIS.TEST.FIELD = TEST.PARAMETER<TEST.LOOP>

            LOCATE THIS.TEST.FIELD IN TEST.CALL.PARAMETER SETTING THROWAWAY THEN
                THIS.FIELD.MATCHES = @TRUE
            END

            IF ALLOW.PARTIAL.NAMED.FIELDS AND NOT(THIS.FIELD.MATCHES) THEN

                TEST.CALL.PARAMETER.COUNT = DCOUNT(TEST.CALL.PARAMETER, @AM)
                TEST.FIELD.LEN = LEN(THIS.TEST.FIELD)

                FOR CALL.FIELD.LOOP = 1 TO TEST.CALL.PARAMETER.COUNT UNTIL THIS.FIELD.MATCHES

                    IF THIS.TEST.FIELD = TEST.CALL.PARAMETER<CALL.FIELD.LOOP> [1, TEST.FIELD.LEN] THEN
                        THIS.FIELD.MATCHES = @TRUE
                    END

                NEXT CALL.FIELD.LOOP  
              
            END

            IF THIS.FIELD.MATCHES THEN
                MATCH.COUNT += 1
            END

        NEXT TEST.LOOP

* if we matched more fields with this call parameters we have new best
* match.  if we match the same number of fields we have more than one
* best match, which isn't good
        BEGIN CASE

            CASE MATCH.COUNT > BEST.MATCH.COUNT
                BEST.PARAMETER.PTR = MATCH.LOOP
                BEST.MATCH.COUNT = MATCH.COUNT
                MATCHED.PARAMETER.COUNT = 1

            CASE MATCH.COUNT = BEST.MATCH.COUNT
                BEST.PARAMETER.PTR<-1> = MATCH.LOOP
                BEST.MATCH.COUNT = MATCH.COUNT
                MATCHED.PARAMETER.COUNT += 1

        END CASE

    NEXT MATCH.LOOP

* process matches
    BEGIN CASE

* if we found one best match then we're good
        CASE MATCHED.PARAMETER.COUNT = 1 AND MATCHING.INPUT.PARAMETER
            PARAMETER.PTR = BEST.PARAMETER.PTR - OUTPUT.VARIABLE.COUNT

        CASE MATCHED.PARAMETER.COUNT = 1 
            PARAMETER.PTR = BEST.PARAMETER.PTR

* if we have no matches something is really off
        CASE MATCHED.PARAMETER.COUNT = 0
            PARAMETER.MATCH.ERROR = "Parameter '":METHOD.PARAMETER.NAME:"' does not"
            PARAMETER.MATCH.ERROR := " any parameters in method"
            PARAMETER.PTR = ""

* if we have more than one match the named variable was too vague
        CASE 1
            PARAMETER.MATCH.ERROR = "Parameter '":METHOD.PARAMETER.NAME:"' matches"
            PARAMETER.MATCH.ERROR := " ":MATCHED.PARAMETER.COUNT:" method parameters"
            PARAMETER.COUNT = 0

    END CASE

    RETURN

CHECK.OUTPUT.PARAMETERS: *************************************************
* check output paramters for an "eclipse-style" call, where all          *
* parameters (both input and output) are on the right side of the equals *
* sign.  if warn.all.parameters.on.right is set and we have an           *
* eclipse-style call a warning will be generated                         *
*                                                                        *
* this can be very important when "eclipse-style" calls are enabled by   *
* setting AllowAllParametersOnRight to true.  if there's a method that   *
* returns one or more parameters and the method call has no parameters   *
* the compiler treats the call differently if "eclipse-style" calls are  *
* turned on vs when they're turned off.                                  *
*                                                                        *
* for example, say we have a method defined like this, with one returned *
* parameter and two passed:                                              *
*                                                                        *
*     method my.method (output.parameter; optional passed1 = "",         *
*                       optional passed2 = ""):                          *
*                                                                        *
* we can call it using either of these lines if "eclipse-style" calls    *
* are turned on:                                                         *
*                                                                        *
*     my.output = object.handle (my.passed1, my.passed2)                 *
*     object.handle (my.output, my.passed1, my.passed2)                  *
*                                                                        *
* this can cause problems.  in most languages you can leave off the      *
* returned value and call it like this with no ill effects:              *
*                                                                        *
*     object.handle::my.method (my.passed1, my.passed2)                  *
*                                                                        *
* if "eclipse-style" calls are turned on, however, it's assumed that     *
* the returned parameter is in the parameter list inside the parenthesis *
* so it's treated like this, and parameters aren't passed in the order   *
* they should be:                                                        *
*                                                                        *
*     object.handle::my.method (my.passed1, my.passed2, "")              *
*                                                                        *
* the takeaway here is that if "eclipse-style" calls are turned on there *
* MUST be something to the left of the equals sign if you don't want it  *
* to be assumed to be an "eclipse-style" call.  if you don't need the    *
* returned parameter you have to call it like this:                      *
*                                                                        *
*     void = object.handle::my.method (my.passed1, my.passed2)           *
*                                                                        *
* this can be confusing as most languages don't work this way.  a better *
* way may be to NOT support "eclipse-style" calls by setting the         *
* AllowAllParametersOnRight to false.  then, since "eclipse-style" calls *
* are not supported, there is no confusion if there are no parameters    *
* left of the equals sign.  for a call like this:                        *
*                                                                        *
*     object.handle::my.method (my.passed1, my.passed2)                  *
*                                                                        *
* it will NOT be assumed to be an "eclipse-style" call.  rather, it's    *
* assumed that the returned parameter isn't needed.  the returned        *
* parameter will still be passed to the cbp subroutine and all three     *
* parameter will be passed in the right positions                        *
*                                                                        *
* it's probably better to NOT support the eclipse-style calls so there's *
* no confusion when all the returned parameters are throw-aways          *
**************************************************************************
    ECLIPSE.STYLE.CALL = @FALSE

* don't check the parameter count for the string object
    IF HANDLE.OBJECT = STRING.OBJECT.NAME THEN
        RETURN
    END

* we have output.variable.count and input.variable count as the count of
* parameters in the call to the method.  if the call statement has no input
* or output parameters the call is fine whether the called method has
* output parameters or not
    IF OUTPUT.VARIABLE.COUNT = 0 AND INPUT.VARIABLE.COUNT = 0 THEN
        RETURN
    END

* find the number of returned and passed parameters for the called method
    GOSUB FIND.RETURNED.PARAMETER.COUNT
    PASSED.PARAMETER.COUNT = HANDLE.CALL.PARAMETER.COUNT - RETURNED.PARAMETER.COUNT

* if handle.output.count is not zero and output.variable.count is zero
* then the method call has no variables left of the equal sign.  this may
* be an eclipse-style call or the output variables were inadvertantly left
* off the call.  in this case the method call is NOT an eclipse-style call
* but will be compiled as one and hilarity will ensue
    IF PASSED.PARAMETER.COUNT > 0 THEN
        IF RETURNED.PARAMETER.COUNT > 0 AND OUTPUT.VARIABLE.COUNT = 0 THEN
            ECLIPSE.STYLE.CALL = @TRUE
        END
    END

* if we have an eclipse-style call display a warning
    IF ECLIPSE.STYLE.CALL THEN
        OBJECT.WARNING.DESC = "Method ":HANDLE.OBJECT:METHOD.DELIMITER:HANDLE.METHOD
        OBJECT.WARNING.DESC := " has ":RETURNED.PARAMETER.COUNT:" returned"
        OBJECT.WARNING.DESC := " variables but call has none"
        OBJECT.WARNING.LINE = LINE.LOOP
        GOSUB PRINT.OBJECT.WARNING
    END

    RETURN

FIND.RETURNED.PARAMETER.COUNT: *******************************************
* return returned.parameter.count for the current handle.method          *
**************************************************************************

* if we don't have any parameters handle.output.parameter may be "?"
    IF HANDLE.OUTPUT.PARAMETER = "?" THEN
        RETURNED.PARAMETER.COUNT = 0
        RETURN
    END

* handle.output.count is how many returned variables the compiler THINKS
* it has.  if the call has no variables left of the equals sign this count
* will have ALL the parameters to allow for an "eclipse-style" call.  we
* need to know the ACTUAL count of returned parameters for the method.  to
* do this we'll go through the handle.output.parameter.list and add up the
* "byref" variables until we hit one that isn't "byref"
    RETURNED.PARAMETER.COUNT = 0
    DONE.CHECKING = @FALSE

    FOR CHECK.PARM = 1 TO HANDLE.OUTPUT.COUNT UNTIL DONE.CHECKING

*       THIS.PARM = HANDLE.OUTPUT.PARAMETER<CHECK.PARM>
        THIS.BYVAL = HANDLE.CALL.BYVAL<CHECK.PARM>
        THIS.SPECIAL = HANDLE.CALL.SPECIAL<CHECK.PARM>

* "byref" will be the first keyword normally but may be the second keyword
* for an "optional" parameter.  if there is no "byref" or "byval" keyword or
* "optional" keyword then this is a returned variable
*       IF COUNT(THIS.PARM, " ") = 0 OR THIS.PARM [" ", 1, 1] = BYREF.KEYWORD OR THIS.PARM [" ", 2, 1] = BYREF.KEYWORD THEN
        IF THIS.BYVAL THEN
            DONE.CHECKING = @TRUE
        END ELSE
            RETURNED.PARAMETER.COUNT += 1
        END

    NEXT CHECK.PARM

    RETURN

BUILD.SUBROUTINE.CALL.END: ***********************************************
* build the end of the method's subroutine call                          *
**************************************************************************

* if this is a call to a multi.threaded object pad out the call list for
* all possible parameter places.  then add the method name for the call and
* the parameter count
    IF PAD.NULL.PARAMETERS AND MULTI.THREADED.CALL THEN

        ADD.BLANK.COUNT = MAX.MULTI.THREAD.PARAMETERS - HANDLE.CALL.PARAMETER.COUNT

        FOR ADD.LOOP = 1 TO ADD.BLANK.COUNT
            NEW.LINE := ', ""'
        NEXT ADD.LOOP

    END

* if we're converting methods calls all the way down to external
* CALL statements close the parenthesis
    IF CONVERT.METHODS.TO.CALLS THEN
        NEW.LINE := ")"
    END

    RETURN

CONVERT.ASSOCIATED.PARAMETERS: *******************************************
* convert any associated variables in check.parameter.list to see if     *
* they're associated variables.  if they are explode them out to the     *
* list of variables in their association list                            *
**************************************************************************
    ASSOCIATED.CONVERTED = @FALSE
    CHECK.PARAMETER.COUNT = DCOUNT(CHECK.PARAMETER.LIST, @AM)

    FOR CHECK.LOOP = CHECK.PARAMETER.COUNT TO 1 STEP -1

        CHECK.PARAMETER = CHECK.PARAMETER.LIST<CHECK.LOOP>

        IF CHECK.PARAMETER [1, 1] = "{" AND CHECK.PARAMETER [1] ="}" THEN
            CHECK.PARAMETER = CHECK.PARAMETER [2, LEN(CHECK.PARAMETER) - 2]
        END

        LOCATE CHECK.PARAMETER IN ASSOCIATED.NAME.LIST SETTING CHECK.PTR THEN
            CHECK.PARAMETER.LIST<CHECK.LOOP> = RAISE(ASSOCIATED.VARIABLE.LIST<CHECK.PTR>)
            ASSOCIATED.CONVERTED = @TRUE
        END

    NEXT CHECK.LOOP

    RETURN

CHECK.FOR.NESTED.OBJECTS: ************************************************
* check for nested objects in subroutine calls                           *
**************************************************************************

* if we're compiling and object and this object call is calling a different
* instance of the same object then properties will be for the different
* instance when the call is returned.  if this is the case we need to
* restore the properies back to what they were for this instance

* see if this call may result in a call to the same object
    CHECK.NESTED.OBJECT.HANDLE = HANDLE.LIST<HANDLE.PTR>
    GOSUB CHECK.NESTED.CALL

    INSTANCE.LOAD = " ; GOSUB SET.OBJECT.INSTANCE"
    INSTANCE.CHECK = " ; GOSUB CHECK.OBJECT.INSTANCE"

    BEGIN CASE

* not compiling an object, don't need to do anything.  eclipse routines
* and object-enabled subroutines either don't have objects are don't
* need to recheck
        CASE NOT(COMPILE.OBJECT)
            NULL


* if the object has only one instance we don't need to check for the instance
* changing
        CASE MAX.INSTANCES = 1
            NULL

* if the object has no properties we don't need to check for the instance
* changing
        CASE NOT(PROPERTIES.EXIST)
            NULL


* flags for all scenarios:
*     we're set to always load the current instance
        CASE ALWAYS.LOAD.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're set to always check the current instance and reload if necessary
        CASE ALWAYS.CHECK.INSTANCE
            NEW.LINE := INSTANCE.CHECK


* "sub" calls:
*     we're doing a "sub" pseudo-object call and we're set to always load
*     current instances for "sub" calls
        CASE CHECK.NESTED.OBJECT.HANDLE = SUBROUTINE.CALL.KEYWORD AND SUB.CALL.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're doing a "sub" pseudo-object call and we're set to always check
*     the current instance
        CASE CHECK.NESTED.OBJECT.HANDLE = SUBROUTINE.CALL.KEYWORD AND SUB.CALL.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


* non-local calls:
*     non-local call and we're set to always load the current instance
        CASE CHECK.NESTED.OBJECT.HANDLE <> LOCAL.OBJECT.HANDLE AND NON.LOCAL.ALWAYS.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     we're doing a non-local call and non-local calls are set to check the
*     instance
        CASE CHECK.NESTED.OBJECT.HANDLE <> LOCAL.OBJECT.HANDLE AND NON.LOCAL.ALWAYS.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


* "nested" call:
*     call to another instance of the same object and we're set to load the
*     current instance in this situation.  add a call to set.object.instance
*     to reload the current instance
        CASE NESTED.OBJECT.CALL AND SAME.OBJECT.CALL.LOADS.INSTANCE
            NEW.LINE := INSTANCE.LOAD

*     call to another instance of the same object and we're set to check the
*     current instance in this situation.  add a call to check.object.instance
*     to reload the current instance if it changed
        CASE NESTED.OBJECT.CALL AND SAME.OBJECT.CALL.CHECKS.INSTANCE
            NEW.LINE := INSTANCE.CHECK


    END CASE

    RETURN

FINISH.DESTROY.CALL: *****************************************************
* for the "destroy" method we're passing the object handle cat null so   *
* that we avoiding aliasing problems in case the object handle is in     *
* common.  unfortunately that means that the handle still has a value    *
* after we destroy the object.  if the object is destroyed we want the   *
* file handle to be nulled.  if we're converting a "destroy" method add  *
* a line after the call to null the file handle                          *
**************************************************************************
    IF HANDLE.METHOD = DESTROY.KEYWORD THEN
        NEW.LINE := ' ; ':PASSED.HANDLE.PARAMETER :' = ""'
    END

    RETURN

ADD.TEMPORARY.VARIABLE.CODE: *********************************************
* add code for temporary variables used in subroutine call               *
**************************************************************************

* if we had to substitute temporary variable for any parameters
* that were properties or eclipse common variables build statements
* before the call to populate the temporary variables and statements
* after the call to copy the temporary variables back into the
* properties / eclipse common variables
    FIX.PARAMETERS.BEFORE = ""
    FIX.PARAMETERS.AFTER = ""

* if the object handle was passed by val it was really passed through a
* temporary variable.  update the before and after code to set the temporary
* object handle before the call and set the object handle afterwards
    IF TEMP.HANDLE.PARAMETER <> "" AND ORIGINAL.HANDLE.PARAMETER <> "" THEN
        FIX.PARAMETERS.BEFORE = TEMP.HANDLE.PARAMETER:" = ":ORIGINAL.HANDLE.PARAMETER:ENDING.FORK.HANDLE.DIM
        FIX.PARAMETERS.AFTER = ORIGINAL.HANDLE.PARAMETER:ENDING.FORK.HANDLE.DIM:" = ":TEMP.HANDLE.PARAMETER
    END

    FIX.PARAMETER.COUNT = DCOUNT(ORIGINAL.PARAMETER.LIST, @AM)

    FOR FIX.ALIAS.LOOP = 1 TO FIX.PARAMETER.COUNT

* if we have a parameter replacement build the populating / copying
* code.  before calling the method subroutine we'll populate temporary
* variable with the property values.  then we'll call the subroutine
* with the temporary variables.  upon returning we'll update the
* properties with the temporary variables' values that may be changed
* by the called method.

* this prevents passing properties and eclipse common variables by
* reference through method subroutine calls.  passing a common variable
* by reference can cause aliasing problems that can corrupt uniVerse's
* workspace.  Later, sometimes much later, this can cause uniVerse to
* crash.  better to just never send any common variables (properties or
* eclipse common variables) through method subroutine calls
        ORIGINAL.PARAMETER = ORIGINAL.PARAMETER.LIST<FIX.ALIAS.LOOP>
        TEMP.PARAMETER = TEMP.PARAMETER.LIST<FIX.ALIAS.LOOP>

* if original.parameter<n> isn't null then this parameter is a property
* or eclipse common variable, passed byref.  build code to copy this
* property into temporary variable in  fix.parameters.before and build
* code to copy the temporary variables back into the properties in
* fix.parameters after
        IF ORIGINAL.PARAMETER <> "" THEN

            IF FIX.PARAMETERS.BEFORE <> "" THEN
                FIX.PARAMETERS.BEFORE := " ; "
                FIX.PARAMETERS.AFTER := " ; "
            END

            FIX.PARAMETERS.BEFORE := TEMP.PARAMETER:" = ":ORIGINAL.PARAMETER
            FIX.PARAMETERS.AFTER := ORIGINAL.PARAMETER:" = ":TEMP.PARAMETER

        END

    NEXT FIX.ALIAS.LOOP

* if we built any parameter fixing code add it into new.line.
    IF FIX.PARAMETERS.BEFORE <> "" THEN

* insert the "before" code that populates the temporary variables
* after the label and indenting
        INSERT.FIX.PTR = LEN(LABEL) + INDENT.COUNT

* insert "before" code
        NEW.LINE = NEW.LINE [1, INSERT.FIX.PTR]:FIX.PARAMETERS.BEFORE:" ; ":NEW.LINE [INSERT.FIX.PTR + 1, TO.THE.END]
*       NEW.LINE [INSERT.FIX.PTR + 1, 0] = FIX.PARAMETERS.BEFORE:" ; "

* add the "after" code
        NEW.LINE := " ; ":FIX.PARAMETERS.AFTER

    END

    RETURN

ADD.INTIME.CODE: *********************************************************
* if the object being called in an intime object add code to the         *
* beginning of the call to create the object if it doesn't already exist *
**************************************************************************

* see if this object was created as an intime object.  if it's not don't
* add this code
    LOCATE HANDLE.VARIABLE IN CHILD.VARIABLE.LIST SETTING CHECK.INTIME.PTR ELSE
        RETURN
    END

    DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHECK.INTIME.PTR>

    GOSUB DECODE.PROPERTY

    IF NOT(IS.INTIME) THEN
        RETURN
    END

* if the object handle is dimensioned and this is a call to all dimensioned
* objects (the object array dimension ptr is "*") we don't want to initialize
* the intime object
    IF ALL.ARRAY.CALL THEN
        RETURN
    END

* if we got here we have an intime object.  if it hasn't been created it
* will be created now
    BEGIN CASE

        CASE MULTI.THREADED.CALL AND ENDING.FORK AND ENDING.FORK.ARRAY.REF <> ""
            INTIME.CREATE.CALL = "CHILD.INTIME.PTR = ":ENDING.FORK.ARRAY.REF:" ; "

        CASE HANDLE.ARRAY.REF <> ""
            INTIME.CREATE.CALL = "CHILD.INTIME.PTR = ":HANDLE.ARRAY.REF:" ; "

        CASE 1
            INTIME.CREATE.CALL = ""

    END CASE

    INTIME.CREATE.CALL := "GOSUB ":INTIME.OBJECT.SUBROUTINE.PREFIX:HANDLE.OBJECT:".":HANDLE.VARIABLE

    INSERT.INTIME.PTR = LEN(LABEL) + INDENT.COUNT
    NEW.LINE = NEW.LINE [1, INSERT.INTIME.PTR]:INTIME.CREATE.CALL:" ; ":NEW.LINE [INSERT.INTIME.PTR + 1, TO.THE.END]

    RETURN

ADD.ALL.ARRAY.CODE: ******************************************************
* if the object is dimensioned and this call is for all objects in the   *
* dimensioned array the object's array element pointer will be "*".      *
* this will set all.array.call.  if all.array.call is true add a loop    *
* around the call to loop through the array and do the call for any      *
* object handles in the array that have been initialized                 *
**************************************************************************

* if the object isn't dimensioned or if the array element pointer isn't
* "*" we don't have a call to all array elements
    IF NOT(ALL.ARRAY.CALL) THEN
        RETURN
    END

* before the call add code to find the array size and loop through the
* array, executing the call if the object handle has been defined
    ARRAY.HANDLE = CHANGE(HANDLE.VARIABLE, "()", "")
    BEFORE.CODE = "DIM.HANDLE.COUNT = INMAT(":ARRAY.HANDLE:")<1,1> ; "
    BEFORE.CODE := "FOR DIM.HANDLE.LOOP = 1 TO DIM.HANDLE.COUNT ; "
    BEFORE.CODE := 'IF ':ARRAY.HANDLE:'(DIM.HANDLE.LOOP) <> "" AND ':ARRAY.HANDLE:'(DIM.HANDLE.LOOP) <> "0" THEN '

* after the call end the for/next loop
    AFTER.CODE = " ; NEXT DIM.HANDLE.LOOP"

* add the code to new.line
    INSERT.ALL.PTR = LEN(LABEL) + INDENT.COUNT
    NEW.LINE = NEW.LINE [1, INSERT.ALL.PTR]:BEFORE.CODE:NEW.LINE [INSERT.ALL.PTR + 1, TO.THE.END]:AFTER.CODE

    RETURN

CHECK.PARAMETER.COUNT: ***************************************************
* check parameter counts in calls against the method definition          *
**************************************************************************

* if this is a method call check the total parameter count for this call
* (output parameters and input parameters) against the parameter count of
* the method.  if there are too many parameters in the call some parameters
* will be dropped when Eclipse's precompiler processes the cbp.  print a
* warning if this is true

* if this is a forked call there won't be any input parameters in the call
* as the input parameters aren't available until after the forked process
* has finished.  the statement will look like it has one input, parameter,
* however, since the form is "FORK(FORK.ID) = object::method (parameters)"
* so we'll ignore the output parameters
    BEGIN CASE
        CASE STARTING.FORK
            TOTAL.PARAMETER.COUNT = PART.AFTER.COUNT
            CHECK.CALL.TYPE = "forked"
        CASE 1
            TOTAL.PARAMETER.COUNT = OUTPUT.VARIABLE.COUNT + PART.AFTER.COUNT
            CHECK.CALL.TYPE = "called"
    END CASE

    IF TOTAL.PARAMETER.COUNT > HANDLE.CALL.PARAMETER.COUNT THEN

        OBJECT.WARNING.DESC = HANDLE.OBJECT:"::":HANDLE.METHOD:" is ":CHECK.CALL.TYPE
        OBJECT.WARNING.DESC := " with ":TOTAL.PARAMETER.COUNT:" parameter"

        IF TOTAL.PARAMETER.COUNT <> 1 THEN
            OBJECT.WARNING.DESC := "s"
        END

        OBJECT.WARNING.DESC := ".  Only ":HANDLE.CALL.PARAMETER.COUNT

        IF HANDLE.CALL.PARAMETER.COUNT <> 1 THEN
            OBJECT.WARNING.DESC := " are allowed.  "
        END ELSE
            OBJECT.WARNING.DESC := " is allowed.  "
        END

        IF TOTAL.PARAMETER.COUNT - HANDLE.CALL.PARAMETER.COUNT = 1 THEN
            OBJECT.WARNING.DESC := "The extra parameter"
        END ELSE
            OBJECT.WARNING.DESC := "The extra parameters"
        END

        OBJECT.WARNING.DESC := " will be ignored."

        OBJECT.WARNING.LINE = LINE.LOOP
        GOSUB PRINT.OBJECT.WARNING

    END

    RETURN

CHECK.CALL.FOR.UNRESOLVED: ***********************************************
* check for unresolved references                                        *
**************************************************************************
    GOSUB CHECK.UNRESOLVED.REFERENCES

    RETURN

CONVERT.LINE.WRAPUP: *****************************************************
* if convert.this.line can't convert and gives up wrap up any processing *
* on this program line                                                   *
**************************************************************************

* if we're checking unresolved references set new.line to the original
* programming line and check to see if there are any object references
* that still need conversion
    IF CHECK.UNRESOLVED.REFERENCES THEN
        NEW.LINE = THIS.LINE
        GOSUB CHECK.UNRESOLVED.REFERENCES
    END

    RETURN

ADD.ERROR.THROW.CODE: ****************************************************
* add error throwing code to new.line and fixed.code.  if error          *
* throwing is turned on add a line after every other converted line to   *
* check the value of the error throw variable and do a gosub to the      *
* error catching subroutine if the error throw variable is not null      *
**************************************************************************

* if error throws are not enabled add no new code
    IF NOT(ENABLE.ERROR.THROWS) THEN
        RETURN
    END

* don't add error throw code for the short.new method
    IF METHOD = NEW.SHORT.KEYWORD THEN
        RETURN
    END

* identify the error's object (or program) and error line number
    THIS.ERROR.OBJECT = OBJECT.NAME
    IF COMPILE.OBJECT THEN
        THIS.ERROR.OBJECT := METHOD.DELIMITER:METHOD
    END

* find the line number for the original code line.  if this is from an
* object method we'll take the current "source" program line and look it
* up in the object.code.source.list, built when the object method code was
* merged into the subroutine.

* if there's nothing in object.code.source.list then we either aren't
* compiling an object method or we have a bit of code that wasn't from the
* the OBJ source code so we'll use the current program code line number

* if the code line didn't come from the source code (it was added by the
* precompiler) the source line number will be "*"
    SOURCE.LINE.NUMBER = PROGRAM.CODE.SOURCE.LIST<LINE.LOOP>

    IF SOURCE.LINE.NUMBER = "*" THEN
        SOURCE.LINE.NUMBER = "Precompiler Code"
    END

* build the error line showing the source code line first and then the
* cbp program code line in brackets
    THIS.ERROR.LINE = "Line ":SOURCE.LINE.NUMBER:" [":LINE.LOOP:"]"

* build error throwing code
    ERROR.THROW.CODE = SPACE(LEN(LABEL) + INDENT.COUNT)
    ERROR.THROW.CODE := 'IF ':ERROR.MESSAGE.VARIABLE:' <> "" THEN '
    ERROR.THROW.CODE := ERROR.MESSAGE.VARIABLE:" = ":'"':THIS.ERROR.OBJECT:", ":THIS.ERROR.LINE:': ":':ERROR.MESSAGE.VARIABLE
    ERROR.THROW.CODE := " ; GOSUB ":LABEL.GOSUB.NAME

* if we have no fixed code then our converted line is in new.line.
* move it into the fixed code array so we an add more lines
* after it
    IF FIXED.CODE.COUNT = 0 THEN
        FIXED.CODE.COUNT += 1
        FIXED.CODE<FIXED.CODE.COUNT> = NEW.LINE
    END

* for every line in fixed.code if we see the error.message variable insert
* the error throw code after the fxed.code line
    FOR FIX.LOOP = FIXED.CODE.COUNT TO 1 STEP -1

        THIS.FIX.CODE = FIXED.CODE<FIX.LOOP>

        IF INDEX(THIS.FIX.CODE, ERROR.MESSAGE.VARIABLE, 1) > 0 THEN
            INS ERROR.THROW.CODE BEFORE FIXED.CODE<FIX.LOOP + 1>
            FIXED.CODE.COUNT += 1
            ERROR.THROW.ADDED.COUNT += 1
        END

    NEXT FIX.LOOP

    RETURN

MERGE.FIX.CODE: **********************************************************
* merge fix.code.list into program.code and update                       *
* program.code.source.list and program.code.final.list                   *
**************************************************************************

* we had to fix some unresolved entries so we have code in fixed.code.
* merge the fixed.code code into program.code.  this will insert new
* program lines into program.code so we need to update our program line
* xref property

* if we're merging all new lines into the same program line as the
* original generate compound program lines.  this will be difficult to
* read but it keeps the line numbers the same as the original source
    IF ALL.ON.ONE.LINE THEN

        COMPOUND.LINE = FIXED.CODE<1>

        FOR FIX.LOOP = 2 TO FIXED.CODE.COUNT
            COMPOUND.LINE := " ; ":TRIM(FIXED.CODE<FIX.LOOP>, " ", "B")
        NEXT FIX.LOOP

* replace the original program line with the compound lines of the
* fix code
        PROGRAM.CODE<LINE.LOOP> = COMPOUND.LINE

    END ELSE

* insert all the new code from fixed.code into the program.  this will
* add new program lines
        PROGRAM.CODE<LINE.LOOP> = FIXED.CODE

        INSERT.LINE.PTR = LINE.LOOP
        INSERT.LINE.COUNT = FIXED.CODE.COUNT - 1
        PROGRAM.CODE.LINES += INSERT.LINE.COUNT
        NO.INSERT.SOURCE = @FALSE
        GOSUB INSERT.LINE.XREF
        LINE.LOOP += INSERT.LINE.COUNT

    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / "with" statements                                  **
**************************************************************************
**************************************************************************

CONVERT.WITH: ************************************************************
* convert a line with a "with" statement.  updates with.stack and        *
* current.with with the current with value at this "with" depth.         *
* current.with and with.stack<1> contain the current "with" value        *
**************************************************************************

* extract object of with
    WITH.OBJECT = CLEAN.LINE [" ", 2, TO.THE.END]

* if "with" object begins with any delimiter concatenate the current
* "with" object
    WITH.DELIMITER = @FALSE

    IF WITH.OBJECT [1, CHILD.DEL.LENGTH] = CHILD.DELIMITER THEN
        WITH.DELIMITER = @TRUE
    END

    IF WITH.OBJECT [1, METHOD.DEL.LENGTH] = METHOD.DELIMITER THEN
        WITH.DELIMITER = @TRUE
    END

    IF WITH.OBJECT [1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER THEN
        WITH.DELIMITER = @TRUE
    END

    IF WITH.OBJECT [1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER THEN
        WITH.DELIMITER = @TRUE
    END

* this expression starts with a delimiter so we'll add the
* current contents of the "with" stack
    IF WITH.DELIMITER THEN
        WITH.OBJECT = WITH.STACK<1>:WITH.OBJECT
    END

* see if we can find the "with" object in the object table.  also
* look for it in the handle/keyword table since it could be a handle
* with a method call.

* if the object has any dimensioned handles in it we need to remove the
* index from the dimensioned part, leaving only "()", so it's compatible
* with the created handle list
    CHECK.WITH.HANDLE = WITH.OBJECT
    OPEN.PREN.COUNT = COUNT(CHECK.WITH.HANDLE, "(")

    FOR PREN.LOOP = 1 TO OPEN.PREN.COUNT

        OPEN.PTR = INDEX(CHECK.WITH.HANDLE, "(", PREN.LOOP)
        CLOSE.PTR = OPEN.PTR

        LOOP
            CLOSE.PTR += 1
            THIS.CHAR = CHECK.WITH.HANDLE [CLOSE.PTR, 1]
        UNTIL THIS.CHAR = ")" OR THIS.CHAR = ""
        REPEAT

        CHECK.WITH.HANDLE = CHECK.WITH.HANDLE [1, OPEN.PTR]:CHECK.WITH.HANDLE [CLOSE.PTR, TO.THE.END]

    NEXT PREN.LOOP

* first try try to locate it as it is in the object list.  it might be
* an object::method reference so if that doesn't work remove the rightmost
* reference and try it again.  if we can't find it that way then it's a bad
* reference
    FOUND.IN.HANDLE.LIST = @FALSE
    LOCATE CHECK.WITH.HANDLE IN CREATE.HANDLE.LIST SETTING OBJECT.PTR THEN

        FOUND.IN.HANDLE.LIST = @TRUE

    END ELSE

* find the number of method delimiters we have in the reference
        DELIMITERS.IN.REF = -1
        DELIMITER.PTR = -1

        FOR REF.LOOP = 1 TO 1000 UNTIL DELIMITERS.IN.REF >= 0

            IF INDEX(CHECK.WITH.HANDLE, METHOD.DELIMITER, REF.LOOP) < 1 THEN
                DELIMITERS.IN.REF = REF.LOOP - 1
            END ELSE
                DELIMITER.PTR = INDEX(CHECK.WITH.HANDLE, METHOD.DELIMITER, REF.LOOP)
            END

        NEXT REF.LOOP

* if we have at least one method delimiter remove the last field in the object
* and try to locate the result in create.handle.list
        IF DELIMITERS.IN.REF > 0 THEN

            CHECK.WITH.HANDLE.2 = CHECK.WITH.HANDLE [1, DELIMITER.PTR - 1]

            LOCATE CHECK.WITH.HANDLE.2 IN CREATE.HANDLE.LIST SETTING OBJECT.PTR THEN
                FOUND.IN.HANDLE.LIST = @TRUE
            END

        END

    END

* if the handle is the subroutine call pseudo-object it's a good handle
* even if it's not found in the handle list.  check.with.handle may have
* child handles or methods attached to it so pull off the first object
* reference and check it against the subroutine call pseudo-object
    CHECK.SUB.HANDLE.PTR = INDEX(CHECK.WITH.HANDLE, METHOD.DELIMITER, 1)

    IF CHECK.SUB.HANDLE.PTR > 0 THEN
        CHECK.SUB.HANDLE = CHECK.WITH.HANDLE [1, CHECK.SUB.HANDLE.PTR - 1]
    END ELSE
        CHECK.SUB.HANDLE = CHECK.WITH.HANDLE
    END

    IF CHECK.SUB.HANDLE = SUBROUTINE.CALL.KEYWORD THEN
        FOUND.IN.HANDLE.LIST = @TRUE
    END

* flag errors
    BEGIN CASE

* the object handle in the "with" statement is missing
        CASE WITH.OBJECT = ""
            OBJECT.ERROR.DESC = WITH.KEYWORD:" has no Object Handle"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

* the object handle in the "with" statement isn't found in the
* handle list
        CASE NOT(FOUND.IN.HANDLE.LIST) AND VALIDATE.WITH.OBJECTS
            OBJECT.ERROR.DESC = "WITH has invalid Object Handle ":'"':CHECK.WITH.HANDLE:'"'
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

    END CASE

* push into "with" stack for next use
    CURRENT.WITH = WITH.OBJECT
    INS WITH.OBJECT BEFORE WITH.STACK<1>

    GOSUB COMMENT.NEW.LINE

    RETURN

CONVERT.END.WITH: ********************************************************
* convert a line with an "end with" statement.  updates current.with     *
* and with.stack, popping the most recent "with" value by removing       *
* with.stack<1>                                                          *
**************************************************************************

* if the with stack is already empty we can't pop it for the "end with"
    IF WITH.STACK = "" THEN
        OBJECT.ERROR.DESC = "END WITH with no WITH"
        OBJECT.ERROR.LINE = LINE.LOOP
        SHOW.REFERENCE = @FALSE
        GOSUB PRINT.OBJECT.ERROR
    END

* pop "with" stack
    DEL WITH.STACK<1>
    CURRENT.WITH = WITH.STACK<1>

* if the with stack is empty set the current with value to the default with
* object
    IF CURRENT.WITH = "" AND COMPILE.OBJECT THEN
        CURRENT.WITH = DEFAULT.WITH.OBJECT
    END

    GOSUB COMMENT.NEW.LINE

    RETURN

COMMENT.NEW.LINE: ********************************************************
* create NEW.LINE as a commented version of CLEAN.LINE                   *
**************************************************************************

* make this line into a comment for converted code
    IF LABEL <> "" THEN
        NEW.LINE = LABEL:" * ":SPACE(INDENT.COUNT - 3)
    END ELSE
        NEW.LINE = "* ":SPACE(INDENT.COUNT - 2)
    END

    NEW.LINE := CLEAN.LINE

    RETURN


**************************************************************************
**************************************************************************
** code conversion / utility routines                                   **
**************************************************************************
**************************************************************************

GET.HANDLE.FROM.KEY.WORD: ************************************************
* key.word may have a dimensioned handle.  if so, return key.word with   *
* the dimensioned reference changed to "()" and the dimensioned handle   *
* in key.word.array.ref.  if the handle is dimensioned and the array     *
* element pointer is "*" then all.array.call will return true            *
**************************************************************************
    HANDLE.ARRAY.REF = ""
    KEY.WORD.ARRAY.REF = ""
    ALL.ARRAY.CALL = @FALSE

* save original keyword from the program code.  we'll use this later
* when we replace this keyword with modified code
    RAW.KEY.WORD = KEY.WORD

* check possible object handle against "with" structures
    CHECK.OBJECT.HANDLE = KEY.WORD
    GOSUB CHECK.OBJECT.HANDLE
    KEY.WORD = CHECK.OBJECT.HANDLE

* the handle may be dimensioned.  if so, return the key.word with the
* dimensioned handle reduced to handle() and the array reference in
* handle.array.ref

* handle.array.ref will contain the object array pointer.  it will come
* back without parenthesis around it
    METHOD.DELIMITER.PTR = INDEX(KEY.WORD,METHOD.DELIMITER,1)
    AFTER.DELIMITER.PTR = METHOD.DELIMITER.PTR + METHOD.DEL.LENGTH

    IF METHOD.DELIMITER.PTR > 0 THEN

       PREN.PTR = INDEX(KEY.WORD,"(",1)

       IF PREN.PTR > 0 AND PREN.PTR < METHOD.DELIMITER.PTR THEN

           HANDLE.ARRAY.REF = KEY.WORD [PREN.PTR, METHOD.DELIMITER.PTR - PREN.PTR]
           HANDLE.ARRAY.REF = HANDLE.ARRAY.REF [2, LEN(HANDLE.ARRAY.REF) - 2]
           KEY.WORD = KEY.WORD [1, PREN.PTR - 1]:"()":METHOD.DELIMITER:KEY.WORD [AFTER.DELIMITER.PTR, TO.THE.END]

* handle is dimensioned and the array's element pointer is "*" then
* we have a call to every object in the array
* debug
            IF TRIM(HANDLE.ARRAY.REF) = "*" THEN
                ALL.ARRAY.CALL = @TRUE
            END

       END

    END

* keyword may be a property array reference.  if it is save the array
* reference and trim down the keyword so we can find it in our tables

* key.word may have a dimensioned handle in it so we have to check for
* the parenthesis in the property value looking after the object handle

* the array reference will come back without parenthesis
    PROPERTY.DELIMITER.PTR = INDEX(KEY.WORD, PROPERTY.DELIMITER, 1)
    AFTER.DELIMITER.PTR = PROPERTY.DELIMITER.PTR + PROPERTY.DEL.LENGTH

    IF PROPERTY.DELIMITER.PTR > 0 THEN

        IF COUNT(KEY.WORD [AFTER.DELIMITER.PTR, TO.THE.END], "(") <> 0 THEN

* i think i have an array here, in which case i'd want to chop off the
* parenthesis with the array reference, return it in key.word.array.ref,
* and return the keyword without the parenthesis so we can find it in
* our handle table

* however, this could also be a method call with parameters, which also
* has parenthesis. this we also want to return without parenthesis
            PREN.PTR = INDEX(KEY.WORD [AFTER.DELIMITER.PTR, TO.THE.END], "(", 1) + AFTER.DELIMITER.PTR - 1

            IF PREN.PTR > 0 THEN
                KEY.WORD.ARRAY.REF = KEY.WORD [PREN.PTR, TO.THE.END]
                KEY.WORD.ARRAY.REF = KEY.WORD.ARRAY.REF [2, LEN(KEY.WORD.ARRAY.REF) - 2]
                KEY.WORD = KEY.WORD [1, PREN.PTR - 1]
            END

        END

    END

* raw.key.word currently holds the entire object reference along with
* anything in parenthesis after it.  this is okay for property pulls
* with arrays but, for method calls, the parenthetical part after the
* object reference is the parameter list and shouldn't be part of
* raw.key.word.  raw.key.word is replaced in the code later and we
* don't want the parameter list replaced with the keyword

* need to do some cleanup on raw.key.word depending on the type of
* object reference.  find this key.word in the usage table so we know
* what kind of keyword it is
    FIND KEY.WORD IN HANDLE.KEYWORD.LIST SETTING HANDLE.PTR, METHOD.PTR THEN
        THIS.TYPE = HANDLE.TYPE.LIST<HANDLE.PTR,METHOD.PTR>
    END ELSE
        THIS.TYPE = "NONE"
    END

    BEGIN CASE

* for methods remove anything from raw.key.word after the method name
        CASE THIS.TYPE = "METHOD"

            METHOD.DELIMITER.PTR = INDEX(RAW.KEY.WORD, METHOD.DELIMITER, 1)
            METHOD.START.PTR = METHOD.DELIMITER.PTR + METHOD.DEL.LENGTH
            METHOD.ONLY = RAW.KEY.WORD [METHOD.START.PTR, TO.THE.END]

            PREN.PTR = INDEX(METHOD.ONLY,"(",1)

            IF PREN.PTR > 0 THEN
                PREN.PTR += METHOD.START.PTR - 1
                RAW.KEY.WORD = RAW.KEY.WORD [1, PREN.PTR - 1]
            END

    END CASE

    RETURN

SPLIT.DYNAMIC.KEY.WORD: **************************************************
* split key.word into key.word and key.word.multivalue for multivalued   *
* key.words                                                              *
**************************************************************************
    DYNAMIC.KEY.WORD = @FALSE
    TEXT.INSERT.KEY.WORD = @FALSE

    KEY.LEN = LEN(KEY.WORD)
    KEY.WORD.MULTIVALUE = ""

    DYNAMIC.DEPTH = 0
    DYNAMIC.PTR = 0
    DYNAMIC.SPLIT = @FALSE

* see if this keyword has a dynamic array or text reference in it
* that is not inside parenthesis or quotes
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""
    IN.PREN = @FALSE
    PREN.DEPTH = 0

    FOR CHAR.PTR = 1 TO KEY.LEN

        THIS.CHAR = KEY.WORD [CHAR.PTR,1]

        BEGIN CASE

* quotes
            CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* pren
            CASE THIS.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH <= 0 THEN
                    IN.PREN = @FALSE
                END
            CASE IN.PREN
                NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                DYNAMIC.KEY.WORD = @TRUE

* text extract reference
            CASE THIS.CHAR = "["
                TEXT.INSERT.KEY.WORD = @TRUE

        END CASE

    NEXT CHAR.PTR

* if we aren't converting multivalue properties don't bother trying
* to separate anything . . . we shouldn't be using multivalued
* references like this
    IF NOT(MULTIVALUE.PROPERTIES) THEN
        RETURN
    END

* if we have a dynamic keyword separate key.word into
* key.word and key.word.multivalue.  if multivalue.properties
* isn't turned on leave it unsplit since we can't convert it anyway
    IF DYNAMIC.KEY.WORD THEN

* work backwards from the end of the keyword to remove the dynamic array
* reference
        FOR SPLIT.LOOP = KEY.LEN TO 1 STEP -1 UNTIL DYNAMIC.PTR <> 0 OR SPLIT.LOOP = 1

            THIS.CHAR = KEY.WORD [SPLIT.LOOP, 1]

            BEGIN CASE

* dynamic array references
                CASE THIS.CHAR = ">"
                    DYNAMIC.DEPTH += 1

                CASE THIS.CHAR = "<"
                    DYNAMIC.DEPTH -= 1
                    IF DYNAMIC.DEPTH = 0 THEN
                        DYNAMIC.PTR = SPLIT.LOOP
                    END

            END CASE

        NEXT SPLIT.LOOP

* if we couldn't find the opening dynamic array brace we can't split
* the reference.  otherwise split off the multivalued refereence
        IF DYNAMIC.PTR > 0 THEN

* we have a multivalued reference
            DYNAMIC.SPLIT = @TRUE

* extract multivalued portion of assignment variable and remove multivalued
* braces
            KEY.WORD.MULTIVALUE = TRIM(KEY.WORD [DYNAMIC.PTR, TO.THE.END]," ","B")

            IF KEY.WORD.MULTIVALUE [1, 1] = "<" THEN
                KEY.WORD.MULTIVALUE = KEY.WORD.MULTIVALUE [2, TO.THE.END]
            END

            IF KEY.WORD.MULTIVALUE [1] = ">" THEN
                KEY.WORD.MULTIVALUE = KEY.WORD.MULTIVALUE [1, LEN(KEY.WORD.MULTIVALUE) - 1]
            END

            KEY.WORD.MULTIVALUE = TRIM(KEY.WORD.MULTIVALUE," ","B")

* remove multivalued component from the assignment variable
            KEY.WORD = TRIM(KEY.WORD [1, DYNAMIC.PTR - 1]," ","B")

        END

    END

    RETURN

CHECK.NESTED.CALL: *******************************************************
* an object call to another instance of the compiled object could result *
* in the local object properties being loaded with the called object     *
* and returned to the object being executed.  a call to an object that   *
* has a child object that's the same as the compiled object can do the   *
* same thing.  loop through the created object table and see if any      *
* objects downstream from "check.nested.object.handle" are for the same  *
* object being compiled.  if so return "nested.object.call" true.        *
* this does not apply to any local object calls                          *
**************************************************************************
    NESTED.OBJECT.CALL = @FALSE

* if we aren't compiling an object don't do this check
    IF NOT(COMPILE.OBJECT) THEN
        RETURN
    END

* if this is a call to the local object handle don't check for nested
* calls for these.  the local call won't change the object handle
    IF CHECK.NESTED.OBJECT.HANDLE = LOCAL.KEYWORD THEN
        RETURN
    END

    LEN.CHECK.NESTED.OBJECT.HANDLE = LEN(CHECK.NESTED.OBJECT.HANDLE) + METHOD.DEL.LENGTH

    FOR CHECK.NESTED.LOOP = 1 TO CREATE.COUNT

        CHECK.THIS.HANDLE = CREATE.HANDLE.LIST<CHECK.NESTED.LOOP>
        CHECK.THIS.NAME = CREATE.OBJECT.LIST<CHECK.NESTED.LOOP>

        CHECK.THIS.NESTED.NAME = @FALSE

        BEGIN CASE

* check for an exact match on the called object handle.  if the object
* name for this called object is the same as the one we're compiling then
* we need to do a nested object call check to reset the object handle in
* the method we're compiling
            CASE CHECK.THIS.HANDLE = CHECK.NESTED.OBJECT.HANDLE
                CHECK.THIS.NESTED.NAME = @TRUE

* we don't have an exact match on the object handle.  if the checked
* object handle is a deeper object handle than check.nested.object.handle
* see if that object matches the object name we're compiling
             CASE CHECK.THIS.HANDLE [1, LEN.CHECK.NESTED.OBJECT.HANDLE] = CHECK.NESTED.OBJECT.HANDLE:METHOD.DELIMITER
                CHECK.THIS.NESTED.NAME = @TRUE

        END CASE

* if this is a handle to check see if the handle's object name matches
* the one we're compiling
        IF CHECK.THIS.NESTED.NAME THEN
            IF CHECK.THIS.NAME = OBJECT.NAME THEN
                NESTED.OBJECT.CALL = @TRUE
            END
        END

    NEXT CHECK.CREATE.LOOP

    RETURN

CHECK.PROPERTY.PARAMETER: ************************************************
* check check.variable to see if it's a property or one of eclipse's     *
* common variables.  shows a warning if show.property.parameters is      *
* true.  returns variable.is.property true if check.variable is a        *
* property or eclipse common variable                                    *
**************************************************************************
    VARIABLE.IS.PROPERTY = @FALSE

* if show.property.parameters is on we'll show a warning if a parameter
* is a property or eclipse common variable.  if fix.property.parameters
* is on the code for the call will be fixed and we'll want to show something
* in the warning that it was fixed
    IF FIX.PROPERTY.PARAMETERS THEN
        FIXED.NOTE = "  Call fixed."
    END ELSE
        FIXED.NOTE = ""
    END

* if the variable is null ignore it
    IF CHECK.VARIABLE = "" THEN
        RETURN
    END

* if check.variable actually is a variable then check it against the
* property and common tables
    IF IS.VARIABLE(CHECK.VARIABLE) THEN

* check for this variable name in the property list
        LOCATE CHECK.VARIABLE IN PROP.NAME.LIST SETTING ALIAS.PTR THEN

            VARIABLE.IS.PROPERTY = @TRUE

            IF SHOW.PROPERTY.PARAMETERS THEN
                OBJECT.WARNING.DESC = 'Property "':CHECK.VARIABLE:"' used in a same-object ByRef call!":FIXED.NOTE
                OBJECT.WARNING.LINE = LINE.LOOP
                GOSUB PRINT.OBJECT.WARNING                    
            END

        END

* check in the constant list
        LOCATE CHECK.VARIABLE IN CONSTANT.NAME.LIST SETTING ALIAS.PTR THEN

            VARIABLE.IS.PROPERTY = @TRUE

            IF SHOW.PROPERTY.PARAMETERS THEN
                OBJECT.WARNING.DESC = 'Constant "':CHECK.VARIABLE:"' used in a same-object ByRef call!":FIXED.NOTE
                OBJECT.WARNING.LINE = LINE.LOOP
                GOSUB PRINT.OBJECT.WARNING                    
            END

        END

* check in the child list
        LOCATE CHECK.VARIABLE IN CHILD.HANDLE.LIST SETTING ALIAS.PTR THEN

            VARIABLE.IS.PROPERTY = @TRUE

            IF SHOW.PROPERTY.PARAMETERS THEN

                VARIABLE.IS.PROPERTY = @TRUE

                IF SHOW.PROPERTY.PARAMETERS THEN
                    OBJECT.WARNING.DESC = 'Constant "':CHECK.VARIABLE:"' used in a same-object ByRef call!":FIXED.NOTE
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING                    
                END

            END

        END

* check against eclipse commons
        IF CHECK.ECLIPSE.COMMON.VARIABLES THEN

            LOCATE CHECK.VARIABLE IN ECLIPSE.COMMON.NAME.LIST SETTING ECLIPSE.PTR THEN

                VARIABLE.IS.PROPERTY = @TRUE

                IF SHOW.PROPERTY.PARAMETERS THEN
                    OBJECT.WARNING.DESC = 'Parameter "':CHECK.VARIABLE:'" is an Eclipse common variable':FIXED.NOTE
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING
                END

            END

        END

    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / convert subroutine calls                           **
**************************************************************************
**************************************************************************

CONVERT.SUBROUTINE.STATEMENT: ********************************************
* rebuild this.subroutine.statement from one in an object-enabled        *
* subroutine to one that can be used in cbp.  this removes any byval     *
* and byref references from the subroutine statement.  if ";" is used    *
* as a parameter delimiter it is changed to a comma.  byrefs and byvals  *
* are handled by the calling program so the subroutine doesn't need      *
* them.                                                                  *
*                                                                        *
* returns new.subroutine.statement                                       *
**************************************************************************

* as we work through the parameter list we'll build a table of parameters
* with optional values
    OPTIONAL.PARAMETER.LIST = ""
    OPTIONAL.VALUE.LIST = ""
    OPTIONAL.BYREF.LIST = ""
    OPTIONAL.SET.LIST = ""
    OPTIONAL.IN.LIST = ""
    OPTIONAL.COUNT = 0

* tables to update ud.compile.dates
    SUB.PARAMETER.LIST = ""
    SUB.BYREF.LIST = ""
    SUB.VALUE.LIST = ""
    SUB.SET.LIST = ""
    SUB.IN.LIST = ""
    SUB.OPTIONAL.LIST = ""

    NEW.SUBROUTINE.STATEMENT = THIS.SUBROUTINE.STATEMENT

* if this line doesn't start with "subroutine" don't do anything
    IF UPCASE(TRIM(THIS.SUBROUTINE.STATEMENT) [" ", 1, 1]) <> "SUBROUTINE" THEN
        RETURN
    END

* extract parameters from this.subroutine.statement and remove trailing
* parenthesis
    THIS.PARAMETER.LIST = TRIM(THIS.SUBROUTINE.STATEMENT ["(", 2, TO.THE.END])

    IF THIS.PARAMETER.LIST [1] = ")" THEN
        THIS.PARAMETER.LIST = THIS.PARAMETER.LIST [1, LEN(THIS.PARAMETER.LIST) - 1]
    END

* check the parameter list for errors
    IF CHECK.SUB.IO.PARAMETERS THEN

        IF MANDATORY.SUB.IO.PARAMETERS THEN
            PARAMETER.MODE = "MANDATORY.CHECK"
        END ELSE
            PARAMETER.MODE = "CHECK"
        END

        PARAMETER.ERROR = SPLIT.METHOD.PARAMETERS (THIS.PARAMETER.LIST, PARAMETER.MODE)

        IF PARAMETER.ERROR <> "" THEN

            METHOD = "MAIN"
            OBJECT.ERROR.DESC = PARAMETER.ERROR
            OBJECT.ERROR.LINE = "000001 ":THIS.SUBROUTINE.STATEMENT
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

        END

    END

* if there is a semi-colon in the parameter list it will mark the first
* "in" parameter.  if there's no semi-colon they're all "in" parameters
    THIS.IN = "OUT"
    SEMI.COLON.PTR = INDEX (THIS.PARAMETER.LIST, ";", 1)

    IF SEMI.COLON.PTR < 1 THEN
        FIRST.IN.PARAMETER = DCOUNT (THIS.PARAMETER.LIST, ",") + 99
    END ELSE
        BEFORE.SEMI.COLON = THIS.PARAMETER.LIST [1, SEMI.COLON.PTR - 1]
        FIRST.IN.PARAMETER = DCOUNT (BEFORE.SEMI.COLON, ",") + 1
    END

* if all values are input values the first character will be a semicolon.
* there won't be a first parameter.  just remove the semicolon
    IF THIS.PARAMETER.LIST [1, 1] = ";" THEN
        THIS.PARAMETER.LIST = TRIM(THIS.PARAMETER.LIST [2, TO.THE.END])
    END

* if all values are output values the last character will be a semicolon.
* there won't be a parameter after it.  remove the semicolon
    IF THIS.PARAMETER.LIST [1] = ";" THEN
        THIS.PARAMETER.LIST = TRIM(THIS.PARAMETER.LIST [1, LEN(THIS.PARAMETER.LIST) - 1])
    END

* any semicolons in the parameter list should be changed to commas
    THIS.PARAMETER.LIST = CHANGE(THIS.PARAMETER.LIST, ";", ",")

    THIS.PARAMETER.LIST = CHANGE(THIS.PARAMETER.LIST, ",", @AM)
    THIS.PARAMETER.COUNT = DCOUNT(THIS.PARAMETER.LIST, @AM)

    IF THIS.PARAMETER.COUNT = 0 THEN
        RETURN
    END

* build new.subroutine statement.  start off with the old subroutine
* statement up to the parenthesis
    NEW.SUBROUTINE.STATEMENT = THIS.SUBROUTINE.STATEMENT ["(", 1, 1]:" ("

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

* add in the cleaned up parameter list
    FOR THIS.PARAMETER.LOOP = 1 TO THIS.PARAMETER.COUNT

        IF THIS.PARAMETER.LOOP = FIRST.IN.PARAMETER THEN
            THIS.IN = "IN"
        END

        THIS.PARAMETER = TRIM(THIS.PARAMETER.LIST<THIS.PARAMETER.LOOP>)
        OPTIONAL.VALUE = ""

* check for an "optional" keyword and value
        OPTIONAL.PARAMETER = @FALSE
        FIRST.WORD = THIS.PARAMETER [" ", 1, 1]

        IF FIRST.WORD = OPTIONAL.KEYWORD THEN
            OPTIONAL.PARAMETER = @TRUE
            THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
        END

* check for a "byval", "handle" or "byref" keyword and remove it from the parameter
* if found
        FIRST.WORD = THIS.PARAMETER [" ", 1, 1]

        BEGIN CASE

            CASE FIRST.WORD = BYVAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYREF = @FALSE

            CASE FIRST.WORD = BYVAL.SPECIAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYREF = @FALSE

            CASE FIRST.WORD = BYREF.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYREF = @TRUE

            CASE THIS.IN = "OUT"
                THIS.BYREF = @FALSE

            CASE 1
                THIS.BYREF = @TRUE

        END CASE

* if this parameter is optional add it to the table
        IF OPTIONAL.PARAMETER THEN

            OPTIONAL.VALUE = TRIM(THIS.PARAMETER ["=", 2, TO.THE.END], " ", "B")
            THIS.PARAMETER = TRIM(THIS.PARAMETER ["=", 1, 1], " ", "B")

            OPTIONAL.COUNT += 1
            OPTIONAL.PARAMETER.LIST<OPTIONAL.COUNT> = THIS.PARAMETER
            OPTIONAL.VALUE.LIST<OPTIONAL.COUNT> = OPTIONAL.VALUE
            OPTIONAL.BYREF.LIST<OPTIONAL.COUNT> = THIS.BYREF
            OPTIONAL.SET.LIST<OPTIONAL.COUNT> = @FALSE
            OPTIONAL.IN.LIST<OPTIONAL.COUNT> = THIS.IN
             
        END

        IF THIS.PARAMETER.LOOP > 1 THEN
            NEW.SUBROUTINE.STATEMENT := BETWEEN.PARAMETERS
        END

        NEW.SUBROUTINE.STATEMENT := THIS.PARAMETER

* update tables used to update ud.compile.dates
        SUB.PARAMETER.LIST<THIS.PARAMETER.LOOP> = THIS.PARAMETER

        IF THIS.BYREF THEN
            THIS.BYREF = "Y"
        END ELSE
            THIS.BYREF = "N"
        END

        SUB.BYREF.LIST<THIS.PARAMETER.LOOP> = THIS.BYREF

        SUB.VALUE.LIST<THIS.PARAMETER.LOOP> = OPTIONAL.VALUE
        SUB.SET.LIST<THIS.PARAMETER.LOOP> = @FALSE
        SUB.IN.LIST<THIS.PARAMETER.LOOP> = THIS.IN

        IF OPTIONAL.PARAMETER THEN
            OPTIONAL.PARAMETER = "Y"
        END ELSE
            OPTIONAL.PARAMETER = "N"
        END

        SUB.OPTIONAL.LIST<THIS.PARAMETER.LOOP> = OPTIONAL.PARAMETER

    NEXT THIS.PARAMETER.LOOP

    NEW.SUBROUTINE.STATEMENT := ")"

    RETURN

INSERT.OBSUB.OPTIONAL.PARAMETER.CODE: ************************************
* insert code into program<n> to handle optional parameters in an        *
* object-enabled subroutine                                              *
**************************************************************************
    OPTIONAL.CODE.COUNT = 0

* if there are no optional parameters there's nothing to do
    IF OPTIONAL.COUNT = 0 THEN
        RETURN
    END

* find the first line of code (not blank, not a comment) in the subroutine
    SETREM 0 ON PROGRAM.CODE
    FIRST.CODE.LINE = ""

* skip "subroutine" line
    REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* work through remainder of code to find first line of code
    FOR LINE.LOOP = 2 TO PROGRAM.CODE.LINES UNTIL FIRST.CODE.LINE <> ""

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY
        THIS.LINE = TRIM(THIS.LINE)

        IF THIS.LINE [1, 1] <> "*" AND THIS.LINE [1, 1] <> "!" AND THIS.LINE <> "" THEN
            FIRST.CODE.LINE = LINE.LOOP
        END
            
    NEXT LINE.LOOP

* if we couldn't find a line of code something is way amiss
    IF FIRST.CODE.LINE = "" THEN
        FIRST.CODE.LINE = 2
    END

* build a block of code to handle all optional parameters
    OPTIONAL.CODE = ""
    OPTIONAL.CODE.COUNT = 0

    CODE = " "
    GOSUB ADD.OPTIONAL.CODE
    CODE = "* set default values for optional parameters"
    GOSUB ADD.OPTIONAL.CODE

    FOR PARAMETER.LOOP = 1 TO OPTIONAL.COUNT

        THIS.PARAMETER = OPTIONAL.PARAMETER.LIST<PARAMETER.LOOP>
        THIS.VALUE = OPTIONAL.VALUE.LIST<PARAMETER.LOOP>

        CODE = "    BEGIN CASE"
        GOSUB ADD.OPTIONAL.CODE
        CODE = "        CASE ISNULL(":THIS.PARAMETER:")"
        GOSUB ADD.OPTIONAL.CODE
        CODE = "            ":THIS.PARAMETER:' = ""'
        GOSUB ADD.OPTIONAL.CODE
        CODE = "        CASE ":THIS.PARAMETER:' = ""'
        GOSUB ADD.OPTIONAL.CODE
        CODE = "            ":THIS.PARAMETER:" = ":THIS.VALUE
        GOSUB ADD.OPTIONAL.CODE
        CODE = "    END CASE"
        GOSUB ADD.OPTIONAL.CODE

    NEXT PARAMETER.LOOP

    CODE = " "
    GOSUB ADD.OPTIONAL.CODE

* insert the optional code before the first code line in the subroutine
    INS OPTIONAL.CODE BEFORE PROGRAM.CODE<FIRST.CODE.LINE>
    PROGRAM.CODE.LINES += OPTIONAL.CODE.COUNT

    RETURN

ADD.OPTIONAL.CODE: *******************************************************
* add code to optional.code                                              *
**************************************************************************
    OPTIONAL.CODE.COUNT += 1
    OPTIONAL.CODE<OPTIONAL.CODE.COUNT> = CODE

    RETURN


**************************************************************************
**************************************************************************
** compiling / parallel compiling                                       **
**************************************************************************
**************************************************************************

COMPILE.IN.PARALLEL: *****************************************************
* compile a method as a phantom capturing the output in a como           *
**************************************************************************
* this is an experimental thing to see if compiles for an entire object  *
* can be sped up.  this is invoked when compiling with the               *
* (undocumented) PARALLEL option.  each method is run in its own phantom *
* to (hopefully) run things faster.  it's not all that much faster,      *
* thought.  i suspect its a resource shortage in the dev account (?)     *
* but its hard to be sure.  it does take more work when compiling each   *
* method in its own process, of course.  table builds from one method    *
* are cached so that later method builds are faster and this doesn't     *
* happen when each method runs in its own phantom.  still, it seems to   *
* be much slower than i would expect so maybe it's a resource thing.     *
**************************************************************************

* if we've already compiled this method don't compile it again
    ALREADY.COMPILED = @FALSE

    FOR CHECK.LOOP = 1 TO PARALLEL.COUNT UNTIL ALREADY.COMPILED

        IF PARALLEL.OBJECT.LIST<CHECK.LOOP> = OBJECT.NAME THEN
            IF PARALLEL.METHOD.LIST<CHECK.LOOP> = THIS.METHOD THEN
                ALREADY.COMPILED = @TRUE
            END 
        END

    NEXT CHECK.LOOP

    IF ALREADY.COMPILED THEN
        RETURN
    END

    IF THIS.METHOD = COMMON.ROUTINE.METHOD THEN
        RETURN
    END 

* build the como name for this compile and update the parallel tables
    COMO.COUNTER += 1
    COMO.NAME = COMO.PREFIX:COMO.COUNTER

    PARALLEL.COUNT += 1
    PARALLEL.OBJECT.LIST<PARALLEL.COUNT> = OBJECT.NAME
    PARALLEL.METHOD.LIST<PARALLEL.COUNT> = THIS.METHOD
    PARALLEL.COMO.LIST<PARALLEL.COUNT> = COMO.NAME
    PARALLEL.STARTED.LIST<PARALLEL.COUNT> = @FALSE
    PARALLEL.COMPLETE.LIST<PARALLEL.COUNT> = @FALSE
    PARALLEL.SUCCESSFUL.LIST<PARALLEL.COUNT> = @FALSE

* build commands to compile in a phantom
    STATEMENT = "PHANTOM.REAL BRIEF PHANTOM.COMPILE ":COMO.NAME:" "
    STATEMENT := OBJECT.NAME:METHOD.DELIMITER:THIS.METHOD

* fire off the compile
    EXECUTE STATEMENT CAPTURING TEXT

    IF NOT(BRIEF) THEN
        PRINT "Phantom started for ":OBJECT.NAME:METHOD.DELIMITER:THIS.METHOD
        PRINT "    ":COMO.NAME
    END

    WAIT.EVERY = 10000

    IF COMO.COUNTER / WAIT.EVERY = INT(COMO.COUNTER / WAIT.EVERY) THEN
        GOSUB WAIT.FOR.PARALLEL.COMPILES
    END

    RETURN

WAIT.FOR.PARALLEL.COMPILES: **********************************************
* wait for parallel compiles to finish                                   *
**************************************************************************
    WAIT.START.TIME = TIME()
    ALL.FINISHED = @FALSE

    IF NOT(BRIEF) THEN
        PRINT
        PRINT "Waiting for ":PARALLEL.COUNT:" phantom compiles to complete"
        PRINT
    END

    LOOP

        ALL.FINISHED = @TRUE

        FOR CHECK.LOOP = 1 TO PARALLEL.COUNT

            THIS.COMO = PARALLEL.COMO.LIST<CHECK.LOOP>
            THIS.OBJECT = PARALLEL.OBJECT.LIST<CHECK.LOOP>
            THIS.METHOD = PARALLEL.METHOD.LIST<CHECK.LOOP>

            GOSUB CHECK.PHANTOM.COMPILE
 
            IF NOT(PHANTOM.COMPILE.FINISHED) THEN
                ALL.FINISHED = @FALSE
            END

        NEXT CHECK.LOOP

    UNTIL ALL.FINISHED

        SLEEP 1
        PRINT ".":

    REPEAT

    PRINT
    PRINT "Phantom compiles completed"

    RETURN

CHECK.PHANTOM.COMPILE: ***************************************************
* check to see if the phantom compile that generated this.como was       *
* successful or not.  sets flags in the parallel table                   *
**************************************************************************
    PHANTOM.COMPILE.FINISHED = PARALLEL.COMPLETE.LIST<CHECK.LOOP>
    PHANTOM.COMPILE.STARTED = PARALLEL.STARTED.LIST<CHECK.LOOP>
    PHANTOM.COMPILE.SUCCESSFUL = PARALLEL.SUCCESSFUL.LIST<CHECK.LOOP>

    IF PHANTOM.COMPILE.FINISHED THEN
        RETURN
    END

    COMO.EXISTS = @TRUE
    READ COMO.RECORD FROM COMOFILE, THIS.COMO ELSE
        COMO.RECORD = ""
        COMO.EXISTS = @FALSE
    END

* if this phantom compile hasn't started yet check the como to see if it 
* started
    IF NOT(PHANTOM.COMPILE.STARTED) THEN

        IF INDEX(COMO.RECORD, "uniVerse Object Precompiler", 1) <> 0 THEN
            PRINT THIS.OBJECT:METHOD.DELIMITER:THIS.METHOD:" has started"
            PHANTOM.COMPILE.STARTED = @TRUE
            PARALLEL.STARTED.LIST<CHECK.LOOP> = @TRUE
        END

    END

* check to see if the phantom compile finished
    LOCATE "</compile>" IN COMO.RECORD SETTING FINISHED.PTR ELSE
        RETURN
    END

* set the "compile complete" flag
    IF NOT(PHANTOM.COMPILE.FINISHED) THEN

        PHANTOM.COMPILE.FINISHED = @TRUE
        PARALLEL.COMPLETE.LIST<CHECK.LOOP> = @TRUE
        PRINT THIS.OBJECT:METHOD.DELIMITER:THIS.METHOD:" has completed"

* was the compile successful?
        IF INDEX(COMO.RECORD, "Compilation Complete", 1) <> 0 THEN
            PHANTOM.COMPILE.SUCCESSFUL = @TRUE
            PRINT "    Compile successful"
        END ELSE
            PRINT "    Compile had errors"
        END

        PARALLEL.SUCCESSFUL.LIST<CHECK.LOOP> = PHANTOM.COMPILE.SUCCESSFUL

    END

    RETURN

DELETE.PARALLEL.COMOS: ***************************************************
* delete all comos from parallel compiling                               *
**************************************************************************
    PRINT 
    PRINT "Deleting parallel comos"

    FOR COMO.LOOP = 1 TO PARALLEL.COUNT

        COMO.NAME = PARALLEL.COMO.LIST<COMO.LOOP>

        IF COMO.NAME <> "" THEN

            WRITE.ERROR = @FALSE
            DELETE COMOFILE, COMO.NAME ON ERROR WRITE.ERROR = @TRUE

            IF WRITE.ERROR THEN
                ERROR.FILE = "&COMO&"
                ERROR.ITEM = COMO.NAME
                GOSUB DELETE.ERROR
            END

        END

    NEXT COMO.LOOP

    PRINT "    Comos deleted"

    RETURN


**************************************************************************
**************************************************************************
** code conversion / "string" object routines                           **
**************************************************************************
**************************************************************************

CHECK.STRING.OBJECT.KEYWORD: *********************************************
* check key.word to see if it's doing a string pseudo-object call.       *
* checks what should be the object handle (the first part of the         *
* expression) against the object handle list.  if it's not found there   *
* it's assumed to be a string pseudo-object call                         *
**************************************************************************
    STRING.VARIABLE = ""
    STRING.OBJECT.CALL = @FALSE

* a string object call will be using the method delimiter.  separate the
* object name from the method name from key.word.  if the object name is
* found in the handle variable list then we have a "normal" object reference
* and not a string pseudo-object reference
    DELIMITER.PTR = INDEX(KEY.WORD, METHOD.DELIMITER, 1)

    IF DELIMITER.PTR = 0 THEN
        RETURN
    END

    CHECK.OBJECT.HANDLE = KEY.WORD [1, DELIMITER.PTR - 1]
    CHECK.METHOD.NAME = KEY.WORD [DELIMITER.PTR + METHOD.DEL.LENGTH, TO.THE.END]

* check cases where we don't want to convert this reference
    BEGIN CASE

* if the object handle is "local" don't do any conversions
        CASE CHECK.OBJECT.HANDLE = LOCAL.OBJECT.HANDLE
            RETURN
        CASE CHECK.OBJECT.HANDLE = LOCAL.KEYWORD
            RETURN

* if we don't come out with both an object handle and a method name this
* isn't a string pseudo-object reference
        CASE CHECK.OBJECT.HANDLE = "" OR CHECK.METHOD.NAME = ""
            RETURN

* the string pseudo-object is a single instance and won't be dimensioned.
* if any parenthesis exists in the object handle then this isn't a string
* pseudo-object reference
        CASE COUNT(CHECK.OBJECT.HANDLE, "(") <> 0 OR COUNT(CHECK.OBJECT.HANDLE, ")") <> 0
            RETURN

* if there's any dynamic array reference in the object handle then this
* isn't the string pseudo-object handle
        CASE COUNT(CHECK.OBJECT.HANDLE, "<") <> 0 OR COUNT(CHECK.OBJECT.HANDLE, ">") <> 0
            RETURN

* if the object handle begins with a quote and ends with a quote we're
* starting out with a literal text so we'll allow it
        CASE CHECK.OBJECT.HANDLE [1, 1] = '"' AND CHECK.OBJECT.HANDLE [1] = '"' AND LEN(CHECK.OBJECT.HANDLE) > 1
            NULL
        CASE CHECK.OBJECT.HANDLE [1, 1] = "'" AND CHECK.OBJECT.HANDLE [1] = "'" AND LEN(CHECK.OBJECT.HANDLE) > 1
            NULL

* if there is a quote anywhere in the object handle we've hit a string that
* has one of the object delimiters in it.  it's not a real object reference
        CASE CHECK.OBJECT.HANDLE <> CONVERT('"':"'", "", CHECK.OBJECT.HANDLE)
            RETURN

    END CASE

* if the expression's object handle exists in the handle variable list then
* this is not a daisy-chained "string" call.  don't convert this reference
    LOCATE CHECK.OBJECT.HANDLE IN HANDLE.VARIABLE.LIST SETTING THIS.OBJECT.PTR THEN
        RETURN
    END

* if we got here then this is a string pseudo-object call.  find the handle
* for the string object.  if the string object isn't found in the handle
* object list then the string object wasn't initialized and we won't do any
* string pseudo-object conversions

* the string object name may appear in handle.object.list more than once as
* it could be a child object of other objects in the list.  we need to find a
* local reference.  if there's no local reference than we can't convert the
* daisy-chain call.  we'll know its a local reference if the first keyword
* (which will be an object::method reference) pulled from the handle.keyword
* list has only one method delimiters in it as the "string" object can have
* no child objects.  "string" objects that are child objects of other 
* objects would have more than one
    STRING.SEARCH.PTR = 1

    LOOP

        LOCATE STRING.OBJECT.NAME IN HANDLE.OBJECT.LIST, STRING.SEARCH.PTR SETTING STRING.OBJECT.PTR ELSE
            RETURN
        END

        TEST.STRING.KEYWORD = HANDLE.KEYWORD.LIST<STRING.OBJECT.PTR, 1>
        TEST.STRING.KEYWORD = CHANGE(TEST.STRING.KEYWORD, METHOD.DELIMITER, @AM)
        TEST.STRING.DELIMITER.COUNT = COUNT (TEST.STRING.KEYWORD, @AM)

        IF TEST.STRING.DELIMITER.COUNT > 1 THEN
            STRING.SEARCH.PTR = STRING.OBJECT.PTR + 1
            STRING.OBJECT.PTR = 0
        END

    UNTIL STRING.OBJECT.PTR <> 0
    REPEAT

    STRING.HANDLE = HANDLE.VARIABLE.LIST<STRING.OBJECT.PTR>

* the "object" part of the expression is actually the variable name that the
* string methods will be acting on.  the string handle to use for this call
* will be the string pseudo-object's handle
    STRING.VARIABLE = CHECK.OBJECT.HANDLE

* build a list of methods to be called serially for the variable
    KEYWORD.PTR = INDEX(CLEAN.LINE, KEY.WORD, 1)
    METHOD.LIST.PTR = KEYWORD.PTR + LEN(KEY.WORD) - LEN(CHECK.METHOD.NAME)
    STRING.METHOD = CLEAN.LINE [METHOD.LIST.PTR, TO.THE.END]

    GOSUB BUILD.STRING.METHOD.LIST

* check each method in the string.method.list to make sure it's a valid method
* for the string pseudo-object.  if not show an error
    FOR STRING.METHOD.LOOP = 1 TO STRING.METHOD.COUNT

        THIS.STRING.METHOD = STRING.METHOD.LIST<STRING.METHOD.LOOP> ["(", 1, 1]

        LOCATE THIS.STRING.METHOD IN HANDLE.METHOD.LIST<STRING.OBJECT.PTR> SETTING THROWAWAY ELSE

            OBJECT.ERROR.DESC = '"':THIS.STRING.METHOD:'"':" is not a valid method for "
            OBJECT.ERROR.DESC := "the ":'"':STRING.OBJECT.NAME:'"':" object"

            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

        END

    NEXT STRING.METHOD.LOOP

* the "method" for these calls may be a list of methods in a row.  each method
* will be processed given the results of the previous method call.  rebuild
* keyword using the string pseudo-object handle and the first expression in
* the method list
    KEY.WORD = STRING.HANDLE:METHOD.DELIMITER:STRING.METHOD.LIST<1>

    STRING.OBJECT.CALL = @TRUE

    RETURN

BUILD.STRING.METHOD.LIST: ************************************************
* build string.method.list with a list of methods to be processed for    *
* the string pseudo-object call                                          *
**************************************************************************

* clean.line now has a string of one or more methods in the string pseudo-
* object that should be called with string.variable as the first argument.
* build the string.method array with each method
    LEN.STRING.METHOD = LEN(STRING.METHOD)

    STRING.METHOD.LIST = ""
    STRING.CONVERT.LINE = ""
    STRING.METHOD.COUNT = 0

    IN.QUOTES = @FALSE
    THIS.QUOTE = 0

    PREN.DEPTH = 0

    DYN.DEPTH = 0

    EXTRACT.DEPTH = 0

    START.PTR = 1

    FOR CHAR.PTR = 1 TO LEN.STRING.METHOD

        THIS.CHAR = STRING.METHOD [CHAR.PTR, 1]

* check for quotes, parenthesis, dyanamic arrays, text extracts
        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* parenthesis
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH < 0 THEN
                    PREN.DEPTH = 0
                END
            CASE PREN.DEPTH <> 0
                NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                DYN.DEPTH += 1
            CASE THIS.CHAR = ">"
                DYN.DEPTH -= 1
                IF DYN.DEPTH < 0 THEN
                    DYN.DEPTH = 0
                END
            CASE DYN.DEPTH <> 0
                NULL

* text extract
            CASE THIS.CHAR = "["
                EXTRACT.DEPTH += 1
            CASE THIS.CHAR = "]"
                EXTRACT.DEPTH -= 1
                IF EXTRACT.DEPTH < 0 THEN
                    EXTRACT.DEPTH = 0
                END
            CASE EXTRACT.DEPTH <> 0
                NULL

* we've hit a method delimiter and we aren't in any quotes, parenthesis,
* dynamic array reference or text extract
            CASE STRING.METHOD [CHAR.PTR, METHOD.DEL.LENGTH] = METHOD.DELIMITER

* extract the reference and set the "start" extraction pointer to after the
* method delimiter.  spaces in the call.reference confuse later routines so we'll
* remove them before adding call.reference to the string.method.list array
                CALL.REFERENCE = STRING.METHOD [START.PTR, CHAR.PTR - START.PTR]
                START.PTR = CHAR.PTR + METHOD.DEL.LENGTH

                IF CALL.REFERENCE <> "" THEN
                    STRING.METHOD.COUNT += 1
                    STRING.METHOD.LIST<STRING.METHOD.COUNT> = CALL.REFERENCE
                END

        END CASE

    NEXT CHAR.PTR

* if there's anything left it will be the last method reference
    CALL.REFERENCE = STRING.METHOD [START.PTR, TO.THE.END]
    IF CALL.REFERENCE <> "" THEN
        STRING.METHOD.COUNT += 1
        STRING.METHOD.LIST<STRING.METHOD.COUNT> = CALL.REFERENCE
    END

    RETURN

CONVERT.STRING.OBJECT.CALL: **********************************************
* convert string pseudo-object calls from a variable in clean.line, ie:  *
*    MYVARIABLE::STRING.METHOD::ANOTHER.STRING.METHOD . . .              *
**************************************************************************

* the name of the variable returning the function value will be built
* from the string variable name.  if this is an assignment type call
* we'll use the assignment variable as the returned value variable
    IF ASSIGNMENT.TYPE THEN
        STRING.RETURN.VARIABLE = ASSIGNMENT.VARIABLE
    END ELSE
        STRING.RETURN.VARIABLE = STRING.VARIABLE
    END

* convert each call reference into a call to a method in the string
* pseudo-object
    STRING.CONVERT.LINE = ""

    FOR STRING.LOOP = 1 TO STRING.METHOD.COUNT

        THIS.CALL = STRING.METHOD.LIST<STRING.LOOP>
        THIS.METHOD = THIS.CALL ["(", 1, 1]
        THIS.PARAMETER.LIST = THIS.CALL ["(", 2, TO.THE.END]

        FIRST.CHAR = THIS.CALL [1, 1]
        LAST.CHAR = THIS.CALL [1]

        IF FIRST.CHAR = "'" AND LAST.CHAR = "'" THEN
            FIRST.CHAR = '"'
            LAST.CHAR = '"'
        END

* start the new call off with the label (if this is line 1) and the
* indenting
        IF STRING.LOOP = 1 THEN
            NEW.CALL = CLEAN.LABEL:SPACE(INDENT.COUNT)
        END ELSE
            NEW.CALL = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL))
        END

* add in the string pseudo-object handle and the method name
        NEW.CALL := STRING.HANDLE:METHOD.DELIMITER:THIS.METHOD

        BEGIN CASE

* first conversion, text extract
            CASE STRING.LOOP = 1 AND FIRST.CHAR = "[" AND LAST.CHAR = "]"
                NEW.CALL = STRING.RETURN.VARIABLE:" = ":STRING.VARIABLE:THIS.CALL

* second and later conversions, text extract
            CASE STRING.LOOP > 1 AND FIRST.CHAR = "[" AND LAST.CHAR = "]"
                NEW.CALL = STRING.RETURN.VARIABLE:" = ":STRING.RETURN.VARIABLE:THIS.CALL

* first conversion, formatting
            CASE STRING.LOOP = 1 AND FIRST.CHAR = '"' AND LAST.CHAR = '"'
                NEW.CALL = STRING.RETURN.VARIABLE:" = OCONV(":STRING.VARIABLE:",":THIS.CALL:")"

* second and later conversions, formatting
            CASE STRING.LOOP > 1 AND FIRST.CHAR = '"' AND LAST.CHAR = '"'
                NEW.CALL = STRING.RETURN.VARIABLE:" = OCONV(":STRING.RETURN.VARIABLE:",":THIS.CALL:")"

* first conversion, string pseudo-object call, no parameters.  build a
* call passing only the string object call's variable name and the 
* returned variable.name
            CASE STRING.LOOP = 1 AND THIS.PARAMETER.LIST = ""
                NEW.CALL := "(":STRING.RETURN.VARIABLE:","
                NEW.CALL := CONVERT.BYVAL(STRING.VARIABLE, 1):")"

* second and later conversions, string pseudo-object call, no parameters.
* build a call keeping everything in the string.return.variable
            CASE STRING.LOOP > 1 AND THIS.PARAMETER.LIST = ""
                NEW.CALL := "(":STRING.RETURN.VARIABLE:","
                NEW.CALL := CONVERT.BYVAL(STRING.RETURN.VARIABLE, 1):")"


* first conversion, string pseudo-object call with parameters
            CASE STRING.LOOP = 1
                NEW.CALL := "(":STRING.RETURN.VARIABLE:","
                NEW.CALL := CONVERT.BYVAL(STRING.VARIABLE, 1):","
                NEW.CALL := THIS.PARAMETER.LIST

* second and later conversions, string pseudo-object call with
* parameters.  build a call keeping everything in the string.return.variable
            CASE 1
                NEW.CALL := "(":STRING.RETURN.VARIABLE:","
                NEW.CALL := CONVERT.BYVAL(STRING.RETURN.VARIABLE, 1):","
                NEW.CALL := THIS.PARAMETER.LIST

        END CASE

        STRING.CONVERT.LINE<STRING.LOOP> = NEW.CALL

    NEXT STRING.LOOP

    STRING.CONVERT.COUNT = STRING.METHOD.COUNT

    IF DETAILS THEN
        GOSUB LIST.STRING.OBJECT.CONVERSIONS
    END

    RETURN

LIST.STRING.OBJECT.CONVERSIONS: ******************************************
* list conversions performed for pseudo-object calls to the string       *
* object.  for debugging                                                 *
**************************************************************************

    PRINT 
    PRINT "String pseudo-object conversion"
    PRINT "Code: ":CLEAN.LINE
    PRINT
    PRINT "Reference........... Converted.............................................."

    FOR STRING.LOOP = 1 TO STRING.CONVERT.COUNT
        PRINT STRING.METHOD.LIST<STRING.LOOP> "L#20":" ":
        PRINT STRING.CONVERT.LINE<STRING.LOOP> "L#55"
    NEXT STRING.LOOP

    PRINT

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / literal text expressions                           **
**************************************************************************
**************************************************************************

CONVERT.ALL.LITERAL.TEXT: ************************************************
* Eclipse's precompiler does a trim() on each program line before        *
* translating.  the trim doesn't respect quotes so if there's a          *
* literal expression like "      string     " in a subroutine call       *
* Eclipse's precompiler turns it into " string ".  this is very          *
* annoying if you want the spaces to be passed.                          *
*                                                                        *
* this routine checks every string that's inside quotes.  any sequence   *
* of two spaces or more is converted into a "space(n)" expression so     *
* that Eclipse's precompiler won't mangle it                             *
**************************************************************************
    LITERAL.START.DATE = DATE()
    LITERAL.START.TIME = TIME()

    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

* skip over any obvious lines that won't need conversions
        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE COUNT(THIS.LINE, "'") = 0 OR COUNT(THIS.LINE, '"') = 0
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            THIS.LABEL = LINE.LABEL (THIS.LINE)
            INDENT.COUNT = FIND.INDENT.COUNT (THIS.LABEL, THIS.LINE)

            IF THIS.LABEL <> "" THEN
                THIS.LINE = LINE.WITHOUT.LABEL (THIS.LINE)
            END ELSE
                THIS.LINE = TRIM(THIS.LINE, " ", "B")
            END

            NEW.LINE = CONVERT.LITERAL.SPACES (THIS.LINE)

            IF NEW.LINE <> THIS.LINE THEN
                PROGRAM.CODE<LINE.LOOP> = THIS.LABEL:SPACE(INDENT.COUNT):NEW.LINE
            END

        END

    NEXT LINE.LOOP

    LITERAL.END.DATE = DATE()
    LITERAL.END.TIME = TIME()
    LITERAL.ELAPSED.TIME += TIME.ELAPSED (LITERAL.START.DATE, LITERAL.START.TIME)

    RETURN

CHECK.SUB.OBJECT.KEYWORD: ************************************************
* check key.word to see if it's a call to the subroutine pseudo-object.  *
* if so then check the subroutine being called and see if it's been      *
* set up in the object usage tables.  if it's not then add it to the     *
* object usage tables so that the call can be processed.                 *
**************************************************************************

* test to see if key.word's object reference is the subroutine pseudo-object
    TEST.PTR = INDEX(KEY.WORD, METHOD.DELIMITER, 1)

    IF TEST.PTR < 1 THEN
        RETURN
    END

    TEST.OBJECT = KEY.WORD [1, TEST.PTR - 1]

    IF TEST.OBJECT <> SUBROUTINE.CALL.KEYWORD THEN
        RETURN
    END

* if we can find this keyword in the usage tables then we've already
* updated the usage tables with this subroutine and don't need to do
* anything
    FIND KEY.WORD IN HANDLE.KEYWORD.LIST SETTING TEST.HANDLE.PTR, TEST.METHOD.PTR THEN

* convert.this.line uses raw.key.word to separate parameters before and after
* the keyword.  raw.key.word sometimes comes here with parameters attached
* to it if there's an open parenthesis there.  if so set raw.key.word to
* the part before the parenthesis so that convert.this.line can convert
* things properly
        RAW.KEY.WORD = RAW.KEY.WORD ["(", 1, 1]

        RETURN

    END

* we need to add this subroutine call to the usage tables.

* the object reference is the subroutine pseudo-object.  extract the
* subroutine name and make sure it exists in OBP or in OC.  if it
* doesn't flag an error
    SUBROUTINE.CALL.NAME = KEY.WORD [TEST.PTR + METHOD.DEL.LENGTH, TO.THE.END]

    SUBROUTINE.DEFINITION = ""
    READV SUBROUTINE.DEFINITION FROM OBPFILE, SUBROUTINE.CALL.NAME, 1 ELSE

        READV SUBROUTINE.DEFINITION FROM OCFILE, SUBROUTINE.CALL.NAME, 1 ELSE

* update error table
            ERROR.SUBROUTINE = SUBROUTINE.CALL.NAME
            ERROR.METHOD = SUBROUTINE.CALL.KEYWORD
            ERROR.SOURCE.LINE = LINE.LOOP
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = 'External subroutine "':SUBROUTINE.CALL.NAME:'" does not exist'
            GOSUB ADD.ERROR

            RETURN

        END

    END

* if this line wraps read ahead and add in wrapped lines until it doesn't
* wrap any more
    SUBROUTINE.DEFINITION = TRIM(SUBROUTINE.DEFINITION, " ", "B")
    LAST.SUBROUTINE.CHAR = SUBROUTINE.DEFINITION [1]

    IF LAST.SUBROUTINE.CHAR = "," OR LAST.SUBROUTINE.CHAR = ";" THEN

        WRAP.PTR = 2
        NO.MORE.WRAPPING = @FALSE

        LOOP

            READV SUBROUTINE.LINE FROM OBPFILE, SUBROUTINE.CALL.NAME, WRAP.PTR THEN

                SUBROUTINE.DEFINITION := TRIM(SUBROUTINE.LINE, " ", "B")
                LAST.SUBROUTINE.CHAR = SUBROUTINE.DEFINITION [1]

                IF LAST.SUBROUTINE.CHAR <> "," AND LAST.SUBROUTINE.CHAR <> ";" THEN
                    NO.MORE.WRAPPING = @TRUE
                END

            END ELSE

                NO.MORE.WRAPPING = @TRUE

            END

        UNTIL NO.MORE.WRAPPING

            WRAP.PTR += 1

        REPEAT

    END

    IF UPCASE.CODE THEN
        SUBROUTINE.DEFINITION = UPCASE(SUBROUTINE.DEFINITION)
    END

* make sure the first line is a "subroutine" reference
    IF TRIM(SUBROUTINE.DEFINITION) [" ", 1, 1] <> "SUBROUTINE" THEN

* update error table
        ERROR.SUBROUTINE = SUBROUTINE.CALL.NAME
        ERROR.METHOD = SUBROUTINE.CALL.KEYWORD
        ERROR.SOURCE.LINE = LINE.LOOP
        ERROR.ECLIPSE.LINE = ""
        ERROR.DESC = '"':SUBROUTINE.CALL.NAME:'" is not an external subroutine'
        GOSUB ADD.ERROR

        RETURN

    END

* add the pseudo-handle to the handle list if it doesn't already exist
    LOCATE SUBROUTINE.CALL.KEYWORD IN HANDLE.LIST SETTING CALL.PTR ELSE

        HANDLE.COUNT += 1
        CALL.PTR = HANDLE.COUNT

        HANDLE.LIST<HANDLE.COUNT> = SUBROUTINE.CALL.KEYWORD
        HANDLE.VARIABLE.LIST<HANDLE.COUNT> = SUBROUTINE.CALL.KEYWORD
        HANDLE.OBJECT.LIST<HANDLE.COUNT> = SUBROUTINE.CALL.KEYWORD
        HANDLE.MULTI.THREADED.LIST<HANDLE.COUNT> = @FALSE

    END

* we'll add this subroutine call as if it was a method of the pseudo-
* object keyword
    METHOD.PTR = DCOUNT(HANDLE.METHOD.LIST<CALL.PTR>, @VM) + 1
    HANDLE.METHOD.LIST<CALL.PTR, METHOD.PTR> = SUBROUTINE.CALL.NAME
    HANDLE.METHOD.CALLED.LIST<CALL.PTR, METHOD.PTR> = @TRUE

* get parameter list of the called subroutine.  the parameter list may
* have optionals and byref / byvals in it.  build a list of only the
* variable names and also build the byval list
    PARAMETER.STRING = SUBROUTINE.DEFINITION ["(", 2, TO.THE.END]
    CALL.PARAMETER.LIST = SPLIT.METHOD.PARAMETERS (PARAMETER.STRING, "LIST")
    CALL.PARAMETER.COUNT = DCOUNT(CALL.PARAMETER.LIST, @AM)

* how many output parameters does this subroutine have?
    CALL.OUTPUT.PARAMETER.LIST = SPLIT.METHOD.PARAMETERS (PARAMETER.STRING, "OUT")

    IF CALL.OUTPUT.PARAMETER.LIST = "?" THEN
        CALL.OUTPUT.PARAMETER.COUNT = 0
    END ELSE
        CALL.OUTPUT.PARAMETER.COUNT = DCOUNT(CALL.OUTPUT.PARAMETER.LIST, @AM)
    END

    CALL.BYVAL.LIST = ""
    CALL.SPECIAL.LIST = ""
    CALL.VARIABLE.LIST = ""

    FOR PARAMETER.LOOP = 1 TO CALL.PARAMETER.COUNT

        THIS.PARAMETER = CALL.PARAMETER.LIST<PARAMETER.LOOP>

* remove any "optional" references
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        IF FIRST.PARM.WORD = OPTIONAL.KEYWORD THEN
            THIS.PARAMETER = TRIM(THIS.PARAMETER [" ", 2, TO.THE.END] ["=", 1, 1])
        END

* remove any "byval", "handle" or "byref" keywords and update the byval table
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        BEGIN CASE

* byval
            CASE FIRST.PARM.WORD = BYVAL.KEYWORD
                THIS.PARAMETER = TRIM(THIS.PARAMETER [" ", 2, TO.THE.END])
                CALL.BYVAL.LIST<PARAMETER.LOOP> = @TRUE
                CALL.SPECIAL.LIST<PARAMETER.LOOP> = @FALSE

* byval special
            CASE FIRST.PARM.WORD = BYVAL.SPECIAL.KEYWORD
                THIS.PARAMETER = TRIM(THIS.PARAMETER [" ", 2, TO.THE.END])
                CALL.BYVAL.LIST<PARAMETER.LOOP> = @TRUE
                CALL.SPECIAL.LIST<PARAMETER.LOOP> = @TRUE

* byref
            CASE FIRST.PARM.WORD = BYREF.KEYWORD
                THIS.PARAMETER = TRIM(THIS.PARAMETER [" ", 2, TO.THE.END])
                CALL.BYVAL.LIST<PARAMETER.LOOP> = @FALSE
                CALL.SPECIAL.LIST<PARAMETER.LOOP> = @FALSE

* anything else defaults to byref
            CASE 1
                CALL.BYVAL.LIST<PARAMETER.LOOP> = @FALSE
                CALL.SPECIAL.LIST<PARAMETER.LOOP> = @FALSE
 
        END CASE

        CALL.VARIABLE.LIST<PARAMETER.LOOP> = THIS.PARAMETER

    NEXT PARAMETER.LOOP

* update the parameter list in the usage table
    HANDLE.PARAMETER.LIST<CALL.PTR, METHOD.PTR> = LOWER(LOWER(CALL.VARIABLE.LIST))

    HANDLE.PARAMETER.BYVAL.LIST<CALL.PTR, METHOD.PTR> = LOWER(LOWER(CALL.BYVAL.LIST))
    HANDLE.PARAMETER.SPECIAL.LIST<CALL.PTR, METHOD.PTR> = LOWER(LOWER(CALL.SPECIAL.LIST))

    HANDLE.OUTPUT.PARAMETER.LIST<CALL.PTR, METHOD.PTR> = LOWER(LOWER(CALL.OUTPUT.PARAMETER.LIST))
    HANDLE.OUTPUT.COUNT.LIST<CALL.PTR, METHOD.PTR> = CALL.OUTPUT.PARAMETER.COUNT

* update other usage table values
    HANDLE.KEYWORD.LIST<CALL.PTR, METHOD.PTR> = KEY.WORD
    HANDLE.TYPE.LIST<CALL.PTR, METHOD.PTR> = "METHOD"
    HANDLE.DIMENSIONS.LIST<CALL.PTR> = ""

* convert.this.line uses raw.key.word to separate parameters before and after
* the keyword.  raw.key.word sometimes comes here with parameters attached
* to it if there's an open parenthesis there.  if so set raw.key.word to
* the part before the parenthesis so that convert.this.line can convert
* things properly
    RAW.KEY.WORD = RAW.KEY.WORD ["(", 1, 1]

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / brace expressions                 **
**************************************************************************
**************************************************************************

CONVERT.BRACES: **********************************************************
* convert all braces in program text                                     *
**************************************************************************
    BRACE.START.DATE = DATE()
    BRACE.START.TIME = TIME()

* start / else / end keywords and flags
    BEGIN.KEYWORD = ""
    KEYWORD.LINE = 0

    START.KEYWORD = ""
    ALT.START.KEYWORD = ""
    START.KEYWORD.LEN = 0
    ALT.START.KEYWORD.LEN = 0
    HIT.START = @FALSE
    START.LINE = 0

    ELSE.KEYWORD = ""
    ELSE.KEYWORD.LEN = 0
    HIT.ELSE = @FALSE
    ELSE.LINE = 0

    END.KEYWORD = ""
    END.KEYWORD.LEN = 0

* statements to execute before the end of the next brace
    END.EXECUTE = ""

* brace stack, one entry for each level deep we are
    BRACE.KEYWORD.STACK = ""
    BRACE.KEYWORD.LINE.STACK = ""

    BRACE.START.STACK = ""
    BRACE.ALT.START.STACK = ""
    BRACE.START.LINE.STACK = ""
    BRACE.HIT.START.STACK = ""

    BRACE.ELSE.STACK = ""
    BRACE.ELSE.LINE.STACK = ""
    BRACE.HIT.ELSE.STACK = ""

    BRACE.END.EXECUTE.STACK = ""
    BRACE.END.STACK = ""

    BRACE.LOOP.START.STACK = ""
    BRACE.LOOP.END.STACK = ""
    BRACE.LOOP.INDEX.STACK = ""
    BRACE.LOOP.INCREMENT.STACK = ""
    BRACE.LOOP.COMPLETE.STACK = ""

    BRACE.CODE.AFTER.START = ""
    BRACE.CODE.AFTER.ELSE = ""

    BRACE.DEPTH = 0

    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have labels
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            GOSUB CONVERT.LINE.BRACES

            IF BRACE.CONVERTED THEN
                PROGRAM.CODE<LINE.LOOP> = THIS.LINE
            END

        END

    NEXT LINE.LOOP

    BRACE.END.DATE = DATE()
    BRACE.END.TIME = TIME()
    BRACE.ELAPSED.TIME += TIME.ELAPSED (BRACE.START.DATE, BRACE.START.TIME)

    GOSUB CHECK.BRACE.STACK

    RETURN

CONVERT.LINE.BRACES: *****************************************************
* convert braces in a line                                               *
**************************************************************************

* look across clean line for any keywords that affect braces
    BRACE.CONVERTED = @FALSE
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    KEYWORD.COUNT = DCOUNT(THIS.LINE, " ")

* does code exist on the same line after hitting a "start" or "else" keyword
    CODE.AFTER.START = @FALSE
    CODE.AFTER.ELSE = @FALSE

    BRACE.DEPTH.BEFORE.LINE = BRACE.DEPTH

    FOR KEYWORD.LOOP = 1 TO KEYWORD.COUNT

        IF KEYWORD.LOOP = KEYWORD.COUNT THEN
            END.OF.LINE = @TRUE
        END ELSE
            END.OF.LINE = @FALSE
        END

        THIS.KEYWORD = THIS.LINE [" ", KEYWORD.LOOP, 1]

        IF THIS.KEYWORD <> "" OR END.OF.LINE THEN

            GOSUB PROCESS.KEYWORD.BRACES

            IF CONVERT.STRUCTURE.KEYWORDS THEN
                GOSUB PROCESS.BRACE.KEYWORDS
            END

            GOSUB CHECK.FOR.BRACE.END

            LOOP UNTIL NOT(POP.BRACE.STACK)
                GOSUB CHECK.FOR.BRACE.END
            REPEAT

        END

    NEXT KEYWORD.LOOP

    RETURN

PROCESS.BRACE.KEYWORDS: **************************************************
* process any "special" brace keywords.  brace keywords are strings that *
* convert into values derived from the current brace structure:          *
*                                                                        *
* $STRUCT.DEPTH$    a number from 0+ indicating the structure depth--    *
*                   how many structures deep we currently are            *
*                                                                        *
* if any of these keywords exist in this.keyword they are converted in   *
* this.keyword and this.line                                             *
**************************************************************************
    NEXT.BRACE.DEPTH = BRACE.DEPTH + 1
    PREV.BRACE.DEPTH = BRACE.DEPTH - 1

    IF PREV.BRACE.DEPTH < 0 THEN
        PREV.BRACE.DEPTH = 0
    END

    CONVERT.KEYWORD = THIS.KEYWORD

* convert brace depth keywords
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.DEPTH.KEYWORD, BRACE.DEPTH)
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.NEXT.DEPTH.KEYWORD, NEXT.BRACE.DEPTH)
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.PREV.DEPTH.KEYWORD, PREV.BRACE.DEPTH)

* convert structure keywords
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.START.KEYWORD, START.KEYWORD)
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.ALT.START.KEYWORD, ALT.START.KEYWORD)
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.ELSE.KEYWORD, ELSE.KEYWORD)
    CONVERT.KEYWORD = CHANGE(CONVERT.KEYWORD, STRUCTURE.END.KEYWORD, END.KEYWORD)

* if converting the special brace keywords changed this.keyword update
* this.line with the updated this.keyword
    IF THIS.KEYWORD <> CONVERT.KEYWORD THEN

        THIS.KEYWORD = CONVERT.KEYWORD

        THIS.LINE = THIS.LINE [" ", 1, KEYWORD.LOOP - 1]:" ":CONVERT.KEYWORD:" ":THIS.LINE [" ", KEYWORD.LOOP + 1, TO.THE.END]
        PROGRAM.CODE<LINE.LOOP> = THIS.LINE
        KEYWORD.COUNT = DCOUNT(THIS.LINE, " ")

    END

    RETURN

PROCESS.KEYWORD.BRACES: **************************************************
* process this.keyword and update brace variables and tables             *
**************************************************************************
    KEYWORD.LEN = LEN(THIS.KEYWORD)

* program line starting with the keyword and everything after that
    REST.OF.LINE = THIS.LINE [" ", KEYWORD.LOOP, TO.THE.END]:" "

* if this keyword could have a brace later add it to the brace stack
    THIS.START = ""
    THIS.ALT.START = ""
    THIS.ELSE = ""
    THIS.END = ""

* loop variables
    LOOP.START = ""
    LOOP.END = ""
    LOOP.INDEX = ""
    LOOP.INCREMENT = ""
    LOOP.COMPLETE = ""

    KEYWORD.LEN = LEN(THIS.KEYWORD)
    FIRST.CHAR = THIS.KEYWORD [1, 1]
    LAST.CHAR = THIS.KEYWORD [KEYWORD.LEN, 1]

    HIT.END = @FALSE

* if the keyword starting the brace structure is one of these keywords
* and we hit an opening brace that converts to a null the compiler should
* not generate an error.  otherwise we have an opening brace that isn't
* attached to anything and we should kick out an error
    NO.OPEN.BRACE.LIST = "LOOP,BEGIN,FOR,":WITH.KEYWORD

* the same with ending brace structures
    NO.END.BRACE.LIST = ""

* if we have code and we've already hit the start or alternate start then
* we have "code after start"
    IF HIT.START AND START.LINE = LINE.LOOP AND THIS.KEYWORD <> "" THEN
        CODE.AFTER.START = @TRUE
    END

* if we have code and we've already hit the else we have "code after end"
    IF HIT.ELSE AND ELSE.LINE = LINE.LOOP AND THIS.KEYWORD <> "" THEN
        CODE.AFTER.ELSE = @TRUE
    END

    BEGIN CASE

* keyword is null
         CASE THIS.KEYWORD = ""
             NULL


* keyword is the "start" expression for code to be executed at the end
* of the current statement
*       CASE THIS.KEYWORD = END.EXECUTE.START
*           GOSUB REPLACE.END.EXECUTE


* quotes

*     quote at beginning and end of keyword
        CASE NOT(IN.QUOTES) AND KEYWORD.LEN > 1 AND FIRST.CHAR = '"' AND LAST.CHAR = '"'
            NULL
        CASE NOT(IN.QUOTES) AND KEYWORD.LEN > 1 AND FIRST.CHAR = "'" AND LAST.CHAR = "'"
            NULL

*     ending quote
        CASE IN.QUOTES AND COUNT(THIS.KEYWORD,THIS.QUOTE) <> 0

            FOR CHAR.LOOP = 1 TO KEYWORD.LEN

                THIS.CHAR = THIS.KEYWORD [CHAR.LOOP, 1]

                BEGIN CASE
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR
                END CASE

            NEXT CHAR.LOOP

*     starting quote
        CASE NOT(IN.QUOTES) AND (COUNT(THIS.KEYWORD,"'") <> 0 OR COUNT(THIS.KEYWORD,'"') <> 0)

            FOR CHAR.LOOP = 1 TO KEYWORD.LEN

                THIS.CHAR = THIS.KEYWORD [CHAR.LOOP, 1]

                BEGIN CASE
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR
                END CASE

            NEXT CHAR.LOOP

* inside quotes
        CASE IN.QUOTES
            NULL


* keyword is the "start" expression for code to be executed at the end
* of the current statement
        CASE THIS.KEYWORD = END.EXECUTE.START
            GOSUB REPLACE.END.EXECUTE


* special case for "THEN IF".  a then-if shouldn't change anything
* as far as braces and things
        CASE THIS.LINE [" ", KEYWORD.LOOP - 1, 2] = "THEN IF"
            NULL
        CASE THIS.LINE [" ", KEYWORD.LOOP, 2] = "THEN IF"
            NULL


* expressions that may indicate a brace later:

*     if / then / else
        CASE THIS.KEYWORD = "IF"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     for / next / else.  note that we're loading up this.else assuming that
*     the for-loop has an else expression.  if we hit the else expression we'll
*     reset this.end
        CASE THIS.KEYWORD = "FOR"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            GOSUB SEPARATE.FOR.STATEMENT
            THIS.ELSE = "NEXT ":LOOP.INDEX:" ; IF ":LOOP.INDEX:" <> ":LOOP.COMPLETE:" THEN"
            THIS.END = "NEXT ":LOOP.INDEX
            GOSUB UPDATE.BRACE.STACK

*     loop / repeat
        CASE THIS.KEYWORD = "LOOP"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.END = "REPEAT"
            GOSUB UPDATE.BRACE.STACK

*     begin (case) / end case
        CASE THIS.KEYWORD = "BEGIN"
            THIS.END = "END CASE"
            GOSUB UPDATE.BRACE.STACK

*     with / end with
        CASE THIS.KEYWORD = WITH.KEYWORD
            THIS.END = END.WITH.KEYWORD
            GOSUB UPDATE.BRACE.STACK

*     open, opencheck, opendev then / end else / end
        CASE THIS.KEYWORD = "OPEN" OR THIS.KEYWORD = "OPENCHECK" OR THIS.KEYWORD = "OPENDEV"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     openpath, openseq, status then / end else / end
        CASE THIS.KEYWORD = "OPENPATH" OR THIS.KEYWORD = "OPENSEQ" OR THIS.KEYWORD = "STATUS"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     procread then / end else / end
        CASE THIS.KEYWORD = "PROCREAD"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     send then / end else / end
        CASE THIS.KEYWORD = "SEND"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     read, readv, matread, delete / then / end else / end
        CASE THIS.KEYWORD = "READ" OR THIS.KEYWORD = "READV" OR THIS.KEYWORD = "MATREAD" OR THIS.KEYWORD = "DELETE"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     readu, readvu, matreadu, deleteu / then / end else / end
        CASE THIS.KEYWORD = "READU" OR THIS.KEYWORD = "READVU" OR THIS.KEYWORD = "MATREADU" OR THIS.KEYWORD = "DELETEU"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     write, writev, matwrite, delete / then / end else / end
        CASE THIS.KEYWORD = "WRITE" OR THIS.KEYWORD = "WRITEV" OR THIS.KEYWORD = "MATWRITE"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     writeu, writevu, matwriteu, deleteu / then / end else / end
        CASE THIS.KEYWORD = "WRITEU" OR THIS.KEYWORD = "WRITEVU" OR THIS.KEYWORD = "MATWRITEU"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     readblk, readseq, seek then / end else / end
        CASE THIS.KEYWORD = "READBLK" OR THIS.KEYWORD = "READSEQ" OR THIS.KEYWORD = "SEEK"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     writeblk, writeseq, writeseqf, weof then / end else / end
        CASE THIS.KEYWORD = "WRITEBLK" OR THIS.KEYWORD = "WRITESEQ" OR THIS.KEYWORD = "WRITESEQF" OR THIS.KEYWORD = "WEOF"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*    readt, writet, rewind then / end else / end
        CASE THIS.KEYWORD = "READT" OR THIS.KEYWORD = "WRITET" OR THIS.KEYWORD = "REWIND"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     lock then / end else / end
        CASE THIS.KEYWORD = "LOCK"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     readnext then / end else / end

*         special case for the "LOOP WHILE READNEXT" expression.  for
*         this expression we've already started things with the "LOOP"
*         but we don't want the "READNEXT" to trigger another.  if the
*         current keyword is "LOOP" and we're on the same line as the
*         "LOOP" ignore this "READNEXT"
        CASE THIS.KEYWORD = "READNEXT" AND BEGIN.KEYWORD = "LOOP" AND LINE.LOOP = KEYWORD.LINE
                NULL

        CASE THIS.KEYWORD = "READNEXT"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     getlist, readlist then / end else / end
        CASE THIS.KEYWORD = "GETLIST" OR THIS.KEYWORD = "READLIST"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     inputif, inputdp then / end else / end
        CASE THIS.KEYWORD = "INPUTIF" OR THIS.KEYWORD = "INPUTDP"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     locate, find, findstr then / end else / end
        CASE THIS.KEYWORD = "LOCATE" OR THIS.KEYWORD = "FIND" OR THIS.KEYWORD = "FINDSTR"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     create, flush, nobuf then / end else / end
        CASE THIS.KEYWORD = "CREATE" OR THIS.KEYWORD = "FLUSH" OR THIS.KEYWORD = "NOBUF"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     bscan then / end else / end
        CASE THIS.KEYWORD = "BSCAN"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     ttyctl, ttyget, ttyset then / end else / end
        CASE THIS.KEYWORD = "TTYCTL" OR THIS.KEYWORD = "TTYGET" OR THIS.KEYWORD = "TTYSET"
            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     commit, rollback, start then / end else / end
        CASE THIS.KEYWORD = "COMMIT" OR THIS.KEYWORD = "ROLLBACK" OR THIS.KEYWORD = "START"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK

*     get then / end else / end
        CASE THIS.KEYWORD = "GET"

            IF KEYWORD.LOOP > 1 THEN
                GOSUB RESTORE.PRE.LINE.BRACE.STACK
            END

            THIS.START = "THEN"
            THIS.ALT.START = "ELSE"
            THIS.ELSE = "END ELSE"
            THIS.END = "END"
            GOSUB UPDATE.BRACE.STACK


* expressions that close a structure without being a brace:

*     special case to close a structure.  we have an "else" in the middle of a
*     line that's not part of an "end else" and we're looking for an 
*     "end else" as our "else"
        CASE KEYWORD.LOOP > 1 AND NOT(END.OF.LINE) AND HIT.START AND ELSE.KEYWORD = "END ELSE" AND THIS.KEYWORD = "ELSE" AND THIS.LINE [" ", KEYWORD.LOOP - 1, 1] <> "END"
            GOSUB SET.HIT.ELSE

*     hit the start expression
        CASE START.KEYWORD <> "" AND REST.OF.LINE [1, START.KEYWORD.LEN + 1] = START.KEYWORD:" "
            GOSUB SET.HIT.START

*     hit the alternate start expression.  treat it as hitting
*     the start expression AND the else expression
        CASE ALT.START.KEYWORD <> "" AND REST.OF.LINE [1, ALT.START.KEYWORD.LEN + 1] = ALT.START.KEYWORD:" "
            GOSUB SET.HIT.START
            GOSUB SET.HIT.ELSE

*     hit the else expression
        CASE ELSE.KEYWORD <> "" AND REST.OF.LINE [1, ELSE.KEYWORD.LEN + 1] = ELSE.KEYWORD:" "
            GOSUB SET.HIT.ELSE

*     hit the "end" keyword expression
        CASE END.KEYWORD <> "" AND REST.OF.LINE [1, END.KEYWORD.LEN + 1] = END.KEYWORD:" "
            HIT.END = @TRUE
            GOSUB ADD.END.EXECUTE

* braces:

*     open brace that isn't part of a program structure
        CASE THIS.KEYWORD = OPEN.BRACE AND START.KEYWORD = "" AND INDEX(NO.OPEN.BRACE.LIST, THIS.START, 1) = 0
            ERROR.METHOD = METHOD
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = "Open brace invalid"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

*     open brace
        CASE THIS.KEYWORD = OPEN.BRACE
            GOSUB SET.HIT.START
            REPLACE.BRACE = START.KEYWORD
            GOSUB REPLACE.BRACE


*     else brace without an opening brace
        CASE THIS.KEYWORD = ELSE.BRACE AND ELSE.KEYWORD = ""
            ERROR.METHOD = METHOD
            OBJECT.ERROR.DESC = "Else brace without opening brace"
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

*     else brace and we haven't hit a starting brace yet and we have an
*     alternate start defined.  this will happen with read statements where we
*     have an else clause but no then
        CASE THIS.KEYWORD = ELSE.BRACE AND NOT(HIT.START) AND ALT.START.KEYWORD <> ""
            GOSUB SET.HIT.START
            REPLACE.BRACE = ALT.START.KEYWORD
            GOSUB REPLACE.BRACE

*     else brace for a "for" loop, special case:
        CASE THIS.KEYWORD = ELSE.BRACE AND BEGIN.KEYWORD = "FOR"
            GOSUB SET.HIT.ELSE
            REPLACE.BRACE = ELSE.KEYWORD
            GOSUB REPLACE.BRACE
            END.KEYWORD = "END"
            BRACE.END.STACK<BRACE.DEPTH> = END.KEYWORD

*     else brace
        CASE THIS.KEYWORD = ELSE.BRACE
            GOSUB SET.HIT.ELSE
            REPLACE.BRACE = ELSE.KEYWORD
            GOSUB REPLACE.BRACE


*     end brace without an opening brace
        CASE THIS.KEYWORD = CLOSE.BRACE AND END.KEYWORD = ""
            ERROR.METHOD = METHOD
            OBJECT.ERROR.DESC = "Close brace without opening brace ":START.KEYWORD
            OBJECT.ERROR.LINE = LINE.LOOP
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR

*     end brace
        CASE THIS.KEYWORD = CLOSE.BRACE
            REPLACE.BRACE = END.KEYWORD
            GOSUB REPLACE.BRACE
            GOSUB ADD.END.EXECUTE
            HIT.END = @TRUE


    END CASE

    RETURN

SEPARATE.FOR.STATEMENT: **************************************************
* separate a "for" statement into loop.start, loop.end, loop.index,      *
* loop.increment                                                         *
**************************************************************************
    THIS.FOR.LINE = THIS.LINE [" ", KEYWORD.LOOP, TO.THE.END]
    THIS.FOR.LINE = SPLIT.CODE.LINE(THIS.FOR.LINE)

    LOCATE "FOR" IN THIS.FOR.LINE SETTING LOOP.START.PTR ELSE
        RETURN
    END

    LOOP.START = ""
    LOOP.END = ""
    LOOP.INDEX = ""
    LOOP.INCREMENT = ""
    LOOP.COMPLETE = ""

* extract the index variable.  this will only be one word
    LOOP.INDEX = THIS.FOR.LINE<LOOP.START.PTR + 1>

* extract the starting expression.  this could be multiple words
    LOCATE "=" IN THIS.FOR.LINE, LOOP.START.PTR SETTING LOOP.EQUALS.PTR ELSE
        RETURN
    END

    LOCATE "TO" IN THIS.FOR.LINE,LOOP.START.PTR SETTING LOOP.TO.PTR ELSE
        RETURN
    END

    LOOP.START = THIS.FOR.LINE [@AM, LOOP.EQUALS.PTR + 1, LOOP.TO.PTR - LOOP.EQUALS.PTR - 1]

* find the "step", "while" and "until" expressions if there are any
    LOCATE "STEP" IN THIS.FOR.LINE, LOOP.TO.PTR SETTING STEP.PTR ELSE
        STEP.PTR = 0
    END

    LOCATE "WHILE" IN THIS.FOR.LINE, LOOP.TO.PTR SETTING WHILE.PTR ELSE
        WHILE.PTR = 0
    END

    LOCATE "UNTIL" IN THIS.FOR.LINE, LOOP.TO.PTR SETTING UNTIL.PTR ELSE
        UNTIL.PTR = 0
    END

* we may also have an open brace at the end
    LOCATE "{" IN THIS.FOR.LINE, LOOP.TO.PTR SETTING BRACE.PTR ELSE
        BRACE.PTR = 0
    END

* set for.end.of.line.  this will be the end of the line when it comes to
* extracting components of the "for" statement, not necessarily the "real"
* end of the line
    IF BRACE.PTR <> 0 THEN
        FOR.END.OF.LINE = BRACE.PTR - 1
    END ELSE
        FOR.END.OF.LINE = DCOUNT(THIS.FOR.LINE, @AM) + 1
    END

    BEGIN CASE

* no "step" expression:

*     if we don't have any of the keywords (step, while, until) set the
*     increment to the default (1) and find the loop's "end" expression
        CASE STEP.PTR = 0 AND WHILE.PTR = 0 AND UNTIL.PTR = 0
            LOOP.INCREMENT = 1
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, FOR.END.OF.LINE - LOOP.TO.PTR - 1]

*     if we have no "step" but we have a "while" use the default increment
*     (1) and extract the loop's "end" expression
        CASE STEP.PTR = 0 AND WHILE.PTR <> 0
            LOOP.INCREMENT = 1
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, WHILE.PTR - LOOP.TO.PTR - 1]

*     we have no "step" but we have an "until"
        CASE STEP.PTR = 0 AND UNTIL.PTR <> 0
            LOOP.INCREMENT = 1
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, UNTIL.PTR - LOOP.TO.PTR - 1]


* we have a "step" expression:

*     we have a "step" expression but no "while" or "until"
        CASE STEP.PTR <> 0 AND WHILE.PTR = 0 AND UNTIL.PTR = 0
            LOOP.INCREMENT = THIS.FOR.LINE [@AM, STEP.PTR + 1, FOR.END.OF.LINE - STEP.PTR - 1]
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, STEP.PTR - LOOP.TO.PTR - 1]

*     we have a "step" expression and a "while"
        CASE STEP.PTR <> 0 AND WHILE.PTR <> 0
            LOOP.INCREMENT = THIS.FOR.LINE [@AM, STEP.PTR + 1, WHILE.PTR - STEP.PTR - 1]
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, STEP.PTR - LOOP.TO.PTR - 1]
 
*     we have a "step" expression and an "until"
        CASE STEP.PTR <> 0 AND UNTIL.PTR <> 0
            LOOP.INCREMENT = THIS.FOR.LINE [@AM, STEP.PTR + 1, UNTIL.PTR - STEP.PTR - 1]
            LOOP.END = THIS.FOR.LINE [@AM, LOOP.TO.PTR + 1, STEP.PTR - LOOP.TO.PTR - 1]

    END CASE

* set the "loop.complete" expression.  this will be the value of the loop
* index if it ran the full course of the loop without hitting the "while"
* or "until" conditions
    LOOP.COMPLETE = LOOP.END:" + (":LOOP.INCREMENT:")"

* change all ams to spaces
    LOOP.INDEX = CHANGE(LOOP.INDEX, @AM, " ")
    LOOP.START = CHANGE(LOOP.START, @AM, " ")
    LOOP.END = CHANGE(LOOP.END, @AM, " ")
    LOOP.INCREMENT = CHANGE(LOOP.INCREMENT, @AM, " ")
    LOOP.COMPLETE = CHANGE(LOOP.COMPLETE, @AM, " ")

    RETURN

CHECK.FOR.BRACE.END: *****************************************************
* check for the end of the current brace level due to hitting a keyword  *
* closing a structure or the end of a code line.  updates brace tables   *                          
**************************************************************************
    POP.BRACE.STACK = @FALSE

* handle single-line expressins
    BEGIN CASE

* if there's nothing in the brace stack there's nothing to pop
        CASE BRACE.DEPTH = 0
            NULL

* we hit an "end" keyword or brace
        CASE HIT.END
            POP.BRACE.STACK = @TRUE

* if:
*    - we're at the end of the line
*    - we're on the same line as the keyword that starts the structure
*    - we have not hit the start or alternate start expressions
* then we have a line with an optional then / end else / end clause and
* we should dump it from our tables

* note:  the LOOP keyword is exempt from this since "LOOP" can be on a
* line all by itself
        CASE END.OF.LINE AND KEYWORD.LINE = LINE.LOOP AND NOT(HIT.START) AND BEGIN.KEYWORD = "LOOP"
            NULL

        CASE END.OF.LINE AND KEYWORD.LINE = LINE.LOOP AND NOT(HIT.START)
            POP.BRACE.STACK = @TRUE

* if:
*    - we're at the end of the line
*    - we hit the start expression
*    - we're still on the same line as the start expression
*    - we have code after the start expression
*    - we have not hit an else expression
* then we have a single-line expression and we can dump it from our tables
        CASE END.OF.LINE AND HIT.START AND START.LINE = LINE.LOOP AND CODE.AFTER.START AND NOT(HIT.ELSE)
            POP.BRACE.STACK = @TRUE

* if:
*    - we're at the end of the line
*    - we hit the else expression
*    - we're still on the same line as the else expression
*    - we have code after the else expression
* then we have a single-line "else" expression and we can dump it from
* our tables
        CASE END.OF.LINE AND HIT.ELSE AND ELSE.LINE = LINE.LOOP AND CODE.AFTER.ELSE
            POP.BRACE.STACK = @TRUE

    END CASE

    IF POP.BRACE.STACK THEN
        GOSUB ADD.END.EXECUTE
        GOSUB POP.BRACE.STACK
    END

    RETURN

UPDATE.BRACE.STACK: ******************************************************
* update brace stack with this.start, this.else and this.end             *
**************************************************************************
    BEGIN.KEYWORD = THIS.KEYWORD
    KEYWORD.LINE = LINE.LOOP

    START.LINE = 0
    ELSE.LINE = 0

    BRACE.DEPTH += 1

* these variables are part of the new stack depth
    BRACE.KEYWORD.STACK<BRACE.DEPTH> = BEGIN.KEYWORD
    BRACE.KEYWORD.LINE.STACK<BRACE.DEPTH> = KEYWORD.LINE

    BRACE.START.STACK<BRACE.DEPTH> = THIS.START
    BRACE.ALT.START.STACK<BRACE.DEPTH> = THIS.ALT.START
    BRACE.START.LINE.STACK<BRACE.DEPTH> = START.LINE
    BRACE.HIT.START.STACK<BRACE.DEPTH> = @FALSE

    BRACE.ELSE.STACK<BRACE.DEPTH> = THIS.ELSE
    BRACE.ELSE.LINE.STACK<BRACE.DEPTH> = ELSE.LINE
    BRACE.HIT.ELSE.STACK<BRACE.DEPTH> = @FALSE

    BRACE.END.STACK<BRACE.DEPTH> = THIS.END

* loop variables
    BRACE.LOOP.START.STACK<BRACE.DEPTH> = LOOP.START
    BRACE.LOOP.END.STACK<BRACE.DEPTH> = LOOP.END
    BRACE.LOOP.INDEX.STACK<BRACE.DEPTH> = LOOP.INDEX
    BRACE.LOOP.INCREMENT.STACK<BRACE.DEPTH> = LOOP.INCREMENT

* these variables are part of the previous stack depth
    IF BRACE.DEPTH > 1 THEN
        BRACE.END.EXECUTE.STACK<BRACE.DEPTH - 1> = END.EXECUTE
        BRACE.CODE.AFTER.START<BRACE.DEPTH - 1> = CODE.AFTER.START
        BRACE.CODE.AFTER.ELSE<BRACE.DEPTH - 1> = CODE.AFTER.ELSE
    END

    START.KEYWORD = THIS.START
    ALT.START.KEYWORD = THIS.ALT.START
    ELSE.KEYWORD = THIS.ELSE
    END.KEYWORD = THIS.END

    HIT.START = @FALSE
    HIT.ELSE = @FALSE

    CODE.AFTER.START = @FALSE
    CODE.AFTER.ELSE = @FALSE

    END.EXECUTE = ""

    START.KEYWORD.LEN = LEN(START.KEYWORD)
    ALT.START.KEYWORD.LEN = LEN(ALT.START.KEYWORD)
    ELSE.KEYWORD.LEN = LEN(ELSE.KEYWORD)
    END.KEYWORD.LEN = LEN(END.KEYWORD)

    RETURN

RESTORE.PRE.LINE.BRACE.STACK: ********************************************
* reset the brace stack to what it was before looping through compound   *
* lines in the current line                                              *
**************************************************************************
    STACK.POPS = BRACE.DEPTH - BRACE.DEPTH.BEFORE.LINE

    IF STACK.POPS > 0 THEN

        FOR STACK.POP.LOOP = 1 TO STACK.POPS
            GOSUB POP.BRACE.STACK
        NEXT STACK.POP.LOOP

    END

    RETURN

POP.BRACE.STACK: *********************************************************
* pop the brace stack, removing the most recent entry                    *
**************************************************************************
    IF BRACE.DEPTH > 0 THEN

        DEL BRACE.KEYWORD.STACK<BRACE.DEPTH>
        DEL BRACE.KEYWORD.LINE.STACK<BRACE.DEPTH>

        DEL BRACE.START.STACK<BRACE.DEPTH>
        DEL BRACE.ALT.START.STACK<BRACE.DEPTH>
        DEL BRACE.START.LINE.STACK<BRACE.DEPTH>
        DEL BRACE.HIT.START.STACK<BRACE.DEPTH>

        DEL BRACE.ELSE.STACK<BRACE.DEPTH>
        DEL BRACE.ELSE.LINE.STACK<BRACE.DEPTH>
        DEL BRACE.HIT.ELSE.STACK<BRACE.DEPTH>

        DEL BRACE.END.STACK<BRACE.DEPTH>
        DEL BRACE.END.EXECUTE.STACK<BRACE.DEPTH>

        DEL BRACE.LOOP.START.STACK<BRACE.DEPTH>
        DEL BRACE.LOOP.END.STACK<BRACE.DEPTH>
        DEL BRACE.LOOP.INDEX.STACK<BRACE.DEPTH>
        DEL BRACE.LOOP.INCREMENT.STACK<BRACE.DEPTH>

        DEL BRACE.CODE.AFTER.START<BRACE.DEPTH>
        DEL BRACE.CODE.AFTER.ELSE<BRACE.DEPTH>

        BRACE.DEPTH -= 1

    END ELSE

        PRINT "Closing brace without opening brace in line ":LINE.LOOP

    END

    KEYWORD.LINE = ""

    START.KEYWORD = ""
    ALT.START.KEYWORD = ""
    START.LINE = ""
    HIT.START = @FALSE

    ELSE.KEYWORD = ""
    ELSE.LINE = ""
    HIT.ELSE = @FALSE

    END.KEYWORD = ""
    HIT.END = @FALSE

    END.EXECUTE = ""

    CODE.AFTER.START = @FALSE
    CODE.AFTER.ELSE = @FALSE

    IF BRACE.DEPTH > 0 THEN

        BEGIN.KEYWORD = BRACE.KEYWORD.STACK<BRACE.DEPTH>
        KEYWORD.LINE = BRACE.KEYWORD.LINE.STACK<BRACE.DEPTH>

        START.KEYWORD = BRACE.START.STACK<BRACE.DEPTH>
        ALT.START.KEYWORD = BRACE.ALT.START.STACK<BRACE.DEPTH>
        START.LINE = BRACE.START.LINE.STACK<BRACE.DEPTH>
        HIT.START = BRACE.HIT.START.STACK<BRACE.DEPTH>

        ELSE.KEYWORD = BRACE.ELSE.STACK<BRACE.DEPTH>
        ELSE.LINE = BRACE.ELSE.LINE.STACK<BRACE.DEPTH>
        HIT.ELSE = BRACE.HIT.ELSE.STACK<BRACE.DEPTH>

        END.KEYWORD = BRACE.END.STACK<BRACE.DEPTH>
        END.EXECUTE = BRACE.END.EXECUTE.STACK<BRACE.DEPTH>

        CODE.AFTER.START = BRACE.CODE.AFTER.START<BRACE.DEPTH>
        CODE.AFTER.ELSE = BRACE.CODE.AFTER.ELSE<BRACE.DEPTH>

        LOOP.START = BRACE.LOOP.START.STACK<BRACE.DEPTH>
        LOOP.END = BRACE.LOOP.END.STACK<BRACE.DEPTH>
        LOOP.INDEX = BRACE.LOOP.INDEX.STACK<BRACE.DEPTH>
        LOOP.INCREMENT = BRACE.LOOP.INCREMENT.STACK<BRACE.DEPTH>

    END

    START.KEYWORD.LEN = LEN(START.KEYWORD)
    ALT.START.KEYWORD.LEN = LEN(ALT.START.KEYWORD)
    ELSE.KEYWORD.LEN = LEN(ELSE.KEYWORD)
    END.KEYWORD.LEN = LEN(END.KEYWORD)

    RETURN

SET.HIT.START: ***********************************************************
* set a flag for this brace depth denoting that we hit the start         *
* expression                                                             *
**************************************************************************
    IF NOT(HIT.START) THEN
        HIT.START = @TRUE
        BRACE.HIT.START.STACK<BRACE.DEPTH> = HIT.START
        GOSUB SET.START.LINE
    END

    RETURN

SET.HIT.ELSE: ************************************************************
* set a flag for this brace depth denoting that we hit the else          *
* expression                                                             *
**************************************************************************
    GOSUB SET.HIT.START

    IF NOT(HIT.ELSE) THEN
        HIT.ELSE = @TRUE
        BRACE.HIT.ELSE.STACK<BRACE.DEPTH> = HIT.ELSE
        GOSUB SET.ELSE.LINE
    END

    RETURN

SET.START.LINE: **********************************************************
* set start line for the current brace depth                             *
**************************************************************************
    START.LINE = LINE.LOOP
    BRACE.START.LINE.STACK<BRACE.DEPTH> = START.LINE

    RETURN

SET.ELSE.LINE: ***********************************************************
* set else line for the current brace depth                              *
**************************************************************************
    ELSE.LINE = LINE.LOOP
    BRACE.ELSE.LINE.STACK<BRACE.DEPTH> = ELSE.LINE

    RETURN

REPLACE.BRACE: ***********************************************************
* replace a brace expression with replace.brace                          *
**************************************************************************
    BRACE.CONVERTED = @TRUE

    IF REPLACE.BRACE <> "" THEN
        THIS.LINE = THIS.LINE [" ", 1, KEYWORD.LOOP - 1]:" ":REPLACE.BRACE:" ":THIS.LINE [" ", KEYWORD.LOOP + 1, TO.THE.END]
    END ELSE
        THIS.LINE = THIS.LINE [" ", 1, KEYWORD.LOOP - 1]:" ":THIS.LINE [" ", KEYWORD.LOOP + 1, TO.THE.END]
    END

    IF REPLACE.BRACE <> "" THEN
        KEYWORD.LOOP += DCOUNT(REPLACE.BRACE, " ") - 1
    END

    RETURN

REPLACE.END.EXECUTE: *****************************************************
* pull the "end execute" expression out of a program line and save it    *
* for processing later                                                   *
**************************************************************************

* find "end" expression
    END.KEYWORD.PTR = 0

    FOR SEARCH.LOOP = KEYWORD.LOOP + 1 TO KEYWORD.COUNT UNTIL END.KEYWORD.PTR <> 0

        IF THIS.LINE [" ", SEARCH.LOOP,1] = END.EXECUTE.END THEN
            END.KEYWORD.PTR = SEARCH.LOOP
        END

    NEXT SEARCH.LOOP

    IF END.KEYWORD.PTR = 0 THEN
        END.KEYWORD.PTR = KEYWORD.COUNT
    END

* remove "execute at end" expression and add it to the "execute at end"
* for the next program structure.  we don't want to add it to the "execute at end"
* expression for the current program structure as we'll hit an "open brace"
* later.  we want this to be in the "execute end" for that structure (the next
* one), not the current one.  so, add it to next.end.execute.  when the
* next structure starts next.end.execute will be copied to end.execute and the
* "execute at end" code will be inserted before that structure ends
    THIS.END.EXECUTE = THIS.LINE [" ", KEYWORD.LOOP + 1, END.KEYWORD.PTR - KEYWORD.LOOP - 1]
    THIS.LINE = THIS.LINE [" ", 1, KEYWORD.LOOP - 1]:" ":THIS.LINE [" ", END.KEYWORD.PTR + 1, TO.THE.END]

* if we already have something in end.execute for some reason (?) add a
* semicolon and then our new expression(s)
    IF END.EXECUTE <> "" THEN
        END.EXECUTE := " ; "
    END
    END.EXECUTE := THIS.END.EXECUTE

* reset keyword count for this line and back up keyword.loop to process
* the next keyword
    KEYWORD.COUNT = DCOUNT(THIS.LINE, " ")
    KEYWORD.LOOP -= 1

    BRACE.CONVERTED = @TRUE

    RETURN

ADD.END.EXECUTE: *********************************************************
* if there's an "execute at end" expression for the structure that is    *
* just ending insert it before the ending keyword                        *
**************************************************************************
    IF END.EXECUTE = "" THEN
        RETURN
    END

* insert the "at end" expression before the ending keyword followed by a
* semicolon
    END.EXECUTE.INDENT = "    "
    THIS.LINE = THIS.LINE [" ", 1, KEYWORD.LOOP - 1]:" ":END.EXECUTE.INDENT:END.EXECUTE:" ; ":THIS.LINE [" ", KEYWORD.LOOP, TO.THE.END]

* we've inserted some number of spaces into this.line.  advance keyword.loop
* so that we don't process the inserted text and reprocess the end keyword
    KEYWORD.LOOP += DCOUNT(END.EXECUTE," ") + 2

    END.EXECUTE = ""
    BRACE.CONVERTED = @TRUE

    RETURN

CHECK.BRACE.STACK: *******************************************************
* check to make sure that the brace stack is empty.  at the end of each  *
* program or method the brace stack should be empty.  if it's not then   *
* we didn't close all of our structures so kick out an error             *
**************************************************************************
    IF BRACE.DEPTH = 0 THEN
        RETURN
    END

    IF NOT(SHOW.OPEN.STRUCTURE.ERRORS) THEN
        RETURN
    END

* we haven't closed all of our structures.  kick back an error
    ERROR.METHOD = METHOD
    OBJECT.ERROR.DESC = BRACE.DEPTH:" structures remain open at the end of the"

    IF COMPILE.OBJECT THEN
        OBJECT.ERROR.DESC := " method"
    END ELSE
        OBJECT.ERROR.DESC := " program"
    END

    OBJECT.ERROR.LINE = LINE.LOOP - 1
    LOOP UNTIL TRIM(PROGRAM.CODE<OBJECT.ERROR.LINE>) <> "" OR OBJECT.ERROR.LINE = 1
        OBJECT.ERROR.LINE -= 1
    REPEAT

    SHOW.REFERENCE = @FALSE

    GOSUB PRINT.OBJECT.ERROR

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / debugging shortcuts               **
**************************************************************************
**************************************************************************

CONVERT.DEBUG.SHORTCUTS: *************************************************
* convert debugging shortcuts to ud.debug calls.  the code that the      *
* debug keywords are converted into comes from the ud.control            *
* compile.setup record.  routine.has.debug.code is set true if any of    *
* these debugging shortcuts are converted:                               *
*                                                                        *
* DebugOnText               no longer used.  was used to turn debug text *
*                           on via a flag but that turned out to be an   *
*                           annoyance rather than a feature.             *
* DebugOffText              no longer used.  used to turn debug text     *
*                           off                                          *
*                                                                        *
* DebugSendText             used to convert a "<" debug command to a     *
*                           ud.debug call.   %PARAMETERS% are convereted *
*                           to the debugging parameters                  *
* DebugOnSendText           no longer used.  used to turn on the debug   *
*                           flag (no longer used) and call ud.debug.     *
*                           now it's the same as DebugSendText           *
*                                                                        *
* DebugClearText            clears the debugging window for the "#"      *
*                           debug command                                *
*                                                                        *
* DebugVariableText         beginning of a ud.debug.call when variables  *
*                           or literals are displayed with "<<"          *
* DebugVariableLiteralText  code added to DebugVariableText for each     *
*                           literal parameter in an "<<" debug           *
*                           statement. %VALUE% is converted to the       *
*                           literal value                                *
* DebugVariableValueText    code added to DebugVariableText for each     *
*                           variable parameter in an "<<" debug          *
*                           statement.  %NAME% is converted into the     *
*                           variable name and %VALUE% is converted into  *
*                           the variable's value                         *
**************************************************************************
    CONVERTED.FOR.DEBUG = @TRUE    

* it's possible that some debugging keywords may contain other debugging
* keywords.  we'll check each keyword and only keep the one with the longest
* keyword
    GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
    FOUND.LENGTH = 0

    IF KEY.WORD [1, DEBUG.SEND.ARRAY.KEYWORD.LEN] = DEBUG.SEND.ARRAY.KEYWORD THEN
        IF DEBUG.SEND.ARRAY.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.SEND.ARRAY = @TRUE
            FOUND.LENGTH = DEBUG.SEND.ARRAY.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.CLEAR.AND.MESSAGE.KEYWORD.LEN] = DEBUG.CLEAR.AND.MESSAGE.KEYWORD THEN
        IF DEBUG.CLEAR.AND.MESSAGE.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.CLEAR.AND.MESSAGE = @TRUE
            FOUND.LENGTH = DEBUG.CLEAR.AND.MESSAGE.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.SEND.VARIABLE.KEYWORD.LEN] = DEBUG.SEND.VARIABLE.KEYWORD THEN
        IF DEBUG.SEND.VARIABLE.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.SEND.VARIABLE = @TRUE
            FOUND.LENGTH = DEBUG.SEND.VARIABLE.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.SEND.TEXT.KEYWORD.LEN] = DEBUG.SEND.TEXT.KEYWORD THEN
        IF DEBUG.SEND.TEXT.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.SEND.TEXT = @TRUE
            FOUND.LENGTH = DEBUG.SEND.TEXT.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.SET.SOURCE.KEYWORD.LEN] = DEBUG.SET.SOURCE.KEYWORD THEN
        IF DEBUG.SET.SOURCE.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.SET.SOURCE = @TRUE
            FOUND.LENGTH = DEBUG.SET.SOURCE.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.CLEAR.SOURCE.KEYWORD.LEN] = DEBUG.CLEAR.SOURCE.KEYWORD THEN
        IF DEBUG.CLEAR.SOURCE.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.CLEAR.SOURCE = @TRUE
            FOUND.LENGTH = DEBUG.CLEAR.SOURCE.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.CLEAR.KEYWORD.LEN] = DEBUG.CLEAR.KEYWORD THEN
        IF DEBUG.CLEAR.SOURCE.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.CLEAR = @TRUE
            FOUND.LENGTH = DEBUG.CLEAR.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    IF KEY.WORD [1, DEBUG.IDENTIFY.METHOD.KEYWORD.LEN] = DEBUG.IDENTIFY.METHOD.KEYWORD THEN
        IF DEBUG.IDENTIFY.METHOD.KEYWORD.LEN > FOUND.LENGTH THEN
            GOSUB CLEAR.DEBUG.KEYWORD.FLAGS
            FOUND.IDENTIFY.KEYWORD = @TRUE
            FOUND.LENGTH = DEBUG.IDENTIFY.METHOD.KEYWORD.LEN
            ROUTINE.HAS.DEBUG.CODE = @TRUE
        END
    END

    BEGIN CASE


* send text to the "view debug" screen:

*     send an array to a view-only editor window via the "view debug"
*     window
        CASE FOUND.SEND.ARRAY

            DEBUG.PARAMETER.LIST = KEY.WORD [DEBUG.SEND.ARRAY.KEYWORD.LEN + 1, TO.THE.END]:" ":CLEAN.LINE [" ", 2, TO.THE.END]
            GOSUB CONDITION.DEBUG.PARAMETER.LIST

            CLEAN.LINE = CHANGE(DEBUG.SEND.MESSAGE.TEXT, "%PARAMETERS%", DEBUG.PARAMETER.LIST)

*     clear debug messages and send a message to the "view debug" window
        CASE FOUND.CLEAR.AND.MESSAGE

            DEBUG.PARAMETER.LIST = KEY.WORD [DEBUG.CLEAR.AND.MESSAGE.KEYWORD.LEN + 1, TO.THE.END]:" ":CLEAN.LINE [" ", 2, TO.THE.END]
            IF SCAN.DEBUG.SPACES THEN
                DEBUG.PARAMETER.LIST = CONVERT.LITERAL.SPACES (DEBUG.PARAMETER.LIST)
            END

            CLEAN.LINE = CHANGE(DEBUG.CLEAR.SEND.TEXT, "%PARAMETERS%", DEBUG.PARAMETER.LIST)


*     send output to the debugging window.  anything that's not a literal string is
*     assumed to be a variable name and will be sent to the debugging window prefixed
*     with a literal string identifying the variable.  multiple variables may be delimited
*     with commas
        CASE FOUND.SEND.VARIABLE

            GOSUB SEND.VARIABLE.LIST.TO.DEBUG


*     send text output to the debugging window.:
        CASE FOUND.SEND.TEXT

            DEBUG.PARAMETER.LIST = KEY.WORD [DEBUG.SEND.TEXT.KEYWORD.LEN + 1, TO.THE.END]:" ":CLEAN.LINE [" ", 2, TO.THE.END]

            GOSUB CONDITION.DEBUG.PARAMETER.LIST

            CLEAN.LINE = CHANGE(DEBUG.SEND.TEXT, "%PARAMETERS%", DEBUG.PARAMETER.LIST)


* debugging source value.  the debugging source value will display on the "view debug"
* screen.  the developer may sort and/or filter by the debugging source value.  once the
* source value is set it will remain until it is cleared or reset

*     set debugging source value
        CASE FOUND.SET.SOURCE

            DEBUG.PARAMETER.LIST = KEY.WORD [DEBUG.SET.SOURCE.KEYWORD.LEN + 1, TO.THE.END]:" ":CLEAN.LINE [" ", 2, TO.THE.END]
            IF SCAN.DEBUG.SPACES THEN
                DEBUG.PARAMETER.LIST = CONVERT.LITERAL.SPACES (DEBUG.PARAMETER.LIST)
            END

            CLEAN.LINE = CHANGE(DEBUG.ON.TEXT, "%VALUE%", DEBUG.PARAMETER.LIST)

*     clear debugging source value
        CASE FOUND.CLEAR.SOURCE

            CLEAN.LINE = DEBUG.OFF.TEXT

*     identify current method and/or program
        CASE FOUND.IDENTIFY.KEYWORD AND COMPILE.OBJECT

            IDENTIFY.TEXT = '"':DOWNCASE(OBJECT.NAME):METHOD.DELIMITER:DOWNCASE(METHOD):'"'

            IF PROPERTIES.EXIST THEN
                IDENTIFY.TEXT := ':" (":OBJECT.PTR:"):"'
            END

            CLEAN.LINE = CHANGE(DEBUG.IDENTIFY.METHOD.TEXT, "%METHOD%", IDENTIFY.TEXT)

        CASE FOUND.IDENTIFY.KEYWORD AND COMPILE.SUBROUTINE

            IDENTIFY.TEXT = '"':DOWNCASE(OBJECT.NAME):':"'

            CLEAN.LINE = CHANGE(DEBUG.IDENTIFY.METHOD.TEXT, "%METHOD%", IDENTIFY.TEXT)

*     clear debugging messages
        CASE FOUND.CLEAR

            CLEAN.LINE = DEBUG.CLEAR.TEXT

* not a debugging statement:
        CASE 1

            CONVERTED.FOR.DEBUG = @FALSE

    END CASE

* if we converted the line set this.line with the converted line and
* call clean.line so that it's as if the program line was this way all
* along
    IF CONVERTED.FOR.DEBUG THEN
        DEBUG.CODE.EXISTS = @TRUE
        GOSUB CONVERT.WRAPUP
    END

    RETURN

CLEAR.DEBUG.KEYWORD.FLAGS: ***********************************************
* clear all flags indicating if a debugging keyword was found            *
**************************************************************************
    FOUND.SEND.ARRAY = @FALSE
    FOUND.CLEAR.AND.MESSAGE = @FALSE
    FOUND.SEND.VARIABLE = @FALSE
    FOUND.SEND.TEXT = @FALSE
    FOUND.SET.SOURCE = @FALSE
    FOUND.CLEAR.SOURCE = @FALSE
    FOUND.CLEAR.KEYWORD = @FALSE
    FOUND.IDENTIFY.KEYWORD = @FALSE

    RETURN

SEND.VARIABLE.LIST.TO.DEBUG: *********************************************
* send a single message line to the debug window                         *
**************************************************************************

* get parameters from the variable-listing debug line and split them up
    DEBUG.PARAMETER.LIST = KEY.WORD [DEBUG.SEND.VARIABLE.KEYWORD.LEN + 1, TO.THE.END]:" ":CLEAN.LINE [" ", 2, TO.THE.END]

    IF SCAN.DEBUG.SPACES THEN
        DEBUG.PARAMETER.LIST = CONVERT.LITERAL.SPACES (DEBUG.PARAMETER.LIST)
    END

    DEBUG.PARAMETER.LIST = SPLIT.PARAMETERS(DEBUG.PARAMETER.LIST)
    DEBUG.PARAMETER.COUNT = DCOUNT(DEBUG.PARAMETER.LIST, @AM)

* start the ud.debug call
    CLEAN.LINE = DEBUG.VARIABLE.TEXT

* add code to display each variable in the listing
    FOR DEBUG.LOOP = 1 TO DEBUG.PARAMETER.COUNT

* if this is the second value or later add a separator between the individual
* displays
        IF DEBUG.LOOP > 1 THEN
            CLEAN.LINE := ":', '"
        END

        DEBUG.VALUE = TRIM(DEBUG.PARAMETER.LIST<DEBUG.LOOP>, " ", "B")

* if this value is a literal string use the debug.variable.literal.text (from the
* compiler setup record) to build a ud.debug call
        IF DEBUG.VALUE [1, 1] = '"' OR DEBUG.VALUE [1, 1] = "'" THEN

            CLEAN.LINE := CHANGE(DEBUG.VARIABLE.LITERAL.TEXT, "%VALUE%", DEBUG.VALUE)

        END ELSE

* if the value isn't a literal string use the debug.variable.value.text (from the
* compiler setup record, again) to build a ud.debug call
            IF UPCASE.CODE THEN
                DEBUG.VALUE.NAME = DOWNCASE(DEBUG.VALUE)
            END ELSE
                DEBUG.VALUE.NAME = DEBUG.VALUE
            END

            CLEAN.LINE := CHANGE(DEBUG.VARIABLE.VALUE.TEXT, "%NAME%", DEBUG.VALUE.NAME)
            CLEAN.LINE = CHANGE(CLEAN.LINE, "%VALUE%", DEBUG.VALUE)

        END

    NEXT DEBUG.LOOP

* add the debugging source
    CLEAN.LINE := ", UD.DEBUG.SOURCE.VALUE"

    RETURN

CONDITION.DEBUG.PARAMETER.LIST: ******************************************
* clean up debug.parameter.list.  if scan.debug.spaces is enabled then   *
* replace any literal spaces with space() statements.  if the second     *
* parameter (debug source) is null replace it with "                     *
**************************************************************************
    IF SCAN.DEBUG.SPACES THEN
        DEBUG.PARAMETER.LIST = CONVERT.LITERAL.SPACES (DEBUG.PARAMETER.LIST)
    END

    DEBUG.PARAMETER.LIST = SPLIT.PARAMETERS(DEBUG.PARAMETER.LIST)

* if the second parameter is null replace it with ud.debug.source.value
    DEBUG.PARAMETER.LIST = SPLIT.PARAMETERS(DEBUG.PARAMETER.LIST)

    IF DEBUG.PARAMETER.LIST<2> = "" THEN
        DEBUG.PARAMETER.LIST<2> = "UD.DEBUG.SOURCE.VALUE"
    END

    DEBUG.PARAMETER.LIST = CHANGE(DEBUG.PARAMETER.LIST, @AM, ", ")

    RETURN


**************************************************************************
**************************************************************************
** code conversion / "replace with" character, "::"                     **
**************************************************************************
**************************************************************************

CONVERT.REPLACE.WITH.KEYWORD: ********************************************
* when using "with" clauses where the entire object/method expression is *
* going to be replaced with the current "with" stack the expression will *
* only be "::".  this is too vague to be picked up by the other          *
* conversion routines so we'll convert these expressions here            *
**************************************************************************
    REPLACE.WITH.CONVERTED = @FALSE

* if there isn't an active "with" stack dump out
    IF CURRENT.WITH = "" THEN
        RETURN
    END

* if the "replace with" keyword isn't defined dump out
    IF REPLACE.WITH.KEYWORD = "" THEN
        RETURN
    END

    REPLACE.OCCURRENCE = 0

* check for replace.keyword occurences in clean.line.  if it's not found or
* it's found but doesn't have spaces on both sides of it return
    LOOP
        REPLACE.OCCURRENCE += 1
        WITH.PTR = INDEX(CLEAN.LINE, REPLACE.WITH.KEYWORD, REPLACE.OCCURRENCE)
    UNTIL WITH.PTR < 1
        GOSUB CONVERT.ONE.REPLACE.WITH
    REPEAT

* if we did a conversion wrap up the change
    IF REPLACE.WITH.CONVERTED THEN
        GOSUB CONVERT.WRAPUP
    END

    RETURN

CONVERT.ONE.REPLACE.WITH: ************************************************
* a "replace with" keyword (usually "::") was found at with.ptr.  see if *
* it's a replace.keyword for real (ie, has spaces on both sides of it)   *
* and replace it if it is                                                *
* this may add "::" strings but it won't remove any since the            *
* will have to be at least object::method.  this may add some            *
* additional checks for the "::" replacement string but it won't         *
* miss any due to the replacement                                        *
**************************************************************************

* find the characters immediately before and immediately after the
* "replace with" string
    IF WITH.PTR > 1 THEN
        CHAR.BEFORE = CLEAN.LINE [WITH.PTR - 1, 1]
    END ELSE
        CHAR.BEFORE = ""
    END

    CHAR.AFTER = CLEAN.LINE [WITH.PTR + LEN(REPLACE.WITH.KEYWORD), 1]

* both the character before and the character after have to be a space
* or null for this to be a "replace with" string.  this is to avoid
* converting normal method definitions
    IF CHAR.BEFORE <> " " AND CHAR.BEFORE <> "" AND CHAR.BEFORE <> ";" THEN
        RETURN
    END
    IF CHAR.AFTER <> " " AND CHAR.AFTER <> "(" AND CHAR.AFTER <> "" THEN
        RETURN
    END

* we have a "replace with" keyword here.  replace it with the current
* "with" stack
    CLEAN.LINE = CLEAN.LINE [1, WITH.PTR - 1]:CURRENT.WITH:CLEAN.LINE [WITH.PTR + LEN(REPLACE.WITH.KEYWORD), TO.THE.END]

    REPLACE.WITH.CONVERTED = @TRUE

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / short gosubs                      **
**************************************************************************
**************************************************************************

PROCESS.GOSUBS: **********************************************************
* build the label table and (possibly) list and remove any subroutines   *
* that are not called.  needs include.instance.code.labels to indicate   *
* whether or not labels from the instance.code should be included when   *
* building the label list.  this should be set true for object methods   *
* and false for wappers                                                  *
**************************************************************************
    LINES.DELETED = 0

    GOSUB BUILD.LABEL.TABLE

    IF ENABLE.SHORT.GOSUBS THEN
        GOSUB CONVERT.SHORT.GOSUBS
    END

    GOSUB REMOVE.UNUSED.SUBROUTINES

* if any subroutines were removed there may be other subroutines still
* in the code that were only called by subroutines that have been
* removed.  if subroutines were removed redo the process again until
* no subroutines are removed
    LOOP UNTIL NOT (SUBROUTINES.REMOVED) DO

        GOSUB BUILD.LABEL.TABLE

        IF ENABLE.SHORT.GOSUBS THEN
            GOSUB CONVERT.SHORT.GOSUBS
        END

        GOSUB REMOVE.UNUSED.SUBROUTINES

    REPEAT

    IF LINES.DELETED > 0 AND SHOW.UNCALLED.SUBROUTINES THEN
        PRINT "        ":LINES.DELETED:" lines deleted (uncalled subroutines)."
    END

    RETURN

CONVERT.SHORT.GOSUBS: ****************************************************
* convert any short gosubs.  if a subroutine label is on a program line  *
* by itself convert it to a gosub call.  for example, "MY.ROUTINE" on    *
* its own line explodes into "GOSUB MY.ROUTINE"                          *
**************************************************************************
    GOSUB.START.DATE = DATE()
    GOSUB.START.TIME = TIME()

* find the start and end lines of the thrown error subroutine.  when
* deciding if a subroutine call is used or not we won't count any calls
* in this range
    ERROR.GOSUB.START.LINE = 0
    ERROR.GOSUB.END.LINE = 0
   
    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

*       THIS.LINE = PROGRAM.CODE<LINE.LOOP>
        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious code that won't have gosubs in it
        TRIM.THIS.LINE = TRIM(THIS.LINE)

* skip any lines that are null or comments
        IF TRIM.THIS.LINE <> "" AND TRIM.THIS.LINE [1, 1] <> "*" AND TRIM.THIS.LINE [1, 1] <> "!" THEN

            IF IS.CODE(THIS.LINE) THEN

                THIS.CODE = LINE.WITHOUT.LABEL(THIS.LINE)

                IF THIS.CODE <> "" AND THIS.CODE [1, 1] <> "*" AND THIS.CODE [1, 1] <> "!" THEN
                    GOSUB CONVERT.THIS.SHORT.GOSUB
                END

            END

        END

    NEXT LINE.LOOP

    GOSUB.END.DATE = DATE()
    GOSUB.END.TIME = TIME()
    GOSUB.ELAPSED.TIME += TIME.ELAPSED (GOSUB.START.DATE, GOSUB.START.TIME)

    RETURN

CONVERT.THIS.SHORT.GOSUB: ************************************************
* convert a short gosub in this.code in program.code at line.loop        *
**************************************************************************

* a short gosub has to be the only thing on the line.  if so then the
* trimmed code won't have any spaces in it
    IF COUNT(THIS.CODE, " ") = 0 THEN

        IF CONVERT(BAD.SHORT.GOSUB.CHARACTERS, "", THIS.CODE) = THIS.CODE THEN

* if this subroutine is in our label list then we have a short gosub.
* change the statement to a gosub
            THIS.GOSUB.NAME = THIS.CODE

            LOCATE THIS.GOSUB.NAME IN LABEL.LIST SETTING SHORT.GOSUB.PTR THEN

                THIS.LABEL = LINE.LABEL(THIS.LINE)
                INDENT.COUNT = FIND.INDENT.COUNT (THIS.LABEL, THIS.LINE)

                GOSUB.LINE = THIS.LABEL:SPACE(INDENT.COUNT):"GOSUB ":THIS.GOSUB.NAME
                PROGRAM.CODE<LINE.LOOP> = GOSUB.LINE

                LABEL.CALLED.LIST<SHORT.GOSUB.PTR> = @TRUE

            END ELSE

                GOSUB CHECK.INVALID.SHORT.GOSUBS

            END

        END

        RETURN

    END

    FIRST.WORD = THIS.CODE [" ", 1, 1]

* if this is a conditional gosub (ending in ".IF") convert the line if
* the subroutine name is in the label.list.  if it's not in the label list
* we'll ignore it as it may just be a variable name or something
    GOSUB CHECK.CONDITIONAL.GOSUBS
    IF GOSUB.CONVERTED THEN
        RETURN
    END

* if this line has a "THEN GOSUB" in it then we have a converted conditional
* short gosub call.  get the gosub nameand update the label list so we know the
* subroutine has been called
    CONDITIONAL.GOSUB.PTR = INDEX (THIS.CODE, " THEN GOSUB ", 1) 
    IF CONDITIONAL.GOSUB.PTR > 0 THEN

        GOSUB.NAME = TRIM(THIS.CODE [CONDITIONAL.GOSUB.PTR + 12, 1000]) [" ", 1, 1]
        GOSUB SET.GOSUB.USED

        RETURN

    END

* if this is a "long" gosub update the label list so that we know the
* subroutine has been called
    IF FIRST.WORD = "GOSUB" THEN

        GOSUB.NAME = THIS.CODE [" ", 2, 1]
        GOSUB SET.GOSUB.USED

        RETURN

    END

* if this is a "goto" count it as calling a label
    IF FIRST.WORD = "GOTO" THEN

        GOSUB.NAME = THIS.CODE [" ", 2, 1]
        GOSUB SET.GOSUB.USED

        RETURN

    END

* "on x gosub"
    IF FIRST.WORD = "ON" THEN

        IF INDEX(THIS.CODE, "GOSUB", 1) <> 0 THEN

            GOSUB.PTR = INDEX(THIS.CODE, "GOSUB", 1) + 6
            GOSUB.LIST = THIS.CODE [GOSUB.PTR, TO.THE.END]
            GOSUB.LIST = CHANGE(GOSUB.LIST, ",", @AM)
            GOSUB.LIST.COUNT = DCOUNT(GOSUB.LIST, @AM)

            FOR GOSUB.LOOP = 1 TO GOSUB.LIST.COUNT
                GOSUB.NAME = TRIM(GOSUB.LIST<GOSUB.LOOP>)
                GOSUB SET.GOSUB.USED
            NEXT GOSUB.LOOP

            RETURN

        END

    END

* "on x goto"
    IF FIRST.WORD = "ON" THEN

        IF INDEX(THIS.CODE, "GOTO", 1) <> 0 THEN

            GOSUB.PTR = INDEX(THIS.CODE, "GOSUB", 1) + 5
            GOSUB.LIST = THIS.CODE [GOSUB.PTR, TO.THE.END]
            GOSUB.LIST = CHANGE(GOSUB.LIST, ",", @AM)
            GOSUB.LIST.COUNT = DCOUNT(GOSUB.LIST, @AM)

            FOR GOSUB.LOOP = 1 TO GOSUB.LIST.COUNT
                GOSUB.NAME = TRIM(GOSUB.LIST<GOSUB.LOOP>)
                GOSUB SET.GOSUB.USED
            NEXT GOSUB.LOOP

            RETURN

        END

    END

    RETURN

CHECK.CONDITIONAL.GOSUBS: ************************************************
* check for a conditional gosub based in "this.code".  this.code will    *
* potentially be a short gosub (a "gosub" without the "gosub" keyword)   *
* possibly followed by ".if", ".ifnot", etc.  if a conditional short     *
* gosub is found the gosub in program.code<line.loop> will be converted  *
* and gosub.converted will be returned true                              *
**************************************************************************
    GOSUB.CONVERTED = @FALSE
    FIRST.WORD = THIS.CODE [" ", 1, 1]

    IF FIRST.WORD = "" THEN
        RETURN
    END

* if this is a short gosub the gosub name will be the first word on the line.
* if there are no dots in this word it can't be a conditional gosub
    GOSUB.DOT.COUNT = COUNT(FIRST.WORD, ".")
    IF GOSUB.DOT.COUNT = 0 THEN
        RETURN
    END

* if this is a conditional gosub the "type" of the conditional ("if", "ifnot",
* etc) will be the last field, delimited by dots
    CONDITIONAL.TYPE = FIRST.WORD [".", GOSUB.DOT.COUNT + 1, 1]

* if the conditional type matches any valid short gosub suffix convert the
* short gosub
    BEGIN CASE

* conditional gosub ending in ".IF"
        CASE CONDITIONAL.TYPE = "IF"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF CALL.COND.SUB"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNOT"
        CASE CONDITIONAL.TYPE = "IFNOT"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NOT(CALL.COND.SUB)"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFZERO"
        CASE CONDITIONAL.TYPE = "IFZERO"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NUM(CALL.COND.SUB) THEN IF CALL.COND.SUB+0 = 0"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNOTZERO"
        CASE CONDITIONAL.TYPE = "IFNOTZERO"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NUM(CALL.COND.SUB) THEN IF CALL.COND.SUB+0 <> 0"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNULL"
        CASE CONDITIONAL.TYPE = "IFNULL"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = ' ; IF CALL.COND.SUB = ""'
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNOTNULL"
        CASE CONDITIONAL.TYPE = "IFNOTNULL"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = ' ; IF CALL.COND.SUB <> ""'
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNUM"
        CASE CONDITIONAL.TYPE = "IFNUM"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NUM(CALL.COND.SUB)"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNOTNUM"
        CASE CONDITIONAL.TYPE = "IFNOTNUM"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NOT(NUM(CALL.COND.SUB))"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFALPHA"
        CASE CONDITIONAL.TYPE = "IFALPHA"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF ALPHA(CALL.COND.SUB)"
            GOSUB CONVERT.CONDITIONAL.GOSUB

* conditional gosub ending in ".IFNOTALPHA"
        CASE CONDITIONAL.TYPE = "IFNOTALPHA"
            CONDITIONAL.BEFORE = "CALL.COND.SUB = "
            CONDITIONAL.AFTER = " ; IF NOT(ALPHA(CALL.COND.SUB))"
            GOSUB CONVERT.CONDITIONAL.GOSUB

    END CASE

    RETURN

CONVERT.CONDITIONAL.GOSUB: ***********************************************
* attempt to convert a conditional gosub in this.code, updating          *
* program.code<line.loop> and upating label.called.list<n>.  also        *
* needs this.line with the entire code line, with label if a label       *
* exists.                                                                *
*                                                                        *
* checks to see if the gosub subroutine name is a valid subroutine.  if  *
* it is the code is converted and saved to program.code<line.loop> and   *
* gosub.converted is returned true.  conditional.before has code to      *
* insert before the logical expression and conditional.after has the     *
* code for after the expression                                          *
**************************************************************************
    GOSUB.CONVERTED = @FALSE

* get the name of the (possible) short gosub routine and see if it's a valid
* program label
    THIS.GOSUB.NAME = FIRST.WORD [".", 1, GOSUB.DOT.COUNT]
    IF THIS.GOSUB.NAME = "" THEN
        RETURN
    END

    LOCATE THIS.GOSUB.NAME IN LABEL.LIST SETTING SHORT.GOSUB.PTR ELSE
        RETURN
    END

* we have a conditional gosub.  everything after the conditional gosub goes into
* the "if" statement before the gosub
    LOGIC.EXPRESSION = THIS.CODE [" ", 2, 10000]

    THIS.LABEL = LINE.LABEL(THIS.LINE)
    INDENT.COUNT = FIND.INDENT.COUNT (THIS.LABEL, THIS.LINE)

    GOSUB.LINE = THIS.LABEL:SPACE(INDENT.COUNT):CONDITIONAL.BEFORE:LOGIC.EXPRESSION
    GOSUB.LINE := CONDITIONAL.AFTER:" THEN GOSUB ":THIS.GOSUB.NAME

    PROGRAM.CODE<LINE.LOOP> = GOSUB.LINE

    LABEL.CALLED.LIST<SHORT.GOSUB.PTR> = @TRUE

    GOSUB.CONVERTED = @TRUE

    RETURN

SET.GOSUB.USED: **********************************************************
* if gosub.name exists in label.list flag it as called                   *
**************************************************************************
    LOCATE GOSUB.NAME IN LABEL.LIST SETTING GOSUB.PTR THEN
        LABEL.CALLED.LIST<GOSUB.PTR> = @TRUE
    END

    RETURN

CHECK.INVALID.SHORT.GOSUBS: **********************************************
* we have a potential short gosub label in this.code but could not       *
* find it in label.list.  determine if this.code is a basic keyword      *
* or not and show an error if it looks like an invalid short gosub       *
**************************************************************************

* if this code is split and the keyword is the subroutine name catted with
* the split code suffix then it's not an invalid gosub.  it's a call to the
* slit routine which hasn't been created and compiled yet
    IF IS.SPLIT THEN
        IF THIS.CODE = SUBROUTINE.NAME:SPLIT.SUFFIX THEN
            RETURN
        END
    END

* if this is a basic keyword it's not a bad short gosub
    LOCATE THIS.CODE IN BASIC.KEYWORD.LIST SETTING THROWAWAY THEN
        RETURN
    END

* if this is a macro it's not a bad short gosub
    LOCATE THIS.CODE IN MACRO.KEYWORD.LIST SETTING THROWAWAY THEN
        RETURN
    END

* if this line is aa shortcut it's not a bad short gosub
    LOCATE THIS.CODE IN SHORTCUT.KEYWORD.LIST SETTING THROWAWAY THEN
        RETURN
    END

* if it's a debugging shortcut it's not bad
    LOCATE THIS.CODE IN DEBUG.SHORTCUT.LIST SETTING THROWAWAY THEN
        RETURN
    END

* if it's in the short gosub exemption list it's not bad
    LOCATE THIS.CODE IN SHORT.GOSUB.EXEMPT.LIST SETTING THROWAWAY THEN
        RETURN
    END

* this may be an eclipse-style subroutine call with no parameters. check
* oc to see if the possible short gosub is really a compiled subroutine
    READV TEST.READ FROM OCFILE, THIS.CODE, 0 THEN
        RETURN
    END

    OBJECT.WARNING.DESC = "Invalid short gosub ":'"':THIS.CODE:'"'
    OBJECT.WARNING.LINE = LINE.LOOP
    GOSUB PRINT.OBJECT.WARNING

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / wrappers / unused subroutine removal     **
**************************************************************************
**************************************************************************

REMOVE.UNUSED.WRAPPER.SUBROUTINES: ***************************************
* remove unused subroutines from wrapper code.  the wrapper code is      *
* built in wrapper.code but remove.unused.subroutines works with         *
* program.code.  wrapper.code is copied into program.code, the           *
* subroutine list is built and any unused suborutines are removed.       *
**************************************************************************
    IF NOT (SHOW.UNCALLED.SUBROUTINES) THEN

        IF NOT (REMOVE.UNCALLED.SUBROUTINES) OR NOT(REMOVE.UNCALLED.IN.WRAPPERS) THEN
            RETURN
        END

    END

* we're going to need some routines that work with program.code but we don't
* want to clobber what's in program.code.  save it so we can restore it when
* we're finished.  once we do this we'll copy the wrapper.code into program.code
* and do any case conversions needed.  then we'll unwrap any wrapped code
* and build a list of wapper labels.  then we'll process the gosubs, building
* a list of uncalled subroutines
    GOSUB SAVE.PROGRAM.CODE
    GOSUB COPY.WRAPPER.CODE
    GOSUB UNWRAP.WRAPPER.LINES
    GOSUB BUILD.WRAPPER.LABEL.LIST

    INCLUDE.INSTANCE.CODE.LABELS = @FALSE
    GOSUB PROCESS.GOSUBS

* all of the above is necessary to show the uncalled subroutine list if we're
* set to display it.  if we're showing the uncalled display list but not removing
* the uncalled routines exit
    IF NOT (REMOVE.UNCALLED.SUBROUTINES) OR NOT(REMOVE.UNCALLED.IN.WRAPPERS) THEN
        GOSUB RESTORE.PROGRAM.CODE
        RETURN
    END

* label.list will now contain only the subroutines that survived the
* unused subroutine removal.  build a list of the labels from the previous
* subroutine list that don't exist now.  this will be the list of unused
* subroutines that should be removed
    GOSUB BUILD.UNUSED.WRAPPER.SUBROUTINE.LIST

* if there are any unused subroutines remove them from the wrapper code
    IF UNUSED.LABEL.COUNT > 0 THEN
        GOSUB DELETE.UNUSED.WRAPPER.SUBROUTINE.CODE
    END

    GOSUB RESTORE.PROGRAM.CODE

    RETURN

SAVE.PROGRAM.CODE: *******************************************************
* copy program.code variables to save variables so they can be restored  *
* later                                                                  *
**************************************************************************
    SAVE.PROGRAM.CODE = PROGRAM.CODE
    SAVE.PROGRAM.CODE.LINES = PROGRAM.CODE.LINES
    SAVE.ADD.LAST.CODE = ADD.LAST.CODE

    SAVE.OBJECT.CODE = OBJECT.CODE
    SAVE.OBJECT.CODE.LINES = OBJECT.CODE.LINES

    SAVE.LABEL.LIST = LABEL.LIST
    SAVE.LABEL.LINE.LIST = LABEL.LINE.LIST
    SAVE.LABEL.COUNT = LABEL.COUNT

    SAVE.ERROR.THROWS.USED = ERROR.THROWS.USED

    RETURN

RESTORE.PROGRAM.CODE: ****************************************************
* restore program.code variables from the save variables                 *
**************************************************************************
    PROGRAM.CODE = SAVE.PROGRAM.CODE
    PROGRAM.CODE.LINES = SAVE.PROGRAM.CODE.LINES
    ADD.LAST.CODE = SAVE.ADD.LAST.CODE

    OBJECT.CODE = SAVE.OBJECT.CODE
    OBJECT.CODE.LINES = SAVE.OBJECT.CODE.LINES

    LABEL.LIST = SAVE.LABEL.LIST
    LABEL.LINE.LIST = SAVE.LABEL.LINE.LIST
    LABEL.COUNT = SAVE.LABEL.COUNT

    ERROR.THROWS.USED = SAVE.ERROR.THROWS.USED

    RETURN

COPY.WRAPPER.CODE: *******************************************************
* copy the wrapper.code to program.code, correct any case conversions    *
* and check to see if there are any thrown errors                        *
**************************************************************************
    PROGRAM.CODE = WRAPPER.CODE
    PROGRAM.CODE.LINES = WRAPPER.CODE.LINES

    GOSUB UPCASE.PROGRAM.CODE

* the parent object of the wrapper may have error throws set but the wrapper
* routine may not.  check the wrapper code to see if there are any thrown
* errors.  if there are thrown errors uncalled subroutines will not be
* removed as they could be called with a thrown error
    GOSUB CHECK.THROWN.ERRORS

    RETURN

UNWRAP.WRAPPER.LINES: ****************************************************
* unwrap any wrapped lines in wrapper code in program.code               *
**************************************************************************

* we'll need to unwrap any wrapped lines as wrapped lines may look like a
* subroutine call or something to build.label.list
    OBJECT.CODE = PROGRAM.CODE
    OBJECT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB UNWRAP.LINES

    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES

    RETURN

BUILD.WRAPPER.LABEL.LIST: ************************************************
* build a list of labels in the current wrapper in wrapper.label.list    *
* variables.  wrapper.code should have alredy been copied into           *
* program.code via copy.wrapper.code                                     *
**************************************************************************

* build and save a list of subroutine labels in label.list
    INCLUDE.INSTANCE.CODE.LABELS = @FALSE
    GOSUB BUILD.LABEL.TABLE

* there may be some default labels in the list that aren't used in the
* wrapper.  remove any entries that don't have a starting line
    FOR LABEL.LOOP = LABEL.COUNT TO 1 STEP -1

        IF LABEL.LINE.LIST<LABEL.LOOP> = "" THEN
            DEL LABEL.LIST<LABEL.LOOP>
            DEL LABEL.LINE.LIST<LABEL.LOOP>
            LABEL.COUNT -= 1
        END

    NEXT LABEL.LOOP

* save our label list.  we'll have to use build.label.table later and we
* need this version of the label list
    WRAPPER.LABEL.LIST = LABEL.LIST
    WRAPPER.LINE.LIST = LABEL.LINE.LIST
    WRAPPER.LABEL.COUNT = LABEL.COUNT

    RETURN

BUILD.UNUSED.WRAPPER.SUBROUTINE.LIST: ************************************
* build a list of unused subroutines in a wrapper.  needs the            *
* wrapper.label.list and label.list variables and builds                 *
* unused.label.list variables                                            *
**************************************************************************
    UNUSED.LABEL.LIST = ""
    UNUSED.LINE.LIST = ""
    UNUSED.LAST.LIST = ""
    UNUSED.LABEL.COUNT = 0

    FOR LABEL.LOOP = 1 TO WRAPPER.LABEL.COUNT
        
        THIS.LABEL = WRAPPER.LABEL.LIST<LABEL.LOOP>
        ROUTINE.START.LINE = WRAPPER.LINE.LIST<LABEL.LOOP>

        IF LABEL.LOOP = WRAPPER.LABEL.COUNT THEN
            ROUTINE.END.LINE = WRAPPER.CODE.LINES
        END ELSE
            ROUTINE.END.LINE = WRAPPER.LINE.LIST<LABEL.LOOP + 1> - 1
        END

        LOCATE THIS.LABEL IN LABEL.LIST SETTING LABEL.PTR ELSE

            UNUSED.LABEL.COUNT += 1

            UNUSED.LABEL.LIST<UNUSED.LABEL.COUNT> = THIS.LABEL
            UNUSED.LINE.LIST<UNUSED.LABEL.COUNT> = ROUTINE.START.LINE
            UNUSED.LAST.LIST<UNUSED.LABEL.COUNT> = ROUTINE.END.LINE

        END

    NEXT LABEL.LOOP

    RETURN

DELETE.UNUSED.WRAPPER.SUBROUTINE.CODE: ***********************************
* remove code from wrapper.code for unused subroutines                   *
**************************************************************************

* work backwards through the unused label list and remove any routines
* that were not called.  the unused label list was created from program.code
* but processing gosubs won't add or delete anything from program.code so
* the line numbers in the "unused" list should still match up to the lines
* in wrapper.code
    FOR UNUSED.LOOP = UNUSED.LABEL.COUNT TO 1 STEP -1

        GOSUB.NAME = UNUSED.LABEL.LIST<UNUSED.LOOP>

        FIRST.LINE = UNUSED.LINE.LIST<UNUSED.LOOP>
        LAST.LINE = UNUSED.LAST.LIST<UNUSED.LOOP>

        IF FIRST.LINE > 0 AND LAST.LINE > 0 AND LAST.LINE > FIRST.LINE THEN

            FOR DELETE.LINE = FIRST.LINE TO LAST.LINE
                DEL WRAPPER.CODE<FIRST.LINE>
                WRAPPER.CODE.LINES -= 1
            NEXT DELETE.LINE

        END

    NEXT UNUSED.LOOP

    RETURN

**************************************************************************
**************************************************************************
** code conversion / objects / methods / unused subroutine removal      **
**************************************************************************
**************************************************************************

REMOVE.UNUSED.SUBROUTINES: ***********************************************
* remove any subroutines in label.list that are not called if            *
* remove.uncalled.subroutines is set                                     *
**************************************************************************
    SUBROUTINES.REMOVED = @FALSE

    IF SHOW.UNCALLED.SUBROUTINES THEN
        GOSUB LIST.UNUSED.GOSUBS
    END

    IF NOT(REMOVE.UNCALLED.SUBROUTINES) THEN
        RETURN
    END

* if this routine has thrown errors then we may have subroutines that
* will be called by the thrown errors but may not be called by a gosub.
* they will appear to not be called.  this would cause the thrown
* error to fail.  if we have thrown errors skip purging unused
* subroutines
    IF ERROR.THROWS.USED THEN
        RETURN
    END

    GOSUB BUILD.UNUSED.LABEL.LIST

    IF UNUSED.LABEL.COUNT = 0 THEN
        RETURN
    END

    SUBROUTINES.REMOVED = @TRUE

* work backwards through the unused label list and remove any routines
* that are not called
    FOR UNUSED.LOOP = UNUSED.LABEL.COUNT TO 1 STEP -1

        GOSUB.NAME = UNUSED.LABEL.LIST<UNUSED.LOOP>

        FIRST.LINE = UNUSED.LINE.LIST<UNUSED.LOOP>
        LAST.LINE = UNUSED.LAST.LIST<UNUSED.LOOP>

        IF FIRST.LINE > 0 AND LAST.LINE > 0 AND LAST.LINE > FIRST.LINE THEN

            FOR DELETE.LINE = FIRST.LINE TO LAST.LINE

                DEL PROGRAM.CODE<FIRST.LINE>
                PROGRAM.CODE.LINES -= 1
                LINES.DELETED += 1

            NEXT DELETE.LINE

        END

    NEXT UNUSED.LOOP

    RETURN

BUILD.UNUSED.LABEL.LIST: *************************************************
* build a list of labels that are not called                             *
**************************************************************************
    UNUSED.LABEL.LIST = ""
    UNUSED.LINE.LIST = ""
    UNUSED.LAST.LIST = ""
    UNUSED.LABEL.COUNT = 0

    LABEL.COUNT = DCOUNT(LABEL.LIST, @AM)

    FOR LABEL.LOOP = 1 TO LABEL.COUNT

        CHECK.LABEL = LABEL.LIST<LABEL.LOOP>

* if the label isn't called we might delete it
        IF NOT(LABEL.CALLED.LIST<LABEL.LOOP>) THEN

* if the subroutine label exists in the uncalled exception list we won't 
* delete it
            LOCATE CHECK.LABEL IN UNCALLED.EXCEPTION.LIST SETTING EXCEPTION.PTR ELSE

* if the subroutine label is creating an intime object don't delete it 
                IF CHECK.LABEL [1, LEN(INTIME.OBJECT.SUBROUTINE.PREFIX)] <> INTIME.OBJECT.SUBROUTINE.PREFIX THEN

* add the subroutine to the unused label list
                    LABEL.LINE = LABEL.LINE.LIST<LABEL.LOOP>
                    NEXT.LINE = LABEL.LINE.LIST<LABEL.LOOP + 1>

                    UNUSED.LABEL.COUNT += 1
                    UNUSED.LABEL.LIST<UNUSED.LABEL.COUNT> = CHECK.LABEL
                    UNUSED.LINE.LIST<UNUSED.LABEL.COUNT> = LABEL.LINE

                    IF LABEL.LOOP = LABEL.COUNT OR NEXT.LINE = "" OR NEXT.LINE < LABEL.LINE THEN
                        UNUSED.LAST.LIST<UNUSED.LABEL.COUNT> = PROGRAM.CODE.LINES 
                    END ELSE
                        UNUSED.LAST.LIST<UNUSED.LABEL.COUNT> = NEXT.LINE - 1
                    END

                END

            END

        END

    NEXT LABEL.LOOP

    RETURN

LIST.UNUSED.GOSUBS: ******************************************************
* list subroutine labels that weren't called                             *
**************************************************************************
    GOSUB BUILD.UNUSED.LABEL.LIST

    IF UNUSED.LABEL.COUNT = 0 THEN
        RETURN
    END

    IF UNUSED.LABEL.COUNT = 1 THEN
        UNUSED.TEXT = "        1 subroutine was not called"
    END ELSE
        UNUSED.TEXT = "        ":UNUSED.LABEL.COUNT:" subroutines were not called"
    END

    IF REMOVE.UNCALLED.SUBROUTINES THEN
        UNUSED.TEXT := " and will be removed"
    END

    UNUSED.TEXT := ": "

    MAX.UNUSED.DISPLAY.COUNT = 10

    IF UNUSED.LABEL.COUNT > MAX.UNUSED.DISPLAY.COUNT THEN
        UNUSED.LABEL.LIST = UNUSED.LABEL.LIST [@AM, 1, 10]:" and "
        UNUSED.LABEL.LIST := UNUSED.LABEL.COUNT - MAX.UNUSED.DISPLAY.COUNT:" more"
    END

    UNUSED.TEXT := CHANGE(UNUSED.LABEL.LIST, @AM, ", ")
    UNUSED.TEXT = FOLD.ON.COMMA (UNUSED.TEXT, 74, 12)

    UNUSED.TEXT.COUNT = DCOUNT(UNUSED.TEXT, @AM)
        
    IF SEND.TO.WINDOW THEN

        THIS.LINE = " "
        GOSUB ADD.ERROR.TEXT

        FOR UNUSED.LOOP = 1 TO UNUSED.TEXT.COUNT
            THIS.LINE = UNUSED.TEXT<UNUSED.LOOP>
            GOSUB ADD.ERROR.TEXT
        NEXT UNUSED.LOOP

    END

    FOR UNUSED.LOOP = 1 TO UNUSED.TEXT.COUNT
        PRINT UNUSED.TEXT<UNUSED.LOOP>
    NEXT UNUSED.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / shortcuts                         **
**************************************************************************
**************************************************************************

CONVERT.SHORTCUTS: *******************************************************
* convert shortcuts in program.code.lines                                *
**************************************************************************
    SHORTCUT.START.DATE = DATE()
    SHORTCUT.START.TIME = TIME()

    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have shortcuts
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            CLEAN.LINE = THIS.LINE
            GOSUB CLEAN.LINE

* see how many spaces are to the left of the code
            INDENT.COUNT = FIND.INDENT.COUNT (CLEAN.LABEL, THIS.LINE)

            GOSUB CONVERT.LINE.SHORTCUTS

            IF SHORTCUT.CONVERTED THEN

                IF CLEAN.LABEL <> "" THEN
                    CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
                END ELSE
                    CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
                END

                GOSUB CLEAN.AFTER.SHORTCUT

                PROGRAM.CODE<LINE.LOOP> = CLEAN.LINE

            END

        END

    NEXT LINE.LOOP

    SHORTCUT.END.DATE = DATE()
    SHORTCUT.END.TIME = TIME()
    SHORTCUT.ELAPSED.TIME += TIME.ELAPSED (SHORTCUT.START.DATE, SHORTCUT.START.TIME)

    RETURN

CONVERT.LINE.SHORTCUTS: **************************************************
* convert other shortcuts.  returns new.line with the converted line or  *
* returns new.line unchanged if no conversion is done.  note that the    *
* expanded shortcut should NOT have the shortcut string in it!           *
*                                                                        *
* a shortcut will ONLY be converted if the shortcut is found in the      *
* program line and it has:                                               *
*     - a space before it, or a semi-colon before it, or it's at the     *
*       start of a line                                                  *
*     - a space after it, or a semi-colon after it, or it's at the end   *
*       of the line                                                      *
**************************************************************************
    SHORTCUT.CONVERTED = @FALSE

* if any embedded shortcuts are moved to their own line they'll be added
* to one of these arrays
    SHORTCUT.BEFORE.LINE = ""
    SHORTCUT.BEFORE.COUNT = 0

    SHORTCUT.AFTER.LINE = ""
    SHORTCUT.AFTER.COUNT = 0

* check the line for each shortcut
    SETREM 0 ON SHORTCUT.KEYWORD.LIST

    SETREM 0 ON SHORTCUT.EXPAND.LIST
    SETREM 0 ON SHORTCUT.VAR.FOLLOW.LIST
    SETREM 0 ON SHORTCUT.FOLLOW.LIST
    SETREM 0 ON SHORTCUT.OPERATOR.LIST

    SETREM 0 ON SHORTCUT.EMBEDDED.LIST

    SETREM 0 ON SHORTCUT.SPACE.BEFORE.LIST
    SETREM 0 ON SHORTCUT.SPACE.AFTER.LIST

    FOR SHORTCUT.LOOP = 1 TO SHORTCUT.COUNT

* change all occurences of the this.shortcut to this.expand and
* this.follow
        REMOVE THIS.SHORTCUT FROM SHORTCUT.KEYWORD.LIST SETTING THROWAWAY

        REMOVE THIS.EXPAND FROM SHORTCUT.EXPAND.LIST SETTING THROWAWAY
        REMOVE THIS.VAR.FOLLOW FROM SHORTCUT.VAR.FOLLOW.LIST SETTING THROWAWAY
        REMOVE THIS.FOLLOW FROM SHORTCUT.FOLLOW.LIST SETTING THROWAWAY
        REMOVE THIS.OPERATOR FROM SHORTCUT.OPERATOR.LIST SETTING THROWAWAY

        REMOVE THIS.EMBEDDED FROM SHORTCUT.EMBEDDED.LIST SETTING THROWAWAY

        REMOVE THIS.SPACE.BEFORE FROM SHORTCUT.SPACE.BEFORE.LIST SETTING THROWAWAY
        REMOVE THIS.SPACE.AFTER FROM SHORTCUT.SPACE.AFTER.LIST SETTING THROWAWAY

* embedded shortcuts may null out this.expand and this.var.follow so we'll
* keep a safe copy of them
        SAVE.THIS.EXPAND = THIS.EXPAND
        SAVE.THIS.VAR.FOLLOW = THIS.VAR.FOLLOW

        GOSUB CHECK.ONE.SHORTCUT

        IF SHORTCUT.CONVERTED THEN
            TOTAL.SHORTCUTS.CONVERTED += SHORTCUT.CONVERTED.COUNT
        END

    NEXT SHORTCUT.LOOP

    RETURN

CHECK.ONE.SHORTCUT: ******************************************************
* check a single shortcut in clean.line.  a shortcut has to have a       *
* space or semicolon before it and a space or semicolon after it in      *
* order to be converted.  this is to prevent converting things when      *
* a shortcut string is part of a variable or something.                  *
*                                                                        *
* these before/after tests can be shut off by setting allow.bad.before   *
* and/or allow.bad.after                                                 *
*                                                                        *
* if a shortcut is found this routine changes the shortcut in clean.line *
* to the expanded text and returns converted.for.shortcut set true       *                                                            *
**************************************************************************
    SHORTCUT.DONE = @FALSE
    SHORTCUT.CONVERTED.COUNT = 0
    SHORTCUT.LIMIT = 20
    LOCATE.AT = 1

    LOOP UNTIL SHORTCUT.DONE DO

        PTR = INDEX(CLEAN.LINE, THIS.SHORTCUT, LOCATE.AT)
        LOCATE.AT += 1

* if we couldn't find this instance of a shortcut return
        IF PTR < 1 THEN
            SHORTCUT.DONE = @TRUE
            RETURN
        END

* so far so good.  let's make sure that this macro we found isn't part
* of an expression inside quotes
        IN.QUOTES = @FALSE
        THIS.QUOTE = ""

        FOR QUOTE.PTR = 1 TO PTR - 1

            THIS.CHAR = CLEAN.LINE [QUOTE.PTR, 1]

            BEGIN CASE
                CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                    IN.QUOTES = @FALSE
                    THIS.QUOTE = ""
                CASE IN.QUOTES
                    NULL
                CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                    THIS.QUOTE = THIS.CHAR
                    IN.QUOTES = @TRUE
            END CASE

        NEXT QUOTE.PTR

* if the shortcut we found is inside quotes we don't want to convert it
        IF NOT(IN.QUOTES) THEN

* increment the count of shortcuts we've converted.  if its gotten too
* high we probably have a shortcut expanded value with the shortcut
* string in it.  this would expand forever so we'll give up
            SHORTCUT.CONVERTED.COUNT += 1

            IF SHORTCUT.CONVERTED.COUNT > SHORTCUT.LIMIT THEN

                SHORTCUT.DONE = @TRUE

            END ELSE 

* we've found a shortcut string.  make sure it has a space or a semi-colon
* before it (WHY do people still use compound lines?) or it's the first
* thing on the line.  if the string is just part of a longer variable
* name we don't want to convert it
                CHAR.BEFORE = CLEAN.LINE [PTR - 1, 1]

                IF PTR = 1 OR CHAR.BEFORE = " " OR CHAR.BEFORE = ";" OR CHAR.BEFORE = CLOSE.BRACE OR CHAR.BEFORE = ")" OR NOT(THIS.SPACE.BEFORE) THEN

* make sure the following character is either a space, semi-colon or the
* end of the line to make sure this string isn't starting a longer
* variable name or something
                    AFTER.PTR = PTR + LEN(THIS.SHORTCUT)
                    CHAR.AFTER = CLEAN.LINE [AFTER.PTR, 1]

                    DO.SHORTCUT = @FALSE
                    IF CHAR.AFTER = " " OR CHAR.AFTER = ";" OR CHAR.AFTER = OPEN.BRACE OR CHAR.AFTER = "(" OR CHAR.AFTER = "" OR NOT(THIS.SPACE.AFTER) THEN

                        GOSUB CONVERT.THIS.SHORTCUT
                        SHORTCUT.CONVERTED = @TRUE
                        LOCATE.AT -= 1

                    END

                END

            END

        END

    REPEAT

    RETURN

CONVERT.THIS.SHORTCUT: ***************************************************
* convert a single programming shortcut.  converts this.shortcut to      *
* this.expand and adds this.follow afterwards if defined                 *
**************************************************************************
    USE.ONLY.SHORTCUT.LINES = @FALSE

* this.expand and this.var.follow may have been cleared by a previous
* embedded shortcut.  restore them from safe copies
    THIS.EXPAND = SAVE.THIS.EXPAND
    THIS.VAR.FOLLOW = SAVE.THIS.VAR.FOLLOW

* extract code from before and after the shortcut
    BEFORE.CLEAN.LINE = CLEAN.LINE [1, PTR - 1]
    AFTER.CLEAN.LINE = CLEAN.LINE [PTR + LEN(THIS.SHORTCUT), TO.THE.END]

* if the shortcut converts to a function (expand has an open pren and 
* var.follow has a close pren) we may have to do some special handling
    IF COUNT(THIS.EXPAND, "(") > 0 AND COUNT(THIS.VAR.FOLLOW, ")") > 0 THEN
        FUNCTION.SHORTCUT = @TRUE
    END ELSE
        FUNCTION.SHORTCUT = @FALSE
    END

* if this is an embedded shortcut and there is other code in the same line
* move it to its own line and replace the variable and the shortcut in the expression
* to just the variable.  otherwise convert the shortcut in the code line
    BEGIN CASE
        CASE THIS.EMBEDDED
            GOSUB CONVERT.EMBEDDED.SHORTCUT
        CASE FUNCTION.SHORTCUT
            GOSUB CONVERT.UNARY.SHORTCUT
    END CASE

* if we don't have a space before and after where we're inserting the
* shortcut add one
    SPACE.BEFORE = ""
    SPACE.AFTER = ""

    IF THIS.EXPAND <> "" THEN

        IF CLEAN.LINE [PTR - 1, 1] <> " " THEN
            SPACE.BEFORE = " "
        END

        IF CLEAN.LINE [PTR + LEN(THIS.SHORTCUT), 1] <> " " THEN
            SPACE.AFTER = " "
        END

    END

* convert this.shortcut to this.expand
    IF USE.ONLY.SHORTCUT.LINES THEN
        CLEAN.LINE = SPACE.BEFORE:SPACE.AFTER
        PTR += LEN(SPACE.BEFORE:SPACE.AFTER)
    END ELSE
        CLEAN.LINE = BEFORE.CLEAN.LINE:SPACE.BEFORE:THIS.EXPAND:SPACE.AFTER:AFTER.CLEAN.LINE
        PTR += LEN(SPACE.BEFORE:THIS.EXPAND:SPACE.AFTER)
    END

* add the shortcut follower if we have one.  
    IF THIS.FOLLOW <> "" THEN
        GOSUB ADD.SHORTCUT.FOLLOWER
    END

* add the variable follower if we have one.  operator shortcuts have
* already used the follower so we won't use it again
    IF THIS.VAR.FOLLOW <> "" AND NOT(THIS.OPERATOR) THEN
        GOSUB ADD.VARIABLE.FOLLOWER
    END

    GOSUB MERGE.BEFORE.AFTER.LINES

    RETURN

MERGE.BEFORE.AFTER.LINES: ************************************************
* if the shortcut was am embedded shortcut it may have generated code    *
* that belongs before and/or after the current code line.  insert this   *
* code before and after the code line by concatenating it to clean.line  *
**************************************************************************

* if this shortcut is an operator and the resulting clean.line does not
* contain an equals sign then removing the embedded operator expresion
* removed the entire assignment.  don't add the the clean.line in when
* building the final statement
    ADD.CLEAN.LINE = @TRUE
    IF THIS.OPERATOR AND COUNT(CLEAN.LINE, "=") = 0 THEN
        ADD.CLEAN.LINE = @FALSE
    END
    IF TRIM(CLEAN.LINE) = "" THEN
        ADD.CLEAN.LINE = @FALSE
    END

* if embedded shortcuts created lines that should go before or after the code 
* line add them back into clean.line
    IF SHORTCUT.BEFORE.COUNT <> 0 THEN

        IF ADD.CLEAN.LINE THEN
            CLEAN.LINE = CHANGE(SHORTCUT.BEFORE.LINE, @AM, " ; "):" ; ":CLEAN.LINE
        END ELSE
            CLEAN.LINE = CHANGE(SHORTCUT.BEFORE.LINE, @AM, " ; ")
        END

        SHORTCUT.BEFORE.LINE = ""
        SHORTCUT.BEFORE.COUNT = 0

    END ELSE

        IF NOT(ADD.CLEAN.LINE) THEN
            CLEAN.LINE = ""
        END

    END

    IF SHORTCUT.AFTER.COUNT <> 0 THEN

        IF CLEAN.LINE <> "" THEN
            CLEAN.LINE := " ; "
        END

        CLEAN.LINE := CHANGE(SHORTCUT.AFTER.LINE, @AM, " ; ")

        SHORTCUT.AFTER.LINE = ""
        SHORTCUT.AFTER.COUNT = 0

    END

* clean up and return.
    CLEAN.LINE = SMART.TRIM(CLEAN.LINE)

    IF SCAN.SHORTCUT.SPACES THEN
        CLEAN.LINE = CONVERT.LITERAL.SPACES(CLEAN.LINE)
    END

    IF SIMPLIFY.MULTIPLE.DYNAMICS THEN
        CLEAN.LINE = CONVERT.DYNAMIC.DUPE (CLEAN.LINE)
    END

    RETURN

CONVERT.EMBEDDED.SHORTCUT: ***********************************************
* convert an embedded shortcut.  moves the expanded code to its own line *
* in shortcut.before.line or shortcut.after.line and resets this.expand  *
* to be only the variable name in the shortcut                           *
**************************************************************************
    GOSUB GET.SHORTCUT.VARIABLE

* if we didn't find a variable name something is off again.  treat this
* shortcut as non-embedded
    IF SHORTCUT.VARIABLE = "" THEN
        RETURN
    END

    TRIM.BEFORE.CLEAN.LINE = TRIM(BEFORE.CLEAN.LINE)
    TRIM.AFTER.CLEAN.LINE = TRIM(AFTER.CLEAN.LINE)

* special case: if the last word before the shortcut is a then, else, {, }{,
* locked, or error then the shortcut is in a single-line if/then or a locked
* or on error clause.  treat this shortcut as not embedded
    IF BEFORE.CLEAN.LINE <> "" AND VARIABLE.BEFORE THEN

        BEFORE.SPACE.COUNT = DCOUNT(TRIM.BEFORE.CLEAN.LINE, " ")
        IF VARIABLE.BEFORE THEN
            WORD.BEFORE = TRIM.BEFORE.CLEAN.LINE [" ", BEFORE.SPACE.COUNT - 1, 1]
        END ELSE
            WORD.BEFORE = TRIM.BEFORE.CLEAN.LINE [" ", BEFORE.SPACE.COUNT, 1]
        END

        IF WORD.BEFORE <> "" THEN
            LOCATE WORD.BEFORE IN SHORTCUT.SPECIAL.KEYWORD.LIST SETTING THROWAWAY THEN
                SHORTCUT.VARIABLE = ""
                RETURN
            END
        END

    END

* if the first character after the shortcut is a semicolon then this shortcut
* is in a compound statement.  don't treat it as an embedded shortcut
    IF TRIM.AFTER.CLEAN.LINE [1, 1] = ";" THEN
        SHORTCUT.VARIABLE = ""
        RETURN
    END

* the same if the last character before the shortcut is a semicolon
    IF TRIM.BEFORE.CLEAN.LINE [1] = ";" THEN
        SHORTCUT.VARIABLE = ""
        RETURN
    END

* if the shortcut variable is the only thing in the before code or the after
* code then the variable and shortcut is the only thing on the line:

* if the shortcut converts to a function recreate the code line setting the
* variable equal to the function of itself

* if the shortcut does not convert to a function treat this shortcut as 
* non-embedded.Y
    GOSUB CONVERT.UNARY.FUNCTION

* update the appropriate shortcut.line table.  
    BEGIN CASE

* if this shortcut is an operator convert it.  an "operator" shortcut uses
* the expression before it and the expression after it in a function.  the 
* expanded statement will always be executed before the current line
        CASE THIS.OPERATOR
            GOSUB CONVERT.AFTER.FOR.OPERATOR

            CONVERTED.LINE = SHORTCUT.VARIABLE:THIS.EXPAND:NEXT.OPERAND:THIS.VAR.FOLLOW

            SHORTCUT.BEFORE.COUNT += 1
            SHORTCUT.BEFORE.LINE<SHORTCUT.BEFORE.COUNT> = CONVERTED.LINE

* if this is an unary statement convert it
        CASE UNARY.STATEMENT
            CONVERTED.LINE = SHORTCUT.VARIABLE:THIS.EXPAND:THIS.VAR.FOLLOW

            SHORTCUT.BEFORE.COUNT += 1
            SHORTCUT.BEFORE.LINE<SHORTCUT.BEFORE.COUNT> = CONVERTED.LINE
            USE.ONLY.SHORTCUT.LINES = @TRUE

* if the shortcut is before the variable the expanded code should be executed
* before the current line.
        CASE VARIABLE.AFTER AND FUNCTION.SHORTCUT
            CONVERTED.LINE = THIS.EXPAND:SHORTCUT.VARIABLE:THIS.VAR.FOLLOW

            SHORTCUT.BEFORE.COUNT += 1
            SHORTCUT.BEFORE.LINE<SHORTCUT.BEFORE.COUNT> = CONVERTED.LINE

        CASE VARIABLE.AFTER
            CONVERTED.LINE = SHORTCUT.VARIABLE:" ":THIS.EXPAND:THIS.VAR.FOLLOW

            SHORTCUT.BEFORE.COUNT += 1
            SHORTCUT.BEFORE.LINE<SHORTCUT.BEFORE.COUNT> = CONVERTED.LINE

* if the shortcut is after the variable the expanded code should be executed
* after the current line
        CASE VARIABLE.BEFORE AND FUNCTION.SHORTCUT
            CONVERTED.LINE = THIS.EXPAND:SHORTCUT.VARIABLE:THIS.VAR.FOLLOW

            SHORTCUT.AFTER.COUNT += 1
            SHORTCUT.AFTER.LINE<SHORTCUT.AFTER.COUNT> = CONVERTED.LINE
          
        CASE VARIABLE.BEFORE
            CONVERTED.LINE = SHORTCUT.VARIABLE:" ":THIS.EXPAND:THIS.VAR.FOLLOW

            SHORTCUT.AFTER.COUNT += 1
            SHORTCUT.AFTER.LINE<SHORTCUT.AFTER.COUNT> = CONVERTED.LINE

    END CASE

* clear this.expand so that the shortcut conversion will remove the shortcut from the
* code line
    THIS.EXPAND = ""
    THIS.VAR.FOLLOW = ""

    RETURN

CONVERT.AFTER.FOR.OPERATOR: **********************************************
* for operator shortcuts extract the "next" operand from                 *
* after.clean.line and adjust after.clean.line to have the "next"        *
* operator removed                                                       *
**************************************************************************
    NEXT.OPERAND = ""

    PREN.DEPTH = 0

    BRACKET.DEPTH = 0

    DYNAMIC.DEPTH = 0

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    NEXT.CHAR.PTR = 0

    LOOP

        NEXT.CHAR.PTR += 1
        NEXT.CHAR = AFTER.CLEAN.LINE [NEXT.CHAR.PTR, 1]

    UNTIL NEXT.CHAR = "" OR PREN.DEPTH < 0 OR BRACKET.DEPTH < 0 OR DYNAMIC.DEPTH < 0

        BEGIN CASE

* quotes
            CASE IN.QUOTES AND NEXT.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
                NEXT.OPERAND := NEXT.CHAR

            CASE IN.QUOTES
                NEXT.OPERAND := NEXT.CHAR

            CASE NEXT.CHAR = "'" OR NEXT.CHAR = '"'
                THIS.QUOTE = NEXT.CHAR
                IN.QUOTES = @TRUE
                NEXT.OPERAND := NEXT.CHAR

* dynamic array references
            CASE NEXT.CHAR = "<"
                NEXT.OPERAND := NEXT.CHAR

                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = AFTER.CLEAN.LINE
                    DYNAM.START.PTR = NEXT.CHAR.PTR
                    GOSUB CHECK.STARTING.DYNAMIC
                END ELSE
                    DYNAM.START = @TRUE
                END

                IF DYNAM.START THEN
                    DYNAMIC.DEPTH += 1
                END

            CASE NEXT.CHAR = ">" AND DYNAMIC.DEPTH > 0
                NEXT.OPERAND := NEXT.CHAR

                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = NEXT.CHAR.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYNAMIC.DEPTH -= 1
                END

            CASE NEXT.CHAR = ">"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = NEXT.CHAR.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                DYNAMIC.DEPTH -= 1

* brackets
            CASE NEXT.CHAR = "["
                NEXT.OPERAND := NEXT.CHAR
                BRACKET.DEPTH += 1

            CASE NEXT.CHAR = "]" AND BRACKET.DEPTH > 0
                NEXT.OPERAND := NEXT.CHAR
                BRACKET.DEPTH -= 1

            CASE NEXT.CHAR = "]"
                BRACKET.DEPTH -= 1

* parenthesis
            CASE NEXT.CHAR = "("
                NEXT.OPERAND := NEXT.CHAR
                PREN.DEPTH += 1

            CASE NEXT.CHAR = ")" AND PREN.DEPTH > 0
                NEXT.OPERAND := NEXT.CHAR
                PREN.DEPTH -= 1

            CASE NEXT.CHAR = ")"
                PREN.DEPTH -= 1

* if we hit an equals sign we're finished
            CASE NEXT.CHAR = "="
                PREN.DEPTH = -1

* anything else
            CASE 1
                NEXT.OPERAND := NEXT.CHAR

        END CASE

    REPEAT

* remove NEXT.OPERAND from after.clean.line
    AFTER.CLEAN.LINE = AFTER.CLEAN.LINE [LEN(NEXT.OPERAND) + 1, TO.THE.END]

    RETURN

CONVERT.UNARY.SHORTCUT: **************************************************
* if a shortcut converts to a function and the shortcut variable and the *
* shortcut are the only code in the line convert the line so that it     *
* expands to setting the shortcut variable to the function of itself     *
**************************************************************************
    GOSUB GET.SHORTCUT.VARIABLE
    GOSUB CONVERT.UNARY.FUNCTION

    RETURN

CONVERT.UNARY.FUNCTION: **************************************************
* if a shortcut converts to a function and the shortcut variable and the *
* shortcut are the only code in the line convert the line so that it     *
* expands to setting the shortcut variable to the function of itself     *
**************************************************************************
    BEGIN CASE

        CASE SHORTCUT.VARIABLE = ""
            UNARY.STATEMENT = @FALSE

        CASE SHORTCUT.VARIABLE = TRIM(BEFORE.CLEAN.LINE) AND TRIM(AFTER.CLEAN.LINE) = ""
            UNARY.STATEMENT = @TRUE

        CASE SHORTCUT.VARIABLE = TRIM(AFTER.CLEAN.LINE) AND TRIM(BEFORE.CLEAN.LINE) = ""
            UNARY.STATEMENT = @TRUE

        CASE 1
            UNARY.STATEMENT = @FALSE

    END CASE

* only do the unary conversion if we have an unary statement and it converts
* to a function
*   IF NOT(UNARY.STATEMENT) OR NOT(FUNCTION.SHORTCUT) THEN
    IF NOT(UNARY.STATEMENT) THEN
        RETURN
    END

    BEFORE.CLEAN.LINE = SHORTCUT.VARIABLE:" = "
    AFTER.CLEAN.LINE = SHORTCUT.VARIABLE:THIS.VAR.FOLLOW
    THIS.VAR.FOLLOW = ""

    RETURN

GET.SHORTCUT.VARIABLE: ***************************************************
* return the variable name that the shortcut is acting on.  also returns *
* variable.before true if the variable is before the shortcut and        *
* variable.after true if the variable is after the shortcut              *
**************************************************************************
    VALID.VARIABLE.CHARACTERS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz01234567890.$_"

* find the variable name the shortcut modifies.  is it before the shortcut
* string or after?  check the last character of whatever's before the
* variable+shortcut and the first character of what's after.  if one of
* these characters is alphanumeric that tells us where the variable is
    SHORTCUT.VARIABLE = ""
    CHAR.BEFORE = UPCASE(TRIM(BEFORE.CLEAN.LINE) [1])
    CHAR.AFTER = UPCASE(TRIM(AFTER.CLEAN.LINE) [1, 1])

    VARIABLE.BEFORE = @FALSE
    VARIABLE.AFTER = @FALSE

    BEGIN CASE

        CASE CHAR.BEFORE >= "A" AND CHAR.BEFORE <= "Z"
            VARIABLE.BEFORE = @TRUE
        CASE CHAR.BEFORE >= "0" AND CHAR.BEFORE <= "9"
            VARIABLE.BEFORE = @TRUE
        CASE CHAR.BEFORE = ")" OR CHAR.BEFORE = ">"
            VARIABLE.BEFORE = @TRUE

        CASE CHAR.AFTER >= "A" AND CHAR.AFTER <= "Z"
            VARIABLE.AFTER = @TRUE

    END CASE

* if we don't find a variable before or after something is off.  treat
* this shortcut as non-embedded
    IF NOT(VARIABLE.BEFORE) AND NOT(VARIABLE.AFTER) THEN
        RETURN
    END

* extract the variable before or after the shortcut
    IF VARIABLE.AFTER THEN
        GOSUB GET.SHORTCUT.VARIABLE.AFTER
    END ELSE
        GOSUB GET.SHORTCUT.VARIABLE.BEFORE
    END

* if we think the variable is before the shortcut but the variable turned
* out to be a basic keyword or a macro name then we don't have a variable.
* set to having the variable after and try again
    IF VARIABLE.BEFORE AND SHORTCUT.VARIABLE <> "" THEN

        GOSUB CHECK.SHORTCUT.VARIABLE

        IF NOT.SHORTCUT.VARIABLE THEN
            VARIABLE.BEFORE = @FALSE
            VARIABLE.AFTER = @TRUE
            GOSUB GET.SHORTCUT.VARIABLE.AFTER
        END

    END

* if we think the variable is after the shortcut but the variable is a
* basic keyword then we don't have a variable
    IF VARIABLE.AFTER AND SHORTCUT.VARIABLE <> "" THEN

        GOSUB CHECK.SHORTCUT.VARIABLE

        IF NOT.SHORTCUT.VARIABLE THEN
            VARIABLE.AFTER = @FALSE
            SHORTCUT.VARIABLE = ""
        END

    END

    RETURN

CHECK.SHORTCUT.VARIABLE: *************************************************
* check shortcut variable against the basic keyword list and the macro   *
* list.  if it exist in either list then it isn't a shortcut variable    *
**************************************************************************
    NOT.SHORTCUT.VARIABLE = @FALSE

    LOCATE SHORTCUT.VARIABLE IN BASIC.KEYWORD.LIST SETTING BASIC.KEYWORD.PTR THEN
        NOT.SHORTCUT.VARIABLE = @TRUE
    END ELSE
        LOCATE SHORTCUT.VARIABLE IN MACRO.KEYWORD.LIST SETTING MACRO.KEYWORD.PTR THEN
            NOT.SHORTCUT.VARIABLE = @TRUE
        END ELSE
            LOCATE SHORTCUT.VARIABLE IN SHORTCUT.KEYWORD.LIST SETTING SHORTCUT.KEYWORD.PTR THEN
                NOT.SHORTCUT.VARIABLE = @TRUE
            END ELSE
                LOCATE SHORTCUT.VARIABLE IN SHORTCUT.SPECIAL.KEYWORD.LIST SETTING SHORTCUT.KEYWORD.PTR THEN
                    NOT.SHORTCUT.VARIABLE = @TRUE
                END
            END
        END
    END

    RETURN

GET.SHORTCUT.VARIABLE.AFTER: *********************************************
* extract shortcut.variable from after.clean.line                        *
**************************************************************************
    SHORTCUT.VARIABLE = ""
    PREN.DEPTH = 0
    DYNAMIC.DEPTH = 0

    END.OF.VARIABLE = @FALSE
    LEN.AFTER.CLEAN.LINE = LEN(AFTER.CLEAN.LINE)

* skip over any leading spaces in after.clean.line
    SEARCH.START.PTR = 1

    LOOP UNTIL AFTER.CLEAN.LINE [SEARCH.START.PTR, 1] <> " "
        SEARCH.START.PTR += 1
    REPEAT

    FOR VARIABLE.PTR = SEARCH.START.PTR TO LEN.AFTER.CLEAN.LINE UNTIL END.OF.VARIABLE

        VARIABLE.CHAR = AFTER.CLEAN.LINE [VARIABLE.PTR, 1]
        VARIABLE.2CHAR = AFTER.CLEAN.LINE [VARIABLE.PTR, 2]

        BEGIN CASE

            CASE COUNT(VALID.VARIABLE.CHARACTERS, VARIABLE.CHAR) <> 0
                SHORTCUT.VARIABLE := VARIABLE.CHAR

            CASE VARIABLE.CHAR = "("
                PREN.DEPTH += 1
                SHORTCUT.VARIABLE := VARIABLE.CHAR
            CASE VARIABLE.CHAR = ")" AND PREN.DEPTH > 0
                PREN.DEPTH -= 1
                SHORTCUT.VARIABLE := VARIABLE.CHAR
            CASE VARIABLE.CHAR = ")"
                END.OF.VARIABLE = @TRUE

            CASE VARIABLE.2CHAR = "<=" OR VARIABLE.2CHAR = "=<"
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.2CHAR = ">=" OR VARIABLE.2CHAR = "=>"
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.2CHAR = "<>" OR VARIABLE.2CHAR = "!="
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.CHAR = "<" AND COUNT(AFTER.CLEAN.LINE [VARIABLE.PTR + 1, 10000], ">") = 0
                END.OF.VARIABLE = @TRUE

            CASE VARIABLE.2CHAR = METHOD.DELIMITER
                SHORTCUT.VARIABLE := VARIABLE.2CHAR
                VARIABLE.PTR += 1
            CASE VARIABLE.2CHAR = PROPERTY.DELIMITER
                SHORTCUT.VARIABLE := VARIABLE.2CHAR
                VARIABLE.PTR += 1
            CASE VARIABLE.2CHAR = CONSTANT.DELIMITER
                SHORTCUT.VARIABLE := VARIABLE.2CHAR
                VARIABLE.PTR += 1
            CASE VARIABLE.2CHAR = CHILD.DELIMITER
                SHORTCUT.VARIABLE := VARIABLE.2CHAR
                VARIABLE.PTR += 1
            
            CASE VARIABLE.CHAR = "<"
                DYNAMIC.DEPTH += 1
                SHORTCUT.VARIABLE := VARIABLE.CHAR
            CASE VARIABLE.CHAR = ">" AND DYNAMIC.DEPTH > 0
                DYNAMIC.DEPTH -= 1
                SHORTCUT.VARIABLE := VARIABLE.CHAR
            CASE VARIABLE.CHAR = ">"
                END.OF.VARIBLE = @TRUE

            CASE PREN.DEPTH <> 0 OR DYNAMIC.DEPTH <> 0
                SHORTCUT.VARIABLE := VARIABLE.CHAR
            CASE PREN.DEPTH = 0 AND DYNAMIC.DEPTH = 0
                END.OF.VARIABLE = @TRUE

        END CASE

    NEXT VARIABLE.PTR

    RETURN

GET.SHORTCUT.VARIABLE.BEFORE: ********************************************
* extract shortcut.variable from before.clean.line                       *
**************************************************************************
    SHORTCUT.VARIABLE = ""
    PREN.DEPTH = 0
    DYNAMIC.DEPTH = 0

    END.OF.VARIABLE = @FALSE
    LEN.BEFORE.CLEAN.LINE = LEN(BEFORE.CLEAN.LINE)

* skip over any trailing spaces in after.clean.line
    SEARCH.START.PTR = LEN.BEFORE.CLEAN.LINE

    LOOP UNTIL BEFORE.CLEAN.LINE [SEARCH.START.PTR, 1] <> " " OR SEARCH.START.PTR = 1
        SEARCH.START.PTR -= 1
    REPEAT

* start at this location and extract the complete variable expression
    FOR VARIABLE.PTR = SEARCH.START.PTR TO 1 STEP -1 UNTIL END.OF.VARIABLE

        VARIABLE.CHAR = BEFORE.CLEAN.LINE [VARIABLE.PTR, 1]
        VARIABLE.2CHAR = BEFORE.CLEAN.LINE [VARIABLE.PTR - 1, 2]

* if this character is a closed pren and it's not at the end of the shortcut
* variable check to see if this is the end of a function call.  if so then
* we're done extracting our variable
        IF VARIABLE.CHAR = ")" AND SHORTCUT.VARIABLE <> "" THEN

            BEGIN CASE

* if the closed pren is followed by a method delimiter, child delimiter,
* property delimiter or a constant delimiter then we've hit the start of
* a dimensioned object handle, not a function
                CASE BEFORE.CLEAN.LINE [VARIABLE.PTR + 1, METHOD.DEL.LENGTH] = METHOD.DELIMITER
                    NULL
                CASE BEFORE.CLEAN.LINE [VARIABLE.PTR + 1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
                    NULL
                CASE BEFORE.CLEAN.LINE [VARIABLE.PTR + 1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
                    NULL
                CASE BEFORE.CLEAN.LINE [VARIABLE.PTR + 1, CHILD.DEL.LENGTH] = CHILD.DELIMITER
                    NULL

* if this character is a closed pren followed by "<" then it's a dimensioned
* array followed by a dynamic array extraction and it's not the end
* of a function definition
                CASE BEFORE.CLEAN.LINE [VARIABLE.PTR + 1, 1] = "<"
                    NULL

* this closed pren is the end of a function.  we're finished extracting
* our variable
                CASE 1
                    END.OF.VARIABLE = @TRUE

            END CASE

        END

        BEGIN CASE

            CASE END.OF.VARIABLE
                NULL

            CASE COUNT(VALID.VARIABLE.CHARACTERS, VARIABLE.CHAR) <> 0
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE

            CASE VARIABLE.CHAR = ")"
                PREN.DEPTH += 1
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE
            CASE VARIABLE.CHAR = "(" AND PREN.DEPTH > 0
                PREN.DEPTH -= 1
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE
            CASE VARIABLE.CHAR = "("
                END.OF.VARIABLE = @TRUE

            CASE VARIABLE.2CHAR = "<=" OR VARIABLE.2CHAR = "=<"
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.2CHAR = ">=" OR VARIABLE.2CHAR = "=>"
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.2CHAR = "<>" OR VARIABLE.2CHAR = "!="
                END.OF.VARIABLE = @TRUE
            CASE VARIABLE.CHAR = ">" AND COUNT(BEFORE.CLEAN.LINE [1, VARIABLE.PTR - 1], "<") = 0
                END.OF.VARIABLE = @TRUE

            CASE VARIABLE.2CHAR = METHOD.DELIMITER
                SHORTCUT.VARIABLE = VARIABLE.2CHAR:SHORTCUT.VARIABLE
                VARIABLE.PTR -= 1
            CASE VARIABLE.2CHAR = PROPERTY.DELIMITER
                SHORTCUT.VARIABLE = VARIABLE.2CHAR:SHORTCUT.VARIABLE
                VARIABLE.PTR -= 1
            CASE VARIABLE.2CHAR = CONSTANT.DELIMITER
                SHORTCUT.VARIABLE = VARIABLE.2CHAR:SHORTCUT.VARIABLE
                VARIABLE.PTR -= 1
            CASE VARIABLE.2CHAR = CHILD.DELIMITER
                SHORTCUT.VARIABLE = VARIABLE.2CHAR:SHORTCUT.VARIABLE
                VARIABLE.PTR -= 1
            
            CASE VARIABLE.CHAR = ">"
                DYNAMIC.DEPTH += 1
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE
            CASE VARIABLE.CHAR = "<" AND DYNAMIC.DEPTH > 0
                DYNAMIC.DEPTH -= 1
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE
            CASE VARIABLE.CHAR = "<"
                END.OF.VARIABLE = @TRUE

            CASE PREN.DEPTH <> 0 OR DYNAMIC.DEPTH <> 0
                SHORTCUT.VARIABLE = VARIABLE.CHAR:SHORTCUT.VARIABLE

            CASE PREN.DEPTH = 0 AND DYNAMIC.DEPTH = 0
                END.OF.VARIABLE = @TRUE

        END CASE

    NEXT VARIABLE.PTR

    RETURN

ADD.VARIABLE.FOLLOWER: ***************************************************
* find the end of the variable expression after the shortcut we've just  *
* converted we're changing and add this.var.follow there.  search ahead  *
* through the program line, starting with the character after ptr, and   *
* find either an operator character, the end of the line or the next     *
* semi-colon that's not inside a quote or parenthesis                    *
**************************************************************************
    IN.PREN = @FALSE
    PREN.DEPTH = 0

    IN.BRACKET = @FALSE
    BRACKET.DEPTH = 0

    IN.DYNAMIC = @FALSE
    DYNAMIC.DEPTH = 0

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    END.PTR = PTR - 1

    FOUND.FOLLOWER.PTR = @FALSE

    FOLLOWER.SEPARATOR.LIST = "+=/* ,":CLOSE.BRACE:OPEN.BRACE

* search ahead in the command until we hit a separator character
    LOOP UNTIL FOUND.FOLLOWER.PTR DO

        END.PTR += 1
        PTR.CHAR = CLEAN.LINE [END.PTR, 1]

        IF PTR.CHAR <> "" AND INDEX(FOLLOWER.SEPARATOR.LIST, PTR.CHAR, 1) > 0 THEN
            SEPARATOR = @TRUE
        END ELSE
            SEPARATOR = @FALSE
        END

        BEGIN CASE

* we hit the end of the line
            CASE PTR.CHAR = ""
                FOUND.FOLLOWER.PTR = @TRUE

* hit the end of this line in a compound line
            CASE PTR.CHAR = ";" AND NOT(IN.QUOTES)
                FOUND.FOLLOWER.PTR = @TRUE

* hit an expression separator
            CASE SEPARATOR AND NOT(IN.QUOTES) AND NOT(IN.PREN) AND NOT(IN.BRACKET) AND NOT(IN.DYNAMIC)
                FOUND.FOLLOWER.PTR = @TRUE

* quotes
            CASE IN.QUOTES AND PTR.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""

            CASE IN.QUOTES
                NULL

            CASE PTR.CHAR = "'" OR PTR.CHAR = '"'
                THIS.QUOTE = PTR.CHAR
                IN.QUOTES = @TRUE

* parenthesis
            CASE PTR.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1

            CASE PTR.CHAR = ")" AND PREN.DEPTH <= 0
                FOUND.FOLLOWER.PTR = @TRUE
                PREN.DEPTH = 0

            CASE PTR.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END

* brackets
            CASE PTR.CHAR = "["
                IN.BRACKET = @TRUE
                BRACKET.DEPTH += 1

            CASE PTR.CHAR = "]" AND BRACKET.DEPTH <= 0
                FOUND.FOLLOWER.PTR = @TRUE
                BRACKET.DEPTH = 0

            CASE PTR.CHAR = "]"
                BRACKET.DEPTH -= 1
                IF BRACKET.DEPTH = 0 THEN
                    IN.BRACKET = @FALSE
                END

* dynamic array references
            CASE PTR.CHAR = "<"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.START.PTR = END.PTR
                    GOSUB CHECK.STARTING.DYNAMIC
                END ELSE
                    DYNAM.START = @TRUE
                END

                IF DYNAM.START THEN
                    IN.DYNAMIC = @TRUE
                    DYNAMIC.DEPTH += 1
                END

* if we hit a close ">" without an open we won't consider this the end of
* the expression as it gets confused with ">" as a "greater-than" sign
            CASE PTR.CHAR = ">" AND DYNAMIC.DEPTH <= 0
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = END.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYNAMIC.DEPTH = 0
                END

            CASE PTR.CHAR = ">"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = END.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYNAMIC.DEPTH -= 1
                    IF DYNAMIC.DEPTH = 0 THEN
                        IN.DYNAMIC = @FALSE
                    END
                END

        END CASE

    REPEAT

* if we don't have a space before and after where we're inserting our
* shortcut add one to keep things pretty
    SPACE.BEFORE = ""
    SPACE.AFTER = ""

    IF CLEAN.LINE [END.PTR - 1, 1] <> " " THEN
        SPACE.BEFORE = " "
    END

    IF CLEAN.LINE [END.PTR, 1] <> " " THEN
        SPACE.AFTER = " "
    END

* end.ptr now points at the first character after the variable that's the
* object of the shortcut.  insert the following shortcut at the pointer
* and clean up any sloppy spaces
    CLEAN.LINE = CLEAN.LINE [1, END.PTR - 1]:SPACE.BEFORE:THIS.VAR.FOLLOW:SPACE.AFTER:CLEAN.LINE [END.PTR, TO.THE.END]

    CLEAN.LINE = SMART.TRIM(CLEAN.LINE)

    RETURN

ADD.SHORTCUT.FOLLOWER: ***************************************************
* find the end of the program line we're changing and add this.follow    *
* there.  search ahead through the program line, starting with the       *
* character after ptr, and find either the end of the line or the next   *
* semi-colon that's not inside a quote or parenthesis                    *
**************************************************************************
    IN.PREN = @FALSE
    PREN.DEPTH = 0

    IN.BRACKET = @FALSE
    BRACKET.DEPTH = 0

    IN.DYNAMIC = @FALSE
    DYNAMIC.DEPTH = 0

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    END.PTR = PTR - 1

    FOUND.FOLLOWER.PTR = @FALSE

    FOLLOWER.SEPARATOR.LIST = ",":CLOSE.BRACE:OPEN.BRACE

    LOOP UNTIL FOUND.FOLLOWER.PTR DO

        END.PTR += 1
        PTR.CHAR = CLEAN.LINE [END.PTR, 1]

        IF PTR.CHAR <> "" AND INDEX(FOLLOWER.SEPARATOR.LIST, PTR.CHAR, 1) > 0 THEN
            SEPARATOR = @TRUE
        END ELSE
            SEPARATOR = @FALSE
        END

        BEGIN CASE

* we hit the end of the line
            CASE PTR.CHAR = ""
                FOUND.FOLLOWER.PTR = @TRUE

* hit the end of this line in a compound line
            CASE PTR.CHAR = ";" AND NOT(IN.QUOTES)
                FOUND.FOLLOWER.PTR = @TRUE

* hit an expression separator.  a logic structure is starting
            CASE SEPARATOR AND NOT(IN.QUOTES) AND NOT(IN.PREN) AND NOT(IN.BRACKET) AND NOT(IN.DYNAMIC)
                FOUND.FOLLOWER.PTR = @TRUE

* quotes
            CASE IN.QUOTES AND PTR.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""

            CASE IN.QUOTES
                NULL

            CASE PTR.CHAR = "'" OR PTR.CHAR = '"'
                THIS.QUOTE = PTR.CHAR
                IN.QUOTES = @TRUE

* parenthesis
            CASE PTR.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1

            CASE PTR.CHAR = ")" AND PREN.DEPTH <= 0
                FOUND.FOLLOWER.PTR = @TRUE
                PREN.DEPTH = 0

            CASE PTR.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END

* brackets
            CASE PTR.CHAR = "["
                IN.BRACKET = @TRUE
                BRACKET.DEPTH += 1

            CASE PTR.CHAR = "]" AND BRACKET.DEPTH <= 0
                FOUND.FOLLOWER.PTR = @TRUE
                BRACKET.DEPTH = 0

            CASE PTR.CHAR = "]"
                BRACKET.DEPTH -= 1
                IF BRACKET.DEPTH = 0 THEN
                    IN.BRACKET = @FALSE
                END

* dynamic array references
            CASE PTR.CHAR = "<"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.START.PTR = END.PTR
                    GOSUB CHECK.STARTING.DYNAMIC
                END ELSE
                    DYNAM.START = @TRUE
                END

                IF DYNAM.START THEN
                    IN.DYNAMIC = @TRUE
                    DYNAMIC.DEPTH += 1
                END

* if we hit a close ">" without an open we won't consider this the end of
* the expression as it gets confused with ">" as a "greater-than" sign
            CASE PTR.CHAR = ">" AND DYNAMIC.DEPTH <= 0
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = END.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYNAMIC.DEPTH = 0
                END

            CASE PTR.CHAR = ">"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = CLEAN.LINE
                    DYNAM.END.PTR = END.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYNAMIC.DEPTH -= 1
                    IF DYNAMIC.DEPTH = 0 THEN
                        IN.DYNAMIC = @FALSE
                    END
                END

        END CASE

    REPEAT

* if we don't have a space before and after where we're inserting our
* shortcut add one to keep things pretty
    SPACE.BEFORE = ""
    SPACE.AFTER = ""

    IF CLEAN.LINE [END.PTR - 1, 1] <> " " THEN
        SPACE.BEFORE = " "
    END

    IF CLEAN.LINE [END.PTR, 1] <> " " THEN
        SPACE.AFTER = " "
    END

* insert the following shortcut at the pointer, clean up any sloppy spaces
    CLEAN.LINE = CLEAN.LINE [1, END.PTR - 1]:SPACE.BEFORE:THIS.FOLLOW:SPACE.AFTER:CLEAN.LINE [END.PTR, TO.THE.END]

    CLEAN.LINE = SMART.TRIM(CLEAN.LINE)

    RETURN

CHECK.VARIABLE.NAME: *****************************************************
* test long.variable against the maximum variable name length.  if       *
* long.variable is too long build a shortened version of the name that   *
* hasn't been used before and update the variable name table.            *
*                                                                        *
* if the variable name is shortened the shortened name will be returned  *
* in short.variable.  if not the original name will be returned in       *
* short.variable                                                         *
**************************************************************************
    SHORT.VARIABLE = LONG.VARIABLE

    IF NOT(SHORTEN.LONG.VARIABLE.NAMES) THEN
        RETURN
    END

    IF LEN(LONG.VARIABLE) <= MAXIMUM.VARIABLE.LENGTH THEN
        RETURN
    END

* if we've already seen this long.variable before get the associated
* short.variable and return
    LOCATE LONG.VARIABLE IN LONG.VARIABLE.NAME.LIST SETTING VARIABLE.PTR THEN
        SHORT.VARIABLE = SHORT.VARIABLE.NAME.LIST<VARIABLE.PTR>
        RETURN
    END

* this.variable is too long.  create a shortened version that doesn't
* already exist in long.variable.name.list.  

* we'll create a shortened variable name a bit shorter than it has to be to
* allow for a unique counter if we need it.  if we need the counter
* increment it until we find a variable that isn't being used
    FOUND.UNIQUE.VARIABLE = @FALSE
    FOR VARIABLE.COUNTER = 1 TO 999 UNTIL FOUND.UNIQUE.VARIABLE

        SHORT.VARIABLE = LONG.VARIABLE [1, MAXIMUM.VARIABLE.LENGTH - 1 - LEN(VARIABLE.COUNTER)]
        SHORT.VARIABLE := ".":VARIABLE.COUNTER

        LOCATE SHORT.VARIABLE IN SHORT.VARIABLE.NAME.LIST SETTING SHORT.PTR ELSE
            GOSUB ADD.SHORT.VARIABLE
            RETURN
        END

    NEXT VARIABLE.COUNTER

    RETURN

ADD.SHORT.VARIABLE: ******************************************************
* add this.variable and short.variable to the variable xref list         *
**************************************************************************
    VARIABLE.NAME.COUNT += 1

    SHORT.VARIABLE.NAME.LIST<VARIABLE.NAME.COUNT> = SHORT.VARIABLE
    LONG.VARIABLE.NAME.LIST<VARIABLE.NAME.COUNT> = LONG.VARIABLE

    RETURN

CLEAN.AFTER.SHORTCUT: ****************************************************
* shortcuts sometimes leave a trailing semicolon for a compound line     *
* that isn't there.  this routine removes them                           *
**************************************************************************
    CLEAN.LINE = TRIM(CLEAN.LINE, " ", "T")

    LOOP UNTIL CLEAN.LINE [1] <> ";"
        CLEAN.LINE = CLEAN.LINE [1, LEN(CLEAN.LINE) - 1]
        CLEAN.LINE = TRIM(CLEAN.LINE, " ", "T")
    REPEAT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / dynamic array reference checking                   **
**************************************************************************
**************************************************************************

CHECK.STARTING.DYNAMIC: **************************************************
* if a "<" character is encountered when checking a code line for a      *
* shortcut or macro the character can be the start of a dynamic array    *
* reference or it could be a less-than sign.  which one it is depends    *
* on the contect of the program line.                                    *
*                                                                        *
* given DYNAM.CHECK.LINE and DYNAM.START.PTR that points to the "<"      *
* character this routine returns DYNAM.START true if "<" is starting a   *
* dynamic array reference                                                *
**************************************************************************

* starting at dyn.start.ptr look ahead for a closing ">" for every opening
* "<"
    CHECK.DYNAM.DEPTH = 0
    DYNAM.END.PTR = DYNAM.START.PTR - 1

    DYNAM.IN.QUOTES = @FALSE
    DYNAM.THIS.QUOTE = ""

    DYNAM.CHECK.FINISHED = @FALSE
    DYNAM.START = @FALSE

    LOOP UNTIL DYNAM.CHECK.FINISHED

        DYNAM.END.PTR += 1

        DYNAM.CHAR = DYNAM.CHECK.LINE [DYNAM.END.PTR, 1]

        BEGIN CASE

* we ran off the end of the line without finding the closing "<".  this
* must be a less-than sign
            CASE DYNAM.CHAR = ""
                DYNAM.START = @FALSE
                RETURN

* handle quotes
            CASE DYNAM.IN.QUOTES AND DYNAM.CHAR = DYNAM.THIS.QUOTE
                DYNAM.IN.QUOTES = @FALSE
            CASE DYNAM.IN.QUOTES
                NULL
            CASE DYNAM.CHAR = "'" OR DYNAM.CHAR = '"'
                DYNAM.IN.QUOTES = @TRUE
                DYNAM.THIS.QUOTE = DYNAM.CHAR

* hit a ";" character and we aren't in quotes.  this is a compound line
* and we hit the end of this code line
            CASE DYNAM.CHAR = ";" AND CHECK.DYNAM.DEPTH <> 0
                DYNAM.START = @FALSE
                RETURN
            CASE DYNAM.CHAR = ";"
                DYNAM.CHECK.FINISHED = @TRUE

* we hit a "<" character.  increase the nesting depth
            CASE DYNAM.CHAR = "<"
                CHECK.DYNAM.DEPTH += 1

* we hit a ">" character and we're at least two nesting levels deep.  
* decrease the nesting depth and keep looking
            CASE DYNAM.CHAR = ">" AND CHECK.DYNAM.DEPTH > 1
                CHECK.DYNAM.DEPTH -= 1

* we hit a ">" character and we aren't two nesting levels deep.  this
* closes the dynamic expression
            CASE DYNAM.CHAR = ">"
                CHECK.DYNAM.DEPTH -= 1
                DYNAM.CHECK.FINISHED = @TRUE

        END CASE

    REPEAT

* now the "< . . . >" expression is marked by dynam.start.ptr and
* dynam.end.ptr.  check this expression to see if it's a dynamic array
* reference or a set of less-than / greater-than expressions
    DYNAMIC.EXPRESSION = DYNAM.CHECK.LINE [DYNAM.START.PTR, DYNAM.END.PTR - DYNAM.START.PTR + 1]
    GOSUB CHECK.DYNAMIC.EXPRESSION
    DYNAM.START = IS.DYNAMIC

    RETURN

CHECK.ENDING.DYNAMIC: ****************************************************
* if a ">" character is encountered when checking a code line for a      *
* shortcut or macro the character can be the end of a dynamic array      *
* reference or it could be a greater-than sign.  which one it is depends *
* on the contect of the program line.                                    *
*                                                                        *
* given DYNAM.CHECK.LINE and DYNAM.END.PTR that points to the ">"        *
* character this routine returns DYNAM.END true if ">" is ending a       *
* dynamic array reference                                                *
**************************************************************************

* starting at dyn.start.ptr look ahead for a closing ">" for every opening
* "<"
    CHECK.DYNAM.DEPTH = 0
    DYNAM.START.PTR = DYNAM.END.PTR + 1

    DYNAM.IN.QUOTES = @FALSE
    DYNAM.THIS.QUOTE = ""

    DYNAM.CHECK.FINISHED = @FALSE
    DYNAM.END = @FALSE

    LOOP UNTIL DYNAM.CHECK.FINISHED

        DYNAM.START.PTR -= 1

        DYNAM.CHAR = DYNAM.CHECK.LINE [DYNAM.START.PTR, 1]

        BEGIN CASE

* we ran off the beginning of the line without finding the closing "<".  this
* must be a greater-than sign
            CASE DYNAM.START.PTR = 0
                DYNAM.END = @FALSE
                RETURN

* handle quotes
            CASE DYNAM.IN.QUOTES AND DYNAM.CHAR = DYNAM.THIS.QUOTE
                DYNAM.IN.QUOTES = @FALSE
            CASE DYNAM.IN.QUOTES
                NULL
            CASE DYNAM.CHAR = "'" OR DYNAM.CHAR = '"'
                DYNAM.IN.QUOTES = @TRUE
                DYNAM.THIS.QUOTE = DYNAM.CHAR

* hit a ";" character and we aren't in quotes.  this is a compound line
* and we hit the beginning of this code line
            CASE DYNAM.CHAR = ";" AND CHECK.DYNAM.DEPTH <> 0
                DYNAM.START = @FALSE
                RETURN
            CASE DYNAM.CHAR = ";"
                DYNAM.CHECK.FINISHED = @TRUE

* we hit a ">" character.  increase the nesting depth
            CASE DYNAM.CHAR = ">"
                CHECK.DYNAM.DEPTH += 1

* we hit a "<" character and we're at least two nesting levels deep.  
* decrease the nesting depth and keep looking
            CASE DYNAM.CHAR = "<" AND CHECK.DYNAM.DEPTH > 1
                CHECK.DYNAM.DEPTH -= 1

* we hit a "<" character and we aren't two nesting levels deep.  this
* closes the dynamic expression
            CASE DYNAM.CHAR = "<"
                CHECK.DYNAM.DEPTH -= 1
                DYNAM.CHECK.FINISHED = @TRUE

        END CASE

    REPEAT

* now the "< . . . >" expression is marked by dynam.start.ptr and
* dynam.end.ptr.  check this expression to see if it's a dynamic array
* reference or a set of less-than / greater-than expressions
    DYNAMIC.EXPRESSION = DYNAM.CHECK.LINE [DYNAM.START.PTR, DYNAM.END.PTR - DYNAM.START.PTR + 1]
    GOSUB CHECK.DYNAMIC.EXPRESSION
    DYNAM.END = IS.DYNAMIC

    RETURN

CHECK.DYNAMIC.EXPRESSION: ************************************************
* dynamic.expression is a string beginning with "<" and ending with ">". *
* test to see if it's actually a dynamic array expression or if it's     *
* really part of two logical expressions, a less-than and a              *
* greater-than.  returns is.dynamic true if it's a dynamic expression    *
**************************************************************************
    IS.DYNAMIC = @TRUE

* check for things inside the "<" and ">" that indicate that this is not
* a dynamic expression
    BEGIN CASE

* if the expression is "<>" it's really a "not equals"
        CASE DYNAMIC.EXPRESSION = "<>"
            IS.DYNAMIC = @FALSE

* if the expression is a simple numeric value then it's a dynamic expression
        CASE NUM(DYNAMIC.EXPRESSION [2, LEN(DYNAMIC.EXPRESSION) - 2])
            IS.DYNAMIC = @TRUE

* logical expressions
        CASE INDEX(DYNAMIC.EXPRESSION, " AND ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " OR ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " & ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " | ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " AND ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " ANDALSO ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " &+ ", 1) > 0
            IS.DYNAMIC = @FALSE

* a "then" or "else" could indicate a complex if statement
        CASE INDEX(DYNAMIC.EXPRESSION, " THEN ", 1) > 0
            IS.DYNAMIC = @FALSE
        CASE INDEX(DYNAMIC.EXPRESSION, " ELSE ", 1) > 0
            IS.DYNAMIC = @FALSE

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** code analysis / keyword utilities                                    **
**************************************************************************
**************************************************************************

IS.PROPERTY.KEYWORD: *****************************************************
* check decode.keyword to see if it's a keyword that indicates this      *
* program line declares properties that should be added to the property  *
* table.  any decode.keyword that declare a property or static will      *
* return is.property or is.statuc true.  if the keyword declares a       *
* property that's a handle (as opposed to a normal variable) is.handle   *
* returns true                                                           *
**************************************************************************
    IS.PROPERTY = @FALSE
    IS.LOCAL = @FALSE
    IS.STATIC = @FALSE
    IS.HANDLE = @FALSE

    BEGIN CASE

* property keywords
        CASE DECODE.KEYWORD = PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE

        CASE DECODE.KEYWORD = FILE.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.HANDLE = @TRUE

        CASE DECODE.KEYWORD = LIST.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.HANDLE = @TRUE

* local properties
        CASE DECODE.KEYWORD = LOCAL.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.FILE.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.HANDLE = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.LIST.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.HANDLE = @TRUE
            IS.LOCAL = @TRUE

* static keywords
        CASE DECODE.KEYWORD = STATIC.KEYWORD
            IS.STATIC = @TRUE

        CASE DECODE.KEYWORD = FILE.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.HANDLE = @TRUE

        CASE DECODE.KEYWORD = LIST.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.HANDLE = @TRUE

* local static keywords
        CASE DECODE.KEYWORD = LOCAL.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.FILE.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.HANDLE = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.LIST.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.HANDLE = @TRUE
            IS.LOCAL = @TRUE

    END CASE

    RETURN

IS.CONSTANT.KEYWORD: *****************************************************
* check decode.keyword to see if it's a keyword that indicates this      *
* program line declares constants that should be added to the constant   *
* table.  any decode.keyword that declares a constant will return        *
* is.constant true                                                       *
**************************************************************************
    IS.CONSTANT = @FALSE

    BEGIN CASE

        CASE DECODE.KEYWORD = CONSTANT.KEYWORD
            IS.CONSTANT = @TRUE

        CASE DECODE.KEYWORD = LOCAL.CONSTANT.KEYWORD
            IS.CONSTANT = @TRUE

    END CASE

    RETURN

IS.CHILD.KEYWORD: ********************************************************
* check decode.keyword to see if it's a keyword that indicates this      *
* program line declares a child that should be added to the child table. *
* any decode.keyword that declares a child will return is.child true     *
*                                                                        *
* keyword           is.child      is.intime                              *
*                                                                        *
* CHILD                 x                                                *
* LOCAL.CHILD           x                                                *
* INTIME.CHILD          x              x                                 *
* LOCAL.INTIME.CHILD    x              x                                 *
**************************************************************************
    IS.CHILD = @FALSE
    IS.INTIME = @FALSE

    BEGIN CASE

        CASE DECODE.KEYWORD = CHILD.KEYWORD
            IS.CHILD = @TRUE

        CASE DECODE.KEYWORD = LOCAL.CHILD.KEYWORD
            IS.CHILD = @TRUE

        CASE DECODE.KEYWORD = INTIME.CHILD.KEYWORD
            IS.CHILD = @TRUE
            IS.INTIME = @TRUE

        CASE DECODE.KEYWORD = LOCAL.INTIME.CHILD.KEYWORD
            IS.CHILD = @TRUE
            IS.INTIME = @TRUE

    END CASE

    RETURN

DECODE.PROPERTY: *********************************************************
* based on decode.keyword return flags as to what kind of property the   *
* keyword defines:                                                       *
*                                                                        *
* keyword          property static constant child    local file list old *
*                                                                        *
* PROPERTY            x                                                  *
* LOCAL.PROPERTY      x                                x                 *
* FILE.PROPERTY       x                                      x           *
* LIST.PROPERTY       x                                          x       *
* LOCAL.FILE.PROPERTY x                                x     x           *
* LOCAL.LIST.PROPERTY x                                x         x       *
*                                                                        *
* STATIC                       x                                         *
* LOCAL.STATIC                 x                       x                 *
* FILE.STATIC                  x                             x           *
* LIST.STATIC                  x                                 x       *
* LOCAL.FILE.STATIC            x                       x     x           *
* LOCAL.LIST.STATIC            x                       x         x       *
*                                                                        *
* CONSTANT                              x                                *
* LOCAL.CONSTANT                        x              x                 *
*                                                                        *
* CHILD                                       x                          *
* LOCAL.CHILD                                 x        x                 *
* INTIME.CHILD                                x                       x  *
*     local will be set if intime.child.objects.local is set             *
* LOCAL.INTIME.CHILD                          x        x              x  *
**************************************************************************
    IS.PROPERTY = @FALSE
    IS.STATIC = @FALSE
    IS.CHILD = @FALSE
    IS.CONSTANT = @FALSE

    IS.LOCAL = @FALSE

    IS.FILE = @FALSE
    IS.LIST = @FALSE

    IS.INTIME = @FALSE

    BEGIN CASE

* property keywords
        CASE DECODE.KEYWORD = PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE

        CASE DECODE.KEYWORD = LOCAL.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = FILE.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.FILE = @TRUE

        CASE DECODE.KEYWORD = LIST.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.LIST = @TRUE

        CASE DECODE.KEYWORD = LOCAL.FILE.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.FILE = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.LIST.PROPERTY.KEYWORD
            IS.PROPERTY = @TRUE
            IS.LIST = @TRUE
            IS.LOCAL = @TRUE

* static keywords
        CASE DECODE.KEYWORD = STATIC.KEYWORD
            IS.STATIC = @TRUE

        CASE DECODE.KEYWORD = LOCAL.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = FILE.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.FILE = @TRUE

        CASE DECODE.KEYWORD = LIST.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.LIST = @TRUE

        CASE DECODE.KEYWORD = LOCAL.FILE.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.FILE = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = LOCAL.LIST.STATIC.KEYWORD
            IS.STATIC = @TRUE
            IS.LOCAL = @TRUE
            IS.LIST = @TRUE

* constant keywords
        CASE DECODE.KEYWORD = CONSTANT.KEYWORD
            IS.CONSTANT = @TRUE

        CASE DECODE.KEYWORD = LOCAL.CONSTANT.KEYWORD
            IS.CONSTANT = @TRUE
            IS.LOCAL = @TRUE

* child keywords
        CASE DECODE.KEYWORD = CHILD.KEYWORD
            IS.CHILD = @TRUE

        CASE DECODE.KEYWORD = LOCAL.CHILD.KEYWORD
            IS.CHILD = @TRUE
            IS.LOCAL = @TRUE

        CASE DECODE.KEYWORD = INTIME.CHILD.KEYWORD
            IS.CHILD = @TRUE
            IS.INTIME = @TRUE
            IF INTIME.CHILD.OBJECTS.LOCAL THEN
                IS.LOCAL = @TRUE
            END

        CASE DECODE.KEYWORD = LOCAL.INTIME.CHILD.KEYWORD
            IS.CHILD = @TRUE
            IS.LOCAL = @TRUE
            IS.INTIME = @TRUE

    END CASE

    RETURN

IS.METHOD.KEYWORD: *******************************************************
* check decode.keyword to see if it's a method keyword                   *
**************************************************************************
    IS.METHOD = @FALSE

    BEGIN CASE

* methods
        CASE DECODE.KEYWORD = METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = LOCAL.METHOD.KEYWORD
            IS.METHOD = @TRUE

        CASE DECODE.KEYWORD = INLINE.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = LOCAL.INLINE.METHOD.KEYWORD
            IS.METHOD = @TRUE

* wrappers
        CASE DECODE.KEYWORD = WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = TCL.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = DRIVER.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = PHANTOM.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = ROUTINE.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
        CASE DECODE.KEYWORD = INHERIT.KEYWORD
            IS.METHOD = @TRUE

    END CASE 

    RETURN

DECODE.METHOD: ***********************************************************
* based on decode.keyword return flags as to what kind of method the     *
* keyword defines:                                                       *
*                                                                        *
* keyword      method local inline wrapper tcl driver phantom routine    *
* METHOD          x                                                      *
* LOCAL.METHOD    x     x                                                *
* INLINE          x            x                                         *
* LOCAL.INLINE    x     x      x                                         *
* WRAPPER         x                   x                                  *
* TCL.WRAPPER     x                   x     x                            *
* DRIVER.WRAPPER  x                   x           x                      *
* PHANTOM.WRAPPER x                   x                  x               *
* ROUTINE         x                   x                          x       *
* INHERITED       x                                    inherited: x      *
* INHERIT                                              inherit.from:   x *
*                                                                        *
* keyword        section  subroutine  object  ph.args                    *
* SECTION           x                                                    *
* SUBROUTINE                   x                                         *
* OBJECT                                 x                               *
* PH.ARGS                                         x                      *
**************************************************************************
    IS.METHOD = @FALSE
    IS.INLINE = @FALSE
    IS.LOCAL.METHOD = @FALSE

    IS.WRAPPER = @FALSE

    IS.TCL = @FALSE
    IS.DRIVER = @FALSE
    IS.PHANTOM = @FALSE
    IS.ROUTINE = @FALSE

    IS.SECTION = @FALSE

    IS.SUBROUTINE = @FALSE

    IS.OBJECT = @FALSE

    IS.PH.ARGS = @FALSE

    IS.INHERITED = @FALSE
    IS.INHERITED.FROM = @FALSE

    IS.NOTHING = @FALSE

    BEGIN CASE

* methods
        CASE DECODE.KEYWORD = METHOD.KEYWORD
            IS.METHOD = @TRUE

        CASE DECODE.KEYWORD = LOCAL.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.LOCAL.METHOD = @TRUE

        CASE DECODE.KEYWORD = INLINE.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.INLINE = @TRUE

        CASE DECODE.KEYWORD = LOCAL.INLINE.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.INLINE = @TRUE
            IS.LOCAL.METHOD = @TRUE

* wrappers
        CASE DECODE.KEYWORD = WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.WRAPPER = @TRUE

        CASE DECODE.KEYWORD = TCL.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.WRAPPER = @TRUE
            IS.TCL = @TRUE

        CASE DECODE.KEYWORD = DRIVER.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.WRAPPER = @TRUE
            IS.DRIVER = @TRUE

        CASE DECODE.KEYWORD = PHANTOM.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.WRAPPER = @TRUE
            IS.PHANTOM = @TRUE

        CASE DECODE.KEYWORD = ROUTINE.WRAPPER.METHOD.KEYWORD
            IS.METHOD = @TRUE
            IS.WRAPPER = @TRUE
            IS.ROUTINE = @TRUE

* inherited method
        CASE DECODE.KEYWORD = INHERIT.FROM.KEYWORD
            IS.INHERITED.FROM = @TRUE

        CASE DECODE.KEYWORD = INHERIT.KEYWORD
            IS.METHOD = @TRUE
            IS.INHERITED = @TRUE

* sections
        CASE DECODE.KEYWORD = SECTION.KEYWORD
            IS.SECTION = @TRUE

* object type definitions
        CASE DECODE.KEYWORD = "SUBROUTINE"
            IS.SUBROUTINE = @TRUE

        CASE DECODE.KEYWORD = "OBJECT"
            IS.OBJECT = @TRUE

        CASE DECODE.KEYWORD = "PH.ARGS"
            IS.PH.ARGS = @TRUE

        CASE 1
            IS.NOTHING = @TRUE

    END CASE 

    RETURN 


**************************************************************************
**************************************************************************
** code conversion / code expanding / dynamic array assignments         **
**************************************************************************
**************************************************************************

CONVERT.ARRAY.ASSIGNMENTS: ***********************************************
* convert dynamic array assignments in this form:                        *
*                                                                        *
* variable = [attr1, attr2, attr3 . . . ]                                *
*                                                                        *
* this form will set variable equal to a dynamic array with attr1 being  *
* the first attrbiute, attr2 the second, attr3 the third, etc            *
*                                                                        *
* variable := [attr1, attr2, attr3 . . .]                                *
*                                                                        *
* this form will append attributes attr1, attr2, attr3, etc as new       *
* attributes at the end of variable                                      *
**************************************************************************

* build a table of line numbers and new code here
    ARRAY.LINE.LIST = ""
    ARRAY.CODE.LIST = ""
    ARRAY.CODE.COUNT = 0

    SETREM 0 ON PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any associated lists in it
        TRIM.THIS.LINE = TRIM(THIS.LINE)

        IF TRIM.THIS.LINE <> "" AND TRIM.THIS.LINE [1, 1] <> "*" AND TRIM.THIS.LINE [1, 1] <> "!" THEN

            IF IS.CODE(THIS.LINE) THEN

                CLEAN.LINE = THIS.LINE
                GOSUB CLEAN.LINE

                BEGIN CASE
                    CASE INDEX(CLEAN.LINE, ":= [", 1) <> 0 AND CLEAN.LINE [1] = "]"
                        ASSIGNMENT.OPERATOR = ":="
                        GOSUB CONVERT.ARRAY.LINE
                    CASE INDEX(CLEAN.LINE, "= [", 1) <> 0 AND CLEAN.LINE [1] = "]"
                        ASSIGNMENT.OPERATOR = "="
                        GOSUB CONVERT.ARRAY.LINE
                END CASE

            END

        END

    NEXT LINE.LOOP

    IF ARRAY.CODE.COUNT > 0 THEN
        GOSUB CONVERT.ARRAY.CODE
    END

    RETURN

CONVERT.ARRAY.LINE: ******************************************************
* convert a program line that has an array assignment                    *
**************************************************************************
    THIS.LINE.LABEL = LINE.LABEL (CLEAN.LINE)

    IF THIS.LINE.LABEL <> "" THEN
        CLEAN.LINE = LINE.WITHOUT.LABEL (CLEAN.LINE)
    END

    INDENT.COUNT = FIND.INDENT.COUNT (THIS.LINE.LABEL, THIS.LINE)

* extract the assigned variable
    ARRAY.VARIABLE = CLEAN.LINE [1, INDEX(CLEAN.LINE, ASSIGNMENT.OPERATOR, 1) - 1]
    ARRAY.VARIABLE = TRIM(ARRAY.VARIABLE)

* find the start of the array's attribute list
    START.PTR = INDEX(CLEAN.LINE, "[", 1) + 1

* remove the closing bracket
    CLEAN.LINE = CLEAN.LINE [1, LEN(CLEAN.LINE) - 1]

* extract the attribute list and build code to set the variable to a
* dynamic array made up of the attribute list
    ATTRIBUTE.LIST = SPLIT.PARAMETERS (CLEAN.LINE [START.PTR, TO.THE.END])
    ATTRIBUTE.COUNT = DCOUNT(ATTRIBUTE.LIST, @AM)
    NEW.CODE = ""

* does the assigned variable have dynamic array assignments?  if so we
* may be assigning values or subvalues.  if we're assigning values or
* subvalues remove the trailing ">".  if we're assigning attributes
* add a "<" to the end of the variable
    IF COUNT(ARRAY.VARIABLE, "<") > 0 AND ARRAY.VARIABLE [1] = ">" THEN
        SECOND.VARIABLE = ARRAY.VARIABLE [1, LEN(ARRAY.VARIABLE) - 1]:","
    END ELSE
        SECOND.VARIABLE = ARRAY.VARIABLE:"<"
    END

* find the delimiter for this array given second.variable
    COMMA.COUNT = COUNT(SECOND.VARIABLE ["<", 2, 100], ",")

    BEGIN CASE
        CASE COMMA.COUNT = 0
            ARRAY.DELIMITER = "@AM"
        CASE COMMA.COUNT = 1
            ARRAY.DELIMITER = "@VM"
        CASE COMMA.COUNT = 2
            ARRAY.DELIMITER = "@SM"
        CASE 1
            ARRAY.DELIMITER = "@AM"
    END CASE

    FOR ATTRIBUTE.LOOP = 1 TO ATTRIBUTE.COUNT

        BEGIN CASE

* assigned with the "=" operator:
*     this is the first attribute in the list
            CASE ATTRIBUTE.LOOP = 1 AND ASSIGNMENT.OPERATOR = "="
                NEW.CODE = THIS.LINE.LABEL:SPACE(INDENT.COUNT)
                NEW.CODE := ARRAY.VARIABLE:" = ":ATTRIBUTE.LIST<ATTRIBUTE.LOOP>

*     this is the second attribute in the list or later.  append to the
*     dynamic array
            CASE ASSIGNMENT.OPERATOR = "="
                NEW.CODE := " ; "
                NEW.CODE := SECOND.VARIABLE:ATTRIBUTE.LOOP:"> = ":ATTRIBUTE.LIST<ATTRIBUTE.LOOP>

* assigned with the ":=" operator
*     this is the first attribute in the list
            CASE ATTRIBUTE.LOOP = 1 AND ASSIGNMENT.OPERATOR = ":="
                NEW.CODE = THIS.LINE.LABEL:SPACE(INDENT.COUNT)
                NEW.CODE := "ARRAY.BUILD.COUNT = DCOUNT(":ARRAY.VARIABLE:", ":ARRAY.DELIMITER:") ; "
                NEW.CODE := SECOND.VARIABLE:"ARRAY.BUILD.COUNT+":ATTRIBUTE.LOOP:"> = ":ATTRIBUTE.LIST<ATTRIBUTE.LOOP>

*     this is the second attribute in the list or later.  append to the
*     dynamic array
            CASE ASSIGNMENT.OPERATOR = ":="
                NEW.CODE := " ; "
                NEW.CODE := SECOND.VARIABLE:"ARRAY.BUILD.COUNT+":ATTRIBUTE.LOOP:"> = ":ATTRIBUTE.LIST<ATTRIBUTE.LOOP>

        END CASE

    NEXT ATTRIBUTE.LOOP

* add to code table
    ARRAY.CODE.COUNT += 1
    ARRAY.CODE.LIST<ARRAY.CODE.COUNT> = NEW.CODE
    ARRAY.LINE.LIST<ARRAY.CODE.COUNT> = LINE.LOOP

    RETURN

CONVERT.ARRAY.CODE: ******************************************************
* replace code lines in program.code with new lines from the array       *
* code table                                                             *
**************************************************************************
    FOR ARRAY.CODE.LOOP = 1 TO ARRAY.CODE.COUNT

        LINE.PTR = ARRAY.LINE.LIST<ARRAY.CODE.LOOP>
        NEW.CODE = ARRAY.CODE.LIST<ARRAY.CODE.LOOP>
        PROGRAM.CODE<LINE.PTR> = NEW.CODE

    NEXT ARRAY.CODE.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / associated variables              **
**************************************************************************
**************************************************************************

CONVERT.ASSOCIATED: ******************************************************
* convert program.code for assicated references                          *
**************************************************************************
    ASSOC.START.DATE = DATE()
    ASSOC.START.TIME = TIME()

    GOSUB BUILD.ASSOCIATED.LIST

    IF ASSOCIATED.COUNT = 0 THEN
        RETURN
    END

    GOSUB CONVERT.ASSOCIATED.LINES
    GOSUB CONVERT.ASSOCIATED.CODE

    ASSOC.END.DATE = DATE()
    ASSOC.END.TIME = TIME()
    ASSOC.ELAPSED.TIME += TIME.ELAPSED (ASSOC.START.DATE, ASSOC.START.TIME)

    RETURN

BUILD.ASSOCIATED.LIST: ***************************************************
* build a table of associated tables from program.code                   *
**************************************************************************
    ASSOCIATED.NAME.LIST = ""
    ASSOCIATED.VARIABLE.LIST = ""
    ASSOCIATED.VARIABLE.COUNT.LIST = ""
    ASSOCIATED.OCONV.LIST = ""
    ASSOCIATED.LINE.LIST = ""
    ASSOCIATED.COUNT = 0

* table of lines in the program to replace.  if we replace lines as we
* go we can't use the "remove" statement and it's slow
    REPLACE.LINE.LIST = ""
    REPLACE.LINE.NEW.LIST = ""
    REPLACE.LINE.COUNT = 0

    SETREM 0 ON PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any associated lists in it
        IF IS.CODE(THIS.LINE) THEN

            CLEAN.LINE = THIS.LINE
            GOSUB CLEAN.LINE

* line should be in this format:
*    associated table.name = var1, var2, var3, etc
* if we have the associated keyword as the first field and an equals sign
* for the third then we have an associated line
            KEY.WORD = CLEAN.LINE [" ", 1, 1]
            THIRD.WORD = CLEAN.LINE [" ", 3, 1]

* if we have the associated keyword process it as a "normal" associated
* definition.  otherwise look for on-the-fly associations
            IF UPCASE(KEY.WORD) = ASSOCIATED.KEYWORD AND THIRD.WORD = "=" THEN
                GOSUB PROCESS.ASSOCIATED.CODE.LINE
            END ELSE
                GOSUB PROCESS.TEMP.ASSOCIATIONS
            END

        END

    NEXT LINE.LOOP

* if we changed any code lines due to on-the-fly associations replace the
* old code lines with the new
    FOR LINE.LOOP = 1 TO REPLACE.LINE.COUNT
        LINE.PTR = REPLACE.LINE.LIST<LINE.LOOP>
        PROGRAM.CODE<LINE.PTR> = REPLACE.LINE.NEW.LIST<LINE.LOOP>
    NEXT LINE.LOOP

    IF DETAILS THEN
        GOSUB PRINT.ASSOCIATED.TABLE
    END

    RETURN

PROCESS.ASSOCIATED.CODE.LINE: ********************************************
* process a code line with an associated keyword.  looks for associated  *
* definitions in this format:                                            *
*     ASSOCIATED associated.name = var1, var2, var3 . . .                *
**************************************************************************

* get table name.  line should be in this format:
*    associated table.name = var1, var2, var3, etc
    THIS.ASSOCIATED.NAME = CLEAN.LINE [" ", 2, 1]

* get list of associated variables
    THIS.VARIABLE.PHRASE = CLEAN.LINE [" ", 4, TO.THE.END]
    THIS.VARIABLE.LIST = SPLIT.PARAMETERS(THIS.VARIABLE.PHRASE)

    THIS.OCONV.LIST = ""
    THIS.VARIABLE.COUNT = DCOUNT(THIS.VARIABLE.LIST, @AM)

* if any of these variables in the associated list have a conversion
* remove the conversion from the variable list and update the
* conversion list
    FOR VARIABLE.LOOP = 1 TO THIS.VARIABLE.COUNT

        THIS.VARIABLE = THIS.VARIABLE.LIST<VARIABLE.LOOP>

        THIS.OCONV = TRIM(THIS.VARIABLE [ASSOCIATED.OCONV.DELIMITER, 2, TO.THE.END])
        THIS.OCONV = CHANGE(THIS.OCONV, ASSOCIATED.OCONV.DELIMITER, @VM)

        THIS.VARIABLE.LIST<VARIABLE.LOOP> = TRIM(THIS.VARIABLE [ASSOCIATED.OCONV.DELIMITER, 1, 1])
        THIS.OCONV.LIST<VARIABLE.LOOP> = THIS.OCONV

    NEXT VARIABLE.LOOP

* give warning if we've already seen this table name
    LOCATE THIS.ASSOCIATED.NAME IN ASSOCIATED.NAME.LIST SETTING THROWAWAY THEN
        OBJECT.WARNING.DESC = "Associated Name '":THIS.ASSOCIATED.NAME:"' defined twice!"
        OBJECT.WARNING.LINE = LINE.LOOP
        GOSUB PRINT.OBJECT.WARNING
    END

* add table to the associated table list
    ASSOCIATED.COUNT += 1

    ASSOCIATED.NAME.LIST<ASSOCIATED.COUNT> = THIS.ASSOCIATED.NAME
    ASSOCIATED.VARIABLE.LIST<ASSOCIATED.COUNT> = LOWER(THIS.VARIABLE.LIST)
    ASSOCIATED.OCONV.LIST<ASSOCIATED.COUNT> = LOWER(THIS.OCONV.LIST)
    ASSOCIATED.VARIABLE.COUNT.LIST<ASSOCIATED.COUNT> = THIS.VARIABLE.COUNT
    ASSOCIATED.LINE.LIST<ASSOCIATED.COUNT> = LINE.LOOP

    RETURN

PROCESS.TEMP.ASSOCIATIONS: ***********************************************
* watch for braces with more than one parameter between them, ie:        *
* {var1, var2, var3, . . .}.  if we see one of these make a "temporary"  *
* associated variable so that we can define associated sets on the fly   *
**************************************************************************

* build a list of associated variables, separated by commas
    THIS.VARIABLE = ""
    THIS.VARIABLE.LIST = ""
    THIS.OCONV.LIST = ""
    THIS.VARIABLE.COUNT = 0

* keep track of any brace expressions
    IN.BRACE = @FALSE
    BRACE.SET.START.PTR = 0
    BRACE.SET.END.PTR = 0
    BRACE.SET.PARAMETER.COUNT = 0
    FOUND.TEMPORARY.ASSOCIATED = @FALSE

* if there are no braces in the program line we can't have any temporary
* associations
    IF COUNT(THIS.LINE, "{") = 0 THEN
        RETURN
    END
    IF COUNT(THIS.LINE, "}") = 0 THEN
        RETURN
    END

* keep track of how deep we are in parenthesis, dynamic array
* references and quotes
    PREN.DEPTH = 0
    DYNAMIC.DEPTH = 0
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    LINE.LENGTH = LEN(THIS.LINE)

    FOR PTR = 1 TO LINE.LENGTH

        THIS.CHAR = THIS.LINE [PTR, 1]
        ADD.THIS.CHAR = @TRUE

        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* we hit an open brace ("{").  this could be the start of a
* temporary associated set definition or it could be a structure.
* set our brace variables and try to accumulate a variable list
            CASE THIS.CHAR = "{"
                BRACE.SET.START.PTR = PTR
                IN.BRACE = @TRUE

                THIS.VARIABLE = ""
                THIS.VARIABLE.LIST = ""
                THIS.OCONV.LIST = ""
                THIS.VARIABLE.COUNT = 0

                ADD.THIS.CHAR = @FALSE

* we hit a closed brace ("}") and we're inside a brace expression.
* this could be the end of a temporary associated set or it could
* just be the end of a structure.  if the variable count is more
* than one then we have multiple variable expressions inside the
* braces so we'll consider it a temporary association
            CASE THIS.CHAR = "}" AND IN.BRACE
                BRACE.SET.END.PTR = PTR
                BRACE.SET.LENGTH = BRACE.SET.END.PTR - BRACE.SET.START.PTR - 1
                BRACE.STRING = THIS.LINE [BRACE.SET.START.PTR + 1, BRACE.SET.LENGTH]

                THIS.VARIABLE.LIST = SPLIT.PARAMETERS (BRACE.STRING)
                THIS.VARIABLE.COUNT = DCOUNT(THIS.VARIABLE.LIST, @AM)

                IF THIS.VARIABLE.COUNT > 1 THEN
                    GOSUB ADD.TEMPORARY.ASSOCIATED.VARIABLE
                END

                IN.BRACE = @FALSE
                THIS.VARIABLE = ""
                THIS.VARIABLE.LIST = ""
                THIS.OCONV.LIST = ""
                THIS.VARIABLE.COUNT = 0

                ADD.THIS.CHAR = @FALSE

* don't think I need to count the rest of this
            CASE 1
                NULL

* parenthesis
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH < 0 THEN
                    PREN.DEPTH = 0
                END

* dynamic array reference
            CASE THIS.CHAR = "<"
                DYNAMIC.DEPTH += 1
            CASE THIS.CHAR = ">"
                DYNAMIC.DEPTH -= 1
                IF DYNAMIC.DEPTH < 0 THEN
                    DYNAMIC.DEPTH = 0
                END

* we're inside a parenthesis set or a dynamic array reference
            CASE PREN.DEPTH <> 0
                NULL
            CASE DYNAMIC.DEPTH <> 0
                NULL

        END CASE

* update the variable name (so far) for this reference
        IF ADD.THIS.CHAR THEN
            THIS.VARIABLE := THIS.CHAR
        END

    NEXT PTR

    RETURN

ADD.TEMPORARY.ASSOCIATED.VARIABLE: ***************************************
* add a "temporary" associated variable to the list and change           *
* clean.line to have the temporary associated variable reference in      *
* place of the variable list                                             *
**************************************************************************

* create unique "temporary" name for the temporary associated set.  we'll
* pad the associated counter variable to four places because later code
* searches for associated variables by an index() statement.  we don't
* want "TEMP.ASSOCIATED.1" to be found when "TEMP.ASSOCIATED.10" is the
* real associated name
    TEMPORARY.ASSOCIATED.COUNTER += 1
    THIS.ASSOCIATED.NAME = "TEMP.ASSOCIATED.":TEMPORARY.ASSOCIATED.COUNTER "R%4"

* add table to the associated table list.  normally associated lines are
* commented out but if this is an on-the-fly associated list we don't want
* to comment out the line so we'll make the line number 0
    ASSOCIATED.COUNT += 1

    ASSOCIATED.NAME.LIST<ASSOCIATED.COUNT> = THIS.ASSOCIATED.NAME
    ASSOCIATED.VARIABLE.LIST<ASSOCIATED.COUNT> = LOWER(THIS.VARIABLE.LIST)
    ASSOCIATED.OCONV.LIST<ASSOCIATED.COUNT> = ""
    ASSOCIATED.VARIABLE.COUNT.LIST<ASSOCIATED.COUNT> = THIS.VARIABLE.COUNT
    ASSOCIATED.LINE.LIST<ASSOCIATED.COUNT> = 0

* replace expression in THIS.LINE with the new temporary associated
* variable name
    THIS.LINE = THIS.LINE [1, BRACE.SET.START.PTR - 1]:THIS.ASSOCIATED.NAME:THIS.LINE [BRACE.SET.END.PTR + 1, TO.THE.END]

* set flag so that calling routine knows THIS.LINE was changed
    FOUND.TEMPORARY.ASSOCIATED = @TRUE

* adjust ptr for the change in THIS.LINE length
    PTR = PTR - (BRACE.SET.END.PTR - BRACE.SET.START.PTR + 1) + LEN(THIS.ASSOCIATED.NAME)
    LINE.LENGTH = LEN(THIS.LINE)

* add this line to the list of program lines to replace later
    LOCATE LINE.LOOP IN REPLACE.LINE.LIST SETTING REPLACE.PTR ELSE
        REPLACE.LINE.COUNT += 1
        REPLACE.PTR = REPLACE.LINE.COUNT
    END

    REPLACE.LINE.LIST<REPLACE.PTR> = LINE.LOOP
    REPLACE.LINE.NEW.LIST<REPLACE.PTR> = THIS.LINE

    RETURN

CONVERT.ASSOCIATED.LINES: ************************************************
* convert all associated code lines to comments                          *
**************************************************************************

* convert each program line
    FOR TABLE.LOOP = 1 TO ASSOCIATED.COUNT

        CODE.PTR = ASSOCIATED.LINE.LIST<TABLE.LOOP>

        IF CODE.PTR > 0 THEN

            THIS.LINE = PROGRAM.CODE<CODE.PTR>
            CLEAN.LINE = THIS.LINE
            GOSUB CLEAN.LINE

            IF CLEAN.LABEL = "" THEN
                NEW.LINE = "* ":THIS.LINE
            END ELSE
                NEW.LINE = CLEAN.LABEL:": * ":CLEAN.LINE
            END

            PROGRAM.CODE<CODE.PTR> = NEW.LINE

        END

    NEXT TABLE.LOOP

    RETURN

CONVERT.ASSOCIATED.CODE: *************************************************
* convert associated tables code in program.code                         *
**************************************************************************
    IF ASSOCIATED.COUNT = 0 THEN
        RETURN
    END

* copy program.code to old.program.code so that we can use a remove
* statement on it.  we'll be changing program.code and that would reset
* the remove pointer.

* old.line.loop will point to the line being read in old.program.code.
* line.loop will point to the line in program.code. a line in old.program.code
* may expand into multiple lines so two pointers are needed
    LINE.LOOP = 0
    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR OLD.LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        LINE.LOOP += 1

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any associated lists in it
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            CLEAN.LINE = THIS.LINE
            GOSUB CLEAN.LINE

* see how many spaces are to the left of the code
            INDENT.COUNT = FIND.INDENT.COUNT (CLEAN.LABEL, THIS.LINE)

            GOSUB CONVERT.ASSOCIATED.CODE.LINE

* if we got new code back and AllOnOneLine is set convert the added code to
* one giant line and add it into the program.  otherwise add it as separate
* code lines
            IF NEW.CODE.COUNT > 0 THEN

                IF ALL.ON.ONE.LINE THEN

                    THIS.LINE = NEW.CODE<1>
                    FOR NEW.CODE.LOOP = 2 TO NEW.CODE.COUNT
                        THIS.LINE := " ; ":TRIM(NEW.CODE<NEW.CODE.LOOP>, " ", "B")
                    NEXT NEW.CODE.LOOP

                    PROGRAM.CODE<LINE.LOOP> = THIS.LINE

                END ELSE

                    PROGRAM.CODE<LINE.LOOP> = NEW.CODE

                    INSERT.LINE.PTR = LINE.LOOP
                    INSERT.LINE.COUNT = NEW.CODE.COUNT - 1
                    NO.INSERT.SOURCE = @FALSE
                    GOSUB INSERT.LINE.XREF

                    LINE.LOOP += INSERT.LINE.COUNT
                    PROGRAM.CODE.LINES += INSERT.LINE.COUNT

                END

            END

        END

    NEXT LINE.LOOP

    RETURN

CONVERT.ASSOCIATED.CODE.LINE: ********************************************
* go through a program line, find any references to associated tables    *
* and convert the code                                                   *
**************************************************************************

* we'll build new code here
    NEW.CODE = ""
    NEW.CODE.COUNT = 0

    GOSUB EXPAND.ASSOCIATED.PARAMETERS

    GOSUB BUILD.ASSOCIATED.REFERENCES.TABLE

* if we didn't find any table references return with new.code unchanged
    IF START.PTR.LIST = "" THEN
        RETURN
    END

* check for multi (compound) lines
    MULTI.LINE = SPLIT.COMPOUND.LINE(CLEAN.LINE)
    MULTI.LINE.COUNT = DCOUNT(MULTI.LINE, @AM)

* we have additional associated variables to convert.  if there were any
* associated parameters they've already updated clean.line. 
* convert.associated.variables will build a new code line in new.code
* for each constituent associated variable so we need to reset new.code
* to remove any entries added by expand.associated.parameters
    NEW.CODE = ""
    NEW.CODE.COUNT = 0

* if this is a compound line we don't want to duplicate the entire line
* for each associated variable.  we only want to duplicate the lines
* with associations in them

* if we don't have compound lines convert.associated.variables can take
* care of everything as it is

* if we do have compound lines we'll need to evaluate each line separately
* and also update new.code with compound lines that may not have any
* associated values at all
    IF MULTI.LINE.COUNT = 1 THEN

        GOSUB CONVERT.ASSOCIATED.VARIABLES

    END ELSE

        FOR MULTI.LINE.LOOP = 1 TO MULTI.LINE.COUNT

            CLEAN.LINE = MULTI.LINE<MULTI.LINE.LOOP>
            GOSUB CLEAN.LINE
            GOSUB BUILD.ASSOCIATED.REFERENCES.TABLE

* if this part of the compound line has no associated variables add it
* to new.code unchanged.  otherwise convert the associated values
            IF START.PTR.LIST = "" THEN

                NEW.CODE.COUNT += 1
                IF NEW.CODE.COUNT = 1 AND CLEAN.LABEL <> "" THEN
                    NEW.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
                END ELSE
                    NEW.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):CLEAN.LINE
                END

                NEW.CODE<NEW.CODE.COUNT> = NEW.LINE

            END ELSE

                GOSUB CONVERT.ASSOCIATED.VARIABLES

            END

        NEXT MULTI.LINE.LOOP

    END

    RETURN

EXPAND.ASSOCIATED.PARAMETERS: *******************************************
* convert associated names that are inside braces.  when the associated *
* name variable is used inside braces we'll treat this as a special     *
* case.  we won't expand the code line into a list of multiple          *
* statements.  we'll expand it into a list of its constituent           *
* associated variables separated by commas.  this allows us to use an   *
* associated variable as a parameter in a subroutine that is then       *
* expanded into a list of parameters                                    *
*************************************************************************
    FOR TABLE.LOOP = 1 TO ASSOCIATED.COUNT

        THIS.ASSOCIATED.NAME = ASSOCIATED.NAME.LIST<TABLE.LOOP>

        FIND.PTR = 1
        REF.PTR = 0

        LOOP

            PTR = INDEX(CLEAN.LINE, THIS.ASSOCIATED.NAME, FIND.PTR)
            SKIP.REFERENCE = @FALSE

        UNTIL PTR < 1

* if there's a dot, alpha, or underscore immediately before or after
* this reference then it's part of a larger variable name and is not an
* associated table reference.  the clean.line subroutine puts spaces
* before and after braces so we'll look back and forward two (not one)
* characters
            IF PTR > 2 THEN
                CHAR.BEFORE = UPCASE(CLEAN.LINE [PTR - 2, 1])
            END ELSE
                CHAR.BEFORE = ""
            END

            CHAR.AFTER = UPCASE(CLEAN.LINE [PTR + LEN(THIS.ASSOCIATED.NAME) + 1, 1])

* if we have a valid associated list name check for braces before and
* after.  if we find them then we'll expand this associated name into its
* consitituent associated variables
            IF CHAR.BEFORE <> "{" OR CHAR.AFTER <> "}" THEN
                SKIP.REFERENCE = @TRUE
            END

            IF NOT(SKIP.REFERENCE) THEN
                GOSUB EXPAND.ONE.ASSOCIATED.PARAMETER
            END

            FIND.PTR += 1

        REPEAT

    NEXT TABLE.LOOP

    RETURN

EXPAND.ONE.ASSOCIATED.PARAMETER: *****************************************
* expand an associated variable name, this.associated.name, surrounded   *
* by braces, into a list of parameters.  an additional parameter will    *
* be added before the expanded parameters with a count of parameters.    *
*                                                                        *
* this association:  associated list = variable1, variable2, variable3   *
*                                                                        *
* would expand this: object::method ({list})                             *
*                                                                        *
* to:                object::method (3, variable1, variable2, variable3) *
*                                                                        *
* this is most often used to call methods that may receive a variable    *
* number of parameters.  the method needs to have enough hardcoded       *
* parameters to catch the variable number of parameters but then will    *
* also need to know how many "good" parameters there are.  the initial   *
* parameter count value is the number of "good" parameters               *
*                                                                        *
* ptr points to the start of the associated name.  table.loop points to  *
* the associated variables in the associated tables                      *
**************************************************************************

* start with the current program line and replace each instance of a
* table variable with its unrolled variable.  we'll build a list of the
* exploded parameters in new.parameters
    NEW.LINE = CLEAN.LINE
    NEW.PARAMETERS = ""

* adjust ptr to take the braces into account and remove the braces from
* the associated name.  clean.line puts a space before and after braces
* so each brace is " { " and " }"
    PTR -= 3
    BRACE.REF.LENGTH = LEN(THIS.ASSOCIATED.NAME) + 5

* build a new.code line for each variable associated with the table
    VAR.COUNT = DCOUNT(ASSOCIATED.VARIABLE.LIST<TABLE.LOOP>, @VM)

    FOR UNROLL.LOOP = 1 TO VAR.COUNT

* set reference length to the length of the field that's being replaced,
* the associated variable name with both braces

* get the variable from the associated list that we'll replace the table
* reference with
        REF.LENGTH = BRACE.REF.LENGTH
        NEW.VARIABLE = ASSOCIATED.VARIABLE.LIST<TABLE.LOOP, UNROLL.LOOP>
        NEW.OCONV = ASSOCIATED.OCONV.LIST<TABLE.LOOP, UNROLL.LOOP>

* is there a dynamic array reference in the variable we're replacing the
* associated name with?
        IF COUNT(NEW.VARIABLE, "<") > 0 AND COUNT(NEW.VARIABLE, ">") > 0 THEN
            NEW.VARIABLE.DYNAMIC = @TRUE
            NEW.VARIABLE.ARRAY.START = INDEX(NEW.VARIABLE, "<", 1) + 1
            NEW.VARIABLE.ARRAY.END = INDEX(NEW.VARIABLE, ">", 1) - 1
            NEW.ARRAY.PARAMETER = SPLIT.PARAMETERS (NEW.VARIABLE [NEW.VARIABLE.ARRAY.START, TO.THE.END])
            NEW.ARRAY.COUNT = DCOUNT(NEW.ARRAY.PARAMETER, @AM)
        END ELSE
            NEW.VARIABLE.DYNAMIC = @FALSE
        END

* is there a dynamic array reference immediately after the associated
* name we're replacing?
        IF NEW.LINE [PTR + REF.LENGTH, 1] = "<" THEN
            OLD.VARIABLE.DYNAMIC = @TRUE
            OLD.VARIABLE.ARRAY.START = START.PTR + REF.LENGTH + 1
            OLD.VARIABLE.ARRAY.END = OLD.VARIABLE.ARRAY.START + INDEX(NEW.LINE [OLD.VARIABLE.ARRAY.START, TO.THE.END], ">", 1) - 1
            OLD.VARIABLE.REF.LENGTH = OLD.VARIABLE.ARRAY.END - OLD.VARIABLE.ARRAY.START
            OLD.ARRAY.PARAMETER = SPLIT.PARAMETERS (NEW.LINE [OLD.VARIABLE.ARRAY.START, TO.THE.END])
            OLD.ARRAY.COUNT = DCOUNT(OLD.ARRAY.PARAMETER, @AM)
        END ELSE
            OLD.VARIABLE.DYNAMIC = @FALSE
        END

* if both the old variable (the associated table name) and the new
* variable (the variable we're replacing the associated table name with)
* are dynamic we want to merge the dynamic array references
        IF OLD.VARIABLE.DYNAMIC AND NEW.VARIABLE.DYNAMIC THEN

* compare the attribute, value and subvalue reference for both variables
            MERGE.ARRAY.PARAMETER = ""

            FOR PAR.LOOP = 1 TO 3

                NEW.PARAMETER = NEW.ARRAY.PARAMETER<PAR.LOOP>
                OLD.PARAMETER = OLD.ARRAY.PARAMETER<PAR.LOOP>

                BEGIN CASE

* if both parameters are null ignore
                    CASE NEW.PARAMETER = "" AND OLD.PARAMETER = ""
                        NULL

* the new parameter is null but the old parameter exists.  use the old parameter
                    CASE NEW.PARAMETER = "" AND OLD.PARAMETER <> ""
                        MERGE.ARRAY.PARAMETER<PAR.LOOP> = OLD.PARAMETER

* the new parameter exists and the old parameter is a 1.  use the new parameter
                    CASE NEW.PARAMETER <> "" AND OLD.PARAMETER = "1"
                        MERGE.ARRAY.PARAMETER<PAR.LOOP> = NEW.PARAMETER

* if there's a new parameter use it
                    CASE NEW.PARAMETER <> ""
                        MERGE.ARRAY.PARAMETER<PAR.LOOP> = NEW.PARAMETER

* if there's an old parameter use it
                    CASE OLD.PARAMETER <> ""
                        MERGE.ARRAY.PARAMETER<PAR.LOOP> = OLD.PARAMETER

                END CASE

            NEXT PAR.LOOP

* increase the reference length by the old dynamic array reference length
* and add the new dynamic array reference to new.variable
            REF.LENGTH += OLD.VARIABLE.REF.LENGTH
            NEW.VARIABLE = NEW.VARIABLE ["<", 1, 1]:"<"

            FOR PAR.LOOP = 1 TO 3

                IF MERGE.ARRAY.PARAMETER<PAR.LOOP> <> "" THEN

                    IF PAR.LOOP > 1 THEN
                        NEW.VARIABLE := ","
                    END

                    NEW.VARIABLE := MERGE.ARRAY.PARAMETER<PAR.LOOP>

                END

            NEXT PAR.LOOP

            NEW.VARIABLE := ">"

        END

* if this expression has a conversion perform an output conversion on it
        GOSUB ADD.CONVERSIONS

* add to our "new" parameter list.  if this is the first parameter added
* add in the parameter count
        IF NEW.PARAMETERS = "" THEN
            NEW.PARAMETERS := VAR.COUNT:",":NEW.VARIABLE
        END ELSE
            NEW.PARAMETERS := ",":NEW.VARIABLE
        END

    NEXT UNROLL.LOOP

* replace the associated name (and surrounding braces) with the new parameter
* list
*   NEW.LINE [PTR, REF.LENGTH] = NEW.VARIABLE
    NEW.LINE = NEW.LINE [1, PTR - 1]:NEW.PARAMETERS:NEW.LINE [PTR + REF.LENGTH, TO.THE.END]

* save the new.line in clean.line.  this is so that later associated name
* conversions will start with these associated parameters expanded
    CLEAN.LINE = NEW.LINE

* save new program line in new.code
    NEW.CODE.COUNT = 1

    IF CLEAN.LABEL <> "" THEN
        NEW.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):NEW.LINE
    END ELSE
        NEW.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):NEW.LINE
    END

    NEW.CODE<NEW.CODE.COUNT> = NEW.LINE

    RETURN

BUILD.ASSOCIATED.REFERENCES.TABLE: ***************************************
* build a table of any references found for each associated table name.  *
**************************************************************************

* find the location of an equals expression in clean.line.  if any
* oconverts were defined in the association it will be important to
* know if we're assigning into a variable or from a variable.

* if we're assigning into a variable we'll iconvert the expression.
* if we're assigning out of a variable we'll oconvert the expression.

* if there is no equals expression in the line (ie, an "INS" or "DEL" or
* something) equals.ptr will be set arbitrarily high so that no conversions
* will be done and all expressions will be left unconverted
    EQUALS.PTR = INDEX(CLEAN.LINE, " =", 1)

    IF EQUALS.PTR > 0 THEN
        EQUALS.PTR += 1
    END ELSE
        EQUALS.PTR = TO.THE.END
    END

* also build a table for whether this reference is before or after
* the equals sign so we know how to process iconverts / oconverts.
    START.PTR.LIST = ""
    BEFORE.EQUALS.LIST = ""
    BEFORE.CONVERT.LIST = ""
    BEFORE.CONVERT.COUNT = 0

    FOR TABLE.LOOP = 1 TO ASSOCIATED.COUNT

        THIS.ASSOCIATED.NAME = ASSOCIATED.NAME.LIST<TABLE.LOOP>

        FIND.PTR = 1
        REF.PTR = 0

        LOOP

            PTR = INDEX(CLEAN.LINE, THIS.ASSOCIATED.NAME, FIND.PTR)
            SKIP.REFERENCE = @FALSE

        UNTIL PTR < 1

* if there's a dot, alpha, or underscore immediately before or after
* this reference then it's part of a larger variable name and is not an
* associated table reference
            IF PTR > 1 THEN
                CHAR.BEFORE = UPCASE(CLEAN.LINE [PTR - 1, 1])
            END ELSE
                CHAR.BEFORE = ""
            END

            CHAR.AFTER = UPCASE(CLEAN.LINE [PTR + LEN(THIS.ASSOCIATED.NAME), 1])

            IF CHAR.BEFORE = "." OR CHAR.BEFORE = "_" OR (CHAR.BEFORE >= "A" AND CHAR.BEFORE <= "Z") THEN
                SKIP.REFERENCE = @TRUE
            END

            IF CHAR.AFTER = "." OR CHAR.AFTER = "_" OR (CHAR.AFTER >= "A" AND CHAR.AFTER <= "Z") THEN
                SKIP.REFERENCE = @TRUE
            END

* if we have a reference add it to our reference table
            IF NOT(SKIP.REFERENCE) THEN

                REF.PTR += 1
                START.PTR.LIST<TABLE.LOOP, REF.PTR> = PTR

                IF PTR < EQUALS.PTR THEN
                    BEFORE.EQUALS.LIST<TABLE.LOOP, REF.PTR> = @TRUE
                END

            END

            FIND.PTR += 1

        REPEAT

    NEXT TABLE.LOOP

    RETURN

CONVERT.ASSOCIATED.VARIABLES: ********************************************
* convert the associated variables in clean.line into multiple code      *
* lines, one for each constituent associated variable                    *
**************************************************************************

* as we change program code we'll be moving the start.ptr.list pointers
* around.  save its contents now so we can reset it for each roll
    SAVE.START.PTR.LIST = START.PTR.LIST

* find lowest parameter count.  all parameter counts should be the same
* for a good conversion so we'll give a warning if any counts are different
    VAR.COUNT = 0
    VAR.MISMATCH = @FALSE
    FOR TABLE.LOOP = 1 TO ASSOCIATED.COUNT

        IF START.PTR.LIST<TABLE.LOOP> <> "" THEN

            THIS.VAR.COUNT = ASSOCIATED.VARIABLE.COUNT.LIST<TABLE.LOOP>

            IF VAR.COUNT = 0 THEN
                VAR.COUNT = THIS.VAR.COUNT
            END

            IF THIS.VAR.COUNT <> VAR.COUNT THEN
                VAR.MISMATCH = @TRUE
            END

            IF THIS.VAR.COUNT < VAR.COUNT THEN
                VAR.COUNT = THIS.VAR.COUNT
            END

        END

    NEXT TABLE.LOOP

* if we have a mismatch count print a warning
    IF VAR.MISMATCH THEN
        OBJECT.WARNING.DESC = "Associated variable count mismatch in line "
        OBJECT.WARNING.LINE = LINE.LOOP
        GOSUB PRINT.OBJECT.WARNING
    END

* build a new.code line for each variable associated with the table
    FOR UNROLL.LOOP = 1 TO VAR.COUNT

* start with original starting pointer list
        START.PTR.LIST = SAVE.START.PTR.LIST

* start with the current program line and replace each instance of a
* table variable with its unrolled variable
        NEW.LINE = CLEAN.LINE

* check each associated name that has a start pointer in this line
        FOR TABLE.LOOP = 1 TO ASSOCIATED.COUNT

            REF.COUNT = DCOUNT(START.PTR.LIST<TABLE.LOOP>, VM)

            IF REF.COUNT > 0 THEN

* extract the table reference name we're replacing
                THIS.ASSOCIATED.NAME = ASSOCIATED.NAME.LIST<TABLE.LOOP>
                REF.LENGTH = LEN(THIS.ASSOCIATED.NAME)

* get the variable from the associated list that we'll replace the table
* reference with
                NEW.VARIABLE = ASSOCIATED.VARIABLE.LIST<TABLE.LOOP, UNROLL.LOOP>
                NEW.OCONV = ASSOCIATED.OCONV.LIST<TABLE.LOOP, UNROLL.LOOP>

* replace each reference of this.associated.name with new.variable.  we'll
* loop backwards through the references so that replacements won't screw up
* locates
                FOR REF.LOOP = REF.COUNT TO 1 STEP -1

* find the start of the table expression to replace
                    START.PTR = START.PTR.LIST<TABLE.LOOP, REF.LOOP>
                    BEFORE.EQUALS = BEFORE.EQUALS.LIST<TABLE.LOOP, REF.LOOP>

* is there a dynamic array reference in the variable we're replacing the
* associated name with?
                    IF COUNT(NEW.VARIABLE, "<") > 0 AND COUNT(NEW.VARIABLE, ">") > 0 THEN
                        NEW.VARIABLE.DYNAMIC = @TRUE
                        NEW.VARIABLE.ARRAY.START = INDEX(NEW.VARIABLE, "<", 1) + 1
                        NEW.VARIABLE.ARRAY.END = INDEX(NEW.VARIABLE, ">", 1) - 1
                        NEW.ARRAY.PARAMETER = SPLIT.PARAMETERS (NEW.VARIABLE [NEW.VARIABLE.ARRAY.START, TO.THE.END])
                        NEW.ARRAY.COUNT = DCOUNT(NEW.ARRAY.PARAMETER, @AM)
                    END ELSE
                        NEW.VARIABLE.DYNAMIC = @FALSE
                    END

* is there a dynamic array reference immediately after the associated
* name we're replacing
                    IF NEW.LINE [START.PTR + REF.LENGTH, 1] = "<" THEN
                        OLD.VARIABLE.DYNAMIC = @TRUE
                        OLD.VARIABLE.ARRAY.START = START.PTR + REF.LENGTH + 1
                        OLD.VARIABLE.ARRAY.END = OLD.VARIABLE.ARRAY.START + INDEX(NEW.LINE [OLD.VARIABLE.ARRAY.START, TO.THE.END], ">", 1) - 1
                        OLD.VARIABLE.REF.LENGTH = OLD.VARIABLE.ARRAY.END - OLD.VARIABLE.ARRAY.START + 2
                        OLD.ARRAY.PARAMETER = SPLIT.PARAMETERS (NEW.LINE [OLD.VARIABLE.ARRAY.START, TO.THE.END])
                        OLD.ARRAY.COUNT = DCOUNT(OLD.ARRAY.PARAMETER, @AM)
                    END ELSE
                        OLD.VARIABLE.DYNAMIC = @FALSE
                    END

* if both the old variable (the associated table name) and the new
* variable (the variable we're replacing the associated table name with)
* are dynamic we want to merge the dynamic array references
                    IF OLD.VARIABLE.DYNAMIC AND NEW.VARIABLE.DYNAMIC THEN

* compare the attribute, value and subvalue reference for both variables
                        MERGE.ARRAY.PARAMETER = ""

                        FOR PAR.LOOP = 1 TO 3

                            NEW.PARAMETER = NEW.ARRAY.PARAMETER<PAR.LOOP>
                            OLD.PARAMETER = OLD.ARRAY.PARAMETER<PAR.LOOP>

                            BEGIN CASE

* if both parameters are null ignore
                                CASE NEW.PARAMETER = "" AND OLD.PARAMETER = ""
                                    NULL

* the new parameter is null but the old parameter exists.  use the old parameter
                                CASE NEW.PARAMETER = "" AND OLD.PARAMETER <> ""
                                    MERGE.ARRAY.PARAMETER<PAR.LOOP> = OLD.PARAMETER

* the new parameter exists and the old parameter is a 1.  use the new parameter
                                CASE NEW.PARAMETER <> "" AND OLD.PARAMETER = "1"
                                    MERGE.ARRAY.PARAMETER<PAR.LOOP> = NEW.PARAMETER

* if there's a new parameter use it
                                CASE NEW.PARAMETER <> ""
                                    MERGE.ARRAY.PARAMETER<PAR.LOOP> = NEW.PARAMETER

* if there's an old parameter use it
                                CASE OLD.PARAMETER <> ""
                                    MERGE.ARRAY.PARAMETER<PAR.LOOP> = OLD.PARAMETER

                            END CASE

                        NEXT PAR.LOOP

* increase the reference length by the old dynamic array reference length
* and add the new dynamic array reference to new.variable
                        REF.LENGTH += OLD.VARIABLE.REF.LENGTH
                        NEW.VARIABLE = NEW.VARIABLE ["<", 1, 1]:"<"

                        FOR PAR.LOOP = 1 TO 3

                            IF MERGE.ARRAY.PARAMETER<PAR.LOOP> <> "" THEN

                                IF PAR.LOOP > 1 THEN
                                    NEW.VARIABLE := ","
                                END

                                NEW.VARIABLE := MERGE.ARRAY.PARAMETER<PAR.LOOP>

                            END

                        NEXT PAR.LOOP

                        NEW.VARIABLE := ">"

                    END

* if this expression has a conversion and it's to the right of the equals
* perform an output conversion on it
                    IF NOT(BEFORE.EQUALS) THEN
                        GOSUB ADD.CONVERSIONS
                    END

                    BEFORE.ASSOCIATED = NEW.LINE [1, START.PTR - 1]
                    AFTER.ASSOCIATED = NEW.LINE [START.PTR + REF.LENGTH, TO.THE.END]
                    NEW.LINE = BEFORE.ASSOCIATED:NEW.VARIABLE:AFTER.ASSOCIATED

* this replacement probably moved all the text after the replacement to
* the right or the left.  we're okay for this reference since we're
* looping backwards but for later associations the start pointer would
* be off.  loop through the later associations and adjust their pointers
                    MOVE.POSITIONS = LEN(NEW.VARIABLE) - REF.LENGTH

                    FOR ADJUST.LOOP = TABLE.LOOP + 1 TO ASSOCIATED.COUNT

                        ADJUST.REF.COUNT = DCOUNT(START.PTR.LIST<ADJUST.LOOP>, VM)

                        FOR ADJUST.REF.LOOP = 1 TO ADJUST.REF.COUNT

                            THIS.START.PTR = START.PTR.LIST<ADJUST.LOOP, ADJUST.REF.LOOP>

                            IF THIS.START.PTR >= START.PTR + REF.LENGTH THEN
                                THIS.START.PTR += MOVE.POSITIONS
                                START.PTR.LIST<ADJUST.LOOP, ADJUST.REF.LOOP> = THIS.START.PTR
                            END

                        NEXT ADJUST.REF.LOOP

                    NEXT ADJUST.LOOP

                NEXT REF.LOOP

            END

        NEXT TABLE.LOOP

* save new program line in new.code
        NEW.CODE.COUNT += 1

        IF NEW.CODE.COUNT = 1 AND CLEAN.LABEL <> "" THEN
            NEW.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):NEW.LINE
        END ELSE
            NEW.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):NEW.LINE
        END

        NEW.CODE<NEW.CODE.COUNT> = NEW.LINE

    NEXT UNROLL.LOOP

    RETURN

ADD.CONVERSIONS: *********************************************************
* add input and output conversions to new.variable                       *
**************************************************************************

* if this field has any conversions add an oconv for each one
    CONVERT.COUNT = DCOUNT(NEW.OCONV, @VM)
    FOR CONVERT.LOOP = 1 TO CONVERT.COUNT

        THIS.CONVERT = TRIM(NEW.OCONV<1,CONVERT.LOOP>)
        IF THIS.CONVERT <> "" THEN
            NEW.VARIABLE = "OCONVS(":NEW.VARIABLE:",":THIS.CONVERT:")"
        END

    NEXT CONVERT.LOOP

* if there are any associated variables left of the equals sign
* and they have a conversion we need to do an iconv on this
* variable
    FOR BEFORE.LOOP = 1 TO ASSOCIATED.COUNT

        BEFORE.REF.COUNT = DCOUNT(START.PTR.LIST<BEFORE.LOOP>, VM)

        IF BEFORE.REF.COUNT > 0 THEN

            FOR BEFORE.REF.LOOP = 1 TO BEFORE.REF.COUNT

                IF BEFORE.EQUALS.LIST<BEFORE.LOOP, BEFORE.REF.LOOP> THEN

                    BEFORE.CONVERT = ASSOCIATED.OCONV.LIST<BEFORE.LOOP, UNROLL.LOOP>
                    BEFORE.CONVERT.COUNT = DCOUNT(BEFORE.CONVERT, @VM)

                    FOR BEFORE.CONVERT.LOOP = 1 TO BEFORE.CONVERT.COUNT

                        THIS.CONVERT = TRIM(BEFORE.CONVERT<1,BEFORE.CONVERT.LOOP>)
                        IF THIS.CONVERT <> "" THEN
                            NEW.VARIABLE = "ICONVS(":NEW.VARIABLE:",":THIS.CONVERT:")"
                        END

                    NEXT BEFORE.CONVERT.LOOP

                END

            NEXT BEFORE.REF.LOOP

        END

    NEXT BEFORE.LOOP

    RETURN

PRINT.ASSOCIATED.TABLE: **************************************************
* print out the associated variables tables for debugging                *
**************************************************************************
    PRINT
    PRINT "Associated Variables:"
    PRINT "AssociatedName........... AssociatedVariables. Oconvert.. Count ":
    PRINT "Line...."

    FOR DISP.LOOP = 1 TO ASSOCIATED.COUNT

        FOR VAR.LOOP = 1 TO ASSOCIATED.VARIABLE.COUNT.LIST<DISP.LOOP>

            IF VAR.LOOP = 1 THEN
                PRINT ASSOCIATED.NAME.LIST<DISP.LOOP> "L#25":" ":
            END ELSE
                PRINT SPACE(25):" ":
            END

            PRINT ASSOCIATED.VARIABLE.LIST<DISP.LOOP, VAR.LOOP> "L#20":" ":
            PRINT ASSOCIATED.OCONV.LIST<DISP.LOOP, VAR.LOOP> "L#10":" ":

            IF VAR.LOOP = 1 THEN
                PRINT ASSOCIATED.VARIABLE.COUNT.LIST<DISP.LOOP> "R#5":" ":
                PRINT ASSOCIATED.LINE.LIST<DISP.LOOP> "R#8"
            END ELSE
                PRINT
            END

        NEXT VAR.LOOP

    NEXT DISP.LOOP

    IF REPLACE.LINE.COUNT > 0 THEN

        PRINT
        PRINT "Replaced lines:"
        PRINT "Line.. New Line.............................................................."

        FOR DISP.LOOP = 1 TO REPLACE.LINE.COUNT
            PRINT REPLACE.LINE.LIST<DISP.LOOP> "R#6":" ":
            PRINT REPLACE.LINE.NEW.LIST<DISP.LOOP> "L#70"
        NEXT DISP.LOOP

    END

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / macros                            **
**************************************************************************
**************************************************************************

CONVERT.MACROS: **********************************************************
* convert macros in program.code.lines                                   *
**************************************************************************
    MACRO.START.DATE = DATE()
    MACRO.START.TIME = TIME()

* if there are any embedded macros we'll need to move the macro code to a
* new line and save the first returned value in a temporary variable.  this
* counter is used to create the temporary variable name
    MACRO.TEMP.COUNTER = 0

* copy program.code to old.program.code so that we can use a remove
* statement on it.  we'll be changing program.code and that would reset
* the remove pointer
    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any macros in it.  if the line is
* null, if it's a comment, if doesn't have at least one opening parenthesis,
* or if it's not code then skip the macro checking
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE

        BEGIN CASE
            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE
            CASE COUNT(TRIM.THIS.LINE, "(") = 0
                CHECK.THIS.LINE = @FALSE
            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE
        END CASE

        IF CHECK.THIS.LINE THEN

            GOSUB CONVERT.MACRO.SINGLE.LINE

            IF MACRO.CONVERTED THEN
                PROGRAM.CODE<LINE.LOOP> = CONVERTED.MACRO.LINE
                TOTAL.MACROS.CONVERTED += MACRO.CONVERTED.COUNT
            END

        END

    NEXT LINE.LOOP

    MACRO.END.DATE = DATE()
    MACRO.END.TIME = TIME()
    MACRO.ELAPSED.TIME += TIME.ELAPSED (MACRO.START.DATE, MACRO.START.TIME)

    RETURN

CONVERT.MACRO.SINGLE.LINE: ***********************************************
* convert macros in a single line of code.  if the code line is a        *
* line it will be separated into single lines and each line will be      *
* evaluated separately                                                   *
*                                                                        *
* returns macro.converted true if at least one macro was converted       *
**************************************************************************
    MACRO.CONVERTED.COUNT = 0
    CONVERTED.MACRO.LINE = ""

* separate this (possibly) compound line into multiple lines
    MULTI.LINE = SPLIT.COMPOUND.LINE (THIS.LINE)
    MULTI.LINE.COUNT = DCOUNT(MULTI.LINE, @AM)

    FOR MULTI.LOOP = 1 TO MULTI.LINE.COUNT

        THIS.LINE = MULTI.LINE<MULTI.LOOP>
        CLEAN.LINE = THIS.LINE
        GOSUB CLEAN.LINE

* see how many spaces are to the left of the code
        INDENT.COUNT = FIND.INDENT.COUNT (CLEAN.LABEL, THIS.LINE)

* if converting embedded macros is enabled check the line to see if
* there are any embedded macros to move to their own lines
        IF ENABLE.EMBEDDED.MACROS THEN

            GOSUB CONVERT.EMBEDDED.MACROS

            IF NOT (EMBEDDED.CONVERTED) THEN
                GOSUB CONVERT.MACROS.ONE.LINE
            END

        END ELSE

            GOSUB CONVERT.MACROS.ONE.LINE

        END

        IF NOT (EMBEDDED.CONVERTED) THEN

            IF CLEAN.LABEL <> "" THEN
                CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
            END ELSE
                CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
            END

            IF CONVERTED.MACRO.LINE = "" THEN
                CONVERTED.MACRO.LINE = CLEAN.LINE
            END ELSE
                CONVERTED.MACRO.LINE := " ; ":CLEAN.LINE
            END
     
            IF MACRO.CONVERTED THEN
                MACRO.CONVERTED.COUNT += 1
            END

        END

    NEXT MULTI.LOOP

    IF MACRO.CONVERTED.COUNT > 0 THEN
        MACRO.CONVERTED = @TRUE
    END ELSE
        MACRO.CONVERTED = @FALSE
    END

    RETURN

CONVERT.EMBEDDED.MACROS: *************************************************
* extract any embedded macros from clean.line and save them in the       *
* embedded.line.list array.  this will allow the embedded macros to be   *
* processed one at a time before the program line with the embedded      *
* macro, saving them in temporary variables                              *
**************************************************************************
    OLD.CLEAN.LINE = CLEAN.LINE

    EMBEDDED.CONVERTED = @FALSE
    EMBEDDED.LINE.LIST = ""
    EMBEDDED.LINE.COUNT = 0

    EMBEDDED.PREN.PTR = 0

* all macros have parenthesis so if there isn't at least one open pren
* the line can't have any macros
    IF COUNT(CLEAN.LINE, "(") = 0 THEN
        RETURN
    END

* check each keyword ahead of an open pren to see if it's a macro.  if
* it is an it's not the only thing in the line then extract it and add
* it to embedded.line.list
    EMBEDDED.PREN.PTR = COUNT(CLEAN.LINE, "(") + 1

    LOOP

        EMBEDDED.PREN.PTR -= 1
        PREN.PTR = INDEX(CLEAN.LINE, "(", EMBEDDED.PREN.PTR)

    UNTIL EMBEDDED.PREN.PTR < 1

        GOSUB EXTRACT.MACRO.KEYWORD

* if the keyword is a macro and the macro is an embedded macro we may
* want to extract this macro
        IF MACRO.KEYWORD <> "" THEN

            GOSUB EXTRACT.EMBEDDED.MACRO

            MACRO.STRING = MACRO ["(", 2, TO.THE.END]
            GOSUB EXTRACT.MACRO.PARAMETERS

* if this macro is embedded then there is one more parameter to the
* macro call, for the result, that will be left in the position of the
* macro.  find the macro definition for this macro with one more
* parameter than what's defined in the code line
            PARAMETER.COUNT += 1

            MACRO.NAME = MACRO.KEYWORD
            GOSUB GET.MACRO.PTR

* if this macro was defined as an "embedded" macro, meaning it could be
* embedded in a larger statement, separate the macro from this line and
* create a new code line ahead of this code line that processes the macro
* and saves the result in a temporary variable
            IF MACRO.EMBEDDED.LIST<MACRO.PTR> THEN

                IF MACRO <> "" AND EXTRACT.FINISHED THEN
                    GOSUB SEPARATE.EMBEDDED.MACRO
                END

            END

        END

    REPEAT

* if we didn't end up with any code lines exploded from the original line
* we didn't remove any embedded macros so dump out
    IF EMBEDDED.LINE.COUNT = 0 THEN
        RETURN
    END

* insert the code lines exploded from embedded macros back into the
* code.  if this code line is a "case" or "?" line a special case statement
* routine must be used
    CASE.KEYWORD = CLEAN.LINE [" ", 1, 1]

    IF CASE.KEYWORD = "CASE" OR CASE.KEYWORD = "?" THEN
        GOSUB INSERT.EMBEDDED.CASE.MACRO
    END ELSE
        GOSUB INSERT.EMBEDDED.MACRO
    END

    EMBEDDED.CONVERTED = @TRUE

    RETURN

EXTRACT.MACRO.KEYWORD: ****************************************************
* extract the possible macro name from clean.line before                  *
* embedded.pren.ptr by catting all characters befor the pren that are     *
* a-z, A-Z, 0-9, dot or underscore                                        *
***************************************************************************
    MACRO.KEYWORD = ""
    GOOD.CHAR.LIST = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._"

    LOOP
        PREN.PTR -= 1
        THIS.CHAR = CLEAN.LINE [PREN.PTR, 1]
    UNTIL PREN.PTR = 0 OR COUNT(GOOD.CHAR.LIST, THIS.CHAR) = 0
        MACRO.KEYWORD = THIS.CHAR:MACRO.KEYWORD
    REPEAT

    MACRO.KEYWORD = UPCASE(MACRO.KEYWORD)
    MACRO.KEYWORD.PTR = PREN.PTR + 1

* if the characters before the "macro" are an object delimiter of some kind
* then this isn't a macro.  null out macro.keyword so it won't be processed
* as a macro
    BEGIN CASE
        CASE CLEAN.LINE [MACRO.KEYWORD.PTR - METHOD.DEL.LENGTH, METHOD.DEL.LENGTH] = METHOD.DELIMITER
            MACRO.KEYWORD = ""
        CASE CLEAN.LINE [MACRO.KEYWORD.PTR - PROPERTY.DEL.LENGTH, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
            MACRO.KEYWORD = ""
        CASE CLEAN.LINE [MACRO.KEYWORD.PTR - CONSTANT.DEL.LENGTH, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
            MACRO.KEYWORD = ""
        CASE CLEAN.LINE [MACRO.KEYWORD.PTR - CHILD.DEL.LENGTH, CHILD.DEL.LENGTH] = CHILD.DELIMITER
            MACRO.KEYWORD = ""
    END CASE

    RETURN

EXTRACT.EMBEDDED.MACRO: **************************************************
* extract the possible macro from clean.line starting at                 *
* macro.keyword.ptr and going until we hit at least one pren and we've   *
* hit the matching closing pren                                          *
**************************************************************************

* cat characters from macro.keyword.ptr
    HIT.OPEN.PREN = @FALSE
    PREN.DEPTH = 0
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    LINE.LENGTH = LEN(CLEAN.LINE)
    EXTRACT.FINISHED = @FALSE

    MACRO = ""
    THIS.CHAR = "*"

    FOR CHAR.PTR = MACRO.KEYWORD.PTR TO LINE.LENGTH UNTIL EXTRACT.FINISHED OR THIS.CHAR = ""

        THIS.CHAR = CLEAN.LINE[CHAR.PTR, 1]

        BEGIN CASE

* handle quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* pren
            CASE THIS.CHAR = "("
                HIT.OPEN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1

        END CASE

        MACRO := THIS.CHAR

        IF HIT.OPEN.PREN AND NOT(IN.QUOTES) AND PREN.DEPTH = 0 THEN
            EXTRACT.FINISHED = @TRUE
        END

    NEXT CHAR.PTR

    MACRO.NAME = TRIM(MACRO ["(", 1, 1])

    RETURN

SEPARATE.EMBEDDED.MACRO: *************************************************
* remove the embedded macro from clean.line and replace it with the      *
* temporary value name.  add the macro to embedded.line.list to populate *
* the temporary value                                                    *
**************************************************************************

* save current values for embedded lines and clean.line in case we decide
* not to un-embed this macro
    SAVE.EMBEDDED.LINE.LIST = EMBEDDED.LINE.LIST
    SAVE.EMBEDDED.LINE.COUNT = EMBEDDED.LINE.COUNT
    SAVE.CLEAN.LINE = CLEAN.LINE

* build the temporary variable
    MACRO.TEMP.COUNTER += 1
    TEMP.VARIABLE = TEMP.MACRO.VARIABLE.PREFIX:MACRO.TEMP.COUNTER

* build the code line that populates the temporary macro variable with
* the macro and add it to the embedded line list
    EMBEDDED.LINE = TEMP.VARIABLE:" = ":MACRO
    EMBEDDED.LINE.COUNT += 1
    EMBEDDED.LINE.LIST<EMBEDDED.LINE.COUNT> = EMBEDDED.LINE

* replace the macro in the program statement with the temporary variable.
* we'll add spaces after the temporary variable if the macro ran up 
* against something in the code line
    SPACE.AFTER.MACRO = ""
    CHAR.AFTER.MACRO = CLEAN.LINE [MACRO.KEYWORD.PTR + LEN(MACRO), 1]

    BEGIN CASE
        CASE CHAR.AFTER.MACRO >= "A" AND CHAR.AFTER.MACRO <= "Z"
            SPACE.AFTER.MACRO = " "
        CASE CHAR.AFTER.MACRO >= "a" AND CHAR.AFTER.MACRO <= "z"
            SPACE.AFTER.MACRO = " "
        CASE CHAR.AFTER.MACRO >= "0" AND CHAR.AFTER.MACRO <= "9"
            SPACE.AFTER.MACRO = " "
    END CASE

    CLEAN.LINE = CLEAN.LINE [1, MACRO.KEYWORD.PTR - 1]:TEMP.VARIABLE:SPACE.AFTER.MACRO:CLEAN.LINE [MACRO.KEYWORD.PTR + LEN(MACRO), TO.THE.END]

* if clean.line ends up as "something = temporary variable" or just
* "temporary variable" with nothing else then this macro didn't need to be
* un-embedded.  put things back to where they were before.

* however, if the line has a "+=" or a "-=" in it then we DO need to unembed
* the macro as its really part of a function
    REVERSE.EMBEDDING = @FALSE
    TRIM.CLEAN.LINE = TRIM(CLEAN.LINE)

    IF TRIM(CLEAN.LINE ["=", 2, 1000]) = TEMP.VARIABLE OR TRIM.CLEAN.LINE = TEMP.VARIABLE THEN
        IF INDEX(CLEAN.LINE, "+=", 1) = 0 AND INDEX(CLEAN.LINE, "-=", 1) = 0 THEN
            REVERSE.EMBEDDING = @TRUE
        END
    END

* if clean.line ends up as "temporary variable THEN" or "temporary variable {"
* then we have a macro that starts an if/then statement.  we've evaluated this
* macro with one too many parameters since testing for am embedded macro tests
* using the code line's parameter count + 1 so the embedded flag may be wrong
* and we got here by mistake.

* if the macro is the start of an if/then we don't want to treat this macro
* as embedded
    IF TRIM.CLEAN.LINE = TEMP.VARIABLE:" THEN" OR TRIM.CLEAN.LINE = TEMP.VARIABLE:" {" THEN
        REVERSE.EMBEDDING = @TRUE
    END

    IF REVERSE.EMBEDDING THEN
        EMBEDDED.LINE.LIST = SAVE.EMBEDDED.LINE.LIST
        EMBEDDED.LINE.COUNT = SAVE.EMBEDDED.LINE.COUNT
        CLEAN.LINE = SAVE.CLEAN.LINE
    END

    RETURN

INSERT.EMBEDDED.MACRO: ***************************************************
* insert the embedded macro lines ahead of the current line and update   *
* the current line with the modified macro                               *
**************************************************************************

* save clean line as the last embedded line we'll add to the code
    GOSUB CONVERT.MACROS.ONE.LINE

    BEGIN CASE
        CASE CLEAN.LABEL = ""
            CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
        CASE EMBEDDED.LOOP = 1
            CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
        CASE 1
            CLEAN.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):CLEAN.LINE
    END CASE

    LAST.EMBEDDED.LINE = CLEAN.LINE

* convert each macro line in embedded.line expand the the macro
* into eclipse-compatible code
    FOR EMBEDDED.LOOP = 1 TO EMBEDDED.LINE.COUNT

        CLEAN.LINE = EMBEDDED.LINE.LIST<EMBEDDED.LOOP>

        GOSUB CONVERT.MACROS.ONE.LINE

        BEGIN CASE
            CASE CLEAN.LABEL = ""
                CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
            CASE EMBEDDED.LOOP = 1
                CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
            CASE 1
                CLEAN.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):CLEAN.LINE
        END CASE

        EMBEDDED.LINE.LIST<EMBEDDED.LOOP> = CLEAN.LINE

    NEXT EMBEDDED.LOOP

* adjust the program line xref
    INSERT.LINE.PTR = LINE.LOOP
    INSERT.LINE.COUNT = EMBEDDED.LINE.COUNT

    GOSUB BEFORE.INSERT.EMBEDDED.MACRO

* replace the current program line with the expanded code and add the last
* embedded line after to catch the rest of the macro conversion
    PROGRAM.CODE<INSERT.LINE.PTR> = EMBEDDED.LINE.LIST:@AM:LAST.EMBEDDED.LINE

* adjust the program line xref
    PROGRAM.CODE.LINES += INSERT.LINE.COUNT
    NO.INSERT.SOURCE = @FALSE
    GOSUB INSERT.LINE.XREF

* adjust line.loop by the number of additional lines we added
    LINE.LOOP += INSERT.LINE.COUNT

* add the last converted line to converted.macro.line so it will be 
* saved into the program code by the calling routine
    CONVERTED.MACRO.LINE = LAST.EMBEDDED.LINE
    MACRO.CONVERTED.COUNT += 1

    RETURN

INSERT.EMBEDDED.CASE.MACRO: **********************************************
* for code lines that are case statements insert the embedded macro      *
* lines ahead of the current line and update the current line with the   *
* modified macro.  this is a special routine for case statements as the  *
* macro code must be inserted ahead of the start of the case statement   *
* rather than at the start of the current line                           *
**************************************************************************

* save clean line as the last embedded line we'll add to the code
    GOSUB CONVERT.MACROS.ONE.LINE

    BEGIN CASE
        CASE CLEAN.LABEL = ""
            CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
        CASE EMBEDDED.LOOP = 1
            CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
        CASE 1
            CLEAN.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):CLEAN.LINE
    END CASE

    LAST.EMBEDDED.LINE = CLEAN.LINE

* find and save the start of the current cast statement
    GOSUB FIND.CASE.STATEMENT.START
    CASE.CODE.LINE = PROGRAM.CODE<CASE.PTR>

* convert each macro line in embedded.line expand the the macro
* into eclipse-compatible code
    FOR EMBEDDED.LOOP = 1 TO EMBEDDED.LINE.COUNT

        CLEAN.LINE = EMBEDDED.LINE.LIST<EMBEDDED.LOOP>
        GOSUB CONVERT.MACROS.ONE.LINE

        BEGIN CASE
            CASE CLEAN.LABEL = ""
                CLEAN.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
            CASE EMBEDDED.LOOP = 1
                CLEAN.LINE = CLEAN.LABEL:SPACE(INDENT.COUNT):CLEAN.LINE
            CASE 1
                CLEAN.LINE = SPACE(INDENT.COUNT + LEN(CLEAN.LABEL)):CLEAN.LINE
        END CASE

        EMBEDDED.LINE.LIST<EMBEDDED.LOOP> = CLEAN.LINE

    NEXT EMBEDDED.LOOP

* prep program code for the inserted code
    INSERT.LINE.PTR = CASE.PTR
    INSERT.LINE.COUNT = EMBEDDED.LINE.COUNT
    GOSUB BEFORE.INSERT.EMBEDDED.MACRO

* replace the start of the case statement with the new code lines
    PROGRAM.CODE<INSERT.LINE.PTR> = EMBEDDED.LINE.LIST

* save the start of the case statement after the inserted code
    PROGRAM.CODE<INSERT.LINE.PTR + INSERT.LINE.COUNT> = CASE.CODE.LINE

* adjust the program line xref
    PROGRAM.CODE.LINES += INSERT.LINE.COUNT
    NO.INSERT.SOURCE = @FALSE
    GOSUB INSERT.LINE.XREF

* adjust line.loop by the number of additional lines we added
    LINE.LOOP += INSERT.LINE.COUNT - 1

* add the last converted line to converted.macro.line so it will be 
* saved into the program code by the calling routine
    CONVERTED.MACRO.LINE = LAST.EMBEDDED.LINE
    MACRO.CONVERTED.COUNT += 1

    RETURN

BEFORE.INSERT.EMBEDDED.MACRO: ********************************************
* prepare program.code to accept an embedded macro.  as we work through  *
* the code line converting macros converted.macro.line will accumulate   *
* the converted code.  if the line has no embedded macros in it          *
* converted.macro.line will replace the current program line and all is  *
* good                                                                   *
*                                                                        *
* however, if an embedded macro is converted it will explode into        *
* multiple code lines.  these code lines will be inserted into           *
* program code by insert.embedded.macro or insert.embedded.case          *
*                                                                        *
* if any code has already accumulated in converted.macro.line this code  *
* must be saved in program.code before the exploded embedded code and    *
* then the embedded code may be saved beginning with a new line after    *
* the accumulated converted.macro.line code                              *
*                                                                        *
* if there's any code in converted.macro.line this code saves it at the  *
* current program line and inserts a blank program line after for the    *
* embedded code insertion.  any pointers that need to be updated are     *
* updated                                                                *
**************************************************************************

* if no code has accumulated in converted.macro line nothing needs to be
* done
    IF CONVERTED.MACRO.LINE = "" THEN
        RETURN
    END

* save the accumulated code at the current program line with a blank line
* after
    PROGRAM.CODE<INSERT.LINE.PTR> = CONVERTED.MACRO.LINE:@AM

* adjust the line xref
    INSERT.LINE.PTR += 1
    INSERT.LINE.COUNT = 1
    PROGRAM.CODE.LINES += 1
    NO.INSERT.SOURCE = @FALSE
    GOSUB INSERT.LINE.XREF

    LINE.LOOP += INSERT.LINE.COUNT

* any previous macros have been saved so reset the macro processed flags
    CONVERTED.MACRO.LINE = ""
    MACRO.CONVERTED.COUNT = 0

    RETURN

FIND.CASE.STATEMENT.START: ***********************************************
* given the end of a case statement at line.loop find the start of the   *
* case statement.  returns case.ptr                                      *
**************************************************************************
    CASE.PTR = ""
    CASE.DEPTH = 0

    FOR CASE.LOOP = LINE.LOOP - 1 TO 1 STEP -1 UNTIL CASE.PTR <> "" AND CASE.DEPTH = 0

        TEST.CASE.LINE = TRIM(PROGRAM.CODE<CASE.LOOP>)

        IF IS.CODE (TEST.CASE.LINE) THEN

            TEST.CASE.LINE = LINE.WITHOUT.LABEL (TEST.CASE.LINE)

            TEST.CASE.KEYWORD = TEST.CASE.LINE [" ", 1, 2]
            TEST.CASE.START = TRIM(TEST.CASE.LINE [1, 2])
            TEST.CASE.END = TRIM(TEST.CASE.LINE [2])

* if the test case start is "}{" ignore it.  it's an "ELSE" and we need
* to get to the start of the structure
            IF TEST.CASE.START = "}{" THEN
                TEST.CASE.END = ""
            END

* the test case end is "{}" it's the start of a structure
            IF TEST.CASE.END = "{}" THEN
                TEST.CASE.END = "{"
            END

* if the test case is "}{" at the end of a line treat it as the start
* of a structure
            IF TEST.CASE.END = "}{" THEN
                TEST.CASE.END = "{"
            END

            BEGIN CASE

* if we hit an "end case" we need to go all the way through this new case
* statement to get back to the case statement we're searching.  increment the
* case depth
                CASE TEST.CASE.KEYWORD = "END CASE" OR TEST.CASE.END = "}"
                    CASE.DEPTH += 1

* if we hit a "begin case" and the case depth is not zero then this begin case
* isn't the one we're looking for.  it's a case statement nested within the
* one we're looking for
                CASE (TEST.CASE.KEYWORD = "BEGIN CASE" OR TEST.CASE.END = "{") AND CASE.DEPTH > 0
                    CASE.DEPTH -= 1

* if we hit a "begin case" and the case depth is zero this is the one we're looking
* for
                CASE TEST.CASE.KEYWORD = "BEGIN CASE" OR TEST.CASE.END = "{"
                    CASE.PTR = CASE.LOOP

            END CASE

        END

    NEXT CASE.LOOP

* if we didn't find the start of the case statement something's off
* insert it at the current line so at least we don't lose the code
    IF CASE.PTR = "" THEN
        CASE.PTR = LINE.LOOP
    END

    RETURN

CONVERT.MACROS.ONE.LINE: *************************************************
* convert macros in clean.line.  all macros work in statements that      *
* look like this:                                                        *
*                                                                        *
*    parameter0 = macro.name parameter1, parameter2, parameter n . . .   *
*                                                                        *
*                                  or                                    *
*                                                                        *
*    parameter0 = macro.name(parameter1, parameter2, perameter n . . . ) *
*                                                                        *
* a macro in the control record may be defined multiple times with a     *
* different number of parameters.  the program macro is matched to the   *
* macro with the same number of parameters and then expaded.  the macro  *
* is defined like this:                                                  *
*                                                                        *
*    FOR %0 = 1 TO %1             "%n" refers to macro parameters        *
*    %%0.COUNT = DCOUNT(%1,@AM)   "%%0" is used to create a new variable *
*                                 name from %0 and ".COUNT".  the "%%"   *
*                                 converts whatever's in %0 to           *
*                                 characters that will render a valid    *
*                                 variable name.  ie, parenthesis and    *
*                                 dynamic array references and other     *
*                                 characters that would invalid in a     *
*                                 variable name are changed to dots      *
*                                                                        *
* special variables for macros:                                          *
*                                                                        *
* $object.name$                   name of the object                     *
* $method.name$                   name of the method                     *
**************************************************************************
    MACRO.CONVERTED = @FALSE
    ASSIGNMENT.MACRO = @FALSE
    STATEMENT.MACRO = @FALSE

* all macros have parenthesis so if there isn't at least one open pren
* the line can't have any macros
    IF COUNT(CLEAN.LINE, "(") = 0 THEN
        RETURN
    END

* is this macro assignment style (%0 = MacroName) or statement style
* (MacroName %0)?  If it's a statement style macro the first word in
* the program line will have an open parenthesis in it but not a
* closed parenthesis
    FIRST.KEYWORD = CLEAN.LINE [" ", 1, 1]

    IF COUNT(FIRST.KEYWORD, "(") <> COUNT(FIRST.KEYWORD, ")") OR CLEAN.LINE [" ", 2, 1] <> "=" THEN
        STATEMENT.MACRO = @TRUE
    END ELSE
        ASSIGNMENT.MACRO = @TRUE
    END

* check for a macro in an assignment, ie, %0 = MacroName (%1, %2, etc)
    BEGIN CASE

* get the first word after the equals sign and see if it's a macro name.
* if the macro has any parameters it will have an open parenthesis
* immediately after the name so we'll extract before the parenthesis
        CASE ASSIGNMENT.MACRO
            MACRO.NAME.PTR = 3

* check for the macro in a statement format, ie, Macroname (%0, %1, %2, etc)
        CASE STATEMENT.MACRO
            MACRO.NAME.PTR = 1

    END CASE

* get macro name from the program line.  if it doesn't have an open
* parenthesis in it then it's not a macro, it's something else
    MACRO.NAME = CLEAN.LINE [" ", MACRO.NAME.PTR, 1]

    IF COUNT(MACRO.NAME, "(") = 0 THEN
        RETURN
    END

* pull the macro name out of the expression before the open parenthesis.
* if it's not in the macro table then it's not a macro
    MACRO.NAME = MACRO.NAME ["(", 1, 1]

    LOCATE MACRO.NAME IN MACRO.KEYWORD.LIST SETTING MACRO.PTR ELSE
        RETURN
    END

* get a count of parameters in the program's macro and break the expression
* up
    PARAMETER.LIST = ""
    PARAMETER.COUNT = 0

    BEGIN CASE
        CASE ASSIGNMENT.MACRO
            EXTRACT.STRING = CLEAN.LINE [" ", 3, TO.THE.END] [LEN(MACRO.NAME) + 1, TO.THE.END]
        CASE STATEMENT.MACRO
            EXTRACT.STRING = CLEAN.LINE [LEN(MACRO.NAME) + 1, TO.THE.END]
    END CASE

    MACRO.STRING = TRIM(EXTRACT.STRING, " ", "B")

* convert spaces to space() functions if set up to convert
    IF SCAN.MACRO.SPACES THEN
        MACRO.STRING = CONVERT.LITERAL.SPACES(MACRO.STRING)
    END

    GOSUB EXTRACT.MACRO.PARAMETERS

* the first parameter (parameter zero) will be whatever's left of the equals
* sign for assignment macros.  if there is more than one parameter to the
* left of the equal sign we'll split them up with split.parameters, insert
* them as in the first parameter spot and adjust parameter.count by the
* number of parameters that appear left of the equals sign
    IF ASSIGNMENT.MACRO THEN

        MACRO.ASSIGNMENT.VARIABLE = TRIM(CLEAN.LINE [" ", 1, 1], " ", "B")
        MACRO.ASSIGNMENT.VARIABLE = SPLIT.PARAMETERS (MACRO.ASSIGNMENT.VARIABLE)
        MACRO.ASSIGNMENT.COUNT = DCOUNT(MACRO.ASSIGNMENT.VARIABLE, @AM)

        INS MACRO.ASSIGNMENT.VARIABLE BEFORE PARAMETER.LIST<1>

        PARAMETER.COUNT += MACRO.ASSIGNMENT.COUNT

    END

    GOSUB GET.MACRO.PTR

* couldn't find the macro with the right parameter count?
    IF MACRO.PTR = 0 THEN

        OBJECT.WARNING.DESC = "Can't find macro '":MACRO.NAME:"' expansion for ":PARAMETER.COUNT:" parameters"
        OBJECT.WARNING.LINE = LINE.LOOP
        GOSUB PRINT.OBJECT.WARNING                    

        RETURN

    END

* convert the macro expansion.  convert.macro.special.variables may
* use line.loop so we'll save it and restore it
    SAVE.LINE.LOOP = LINE.LOOP

* start with the macro expansion expression
    MACRO.STRING = MACRO.EXPAND.LIST<MACRO.PTR>
    GOSUB CONVERT.MACRO.SPECIAL.VARIABLES
    CLEAN.LINE = MACRO.STRING

    LINE.LOOP = SAVE.LINE.LOOP

* convert each "%" expression to the parameter from the code line.

* convert each "%%" expression to something that can be all or part of
* a valid variable name by changing any parenthesis, dynamic array,
* references, commas, etc to dots

* the "%%" expression is converted to the name of the variable in this
* macro position rather than the variable's value.  the variable name
* could be a dynamic array reference or a dimensioned variable so we'll
* use only the part of the variable name before "<" or "(" or "["
    BAD.VARIABLE.CHARACTERS = "()[]<>,'":'"'
    VARIABLE.DOTS = STR(".", LEN(BAD.VARIABLE.CHARACTERS))

    FOR PARM.LOOP = 1 TO PARAMETER.COUNT

        REPLACE.STRING = "%%":(PARM.LOOP - 1)
        REPLACE.WITH = PARAMETER.LIST<PARM.LOOP> 
        REPLACE.WITH = REPLACE.WITH ["(", 1, 1] ["<", 1, 1] ["[", 1, 1] [" ", 1, 1]
        REPLACE.WITH = CONVERT(BAD.VARIABLE.CHARACTERS, VARIABLE.DOTS, REPLACE.WITH)
        CLEAN.LINE = CHANGE(CLEAN.LINE, REPLACE.STRING, REPLACE.WITH)

        REPLACE.STRING = "%":(PARM.LOOP - 1)
        REPLACE.WITH = PARAMETER.LIST<PARM.LOOP>
        CLEAN.LINE = CHANGE(CLEAN.LINE, REPLACE.STRING, REPLACE.WITH)

    NEXT PARM.LOOP

* if this macro has an expression to be executed before the end
* of the current program structure add it to the line with "@START@"
* before and "@END@" after.  convert.braces will see this, extract
* it, and insert it at the end of the current expression
    MACRO.STRING = MACRO.END.EXECUTE.LIST<MACRO.PTR>
    GOSUB CONVERT.MACRO.SPECIAL.VARIABLES
    END.EXECUTE = MACRO.STRING

    IF END.EXECUTE <> "" THEN

* convert any "%" expressions in the end.execute expression
        FOR PARM.LOOP = 1 TO PARAMETER.COUNT
            REPLACE.STRING = "%":(PARM.LOOP - 1)
            REPLACE.WITH = PARAMETER.LIST<PARM.LOOP>
            END.EXECUTE = CHANGE(END.EXECUTE, REPLACE.STRING, REPLACE.WITH)
        NEXT PARM.LOOP

        CLEAN.LINE := " ":END.EXECUTE.START:" ":END.EXECUTE:" ":END.EXECUTE.END

    END

* if there's anything on the original program line after the macro
* add it onto the end
    IF AFTER.MACRO <> "" THEN
        CLEAN.LINE := " ":AFTER.MACRO
    END

* this can end up with extra spaces.  clean it up so it's not sloppy
    CLEAN.LINE = SMART.TRIM(CLEAN.LINE)

    IF SIMPLIFY.MULTIPLE.DYNAMICS THEN
        CLEAN.LINE = CONVERT.DYNAMIC.DUPE (CLEAN.LINE)
    END

    MACRO.CONVERTED = @TRUE

    RETURN

EXTRACT.MACRO.PARAMETERS: ************************************************
* extract macro parameters from macro.string.  macro.string should       *
* contain the parameter list after the macro name without the macro      *
* name                                                                   *
*                                                                        *
* returns the parameter list in parameter.list with parameter.count.     *
* returns after.macro with anything after the macro in the code line.    *
**************************************************************************

* the parameter list will begin with a parenthesis.  if it does remove
* the start parenthesis from the line
    IF MACRO.STRING [1, 1] = "(" THEN
        MACRO.STRING = MACRO.STRING [2, TO.THE.END]
    END

    MACRO.STRING.LEN = LEN(MACRO.STRING)

    PARAMETER.LIST = ""
    PARAMETER.COUNT = 0

    AFTER.MACRO = ""

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    IN.PREN = @FALSE
    PREN.DEPTH = 0

    IN.DYN = @FALSE
    DYN.DEPTH = 0

    IN.EXTRACT = @FALSE
    EXTRACT.DEPTH = 0

    IN.BRACES = @FALSE
    BRACE.DEPTH = 0

    START.PTR = 1
    END.PTR = MACRO.STRING.LEN + 1

* work through the line and split off parameters
    DONE = @FALSE

    FOR CHAR.PTR = 1 TO MACRO.STRING.LEN UNTIL DONE

        IF CHAR.PTR = 1 THEN
            PREV.CHAR = ""
        END ELSE
            PREV.CHAR = MACRO.STRING [CHAR.PTR - 1, 1]
        END

        THIS.CHAR = MACRO.STRING [CHAR.PTR, 1]
        NEXT.CHAR = MACRO.STRING [CHAR.PTR + 1, 1]
        END.PARAMETER = @FALSE

        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* parenthesis
            CASE THIS.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1

* if pren count went negative we must have started with a parenthesis
* and now we're hitting the closed pren.  end the parameter, remove the
* pren, and we're done with the line
                IF PREN.DEPTH < 0 THEN
                    END.PARAMETER = @TRUE
                    MACRO.STRING = MACRO.STRING [1, CHAR.PTR - 1]:MACRO.STRING [CHAR.PTR + 1, TO.THE.END]
                END
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END
            CASE IN.PREN
                NULL

* trap greater-than or less-than expressions.  there is difficulty determining
* if "<" is a less-than sign or the start of a dynamic array reference.
* it's also difficult to determine if ">" is a greater-than sign or the
* end of a dynamic array reference.  we'll try to trap the greater-than
* and less-than references before we get to where we're evaluating them
* as dynamic array references

* we can trap a less-than-or-equals sign by looking for the "=" before
* or after it.  the same with greater-than-or-equals

* if we see the less than sign and the rest of the parameters have no
* greater-than sign we'll assume it's a less-than sign and not a dynamic 
* array reference

* if we see a greater-than sign and there is no less-than sign (opening
* a dynamic array reference) before it we'll assume it's a greater-than sign

* not equals
            CASE THIS.CHAR = "<" AND NEXT.CHAR = ">"
                NULL
            CASE THIS.CHAR = ">" AND PREV.CHAR = "<"
                NULL

* less than or equals sign
            CASE THIS.CHAR = "<" AND (NEXT.CHAR = "=" OR PREV.CHAR = "=")
                NULL

* greater than or equals sign
            CASE THIS.CHAR = ">" AND (NEXT.CHAR = "=" OR PREV.CHAR = "=")
                NULL

* less than sign
            CASE THIS.CHAR = "<" AND COUNT(MACRO.STRING [CHAR.PTR + 1, 1000], ">") = 0
                NULL

* greater-than sign
*           CASE THIS.CHAR = ">" AND COUNT(MACRO.STRING [1, CHAR.PTR - 1], "<") = 0
*               NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = MACRO.STRING
                    DYNAM.START.PTR = CHAR.PTR
                    GOSUB CHECK.STARTING.DYNAMIC
                END ELSE
                    DYNAM.START = @TRUE
                END
                
                IF DYNAM.START THEN
                    IN.DYN = @TRUE
                    DYN.DEPTH += 1
                END

            CASE THIS.CHAR = ">" AND DYN.DEPTH > 0
                IF TEST.DYNAMIC.REFERENCES THEN
                    DYNAM.CHECK.LINE = MACRO.STRING
                    DYNAM.END.PTR = CHAR.PTR
                    GOSUB CHECK.ENDING.DYNAMIC
                END ELSE
                    DYNAM.END = @TRUE
                END

                IF DYNAM.END THEN
                    DYN.DEPTH -= 1
                    IF DYN.DEPTH < 1 THEN
                        DYN.DEPTH = 0
                        IN.DYN = @FALSE
                    END
                END

            CASE IN.DYN
                NULL

* text references
            CASE THIS.CHAR = "["
                IN.EXTRACT = @TRUE
                EXTRACT.DEPTH += 1
            CASE THIS.CHAR = "]"
                EXTRACT.DEPTH -= 1
                IF EXTRACT.DEPTH < 1 THEN
                    EXTRACT.DEPTH = 0
                    IN.EXTRACT = @FALSE
                END
            CASE IN.EXTRACT
                NULL

* associated reference (braces)
            CASE THIS.CHAR = "{"
                IN.BRACES = @TRUE
                BRACE.DEPTH += 1
            CASE THIS.CHAR = "}"
                BRACE.DEPTH -= 1
                IF BRACE.DEPTH < 1 THEN
                    BRACE.DEPTH = 0
                    IN.BRACES = @FALSE
                END
            CASE IN.BRACES
                NULL

* comma or end of line
            CASE THIS.CHAR = "," OR THIS.CHAR = "" OR THIS.CHAR = ";"
                END.PARAMETER = @TRUE

* braces
            CASE THIS.CHAR = OPEN.BRACE OR THIS.CHAR = CLOSE.BRACE
                END.PARAMETER = @TRUE

        END CASE

* if we've hit the end of this parameter extract it from the code and add
* it to the parameter list
        IF END.PARAMETER THEN

            THIS.ADD.PARAMETER = TRIM(MACRO.STRING [START.PTR, CHAR.PTR - START.PTR], " ", "B")

* if dyn.depth is not zero then we hit a "<" that was a less-than rather
* then the start of a dynamic array reference.  anything after the
* "<" was a parameter of the macro not a parameter of the dynamic array
* extract.  loop backwards through this.add.parameter until we hit all
* of the erroneous "<"'s and change the commas to ams to separate the
* macro parameters
            IF DYN.DEPTH <> 0 THEN
                GOSUB FIX.MISTAKEN.DYNAMIC.ARRAY
            END

            IF THIS.ADD.PARAMETER <> "" THEN
                PARAMETER.LIST<PARAMETER.COUNT + 1> = THIS.ADD.PARAMETER
                PARAMETER.COUNT += DCOUNT(THIS.ADD.PARAMETER, @AM)
            END
            START.PTR = CHAR.PTR + 1

        END

* check for end of line
        BEGIN CASE

* we ran out of characters we're at the end of the program line
            CASE THIS.CHAR = ""
                END.PTR = CHAR.PTR
                DONE = @TRUE

* if we're still in quotes none of this matters
            CASE IN.QUOTES
                NULL

* we've hit a character indicating the end of the line
            CASE THIS.CHAR = ";"
                END.PTR = CHAR.PTR
                DONE = @TRUE

* pren depth went negative.  we must have started the parameter list
* with an open pren and this is the end.
            CASE PREN.DEPTH < 0
                END.PTR = CHAR.PTR
                DONE = @TRUE

        END CASE

    NEXT CHAR.PTR

* end.ptr points to the first character of the rest of the line after the
* macro.  if there are spaces before end.ptr back it up so we preserve
* the spaces
    LOOP UNTIL END.PTR <= 2 OR MACRO.STRING [END.PTR - 1, 1] <> " " DO
        END.PTR -= 1
    REPEAT

* extract the code after the end of the macro
    AFTER.MACRO = MACRO.STRING [END.PTR, TO.THE.END]

    RETURN

FIX.MISTAKEN.DYNAMIC.ARRAY: **********************************************
* if dyn.depth is not zero then we hit a "<" that was a less-than rather *
* then the start of a dynamic array reference.  anything after the       *
* "<" was a parameter of the macro not a parameter of the dynamic array  *
* extract.  loop backwards through this.add.parameter until we hit all   *
* of the erroneous "<"'s and change the commas to ams to separate the    *
* macro parameters                                                       *
*                                                                        *
* this isn't perfect.  some parameter lists with dyanmic array           *
* references and ">" or "<" signs may confuse things still.  if this     *
* happens the parameter list will have to be simplified                  *
**************************************************************************
    LEN.ADD.PARAMETER = LEN(THIS.ADD.PARAMETER)

    FOR COMMA.LOOP = LEN.ADD.PARAMETER TO 1 STEP -1 UNTIL DYN.DEPTH = 0

        THIS.CHAR = THIS.ADD.PARAMETER [COMMA.LOOP, 1]
        NEXT.CHAR = THIS.ADD.PARAMETER [COMMA.LOOP + 1, 1]
        IF COMMA.LOOP > 1 THEN
            PREV.CHAR = THIS.ADD.PARAMETER [COMMA.LOOP - 1, 1]
        END ELSE
            PREV.CHAR = ""
        END

        IN.QUOTES = @FALSE
        THIS.QUOTE = ""

        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* entering / leaving a dynamic array reference
            CASE THIS.CHAR = "<" AND NEXT.CHAR <> "=" AND PREV.CHAR <> "=" AND NEXT.CHAR <> ">"
                DYN.DEPTH -= 1
            CASE THIS.CHAR = ">" AND NEXT.CHAR <> "=" AND PREV.CHAR <> "=" AND PREV.CHAR <> "<"
                DYN.DEPTH += 1

* comma.  treat as a parameter separator
            CASE THIS.CHAR = ","
                THIS.ADD.PARAMETER [COMMA.LOOP, 1] = @AM

        END CASE

    NEXT COMMA.LOOP

    RETURN

GET.MACRO.PTR: ***********************************************************
* find a macro definition with the same parameter count                  *
**************************************************************************
    NO.MACRO.PTR = @FALSE
    MACRO.PTR = 0
    FOUND.MACRO.COUNT = 1
    
    LOOP

        LOCATE MACRO.NAME IN MACRO.KEYWORD.LIST, FOUND.MACRO.COUNT SETTING FOUND.MACRO.PTR THEN
            IF MACRO.PARM.COUNT.LIST<FOUND.MACRO.PTR> = PARAMETER.COUNT THEN
                MACRO.PTR = FOUND.MACRO.PTR
            END ELSE
                FOUND.MACRO.COUNT += 1
            END
        END ELSE
            NO.MACRO.PTR = @TRUE
        END

    UNTIL MACRO.PTR <> 0 OR NO.MACRO.PTR REPEAT

    RETURN

CONVERT.MACRO.SPECIAL.VARIABLES: *****************************************
* convert any special variables in macro.string:                         *
*                                                                        *
* string                replaced with                                    *
*                                                                        *
* $new.counter$         increments the macro variable counter and        *
*                       substitutes the new value                        *
* $counter$             current macro variable counter                   *
*                                                                        *
* $object.name$         current object name                              *
* $method.name$         current method name                              *
*                                                                        *
* $create.new.object$   code to create a new object instance             *
* $destroy.object$      code to destroy the current object instance      *
*                                                                        *
* $is.resident$         returns true if this object instance is a        *
*                       resident instance, false otherwise               *
* $is.nonresident$      returns true if this object is not a resident    *
*                       instance, false otherwise                        *
* $set.resident$        code to set the current object instance as a     *
*                       resident object instance                         *
* $unset.resident$      code to set current object as a nonresident      *
*                       object instance                                  *
*                                                                        *
* $set.create.resident$ set flags so that any child objects created will *
*                       be created as resident objects                   *
* $unset.create.resident$  set flags so that any child objects will be   *
*                       created as non-resident.  only use to restore    *
*                       settings after using $set.create.resident$       *
* $is.create.resident$  are things set up to create resident objects and *
*                       child objects?                                   *
* $is.create.nonresident$ are things set up to create nonresident        *
*                       objects and child objects?                       *
*                                                                        *
* $set.single$          code to set the current object as a "single-     *
*                       instance" object instance but not as a resident  *
*                       object                                           *
* $unset.single$        code to set the current object as a non-single-  *
*                       instance object                                  *
*                                                                        *
*                                                                        *
* $load$                reload current object instance properties from   *
*                       the instance properties arrays                   *
* $save$                save the current object instance properties in   *
*                       the instance properties arrays                   *
* $clear$               initialize (clear) the current instance          *
*                       properties                                       *
* $check$               check the current instance properties against    *
*                       object.handle and reload if they're for a        *
*                       different object instance                        *
* $new$                 discard current object handle and create a new   *
*                       one                                              *
*                                                                        *
* $exit$                exit to the calling program                      *
* $exit.on.error$       on an error exit to the calling program          *
* $show.error$          on an error display the error and exit to the    *
*                       calling program                                  *
**************************************************************************
    CREATE.LINE = @FALSE
    DESTROY.LINE = @FALSE
    ADD.REGISTRY = @FALSE

    IF COUNT(MACRO.STRING, "$") = 0 THEN
        RETURN
    END

* macro variable counter
    IF INDEX(MACRO.STRING, "$NEW.COUNTER$", 1) > 0 THEN
        MACRO.VARIABLE.COUNTER += 1
        SPECIAL.NAME = "$NEW.COUNTER$"
        SPECIAL.VALUE = MACRO.VARIABLE.COUNTER
        GOSUB CONVERT.ONE.MACRO.VARIABLE
    END

    SPECIAL.NAME = "$COUNTER$"
    SPECIAL.VALUE = MACRO.VARIABLE.COUNTER
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* names
    SPECIAL.NAME = "$OBJECT.NAME$"
    SPECIAL.VALUE = OBJECT.NAME
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$METHOD.NAME$"
    SPECIAL.VALUE = METHOD
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* create / destroy current object
    CREATE.LINE = @TRUE
    SPECIAL.NAME = "$CREATE.NEW.OBJECT$"
    SPECIAL.VALUE = ""    
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    CREATE.LINE = @FALSE
    DESTROY.LINE = @TRUE
    SPECIAL.NAME = "$DESTROY.OBJECT$"
    SPECIAL.VALUE = OBJECT.DESTROY.LINE
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* resident / single-instance settings
    DESTROY.LINE = @FALSE
    SPECIAL.NAME = "$IS.RESIDENT$"
    SPECIAL.VALUE = "OBJECT.HANDLE<6> = @TRUE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$IS.NONRESIDENT$"
    SPECIAL.VALUE = 'OBJECT.HANDLE<6> = @FALSE OR OBJECT.HANDLE<6> = ""'
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    DESTROY.LINE = @FALSE
    SPECIAL.NAME = "$IS.SINGLE$"
    SPECIAL.VALUE = "OBJECT.HANDLE<7> = @TRUE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$IS.NONSINGLE$"
    SPECIAL.VALUE = 'OBJECT.HANDLE<7> = @FALSE OR OBJECT.HANDLE<7> = ""'
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    ADD.REGISTRY = @TRUE
    REGISTRY.COMMAND = "RESIDENT"
    SPECIAL.NAME = "$SET.RESIDENT$"
    SPECIAL.VALUE = "OBJECT.HANDLE<6> = @TRUE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    REGISTRY.COMMAND = "NONRESIDENT"
    SPECIAL.NAME = "$UNSET.RESIDENT$"
    SPECIAL.VALUE = "OBJECT.HANDLE<6> = @FALSE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    REGISTRY.COMMAND = "SINGLE"
    SPECIAL.NAME = "$SET.SINGLE$"
    SPECIAL.VALUE = "OBJECT.HANDLE<7> = @TRUE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    REGISTRY.COMMAND = "NONSINGLE"
    SPECIAL.NAME = "$UNSET.SINGLE$"
    SPECIAL.VALUE = "OBJECT.HANDLE<7> = @FALSE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* set / test object creation flags
    ADD.REGISTRY = @FALSE
    SPECIAL.NAME = "$SET.CREATE.RESIDENT$"
    SPECIAL.VALUE = "SAVE.INSTANCE.REGISTRY.SOURCE.ID = INSTANCE.REGISTRY.SOURCE.ID ; "
    SPECIAL.VALUE := "SAVE.REGISTRY.SOURCE.ID = REGISTRY.SOURCE.ID ; "
    SPECIAL.VALUE := "REGISTRY.SOURCE.ID = -1"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$UNSET.CREATE.RESIDENT$"
    SPECIAL.VALUE = "INSTANCE.REGISTRY.SOURCE.ID = SAVE.INSTANCE.REGISTRY.SOURCE.ID ; "
    SPECIAL.VALUE := "REGISTRY.SOURCE.ID = SAVE.REGISTRY.SOURCE.ID"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$IS.CREATE.RESIDENT$"
    SPECIAL.VALUE = "INSTANCE.REGISTRY.SOURCE.ID < 1"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$IS.CREATE.NONRESIDENT$"
    SPECIAL.VALUE = "INSTANCE.REGISTRY.SOURCE.ID >= 0"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* calling instance subroutines
    SPECIAL.NAME = "$LOAD$"
    SPECIAL.VALUE = 'LAST.OBJECT.HANDLE = "" ; '
    SPECIAL.VALUE := "GOSUB LOAD.CURRENT.OBJECT.INSTANCE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$SAVE$"
    SPECIAL.VALUE = "GOSUB SAVE.CURRENT.OBJECT.INSTANCE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$CLEAR$"
    SPECIAL.VALUE = "GOSUB INIT.CURRENT.OBJECT.INSTANCE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$CHECK$"
    SPECIAL.VALUE = "GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$NEW$"
    SPECIAL.VALUE = "GOSUB GET.NEW.OBJECT.HANDLE"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

* exiting / errors
    SPECIAL.NAME = "$EXIT$"
    SPECIAL.VALUE = "GOSUB EXIT.TO.CALLING.PROGRAM"
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$EXIT.ON.ERROR$"
    SPECIAL.VALUE = 'GOSUB EXIT.IF.ERROR.MESSAGE'
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    SPECIAL.NAME = "$SHOW.ERROR$"
    SPECIAL.VALUE = 'GOSUB CATCH.OBJECT.ERROR'
    GOSUB CONVERT.ONE.MACRO.VARIABLE

    RETURN

CONVERT.ONE.MACRO.VARIABLE: **********************************************
* convert special.name to special.value in macro.string.  checks and     *
* converts special.value and downcase(special.value)                     *
**************************************************************************
    IF INDEX(MACRO.STRING, SPECIAL.NAME, 1) > 0 THEN
        GOSUB GET.OBJECT.LINE
        MACRO.STRING = CHANGE(MACRO.STRING, SPECIAL.NAME, SPECIAL.VALUE)
    END

    SPECIAL.NAME = DOWNCASE(SPECIAL.NAME)

    IF INDEX(MACRO.STRING, SPECIAL.NAME, 1) > 0 THEN
        GOSUB GET.OBJECT.LINE
        MACRO.STRING = CHANGE(MACRO.STRING, SPECIAL.NAME, SPECIAL.VALUE)
    END

    RETURN

GET.OBJECT.LINE: *********************************************************
* return special.value as object.create.line or object.destroy.line      *
* depending on flags create.line and destroy.line                        *
**************************************************************************
    IF CREATE.LINE THEN
        GOSUB BUILD.OBJECT.CREATE.LINE
        SPECIAL.VALUE = 'LAST.OBJECT.HANDLE = "" ; OBJECT.HANDLE = "" ; ':OBJECT.CREATE.LINE
    END

    IF DESTROY.LINE THEN
        GOSUB BUILD.OBJECT.DESTROY.LINE
        SPECIAL.VALUE = OBJECT.DESTROY.LINE
    END

* concatenate a registry update to special value
    IF ADD.REGISTRY THEN

        SPECIAL.VALUE := ' ; REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("':REGISTRY.COMMAND:'", '

        BEGIN CASE

            CASE PASS.REGISTRY.HANDLES.BYVAL
                SPECIAL.VALUE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            CASE 1
                 SPECIAL.VALUE := "OBJECT.HANDLE, "

        END CASE
    
        SPECIAL.VALUE := '"':ECLIPSE.PREFIX:'", "", "", REGISTRY.ERROR)'

    END

    RETURN

CONVERT.WRAPUP: **********************************************************
* wrap up after converting clean.line with shortcuts                     *
**************************************************************************

* rebuild this.line with converted line
    IF LABEL <> "" THEN
        THIS.LINE = LABEL:":":SPACE(INDENT.COUNT):CLEAN.LINE
    END ELSE
        THIS.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
    END

* clean the line up again
    CLEAN.LINE = THIS.LINE
    GOSUB CLEAN.LINE

* build new.line with converted line
    IF LABEL <> "" THEN
        NEW.LINE = LABEL:":":SPACE(INDENT.COUNT):CLEAN.LINE
    END ELSE
        NEW.LINE = SPACE(INDENT.COUNT):CLEAN.LINE
    END

* if we found a shortcut conversion set unresolved.reference.found false
    IF NEW.LINE <> "" THEN
        UNRESOLVED.REFERENCE.FOUND = @FALSE
    END

    RETURN

ADD.TEMPORARY.MACROS: ****************************************************
* search through the code for temporary macros and add them to the       *
* macro list with the temporary.macro flag set.                          *
* temporary macros are defined in the code like this:                    *
*                                                                        *
*     macro macro.name macro.definition                                  *
*                                                                        *
* where "macro.definition" follows the same form as the "Expand" part    *
* of the macros set up in the compile.setup control record               *
**************************************************************************
    SETREM 0 ON PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

*       THIS.LINE = PROGRAM.CODE<LINE.LOOP>
        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any macros in it
        TRIM.THIS.LINE = TRIM(THIS.LINE)

        IF TRIM.THIS.LINE <> "" AND TRIM.THIS.LINE [1, 1] <> "*" AND TRIM.THIS.LINE [1, 1] <> "!" THEN

            IF IS.CODE(THIS.LINE) THEN

                CLEAN.LINE = THIS.LINE
                GOSUB CLEAN.LINE

                IF UPCASE(CLEAN.LINE [" ", 1, 1]) = UPCASE(MACRO.KEYWORD) THEN
                    GOSUB ADD.ONE.TEMPORARY.MACRO
                END

            END

        END

    NEXT LINE.LOOP

* set all temporary macro program lines as comments
    FOR MACRO.LOOP = 1 TO MACRO.COUNT

        IF MACRO.TEMPORARY.LIST<MACRO.LOOP> THEN
            MACRO.LINE = MACRO.TEMPORARY.LINE.LIST<MACRO.LOOP>
            PROGRAM.CODE<MACRO.LINE> = "*":PROGRAM.CODE<MACRO.LINE> [2, TO.THE.END]
        END

    NEXT MACRO.LOOP

    RETURN

ADD.ONE.TEMPORARY.MACRO: *************************************************
* extract a temporary macro from this.line and add to the macro list     *
* with the temporary flag set                                            *
**************************************************************************

* the form is "macro macro.name macro.definition".  extract the temporary
* macro name and its definition
    MACRO.NAME = CLEAN.LINE [" ", 2, 1]
    MACRO.DEFINITION = CLEAN.LINE [" ", 3, TO.THE.END]

* find largest parameter in the macro definition so we can get a parameter
* count
    MAX.PARAMETER = 0
    PERCENT.COUNT = COUNT(MACRO.DEFINITION, "%")

    FOR PERCENT.LOOP = 1 TO PERCENT.COUNT

        PERCENT.PTR = INDEX(MACRO.DEFINITION, "%", PERCENT.LOOP)
        THIS.PARAMETER = ""

        LOOP
            PERCENT.PTR += 1
            THIS.CHAR = MACRO.DEFINITION [PERCENT.PTR, 1]
        UNTIL NOT(NUM(THIS.CHAR)) OR THIS.CHAR = ""
            THIS.PARAMETER := THIS.CHAR
        REPEAT

        IF THIS.PARAMETER + 1 > MAX.PARAMETER THEN
            MAX.PARAMETER = THIS.PARAMETER + 1
        END

    NEXT PERCENT.LOOP

* add to the macro list with the temporary flag set.  we'll use the
* temporary flag later to remove all temporary macros from the list
    MACRO.COUNT += 1

    MACRO.KEYWORD.LIST<MACRO.COUNT> = MACRO.NAME

    MACRO.DESCRIPTION.LIST<MACRO.COUNT> = "Temporary Macro"

    MACRO.PARM.COUNT.LIST<MACRO.COUNT> = MAX.PARAMETER

    MACRO.EXPAND.LIST<MACRO.COUNT> = MACRO.DEFINITION
    MACRO.END.EXECUTE.LIST<MACRO.COUNT> = ""

    MACRO.DISPLAY.STYLE.LIST<MACRO.COUNT> = ""

    MACRO.TEMPORARY.LIST<MACRO.COUNT> = @TRUE
    MACRO.TEMPORARY.LINE.LIST<MACRO.COUNT> = LINE.LOOP

    RETURN

REMOVE.TEMPORARY.MACROS: *************************************************
* remove all temporary macros from the macro list                        *
**************************************************************************
    FOR MACRO.LOOP = MACRO.COUNT TO 1 STEP -1

        IF MACRO.TEMPORARY.LIST<MACRO.LOOP> THEN
            DEL MACRO.KEYWORD.LIST<MACRO.LOOP>
            DEL MACRO.DESCRIPTION.LIST<MACRO.LOOP>
            DEL MACRO.PARM.COUNT.LIST<MACRO.LOOP>
            DEL MACRO.EXPAND.LIST<MACRO.LOOP>
            DEL MACRO.END.EXECUTE.LIST<MACRO.LOOP>
            DEL MACRO.DISPLAY.STYLE.LIST<MACRO.LOOP>
            DEL MACRO.TEMPORARY.LIST<MACRO.LOOP>
            DEL MACRO.TEMPORARY.LINE.LIST<MACRO.LOOP>
            MACRO.COUNT -= 1
        END

    NEXT MACRO.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / code expanding / unary functions                   **
**************************************************************************
**************************************************************************

CONVERT.UNARY.FUNCTIONS: *************************************************
* convert any unary functions to the "expanded" versions of the          *
* functions.  ie, convert "trim(var)" to "var = trim(var)"               *
**************************************************************************
    UNARY.START.DATE = DATE()
    UNARY.START.TIME = TIME()

* copy program.code to old.program.code so that we can use a remove
* statement on it.  we'll be changing program.code and that would reset
* the remove pointer
    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* skip any obvious lines that won't have any macros in it.  if the line is
* null, if it's a comment, if doesn't have at least one opening parenthesis,
* or if it's not code then skip the macro checking
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        FIRST.CHAR = TRIM.THIS.LINE [1, 1]

        CHECK.THIS.LINE = @TRUE
        CHECK.UNARY.FUNCTION = @TRUE
        CHECK.UNARY.TEXT.EXTRACT = @TRUE

        BEGIN CASE

            CASE TRIM.THIS.LINE = ""
                CHECK.THIS.LINE = @FALSE

            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                CHECK.THIS.LINE = @FALSE

            CASE NOT(IS.CODE(THIS.LINE))
                CHECK.THIS.LINE = @FALSE

* if there aren't any parenthesis in the line then we can't have an unary
* function.  it could still be an unary text extract, though
            CASE COUNT(TRIM.THIS.LINE, "(") = 0
                CHECK.UNARY.FUNCTION = @FALSE

* if there aren't any braces in the line then we can't have an unary text
* extract
            CASE COUNT(TRIM.THIS.LINE, "[") = 0
                CHECK.UNARY.TEXT.EXTRACT = @FALSE

        END CASE

* if this is a code line first try any unary function conversions.  if there
* aren't any check for any unary text extracts
        IF CHECK.THIS.LINE THEN

            UNARY.CONVERTED = @FALSE
            CONVERTED.UNARY.LINE = ""

            IF CHECK.UNARY.FUNCTION THEN
                GOSUB CONVERT.UNARY.SINGLE.LINE
            END

            IF NOT(UNARY.CONVERTED) AND CHECK.UNARY.TEXT.EXTRACT THEN
                GOSUB CONVERT.UNARY.TEXT.EXTRACT
            END

            IF UNARY.CONVERTED THEN
                PROGRAM.CODE<LINE.LOOP> = CONVERTED.UNARY.LINE
            END

        END

    NEXT LINE.LOOP

    UNARY.END.DATE = DATE()
    UNARY.END.TIME = TIME()
    UNARY.ELAPSED.TIME += TIME.ELAPSED (UNARY.START.DATE, UNARY.START.TIME)

    RETURN

CONVERT.UNARY.SINGLE.LINE: ***********************************************
* check this.line to see if it's an unary expression, ie, "trim(var)"    *
* instead of "var = trim(var)".  if it is expand the unary expression    *
* to one that's valid for the compiler                                   *
**************************************************************************
    UNARY.CONVERTED = @FALSE
    CONVERTED.UNARY.LINE = ""

* extract the label for this line if there is one
    THIS.LABEL = LINE.LABEL (THIS.LINE)
    INDENT.COUNT = FIND.INDENT.COUNT (THIS.LABEL, THIS.LINE)

    IF THIS.LABEL <> "" THEN
        THIS.LINE = LINE.WITHOUT.LABEL (THIS.LINE)
    END ELSE
        THIS.LINE = TRIM(THIS.LINE, " ", "B")
    END

* if this line is an unary function it will begin with a function in the
* unary.keyword.list followed by an open parenthesis and will have a close
* parenthesis somewhere.  note:  the close parenthesis may not necessarily
* be at the end of the code line as other code could follow the unary
* function
    IF COUNT(THIS.LINE, ")") = 0 THEN
        RETURN
    END

    IF COUNT(THIS.LINE, "(") = 0 THEN
        RETURN
    END

    THIS.KEYWORD = TRIM(THIS.LINE ["(", 1, 1], " ", "B")

* if there are any spaces in what should be the function name then this
* can't be an unary keyword
    IF COUNT(THIS.KEYWORD, " ") <> 0 THEN
        RETURN
    END

* the function must be in the unary function list for it to be a valid unary
* function
    THIS.KEYWORD = UPCASE(THIS.KEYWORD)
    LOCATE THIS.KEYWORD IN UNARY.KEYWORD.LIST SETTING KEYWORD.PTR ELSE
        RETURN
    END

* this line is an unary expression.  get a list of the expression's
* parameters
    PARAMETER.STRING = THIS.LINE ["(", 2, TO.THE.END]
    PARAMETER.LIST = SPLIT.PARAMETERS (PARAMETER.STRING)
    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST, @AM)

* if we have no parameters something's off.  don't convert
    IF PARAMETER.COUNT = 0 THEN
        RETURN
    END

* if the first parameter is also an unary function then we have nested unary
* functions and they have to be expanded one at a time.  see how many levels
* deep this unary expression goes
    UNARY.DEPTH = 1
    AT.BOTTOM.DEPTH = @FALSE

    NESTED.PARAMETER.LIST = PARAMETER.LIST
    NESTED.PARAMETER.COUNT = PARAMETER.COUNT

    DEEPEST.PARAMETER.LIST = PARAMETER.LIST
    DEEPEST.PARAMETER.COUNT = PARAMETER.COUNT

    LOOP UNTIL AT.BOTTOM.DEPTH

        TEST.KEYWORD = NESTED.PARAMETER.LIST<1>

        BEGIN CASE 

            CASE COUNT(TEST.KEYWORD, "(") = 0
                AT.BOTTOM.DEPTH = @TRUE

            CASE 1
                CHECK.KEYWORD = UPCASE(TRIM(TEST.KEYWORD ["(", 1, 1]))

                LOCATE CHECK.KEYWORD IN UNARY.KEYWORD.LIST SETTING KEYWORD.PTR THEN

                    NESTED.PARAMETER.STRING = TEST.KEYWORD ["(", 2, TO.THE.END]
                    NESTED.PARAMETER.LIST = SPLIT.PARAMETERS (NESTED.PARAMETER.STRING)
                    NESTED.PARAMETER.COUNT = DCOUNT(NESTED.PARAMETER.LIST, @AM)

                    IF NESTED.PARAMETER.COUNT > 0 THEN

                        UNARY.DEPTH += 1

                        DEEPEST.PARAMETER.LIST = NESTED.PARAMETER.LIST
                        DEEPEST.PARAMETER.COUNT = NESTED.PARAMETER.COUNT

                    END ELSE
                        AT.BOTTOM.DEPTH = @TRUE
                    END

                END ELSE

                    AT.BOTTOM.DEPTH = @TRUE

                END

        END CASE

    REPEAT

* if this line has a label start with the label.  otherwise set the
* line indention
    IF THIS.LABEL <> "" THEN
        CONVERTED.UNARY.LINE = THIS.LABEL:SPACE(INDENT.COUNT)
    END ELSE
        CONVERTED.UNARY.LINE = SPACE(INDENT.COUNT)
    END

* if the unary expression is nested the variable will be the first parameter
* of the deepest nested unary expression
    UNARY.VARIABLE.NAME = DEEPEST.PARAMETER.LIST<1>

* there could be a text extract on the unary variable name.  if so only use
* the variable name without the text extract
    IF COUNT(UNARY.VARIABLE.NAME, "[") > 0 THEN
        UNARY.VARIABLE.NAME = TRIM (UNARY.VARIABLE.NAME ["[", 1, 1])
    END

    CONVERTED.UNARY.LINE := UNARY.VARIABLE.NAME:" = ":THIS.LINE

    UNARY.CONVERTED = @TRUE

    RETURN

CONVERT.UNARY.TEXT.EXTRACT: **********************************************
* check this.line to see if it's an unary text extract.  if it is        *
* convert it to an assignment statment that uv can compile.  for         *
* for example, "variable [1, 2]" would expand to                         *
* "variable = variable [1, 2]"                                           *
**************************************************************************
    UNARY.CONVERTED = @FALSE
    CONVERTED.UNARY.LINE = ""

* if there's an equals sign in the line it's not an unary expression
    IF COUNT(THIS.LINE, "=") > 0 THEN
        RETURN
    END

* there has to be at least one open bracket or it's not a text extract.
    IF COUNT(THIS.LINE, "[") = 0 THEN
        RETURN
    END

* extract the label for this line if there is one
    THIS.LABEL = LINE.LABEL (THIS.LINE)
    INDENT.COUNT = FIND.INDENT.COUNT (THIS.LABEL, THIS.LINE)

    IF THIS.LABEL <> "" THEN
        THIS.LINE = LINE.WITHOUT.LABEL (THIS.LINE)
    END ELSE
        THIS.LINE = TRIM(THIS.LINE, " ", "B")
    END

* extract the (possible) variable name ahead of the text extract.  if there
* are any spaces in the variable name then something's amiss and we won't
* convert the code line
    UNARY.VARIABLE.NAME = TRIM(THIS.LINE ["[", 1, 1])

    IF COUNT(UNARY.VARIABLE.NAME, " ") > 0 THEN
        RETURN
    END

* if the (possible) variable name has any invalid characters in it then it
* isn't a variable name
    INVALID.CHAR.LIST = "~`!@#%^&*-=+\|;:',?/":"'"
    IF CONVERT(INVALID.CHAR.LIST, "", UNARY.VARIABLE.NAME) <> UNARY.VARIABLE.NAME THEN
        RETURN
    END

* build the converted assignment line.  if this line has a label start with
* the label.  otherwise set the line indention
    IF THIS.LABEL <> "" THEN
        CONVERTED.UNARY.LINE = THIS.LABEL:SPACE(INDENT.COUNT)
    END ELSE
        CONVERTED.UNARY.LINE = SPACE(INDENT.COUNT)
    END

    CONVERTED.UNARY.LINE := UNARY.VARIABLE.NAME:" = ":THIS.LINE

    UNARY.CONVERTED = @TRUE

    RETURN


**************************************************************************
**************************************************************************
** code conversion / case conversions                                   **
**************************************************************************
**************************************************************************

UPCASE.PROGRAM.CODE: *****************************************************
* convert anything to upper case that's not enclosed in quotes           *
**************************************************************************
    NEW.PROGRAM.CODE = ""
    SETREM 0 ON PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

        GOSUB UPCASE.ONE.LINE

        IF LINE.LOOP = 1 THEN
            NEW.PROGRAM.CODE = THIS.LINE
        END ELSE
            NEW.PROGRAM.CODE := @AM:THIS.LINE
        END

    NEXT LINE.LOOP

    PROGRAM.CODE = NEW.PROGRAM.CODE

    RETURN

UPCASE.OBJECT.CODE: ******************************************************
* convert anything in object.text to upper case that's not enclosed      *
* in quotes                                                              *
**************************************************************************
    NEW.OBJECT.CODE = ""
    SETREM 0 ON OBJECT.CODE

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        GOSUB UPCASE.ONE.LINE

        IF LINE.LOOP = 1 THEN
            NEW.OBJECT.CODE = THIS.LINE
        END ELSE
            NEW.OBJECT.CODE := @AM:THIS.LINE
        END

    NEXT LINE.LOOP

    OBJECT.CODE = NEW.OBJECT.CODE

    RETURN

UPCASE.ONE.LINE: *********************************************************
* convert this line to upper case                                        *
**************************************************************************
    LINE.CONVERTED = @FALSE

* don't convert if it's not a code line
    IF NOT(IS.CODE(THIS.LINE)) THEN
        RETURN
    END

* go through the line and convert anything not in quotes to upper case
    THIS.LEN = LEN(THIS.LINE)
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    FOR PTR = 1 TO THIS.LEN

        THIS.CHAR = THIS.LINE [PTR, 1]

        BEGIN CASE

* handle quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* if we're not in quotes and this is a lower case character convert it
* to upper case
            CASE THIS.CHAR >= "a" AND THIS.CHAR <= "z"
                THIS.LINE [PTR, 1] = UPCASE(THIS.CHAR)
                LINE.CONVERTED = @TRUE

        END CASE

    NEXT PTR

    RETURN


**************************************************************************
**************************************************************************
** code conversion / utilities / program line cleanup                   **
**************************************************************************
**************************************************************************

CLEAN.LINE: **************************************************************
* clean up clean.line to make it easier to find things.  breaks off      *
* label into clean.label if there is one                                 *
**************************************************************************
    CLEAN.LINE.START.DATE = DATE()
    CLEAN.LINE.START.TIME = TIME()

    CLEAN.LABEL = ""

* if this line isn't code return without changing anything
    IF NOT(IS.CODE(CLEAN.LINE)) THEN
        RETURN
    END

* objects end up having a lot of common lines from one method to another.
* we can speed up object compilation by keeping an index of the original
* code lines to the "cleaned" code lines and looking up the code lines
* in this index
    IF COMPILE.OBJECT THEN
        USE.CLEAN.LINE.INDEX = USE.CLEAN.LINE.INDEX.OBJECTS
    END ELSE
        USE.CLEAN.LINE.INDEX = USE.CLEAN.LINE.INDEX.SUBROUTINES
    END

    CLEAN.LINE = SMART.TRIM(CLEAN.LINE)

* if the first word is a label chop it off
    CLEAN.LABEL = LINE.LABEL(CLEAN.LINE)

    IF CLEAN.LABEL <> "" THEN
        CLEAN.LINE = LINE.WITHOUT.LABEL(CLEAN.LINE)
    END

* if clean.line is in the clean line indexes get the last converted value
* for this line and return
    IF USE.CLEAN.LINE.INDEX THEN

        LOCATE CLEAN.LINE IN CLEAN.SOURCE.INDEX SETTING CLEAN.PTR THEN
            CLEAN.LINE = CLEAN.FINAL.INDEX<CLEAN.PTR>
            GOSUB STAMP.CLEAN.LINE
            RETURN
        END

        ORIGINAL.CLEAN.LINE = CLEAN.LINE

    END

* if spaces follow or preceed any of these characters we'll remove them
    IF UNASSIGNED(CLEAN.FOLLOWING) THEN

        CLEAN.FOLLOWING = ", ":@AM:") ":@AM:"( ":@AM:"< ":@AM:"> "
        CLEAN.PRECEEDING = " ,":@AM:" )":@AM:" (":@AM:" <":@AM:" >"

* if these strings are seen don't clean up around them
        LEAVE.ALONE.LIST = ":=":@AM:"+=":@AM:"-=":@AM:"*=":@AM:"/="
        LEAVE.ALONE.LIST := @AM:"<=":@AM:"=<":@AM:">=":@AM:"=>":@AM:"<>"
        LEAVE.ALONE.LIST := @AM:"}{"

* some of the shorter shortcuts may get chopped up.  add any shortcuts
* that are 2 or 3 characters to the "leave alone" list
        FOR SHORTCUT.LOOP = 1 TO SHORTCUT.COUNT

            THIS.SHORTCUT = SHORTCUT.KEYWORD.LIST<SHORTCUT.LOOP>

            IF LEN(THIS.SHORTCUT) < 4 AND LEN(THIS.SHORTCUT) > 1 THEN
                LEAVE.ALONE.LIST<-1> = THIS.SHORTCUT
            END

        NEXT SHORTCUT.LOOP

    END

* make sure assignment operators are surrounded by spaces to make them
* easier to find
    CLEAN.LEN = LEN(CLEAN.LINE)
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    FOR CHAR.PTR = 1 TO CLEAN.LEN

        THIS.CHAR = CLEAN.LINE [CHAR.PTR, 1]

* extract two and three characters from before and after the current
* character position.  we'll use these with the clean.following,
* clean.preceeding and leave.alone.list lists to decide whether or not
* to add or remove spaces to make the code easier to process
        TWO.CHAR.BEFORE = "**"
        TWO.CHAR.AFTER = "**"
        THREE.CHAR.BEFORE = "***"

        IF CHAR.PTR >= 2 THEN
            TWO.CHAR.BEFORE = CLEAN.LINE [CHAR.PTR - 1, 2]
        END

        IF CHAR.PTR >= 3 THEN
            THREE.CHAR.BEFORE = CLEAN.LINE [CHAR.PTR - 2, 3]
        END

        IF CHAR.PTR < CLEAN.LEN THEN
            TWO.CHAR.AFTER = CLEAN.LINE [CHAR.PTR, 2]
        END

* flags for adding spaces around this character
        ADD.SPACES.AROUND.ONE = @FALSE
        ADD.SPACES.AROUND.TWO = @FALSE

* if the characters before and including the current character position
* match one of the strings in the "leave alone" list don't consider
* adding any spaces around / in this string.  leave these alone.

* this is to prevent things like adding a space in the middle of "+=".
* spaces are normally added around equals signs but we don't want to
* break up things like "+=" and "-="
        IN.LEAVE.ALONE.LIST = @FALSE

        LOCATE TWO.CHAR.BEFORE IN LEAVE.ALONE.LIST SETTING THROWAWAY THEN
            IN.LEAVE.ALONE.LIST = @TRUE 
        END ELSE
            LOCATE THREE.CHAR.BEFORE IN LEAVE.ALONE.LIST SETTING THROWAWAY THEN
                IN.LEAVE.ALONE.LIST = @TRUE
            END
        END

        BEGIN CASE

* handle quotes.  nothing inside quotes will be changed
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* if the characters before the pointer are in the "leave alone" list don't do
* anything
            CASE IN.LEAVE.ALONE.LIST
                NULL

* if we're on a "replace with" keyword inside a "with" statement
* leave it alone
            CASE TWO.CHAR.BEFORE = REPLACE.WITH.KEYWORD
                NULL
            CASE TWO.CHAR.AFTER = REPLACE.WITH.KEYWORD
                NULL

* if we're on any object delimiters leave this part of the line alone
            CASE TWO.CHAR.BEFORE = METHOD.DELIMITER OR TWO.CHAR.AFTER = METHOD.DELIMITER
                NULL
            CASE TWO.CHAR.BEFORE = CHILD.DELIMITER OR TWO.CHAR.AFTER = CHILD.DELIMITER
                NULL
            CASE TWO.CHAR.BEFORE = PROPERTY.DELIMITER OR TWO.CHAR.AFTER = PROPERTY.DELIMITER
                NULL
            CASE TWO.CHAR.BEFORE = CONSTANT.DELIMITER OR TWO.CHAR.AFTER = CONSTANT.DELIMITER
                NULL

* make sure we have spaces around braces
            CASE TWO.CHAR.AFTER = ELSE.BRACE
                ADD.SPACES.AROUND.TWO = @TRUE
            CASE THIS.CHAR = OPEN.BRACE
                ADD.SPACES.AROUND.ONE = @TRUE
            CASE THIS.CHAR = CLOSE.BRACE
                ADD.SPACES.AROUND.ONE = @TRUE

* make sure we have spaces around any equals signs.  this will make it
* easier to extract things later as there will always be one, but only
* one, space around all assignment operators
            CASE THIS.CHAR = "="
                ADD.SPACES.AROUND.ONE = @TRUE

* if we have "clean after" string followed by any spaces we'll remove
* all spaces after the "clean after" string.  this keeps array references
* and multivalued references together.  this makes it easier to process
* the object references since we don't have to deal with some unknown
* number of spaces inside the object reference

* if, however, there's an equal sign on the other side of the next space
* we do NOT want to delete the space.  we always want to keep assignment
* operators separated by a single space so we can pick them apart more easily

* we'll also check the keyword afterwards following the "clean after"
* string.  for some keywords, like ands and ors, we want to remove any
* redundant spaces but still leave a single space
            CASE INDEX(CLEAN.FOLLOWING, TWO.CHAR.AFTER, 1) > 0

                STOP.CLEANING = @FALSE

                LOOP

                    EXTRACT.9 = CLEAN.LINE [CHAR.PTR + 1, 9]
                    EXTRACT.6 = EXTRACT.9 [1, 6]

                    BEGIN CASE

                        CASE EXTRACT.6 = " THEN " OR EXTRACT.6 = " THEN"
                            STOP.CLEANING = @TRUE
                        CASE EXTRACT.6 = " ELSE " OR EXTRACT.6 = " ELSE"
                            STOP.CLEANING = @TRUE

                        CASE EXTRACT.6 [1, 5] = " AND "
                            STOP.CLEANING = @TRUE
                        CASE EXTRACT.6 [1, 4] = " OR "
                            STOP.CLEANING = @TRUE
                        CASE EXTRACT.9 = " ANDALSO "
                            STOP.CLEANING = @TRUE

                    END CASE

                UNTIL CLEAN.LINE [CHAR.PTR + 1, 1] <> " " OR CLEAN.LINE [CHAR.PTR + 2, 1] = "=" OR STOP.CLEANING

                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR]:CLEAN.LINE [CHAR.PTR + 2, TO.THE.END]
                    CLEAN.LEN -= 1

                REPEAT

* if we have "clean before" string with spaces before it get rid of the spaces
* to keep our array and multivalued references together.  if, however, there's
* an equal sign before the space to the left of the "clean before" character
* we're checking we do NOT want to remove the space.  we want to keep equals
* signs separated a single space so we an pull things apart more easily later

* when purging spaces before an open parenthesis, if the last word before the
* "clean before" character is one of some basic keywords we can't remove all
* the spaces.  in these cases we'll remove redundant spaces and leave a single
* space.  for example, in a case statement if the case expression starts
* with an open parentheses (ie, "case (this or that)") and we remove the space
* the compile thinks "case" is now a dimensioned variable

* we'll do the same thing with "IF" statements
            CASE INDEX(CLEAN.PRECEEDING, TWO.CHAR.BEFORE, 1) > 0

                STOP.CLEANING = @FALSE

                LOOP

                    BEGIN CASE
                        CASE TWO.CHAR.BEFORE <> " ("
                            NULL
                        CASE CHAR.PTR = 6 AND CLEAN.LINE [CHAR.PTR - 5, 5] = "CASE "
                            STOP.CLEANING = @TRUE
                        CASE CHAR.PTR = 4 AND CLEAN.LINE [CHAR.PTR - 3, 3] = "IF "
                            STOP.CLEANING = @TRUE
                        CASE CLEAN.LINE [CHAR.PTR - 4, 4] = " IF "
                            STOP.CLEANING = @TRUE
                    END CASE

                UNTIL CLEAN.LINE [CHAR.PTR - 1, 1] <> " " OR CLEAN.LINE [CHAR.PTR - 2, 1] = "=" OR STOP.CLEANING

                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR - 2]:CLEAN.LINE [CHAR.PTR, TO.THE.END]
                    CHAR.PTR -= 1
                    CLEAN.LEN -= 1

                REPEAT

        END CASE

* should we add spaces around this character or two characters?
        BEGIN CASE

* make sure we have a single space before and after this single character
            CASE ADD.SPACES.AROUND.ONE

* if there isn't a space before this character add one
                IF CLEAN.LINE [CHAR.PTR - 1, 1] <> " " THEN
                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR - 1]:" ":CLEAN.LINE [CHAR.PTR, TO.THE.END]
                    CHAR.PTR += 1
                    CLEAN.LEN += 1
                END

* if there isn't a space after this character and it's not the end of the
* line then add one
                IF CLEAN.LINE [CHAR.PTR + 1, 1] <> " " THEN IF CLEAN.LINE [CHAR.PTR + 1, 1] <> "" THEN
                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR]:" ":CLEAN.LINE [CHAR.PTR + 1, TO.THE.END]
                    CHAR.PTR += 1
                    CLEAN.LEN += 1
                END

* make sure we have a single space before and after this double character
            CASE ADD.SPACES.AROUND.TWO

* if there isn't a space before this character add one
                IF CLEAN.LINE [CHAR.PTR - 1, 1] <> " " THEN
                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR - 1]:" ":CLEAN.LINE [CHAR.PTR, TO.THE.END]
                    CHAR.PTR += 1
                    CLEAN.LEN += 1
                END

* if there isn't a space after these two characters and it's not the end
* of the line then add one
                IF CLEAN.LINE [CHAR.PTR + 2, 1] <> " " THEN IF CLEAN.LINE [CHAR.PTR + 2, 1] <> "" THEN
                    CLEAN.LINE = CLEAN.LINE [1, CHAR.PTR + 1]:" ":CLEAN.LINE [CHAR.PTR + 2, TO.THE.END]
                    CHAR.PTR += 1
                    CLEAN.LEN += 1
                END

                CHAR.PTR += 1

        END CASE

    NEXT CHAR.PTR

* update the clean.line index if we're using it
    IF USE.CLEAN.LINE.INDEX AND CLEAN.LINE <> "" THEN
        CLEAN.INDEX.COUNT += 1
        CLEAN.SOURCE.INDEX<-1> = ORIGINAL.CLEAN.LINE
        CLEAN.FINAL.INDEX<-1> = CLEAN.LINE
    END

    GOSUB STAMP.CLEAN.LINE

    RETURN

STAMP.CLEAN.LINE: ********************************************************
* update the time spend cleaning lines                                   *
**************************************************************************
    CLEAN.LINE.COUNT += 1

    CLEAN.LINE.END.DATE = DATE()
    CLEAN.LINE.END.TIME = TIME()
    CLEAN.LINE.ELAPSED.TIME += TIME.ELAPSED (CLEAN.LINE.START.DATE, CLEAN.LINE.START.TIME)

    RETURN


**************************************************************************
**************************************************************************
** notepad ++ / autocomplete routines                                   **
**************************************************************************
**************************************************************************

NOTEPAD.PP.AUTOCOMPLETE: *************************************************
* print the NOTEPAD++ auto complete xml file                             *
**************************************************************************
    PGM.XREF.EXISTS = @TRUE

    OPEN "PGM.XREF" TO XREF.FILE.HANDLE ELSE
        PGM.XREF.EXISTS = @FALSE
    END

    NEWLINE = CHAR(10)
    AUTOCOMPLETE.LIST = ""

* start the xml file
    PRINT '<?xml version="1.0" encoding="Windows-1252" ?>'
    PRINT "<NotepadPlus>"
    PRINT "    <AutoComplete>"
    PRINT '        <Environment ignoreCase="yes" startFunc="(" stopFunc=")" paramSeparator="," terminal=";" additionalWordChar = "."/>'

    IF AUTOCOMPLETE.MACROS THEN
        GOSUB AUTOCOMPLETE.MACROS
    END

    IF AUTOCOMPLETE.SHORTCUTS THEN
        GOSUB AUTOCOMPLETE.SHORTCUTS
    END

    IF AUTOCOMPLETE.BASIC THEN
        GOSUB AUTOCOMPLETE.BASIC
    END

    IF AUTOCOMPLETE.OBP THEN
        GOSUB AUTOCOMPLETE.OBP
    END

    IF AUTOCOMPLETE.CBP THEN
        GOSUB AUTOCOMPLETE.CBP
    END

    IF AUTOCOMPLETE.BP THEN
        GOSUB AUTOCOMPLETE.BP
    END

    IF AUTOCOMPLETE.SP THEN
        GOSUB AUTOCOMPLETE.SP
    END

    PRINT "    </AutoComplete>"
    PRINT "</NotepadPlus>"

    RETURN

AUTOCOMPLETE.MACROS: *****************************************************
* add in each macro to the autocomplete xml document                     *
**************************************************************************
    LAST.MACRO = ""
    LAST.PARM.COUNT = 0
    LAST.RETURN.TYPE = ""
    THIS.DESCRIPTION = ""
    PARAMETER.TEXT = ""

    FOR MACRO.LOOP = 1 TO MACRO.COUNT

        THIS.MACRO = MACRO.KEYWORD.LIST<MACRO.LOOP>
        THIS.MACRO.DESCRIPTION = MACRO.DESCRIPTION.LIST<MACRO.LOOP>
        THIS.DISPLAY.STYLE = MACRO.DISPLAY.STYLE.LIST<MACRO.LOOP>
        PARM.COUNT = MACRO.PARM.COUNT.LIST<MACRO.LOOP>
        PARM.LIST = RAISE(MACRO.PARM.LIST<MACRO.LOOP>)

        IF DOWNCASE.METHODS THEN
            THIS.MACRO = DOWNCASE(THIS.MACRO)
            PARM.LIST = DOWNCASE(PARM.LIST)
        END

* build the description line based on the number of parameters
        BEGIN CASE
            CASE PARM.COUNT = 0
                MACRO.DESCRIPTION = " No parameters: ":THIS.MACRO.DESCRIPTION
            CASE PARM.COUNT = 1
                MACRO.DESCRIPTION = " 1 parameter:   ":THIS.MACRO.DESCRIPTION
            CASE 1
                MACRO.DESCRIPTION = " ":PARM.COUNT:" parameters:  ":THIS.MACRO.DESCRIPTION                
        END CASE

* if the display style is not 1 then we have a "function" type description.
* set the return variable and remove the first parameter from the list
        IF THIS.DISPLAY.STYLE = 1 THEN
            RETURN.TYPE = ""
        END ELSE
            RETURN.TYPE = " ":PARM.LIST<1>:" ="
            DEL PARM.LIST<1>
            PARM.COUNT -= 1
        END

* add a description line showing the variables for this parameter count
        PARM.DISPLAY = CHANGE(PARM.LIST, @AM, ", ")

        IF DOWNCASE.METHODS THEN
            PARM.DISPLAY = DOWNCASE(PARM.DISPLAY)
        END

        BEGIN CASE
            CASE RETURN.TYPE = "" AND PARM.COUNT = 0
                MACRO.STATEMENT = SPACE(16):THIS.MACRO:" ()"
            CASE RETURN.TYPE = ""
                MACRO.STATEMENT = SPACE(16):THIS.MACRO:" (":PARM.DISPLAY:")"
            CASE PARM.COUNT = 0
                MACRO.STATEMENT = SPACE(15):RETURN.TYPE:" ":THIS.MACRO:" ()"
            CASE 1
                MACRO.STATEMENT = SPACE(15):RETURN.TYPE:" ":THIS.MACRO:" (":PARM.DISPLAY:")"
        END CASE

        IF THIS.MACRO.DESCRIPTION = "" THEN
            MACRO.DESCRIPTION := TRIM(MACRO.STATEMENT, " ", "L")
        END ELSE
            MACRO.DESCRIPTION := NEWLINE:MACRO.STATEMENT
        END

* if this macro name is the same as the last one only show the
* additional parameters as optional
        START.LOOP = 1

        IF THIS.MACRO <> LAST.MACRO THEN

            IF MACRO.LOOP > 1 THEN
                GOSUB PRINT.AUTOCOMPLETE
            END

            THIS.DESCRIPTION = MACRO.DESCRIPTION
            PARAMETER.TEXT = ""

        END ELSE

            START.LOOP = LAST.PARM.COUNT + 1
            PARM.TAG = "optional "
            IF THIS.DESCRIPTION <> "" THEN
                THIS.DESCRIPTION := NEWLINE
            END
            THIS.DESCRIPTION := MACRO.DESCRIPTION

        END

        GOSUB FOLD.AUTOCOMPLETE.DESCRIPTION

        PARM.TAG = ""
        GOSUB BUILD.PARAMETER.TEXT

        LAST.MACRO = THIS.MACRO
        LAST.RETURN.TYPE = RETURN.TYPE
        LAST.PARM.COUNT = PARM.COUNT

    NEXT MACRO.LOOP

    GOSUB PRINT.AUTOCOMPLETE

    RETURN

PRINT.AUTOCOMPLETE: ******************************************************
* print out the function and parameters in parameter.text                *
**************************************************************************
    AUTOCOMPLETE.LIST<-1> = LAST.MACRO

* don't allow double quotes in the description
    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, '"', "''")
    FOLD.INDENT = 16
    GOSUB FOLD.AUTOCOMPLETE.DESCRIPTION

    PRINT '        <KeyWord name="':LAST.MACRO:'" func="yes">'
    PRINT '            <Overload retVal="':LAST.RETURN.TYPE:'" descr="':THIS.DESCRIPTION:'">'

    PARAMETER.TEXT.COUNT = DCOUNT(PARAMETER.TEXT, @AM)
    GOSUB PRINT.PARAMETER.TEXT

    PRINT "            </Overload>"
    PRINT "        </KeyWord>"

    RETURN

AUTOCOMPLETE.SHORTCUTS: **************************************************
* add in shortcuts to the xml file                                       *
**************************************************************************
    FOR SHORTCUT.LOOP = 1 TO SHORTCUT.COUNT
        
        THIS.SHORTCUT = SHORTCUT.KEYWORD.LIST<SHORTCUT.LOOP>

        THIS.DESCRIPTION = SHORTCUT.DESCRIPTION.LIST<SHORTCUT.LOOP>

        THIS.EXPAND = SHORTCUT.EXPAND.LIST<SHORTCUT.LOOP>
        THIS.FOLLOW = SHORTCUT.FOLLOW.LIST<SHORTCUT.LOOP>
        THIS.VAR.FOLLOW = SHORTCUT.VAR.FOLLOW.LIST<SHORTCUT.LOOP>

        IF DOWNCASE.METHODS THEN
            THIS.SHORTCUT = DOWNCASE(THIS.SHORTCUT)
            THIS.EXPAND = DOWNCASE(THIS.EXPAND)
            THIS.FOLLOW = DOWNCASE(THIS.FOLLOW)
            THIS.VAR.FOLLOW = DOWNCASE(THIS.FOLLOW)
        END

* build shortcut description
        SHORTCUT.DESCRIPTION = " ":THIS.EXPAND

        BEGIN CASE
            CASE THIS.FOLLOW <> "" AND THIS.VAR.FOLLOW <> ""
                SHORTCUT.DESCRIPTION := " { { . . . }":THIS.VAR.FOLLOW:" . . . }":THIS.FOLLOW
            CASE THIS.FOLLOW <> ""
                SHORTCUT.DESCRIPTION := " { . . . }":THIS.FOLLOW
            CASE THIS.VAR.FOLLOW <> ""
                SHORTCUT.DESCRIPTION := " { . . . }":THIS.VAR.FOLLOW
        END CASE

        IF THIS.DESCRIPTION = "" THEN
            THIS.DESCRIPTION = SHORTCUT.DESCRIPTION
        END ELSE
            THIS.DESCRIPTION := NEWLINE:SHORTCUT.DESCRIPTION
        END

        GOSUB PRINT.SHORTCUT.AUTOCOMPLETE

    NEXT SHORTCUT.LOOP

    RETURN

PRINT.SHORTCUT.AUTOCOMPLETE: *********************************************
* print out a shortcut's autocomplete xml.  writes the autcomplete so    *
* that typing an open parenthesis after the shortcut name will bring up  *
* a description of how the shortcut expands                              *
**************************************************************************
    AUTOCOMPLETE.LIST<-1> = THIS.SHORTCUT

* don't allow double quotes in the description
    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, '"', "''")
    FOLD.INDENT = 5
    GOSUB FOLD.AUTOCOMPLETE.DESCRIPTION

    PRINT '    <KeyWord name="':THIS.SHORTCUT:'" func="yes">'
    PRINT '        <Overload retVal="" descr=" shortcut: ':THIS.DESCRIPTION:'">'
    PRINT "        </Overload>"
    PRINT "    </KeyWord>"

    RETURN

AUTOCOMPLETE.BASIC: ******************************************************
* add basic functions to the autocomplete document                       *
**************************************************************************

* select basic functions in basic.help
    OPEN "BASIC.HELP" TO BASIC.HELP.FILE ELSE
        RETURN
    END

    STATEMENT = 'SSELECT BASIC.HELP = "[()]"'
    EXECUTE STATEMENT CAPTURING TEXT RTNLIST BASIC.LIST

    LOOP WHILE READNEXT BASIC.KEYWORD FROM BASIC.LIST

        READ BASIC.RECORD FROM BASIC.HELP.FILE, BASIC.KEYWORD THEN
            GOSUB PRINT.BASIC.AUTOCOMPLETE
        END

    REPEAT

    RETURN

PRINT.BASIC.AUTOCOMPLETE: ************************************************
* add basic.keyword to the xml autocomplete document                     *
**************************************************************************
    AUTOCOMPLETE.LIST<-1> = BASIC.KEYWORD

* get the basic keyword without the parenthesis
    BASIC.KEYWORD = CHANGE(BASIC.KEYWORD, "()", "")

* don't allow double quotes anywhere
    BASIC.RECORD = CHANGE(BASIC.RECORD, '"', "''")
    
* find the start and end of the description and example
    LAST.PTR = DCOUNT(BASIC.RECORD, @AM)

    LOCATE "DESCRIPTION" IN BASIC.RECORD SETTING DESCRIPTION.START.PTR ELSE
        DESCRIPTION.START.PTR = 0
    END

    LOCATE "EXAMPLE" IN BASIC.RECORD SETTING EXAMPLE.START.PTR THEN
        EXAMPLE.END.PTR = LAST.PTR
    END ELSE
        EXAMPLE.START.PTR = 0
        EXAMPLE.END.PTR = 0
    END

    IF DESCRIPTION.START.PTR <> 0 THEN
        IF EXAMPLE.START.PTR <> 0 THEN
            DESCRIPTION.END.PTR = EXAMPLE.START.PTR - 1
        END ELSE
            DESCRIPTION.END.PTR = LAST.PTR
        END
    END ELSE
        DESCRIPTION.END.PTR = 0
    END

* extract description and example
    THIS.DESCRIPTION = ""
    THIS.EXAMPLE = ""

    IF DESCRIPTION.START.PTR <> 0 AND DESCRIPTION.END.PTR <> 0 THEN
        DESCRIPTION.START.PTR += 1
        THIS.DESCRIPTION = BASIC.RECORD [@AM, DESCRIPTION.START.PTR, DESCRIPTION.END.PTR - DESCRIPTION.START.PTR + 1]
    END

    IF EXAMPLE.START.PTR <> 0 AND EXAMPLE.END.PTR <> 0 THEN
        EXAMPLE.START.PTR += 1
        THIS.EXAMPLE = BASIC.RECORD [@AM, EXAMPLE.START.PTR, EXAMPLE.END.PTR - EXAMPLE.START.PTR + 1]
    END

* merge all indented lines so they can be reformatted later
    BASIC.TEXT = THIS.DESCRIPTION
    GOSUB UNWRAP.BASIC.TEXT
    THIS.DESCRIPTION = BASIC.TEXT

    BASIC.TEXT = THIS.EXAMPLE
    GOSUB UNWRAP.BASIC.TEXT
    THIS.EXAMPLE = BASIC.TEXT

    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, @AM, NEWLINE)
    THIS.EXAMPLE = CHANGE(THIS.EXAMPLE, @AM, NEWLINE)
    FOLD.INDENT = 0

    GOSUB FOLD.AUTOCOMPLETE.DESCRIPTION

* there won't be a returned variable
    RETURN.TYPE = ""

* the example expression is in line 9 of the basic help.  build a parameter
* list from the example
    EXPRESSION = TRIM(BASIC.RECORD<9>, " ", "A")
    IF EXPRESSION [1] = "," THEN
        EXPRESSION := TRIM(BASIC.RECORD<10>, " ", "A")
    END

    EXPRESSION = EXPRESSION ["(", 2, 1] [")", 1, 1]
    EXPRESSION = CHANGE(EXPRESSION, "[,", ",[")

    PARM.LIST = SPLIT.PARAMETERS (EXPRESSION)
    PARM.TAG = ""
    GOSUB BUILD.PARAMETER.TEXT

* print the xml
    PRINT '        <KeyWord name="':DOWNCASE(BASIC.KEYWORD):'" func="yes">'
    PRINT '            <Overload retVal="':RETURN.TYPE:'" descr="':THIS.DESCRIPTION:'">'

    GOSUB PRINT.PARAMETER.TEXT

    PRINT "            </Overload>"
    PRINT "        </KeyWord>"

    RETURN

UNWRAP.BASIC.TEXT: *******************************************************
* unwrap text in basic.text so that each paragraph is one dynamic array  *
* element                                                                *
**************************************************************************
    BASIC.COUNT = DCOUNT(BASIC.TEXT, @AM)

    FOR BASIC.LOOP = 1 TO BASIC.COUNT

        THIS.BASIC.TEXT = BASIC.TEXT<BASIC.LOOP>
        NEXT.BASIC.TEXT = BASIC.TEXT<BASIC.LOOP + 1>

        IF THIS.BASIC.TEXT [1, 2] = "  " THEN

            IF NEXT.BASIC.TEXT [1, 2] = "  " THEN

                LOOP

                    COMBINED = TRIM(THIS.BASIC.TEXT, " ", "B"):" ":TRIM(NEXT.BASIC.TEXT, " ", "B")
                    BASIC.TEXT<BASIC.LOOP> = COMBINED
                    DEL BASIC.TEXT<BASIC.LOOP + 1>

                    BASIC.COUNT -= 1

                    NEXT.BASIC.TEXT = BASIC.TEXT<BASIC.LOOP + 1>

                UNTIL NEXT.BASIC.TEXT [1, 2] <> "  "
                REPEAT

                BASIC.LOOP -= 1

            END ELSE

                THIS.BASIC.TEXT = TRIM(THIS.BASIC.TEXT, " ", "B")
                BASIC.TEXT<BASIC.LOOP> = THIS.BASIC.TEXT

            END

        END

    NEXT BASIC.LOOP

    RETURN

AUTOCOMPLETE.OBP: ********************************************************
* add subroutines from obp to the autocomplete file                      *
**************************************************************************
    STATEMENT = "SSELECT OBP"
    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    LOOP WHILE READNEXT OBP.ID FROM SLIST

        READV FIRST.LINE FROM OBPFILE, OBP.ID, 1 THEN

* look for the "subroutine" statement and parenthesis to indicate a parameter
* list
            FIRST.LINE = DOWNCASE (TRIM(FIRST.LINE, " ", "B"))
            FIRST.WORD = FIRST.LINE [" ", 1, 1]

            IF FIRST.WORD = "subroutine" OR FIRST.WORD = "ph.args" THEN

                SUBROUTINE.ID = OBP.ID
                PROGRAM.FILE.NAME = "OBP"
                PROGRAM.FILE.HANDLE = OBPFILE
                GOSUB PRINT.SUBROUTINE.AUTOCOMPLETE

            END

        END

    REPEAT

    RETURN

AUTOCOMPLETE.CBP: ********************************************************
* add subroutines from sp to the autocomplete file.  the CBP file is     *
* pretty huge so we'll only set up subroutines that don't have "PASSER"  *
* as their parameter.  skips method subroutines                          *
**************************************************************************
    OPEN "CBP" TO CBPFILE ELSE
        RETURN
    END

    STATEMENT = 'SSELECT CBP WITH @ID <> "':ECLIPSE.PREFIX:']"'
    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    LOOP WHILE READNEXT CBP.ID FROM SLIST

        READV FIRST.LINE FROM CBPFILE, CBP.ID, 1 THEN

* look for the "subroutine" statement and parenthesis to indicate a parameter
* list
            FIRST.LINE = DOWNCASE (TRIM(FIRST.LINE, " ", "B"))
            FIRST.WORD = FIRST.LINE [" ", 1, 1]

            IF FIRST.WORD = "subroutine" OR FIRST.WORD = "ph.args" THEN

                IF INDEX(FIRST.LINE, "(passer)", 1) = 0 THEN

                    SUBROUTINE.ID = CBP.ID
                    PROGRAM.FILE.NAME = "CBP"
                    PROGRAM.FILE.HANDLE = CBPFILE
                    GOSUB PRINT.SUBROUTINE.AUTOCOMPLETE

                END

            END

        END

    REPEAT

    RETURN

AUTOCOMPLETE.BP: *********************************************************
* add subroutines from sp to the autocomplete file.  the bp file is      *
* pretty huge so we'll only set up subroutines that don't have "PASSER"  *
* as their parameter                                                     *
**************************************************************************
    STATEMENT = "SSELECT BP"
    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    LOOP WHILE READNEXT BP.ID FROM SLIST

        READV FIRST.LINE FROM BPFILE, BP.ID, 1 THEN

* look for the "subroutine" statement and parenthesis to indicate a parameter
* list
            FIRST.LINE = DOWNCASE (TRIM(FIRST.LINE, " ", "B"))
            FIRST.WORD = FIRST.LINE [" ", 1, 1]

            IF FIRST.WORD = "subroutine" OR FIRST.WORD = "ph.args" THEN

                IF INDEX(FIRST.LINE, "(passer)", 1) = 0 THEN

                    SUBROUTINE.ID = BP.ID
                    GOSUB GET.DEPENDENCY.COUNT

                    IF DEPENDENCY.COUNT >= MIN.DEPENDENCY.COUNT THEN

                        PROGRAM.FILE.NAME = "BP"
                        PROGRAM.FILE.HANDLE = BPFILE
                        GOSUB PRINT.SUBROUTINE.AUTOCOMPLETE

                    END

                END

            END

        END

    REPEAT

    RETURN

AUTOCOMPLETE.SP: *********************************************************
* add subroutines from sp to the autocomplete file                       *
**************************************************************************
    OPEN "SP" TO SPFILE ELSE
        RETURN
    END

    STATEMENT = "SSELECT SP"
    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    LOOP WHILE READNEXT SP.ID FROM SLIST

        READV FIRST.LINE FROM SPFILE, SP.ID, 1 THEN

* look for the "subroutine" statement and parenthesis to indicate a parameter
* list
            FIRST.LINE = DOWNCASE (TRIM(FIRST.LINE, " ", "B"))
            FIRST.WORD = FIRST.LINE [" ", 1, 1]

            IF FIRST.WORD = "subroutine" OR FIRST.WORD = "ph.args" THEN

                SUBROUTINE.ID = SP.ID
                GOSUB GET.DEPENDENCY.COUNT

                IF DEPENDENCY.COUNT >= MIN.DEPENDENCY.COUNT THEN

                    PROGRAM.FILE.NAME = "SP"
                    PROGRAM.FILE.HANDLE = SPFILE
                    GOSUB PRINT.SUBROUTINE.AUTOCOMPLETE

                END

            END

        END

    REPEAT

    RETURN

GET.DEPENDENCY.COUNT: ****************************************************
* get a count of routines that call subroutine.id                        *
**************************************************************************

* if the pgm.xref file doesn't exist we can't tell how many routines call
* this one.  return a large number so that it's always added to the
* autocomplete
    IF NOT(PGM.XREF.EXISTS) OR MIN.DEPENDENCY.COUNT = 0 THEN
        DEPENDENCY.COUNT = 9999
        RETURN
    END

    READ XREF.RECORD FROM XREF.FILE.HANDLE, SUBROUTINE.ID ELSE
        XREF.RECORD = ""
    END
    
    DEPENDENCY.COUNT = DCOUNT(XREF.RECORD, @AM)

    RETURN

PRINT.SUBROUTINE.AUTOCOMPLETE: *******************************************
* print autocomplete xml for subroutines                                 *
**************************************************************************

* if we've already added autocomplete for a subroutine with this name
* don't add it again
    LOCATE SUBROUTINE.ID IN AUTOCOMPLETE.LIST SETTING THROWAWAY THEN
        RETURN
    END
    AUTOCOMPLETE.LIST<-1> = SUBROUTINE.ID

* add any unwrapped lines to first.line.  this will be our subroutine
* definition
    SUB.LINE.PTR = 1

    LOOP

        LAST.CHAR = FIRST.LINE [1]

    UNTIL LAST.CHAR <> "," AND LAST.CHAR <> ";"

        SUB.LINE.PTR += 1

        READV NEXT.LINE FROM PROGRAM.FILE.HANDLE, SUBROUTINE.ID, SUB.LINE.PTR ELSE
            NEXT.LINE = ""
        END

        NEXT.LINE = DOWNCASE (TRIM(NEXT.LINE, " ", "B"))
        FIRST.LINE := " ":NEXT.LINE

    REPEAT

    PROGRAM.LINE.PTR = SUB.LINE.PTR + 1
    GOSUB BUILD.SUBROUTINE.DESCRIPTION
    GOSUB FOLD.AUTOCOMPLETE.DESCRIPTION

    IF THIS.DESCRIPTION = "" THEN
        THIS.DESCRIPTION = "Subroutine"
    END

* there won't be a returned variable for most routines
    RETURN.TYPE = ""

* build a parameter list from the first line of the subroutine.  for
* phantoms pull off the parameters after ph.args and skip the first one
    IF FIRST.WORD = "subroutine" THEN
        EXPRESSION = FIRST.LINE ["(", 2, 1] [")", 1, 1]
    END ELSE
        EXPRESSION = FIRST.LINE [" ", 2, TO.THE.END] [",", 2, TO.THE.END]
        RETURN.TYPE = "Phantom"
    END

* if there's a leading or trailing semi-colon in the parameter list (defines
* output vs input parameters) remove it
    EXPRESSION = TRIM(EXPRESSION, " ", "B")
    IF EXPRESSION [1, 1] = ";" THEN
        EXPRESSION = EXPRESSION [2, TO.THE.END]
    END

    IF EXPRESSION [1] = ";" THEN
        EXPRESSION = EXPRESSION [1, LEN(EXPRESSION) - 1]
    END

    EXPRESSION = TRIM(EXPRESSION, " ", "B")

* change any semi-colons in the parameter list to commas
    EXPRESSION = CHANGE(EXPRESSION, ";", ",")

    PARM.LIST = SPLIT.PARAMETERS (EXPRESSION)
    PARM.TAG = ""
    GOSUB BUILD.PARAMETER.TEXT

* print the xml
    PRINT '        <KeyWord name="':DOWNCASE(SUBROUTINE.ID):'" func="yes">'
    PRINT '            <Overload retVal="':RETURN.TYPE:'" descr="':THIS.DESCRIPTION:'">'

    GOSUB PRINT.PARAMETER.TEXT

    PRINT "            </Overload>"
    PRINT "        </KeyWord>"

    RETURN

BUILD.SUBROUTINE.DESCRIPTION: ********************************************
* build this.description for subroutine.id from program.file.handle      *
* starting with program.line.ptr.  adds comments starting at             *
* program.line.ptr until a code line is hit                              *
**************************************************************************
    THIS.DESCRIPTION = ""
    THIS.DESCRIPTION.COUNT = 0
    MAX.SEARCH.LINES = 10

* skip over any blank lines, version lines, or "subroutine" lines
    LOOP

        READV THIS.LINE FROM PROGRAM.FILE.HANDLE, SUBROUTINE.ID, PROGRAM.LINE.PTR ELSE
            RETURN
        END

        VERSION.LINE = @FALSE
        SUB.LINE = @FALSE
        BLANK.LINE = @FALSE

        IF THIS.LINE [1, 11] = "** Version#" THEN
            VERSION.LINE = @TRUE
        END

        IF UPCASE(THIS.LINE [" ", 2, 1] [1, 10]) = "SUBROUTINE" THEN
            SUB.LINE = @TRUE
        END

        IF TRIM(THIS.LINE) = "" THEN
            BLANK.LINE = @TRUE
        END

    UNTIL (NOT(BLANK.LINE) AND NOT(VERSION.LINE) AND NOT(SUB.LINE)) OR PROGRAM.LINE.PTR > MAX.SEARCH.LINES

        PROGRAM.LINE.PTR += 1

    REPEAT

* fetch comment lines and add them to this.description
    LOOP

        READV THIS.LINE FROM PROGRAM.FILE.HANDLE, SUBROUTINE.ID, PROGRAM.LINE.PTR ELSE
            RETURN
        END

        BLANK.LINE = @FALSE
        COMMENT.LINE = @FALSE

        IF TRIM(THIS.LINE) = "" THEN
            BLANK.LINE = @TRUE
        END ELSE
            COMMENT.LINE = IS.COMMENT (THIS.LINE)
        END

    UNTIL NOT(COMMENT.LINE) OR PROGRAM.LINE.PTR > MAX.SEARCH.LINES

* description lines can't have double quotes or the xml messes up
        THIS.LINE = CHANGE(THIS.LINE, '"', "'")
        THIS.LINE = TRIM(THIS.LINE, " ", "B")

* clean up comment lines so that they look more like normal text
        
* if the line is entirely made of asterisks or dashes change it to a blank line
        BEGIN CASE
            CASE THIS.LINE = STR("*", LEN(THIS.LINE))
                THIS.LINE = ""
            CASE THIS.LINE = STR("-", LEN(THIS.LINE))
                THIS.LINE = ""
            CASE THIS.LINE = "*":STR("-", LEN(THIS.LINE) - 2):"*"
                THIS.LINE = ""
        END CASE

* remove any leading or trailing asterisks
        LOOP UNTIL THIS.LINE [1, 1] <> "*" AND THIS.LINE [1, 1] <> "!"
            THIS.LINE = THIS.LINE [2, TO.THE.END]
        REPEAT

        LOOP UNTIL THIS.LINE [1] <> "*"
            THIS.LINE = THIS.LINE [1, LEN(THIS.LINE) - 1]
        REPEAT

        THIS.DESCRIPTION.COUNT += 1
        THIS.DESCRIPTION<THIS.DESCRIPTION.COUNT> = THIS.LINE

        PROGRAM.LINE.PTR += 1

    REPEAT

* we'll add a final line with the program file name
    FINAL.LINE = " Program file: ":PROGRAM.FILE.NAME

    THIS.DESCRIPTION = @AM:TRIM(THIS.DESCRIPTION, @AM):@AM:@AM:FINAL.LINE
    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, @AM, NEWLINE)

    RETURN

BUILD.PARAMETER.TEXT: ****************************************************
* given parm.tag and parm.list build parameter.text                      *
**************************************************************************
    PARAMETER.TEXT = ""
    PARM.COUNT = DCOUNT(PARM.LIST, @AM)

    FOR PARM.LOOP = 1 TO PARM.COUNT

        THIS.PARM = PARM.LIST<PARM.LOOP>

* for optional parameters that define a default value remove the default value
        IF COUNT(THIS.PARM, "=") <> 0 THEN
            THIS.PARM = TRIM(THIS.PARM ["=", 1, 1], " ", "B")
        END

        PARAMETER.TEXT<-1> = '                <Param name="':PARM.TAG:THIS.PARM:'" />'

    NEXT PARM.LOOP

    PARAMETER.TEXT.COUNT = DCOUNT(PARAMETER.TEXT, @AM)

    RETURN

PRINT.PARAMETER.TEXT: ****************************************************
* print parameter.text so it will be added to the autocomplete xml       *
**************************************************************************
    FOR TEXT.LOOP = 1 TO PARAMETER.TEXT.COUNT
        PRINT PARAMETER.TEXT<TEXT.LOOP>
    NEXT TEXT.LOOP

    RETURN

FOLD.AUTOCOMPLETE.DESCRIPTION: *******************************************
* fold this.description with newlines to fit within a maximum width      *
**************************************************************************
    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, NEWLINE, @AM)
    DESCRIPTION.LINES = DCOUNT(THIS.DESCRIPTION, @AM)

    FOR FOLD.LOOP = DESCRIPTION.LINES TO 1 STEP -1
        THIS.DESCRIPTION<FOLD.LOOP> = FOLD.ON.COMMA(THIS.DESCRIPTION<FOLD.LOOP>, MAX.AUTOCOMPLETE.WIDTH, FOLD.INDENT)
    NEXT FOLD.LOOP

    IF MAX.AUTOCOMPLETE.HEIGHT <> 0 THEN
        THIS.DESCRIPTION = THIS.DESCRIPTION [@AM, 1, MAX.AUTOCOMPLETE.HEIGHT]
    END

    THIS.DESCRIPTIION = TRIM(THIS.DESCRIPTION, @AM, "T")

    THIS.DESCRIPTION = CHANGE(THIS.DESCRIPTION, @AM, NEWLINE)

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / unresolved references          **
**************************************************************************
**************************************************************************

CHECK.UNRESOLVED.REFERENCES: *********************************************
* check new.line for any unresolved references.  if there are still      *
* any method, property, or constant delimiters there may be an object    *
* reference in the line that was not translated by convert.this.line     *
**************************************************************************

* test for any method, property, or constant delimiters.  hopefully
* we've chosen our delimiters so that they don't normally appear in
* code on their own

* initialize our "unresolved" table
    UNRESOLVED.REFERENCE.FOUND = @FALSE
    UNRESOLVED.PTR.LIST = ""
    UNRESOLVED.START.PTR.LIST = ""
    UNRESOLVED.END.PTR.LIST = ""
    UNRESOLVED.PARM.PTR.LIST = ""
    UNRESOLVED.REFERENCE.LIST = ""
    UNRESOLVED.NESTED.DEPTH.LIST = ""
    UNRESOLVED.TEMP.LIST = ""
    UNRESOLVED.COUNT = 0

* we need to respect quotes, since a string could appear in quotes that
* is the same as a delimiter.  we'll work across the line one character
* at a time.
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

* we may need to insert additional code before this line to make this
* reference work.  we'll build the additional code here
    FIXED.CODE = ""
    FIXED.CODE.COUNT = 0

    NEW.LINE.LENGTH = LEN(NEW.LINE)
    FOR CHAR.PTR = 1 TO NEW.LINE.LENGTH

        THIS.CHAR = NEW.LINE [CHAR.PTR, 1]
        UNRESOLVED = @FALSE
        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* test for method delimiter
            CASE NEW.LINE [CHAR.PTR, METHOD.DEL.LENGTH] = METHOD.DELIMITER
                UNRESOLVED = @TRUE
                FOUND.DELIMITER = METHOD.DELIMITER

* test for property delimiter
            CASE NEW.LINE [CHAR.PTR, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
                UNRESOLVED = @TRUE
                FOUND.DELIMITER = PROPERTY.DELIMITER

* test for constant delimiter
            CASE NEW.LINE [CHAR.PTR, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
                UNRESOLVED = @TRUE
                FOUND.DELIMITER = CONSTANT.DELIMITER

        END CASE

        IF UNRESOLVED THEN
            DELIMITER.PTR = CHAR.PTR
            GOSUB ADD.UNRESOLVED.ENTRY
        END

    NEXT CHAR.PTR

* if any of our unresolved references are inside of other references then
* we have a nested reference--ie, object::method(object::property) or
* something like that.  for each unresolved reference count up how many
* other references are around it and that's the nested depth.  save the
* nested depth in the table.  later we'll need to evaluate the deepest
* nested expressions first
    MAX.NESTED.DEPTH = 0

    FOR NEST.LOOP = 1 TO UNRESOLVED.COUNT

* get start and end for this reference
        NEST.START.PTR = UNRESOLVED.START.PTR.LIST<NEST.LOOP>
        NEST.END.PTR = UNRESOLVED.END.PTR.LIST<NEST.LOOP>

* add up how many other unresolved references encompass this one
        NEST.COUNT = 0

        FOR CHECK.LOOP = 1 TO UNRESOLVED.COUNT

            IF NEST.LOOP <> CHECK.LOOP THEN

* get start and end for the other reference
                CHECK.START.PTR = UNRESOLVED.START.PTR.LIST<CHECK.LOOP>
                CHECK.END.PTR = UNRESOLVED.END.PTR.LIST<CHECK.LOOP>

* is this reference nested within another?
                IF NEST.START.PTR > CHECK.START.PTR AND NEST.END.PTR < CHECK.END.PTR THEN
                    NEST.COUNT += 1
                END

            END

        NEXT CHECK.LOOP

* update our table with the nested count
        UNRESOLVED.NESTED.DEPTH.LIST<NEST.LOOP> = NEST.COUNT
        IF NEST.COUNT > MAX.NESTED.DEPTH THEN
            MAX.NESTED.DEPTH = NEST.COUNT
        END

    NEXT NEST.LOOP

    RETURN

ADD.UNRESOLVED.ENTRY: ****************************************************
* add a new entry to the unresolved table.  try to find the start and    *
* end of the unresolved reference                                        *
**************************************************************************
    NEW.LINE.LENGTH = LEN(NEW.LINE)

* add new entry
    UNRESOLVED.REFERENCE.FOUND = @TRUE
    UNRESOLVED.IDENTIFIED = @FALSE

    UNRESOLVED.COUNT += 1
    UNRESOLVED.PTR.LIST<UNRESOLVED.COUNT> = DELIMITER.PTR

* find start of object reference
*    first, if the character before the delimiter is a close pren we
*    have a dimensioned object.  skip backwards until we get past
*    the opening pren.  if we can't find the opening pren we can't
*    isolate the reference so skip out
    START.PTR = DELIMITER.PTR

    IF NEW.LINE [START.PTR - 1, 1] = ")" THEN

        START.PTR = DELIMITER.PTR - 1
        PREN.COUNT = 1

        LOOP UNTIL PREN.COUNT = 0 OR START.PTR = 1 DO

            START.PTR -= 1
            THIS.CHAR = NEW.LINE [START.PTR,1]

            BEGIN CASE
                CASE THIS.CHAR = ")"
                    PREN.COUNT += 1
                CASE THIS.CHAR = "("
                    PREN.COUNT -= 1
            END CASE

        REPEAT

        IF PREN.COUNT <> 0 THEN
            RETURN
        END

    END

* skip backwards until we hit a space or operator or another character
* that couldn't be in the handle name
    OPERATOR.LIST = "+-*/\<>=():,[]{}|;"
    FOUND.START = @FALSE

    LOOP UNTIL START.PTR = 1 OR FOUND.START DO

        CHAR.BEFORE = NEW.LINE [START.PTR - 1, 1]
        BEGIN CASE

* if there's an operator ahead of our reference then we've reached the
* beginning of the reference.
            CASE INDEX(OPERATOR.LIST, CHAR.BEFORE, 1) <> 0
                FOUND.START = @TRUE

* if there's a space ahead of our reference we've reached the beginning
            CASE CHAR.BEFORE = " "
                FOUND.START = @TRUE

* otherwise keeping looking backwards
            CASE 1
                START.PTR -= 1
        END CASE

    REPEAT

* if we backed into a child delimiter then this reference is part of
* a larger expression that we'll add to this list on another iteration.
* skip out
    IF START.PTR > CHILD.DEL.LENGTH THEN
        IF NEW.LINE [START.PTR - CHILD.DEL.LENGTH, CHILD.DEL.LENGTH] = CHILD.DELIMITER THEN
            RETURN
        END
    END

* if we couldn't find the start dump out
*   IF NOT(FOUND.START) THEN
*       RETURN
*   END

* clean up starting pointer.  move it to the right until it bumps into
* a space or end of line while not being inside quotes or pren
    LOOP UNTIL NEW.LINE [START.PTR,1] <> " " OR START.PTR = NEW.LINE.LENGTH DO
        START.PTR += 1
    REPEAT

* starting after the delimiter work forward to find the end of the
* reference.  if we hit an open pren continue until we hit a closed one
* as it could be an array reference or a function within the array
* reference
    END.PTR = DELIMITER.PTR + LEN(FOUND.DELIMITER) - 1
    PARM.PTR = 0
    FOUND.END = @FALSE
    PREN.DEPTH = 0
    PREN.FOUND = @FALSE
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    LOOP UNTIL END.PTR >= NEW.LINE.LENGTH OR FOUND.END DO

        END.PTR += 1
        THIS.CHAR = NEW.LINE [END.PTR, 1]
        NEXT.CHAR = NEW.LINE [END.PTR + 1, 1]

        BEGIN CASE

* parenthesis
*     open pren.  if we haven't set the parameter starting pointer yet
*     then this is the start of the parameters for the reference
            CASE THIS.CHAR = "(" AND NOT(IN.QUOTES)
                PREN.DEPTH += 1
                IF PARM.PTR = 0 THEN
                    PARM.PTR = END.PTR
                END

                PREN.FOUND = @TRUE

*     close pren.  this means we've opened pren somewhere.  if we're
*     closing a pren we've opened then we're finished with our object
*     reference
            CASE THIS.CHAR = ")" AND NOT(IN.QUOTES)
                PREN.DEPTH -= 1

*     if this closed all open parenthesis and the next character is a
*     ";" or "" then we've closed our parameter list
                IF PREN.DEPTH = 0 THEN
                    FOUND.END = @TRUE
                END

                PREN.FOUND = @TRUE

*     we're inside parenthesis so we haven't finished finding our
*     reference yet
            CASE PREN.DEPTH <> 0
                NULL

*     the next character is opening parenthesis.  we haven't finished
*     finding our reference yet
            CASE NEXT.CHAR = "(" AND NOT(IN.QUOTES)
                NULL


* quotes
*     we hit a quote but we're not inside any parenthesis.  we've
*     hit an argument
            CASE PREN.DEPTH = 0 AND (NEXT.CHAR = "'" OR NEXT.CHAR = '"')
                FOUND.END = @TRUE

*     we're in quotes and we hit an end quote
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""

*     in quotes.  we haven't finished finding our reference yet
            CASE IN.QUOTES
                NULL

*     opening quote
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR


* next character(s) is/are an object delimiter.  we don't want to
* stop looking and move the search pointer to the end of the child object
* delimiter
            CASE NEW.LINE [END.PTR + 1, CHILD.DEL.LENGTH] = CHILD.DELIMITER
                END.PTR += (CHILD.DEL.LENGTH - 1)
            CASE NEW.LINE [END.PTR + 1, METHOD.DEL.LENGTH] = METHOD.DELIMITER
                END.PTR += (METHOD.DEL.LENGTH - 1)
            CASE NEW.LINE [END.PTR + 1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
                END.PTR += (PROPERTY.DEL.LENGTH - 1)
            CASE NEW.LINE [END.PTR + 1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
                END.PTR += (CONSTANT.DEL.LENGTH - 1)

* next character is an operator and we aren't in parenthesis or quotes
            CASE INDEX(OPERATOR.LIST, NEXT.CHAR, 1) > 0
                FOUND.END = @TRUE

* next character is a space and we aren't in parenthesis or quotes.  this may
* be a space between the object call and the parenthesis.  look ahead and see
* if the next non-space character is an open pren.  if not then we're finished
* extracting our reference
            CASE THIS.CHAR = " "
                FOLLOW.CHAR = " "
                FOR SEARCH.PTR = END.PTR + 1 TO NEW.LINE.LENGTH UNTIL FOLLOW.CHAR <> " "
                    FOLLOW.CHAR = NEW.LINE [SEARCH.PTR, 1]
                NEXT SEARCH.PTR

                IF FOLLOW.CHAR <> "(" THEN
                    FOUND.END = @TRUE
                    END.PTR -= 1
                END

* hit end of line and we aren't in parenthesis or quotes
            CASE END.PTR = NEW.LINE.LENGTH
                FOUND.END = @TRUE

        END CASE

    REPEAT

* clean up ending pointer.  move back to the left until it's off a space
    LOOP UNTIL NEW.LINE [END.PTR, 1] <> " " OR END.PTR = START.PTR DO
        END.PTR -= 1
    REPEAT

* this should never happen but let's be safe
    IF END.PTR = START.PTR THEN
        RETURN
    END

* extract the unresolved reference
    THIS.UNRESOLVED.REFERENCE = NEW.LINE [START.PTR, END.PTR - START.PTR + 1]

* we found the start and end.  add them to the table
    UNRESOLVED.IDENTIFIED = @TRUE
    UNRESOLVED.START.PTR.LIST<UNRESOLVED.COUNT> = START.PTR
    UNRESOLVED.END.PTR.LIST<UNRESOLVED.COUNT> = END.PTR
    UNRESOLVED.PARM.PTR.LIST<UNRESOLVED.COUNT> = PARM.PTR
    UNRESOLVED.REFERENCE.LIST<UNRESOLVED.COUNT> = THIS.UNRESOLVED.REFERENCE

    RETURN

FIX.UNRESOLVED.ENTRIES: **************************************************
* add code to fix unresolved entries in new.line                         *
**************************************************************************
* returns:                                                               *
*    ALL.UNRESOLVED.FIX      true if all unresolved entries were fixed   *
* builds:                                                                *
*    FIX.CODE.LIST           code needed to get temporary entries        *
*    FIXED.CODE.COUNT        count of fix.code.list                      *
*    NEW.LINE                returns with temporary variables in place   *
*                            of object references                        *
*    FIX.SUBROUTINE.CODE     code with subroutines needed to extract     *
*                            temporary values                            *
*    FIX.SUBROUTINE.CODE.COUNT count of lines in fix.subroutine.code     *
**************************************************************************

* save for later.  we're going to call convert.new.line which uses these
* variables and we want them back
    SAVE.UNRESOLVED.REFERENCE.FOUND = UNRESOLVED.REFERENCE.FOUND
    SAVE.THIS.LINE = THIS.LINE
    SAVE.CLEAN.LINE = CLEAN.LINE
    SAVE.NEW.LINE = NEW.LINE
    SAVE.LABEL = LABEL
    SAVE.INDENT.COUNT = INDENT.COUNT

    THIS.INDENT = SPACE(LEN(LABEL) + INDENT.COUNT)

    ALL.UNRESOLVED.FIXED = @TRUE
    NO.UNRESOLVED.FIXED = @TRUE

    FIX.CODE.LIST = ""

* evaluate object references starting with the deepest nested objects
* first.  we'll build new code in fix.code.list that will find the value
* for each reference and save it in a temporary variable
    FOR NEST.LOOP = MAX.NESTED.DEPTH TO 0 STEP -1

* we'll increment a pointer for the temporary variable so we always get
* a unique variable
        TEMP.COUNTER = 0

* crunch through each unresolved reference
        FOR FIX.LOOP = 1 TO UNRESOLVED.COUNT

* unload unresolved table
            START.PTR = UNRESOLVED.START.PTR.LIST<FIX.LOOP>
            END.PTR = UNRESOLVED.END.PTR.LIST<FIX.LOOP>
            PARM.PTR = UNRESOLVED.PARM.PTR.LIST<FIX.LOOP>
            UNRESOLVED.REFERENCE = UNRESOLVED.REFERENCE.LIST<FIX.LOOP>
            NEST.DEPTH = UNRESOLVED.NESTED.DEPTH.LIST<FIX.LOOP>

* if this reference is the same nested level as the one we're working in
* build the new code
            IF NEST.DEPTH = NEST.LOOP THEN

* build the name of the temporary variable we'll use to catch this value
* we'll build the value with the nested depth and the temporary counter
* as a sanity check that we evaluated everything in the right order
                TEMP.COUNTER += 1
                TEMP.VARIABLE = TEMP.VARIABLE.PREFIX:TEMP.COUNTER

                IF NEST.LOOP > 0 THEN
                    TEMP.VARIABLE := ".":NEST.LOOP
                END

* the unresolved reference may contain passed parameters.  if it does
* chop it up into only the object reference and then the parameters
                IF PARM.PTR <> 0 THEN
                    UNRESOLVED.PARM = UNRESOLVED.REFERENCE [PARM.PTR, TO.THE.END]
                    UNRESOLVED.REFERENCE = UNRESOLVED.REFERENCE [1, PARM.PTR - 1]
                END ELSE
                    UNRESOLVED.PARM = ""
                END

* if unresolved reference begins with a method, property or constant
* delimiter then add the most recent "with" handle
                CHECK.OBJECT.HANDLE = UNRESOLVED.REFERENCE
                GOSUB CHECK.OBJECT.HANDLE
                UNRESOLVED.REFERENCE = CHECK.OBJECT.HANDLE

                IF START.PTR <> "" THEN

* build new line to assign the object call, with any called parameters,
* to the temporary variable
                    THIS.LINE = "    ":TEMP.VARIABLE:" = ":UNRESOLVED.REFERENCE:UNRESOLVED.PARM

                    CHECK.UNRESOLVED.REFERENCES = @FALSE
                    ALLOW.EXTRAS.RIGHT.OF.EQUALS = @TRUE
                    GOSUB CONVERT.THIS.SINGLE.LINE

* if new.line comes back null then we couldn't convert the reference
                    IF NEW.LINE = "" THEN
                        ALL.UNRESOLVED.FIXED = @FALSE
                    END ELSE

                        NO.UNRESOLVED.FIXED = @FALSE
                        FIX.CODE.LIST<FIX.LOOP> = TRIM(NEW.LINE, " ", "L")

* save temporary variable in our unresolved table for later
                        UNRESOLVED.TEMP.LIST<FIX.LOOP> = TEMP.VARIABLE

                    END

                END

            END

        NEXT FIX.LOOP

    NEXT NEST.LOOP

* restore saved variables and get our original program line back
    UNRESOLVED.REFERENCE.FOUND = SAVE.UNRESOLVED.REFERENCE.FOUND
    THIS.LINE = SAVE.THIS.LINE
    CLEAN.LINE = SAVE.CLEAN.LINE
    NEW.LINE = SAVE.NEW.LINE
    LABEL = SAVE.LABEL
    INDENT.COUNT = SAVE.INDENT.COUNT

* if we couldn't fix anything dump out
    IF NO.UNRESOLVED.FIXED THEN
        RETURN
    END

* for any of our references that we've been able to resolve substitue
* the temporary variable for the reference.  do it backwards since each
* substitution could change the program's line length

* only do this for references that are not nested.  nested reference will
* end up in fixed.code lines so we'll get them there
    FOR FIX.LOOP = UNRESOLVED.COUNT TO 1 STEP -1

        START.PTR = UNRESOLVED.START.PTR.LIST<FIX.LOOP>
        END.PTR = UNRESOLVED.END.PTR.LIST<FIX.LOOP>
        NEST.DEPTH = UNRESOLVED.NESTED.DEPTH.LIST<FIX.LOOP>
        TEMP.VARIABLE = UNRESOLVED.TEMP.LIST<FIX.LOOP>
        FIX.CODE = FIX.CODE.LIST<FIX.LOOP>

* if we have fix code for this unresolved reference and it's not nested
* correct it in the new.line code
        IF FIX.CODE <> "" AND NEST.DEPTH = 0 THEN
            NEW.LINE = NEW.LINE [1, START.PTR - 1]:TEMP.VARIABLE:NEW.LINE [END.PTR + 1, TO.THE.END]
        END

    NEXT FIX.LOOP

* fix.code could still have some nested references in it.  beginning with
* the deepest nesting level check all the nested (only) unresolved
* references against later fix.code lines.  replace any unresolved
* references found with the temporary variables
    FOR NEST.LOOP = MAX.NESTED.DEPTH TO 1 STEP -1

        FOR FIX.LOOP = 1 TO UNRESOLVED.COUNT

* unload references from the object table for references we want to change
* in other fix lines
            NEST.DEPTH = UNRESOLVED.NESTED.DEPTH.LIST<FIX.LOOP>

            IF NEST.DEPTH = NEST.LOOP THEN

* any occurrences of this unresolved reference in other fix lines that
* aren't nested as deep should be replaced with the reference's temporary
* variable
                UNRESOLVED.REFERENCE = UNRESOLVED.REFERENCE.LIST<FIX.LOOP>
                REF.LENGTH = LEN(UNRESOLVED.REFERENCE)
                TEMP.VARIABLE = UNRESOLVED.TEMP.LIST<FIX.LOOP>

* replace all occurences of the unresolved references in the other
* lines that aren't as deep with the temporary variable
                FOR CHANGE.LOOP = 1 TO UNRESOLVED.COUNT

                    CHANGE.NEST.DEPTH = UNRESOLVED.NESTED.DEPTH.LIST<CHANGE.LOOP>

                    IF NEST.DEPTH > CHANGE.NEST.DEPTH THEN

                        FIX.CODE = FIX.CODE.LIST<CHANGE.LOOP>
                        REPLACED.REFERENCE = @FALSE

                        LOOP
                            START.PTR = INDEX(FIX.CODE,UNRESOLVED.REFERENCE,1)
                            END.PTR = START.PTR + REF.LENGTH
                        UNTIL START.PTR < 1 DO
                            FIX.CODE = FIX.CODE [1, START.PTR - 1]:TEMP.VARIABLE:FIX.CODE [END.PTR + 1, TO.THE.END]
                            REPLACED.REFERENCE = @TRUE
                        REPEAT

* if we did a reference replacement put the new fixing code back into
* fix.code.list
                        IF REPLACED.REFERENCE THEN
                            FIX.CODE.LIST<CHANGE.LOOP> = FIX.CODE
                        END

                    END

                NEXT CHANGE.LOOP

            END

        NEXT FIX.LOOP

    NEXT NEXT.LOOP

* our calls are fixed.  create fixed.code to return the current code line
* and the temporary variable subroutine calls in one array.  we'll build
* this code with the deepest nested levels first
    FIXED.CODE.COUNT = 0
    FIXED.CODE = ""

    FOR NEST.LOOP = MAX.NESTED.DEPTH TO 0 STEP -1

        FOR FIX.LOOP = 1 TO UNRESOLVED.COUNT

            FIX.CODE = FIX.CODE.LIST<FIX.LOOP>
            NEST.DEPTH = UNRESOLVED.NESTED.DEPTH.LIST<FIX.LOOP>

            BEGIN CASE

* couldn't convert this line
                CASE FIX.CODE = ""
                    NULL

* this line is on a different nesting depth
                CASE NEST.DEPTH <> NEST.LOOP
                    NULL

* for the first line add the label (if any) and the first temporary code
* line.
                CASE FIXED.CODE.COUNT = 0
                    FIXED.CODE.COUNT += 1
                    FIXED.CODE<FIXED.CODE.COUNT> = LABEL:SPACE(INDENT.COUNT):FIX.CODE

* for later lines only add the code line
                CASE 1
                    FIXED.CODE.COUNT += 1
                    FIXED.CODE<FIXED.CODE.COUNT> = THIS.INDENT:FIX.CODE

            END CASE

        NEXT FIX.LOOP

    NEXT NEST.LOOP

* add the original program line as the last line.  first cut off the
* label and trim any leading spaces.  the label was added to the first
* line of the fixing code so we don't want it here
    ADD.LINE = NEW.LINE

    IF LABEL <> "" THEN
        ADD.LINE = ADD.LINE [LEN(LABEL) + 1, TO.THE.END]
    END

    ADD.LINE = TRIM(ADD.LINE, " ", "L")

* add into fixed code table with appropriate leading spaces.  if the
* program line was calling a function with a single throwaway returned
* parameter (ie, "" = object::method(whatever)) this line can end up
* as "" = temporary.variable or '' = temporary.variable.  if this line
* looks like this we wont' add it into the fixed code
    TEST.THROWAWAY.LINE = TRIM(ADD.LINE, " ", "A") [1, 3]

    IF TEST.THROWAWAY.LINE <> '""=' AND TEST.THROWAWAY.LINE <> "''=" THEN
        FIXED.CODE.COUNT += 1
        FIXED.CODE<FIXED.CODE.COUNT> = THIS.INDENT:ADD.LINE
    END

    RETURN

CHECK.OBJECT.HANDLE: *****************************************************
* check object handle and clean it up if necessary.  takes care of       *
* with-enabled references                                                *
**************************************************************************

* if unresolved reference begins with a method, property, child or constant
* delimiter then add the most recent "with" handle
    ADD.WITH.HANDLE = @FALSE
    REPLACE.WITH.HANDLE = @FALSE

* if the object handle we're checking begins with an object delimiter
* then we want to add the current with stack contents to it
    BEGIN CASE

        CASE CHECK.OBJECT.HANDLE [1, METHOD.DEL.LENGTH] = METHOD.DELIMITER
            ADD.WITH.HANDLE = @TRUE

        CASE CHECK.OBJECT.HANDLE [1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
            ADD.WITH.HANDLE = @TRUE

        CASE CHECK.OBJECT.HANDLE [1, CHILD.DEL.LENGTH] = CHILD.DELIMITER
            ADD.WITH.HANDLE = @TRUE

        CASE CHECK.OBJECT.HANDLE [1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
            ADD.WITH.HANDLE = @TRUE

    END CASE

    IF ADD.WITH.HANDLE THEN
        CHECK.OBJECT.HANDLE = CURRENT.WITH:CHECK.OBJECT.HANDLE
    END

    RETURN

ANALYZE.UNRESOLVED.REFERENCE: ********************************************
* analyze an unresolved reference and see if we can tell why it's        *
* not resolving                                                          *
**************************************************************************
    THIS.START.PTR = UNRESOLVED.START.PTR.LIST<PTR.LOOP>
    THIS.END.PTR = UNRESOLVED.END.PTR.LIST<PTR.LOOP>

* get reference from program line
    THIS.REFERENCE = THIS.LINE [THIS.START.PTR, THIS.END.PTR - THIS.START.PTR + 1]

* if this object handle starts with any delimiter and we have a "WITH"
* active add the current "WITH" value
    BEGINS.WITH = @FALSE

    IF THIS.REFERENCE [1, METHOD.DEL.LENGTH] = METHOD.DELIMITER THEN
        BEGINS.WITH = @TRUE
    END

    IF THIS.REFERENCE [1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER THEN
        BEGINS.WITH = @TRUE
    END

    IF THIS.REFERENCE [1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER THEN
        BEGINS.WITH = @TRUE
    END

    IF BEGINS.WITH AND CURRENT.WITH <> "" THEN
        THIS.REFERENCE = CURRENT.WITH:THIS.REFERENCE
    END

* pull the object handle from the reference.  look for the first delimiter
* in the reference string
    CHILD.PTR = INDEX(THIS.REFERENCE, CHILD.DELIMITER, 1)
    METHOD.PTR = INDEX(THIS.REFERENCE, METHOD.DELIMITER, 1)
    PROPERTY.PTR = INDEX(THIS.REFERENCE, PROPERTY.DELIMITER, 1)
    CONSTANT.PTR = INDEX(THIS.REFERENCE, CONSTANT.DELIMITER, 1)

* if the child delimiter is the same as any of the other delimiters it
* will be difficult to pull this thing apart.  if the child delimiter is
* the same as any other delimiter then see how many times it appears in
* the reference.  if it's more than once we'll assume that the next-to-the-
* last delimiter is a method, property or constant delimiter and all the
* other delimiters are child delimiters
    IF CHILD.DELIMITER = METHOD.DELIMITER OR CHILD.DELIMITER = PROPERTY.DELIMITER OR CHILD.DELIMITER = CONSTANT.DELIMITER THEN

        IF CHILD.PTR <> 0 THEN

            CHILD.DEL.COUNT = 0
            LOOP
                DEL.PTR = INDEX(THIS.REFERENCE, CHILD.DELIMITER, CHILD.DEL.COUNT + 1)
            UNTIL DEL.PTR < 1 DO
                CHILD.DEL.COUNT += 1
            REPEAT

            IF CHILD.DEL.COUNT > 1 THEN
                METHOD.PTR = INDEX(THIS.REFERENCE, METHOD.DELIMITER, CHILD.DEL.COUNT)
                PROPERTY.PTR = INDEX(THIS.REFERENCE, PROPERTY.DELIMITER, CHILD.DEL.COUNT)
                CONSTANT.PTR = INDEX(THIS.REFERENCE, CONSTANT.DELIMITER, CHILD.DEL.COUNT)
            END

        END

    END

* type the right side of the expression based on the delimiter.  if the
* delimiters are all the same, of course, this won't do very much but it's
* trying!
    THIS.DELIMITER = ""
    THIS.PTR = 0
    THIS.TYPE = ""

    IF METHOD.PTR > 0 THEN
        THIS.DELIMITER = METHOD.DELIMITER
        THIS.PTR = METHOD.PTR
        THIS.TYPE = "METHOD"
    END

    IF PROPERTY.PTR > 0 AND (PROPERTY.PTR < THIS.PTR OR THIS.PTR = 0) THEN
        THIS.DELIMITER = PROPERTY.DELIMITER
        THIS.PTR = PROPERTY.PTR
        THIS.TYPE = "PROPERTY"
    END

    IF CONSTANT.PTR > 0 AND (CONSTANT.PTR < THIS.PTR OR THIS.PTR = 0) THEN
        THIS.DELIMITER = CONSTANT.DELIMITER
        THIS.PTR = CONSTANT.PTR
        THIS.TYPE = "CONSTANT"
    END

* extract object reference and its target action from the reference.  if the
* object reference is to a child object (ie, object1::object2) the entire reference
* will be in this.object.handle
    THIS.OBJECT.HANDLE = THIS.REFERENCE [1, THIS.PTR - 1]
    THIS.OBJECT.ACTION = THIS.REFERENCE [THIS.PTR + LEN(THIS.DELIMITER), TO.THE.END]

* if the object is an array change the handle so we can find it in our
* tables
    IF COUNT(THIS.OBJECT.HANDLE, "(") <> 0 THEN
        THIS.OBJECT.HANDLE = THIS.OBJECT.HANDLE ["(", 1, 1]:"()"
    END

* doesn this object handle exist in the object table?
    THIS.OBJECT.IN.TABLES = @FALSE
    FOUND.PTR = 0

    LOCATE THIS.OBJECT.HANDLE IN CREATE.HANDLE.LIST SETTING FOUND.PTR THEN
        THIS.OBJECT.IN.TABLES = @TRUE
    END

* see if string pseudo-object calls are enabled and if the string object
* has been initialied.  if so then this object could be for a string
* pseudo-object call and then anything could be an object handle
    STRING.OBJECT.CALLS = @FALSE

    IF ENABLE.STRING.OBJECT.CALLS THEN
        LOCATE STRING.OBJECT.NAME IN HANDLE.OBJECT.LIST SETTING STRING.OBJECT.PTR THEN
            STRING.OBJECT.CALLS = @TRUE
        END
    END

* is this object handle valid?
    BEGIN CASE

* "local" is always a valid object handle
        CASE THIS.OBJECT.HANDLE = LOCAL.KEYWORD OR THIS.OBJECT.HANDLE = LOCAL.OBJECT.HANDLE

            THIS.OBJECT.NAME = LOCAL.KEYWORD
            THIS.HANDLE.VALID = @TRUE
            CHECK.HANDLE.ACTION = @TRUE

* the subroutine call pseudo-object is always a valid handle
        CASE THIS.OBJECT.HANDLE = SUBROUTINE.CALL.KEYWORD

            THIS.OBJECT.NAME = SUBROUTINE.CALL.KEYWORD
            THIS.HANDLE.VALID = @TRUE
            CHECK.HANDLE.ACTION = @FALSE

* if the object handle appears in the object tables then we have a valid
* object handle
        CASE THIS.OBJECT.IN.TABLES

            THIS.OBJECT.NAME = CREATE.OBJECT.LIST<FOUND.PTR>
            THIS.HANDLE.VALID = @TRUE
            CHECK.HANDLE.ACTION = @TRUE

* if string psuedo-object calls are enabled then just about anything can
* be an object handle
        CASE STRING.OBJECT.CALLS
            
            THIS.OBJECT.NAME = STRING.OBJECT.NAME
            THIS.HANDLE.VALID = @TRUE
            CHECK.HANDLE.ACTION = @FALSE

* if we got this far then the object handle isn't valid.  if the object handle
* is "sub" it's because the subroutine couldn't be found
        CASE 1

            THIS.OBJECT.NAME = "Unknown"
            THIS.HANDLE.VALID = @FALSE
            CHECK.HANDLE.ACTION = @FALSE

* display error
            BEGIN CASE
                CASE UPCASE(THIS.OBJECT.HANDLE) = SUBROUTINE.CALL.KEYWORD
                    ERROR.LINE = "Could not find subroutine in OC for ":SUBROUTINE.CALL.KEYWORD:" object"
                CASE UPCASE(THIS.OBJECT.HANDLE) = LOCAL.KEYWORD
                    THIS.LOCAL.METHOD = THIS.REFERENCE [METHOD.PTR + LEN (METHOD.DELIMITER), 1000]
                    THIS.LOCAL.METHOD = TRIM (THIS.LOCAL.METHOD ["(", 1, 1])
                    ERROR.LINE = '"':THIS.LOCAL.METHOD:'"':" is not a local method in ":THIS.OBJECT.HANDLE
                CASE 1
                    ERROR.LINE = '"':THIS.OBJECT.HANDLE:'"':" is not a valid object handle"
            END CASE

            PRINT "     ":" ":ERROR.LINE

* update error table
            ERROR.SUBROUTINE = SUBROUTINE.NAME
            ERROR.METHOD = METHOD
            ERROR.SOURCE.LINE = LINE.LOOP
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = ERROR.LINE
            GOSUB ADD.ERROR

    END CASE

* if the handle is valid lets see if the action is.  build a version of
* the action with and without parenthesis for properties, without
* parenthesis for methods and with and without for constants
    IF THIS.HANDLE.VALID AND CHECK.HANDLE.ACTION THEN

        THIS.OBJECT.NO.ARRAY = THIS.OBJECT.ACTION ["(", 1, 1]

        IF COUNT(THIS.OBJECT.ACTION,"(") > 0 THEN
            THIS.OBJECT.ARRAY = THIS.OBJECT.NO.ARRAY:"()"
        END ELSE
            THIS.OBJECT.ARRAY = THIS.OBJECT.NO.ARRAY
        END

* build all possible references with this object and action
        THIS.OBJECT.PROPERTY.ARRAY = THIS.OBJECT.HANDLE:PROPERTY.DELIMITER:THIS.OBJECT.ARRAY
        THIS.OBJECT.PROPERTY = THIS.OBJECT.HANDLE:PROPERTY.DELIMITER:THIS.OBJECT.NO.ARRAY
        THIS.OBJECT.METHOD = THIS.OBJECT.HANDLE:METHOD.DELIMITER:THIS.OBJECT.NO.ARRAY
        THIS.OBJECT.CONSTANT.ARRAY = THIS.OBJECT.HANDLE:CONSTANT.DELIMITER:THIS.OBJECT.ARRAY
        THIS.OBJECT.CONSTANT = THIS.OBJECT.HANDLE:CONSTANT.DELIMITER:THIS.OBJECT.NO.ARRAY

* see if we can find this as a method, property, array, constant, or
* whatever.
        FOUND.ACTION = @FALSE

        FIND THIS.OBJECT.PROPERTY.ARRAY IN HANDLE.KEYWORD.LIST SETTING THIS.HANDLE.PTR, THIS.METHOD.PTR THEN
            FOUND.ACTION = @TRUE
        END

        FIND THIS.OBJECT.PROPERTY IN HANDLE.KEYWORD.LIST SETTING THIS.HANDLE.PTR, THIS.METHOD.PTR THEN
            FOUND.ACTION = @TRUE
        END

        FIND THIS.OBJECT.METHOD IN HANDLE.KEYWORD.LIST SETTING THIS.HANDLE.PTR, THIS.METHOD.PTR THEN
            FOUND.ACTION = @TRUE
        END

        FIND THIS.OBJECT.CONSTANT.ARRAY IN HANDLE.KEYWORD.LIST SETTING THIS.HANDLE.PTR, THIS.METHOD.PTR THEN
            FOUND.ACTION = @TRUE
        END

        FIND THIS.OBJECT.CONSTANT IN HANDLE.KEYWORD.LIST SETTING THIS.HANDLE.PTR, THIS.METHOD.PTR THEN
            FOUND.ACTION = @TRUE
        END

* if we couldn't find the reference then the action part of the reference
* is bad
        IF NOT(FOUND.ACTION) THEN

            ERROR.LINE = '"':THIS.OBJECT.ARRAY:'"':" is not a Method or Property of "
            ERROR.LINE := '"':THIS.OBJECT.HANDLE:'", a '
            ERROR.LINE := '"':THIS.OBJECT.NAME:'"':" object"
            PRINT "    ":" ":ERROR.LINE

* update error table
            ERROR.SUBROUTINE = SUBROUTINE.NAME
            ERROR.METHOD = METHOD
            ERROR.SOURCE.LINE = LINE.LOOP
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = ERROR.LINE
            GOSUB ADD.ERROR

        END

    END

    RETURN


**************************************************************************
**************************************************************************
** error and warning logging                                            **
**************************************************************************
**************************************************************************

PRINT.OBJECT.ERROR: ******************************************************
* print an object error and associated program lines                     *
**************************************************************************

* find the line number in the source code given the line in the final
* code.  object.warning.line probably isn't in program.code.final.list
* yet so we'll look for the line before and increment the final source

* if object.error.line isn't numeric then the calling routine passed us
* the program line to display.  if sending a program line to display like
* this pass it as the line number first, a space, and then the rest of
* the line.  ie, "000001 SUBROUTINE MYSUB(PARAMETER)"
    IF NUM(OBJECT.ERROR.LINE) THEN

        LOCATE OBJECT.ERROR.LINE - 1 IN PROGRAM.CODE.FINAL.LIST SETTING ERROR.LINE.PTR THEN
            THIS.ERROR.LINE = PROGRAM.CODE.SOURCE.LIST<OBJECT.LINE.PTR>
        END ELSE
            THIS.ERROR.LINE = 0
        END

        ERROR.SOURCE.LINE = OBJECT.CODE.SOURCE.LIST<THIS.ERROR.LINE> + 1

    END ELSE

        ERROR.SOURCE.LINE = OBJECT.ERROR.LINE [" ", 1, 1]
        THIS.LINE = OBJECT.ERROR.LINE [" ", 2, TO.THE.END]
        OBJECT.ERROR.LINE = ERROR.SOURCE.LINE

    END

* update error table
    ERROR.SUBROUTINE = SUBROUTINE.NAME
    ERROR.METHOD = METHOD
    ERROR.SOURCE.LINE = OBJECT.ERROR.LINE
    ERROR.ECLIPSE.LINE = ""

    PRINT

* print original program line
    IF UPCASE.CODE THEN
        THIS.LINE = DOWNCASE.QUOTE(THIS.LINE)
    END

    PRINT ERROR.SOURCE.LINE "R%6":" ":THIS.LINE

* add to the error table
    ERROR.DESC = THIS.LINE
    GOSUB ADD.ERROR

* show pointers to the reference generating the error if we have it
    IF SHOW.REFERENCE THEN

        GOSUB INDICATE.ERROR.REFERENCE

* if we were able to partially convert the line show what we could convert
        IF THIS.LINE <> NEW.LINE AND NEW.LINE <> "" THEN
            PRINT LINE.LOOP "R%6":" ":NEW.LINE
            ERROR.DESC = NEW.LINE
            GOSUB ADD.ERROR
        END

    END

* print error
    PRINT OBJECT.ERROR.DESC

* update the error table
    ERROR.DESC = OBJECT.ERROR.DESC
    GOSUB ADD.ERROR

    TOTAL.OBJECT.ERRORS += 1

* if "wait after error" is set pause
    IF WAIT.AFTER.ERROR THEN

        IF COMPILE.OBJECT THEN
            SPEECH = "An error was encountered in method ":METHOD
            SPEECH := " of object ":OBJECT.NAME:". "
        END ELSE
            SPEECH = "An error was encountered in subroutine ":OBJECT.NAME:". "
        END

        SPEECH := OBJECT.ERROR.DESC
        GOSUB WAIT.AND.SPEAK
        GOSUB WAIT

    END

    RETURN

ADD.ERROR: ***************************************************************
* add a compile error to the compilation error tables by subroutine /    *
* method name                                                            *
**************************************************************************

* find the subroutine's name in our table.  we'll keep them in order to
* be pretty
    LOCATE ERROR.SUBROUTINE IN ERROR.SUBROUTINE.LIST BY "AL" SETTING SUB.PTR ELSE

        INS "" BEFORE ERROR.SUBROUTINE.LIST<SUB.PTR>
        INS "" BEFORE ERROR.METHOD.LIST<SUB.PTR>
        INS "" BEFORE ERROR.SOURCE.LINE.LIST<SUB.PTR>
        INS "" BEFORE ERROR.ECLIPSE.LINE.LIST<SUB.PTR>
        INS "" BEFORE ERROR.DESC.LIST<SUB.PTR>
        ERROR.SUBROUTINE.COUNT += 1

    END

* increment counter
    ERROR.LIST.COUNT<SUB.PTR> += 1
    LIST.PTR = ERROR.LIST.COUNT<SUB.PTR>

* update table
    ERROR.SUBROUTINE.LIST<SUB.PTR> = ERROR.SUBROUTINE
    ERROR.METHOD.LIST<SUB.PTR> = ERROR.METHOD

    ERROR.SOURCE.LINE.LIST<SUB.PTR,LIST.PTR> = ERROR.SOURCE.LINE
    ERROR.ECLIPSE.LINE.LIST<SUB.PTR,LIST.PTR> = ERROR.ECLIPSE.LINE
    ERROR.DESC.LIST<SUB.PTR,LIST.PTR> = ERROR.DESC

    RETURN

SHOW.ERROR.TABLE: ********************************************************
* display error table                                                    *
**************************************************************************
    ERROR.TEXT = ""
    ERROR.TEXT.COUNT = 0

    IF ERROR.SUBROUTINE.COUNT = 0 THEN
        RETURN
    END

    THIS.LINE = " "
    GOSUB ADD.ERROR.TEXT

    FOR SUB.LOOP = 1 TO ERROR.SUBROUTINE.COUNT

* unload error line
        THIS.ERROR.COUNT = ERROR.LIST.COUNT<SUB.LOOP>
        THIS.SUBROUTINE = ERROR.SUBROUTINE.LIST<SUB.LOOP>
        THIS.METHOD = ERROR.METHOD.LIST<SUB.LOOP>
        THIS.LINE = ""

* update bad compile list
        BAD.COMPILE.PROGRAM = THIS.SUBROUTINE

        IF THIS.METHOD <> "" AND THIS.METHOD <> "MAIN" THEN

            DISPLAY.METHOD = OBJECT.NAME:METHOD.DELIMITER:THIS.METHOD

            IF UPCASE.CODE THEN
                DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
            END

            BAD.COMPILE.PROGRAM = DISPLAY.METHOD
            IF DISPLAY.COMPILE.CBP.NAME THEN
                BAD.COMPILE.PROGRAM := " -> ":BAD.COMPILE.PROGRAM
            END

        END

        LOCATE BAD.COMPILE.PROGRAM IN BAD.COMPILE.LIST BY "AL" SETTING BAD.PTR ELSE
            INS BAD.COMPILE.PROGRAM BEFORE BAD.COMPILE.LIST<BAD.PTR>
            BAD.COMPILE.COUNT += 1
        END

* if we're compiling an object show a more detailed display so we can
* see the name of the eclipse subroutine generated from the object method
        IF COMPILE.OBJECT THEN

            THIS.LINE = OBJECT.FILENAME:" "

            DISPLAY.METHOD = OBJECT.NAME:METHOD.DELIMITER:THIS.METHOD

            IF UPCASE.CODE THEN
                DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
            END

            THIS.LINE := DISPLAY.METHOD

            IF THIS.METHOD <> THIS.SUBROUTINE THEN
                THIS.LINE = THIS.LINE
                IF DISPLAY.COMPILE.CBP.NAME THEN
                    THIS.LINE := " -> [":TARGET.FILENAME:" ":THIS.SUBROUTINE:"]"
                END
            END

        END ELSE
            THIS.LINE = OBJECT.FILENAME:" ":THIS.SUBROUTINE
        END

        GOSUB ADD.ERROR.TEXT

* if we're sending to a window add a few lines so we don't get that annoying
* white spot at the bottom
        IF SEND.TO.WINDOW THEN
            FOR ADD.LINES = 1 TO 20
                THIS.LINE = " "
                GOSUB ADD.ERROR.TEXT
            NEXT ADD.LINES
        END

* list out the compile errors for this method
        LAST.SOURCE.LINE = "****"
        LAST.ECLIPSE.LINE = "****"

* unload errors for this method from the error tables
        THIS.SOURCE.LIST = RAISE(ERROR.SOURCE.LINE.LIST<SUB.LOOP>)
        THIS.ECLIPSE.LIST = RAISE(ERROR.ECLIPSE.LINE.LIST<SUB.LOOP>)
        THIS.ERROR.LIST = RAISE(ERROR.DESC.LIST<SUB.LOOP>)

* clean up error table a bit.  sometimes multiple lines are posted but
* only the first gets a line number
        FOR ERROR.LOOP = 2 TO THIS.ERROR.COUNT
            IF THIS.SOURCE.LIST<ERROR.LOOP> = "" AND THIS.SOURCE.LIST<ERROR.LOOP - 1> <> "" THEN
                THIS.SOURCE.LIST<ERROR.LOOP> = THIS.SOURCE.LIST<ERROR.LOOP - 1>
            END
        NEXT ERROR.LOOP

* some error lines were accumulated before we had a cross reference to
* the compiled code.  for any source line that has an eclipse line make
* sure all other entries for that source line are updated
        FOR ERROR.LOOP = 1 TO THIS.ERROR.COUNT

            THIS.SOURCE.LINE = THIS.SOURCE.LIST<ERROR.LOOP>
            THIS.ECLIPSE.LINE = THIS.ECLIPSE.LIST<ERROR.LOOP>

            IF THIS.SOURCE.LINE <> "" AND THIS.ECLIPSE.LINE <> "" THEN

                FOR CHECK.LOOP = 1 TO THIS.ERROR.COUNT
                    IF THIS.SOURCE.LIST<CHECK.LOOP> = THIS.SOURCE.LINE AND THIS.ECLIPSE.LIST<CHECK.LOOP> = "" THEN
                        THIS.ECLIPSE.LIST<CHECK.LOOP> = THIS.ECLIPSE.LINE
                    END
                NEXT CHECK.LOOP

            END

        NEXT ERROR.LOOP

* build a pointer table since error table may not be in source line number
* order
        ERROR.PTR.LIST = ""
        ERROR.PTR.LINE.LIST = ""
        ERROR.PTR.TYPE.LIST = ""

        FOR PTR.LOOP = 1 TO THIS.ERROR.COUNT

            THIS.SOURCE.LINE = THIS.SOURCE.LIST<PTR.LOOP>

* if the line number is already in the table insert the pointer after
* all entries with the same line number
            LOCATE THIS.SOURCE.LINE IN ERROR.PTR.LINE.LIST BY "AR" SETTING LINE.PTR THEN

                INSERT.PTR = LINE.PTR
                LOOP UNTIL ERROR.PTR.LINE.LIST<INSERT.PTR> > THIS.SOURCE.LINE OR ERROR.PTR.LINE.LIST<INSERT.PTR> = ""
                    INSERT.PTR += 1
                REPEAT

            END ELSE

                INSERT.PTR = LINE.PTR

            END

            INS THIS.SOURCE.LINE BEFORE ERROR.PTR.LINE.LIST<INSERT.PTR>
            INS PTR.LOOP BEFORE ERROR.PTR.LIST<INSERT.PTR>
            INS "Error" BEFORE ERROR.PTR.TYPE.LIST<INSERT.PTR>

        NEXT PTR.LOOP

* this code would leave them in the same order they accumulated rather than
* printing them in line number order.  probably don't want this
*       FOR PTR.LOOP = 1 TO THIS.ERROR.COUNT
*           ERROR.PTR.LIST<PTR.LOOP> = PTR.LOOP
*           ERROR.PTR.LINE.LIST<PTR.LOOP> = THIS.SOURCE.LIST<PTR.LOOP>
*           ERROR.PTR.TYPE.LIST<PTR.LOOP> = "Error"
*       NEXT PTR.LOOP

* list the errors in the new, sorted order
        FOR ERROR.LOOP = 1 TO THIS.ERROR.COUNT

            ERROR.PTR = ERROR.PTR.LIST<ERROR.LOOP>

            THIS.SOURCE.LINE = THIS.SOURCE.LIST<ERROR.PTR>
            THIS.ECLIPSE.LINE = THIS.ECLIPSE.LIST<ERROR.PTR>
            THIS.ERROR = THIS.ERROR.LIST<ERROR.PTR>
            THIS.LINE = ""

* for window displays put a blank between program lines to make it
* more readable
            IF SEND.TO.WINDOW THEN
                IF ERROR.LOOP > 1 THEN
                    IF THIS.SOURCE.LINE <> LAST.SOURCE.LINE THEN
                        THIS.LINE = " "
                        GOSUB ADD.ERROR.TEXT
                    END
                END
            END

* indent
            THIS.LINE = "    "

* show line number
            BEGIN CASE
                CASE THIS.SOURCE.LINE = LAST.SOURCE.LINE AND THIS.ECLIPSE.LINE = LAST.ECLIPSE.LINE
                    THIS.LINE := "      ":" ":"        ":"  "
                CASE THIS.SOURCE.LINE = ""
                    THIS.LINE := "      ":" ":"        ":": "
                CASE THIS.SOURCE.LINE = THIS.ECLIPSE.LINE
                    THIS.LINE := THIS.SOURCE.LINE "R%6":" ":"        ":": "
                CASE THIS.ECLIPSE.LINE = ""
                    THIS.LINE := THIS.SOURCE.LINE "R%6":" ":"        ":": "
                CASE 1
                    THIS.LINE := THIS.SOURCE.LINE "R%6":" ":"[":THIS.ECLIPSE.LINE "R%6":"]":": "
            END CASE

* add error
            THIS.LINE := THIS.ERROR

            GOSUB ADD.ERROR.TEXT

            LAST.SOURCE.LINE = THIS.SOURCE.LINE
            LAST.ECLIPSE.LINE = THIS.ECLIPSE.LINE

        NEXT ERROR.LOOP

    NEXT ERROR.LOOP

* error text can end up with a lot of blank lines in it.  remove any
* blank lines with a blank line ahead of it so we don't get more than
* one blank line in a row
   FOR ERROR.LOOP = ERROR.TEXT.COUNT TO 2 STEP -1

        IF TRIM(ERROR.TEXT<ERROR.LOOP>) = "" AND TRIM(ERROR.TEXT<ERROR.LOOP - 1>) = "" THEN
            DEL ERROR.TEXT<ERROR.LOOP>
            ERROR.TEXT.COUNT -= 1
        END

   NEXT ERROR.LOOP

* send it to an editor window if requested in the command line
    IF SEND.TO.WINDOW THEN

        THIS.LINE = " "
        GOSUB ADD.ERROR.TEXT

        UD.VIEW.TEXT ERROR.TEXT, 0, 0, OBJECT.FILENAME, OBJECT.NAME

    END ELSE

        FOR LINE.LOOP = 1 TO ERROR.TEXT.COUNT
            PRINT ERROR.TEXT<LINE.LOOP>
        NEXT LINE

    END

    RETURN

ADD.ERROR.TEXT: **********************************************************
* add this.line to error text table                                      *
**************************************************************************
    ERROR.TEXT.COUNT += 1
    ERROR.TEXT<ERROR.TEXT.COUNT> = THIS.LINE

    RETURN

PRINT.OBJECT.WARNING: ****************************************************
* print an object warning                                                *
**************************************************************************

* find the line number in the source code given the line in the final
* code.  object.warning.line probably isn't in program.code.final.list
* yet so we'll look for the line before and increment the final soruce
    LOCATE OBJECT.WARNING.LINE - 1 IN PROGRAM.CODE.FINAL.LIST SETTING OBJECT.LINE.PTR THEN
        THIS.OBJECT.LINE = PROGRAM.CODE.SOURCE.LIST<OBJECT.LINE.PTR>
    END ELSE
        THIS.OBJECT.LINE = 0
    END

    IF NUM(THIS.OBJECT.LINE) THEN

        WARNING.SOURCE.LINE = OBJECT.CODE.SOURCE.LIST<THIS.OBJECT.LINE>

        IF NUM(WARNING.SOURCE.LINE) THEN
            WARNING.SOURCE.LINE += 1
        END ELSE
            WARNING.SOURCE.LINE = 1
        END

    END ELSE

        WARNING.SOURCE.LINE = 1

    END

* update error table
    WARNING.SUBROUTINE = SUBROUTINE.NAME
    WARNING.METHOD = METHOD
    WARNING.ECLIPSE.LINE = ""

    PRINT

* print original program line
    PRINT WARNING.SOURCE.LINE "R%6":" [":OBJECT.WARNING.LINE "R%6":"] ":

* print error
    WARNING.TEXT = "":FOLD("Warning: ":OBJECT.WARNING.DESC, 63)
    WARNING.TEXT.COUNT = DCOUNT(WARNING.TEXT, @AM)
    PRINT WARNING.TEXT<1>

    FOR TEXT.LOOP = 2 TO WARNING.TEXT.COUNT
        PRINT SPACE(16):WARNING.TEXT<TEXT.LOOP>
    NEXT TEXT.LOOP

* print the code
    IF OBJECT.WARNING.LINE <> 0 THEN

        WARNING.CODE = TRIM(PROGRAM.CODE<OBJECT.WARNING.LINE>, " ", "B")

        IF UPCASE.CODE THEN
            WARNING.CODE = DOWNCASE.QUOTE(WARNING.CODE)
        END

        PRINT "       ":WARNING.CODE

    END

* update the warning table
    WARNING.DESC = OBJECT.WARNING.DESC
    GOSUB ADD.WARNING

    TOTAL.OBJECT.WARNINGS += 1

* if "wait after warning" is set pause
    IF WAIT.AFTER.WARNING THEN
        SPEECH = "A warning was encountered. ":WARNING.DESC
        GOSUB WAIT.AND.SPEAK
        GOSUB WAIT
    END

    RETURN

ADD.WARNING: *************************************************************
* add a compile error to the compilation error tables by subroutine /    *
* method name                                                            *
**************************************************************************

* find the subroutine's name in our table.  we'll keep them in order to
* be pretty
    LOCATE WARNING.SUBROUTINE IN WARNING.SUBROUTINE.LIST BY "AL" SETTING SUB.PTR ELSE

        INS "" BEFORE WARNING.SUBROUTINE.LIST<SUB.PTR>
        INS "" BEFORE WARNING.METHOD.LIST<SUB.PTR>
        INS "" BEFORE WARNING.SOURCE.LINE.LIST<SUB.PTR>
        INS "" BEFORE WARNING.ECLIPSE.LINE.LIST<SUB.PTR>
        INS "" BEFORE WARNING.DESC.LIST<SUB.PTR>

        WARNING.SUBROUTINE.COUNT += 1

    END

* increment counter
    WARNING.LIST.COUNT<SUB.PTR> += 1
    LIST.PTR = WARNING.LIST.COUNT<SUB.PTR>

* update table
    WARNING.SUBROUTINE.LIST<SUB.PTR> = WARNING.SUBROUTINE
    WARNING.METHOD.LIST<SUB.PTR> = WARNING.METHOD

    WARNING.SOURCE.LINE.LIST<SUB.PTR,LIST.PTR> = WARNING.SOURCE.LINE
    WARNING.ECLIPSE.LINE.LIST<SUB.PTR,LIST.PTR> = WARNING.ECLIPSE.LINE
    WARNING.DESC.LIST<SUB.PTR,LIST.PTR> = WARNING.DESC

    RETURN

INDICATE.ERROR.REFERENCE: ************************************************
* display pointers to the reference if it couldn't be converted          *
**************************************************************************
    POINTER.DESC = SPACE(LEN(NEW.LINE))

    FOR PTR.LOOP = 1 TO UNRESOLVED.COUNT

        THIS.PTR = UNRESOLVED.PTR.LIST<PTR.LOOP>
        THIS.START.PTR = UNRESOLVED.START.PTR.LIST<PTR.LOOP>
        THIS.END.PTR = UNRESOLVED.END.PTR.LIST<PTR.LOOP>
        THIS.FIX.CODE = FIX.CODE.LIST<PTR.LOOP>

        IF THIS.FIX.CODE = "" OR DETAILS THEN

            POINTER.DESC [THIS.PTR, 2] = "^^"

            IF THIS.START.PTR <> "" THEN

                POINTER.DESC [THIS.START.PTR, 2] = "<-"
                POINTER.DESC [THIS.END.PTR - 1, 2] = "->"

                FOR FILL = THIS.START.PTR + 1 TO THIS.END.PTR - 1
                    IF POINTER.DESC [FILL, 1] = " " THEN
                        POINTER.DESC [FILL, 1] = "-"
                    END
                NEXT FILL

            END

        END

    NEXT PTR.LOOP

    POINTER.DESC = TRIM(POINTER.DESC," ","T")
    PRINT "      ":" ":POINTER.DESC

* update error table
    ERROR.SUBROUTINE = SUBROUTINE.NAME
    ERROR.METHOD = METHOD
    ERROR.SOURCE.LINE = LINE.LOOP
    ERROR.ECLIPSE.LINE = ""
    ERROR.DESC = POINTER.DESC
    GOSUB ADD.ERROR

    FOR PTR.LOOP = 1 TO UNRESOLVED.COUNT
        GOSUB ANALYZE.UNRESOLVED.REFERENCE
    NEXT PTR.LOOP

    RETURN


**************************************************************************
**************************************************************************
** eclipse / compiling via the eclipse compiler                         **
**************************************************************************
**************************************************************************

COMPILE.ALL.METHODS: *****************************************************
* compile all subroutines created from object methods                    *
**************************************************************************
    BA.START.DATE = DATE()
    BA.START.TIME = TIME()

    IF DETAILS THEN
        GOSUB PRINT.ALL.COMPILED.LIST
    END

    COMPILE.SUCCESSFUL = @TRUE

* if we didn't export any programs there's nothing to compile
    IF CREATED.METHOD.COUNT = 0 THEN
        RETURN
    END

* build a saved list of the subroutines exported
    SAVE.LIST = CREATED.SUBROUTINE.LIST
    SAVE.LIST.ID = "METHOD.COMPILE.":PORT.NO

    IF DETAILS THEN
        PRINT
        PRINT "Compile List saved as ":SAVE.LIST.ID
    END

    WRITELIST SAVE.LIST ON SAVE.LIST.ID

* build a saved list of subroutine with errors if we have any
    IF BAD.SUBROUTINE.COUNT > 0 THEN

        SAVE.LIST = BAD.SUBROUTINE.LIST
        SAVE.LIST.ID = "BAD.COMPILE.":PORT.NO

        IF DETAILS THEN
            PRINT
            PRINT "Subroutines with errors saved as ":SAVE.LIST.ID
        END

        WRITELIST SAVE.LIST ON SAVE.LIST.ID

    END

    PRINT
    PRINT "Compiling ":CREATED.METHOD.COUNT "L,":" CBP program":

    IF CREATED.METHOD.COUNT <> 1 THEN
        PRINT "s":
    END

    PRINT

* build and execute the compile statement
    STATEMENT = "GET.LIST ":SAVE.LIST.ID
    STATEMENT<2> = COMPILE.COMMAND

* for eclipse compiles add the filename to take care of screens and things
    IF COMPILE.ECLIPSE OR COMPILE.CBP THEN
        STATEMENT<2> := " ":OBJECT.FILENAME
    END ELSE
        STATEMENT<2> := " ":TARGET.FILENAME
    END

    EXECUTE STATEMENT CAPTURING COMPILE.TEXT

    GOSUB PROCESS.COMPILE.TEXT

    GRAND.TOTAL.COMPILED += CREATED.METHOD.COUNT
    GRAND.TOTAL.LINES += SUM(CREATED.SUBROUTINE.COUNT.LIST)
    GRAND.TOTAL.BYTES += SUM(CREATED.SUBROUTINE.BYTE.LIST)

    PE.DOC.LIST = CREATED.SUBROUTINE.LIST
    GOSUB UPDATE.PE.DOC

    BA.END.DATE = DATE()
    BA.END.TIME = TIME()
    BA.ELAPSED.TIME += TIME.ELAPSED (BA.START.DATE, BA.START.TIME)

    RETURN

COMPILE.ONE.METHOD: ******************************************************
* compile a single method                                                *
**************************************************************************
    BA.START.DATE = DATE()
    BA.START.TIME = TIME()

    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Compiling ":TARGET.FILENAME:" ":SUBROUTINE.NAME:" for Method ":METHOD
    END

    COMPILE.SUCCESSFUL = @TRUE

    STATEMENT = COMPILE.COMMAND

* for eclipse compiles add the filename to take care of screens and things
    IF COMPILE.ECLIPSE OR COMPILE.CBP THEN
        STATEMENT<2> := " ":OBJECT.FILENAME
    END ELSE
        STATEMENT<2> := " ":TARGET.FILENAME
    END

    STATEMENT := " ":SUBROUTINE.NAME

    EXECUTE STATEMENT CAPTURING COMPILE.TEXT

    GOSUB PROCESS.COMPILE.TEXT

    GRAND.TOTAL.COMPILED += 1
    GRAND.TOTAL.LINES += SUM(CREATED.SUBROUTINE.COUNT.LIST)
    GRAND.TOTAL.BYES += SUM(CREATED.SUBROUTINE.BYTE.LIST)

    PE.DOC.LIST = SUBROUTINE.NAME
    GOSUB UPDATE.PE.DOC

    BA.END.DATE = DATE()
    BA.END.TIME = TIME()
    BA.ELAPSED.TIME += TIME.ELAPSED (BA.START.DATE, BA.START.TIME)

    RETURN

PROCESS.COMPILE.TEXT: ****************************************************
* process compiler output                                                *
**************************************************************************

* the first captured text line will just be the get-list.  delete it
* so there's less annoying stuff to look at
    DEL COMPILE.TEXT<1>
    DEL COMPILE.TEXT<1>

    COMPILE.TEXT.LINES = DCOUNT(COMPILE.TEXT, @AM)

* go through compile text and adjust any lines with program names or
* line numbers on them
    LAST.SUBROUTINE = ""
    LAST.METHOD = ""
    CREATE.PTR = ""

* printing the original line number will confuse the formatting for later
* error lines.  some use an uparrow to point at a programming problem.
* set the indent so that they will still line up
    LINE.INDENT = "    "

    IF COMPILE.OBJECT OR COMPILE.SUBROUTINE THEN
        LINE.INDENT = "         "
    END

* process each line of the captured compiled text so we can cross reference
* error lines back to the original object error lines
    IF NOT(BRIEF) THEN
        PRINT
        PRINT "Compiling:"
    END

    SETREM 0 ON COMPILE.TEXT

    FOR COMPILE.LOOP = 1 TO COMPILE.TEXT.LINES
        REMOVE THIS.LINE FROM COMPILE.TEXT SETTING THROWAWAY
        GOSUB PROCESS.COMPILE.LINE
    NEXT COMPILE.LOOP

* print a summary of compile errors and warnings
    IF TOTAL.COMPILE.ERRORS = 0 AND TOTAL.COMPILE.WARNINGS = 0 AND TOTAL.OBJECT.ERRORS = 0 THEN

        IF NOT(COMPILE.OBJECT) THEN

            IF OBJECT.COUNT = 1 THEN
                SPEECH = "Compile successful"
                GOSUB MAYBE.WAIT.AND.SPEAK
            END

            IF NOT(BRIEF) THEN
                PRINT
            END

        END

        COMPILE.SUCCESSFUL = @TRUE

    END ELSE

        IF COMPILE.OBJECT THEN

            PRINT "        ":ERROR.SUBROUTINE.COUNT:" Method":
            IF ERROR.SUBROUTINE.COUNT <> 1 THEN
                PRINT "s":
            END
            PRINT " had errors:"
            PRINT

            FOR SUB.LOOP = 1 TO ERROR.SUBROUTINE.COUNT

                DISPLAY.METHOD = ERROR.METHOD.LIST<SUB.LOOP>
                IF UPCASE.CODE THEN
                    DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
                END

                COMPILING.TEXT = "    ":DISPLAY.METHOD
                IF DISPLAY.COMPILE.CBP.NAME THEN
                    COMPILING.TEXT := " -> [":TARGET.FILENAME:" ":ERROR.SUBROUTINE.LIST<SUB.LOOP>:"]"
                END
                GOSUB DISPLAY.COMPILING

            NEXT SUB.LOOP

            SPEECH = ERROR.SUBROUTINE.COUNT:" method"
            IF ERROR.SUBROUTINE.COUNT <> 1 THEN
                SPEECH := "s"
            END
            SPEECH := " had errors"
            GOSUB WAIT.AND.SPEAK

            PRINT

        END ELSE

            IF NOT(BRIEF) THEN
                PRINT
            END

        END

        IF TOTAL.OBJECT.ERRORS <> 0 THEN
            PRINT TOTAL.OBJECT.ERRORS:" Object Error":
            IF TOTAL.OBJECT.ERRORS <> 1 THEN
                PRINT "s":
            END
            PRINT
        END

        IF TOTAL.COMPILE.ERRORS <> 0 THEN
            PRINT TOTAL.COMPILE.ERRORS:" Error":
            IF TOTAL.COMPILE.ERRORS <> 1 THEN
                PRINT "s":
            END
            PRINT
        END

        IF TOTAL.COMPILE.WARNINGS <> 0 THEN
            PRINT TOTAL.COMPILE.WARNINGS:" Warning":
            IF TOTAL.COMPILE.WARNINGS <> 1 THEN
                PRINT "s":
            END
            PRINT
        END

        COMPILE.SUCCESSFUL = @FALSE

        GOSUB SHOW.ERROR.TABLE

    END

    RETURN

PROCESS.COMPILE.LINE: ****************************************************
* process a compiler line and watch for errors                           *
**************************************************************************

* some lines have a clear screen right before the error listing.  if
* there's a clear screen in this.line remove everything on it and before
    IF COUNT(THIS.LINE,CHAR(12)) <> 0 THEN
        THIS.LINE = THIS.LINE [CHAR(12), 2, TO.THE.END]
    END

    FIRST.WORD = THIS.LINE [" ", 1, 1]
    NEXT.WORD = THIS.LINE [" ", 2, 1]
    TRIM.THIS.LINE = TRIM(THIS.LINE)

* ignore empty lines
    IF TRIM.THIS.LINE = "" THEN
        RETURN
    END

* if this compiler message line is in the list of ignored compile warnings
* ignore it
    LOCATE THIS.LINE IN IGNORED.COMPILE.WARNINGS SETTING IGNORE.PTR THEN
        RETURN
    END

* process the compiler message line
    BEGIN CASE

* program compiled correctly
        CASE TRIM.THIS.LINE = "Compilation Complete."
            IF NOT(BRIEF) THEN
                IF COMPILE.CBP OR COMPILE.CORE THEN
                    PRINT "   ":
                END
                PRINT LINE.INDENT:"Compile Successful."
            END

* "cataloged" line
        CASE INDEX(THIS.LINE, "cataloged", 1) > 0
            IF NOT(BRIEF) AND SHOW.CATALOGED.MESSAGE THEN
                IF COMPILE.CBP OR COMPILE.CORE THEN
                    PRINT "    ":
                END
                PRINT LINE.INDENT:THIS.LINE
            END

* core dump lines.  universe's compile has been core-dumping lately
* rather than displaying some errors
        CASE INDEX(THIS.LINE, "Fault type", 1) > 0

            IF NOT(BRIEF) THEN
                IF COMPILE.CBP OR COMPILE.CORE THEN
                    PRINT "    ":
                END
                PRINT LINE.INDENT:THIS.LINE
            END

            TOTAL.COMPILE.ERRORS += 1

*     update error table
            ERROR.SUBROUTINE = LAST.SUBROUTINE
            ERROR.METHOD = LAST.METHOD
            ERROR.SOURCE.LINE = ""
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = THIS.LINE
            GOSUB ADD.ERROR

            GOSUB ADD.BAD.SUBROUTINE

* is this line listing a subroutine name?  if so update our pointer to
* the method creation list and print a line for the method
        CASE FIRST.WORD "R#3" = "CBP"

            LOCATE NEXT.WORD IN CREATED.SUBROUTINE.LIST SETTING CREATE.PTR THEN

                LAST.SUBROUTINE = NEXT.WORD
                LAST.METHOD = CREATED.METHOD.LIST<CREATE.PTR>

                LAST.METHOD.START = CREATED.SOURCE.START.LIST<CREATE.PTR>
                LAST.SUBROUTINE.START = CREATED.TARGET.START.LIST<CREATE.PTR>
                LAST.METHOD.LINES = CREATED.SOURCE.COUNT.LIST<CREATE.PTR>

                LAST.COMMON.METHOD.START = CREATED.SOURCE.COMMON.START.LIST<CREATE.PTR>
                LAST.COMMON.SUBROUTINE.START = CREATED.TARGET.COMMON.START.LIST<CREATE.PTR>
                LAST.COMMON.LINES = CREATED.SOURCE.COMMON.COUNT.LIST<CREATE.PTR>

                LAST.SUBROUTINE.LINES = CREATED.SUBROUTINE.COUNT.LIST<CREATE.PTR>
                LAST.SUBROUTINE.BYTES = CREATED.SUBROUTINE.BYTE.LIST<CREATE.PTR>

                PROGRAM.CODE.SOURCE.LIST = RAISE(CREATED.METHOD.SOURCE.LIST<CREATE.PTR>)
                PROGRAM.CODE.FINAL.LIST = RAISE(CREATED.METHOD.FINAL.LIST<CREATE.PTR>)

* if we're compiling a cbp program tell where it came from
                BEGIN CASE

                    CASE BRIEF
                        NULL

                    CASE COMPILE.OBJECT
                        DISPLAY.METHOD = OBJECT.NAME:METHOD.DELIMITER:LAST.METHOD
                        IF UPCASE.CODE THEN
                            DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
                        END

*                       PRINT "    ":DISPLAY.METHOD:" -> CBP ":LAST.SUBROUTINE:":"
                        PRINT "    CBP ":LAST.SUBROUTINE:":"

                        IF SHOW.LINE.COUNTS THEN
                            PRINT LINE.INDENT:LAST.SUBROUTINE.LINES "L,":" lines, ":
                            PRINT LAST.SUBROUTINE.BYTES "L,":" bytes"
                        END

                    CASE COMPILE.SUBROUTINE
                        DISPLAY.METHOD = LAST.SUBROUTINE
                        IF UPCASE.CODE THEN
                            DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
                        END

*                       PRINT "    OBP ":DISPLAY.METHOD:" -> CBP ":LAST.SUBROUTINE:":"
                        PRINT "    CBP ":LAST.SUBROUTINE:":"

                        IF SHOW.LINE.COUNTS THEN
                            PRINT LINE.INDENT:LAST.SUBROUTINE.LINES "L,":" lines, ":
                            PRINT LAST.SUBROUTINE.BYTES "L,":" bytes"
                        END

                    CASE COMPILE.CBP
                        PRINT "    CBP ":LAST.SUBROUTINE:":"

                        IF SHOW.LINE.COUNTS THEN
                            PRINT LINE.INDENT:LAST.SUBROUTINE.LINES "L,":" lines, ":
                            PRINT LAST.SUBROUTINE.BYTES "L,":" bytes"
                        END

                END CASE

*               IF NOT(BRIEF) THEN
*                   PRINT
*               END

            END

* line has "Errors detected" in it.  this gives us the total errors in
* the compilation.  there may be errors in here that we haven't seen
* yet since not every error produces a program line number.  we can't
* display the error line number but we can at least make sure our
* error count is correct
        CASE INDEX(THIS.LINE, "Errors detected",1) > 0

            ERRORS.DETECTED = THIS.LINE [" ", 1, 1]
            IF TOTAL.COMPILE.ERRORS < ERRORS.DETECTED THEN
                TOTAL.COMPILE.ERRORS = ERRORS.DETECTED
            END

            GOSUB ADD.BAD.SUBROUTINE

* compile line starts with a warning
        CASE FIRST.WORD = "WARNING:"

            TOTAL.COMPILE.WARNINGS += 1
            PRINT LINE.INDENT:THIS.LINE

*     update error table
            ERROR.SUBROUTINE = LAST.SUBROUTINE
            ERROR.METHOD = LAST.METHOD
            ERROR.SOURCE.LINE = ""
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = THIS.LINE
            GOSUB ADD.ERROR

            GOSUB ADD.BAD.SUBROUTINE

* does this line start with a six digit numeric?  If so it's listing a
* program line.  update the line to show the original program line with
* the subroutine line in parenthesis
        CASE LEN(FIRST.WORD) = 6 AND NUM(FIRST.WORD)

            ECLIPSE.SUBROUTINE.LINE = FIRST.WORD + 0
            GOSUB CONVERT.ECLIPSE.LINE

            TOTAL.COMPILE.ERRORS += 1

* print the object's line number
            PRINT CONVERTED.LINE "R%6":

* print the original (the eclipse subroutine) line number
            PRINT " [":ECLIPSE.SUBROUTINE.LINE "R%6":"] ":

* print the rest of the program line
            PRINT THIS.LINE [" ", 2, TO.THE.END]

* update error table
            ERROR.SUBROUTINE = LAST.SUBROUTINE
            ERROR.METHOD = LAST.METHOD
            ERROR.SOURCE.LINE = CONVERTED.LINE
            ERROR.ECLIPSE.LINE = ECLIPSE.SUBROUTINE.LINE
            ERROR.DESC = THIS.LINE [" ", 2, TO.THE.END]
            GOSUB ADD.ERROR

            GOSUB ADD.BAD.SUBROUTINE

* anything else, assume it's a program error without a program line
        CASE 1

* update error table
            ERROR.SUBROUTINE = LAST.SUBROUTINE
            ERROR.METHOD = LAST.METHOD
            ERROR.SOURCE.LINE = ""
            ERROR.ECLIPSE.LINE = ""
            ERROR.DESC = THIS.LINE
            GOSUB ADD.ERROR

            IF COMPILE.CBP OR COMPILE.CORE THEN
                PRINT "    ":
            END

            PRINT LINE.INDENT:THIS.LINE

            GOSUB ADD.BAD.SUBROUTINE

    END CASE

    RETURN

ADD.BAD.SUBROUTINE: ******************************************************
* add error.subroutine to bad.subroutine.list                            *
**************************************************************************
    IF ERROR.SUBROUTINE = "" THEN
        RETURN
    END

    LOCATE ERROR.SUBROUTINE IN BAD.SUBROUTINE.LIST BY "AL" SETTING BAD.PTR THEN
        RETURN
    END

    INS ERROR.SUBROUTINE BEFORE BAD.SUBROUTINE.LIST<BAD.PTR>
    BAD.SUBROUTINE.COUNT += 1

    RETURN

CONVERT.ECLIPSE.LINE: ****************************************************
* convert an "eclipse" line number back to the "source" (in the object   *
* code) line number.  needs eclipse.subroutine.line, returns             *
* converted.line                                                         *
**************************************************************************
    METHOD.LINE = ""
    COMMON.LINE = ""
    CONVERTED.LINE = "******"

* eclipse.subroutine.line is the line number in the eclipse subroutine
* that bombed.  if we're converting unresolved references this line
* number may not match the line number in the original object or
* object-enabled program as fixing the unresolved references can insert
* new program lines into the eclipse subroutine that aren't in the
* original object or object-enabled program.

* first, convert the eclipse subroutine line into the line number in the
* original object or object-enabled program
    LOCATE ECLIPSE.SUBROUTINE.LINE IN PROGRAM.CODE.FINAL.LIST SETTING ECLIPSE.CODE.PTR ELSE
        NULL
    END

    THIS.SOURCE.LINE = PROGRAM.CODE.SOURCE.LIST<ECLIPSE.CODE.PTR>
    CONVERTED.LINE = THIS.SOURCE.LINE

    RETURN

PRINT.ALL.COMPILED.LIST: *************************************************
* print a list of all methods to compile for debugging                   *
**************************************************************************
    PRINT
    PRINT "Compiling all Methods"
    PRINT
    PRINT "Method......... Subroutine.................... Source Target Lines."

    FOR COMPILE.LOOP = 1 TO CREATED.METHOD.COUNT

        PRINT CREATED.METHOD.LIST<COMPILE.LOOP> "L#15":" ":
        PRINT CREATED.SUBROUTINE.LIST<COMPILE.LOOP> "L#30":" ":
        PRINT CREATED.SOURCE.START.LIST<COMPILE.LOOP> "R#6":" ":
        PRINT CREATED.TARGET.START.LIST<COMPILE.LOOP> "R#6":" ":
        PRINT CREATED.SOURCE.COUNT.LIST<COMPILE.LOOP> "R#6"

    NEXT COMPILE.LOOP

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** eclipse / updating eclipse files                                     **
**************************************************************************
**************************************************************************

UPDATE.PE.DOC: ***********************************************************
* update eclipse's PGM.DOC file for successful compiles.  the PGM.DOC    *
* file is usually updated by the eclipse editor.  Solar uses the PGM.DOC *
* file to decide if a subroutine is available to call or not.  since the *
* object precompiler creates code without using the eclipse editor the   *
* PE.DOC file wouldn't normally be updated.                              *
**************************************************************************

* do we update the pe.doc file for this type of compile?
    BEGIN CASE

        CASE COMPILE.OBJECT AND UPDATE.PGM.DOC.OBJ
            UPDATE.PE.DOC = @TRUE
            PE.DOC.PROGRAM.FILE = TARGET.FILENAME

        CASE COMPILE.SUBROUTINE AND UPDATE.PGM.DOC.OBP
            UPDATE.PE.DOC = @TRUE
            PE.DOC.PROGRAM.FILE = TARGET.FILENAME

        CASE COMPILE.CBP AND UPDATE.PGM.DOC.CORE
            UPDATE.PE.DOC = @TRUE
            PE.DOC.PROGRAM.FILE = "CBP"

        CASE COMPILE.CORE AND UPDATE.PGM.DOC.CORE
            UPDATE.PE.DOC = @TRUE
            PE.DOC.PROGRAM.FILE = OBJECT.FILENAME

        CASE 1
            UPDATE.PE.DOC = @FALSE

    END CASE

* update pe.doc with all programs in pe.doc that aren't in bad.subroutine.list
    IF UPDATE.PE.DOC THEN

        PE.DOC.COUNT = DCOUNT(PE.DOC.LIST, @AM)
        EDIT.USER.ID = USER.ID

        FOR PE.LOOP = 1 TO PE.DOC.COUNT

            THIS.NAME = PE.DOC.LIST<PE.LOOP>
            LOCATE THIS.NAME IN BAD.SUBROUTINE.LIST SETTING BAD.PTR ELSE
                PE.UPD.PDOC PE.DOC.PROGRAM.FILE:"~":THIS.NAME, EDIT.USER.ID
            END

        NEXT PE.LOOP

    END

    RETURN


**************************************************************************
**************************************************************************
** eclipse / common variables                                           **
**************************************************************************
**************************************************************************

LIST.ECLIPSE.COMMON.VARIABLES: *******************************************
* list eclipse common variables when no object was specified to compile  *
**************************************************************************

* eclipse common variables
    PRINT
    PRINT "Eclipse Common:"
    PRINT FORMAT.ARRAY (ECLIPSE.COMMON.NAME.LIST)

* eclipse constants
    PRINT
    PRINT "Eclipse Constant:"
    PRINT FORMAT.ARRAY (EQUATE.CONSTANT.LIST)

    RETURN

BUILD.INCLUDE.TABLES: ****************************************************
* look through include.code and make a list of any included or inserted  *
* items                                                                  *
**************************************************************************
    CODE.INSERT.FILE.LIST = ""
    CODE.INSERT.ITEM.LIST = ""
    CODE.INSERT.COUNT = 0

    GOSUB SCAN.INCLUDE.CODE

* loop through code.insert.item.list and scan its code for any additional
* included items.  any that are found are added to the code.insert.item.list                                                  *
    FOR INSERT.LOOP = 1 TO CODE.INSERT.COUNT

        CC.ITEMNAME = CODE.INSERT.ITEM.LIST<INSERT.LOOP>
        READ INCLUDE.CODE FROM CC.FILE, CC.ITEMNAME ELSE
            INCLUDE.CODE = ""
        END

        GOSUB SCAN.INCLUDE.CODE

    NEXT INSERT.LOOP

    RETURN

SCAN.INCLUDE.CODE: *******************************************************
* scan through include.code and add to the list of any included or       *
* inserted items                                                         *
**************************************************************************
    INCLUDE.CODE.LINES = DCOUNT(INCLUDE.CODE, @AM)

    SETREM 0 ON INCLUDE.CODE

    FOR LINE.LOOP = 1 TO INCLUDE.CODE.LINES

*       THIS.LINE = INCLUDE.CODE<LINE.LOOP>
        REMOVE THIS.LINE FROM INCLUDE.CODE SETTING THROWAWAY

* skip any obvious code that won't have gosubs in it
        TRIM.THIS.LINE = TRIM(THIS.LINE)
        IF TRIM.THIS.LINE <> "" AND TRIM.THIS.LINE <> "*" AND TRIM.THIS.LINE <> "!" THEN

            FIRST.WORD = TRIM.THIS.LINE [" ", 1, 1]

            IF FIRST.WORD = "$INCLUDE" OR FIRST.WORD = "$INSERT" THEN

                CC.FILENAME = TRIM.THIS.LINE [" ", 2, 1]
                CC.ITEMNAME = TRIM.THIS.LINE [" ", 3, 1]

* if we're scanning an OC record it may be pointing to ad.dir.  if
* so point it back to the source
                IF CC.FILENAME = "AD.DIR" THEN
                    CC.FILENAME = CC.ITEMNAME ["~", 1, 1]
                    CC.ITEMNAME = CC.ITEMNAME ["~", 2, 1]
                END

                LOCATE CC.ITEMNAME IN CODE.INSERT.ITEM.LIST SETTING CC.PTR ELSE

                    LOCATE CC.ITEMNAME IN ECLIPSE.CC.LIST SETTING CC.PTR ELSE

                        IF CC.ITEMNAME <> "" THEN

                            CODE.INSERT.COUNT += 1

                            CODE.INSERT.FILE.LIST<CODE.INSERT.COUNT> = CC.FILENAME
                            CODE.INSERT.ITEM.LIST<CODE.INSERT.COUNT> = CC.ITEMNAME

                        END

                    END

                END

            END

        END

    NEXT LINE.LOOP

    RETURN

GET.COMPLETE.COMMON.VARIABLES: *******************************************
* starting with the default eclipse common variable and common constant  *
* tables add in any additional includes from program.code.               *
* build.include.tables should have already been called to build the      *
* insert tables                                                          *
**************************************************************************

* load the eclipse common variable and common constant tables from the
* default tables
    ECLIPSE.COMMON.NAME.LIST = DEFAULT.ECLIPSE.COMMON.NAME.LIST
    ECLIPSE.COMMON.CC.LIST = DEFAULT.ECLIPSE.COMMON.CC.LIST
    ECLIPSE.COMMON.COUNT = DEFAULT.ECLIPSE.COMMON.COUNT

    EQUATE.CONSTANT.LIST = DEFAULT.EQUATE.CONSTANT.LIST
    EQUATE.CONSTANT.COUNT = DEFAULT.EQUATE.CONSTANT.COUNT

* loop through the insert tables for this program and add in any common
* variables and constants
    FOR INSERT.LOOP = 1 TO CODE.INSERT.COUNT

        CC.ITEM = CODE.INSERT.ITEM.LIST<INSERT.LOOP>
        GOSUB LOAD.ONE.ECLIPSE.CC

    NEXT INSERT.LOOP

    RETURN

GET.ECLIPSE.COMMON.VARIABLES: ********************************************
* build a table of the eclipse common variables                          *
**************************************************************************

* initialize tables
    ECLIPSE.COMMON.NAME.LIST = ""
    ECLIPSE.COMMON.CC.LIST = ""
    ECLIPSE.COMMON.COUNT = 0

    EQUATE.CONSTANT.LIST = ""
    EQUATE.CONSTANT.COUNT = 0

* basic function names
    BASIC.FUNCTION.NAME.LIST = CHANGE("CHAR,CHARS,DCOUNT,SEQ,ASCII", ",", @AM)
    BASIC.FUNCTION.NAME.COUNT = DCOUNT(BASIC.FUNCTION.NAME.LIST, @AM)

* open the "cc" file
    UT.OPEN.FILE ECLIPSE.CC.FILE, CC.FILE, CC.OPEN.ERROR, 1
    IF CC.OPEN.ERROR <> "" THEN
        RETURN
    END

    FOR CC.PROGRAM.LOOP = 1 TO ECLIPSE.CC.COUNT
        CC.ITEM = ECLIPSE.CC.LIST<CC.PROGRAM.LOOP>
        GOSUB LOAD.ONE.ECLIPSE.CC
    NEXT CC.PROGRAM.LOOP

* save these tables as default common variable tables
    DEFAULT.ECLIPSE.COMMON.NAME.LIST = ECLIPSE.COMMON.NAME.LIST
    DEFAULT.ECLIPSE.COMMON.CC.LIST = ECLIPSE.COMMON.CC.LIST
    DEFAULT.ECLIPSE.COMMON.COUNT = ECLIPSE.COMMON.COUNT

    DEFAULT.EQUATE.CONSTANT.LIST = EQUATE.CONSTANT.LIST
    DEFAULT.EQUATE.CONSTANT.COUNT = EQUATE.CONSTANT.COUNT

    RETURN

LOAD.ONE.ECLIPSE.CC: *****************************************************
* load variables from cc.item into the eclipse common tables             *
**************************************************************************
    READ CC.RECORD FROM CC.FILE, CC.ITEM ELSE
        CC.RECORD = ""
    END
    CC.COUNT = DCOUNT(CC.RECORD, @AM)

    SETREM 0 ON CC.RECORD
    FOR CC.LOOP = 1 TO CC.COUNT

*       THIS.CC = CC.RECORD<CC.LOOP>
        REMOVE THIS.CC FROM CC.RECORD SETTING CC.PTR

        THIS.CC = TRIM(THIS.CC)

        FIRST.WORD = THIS.CC [" ", 1, 1]

        BEGIN CASE

* equates
            CASE FIRST.WORD = "EQU" OR FIRST.WORD = "EQUATE"
                GOSUB ADD.ECLIPSE.EQUATE.LINE

* commons
            CASE FIRST.WORD = "COMMON"
                GOSUB ADD.ECLIPSE.COMMON.LINE

        END CASE

    NEXT CC.LOOP

    RETURN

ADD.ECLIPSE.EQUATE.LINE: *************************************************
* process this.cc as an equate line                                      *
**************************************************************************

* remove "equate"
    THIS.CC = TRIM(THIS.CC [" ", 2, TO.THE.END])

* the next word may be to create a named common block.  if so remove
* it from the line
    TEST.NAMED = THIS.CC [" ", 1, 1]

    IF TEST.NAMED [1, 1] = "/" AND TEST.NAMED [1] = "/" THEN
        THIS.CC = THIS.CC [" ", 2, TO.THE.END]
    END

    THIS.CC.LEN = LEN(THIS.CC)

* convert any commas that aren't inside quotes or parenthesis into
* ams
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""
    PREN.DEPTH = 0
    ARRAY.DEPTH = 0

    FOR CHAR.PTR = 1 TO THIS.CC.LEN

        THIS.CHAR = THIS.CC [CHAR.PTR, 1]
        BEGIN CASE

* quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR
            
* parenthesis
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH < 0 THEN
                    PREN.DEPTH = 0
                END

* dynamic array
            CASE THIS.CHAR = "<"
                ARRAY.DEPTH += 1
            CASE THIS.CHAR = ">"
                ARRAY.DEPTH -= 1
                IF ARRAY.DEPTH < 0 THEN
                    ARRAY.DEPTH = 0
                END

* hit a comma, not in any quotes or parenthesis or dynamic array references
            CASE NOT(IN.QUOTES) AND PREN.DEPTH = 0 AND ARRAY.DEPTH = 0 AND THIS.CHAR = ","
                THIS.CC [CHAR.PTR, 1] = @AM

        END CASE

    NEXT CHAR.PTR

* see how many commas are there for multiple equate expressions
    EQUATE.COUNT = DCOUNT(THIS.CC, @AM)

    FOR EQUATE.LOOP = 1 TO EQUATE.COUNT

        THIS.EQUATE = TRIM(THIS.CC<EQUATE.LOOP>)

* check the variable after the "to" if it's a variable.  if it's not a
* variable don't add anything to the common table.  it's really a
* constant so we'll add it to the equate constant table
        EQUATE.VARIABLE = THIS.EQUATE [" ", 1, 1] ["(", 1, 1] ["<", 1, 1]
        EQUATE.TO.VARIABLE = THIS.EQUATE [" ", 3, 1] ["(", 1, 1] ["<", 1, 1]

        IS.EQUATE.TO.VARIABLE = IS.VARIABLE(EQUATE.TO.VARIABLE)

* some functions will look like a variable (CHAR, for example) but they're
* really constants.  if this "equate to variable" is one of them it's not
* a variable
        LOCATE EQUATE.TO.VARIABLE IN BASIC.FUNCTION.NAME.LIST SETTING FOUND.PTR THEN
            IS.EQUATE.TO.VARIABLE = @FALSE
        END

        IF IS.EQUATE.TO.VARIABLE THEN

* add the variable after the "to"
            CC.VARIABLE = EQUATE.TO.VARIABLE
            GOSUB ADD.ECLIPSE.COMMON.VARIABLE

* check the variable after the equate, before the "to"
            CC.VARIABLE = EQUATE.VARIABLE
            GOSUB ADD.ECLIPSE.COMMON.VARIABLE

        END ELSE

* add the variable after the equate, before the "to", to the constant
* table
            CC.VARIABLE = EQUATE.VARIABLE
            GOSUB ADD.EQUATE.CONSTANT            

        END

    NEXT EQUATE.LOOP

    RETURN

ADD.ECLIPSE.COMMON.LINE: *************************************************
* process this.cc as a common line                                       *
**************************************************************************

* remove the "common"
    THIS.CC = THIS.CC [" ", 2, TO.THE.END]

* if the first word in the common line is a common workspace name remove
* it as well
    FIRST.WORD = THIS.CC [" ", 1, 1]

    IF FIRST.WORD [1, 1] = "/" THEN
        THIS.CC = THIS.CC [" ", 2, TO.THE.END]
    END

* get a count of variables on the common line
    WORD.COUNT = DCOUNT(THIS.CC, ",")

    FOR WORD.LOOP = 1 TO WORD.COUNT

        CC.VARIABLE = TRIM(THIS.CC [",", WORD.LOOP, 1] ["(", 1, 1])
        GOSUB ADD.ECLIPSE.COMMON.VARIABLE

    NEXT WORD.LOOP

    RETURN

ADD.ECLIPSE.COMMON.VARIABLE: *********************************************
* add cc.variable to the eclipse common list                             *
**************************************************************************
    LOCATE CC.VARIABLE IN ECLIPSE.COMMON.NAME.LIST BY "AL" SETTING FOUND.PTR ELSE

        ECLIPSE.COMMON.COUNT += 1
        
        INS CC.VARIABLE BEFORE ECLIPSE.COMMON.NAME.LIST<FOUND.PTR>
        INS CC.ITEM BEFORE ECLIPSE.COMMON.CC.LIST<FOUND.PTR>

    END

    RETURN

ADD.EQUATE.CONSTANT: *****************************************************
* add cc.variable to the equate common list                              *
**************************************************************************
    LOCATE CC.VARIABLE IN EQUATE.CONSTANT.LIST BY "AL" SETTING FOUND.PTR ELSE

        EQUATE.CONSTANT.COUNT += 1

        INS CC.VARIABLE BEFORE EQUATE.CONSTANT.LIST<FOUND.PTR>

    END

    RETURN

CHECK.ECLIPSE.COMMON: ****************************************************
* check check.variable to see if it's an eclipse common variable name.   *
* if so show a compile warning                                           *
**************************************************************************
    IF CHECK.VARIABLE = "" THEN
        RETURN
    END

    LOCATE CHECK.VARIABLE IN ECLIPSE.COMMON.NAME.LIST SETTING ECLIPSE.PTR ELSE
        RETURN
    END

* we found this.variable in the eclipse common list.  throw up a warning
    OBJECT.WARNING.DESC = CHECK.TYPE:' "':CHECK.VARIABLE:'" is an Eclipse common variable.'
    OBJECT.WARNING.LINE = CHECK.LINE
    GOSUB PRINT.OBJECT.WARNING

    RETURN

CHECK.EQUATE.CONSTANT: ***************************************************
* check check.variable to see if it's a constant via an equate           *
* returns check.constant true if it is                                   *
**************************************************************************
    EQUATE.CONSTANT = @FALSE

    LOCATE CHECK.VARIABLE IN EQUATE.CONSTANT.LIST SETTING FOUND.PTR THEN
        EQUATE.CONSTANT = @TRUE
    END

* some variables will always be considered constants
    BEGIN CASE

        CASE EQUATE.CONSTANT
            NULL

        CASE CHECK.VARIABLE = "VOID"
            EQUATE.CONSTANT = @TRUE

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** code splitting                                                       **
**************************************************************************
**************************************************************************

INITIALIZE.CODE.SPLITTING: ***********************************************
* initialize flags for code splitting                                    *
**************************************************************************
    IF NOT(CODE.SPLITTING.ENABLED) THEN
        RETURN
    END

* try to open the ud.object.splitting file.  if it doesn't exist we'll
* shut off any code splitting
    OPEN "UD.OBJECT.SPLIT" TO SPLITFILE ELSE
        CODE.SPLITTING.ENABLED = @FALSE
        RETURN
    END

* if we don't have a suffix to use for creating spit code subroutines
* shut off code splitting
    IF SPLIT.SUFFIX = "" THEN
        CODE.SPLITTING.ENABLED = @FALSE
        RETURN
    END
        
    RETURN

CHECK.METHOD.SPLIT: ******************************************************
* check whether an object / method has been split                        *
**************************************************************************
    IS.SPLIT = @FALSE

    SPLIT.CODE.FILE.NAME = ""
    SPLIT.ID = ""
    SPLIT.RECORD = ""

    SPLIT.USER.ID = ""
    SPLIT.USER.NAME = ""

    IF NOT (CODE.SPLITTING.ENABLED) THEN
        RETURN
    END

* if there's no record in ud.object.split then this object / method isn't
* spit
    SPLIT.ID = UPCASE (OBJECT.NAME):METHOD.DELIMITER:UPCASE (METHOD)
    READ SPLIT.RECORD FROM SPLITFILE, SPLIT.ID ELSE
        SPLIT.RECORD = ""
        RETURN
    END

    SPLIT.USER.ID = SPLIT.RECORD<1>
    SPLIT.USER.NAME = SPLIT.RECORD<3>
    SPLIT.CODE.FILE.NAME = SPLIT.RECORD<13>

* open the private file for this code
    IF SPLIT.CODE.FILE.NAME = "" THEN
        RETURN
    END

    OPEN SPLIT.CODE.FILE.NAME TO SPLITCODEFILE ELSE
        SPLIT.CODE.FILE.NAME = ""
        SPLIT.RECORD = ""
        RETURN
    END

* the private code file opened properly
    IS.SPLIT = @TRUE

    RETURN

CHECK.SUBROUTINE.SPLIT: **************************************************
* check whether an object-enabled subroutine has been split              *
**************************************************************************
    IS.SPLIT = @FALSE

    SPLIT.CODE.FILE.NAME = ""
    SPLIT.ID = ""
    SPLIT.RECORD = ""

    SPLIT.USER.ID = ""
    SPLIT.USER.NAME = ""

    IF NOT (CODE.SPLITTING.ENABLED) THEN
        RETURN
    END

* if there's no record in ud.object.split then this object / method isn't
* spit
    SPLIT.ID = UPCASE (SUBROUTINE.CALL.KEYWORD):METHOD.DELIMITER:UPCASE (SUBROUTINE.NAME)
    READ SPLIT.RECORD FROM SPLITFILE, SPLIT.ID ELSE
        SPLIT.RECORD = ""
        RETURN
    END

    SPLIT.USER.ID = SPLIT.RECORD<1>
    SPLIT.USER.NAME = SPLIT.RECORD<3>
    SPLIT.CODE.FILE.NAME = SPLIT.RECORD<13>

* open the private file for this code
    IF SPLIT.CODE.FILE.NAME = "" THEN
        RETURN
    END

    OPEN SPLIT.CODE.FILE.NAME TO SPLITCODEFILE ELSE
        SPLIT.CODE.FILE.NAME = ""
        SPLIT.RECORD = ""
        RETURN
    END

* the private code file opened properly
    IS.SPLIT = @TRUE

    RETURN

ADD.METHOD.SPLITTING.CODE: ***********************************************
* add splitting code to the object currently being built.                *
* check.method.split should have already been called                     *
**************************************************************************
    IF NOT (IS.SPLIT) THEN
        RETURN
    END

    IF SPLIT.CHECK.SUBROUTINE = "" THEN
        RETURN
    END

* build the call to the split code.  first get the subroutine definition line
* for this routine.  extract the subroutine name and parameter list
    DEFINITION.LINE = TRIM (PROGRAM.CODE<1>, " ", "B")

    THIS.SUBROUTINE.NAME = TRIM(DEFINITION.LINE [" ", 2, 1] ["(", 1, 1])

    OPEN.PREN.PTR = INDEX (DEFINITION.LINE, "(", 1)

    IF OPEN.PREN.PTR < 1 THEN
        SPLIT.PARAMETER.LIST = ""
    END ELSE
        SPLIT.PARAMETER.LIST = DEFINITION.LINE [OPEN.PREN.PTR, TO.THE.END]
        SPLIT.PARAMETER.LIST = TRIM(SPLIT.PARAMETER.LIST, " ", "B")
    END

* if there are parenthesis around the parameter list remove them
    IF SPLIT.PARAMETER.LIST [1, 1] = "(" AND SPLIT.PARAMETER.LIST [1] = ")" THEN
        SPLIT.PARAMETER.LIST = " ":SPLIT.PARAMETER.LIST [2, LEN(SPLIT.PARAMETER.LIST) - 2]
    END

    CODE = BEFORE.SPLIT.CODE
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* this routine was split by ":SPLIT.USER.NAME:" (":SPLIT.USER.ID:")"
    GOSUB ADD.CODE
    CODE = "    ":SPLIT.CHECK.SUBROUTINE:" RUN.SPLIT.CODE, ":'"':OBJECT.NAME:'", "':METHOD:'"'
    GOSUB ADD.CODE
    CODE = "    IF RUN.SPLIT.CODE THEN"
    GOSUB ADD.CODE

    CODE = "        ":THIS.SUBROUTINE.NAME:SPLIT.SUFFIX:SPLIT.PARAMETER.LIST
    GOSUB ADD.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE

    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = AFTER.SPLIT.CODE
    GOSUB ADD.CODE

    RETURN

ADD.SUBROUTINE.SPLITTING.CODE: *******************************************
* add splitting code to the object-enabled subroutine currently being    *
* built.  check.subroutine.split should have already been called         *
**************************************************************************
    IF NOT (IS.SPLIT) THEN
        RETURN
    END

    IF SPLIT.CHECK.SUBROUTINE = "" THEN
        RETURN
    END

* build the call to the split code.  first get the subroutine definition line
* for this routine.  extract the subroutine name and parameter list
    DEFINITION.LINE = TRIM (PROGRAM.CODE<1>, " ", "B")

    THIS.SUBROUTINE.NAME = TRIM(DEFINITION.LINE [" ", 2, 1] ["(", 1, 1])

    OPEN.PREN.PTR = INDEX (DEFINITION.LINE, "(", 1)

    IF OPEN.PREN.PTR < 1 THEN
        SPLIT.PARAMETER.LIST = ""
    END ELSE
        SPLIT.PARAMETER.LIST = DEFINITION.LINE [OPEN.PREN.PTR, TO.THE.END]
        SPLIT.PARAMETER.LIST = TRIM(SPLIT.PARAMETER.LIST, " ", "B")
    END

* if there are parenthesis around the parameter list remove them
    IF SPLIT.PARAMETER.LIST [1, 1] = "(" AND SPLIT.PARAMETER.LIST [1] = ")" THEN
        SPLIT.PARAMETER.LIST = " ":SPLIT.PARAMETER.LIST [2, LEN(SPLIT.PARAMETER.LIST) - 2]
    END

    INSERT.LINE = 2
    PROGRAM.CODE.INDENT = ""

    CODE = BEFORE.SPLIT.CODE
    GOSUB INSERT.CODE
    CODE = " "
    GOSUB INSERT.CODE
    CODE = "* this routine was split by ":SPLIT.USER.NAME:" (":SPLIT.USER.ID:")"
    GOSUB INSERT.CODE
    CODE = "    ":SPLIT.CHECK.SUBROUTINE:" RUN.SPLIT.CODE, ":'"':UPCASE (SUBROUTINE.CALL.KEYWORD):'", "':UPCASE (SUBROUTINE.NAME):'"'
    GOSUB INSERT.CODE
    CODE = "    IF RUN.SPLIT.CODE THEN"
    GOSUB INSERT.CODE

    CODE = "        ":SUBROUTINE.NAME:SPLIT.SUFFIX:SPLIT.PARAMETER.LIST
    GOSUB INSERT.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB INSERT.CODE

    CODE = "    END"
    GOSUB INSERT.CODE

    CODE = " "
    GOSUB INSERT.CODE
    CODE = AFTER.SPLIT.CODE
    GOSUB INSERT.CODE

    RETURN

CREATE.SPLIT.METHOD.VERSION: *********************************************
* save a split code version of the current method subroutine             *
**************************************************************************

* if this routine is not split clean up any previous split code
    IF NOT (IS.SPLIT) THEN
        GOSUB CLEAN.UP.SPLIT.METHOD
        RETURN
    END

* update the method and subroutines names
    METHOD := SPLIT.SUFFIX
    SUBROUTINE.NAME := SPLIT.SUFFIX

    IF NOT(BRIEF) THEN

        MAX.LENGTH = 79

        CREATE.TEXT = "    split version"
        IF DISPLAY.COMPILE.CBP.NAME THEN
            CREATE.TEXT := " -> [":TARGET.FILENAME:" ":SUBROUTINE.NAME
            IF LEN(CREATE.TEXT) > MAX.LENGTH - 1 THEN
                CREATE.TEXT = CREATE.TEXT [1, MAX.LENGTH - 4]:"..."
            END
            CREATE.TEXT := "]"
        END

        PRINT CREATE.TEXT

    END

* the pre-converted method code will have the call to the split version.
* remove this code from pre.convert.code
    GOSUB REMOVE.SPLITTING.CODE

* the original version of the method, before it was converted to eclipse-
* compatible code, is in pre.convert.code and the method creation routines
* saved the start and end of custom code in user.code.start.ptr and
* user.code.end.ptr.  from this original code extract all code lines before
* custom code and after
    SPLIT.CODE.BEFORE = PRE.CONVERT.CODE [@AM, 1, USER.CODE.START.PTR]
    SPLIT.CODE.AFTER = PRE.CONVERT.CODE [@AM, USER.CODE.END.PTR + 1, TO.THE.END]

* get the split version of the custom code for this method and convert the
* method definition to a "split" version
    GOSUB GET.SPLIT.CODE

* replace the method definition in the original code
    FIRST.LINE = SPLIT.CODE.BEFORE<1>
    GOSUB CONVERT.SPLIT.METHOD.DEFINITION

    SPLIT.CODE.BEFORE<1> = FIRST.LINE

* find the first executable code line in the split code
    PROCESS.OBJECT = @TRUE
    GOSUB FIND.SPLIT.CODE.START

    IF FIRST.CODE.LINE = 0 THEN
        RETURN
    END

* chop out all the executable code from the split method.  this skips over the
* "method" statement and any starting comments
    EXECUTABLE.SPLIT.CODE = PROGRAM.CODE [@AM, FIRST.CODE.LINE, TO.THE.END]

* build a new method with the original split code before the custom code,
* the new executable code from the split method, and finally the original
* split code after the custom code
    PROGRAM.CODE = SPLIT.CODE.BEFORE:@AM:EXECUTABLE.SPLIT.CODE:@AM:SPLIT.CODE.AFTER
    PROGRAM.CODE.LINES = DCOUNT(PROGRAM.CODE, @AM)

    GOSUB UNWRAP.LINES

    GOSUB PROCESS.OPTION.LINES

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB BUILD.LABEL.TABLE

    IF ENABLE.SHORT.GOSUBS THEN
        GOSUB CONVERT.SHORT.GOSUBS
    END

    GOSUB CONVERT.ROUTINE

* add $include statements for any inline methods
    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB SAVE.METHOD

    PERMIT.FILE = TARGET.FILENAME
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

    GOSUB UPDATE.SPLIT.COMPILE.DATE

    RETURN

CREATE.SPLIT.SUBROUTINE.VERSION: *****************************************
* save a split code version of the current object-enabled subroutine     *
**************************************************************************

* if this routine is not split clean up any previous split code
    IF NOT (IS.SPLIT) THEN
        GOSUB CLEAN.UP.SPLIT.METHOD
        RETURN
    END

* update the method and subroutines names
    SUBROUTINE.NAME := SPLIT.SUFFIX

    IF NOT(BRIEF) THEN

        MAX.LENGTH = 79

        CREATE.TEXT = "    split version"
        IF DISPLAY.COMPILE.CBP.NAME THEN
            CREATE.TEXT := " -> [":TARGET.FILENAME:" ":SUBROUTINE.NAME
            IF LEN(CREATE.TEXT) > MAX.LENGTH - 1 THEN
                CREATE.TEXT = CREATE.TEXT [1, MAX.LENGTH - 4]:"..."
            END
            CREATE.TEXT := "]"
        END

        PRINT CREATE.TEXT

    END

* the pre-converted method code will have the call to the split version.
* remove this code from pre.convert.code
    GOSUB REMOVE.SPLITTING.CODE

* the original version of the method, before it was converted to eclipse-
* compatible code, is in pre.convert.code and the method creation routines
* saved the start and end of custom code in user.code.start.ptr and
* user.code.end.ptr.  from this original code extract all code lines before
* custom code and after
    SPLIT.CODE.BEFORE = PRE.CONVERT.CODE [@AM, 1, USER.CODE.START.PTR]
    SPLIT.CODE.AFTER = PRE.CONVERT.CODE [@AM, USER.CODE.END.PTR + 1, TO.THE.END]

* get the split version of the custom code for this method and convert the
* method definition to a "split" version
    GOSUB GET.SPLIT.CODE

* replace the method definition in the original code with the converted first
* line (the "subroutine" line) from the split code.  
    FIRST.LINE = PROGRAM.CODE<1>
    GOSUB CONVERT.SPLIT.METHOD.DEFINITION

    SPLIT.CODE.BEFORE<1> = FIRST.LINE

* find the first executable code line in the split code
    PROCESS.OBJECT = @FALSE
    GOSUB FIND.SPLIT.CODE.START

    IF FIRST.CODE.LINE = 0 THEN
        RETURN
    END

* chop out all the executable code from the split method.  this skips over the
* "method" statement and any starting comments
    EXECUTABLE.SPLIT.CODE = PROGRAM.CODE [@AM, FIRST.CODE.LINE, TO.THE.END]

* build a new method with the original split code before the developer's code,
* and the new executable code from the split method.  we'll leave an extra
* blank line for the version stamp the compiler will add
    PROGRAM.CODE = SPLIT.CODE.BEFORE:@AM:@AM:EXECUTABLE.SPLIT.CODE
    PROGRAM.CODE.LINES = DCOUNT(PROGRAM.CODE, @AM)

    GOSUB UNWRAP.LINES

    GOSUB PROCESS.OPTION.LINES

    GOSUB CHECK.THROWN.ERRORS

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB BUILD.LABEL.TABLE

    IF ENABLE.SHORT.GOSUBS THEN
        GOSUB CONVERT.SHORT.GOSUBS
    END

    GOSUB BUILD.OBJECT.SUB.CODE
    GOSUB ADD.INSTANCE.CODE
    GOSUB ADD.SPECIAL.SUBROUTINE.CODE

* we don't have a method here so we'll call it "main"
    METHOD = "MAIN"

    GOSUB CONVERT.ROUTINE

    GOSUB ADD.FINAL.END

    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB SAVE.METHOD

    PERMIT.FILE = TARGET.FILENAME
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

    GOSUB UPDATE.SPLIT.COMPILE.DATE

    RETURN

GET.SPLIT.CODE: **********************************************************
* return split code in program.code.  check.method.split should have     *
* already been called                                                    *
**************************************************************************
    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    IF NOT (IS.SPLIT) THEN
        RETURN
    END

    READ PROGRAM.CODE FROM SPLITCODEFILE, SPLIT.ID ELSE
        PROGRAM.CODE = ""
    END

    PROGRAM.CODE = TRIM (PROGRAM.CODE, @AM, "B")
    PROGRAM.CODE.LINES = DCOUNT (PROGRAM.CODE, @AM)

    IF UPCASE.CODE THEN
        GOSUB UPCASE.PROGRAM.CODE
    END

    RETURN

FIND.SPLIT.CODE.START: ***************************************************
* find the first executable code line in program.code (the spit method   *
* code) and return the line number in first.code.line                    *
**************************************************************************
    FIRST.CODE.LINE = 0
    IN.METHOD.DEFINITION = @FALSE

    SETREM 0 ON PROGRAM.CODE
    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES UNTIL FIRST.CODE.LINE <> 0

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

* if we're not in a method definition check to see if this line starts one.
* if we're processing an object this means look for a method definition
* keyword.  for subroutines look for a "subroutine" statement
        IF NOT(IN.METHOD.DEFINITION) THEN

            DECODE.KEYWORD = UPCASE (TRIM(THIS.LINE) [" ", 1, 1])

            IF PROCESS.OBJECT THEN

                GOSUB IS.METHOD.KEYWORD
                IF IS.METHOD THEN
                    IN.METHOD.DEFINITION = @TRUE
                END

            END ELSE

                IF DECODE.KEYWORD = "SUBROUTINE" THEN
                    IN.METHOD.DEFINITION = @TRUE
                END

            END

        END

* if we're not in a method definition and we hit a code line then this
* is where we should start merging
        IF NOT(IN.METHOD.DEFINITION) AND TRIM(THIS.LINE) <> "" THEN
            IF IS.CODE (THIS.LINE) THEN
                FIRST.CODE.LINE = LINE.LOOP
            END
        END

* if we're in the method definition and this line wraps leave us in "method
* definition" mode for the next code line.  otherwise we're not in the method
* definition any more
        IF IN.METHOD.DEFINITION THEN

            LAST.CHAR = TRIM (THIS.LINE) [1]
            FIRST.CHAR = PROGRAM.CODE<LINE.LOOP + 1> [1, 1]

            BEGIN CASE 

                CASE FIRST.CHAR = ""
                    THIS.LINE.WRAPS = @FALSE
                CASE LAST.CHAR = ""
                    THIS.LINE.WRAPS = @FALSE

                CASE COUNT(LINE.WRAP.REMOVE.CHARACTERS, LAST.CHAR) <> 0
                    THIS.LINE.WRAPS = @TRUE
                CASE COUNT(LINE.WRAP.NEXT.CHARACTERS, FIRST.CHAR) <> 0
                    THIS.LINE.WRAPS = @TRUE

                CASE 1
                    THIS.LINE.WRAPS = @FALSE

            END CASE

            IF NOT(THIS.LINE.WRAPS) THEN
                IN.METHOD.DEFINITION = @FALSE
            END

        END

    NEXT LINE.LOOP

    RETURN

REMOVE.SPLITTING.CODE: ***************************************************
* remove splitting code from program.code                                *
**************************************************************************
    LINES.DELETED = 0

    LOCATE BEFORE.SPLIT.CODE IN PRE.CONVERT.CODE SETTING SPLIT.CODE.START.PTR ELSE
        RETURN
    END

    LOCATE AFTER.SPLIT.CODE IN PRE.CONVERT.CODE SETTING SPLIT.CODE.END.PTR ELSE
        RETURN
    END

    PRE.CONVERT.CODE = PRE.CONVERT.CODE [@AM, 1, SPLIT.CODE.START.PTR - 1]:@AM:PRE.CONVERT.CODE [@AM, SPLIT.CODE.END.PTR + 1, TO.THE.END]

    LINES.DELETED = SPLIT.CODE.END.PTR - SPLIT.CODE.START.PTR + 1
    USER.CODE.START.PTR -= LINES.DELETED
    USER.CODE.END.PTR -= LINES.DELETED

    RETURN

CONVERT.SPLIT.METHOD.DEFINITION: *****************************************
* the first line has the method name and possible the tcl name in it.    *
* append the split code suffix to each of them so we have a unqiue name  *
* for the split version of the method                                    *
**************************************************************************
    KEYWORD = TRIM (FIRST.LINE) [" ", 1, 1]

* start at the character after the first keyword
    START.PTR = INDEX (FIRST.LINE, KEYWORD, 1) + LEN (KEYWORD)

* skip over any spaces after the "method" keyword
    LOOP UNTIL FIRST.LINE [START.PTR, 1] <> " "
        START.PTR += 1
    REPEAT

* start.ptr now points at the start of the method name.  find the
* end of the method name and add the suffix there
    END.PTR = START.PTR + 1
    END.CHAR.LIST = ", (:"

    LOOP
        THIS.CHAR = FIRST.LINE [END.PTR, 1]
    UNTIL THIS.CHAR = "" OR COUNT (END.CHAR.LIST, THIS.CHAR) > 0
        END.PTR += 1
    REPEAT

* insert the split routine suffix
    FIRST.LINE = FIRST.LINE[1, END.PTR - 1]:SPLIT.SUFFIX:FIRST.LINE[END.PTR, TO.THE.END]
    END.PTR += LEN (SPLIT.SUFFIX)

* if the last character we hit was a comma then we have a second name
* in the method declaration line
    IF THIS.CHAR = "," THEN

* start at the character after the terminating character
        START.PTR = END.PTR + 1

* skip over any spaces
        LOOP
            THIS.CHAR = FIRST.LINE [START.PTR, 1]
        UNTIL THIS.CHAR <> " "
            START.PTR += 1
        REPEAT

* now we're at the start of the second identifier, probably the tcl routine
* name.  skip to the end of the identifier
        END.PTR = START.PTR + 1
        END.CHAR.LIST = " (:"

        LOOP
            THIS.CHAR = FIRST.LINE [END.PTR, 1]
        UNTIL THIS.CHAR = "" OR COUNT (END.CHAR.LIST, THIS.CHAR) > 0
            END.PTR += 1
        REPEAT

* insert the split routine suffix
        FIRST.LINE = FIRST.LINE[1, END.PTR - 1]:SPLIT.SUFFIX:FIRST.LINE[END.PTR, TO.THE.END]
        END.PTR += LEN (SPLIT.SUFFIX)

    END

    RETURN

CLEAN.UP.SPLIT.METHOD: ***************************************************
* if we're compiling an object / method or a subroutine it's possible    *
* that it was split before but isn't split now.  check to see if the     *
* split version exists in cbp.  if it does remove any split code from    *
* cbp, oc, oc.o and voc                                                  *
**************************************************************************

* check for the split subroutine in cbp.  if it's not there we don't need
* to do any cleanup
    SPLIT.SUBROUTINE.NAME = SUBROUTINE.NAME:SPLIT.SUFFIX
    READV TEST.READ FROM CBPFILE, SPLIT.SUBROUTINE.NAME, 0 ELSE
        RETURN
    END

* delete the split code
    WRITE.ERROR = @FALSE
    DELETE CBPFILE, SPLIT.SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "CBP"
        ERROR.ITEM = SPLIT.SUBROUTINE.NAME
        GOSUB DELETE.ERROR
    END

    WRITE.ERROR = @FALSE
    DELETE OCFILE, SPLIT.SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "OC"
        ERROR.ITEM = SPLIT.SUBROUTINE.NAME
        GOSUB DELETE.ERROR
    END

    WRITE.ERROR = @FALSE
    DELETE OCOFILE, SPLIT.SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "OC.O"
        ERROR.ITEM = SPLIT.SUBROUTINE.NAME
        GOSUB DELETE.ERROR
    END

    WRITE.ERROR = @FALSE
    DELETE VOC, SPLIT.SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "VOC"
        ERROR.ITEM = SPLIT.SUBROUTINE.NAME
        GOSUB DELETE.ERROR
    END

    RETURN

UPDATE.SPLIT.COMPILE.DATE: ***********************************************
* update the method's last compile date in ud.object.split.              *
* check.method.split should have already been called                     *
**************************************************************************
    IF NOT (IS.SPLIT) OR NOT (CODE.SPLITTING.ENABLED) THEN
        RETURN
    END

    READU SPLIT.RECORD FROM SPLITFILE, SPLIT.ID ELSE
        RELEASE SPLITFILE, SPLIT.ID
        RETURN
    END

    SPLIT.RECORD<7> = DATE()
    SPLIT.RECORD<8> = INT(TIME())

    WRITE.ERROR = @FALSE
    WRITE SPLIT.RECORD ON SPLITFILE, SPLIT.ID ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.OBJECT.SPLIT"
        ERROR.ITEM = SPLIT.ID
        GOSUB WRITE.ERROR
    END

    RETURN


**************************************************************************
**************************************************************************
** listings / generating                                                **
**************************************************************************
**************************************************************************

PRINT.HELP: **************************************************************
* print help text                                                        *
**************************************************************************
    HEADING "'D'                    UD.COMPILE Help                        Page 'P''L'"

    PRINT "UD.COMPILE {file} object1 {object2 {. . .}} {option1 {option2 {. . .}}}"
    PRINT
    PRINT "file:    filename for object; OBJ, OBP or CBP"
    PRINT
    PRINT "object:  program name to edit or object::method to edit a single method"
    PRINT "         * to compile all programs in a file.  filename is mandatory"
    PRINT "         *::method to compile 'method' for all objects"
    PRINT
    PRINT "options: SHORT {keystring}  short method listing for an object"
    PRINT "         LIST {keystring}   long method listing for an object"
    PRINT "         HELP               show object compiler overview"
    PRINT "         NOPAGE             no paging for listings"
    PRINT "         SHORTCUTS          list program shortcuts"
    PRINT "             BOXES          change asterisk boxes to lines"
    PRINT "             NOBOXES        don't change asterisk boxes"
    PRINT "             WIN            send listing to a viewing window"
    PRINT "             NOWIN          send all listings to the screen"
    PRINT
    PRINT "         BUILD              build routines but don't compile"
    PRINT "         NOSAVE             don't save the cbp version or compile"
    PRINT "         ALWAYS             compile all methods, even unchanged"
    PRINT "         USING obj,obj...   compile all programs that use these objects"
    PRINT "         OBJECTS            list object used but don't save/compile"
    PRINT "         DELETE             delete the cbps and ocs before compiling"
    PRINT
    PRINT "         NOADD              compile but don't add to the last pgm list"
    PRINT "         VIEW               display converted cbp code in a view-only window"
    PRINT "         SOURCE             add source code as comments in converted cbp code"
    PRINT "         BREAK              break up compound lines into single lines"
    PRINT "         LOOK               same as VIEW + SOURCE + BREAK + NOSAVE + BUILD"
    PRINT
    PRINT "         WAIT               wait after each compile"
    PRINT "         WAITERROR          wait after compile error or warning"
    PRINT "         NOWAIT             dont' wait for anything, ever.  this suppresses"
    PRINT "                            all prompts.  good for compiling in an execute"
    PRINT
    PRINT "         INEXEC             running in an execute, suppress input.  same"
    PRINT "                            as NOWAIT NOPTS REPAIR NOSPEECH NOABORT"
    PRINT
    PRINT "         OPTS               present a menu with compiler options"
    PRINT "         NOPTS              do not present a menu with compiler options"
    PRINT
    PRINT "         CTIME              display compile times"
    PRINT
    PRINT "         BRIEF              suppress most messages"
    PRINT "         DETAILS            display internal compile tables"
    PRINT
    PRINT "         REPAIR             run compiler without calling any objects"
    PRINT
    PRINT "         NOAPI              don't do any API class exports"
    PRINT "         ONLYAPI            only do the API exports, don't recompile"
    PRINT
    PRINT "         NODOT              don't do any .net class exports"
    PRINT "         ONLYDOT            only do the .net exports, don't recompile"
    PRINT "         NOJAVA             don't do any java class exports"
    PRINT "         ONLYJAVA           only do the java exports, don't recompile"
    PRINT
    PRINT "         NOSPEECH           suppress speech even if turned on"
    PRINT "         NOABORT            don't check for user abort during compilation"
    PRINT
    PRINT "         OBJECTS            output tables in an import format"
    PRINT

    RETURN

PRINT.OVERVIEW: **********************************************************
* print a compiler "overview" from the main comment block of the         *
* compiler                                                               *
**************************************************************************

* fetch the compiler source code
    READ COMPILER.SOURCE FROM CBPFILE, "UD.COMPILE" ELSE
        PRINT
        PRINT "Can't read compiler source from OBJ"
        PRINT
        RETURN
    END

* find start of main comment block
    START.PTR = 0

    FOR LINE.LOOP = 1 TO 10000 UNTIL START.PTR <> 0

        THIS.LINE = COMPILER.SOURCE<LINE.LOOP>

        IF THIS.LINE <> "" AND THIS.LINE = STR("*", LEN(THIS.LINE)) THEN
            START.PTR = LINE.LOOP
        END

    NEXT LINE.LOOP

* find end of the main comment block
    END.PTR = 0

    FOR LINE.LOOP = START.PTR + 1 TO 10000 UNTIL END.PTR <> 0
        IF COMPILER.SOURCE<LINE.LOOP> [1, 1] <> "*" THEN
            END.PTR = LINE.LOOP - 1
        END
    NEXT LINE.LOOP

* copy the comment block into a separate array so we can clean it up
    OVERVIEW.TEXT = ""
    OVERVIEW.TEXT.COUNT = 0

    FOR LINE.LOOP = START.PTR TO END.PTR
        OVERVIEW.TEXT.COUNT += 1
        OVERVIEW.TEXT<OVERVIEW.TEXT.COUNT> = COMPILER.SOURCE<LINE.LOOP>
    NEXT LINE.LOOP

* if we aren't drawing boxes trim leading and trailing asterisks from
* each line
    IF DRAW.BOXES = 0 OR NOT(SEND.TO.WINDOW) THEN

        FOR LINE.LOOP = OVERVIEW.TEXT.COUNT TO 1 STEP -1

            THIS.LINE = OVERVIEW.TEXT<LINE.LOOP>

            BEGIN CASE

* do a double-line break for comment lines with asterisks all the way
* across
                CASE THIS.LINE = STR("*", LEN(THIS.LINE))
                    OVERVIEW.TEXT<LINE.LOOP> = @AM
                    OVERVIEW.TEXT.COUNT += 1

* blank line.  don't need to to anything
                CASE TRIM(THIS.LINE) = ""
                    OVERVIEW.TEXT<LINE.LOOP> = ""

* anything else, clean up asterisks
                CASE 1
                    IF THIS.LINE [1, 2] = "* " THEN
                        THIS.LINE = THIS.LINE [3, TO.THE.END]
                    END

                    THIS.LINE = TRIM(THIS.LINE, " ", "T")
                    THIS.LINE = TRIM(THIS.LINE, "*", "T")
                    THIS.LINE = TRIM(THIS.LINE, " ", "T")
                    OVERVIEW.TEXT<LINE.LOOP> = THIS.LINE

            END CASE

        NEXT LINE.LOOP

    END

* if we're not sending to a window do headings and display the comment
* block.  otherwise send off to
    IF SEND.TO.WINDOW THEN

        UD.VIEW.TEXT OVERVIEW.TEXT, 0, 0, "Compiler", "Overview", DRAW.BOXES

    END ELSE

        HEADING "                          Object Compiler Overview                   Page 'P' 'L'"

        FOR LINE.LOOP = 1 TO OVERVIEW.TEXT.COUNT
            PRINT OVERVIEW.TEXT<LINE.LOOP>
        NEXT LINE.LOOP

    END

    RETURN

LIST.METHODS: ************************************************************
* list methods / properties / etc in an object                           *
**************************************************************************
    LABELS.OUTSIDE.BOX = @FALSE

    OUT.BUFFER = ""
    OUT.BUFFER.COUNT = 0

* set widths for display / display columns.  if sending to a view-only window
* we have more room so we'll make the sizes larger
    IF SEND.TO.WINDOW THEN
        INDENT = WINDOW.NAME.WIDTH
        BOX.WIDTH = WINDOW.BOX.WIDTH
    END ELSE
        INDENT = SCREEN.NAME.WIDTH
        BOX.WIDTH = SCREEN.BOX.WIDTH
    END

    INDENT.MASK = "L#":INDENT
    BOX.MASK = "L#":(BOX.WIDTH - 4)

    PAD.BOX = @TRUE

* build tables and common code
    PROPERTY.LINE.LIST = ""
    PROPERTY.TYPE.LIST = ""
    PROPERTY.LINE.COUNT = 0

    UPDATE.COMMENT.TABLE = @TRUE
    GOSUB BUILD.PROPERTY.LIST
    GOSUB BUILD.CONSTANT.LIST
    GOSUB BUILD.CHILD.LIST
    GOSUB BUILD.SHARED.COMMON.CODE
    GOSUB BUILD.METHOD.LIST
    GOSUB BUILD.COMPILE.TABLE

* build the listing object name
    IF LIST.DOT THEN

        LIST.OBJECT.NAME = DOT.NET (OBJECT.NAME, "", "")
        LIST.LONG.OBJECT.NAME = LIST.OBJECT.NAME

    END ELSE

        LIST.OBJECT.NAME = OBJECT.NAME
        LIST.LONG.OBJECT.NAME = OBJECT.FILENAME:" ":OBJECT.NAME

        IF DOWNCASE.METHODS THEN
            LIST.OBJECT.NAME = DOWNCASE(LIST.OBJECT.NAME)
            LIST.LONG.OBJECT.NAME = DOWNCASE(LIST.LONG.OBJECT.NAME)
        END

    END

* pretty heading
    IF PAGING AND NOT(SEND.TO.WINDOW) THEN

        BEGIN CASE
            CASE LIST.DOT AND SHORT.LIST
                TITLE = "Short Dotnet Object Listing "
            CASE LIST.DOT
                TITLE = "Dotnet Object Listing"
            CASE SHORT.LIST
                TITLE = "Short Object Listing "
            CASE 1
                TITLE = "Object Listing"
        END CASE

        TITLE = TITLE "L#68":"Page 'P'"
        TITLE [40 - LEN(LIST.OBJECT.NAME) / 2, LEN(LIST.OBJECT.NAME)] = LIST.OBJECT.NAME
        TITLE := "'L'"

        HEADING TITLE

    END

* display the object name we're listing
    IF SEND.TO.WINDOW AND BANNER.NAMES AND COMPILE.OBJECT THEN
        BANNER.TEXT = LIST.OBJECT.NAME:" Object:"
        GOSUB BANNER.TEXT
    END

* add the object name to the listing?
    BEGIN CASE

* display labels outside of the box
        CASE LABELS.OUTSIDE.BOX AND SEND.TO.WINDOW
            ADD.HEADING = @TRUE
        CASE LABELS.OUTSIDE.BOX AND SHORT.LIST
            ADD.HEADING = @FALSE
        CASE LABELS.OUTSIDE.BOX
            ADD.HEADING = @TRUE

* we're doing a short list and sending it to a viewing window
        CASE SHORT.LIST AND SEND.TO.WINDOW
            ADD.HEADING = @TRUE

* for anything else skip the object name
        CASE 1
            ADD.HEADING = @FALSE

    END CASE

    IF ADD.HEADING THEN

        BEGIN CASE
            CASE COMPILE.OBJECT AND SHORT.LIST AND SEND.TO.WINDOW
                TEXT = "* Object: ":LIST.LONG.OBJECT.NAME
            CASE COMPILE.OBJECT
                TEXT = "Object: ":LIST.LONG.OBJECT.NAME
            CASE SHORT.LIST AND SEND.TO.WINDOW
                TEXT = "* Program: ":LIST.LONG.OBJECT.NAME
            CASE 1
                TEXT = "Program: ":LIST.LONG.OBJECT.NAME
        END CASE

        GOSUB PRINT.TEXT

        IF NOT(SHORT.LIST) THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = " "
        GOSUB PRINT.TEXT

    END

* if we aren't doing a short list show the object definition's main
* comment block
    IF NOT(SHORT.LIST) AND OBJECT.METHOD = "" THEN
        GOSUB LIST.MAIN.COMMENT.BLOCK
    END

* list properties for this method.  "by.type" displays properties grouped
* together by the type.  "by.line" displays them in the order they appear
* in the object code
    IF LIST.PROPERTIES.BY.TYPE THEN
        GOSUB LIST.PROPERTIES.BY.TYPE
    END ELSE
        GOSUB LIST.PROPERTIES.BY.LINE
    END

* list methods

* if we have a "common" method don't count it in the method count
    SHOW.METHOD.COUNT = METHOD.COUNT

    LOCATE COMMON.ROUTINE.METHOD IN METHOD.LIST SETTING COMMON.PTR THEN
        SHOW.METHOD.COUNT -= 1
    END

* display a heading for all methods unless we're only displaying a single
* method
    IF OBJECT.METHOD = "" THEN

        BEGIN CASE
            CASE SHOW.METHOD.COUNT = 0
                TEXT = "No Methods"
            CASE SHOW.METHOD.COUNT = 1
                TEXT = "1 Method:"
            CASE 1
                TEXT = SHOW.METHOD.COUNT:" Methods:"
        END CASE

        BEGIN CASE

* sending to a view-only window with banners
            CASE SEND.TO.WINDOW AND BANNER.NAMES
                BANNER.TEXT = TEXT
                GOSUB BANNER.TEXT

* sending a short list to a view-only window.  add a title with the method
* count.  we'll send this like it's a comment so that the view-only window
* will highlight it
            CASE SHORT.LIST AND SEND.TO.WINDOW
                TEXT = ("* ":TEXT:" ":STR("*", BOX.WIDTH)) BOX.MASK
                GOSUB PRINT.TEXT
                TEXT = " "
                GOSUB PRINT.TEXT

* sending a short list to the screen.  don't add a title to try and keep
* things compact
            CASE SHORT.LIST
                NULL

* for anything else print a simple line with the method count
            CASE 1
                GOSUB PRINT.TEXT

        END CASE

    END

* display each method
    LAST.METHOD.SECTION = "****"

    FOR METHOD.LOOP = 1 TO METHOD.COUNT

* unload everything for this method
        METHOD = METHOD.LIST<METHOD.LOOP>
        METHOD.LOCAL = METHOD.LOCAL.LIST<METHOD.LOOP>
        METHOD.SECTION = METHOD.SECTION.LIST<METHOD.LOOP>

        METHOD.PARMS = RAISE(METHOD.PARM.LIST<METHOD.LOOP>)

        METHOD.PARM.DEFAULTS = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.LOOP>)
        METHOD.SET = RAISE(METHOD.PARM.SET.LIST<METHOD.LOOP>)
        METHOD.DEFAULT = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.LOOP>)

        METHOD.BYREF = RAISE(METHOD.PARM.BYREF.LIST<METHOD.LOOP>)
        METHOD.SPECIAL = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.LOOP>)
        METHOD.OPTIONAL = RAISE(METHOD.PARM.OPTIONAL.LIST<METHOD.LOOP>)

        METHOD.PARM.COUNT = DCOUNT(METHOD.PARMS, @AM)

        METHOD.START = METHOD.START.LINE<METHOD.LOOP>
        METHOD.PROGRAM.START = METHOD.PROGRAM.START.LINE<METHOD.LOOP>
        METHOD.END = METHOD.END.LINE<METHOD.LOOP>

        METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.LOOP>

        UPCASE.METHOD = METHOD

        IF DOWNCASE.METHODS THEN
            METHOD = DOWNCASE(METHOD)
            LIST.METHOD = METHOD
            METHOD.SECTION = DOWNCASE(METHOD.SECTION)
            METHOD.PARMS = DOWNCASE(METHOD.PARMS)
            METHD.PARM.DEFAULTS = DOWNCASE.QUOTE(METHOD.PARM.DEFAULTS)
        END

* does this parameter list have any optional parameters?
        OPTIONAL.EXISTS = @FALSE
        NON.OPTIONAL.EXISTS = @FALSE
        BREAK.EXISTS = @FALSE

        FOR PARM.LOOP = 1 TO METHOD.PARM.COUNT

            IF METHOD.DEFAULT<PARM.LOOP> <> "" THEN
                OPTIONAL.EXISTS = @TRUE
            END ELSE
                NON.OPTIONAL.EXISTS = @TRUE
            END

            IF PARM.LOOP < METHOD.PARM.COUNT THEN
                IF METHOD.BYREF<PARM.LOOP> <> METHOD.BYREF<PARM.LOOP + 1> THEN
                    BREAK.EXISTS = @TRUE
                END
            END

        NEXT PARM.LOOP

* decide if we should print this method:
*     - if a key string or a method name was defined only print out the method
*       if it matches
*     - never print out the "common" method as it's not really a method but just
*       somewhere to park included subroutines
*     - never print local methods for a "short" listing
        BEGIN CASE

            CASE UPCASE.METHOD = COMMON.ROUTINE.METHOD
                PRINT.METHOD = @FALSE

            CASE METHOD.LOCAL AND SHORT.LIST
                PRINT.METHOD = @FALSE

            CASE LIST.KEY.STRING <> "" AND INDEX(UPCASE.METHOD, LIST.KEY.STRING, 1) > 0
                PRINT.METHOD = @TRUE
            CASE LIST.KEY.STRING <> ""
                PRINT.METHOD = @FALSE

            CASE OBJECT.METHOD <> "" AND OBJECT.METHOD = METHOD
                PRINT.METHOD = @TRUE
            CASE OBJECT.METHOD <> ""
                PRINT.METHOD = @FALSE

            CASE 1
                PRINT.METHOD = @TRUE

        END CASE

* if we don't have a key string and we aren't printing a single method
* and this is a new section display the section name
        IF PRINT.METHOD AND LIST.KEY.STRING = "" AND OBJECT.METHOD = "" THEN

* if this is a new section display the section description
            IF METHOD.SECTION <> LAST.METHOD.SECTION THEN

                IF METHOD.SECTION <> "" AND UPCASE(METHOD.SECTION) <> "NONE" THEN

* if we're sending to a view-only window add an extra break before the section
* to make it pretty
                    IF SEND.TO.WINDOW AND NOT(SHORT.LIST) THEN
                        TEXT = " "
                        GOSUB PRINT.TEXT
                    END

                    TEXT = " "
                    GOSUB PRINT.TEXT

* display the section depending on how we're displaying the method list
                    BEGIN CASE

* sending to a display window and we're showing the sections using "banner"
* text
                        CASE SEND.TO.WINDOW AND BANNER.NAMES
                            BANNER.TEXT = METHOD.SECTION:":"
                            GOSUB BANNER.TEXT

* if this is a short listing and it's going to the display window show the
* section like a comment line so it'll be highlighted
                        CASE SEND.TO.WINDOW AND SHORT.LIST
                            TEXT = "* ":METHOD.SECTION:":"
                            GOSUB PRINT.TEXT

* anything else, just display the method text
                        CASE 1
                            TEXT = METHOD.SECTION:":"
                            GOSUB PRINT.TEXT

                    END CASE

                END

                LAST.METHOD.SECTION = METHOD.SECTION

            END

        END

* display the method if we decided to display
        BEGIN CASE

* don't list this method
            CASE NOT(PRINT.METHOD)
                NULL

* print a short list of the method, only the definition
            CASE SHORT.LIST

                GOSUB BUILD.SHORT.LIST.DESCRIPTION

* if the line folds indent the second and later lines an extra few
* spaces
                INDENT += 4
                GOSUB COMMA.FOLD
                INDENT -= 4

* print a long list of the method.  show the documentation for the
* method as well as the definition
            CASE 1

                TEXT = " "
                GOSUB PRINT.TEXT

                GOSUB LIST.ALL.METHOD.STATEMENTS

* method.start may point to blank lines if we had a wrapped METHOD statement
* or whatever.  move it down to the next non-blank line.  inherited method
* definitions shouldn't wrap so we'll skip this for inherited methods
                IF NOT(METHOD.INHERITED) THEN
                    LOOP UNTIL TRIM(OBJECT.CODE<METHOD.START>) <> "" OR METHOD.START = METHOD.PROGRAM.START DO
                        METHOD.START += 1
                    REPEAT
                END

                GOSUB DISPLAY.OPTIONAL.FIELDS

* display comments from the start of the method until the program code
* starts or until we hit a blank line
                IF METHOD.INHERITED THEN
                    GOSUB DISPLAY.INHERITED.COMMENTS
                END ELSE
                    GOSUB DISPLAY.LISTING.COMMENTS
                END

        END CASE
        
    NEXT METHOD

* if we're displaying more than one method do a line break for visibility
    IF OBJECT.METHOD = "" THEN

        TEXT = " "
        GOSUB PRINT.TEXT
        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

* show the compile history at the end unless we're printing a single
* method or we're doing a short listing
    IF COMPILE.METHOD.COUNT <> 0 AND OBJECT.METHOD = "" AND NOT(SHORT.LIST) THEN

        TEXT = " "
        GOSUB PRINT.TEXT

        TEXT = "Change History:"
        IF SEND.TO.WINDOW AND BANNER.NAMES THEN
            BANNER.TEXT = TEXT
            GOSUB BANNER.TEXT
        END ELSE
            GOSUB PRINT.TEXT
        END

        GOSUB BOX.LINE

* this table gets pretty full so we'll make it as wide as we can
        METHOD.WIDTH = 18
        SUB.WIDTH = 25
        DATE.WIDTH = 8
        TIME.WIDTH = 7
        USER.WIDTH = 8

* if the columns add up shorter than our allowable text widen
* the sub.width until we use it all up
        LOOP
            ENTIRE.WIDTH = METHOD.WIDTH + SUB.WIDTH + DATE.WIDTH + TIME.WIDTH + USER.WIDTH + 4
        UNTIL ENTIRE.WIDTH >= BOX.WIDTH - 4
            SUB.WIDTH += 1
        REPEAT

 * if the columns are too wide reduce things a bit
        LOOP

            ENTIRE.WIDTH = METHOD.WIDTH + SUB.WIDTH + DATE.WIDTH + TIME.WIDTH + USER.WIDTH + 4

        UNTIL ENTIRE.WIDTH <= BOX.WIDTH - 4

            IF METHOD.WIDTH > SUB.WIDTH THEN
                METHOD.WIDTH -= 1
            END ELSE
                SUB.WIDTH -= 1
            END

        REPEAT

        METHOD.MASK = "L#":METHOD.WIDTH
        SUB.MASK = "L#":SUB.WIDTH

        TEXT = ("Method":STR(".", 100)) METHOD.MASK:" "
        TEXT := ("Subroutine":STR(".", 100)) SUB.MASK
        TEXT := " ChDate.. ChTime. ChangeBy"
        GOSUB BOX.TEXT

        FOR COMP.LOOP = 1 TO COMPILE.METHOD.COUNT

            THIS.METHOD = COMPILE.METHOD.LIST<COMP.LOOP>
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:THIS.METHOD
            THIS.DATE = COMPILE.METHOD.DATE.LIST<COMP.LOOP>
            THIS.TIME = COMPILE.METHOD.TIME.LIST<COMP.LOOP>
            THIS.USER = COMPILE.METHOD.USER.LIST<COMP.LOOP>

            TEXT = COMPILE.METHOD.LIST<COMP.LOOP> METHOD.MASK:" "
            TEXT := SUBROUTINE.NAME SUB.MASK:" "
            TEXT := OCONV(THIS.DATE, "D2/") "L#8":" "
            TEXT := OCONV(THIS.TIME, "MTH") "L#7":" "
            TEXT := THIS.USER "L#8"
            GOSUB BOX.TEXT

        NEXT COMP.LOOP

        GOSUB BOX.LINE

    END

    GOSUB OUTPUT.TEXT

    RETURN

BUILD.SHORT.LIST.DESCRIPTION: ********************************************
* build a description line for the current method in a "short" listing   *
* of methods.  returns text.line                                         *
**************************************************************************

* figure out how many returned parameters this method has and where the
* first optional parameter starts
    RETURNED.COUNT = 0
    FOUND.RETURNED = @FALSE
    FIRST.OPTIONAL = 0
    OPTIONAL.COUNT = 0

    FOR PARM.LOOP = 1 TO METHOD.PARM.COUNT UNTIL FOUND.RETURNED AND FIRST.OPTIONAL <> 0

        THIS.BYREF = METHOD.BYREF<PARM.LOOP>
        THIS.SPECIAL = METHOD.SPECIAL<PARM.LOOP>
        THIS.OPTIONAL = METHOD.OPTIONAL<PARM.LOOP>

        IF NOT(FOUND.RETURNED) AND (NOT(THIS.BYREF) OR THIS.SPECIAL) THEN
            FOUND.RETURNED = @TRUE
            RETURNED.COUNT = PARM.LOOP - 1
        END

        IF THIS.OPTIONAL AND FIRST.OPTIONAL = 0 THEN
            FIRST.OPTIONAL = PARM.LOOP
            OPTIONAL.COUNT = METHOD.PARM.COUNT - FIRST.OPTIONAL + 1
        END

    NEXT PARM.LOOP

* if returned.count wasn't set and the first parameter is byref and not a
* special parameter than all parameters must be returned
    IF NOT(FOUND.RETURNED) THEN
        RETURNED.COUNT = METHOD.PARM.COUNT
    END

* calculate the number of passed parameters that aren't optional
    PASSED.COUNT = METHOD.PARM.COUNT - RETURNED.COUNT - OPTIONAL.COUNT

* build an example of the method call
    BEGIN CASE

* no parameters:

*     no returned, passed or optional.  show a call with no parameters
        CASE METHOD.PARM.COUNT = 0
            PARAMETER.TEXT = METHOD.DELIMITER:METHOD

* all parameters are returned: 
 
*     there won't be any passed or optional parameters
        CASE RETURNED.COUNT = METHOD.PARM.COUNT
            PARAMETER.TEXT = CHANGE(METHOD.PARMS, @AM, ", "):" = ":METHOD.DELIMITER:METHOD

* no returned parameters:

*     there are no optional parameters.  the parameter list is only passed
*     parameters
        CASE RETURNED.COUNT = 0 AND OPTIONAL.COUNT = 0
            PARAMETER.TEXT = METHOD.DELIMITER:METHOD:" (":CHANGE(METHOD.PARMS, @AM, ", "):")"

*     all passed parameters are optional.  show the optionals in braces
        CASE RETURNED.COUNT = 0 AND PASSED.COUNT = 0
            PARAMETER.TEXT = METHOD.DELIMITER:METHOD:" ({":CHANGE(METHOD.PARMS, @AM, ", "):"})"

*    there are passed parameters and some of those parameters are optional.
*    display the passed parameters and show the optional parameters inside braces
        CASE RETURNED.COUNT = 0
            PASSED.PARMS = METHOD.PARMS [@AM, 1, PASSED.COUNT]
            OPTIONAL.PARMS = METHOD.PARMS [@AM, FIRST.OPTIONAL, TO.THE.END]

            PARAMETER.TEXT = METHOD.DELIMITER:METHOD:" (":CHANGE(PASSED.PARMS, @AM, ", ")
            PARAMETER.TEXT := ", {":CHANGE(OPTIONAL.PARMS, @AM, ", "):"})"

* at least one returned parameter:

*     we have passed parameters but no optional parameters
        CASE OPTIONAL.COUNT = 0
            RETURNED.PARMS = METHOD.PARMS [@AM, 1, RETURNED.COUNT]
            PASSED.PARMS = METHOD.PARMS [@AM, RETURNED.COUNT + 1, TO.THE.END]

            PARAMETER.TEXT = CHANGE(RETURNED.PARMS, @AM, ", "):" = ":METHOD.DELIMITER:METHOD
            PARAMETER.TEXT := " (":CHANGE (PASSED.PARMS, @AM, ", "):")"

*     we have passed parameters but all passed parameters are optional.  show
*     the entire passed parameter list in braces
        CASE PASSED.COUNT = 0
            RETURNED.PARMS = METHOD.PARMS [@AM, 1, RETURNED.COUNT]
            OPTIONAL.PARMS = METHOD.PARMS [@AM, FIRST.OPTIONAL, TO.THE.END]

            PARAMETER.TEXT = CHANGE(RETURNED.PARMS, @AM, ", "):" = ":METHOD.DELIMITER:METHOD
            PARAMETER.TEXT := " ({":CHANGE(OPTIONAL.PARMS, @AM, ", "):"})"

*    we passed parameters and some are optional parameters.  show the optional
*    parameters in braces
        CASE 1
            RETURNED.PARMS = METHOD.PARMS [@AM, 1, RETURNED.COUNT]
            PASSED.PARMS = METHOD.PARMS [@AM, RETURNED.COUNT + 1, PASSED.COUNT]
            OPTIONAL.PARMS = METHOD.PARMS [@AM, FIRST.OPTIONAL, TO.THE.END]

            PARAMETER.TEXT = CHANGE(RETURNED.PARMS, @AM, ", "):" = ":METHOD.DELIMITER:METHOD
            PARAMETER.TEXT := " (":CHANGE (PASSED.PARMS, @AM, ", ")
            PARAMETER.TEXT := ", {":CHANGE(OPTIONAL.PARMS, @AM, ", "):"})"

    END CASE

* the method name may not fit in the left column.  if not we still want to
* show the entire method name
    IF LEN(METHOD) < INDENT THEN
        TEXT.LINE = METHOD INDENT.MASK:PARAMETER.TEXT
    END ELSE
        TEXT.LINE = METHOD:" ":PARAMETER.TEXT
    END

    RETURN

LIST.ALL.METHOD.STATEMENTS: **********************************************
* list up to four different method statements:                           *
**************************************************************************

* do a simple listing first.  list all mandatory parameters to the right of
* the method name to show the minimum "subroutine" call.  if "eclipse-style"
* calls (with all parameters to the right of the equals sign including returned
* parameters) and we have returned parameters don't display this version.
* dotnet can ONLY call in this way, though, so still display this version
* of the call for dotnet
    IF LIST.DOT OR (ALLOW.ALL.PARAMETERS.ON.RIGHT OR NOT(METHOD.BYREF<1>)) THEN

* simple subroutine call, all parameters to the right of the method name,
* no optional parameters
        SHOW.METHOD.NAME = @TRUE
        LIST.OPTIONAL = @FALSE
        LIST.SIMPLE = @TRUE
        ADD.REMAINING = NOT(OPTIONAL.EXISTS) AND NOT(METHOD.BYREF<1>)
        GOSUB LIST.METHOD.STATEMENT

* if we have optional parameters do a simple listing (all parameters to the
* right of the method name) with all parameters
        IF OPTIONAL.EXISTS THEN

            SHOW.METHOD.NAME = @FALSE
            LIST.OPTIONAL = @TRUE
            LIST.SIMPLE = @TRUE
            ADD.REMAINING = NOT(METHOD.BYREF<1>)
            GOSUB LIST.METHOD.STATEMENT

        END

    END

* if this method has optional parameters and it has at least one leading
* byref parameter (an output parameter) display the method definition in
* a "function" format (parameter1 = method (parameter2)) with a minimum
* number of parameters.  if there are no leading output parameters then we've
* already seen this with the "simple" listing above so we don't need to see it
* again 

* dotnet can't do this style of call so we won't show this form for dotnet
* listings
    IF NOT(LIST.DOT) THEN

        IF OPTIONAL.EXISTS AND NON.OPTIONAL.EXISTS AND METHOD.BYREF<1> THEN

* "function" style listing, no optional parameters
            SHOW.METHOD.NAME = @FALSE
            LIST.OPTIONAL = @FALSE
            LIST.SIMPLE = @FALSE
            ADD.REMAINING = @FALSE
            GOSUB LIST.METHOD.STATEMENT

        END

* display the method call in a "function" format with all parameters if the
* first parameter is an  output parameter

* again, dotnet can't do this style of call
        IF METHOD.BYREF<1> THEN

            SHOW.METHOD.NAME = @FALSE
            LIST.OPTIONAL = @TRUE
            LIST.SIMPLE = @FALSE
            ADD.REMAINING = @TRUE
            GOSUB LIST.METHOD.STATEMENT

        END

    END

    RETURN

LIST.METHOD.STATEMENT: ***************************************************
* list method statement, depending on long.parameter.list.               *
* list.optional turns optional parameters on and off.                    *
* add.remaining adds remaining text from the source code after the       *
* method listing                                                         *
* list.simple doesn't use any of the "special" display methods           *
**************************************************************************

* get the method definition from the called object code for inherited
* methods or from the source code for a "normal" method
    IF METHOD.INHERITED THEN

        TEXT.LINE = METHOD.INHERIT.DEFINITION.LIST<METHOD.LOOP>
        THIS.METHOD = METHOD.LIST<METHOD.LOOP>
        TEXT.LINE = METHOD.KEYWORD:" ":THIS.METHOD:" ":TEXT.LINE [" ", 3, TO.THE.END]

    END ELSE

        TEXT.LINE = OBJECT.CODE<METHOD.START - 1>

    END

* get method name from the method definition line
    LIST.METHOD.NAME = TEXT.LINE [" ", 2, 1] ["(", 1, 1] [":", 1, 1] [",", 1, 1]

* convert the method name for dotnet listings
    IF LIST.DOT THEN
        LIST.METHOD.NAME = DOT.NET (LIST.METHOD.NAME, DOT.NET.FROM.METHOD.LIST, DOT.NET.TO.METHOD.LIST)
    END ELSE
        IF DOWNCASE.METHODS THEN
            LIST.METHOD.NAME = DOWNCASE(LIST.METHOD.NAME)
        END
    END

* long parameter listing
    IF LONG.PARAMETER.LIST THEN

        INDENT = 4
        PREN.PTR = INDEX(TEXT.LINE, "(" ,1)

        IF PREN.PTR > 0 THEN
            INDENT = PREN.PTR
        END

        GOSUB COMMA.FOLD
        RETURN

    END

* short parameter listing
    TEXT.REMAIN = TEXT.LINE [":", 2, TO.THE.END]

    METHOD.PARM.COUNT = DCOUNT(METHOD.PARMS, @AM)

* begin building the listing of the method statement
    TEXT.LINE = ""

* if there aren't any parameters we won't be in the parameter loop to get
* the method name out there so we'll do it here if there aren't any
* parameters
    IF METHOD.PARM.COUNT = 0 THEN    
        TEXT.LINE := LIST.METHOD.NAME
    END

* if we're not supposed to show the method name replace it with spaces
* of an equal length to what the display would be
    IF NOT(SHOW.METHOD.NAME) THEN
        TEXT.LINE = SPACE(LEN(TEXT.LINE))
    END

* if all the beginning parameters are byref and the ending parameters
* are byval with no other variations then we have a method with nice
* blocks of input and output parameters.  we'll show the input and the
* output parameters separately in the display.

* loop across the parameter list and count the number of times a
* parameters changes from byref to byval or byval to byref. 

* to display the parameter list this way the first parameter also
* has to be byref.  then we know we have the output parameters first
* and the input parameters last

* if all parameters are byref then we'll consider it an "all output"
* display

* if all parameters are byval then we'll consider it an "all input"
* display
    OUTPUT.INPUT.DISPLAY = @FALSE
    ALL.OUTPUT.DISPLAY = @FALSE
    ALL.INPUT.DISPLAY = @FALSE

    IF METHOD.PARM.COUNT > 0 THEN

        BYREF.BREAKS = 0
        LAST.PARM.LOOP = 1

        FOR PARM.LOOP = 2 TO METHOD.PARM.COUNT

* unload values for this parameter
            THIS.DEFAULT = METHOD.DEFAULT<PARM.LOOP>

            THIS.BYREF = METHOD.BYREF<PARM.LOOP>
            THIS.SPECIAL = METHOD.SPECIAL<PARM.LOOP>

            IF THIS.DEFAULT = "" OR LIST.OPTIONAL THEN
                IF THIS.BYREF <> METHOD.BYREF<LAST.PARM.LOOP> THEN
                    BYREF.BREAKS += 1
                END
                LAST.PARM.LOOP = PARM.LOOP
            END

        NEXT PARM.LOOP

        BEGIN CASE

* showing a simple listing.  nothing fancy
            CASE LIST.SIMPLE
                NULL

* one or more breaks and the first parameters if byref.  show a split
* output / input display
            CASE BYREF.BREAKS > 0 AND METHOD.BYREF<1> = @TRUE
                OUTPUT.INPUT.DISPLAY = @TRUE

* all parameters are byref.  there are no breaks.  show display
* as "all output"
            CASE BYREF.BREAKS = 0 AND METHOD.BYREF<1> = @TRUE
                ALL.OUTPUT.DISPLAY = @TRUE

* all parameters are byval.  there are no breaks.  show display
* as "all input"
            CASE BYREF.BREAKS = 0 AND METHOD.BYREF<1> = @FALSE
                ALL.INPUT.DISPLAY = @TRUE

        END CASE

    END

* starting parenthesis (or not)
    BEGIN CASE

* method has no parameters
        CASE METHOD.PARM.COUNT = 0
            NULL

* simple output but there won't be any parameters to list as there
* are no non-optional parameters
        CASE LIST.SIMPLE AND NOT(LIST.OPTIONAL) AND NOT(NON.OPTIONAL.EXISTS)
            TEXT.LINE := LIST.METHOD.NAME

* for a simple output just show the list method name
        CASE LIST.SIMPLE
            TEXT.LINE := LIST.METHOD.NAME:" ("

* it's an "all input" display but we're doing a simple display
* (no optionals).  don't show the empty returned values parenthesis
        CASE ALL.INPUT.DISPLAY AND NOT(LIST.OPTIONAL)
            TEXT.LINE := LIST.METHOD.NAME:" ("

* method has parameters and this is an "all input" display
        CASE ALL.INPUT.DISPLAY
            TEXT.LINE := LIST.METHOD.NAME:" ("

* method has parameters and we're doing an "all output" display
        CASE ALL.OUTPUT.DISPLAY
            TEXT.LINE := "("

* we're doing an output / input display
        CASE OUTPUT.INPUT.DISPLAY
            TEXT.LINE := "("

* method has parameters but we aren't doing any special display
        CASE 1
            TEXT.LINE := LIST.METHOD.NAME:" ("

    END CASE

* set the indent if this line wraps around
    INDENT = 8

* display method parameters
    DO.OUTPUT.INPUT.BREAK = @TRUE
    LAST.PARM.LOOP = 1

    FOR PARM.LOOP = 1 TO METHOD.PARM.COUNT

* unload values for this parameter
        THIS.PARM = METHOD.PARMS<PARM.LOOP>

        THIS.DEFAULT = METHOD.DEFAULT<PARM.LOOP>

        THIS.BYREF = METHOD.BYREF<PARM.LOOP>
        THIS.SPECIAL = METHOD.SPECIAL<PARM.LOOP>

        IF LIST.DOT THEN
            THIS.PARM = DOT.NET (THIS.PARM, "", "")
        END

* if flagged to not show optional parameters and we have a default
* parameter don't display this parameter.  however, if there is
* a non-optional parameter after this one we still need to show
* something or the parameters will be out of order
        LIST.THIS.PARAMETER = @TRUE
        NULL.THIS.PARAMETER = @FALSE

        IF NOT(LIST.OPTIONAL) AND THIS.DEFAULT <> "" THEN

            LIST.THIS.PARAMETER = @FALSE

            FOR CHECK.AFTER = PARM.LOOP + 1 TO METHOD.PARM.COUNT UNTIL LIST.THIS.PARAMETER

                IF METHOD.DEFAULT<CHECK.AFTER> = "" THEN
                    LIST.THIS.PARAMETER = @TRUE
                    NULL.THIS.PARAMETER = @TRUE
                END

            NEXT CHECK.AFTER

        END

* show delimiter between parameters
        BEGIN CASE

* we didn't list this parameter
            CASE NOT(LIST.THIS.PARAMETER)
                NULL

* this is the first parameter
            CASE PARM.LOOP = 1
                NULL

* "byref" value for this parameter is different than the previous parameter
            CASE OUTPUT.INPUT.DISPLAY AND THIS.BYREF <> METHOD.BYREF<LAST.PARM.LOOP> AND DO.OUTPUT.INPUT.BREAK
                TEXT.LINE := ") = ":LIST.METHOD.NAME:" ("
                DO.OUTPUT.INPUT.BREAK = @FALSE

* parameter in the middle somewhere.  show a comma
            CASE 1
                TEXT.LINE := ", "

        END CASE

* display this parameter
        BEGIN CASE

            CASE LIST.THIS.PARAMETER AND NULL.THIS.PARAMETER
                TEXT.LINE := '""'
                LAST.PARM.LOOP = PARM.LOOP

            CASE LIST.THIS.PARAMETER
                TEXT.LINE := THIS.PARM
                LAST.PARM.LOOP = PARM.LOOP

        END CASE

    NEXT PARM.LOOP

* close up method line after last parameter is displayed
    BEGIN CASE

* no parameters were listed
        CASE METHOD.PARM.COUNT = 0
            NULL

* simple output but there won't be any parameters to list as there
* are no non-optional parameters
        CASE LIST.SIMPLE AND NOT(LIST.OPTIONAL) AND NOT(NON.OPTIONAL.EXISTS)
            NULL

* simple listing close parenthesis
        CASE LIST.SIMPLE
            TEXT.LINE := ")"

* we have an "all output" display.  display the parameters like a split
* output / input display with no input values
        CASE ALL.OUTPUT.DISPLAY
            TEXT.LINE := ") = ":LIST.METHOD.NAME

* all input display.  close parenthesis
        CASE ALL.INPUT.DISPLAY
            TEXT.LINE := ")"

* output / input display.  close the parenthesis
        CASE OUTPUT.INPUT.DISPLAY
            TEXT.LINE := ")"

* any other display type.  show a closed parenthesis
        CASE 1
            TEXT.LINE := ")"

    END CASE


* add remaining text after the method description if requested
    IF ADD.REMAINING THEN

        TEXT.LINE := TRIM(TEXT.REMAIN, " ", "T")

* if text.remain is all asterisk (for my pretty boxes) and some
* parameters are optional the listing can end up being shorter than the
* original line and boxes don't line up.  if this is the case add to
* text.remain so that everythig does line up.  compare the final length
* to the length of the next line and pad it out to match
        TRIM.REMAIN = TRIM(TEXT.REMAIN," ","B")
        HAVE.BOX.TOP = @FALSE

        IF TRIM.REMAIN <> "" AND TRIM.REMAIN = STR("*",LEN(TRIM.REMAIN)) THEN
            NEED.LENGTH = LEN(OBJECT.CODE<METHOD.START + 1>)
            TEXT.LINE := STR("*",NEED.LENGTH - LEN(TEXT.LINE))
            HAVE.BOX.TOP = @TRUE
        END

    END

    GOSUB COMMA.FOLD

    RETURN

DISPLAY.OPTIONAL.FIELDS: *************************************************
* show default values for any optional fields                            *
**************************************************************************
    OPTIONAL.FIRST.DISPLAY = @TRUE

    FOR PARM.LOOP = 1 TO METHOD.PARM.COUNT

* unload values for this parameter
        THIS.PARM = METHOD.PARMS<PARM.LOOP>

        THIS.DEFAULT = METHOD.PARM.DEFAULTS<PARM.LOOP>
        THIS.SET = METHOD.SET<PARM.LOOP>

        THIS.BYREF = METHOD.BYREF<PARM.LOOP>
        THIS.SPECIAL = METHOD.SPECIAL<PARM.LOOP>

* downcase everything if set to display in lower case
        IF DOWNCASE.METHODS THEN
            THIS.PARM = DOWNCASE(THIS.PARM)
            THIS.DEFAULT= DOWNCASE.QUOTE(THIS.DEFAULT)
            THIS.SET = DOWNCASE(THIS.SET)
        END

        IF LIST.DOT THEN
            THIS.PARM = DOT.NET (THIS.PARM, "", "")
        END

        IF THIS.DEFAULT <> "" THEN

            IF OPTIONAL.FIRST.DISPLAY THEN

                IF LABELS.OUTSIDE.BOX OR NOT(HAVE.BOX.TOP) THEN
                    GOSUB BOX.LINE
                END

                TEXT = "Parameter Defaults: "
                GOSUB BOX.TEXT
                TEXT = "Parameter" "L#25":"Defaults to:" "L#25":"Sets:" "L#25"
                GOSUB BOX.TEXT
                OPTIONAL.FIRST.DISPLAY = @FALSE

            END

            TEXT = THIS.PARM "L#25":THIS.DEFAULT "L#25"

            IF METHOD.SET THEN
                TEXT := THIS.DEFAULT "L#25"
            END ELSE
                TEXT := "nothing" "L#25"
            END

            GOSUB BOX.TEXT

        END

    NEXT PARM.LOOP

* if we printed some defaults close the bottom of the box
    IF NOT(OPTIONAL.FIRST.DISPLAY) AND HAVE.BOX.TOP THEN
        GOSUB BOX.LINE
    END

    RETURN

LIST.MAIN.COMMENT.BLOCK: *************************************************
* list the main comment block for an objet                               *
**************************************************************************
    MAIN.COMMENT.START = @FALSE
    MAIN.COMMENT.END = @FALSE

    MAIN.WIDTH = 0

* first find the first comment block in the program
    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES UNTIL MAIN.COMMENT.START <> 0

        IF IS.COMMENT(OBJECT.CODE<LINE.LOOP>) THEN
            MAIN.COMMENT.START = LINE.LOOP
        END

    NEXT LINE.LOOP

* if we don't find any comments dump out
    IF MAIN.COMMENT.START = 0 THEN
        RETURN
    END

* now search forward for the first non-comment line after the comment block
    FOR LINE.LOOP = MAIN.COMMENT.START + 1 TO OBJECT.CODE.LINES UNTIL MAIN.COMMENT.END <> 0

        IF NOT(IS.COMMENT(OBJECT.CODE<LINE.LOOP>)) THEN
            MAIN.COMMENT.END = LINE.LOOP - 1
        END

    NEXT LINE.LOOP

* if we didn't find an end . . . the whole program is comments?  whatever
    IF MAIN.COMMENT.END = 0 THEN
        MAIN.COMMENT.END = OBJECT.CODE.LINES
    END

* print first line of main comments
    TEXT = TRIM(OBJECT.CODE<MAIN.COMMENT.START>," ","B")

    IF LABELS.OUTSIDE.BOX THEN
        GOSUB PRINT.TEXT
    END ELSE
        TEXT = LIST.LONG.OBJECT.NAME:":"
        GOSUB BOX.TEXT.LEFT
    END

* print out the main comments
    FOR LINE.LOOP = MAIN.COMMENT.START + 1 TO MAIN.COMMENT.END

        THIS.LINE = TRIM(OBJECT.CODE<LINE.LOOP>, " ", "B")

        TEXT.LINE = THIS.LINE
        GOSUB CONVERT.COMMENT.PROPERTIES

        TEXT = TEXT.LINE
        GOSUB PRINT.TEXT

        TEXT.WIDTH = LEN(THIS.LINE)
        IF TEXT.WIDTH > MAIN.WIDTH THEN
            MAIN.WIDTH = TEXT.WIDTH
        END

    NEXT LINE.LOOP

    TEXT = " "
    GOSUB PRINT.TEXT

    RETURN

DISPLAY.LISTING.COMMENTS: ************************************************
* display comments for the methods listing for the current method.       *
* pulls comments from object.code starting with method.start and         *
* searching forward until method.program.start - 1 or until a blank      *
* line is hit                                                            *
**************************************************************************
    HIT.BLANK.LINE = @FALSE

    FOR LINE.LOOP = METHOD.START TO METHOD.PROGRAM.START - 1 UNTIL HIT.BLANK.LINE

        TEXT.LINE = OBJECT.CODE<LINE.LOOP>

        IF DOWNCASE.METHODS THEN
            TEXT.LINE = DOWNCASE.QUOTE(TEXT.LINE)
        END

        IF TRIM(TEXT.LINE) = "" THEN
            HIT.BLANK.LINE = @TRUE
        END ELSE
            GOSUB CONVERT.COMMENT.PARAMETERS
            GOSUB CONVERT.COMMENT.PROPERTIES
            INDENT = 4
            GOSUB COMMA.FOLD
        END

    NEXT LINE.LOOP

    RETURN

DISPLAY.INHERITED.COMMENTS: **********************************************
* display comments for an inherited method.  finds the source code for   *
* the target method and pulls comments from the target method code       *
* beginning with method.start and searching forward until                *
* method.program.start until method.program.start - 1 or until a blank   *
* line is hit                                                            *
**************************************************************************

* fetch the source code for this inherited method
    INHERIT.OBJECT.NAME = METHOD.INHERIT.OBJECT.LIST<METHOD.LOOP>

    READ CALLED.CODE FROM OBJFILE, INHERIT.OBJECT.NAME ELSE
        CALLED.CODE = ""
    END

    CALLED.CODE.COUNT = DCOUNT(CALLED.CODE, @AM)

* skip over any blank lines
    LOOP UNTIL TRIM(CALLED.CODE<METHOD.START>) <> "" OR METHOD.START > CALLED.CODE.COUNT
        METHOD.START += 1
    REPEAT

    HIT.BLANK.LINE = @FALSE

    FOR LINE.LOOP = METHOD.START TO METHOD.PROGRAM.START - 1 UNTIL HIT.BLANK.LINE

        TEXT.LINE = CALLED.CODE<LINE.LOOP>

        IF DOWNCASE.METHODS THEN
            TEXT.LINE = DOWNCASE.QUOTE(TEXT.LINE)
        END

        IF TRIM(TEXT.LINE) = "" THEN
            HIT.BLANK.LINE = @TRUE
        END ELSE
            GOSUB CONVERT.COMMENT.PARAMETERS
            GOSUB CONVERT.COMMENT.PROPERTIES
            INDENT = 4
            GOSUB COMMA.FOLD
        END

    NEXT LINE.LOOP

    RETURN

CONVERT.COMMENT.PROPERTIES: **********************************************
* convert any property names found in text.line from universe names      *
* to dotnet names                                                        *
**************************************************************************
    IF NOT(LIST.DOT) THEN
        RETURN
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

* unload this parameter
        THIS.PROPERTY = PROP.NAME.LIST<PROP.LOOP>

        IF DOWNCASE.METHODS THEN
            THIS.PROPERTY = DOWNCASE(THIS.PROPERTY)
        END

* replace any occurrences of this parameter with the dotnet conversion
        LOOP
            PROPERTY.PTR = INDEX (TEXT.LINE, THIS.PROPERTY, 1)
        UNTIL PROPERTY.PTR < 1
            DOT.PROPERTY = DOT.NET (THIS.PROPERTY, "", "")
            DOT.PROPERTY := SPACE(LEN(THIS.PROPERTY) - LEN(DOT.PROPERTY))
            TEXT.LINE [PROPERTY.PTR, LEN(THIS.PROPERTY)] = DOT.PROPERTY
        REPEAT

    NEXT PARM.LOOP

    RETURN

CONVERT.COMMENT.PARAMETERS: **********************************************
* convert any parameter names found in text.line from universe names     *
* to dotnet names                                                        *
**************************************************************************
    IF NOT(LIST.DOT) THEN
        RETURN
    END

    FOR PARM.LOOP = 1 TO METHOD.PARM.COUNT

* unload this parameter
        THIS.PARM = METHOD.PARMS<PARM.LOOP>

        IF DOWNCASE.METHODS THEN
            THIS.PARM = DOWNCASE(THIS.PARM)
        END

* replace any occurrences of this parameter with the dotnet conversion
        LOOP
            PARM.PTR = INDEX (TEXT.LINE, THIS.PARM, 1)
        UNTIL PARM.PTR < 1
            DOT.PARM = DOT.NET (THIS.PARM, "", "")
            DOT.PARM := SPACE(LEN(THIS.PARM) - LEN(DOT.PARM))
            TEXT.LINE [PARM.PTR, LEN(THIS.PARM)] = DOT.PARM
        REPEAT

    NEXT PARM.LOOP

    RETURN

LIST.PROPERTIES.BY.TYPE: *************************************************
* list properties / constants / child objects grouped together by type   *
**************************************************************************
    CHILD.LINE = 0
    GOSUB LIST.CHILD.OBJECTS

    PROPERTY.LINE = 0
    GOSUB LIST.PROPERTIES

    CONSTANT.LINE = 0
    GOSUB LIST.CONSTANTS

    RETURN

LIST.PROPERTIES.BY.LINE: *************************************************
* list properties / constants / child objects by program line number     *
* with comments                                                          *
**************************************************************************

* start off the property box
    BEGIN CASE

* we're sending to a view-only window and we're doing headings as banners
        CASE SEND.TO.WINDOW AND BANNER.NAMES

            TEXT = " "
            GOSUB PRINT.TEXT

            BANNER.TEXT = PROP.COUNT:" Properties:"
            GOSUB BANNER.TEXT

            TEXT = " "
            GOSUB PRINT.TEXT

            GOSUB BOX.LINE

* sending to a window without banner headings for a short list.  we'll
* send it like a comment so the view-only window will highlight it
        CASE SEND.TO.WINDOW AND SHORT.LIST

            TEXT = ("* ":PROP.COUNT:" properties: ":STR("*", BOX.WIDTH)) BOX.MASK
            GOSUB PRINT.TEXT

            TEXT = " "
            GOSUB PRINT.TEXT

* sending to a window without banner headings
        CASE SEND.TO.WINDOW

            TEXT = (PROP.COUNT:" properties: ":STR("*", BOX.WIDTH)) BOX.MASK
            GOSUB PRINT.TEXT

            TEXT = " "
            GOSUB PRINT.TEXT

* sending a short listing to the screen.  don't display anything at all
        CASE SHORT.LIST

            NULL

* sending to the screen
        CASE 1

            TEXT = (PROP.COUNT:" properties: ":STR("*", BOX.WIDTH)) BOX.MASK
            GOSUB PRINT.TEXT

    END CASE

* if we don't have any properties add a line to that effect
    IF PROPERTY.LINE.COUNT = 0 THEN
        TEXT = "No properties"
        GOSUB BOX.TEXT
    END

    FIRST.PROPERTY.COMMENT = @TRUE
    LAST.PROPERTY.LINE = 0

    FOR PROPERTY.LINE.LOOP = 1 TO PROPERTY.LINE.COUNT

        THIS.PROPERTY.LINE = PROPERTY.LINE.LIST<PROPERTY.LINE.LOOP>
        THIS.TYPE = PROPERTY.TYPE.LIST<PROPERTY.LINE.LOOP>

* if this code line number is more than one line after the previous one
* there's a whitespace break in the code.  we'll show that whitespace break
* to help keep things organized.  if we're sending to the screen we'll never
* do a break to try and show as much as possible at a time
        BEGIN CASE

* don't do a whitespace break if we're sending to the screen
            CASE NOT(SEND.TO.WINDOW)
                ADD.LINE.BREAK = @FALSE

* if we haven't displayed any properties yet don't do a break
            CASE LAST.PROPERTY.LINE = 0
                ADD.LINE.BREAK = @FALSE

* if this code line is more than 1 line away from the previous line do a break
            CASE THIS.PROPERTY.LINE - LAST.PROPERTY.LINE > 1
                ADD.LINE.BREAK = @TRUE

* for anything else don't break
            CASE 1
                ADD.LINE.BREAK = @FALSE

        END CASE

* display this property / constant / child
        BEGIN CASE

* default constants / properties will have a code line number of zero.  we
* won't display these
            CASE THIS.PROPERTY.LINE = 0
                NULL

            CASE THIS.TYPE = "CHILD"
                CHILD.LINE = THIS.PROPERTY.LINE
                GOSUB LIST.CHILD.OBJECTS
                LAST.PROPERTY.LINE = CHILD.LINE

            CASE THIS.TYPE = "PROPERTY"
                PROPERTY.LINE = THIS.PROPERTY.LINE
                GOSUB LIST.PROPERTIES
                LAST.PROPERTY.LINE = PROPERTY.LINE

            CASE THIS.TYPE = "CONSTANT"
                CONSTANT.LINE = THIS.PROPERTY.LINE
                GOSUB LIST.CONSTANTS
                LAST.PROPERTY.LINE = CONSTANT.LINE

        END CASE

    NEXT PROPERTY.LINE.LOOP

* end the box
    GOSUB BOX.LINE

    TEXT = " "
    GOSUB PRINT.TEXT

    IF SEND.TO.WINDOW THEN
        TEXT = " "
        GOSUB PRINT.TEXT
    END

    RETURN

LIST.CHILD.OBJECTS: ******************************************************
* list an object's child objects.  if child.line is zero all child       *
* objects will be listed with a heading and footer.  if child.line is    *
* not zero only child objects from that line will be displayed without   *
* a heading and footer                                                   *
**************************************************************************

* dotnet has no access to child objects so skip the child object listing
* for dotnet listings
    IF LIST.DOT THEN
        RETURN
    END

* add up how many non-local child objects we have.  these are the only
* objects that can be called
    NON.LOCAL.CHILD.COUNT = 0

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        IF NOT(CHILD.LOCAL.LIST<CHILD.LOOP>) THEN
            NON.LOCAL.CHILD.COUNT += 1
        END

    NEXT CHILD.LOOP

* display a banner heading unless we're printing the child object for a single
* code line
    IF CHILD.LINE = 0 THEN

        IF SEND.TO.WINDOW AND BANNER.NAMES AND NON.LOCAL.CHILD.COUNT <> 0 AND OBJECT.METHOD = "" THEN
            BANNER.TEXT = "Child Objects"
            GOSUB BANNER.TEXT
        END

    END

    IF NON.LOCAL.CHILD.COUNT <> 0 AND OBJECT.METHOD = "" THEN

* display the count of child objects unless we're displaying the child object
* for a single code line
        IF CHILD.LINE = 0 THEN

            IF LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.LINE
            END

            BEGIN CASE
                CASE NON.LOCAL.CHILD.COUNT = 0
                    TEXT = "No Child Objects"
                CASE NON.LOCAL.CHILD.COUNT = 1
                    TEXT = "1 Child Object:"
                CASE 1
                    TEXT = NON.LOCAL.CHILD.COUNT:" Child Objects:"
            END CASE

            IF LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.TEXT
            END ELSE
                GOSUB BOX.TEXT.LEFT
            END

            IF NON.LOCAL.CHILD.COUNT > 0 AND LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.LINE
            END

        END

        THIS.COMMENT = ""
        FIRST.CHILD = @TRUE

        FOR CHILD.LOOP = 1 TO CHILD.COUNT

            THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
            THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
            THIS.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>
            THIS.LINE = CHILD.LINE.LIST<CHILD.LOOP>
            THIS.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
            THIS.COMMENT = RAISE(CHILD.COMMENT.LIST<CHILD.LOOP>)
            NEXT.LINE = PROP.LINE.LIST<PROP.LOOP + 1>

            IF UPCASE.CODE THEN
                THIS.KEYWORD = DOWNCASE(THIS.KEYWORD)
            END

            IF DOWNCASE.METHODS THEN
                THIS.NAME = DOWNCASE(THIS.NAME)
                THIS.HANDLE = DOWNCASE(THIS.HANDLE)
            END

* should we display this child object?
            IF TEXT = "" THEN
                FIRST.ON.LINE = @TRUE
            END ELSE
                FIRST.ON.LINE = @FALSE
            END

            DEFINE.LINE = THIS.LINE
            ONLY.LINE = CHILD.LINE
            GOSUB CHECK.DISPLAY

            IF DISPLAY.COMMENTS THEN
                GOSUB DISPLAY.COMMENTS
            END

            IF DISPLAY.NAME THEN

                IF TEXT <> "" THEN

                    TEXT := ", "
                    NEW.LINE = @FALSE

                END ELSE

                    IF CHILD.LINE <> 0 THEN

                        IF ADD.LINE.BREAK AND NOT(DISPLAY.COMMENTS) THEN
                            TEXT = " "
                            GOSUB BOX.TEXT
                        END

                        IF LIST.DOT THEN
                            TEXT = UPCASE(THIS.KEYWORD [1, 1]):DOWNCASE(THIS.KEYWORD [2, TO.THE.END]):" "
                        END ELSE
                            TEXT = THIS.KEYWORD:" "
                        END

                        IF SHORT.LIST THEN
                            TEXT = TEXT INDENT.MASK
                        END

                    END

                END

                TEXT := THIS.HANDLE:" (":THIS.NAME:")"

* if the next entry is from a different line number print out the
* property list we have so far.  if not we'll continue to accumulate
* the property names

* if the next line is more than one line from this one then the
* properties definition skipped a line here.  we'll skip one, too,
* for clarity
                IF CHILD.LOOP = CHILD.COUNT OR THIS.LINE <> NEXT.LINE THEN

                    GOSUB BOX.TEXT

                    IF CHILD.LINE = 0 AND NEXT.LINE - THIS.LINE > 1 THEN
                        TEXT = " "
                        GOSUB BOX.TEXT
                    END

                    TEXT = ""

                END

            END

        NEXT CHILD.LOOP

* if we have a last line display it
        IF TRIM(TEXT) <> "" THEN
            GOSUB BOX.TEXT
        END

* send a line to finish the bottom of the box and a break
        IF CHILD.LINE = 0 THEN
            GOSUB BOX.LINE
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

    RETURN

LIST.PROPERTIES: *********************************************************
* list properties, if we have any.  if property line is zero then all    *
* properties will be listed with a heading and footing.  otherwise only  *
* the property will be printed without a heading and footing.            *
* list.key.string may have a listing of property names to display        *
**************************************************************************
    IF OBJECT.METHOD = "" THEN

        IF PROPERTY.LINE = 0 THEN

            IF PROP.COUNT > 0 THEN

                IF SEND.TO.WINDOW AND BANNER.NAMES THEN
                    BANNER.TEXT = "Properties"
                    GOSUB BANNER.TEXT
                END

                IF LABELS.OUTSIDE.BOX THEN
                    GOSUB BOX.LINE
                END

            END

* add up how many non-local properties we have
            NON.LOCAL.PROP.COUNT = 0

            FOR PROP.LOOP = 1 TO PROP.COUNT
                IF NOT(PROP.LOCAL.LIST<PROP.LOOP>) THEN
                    NON.LOCAL.PROP.COUNT += 1
                END
            NEXT PROP.LOOP

            BEGIN CASE
                CASE NON.LOCAL.PROP.COUNT = 0
                    TEXT = "No Properties"
                CASE NON.LOCAL.PROP.COUNT = 1
                    TEXT = "1 Property:"
                CASE 1
                    TEXT = NON.LOCAL.PROP.COUNT:" Properties:"
            END CASE

            IF LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.TEXT
            END ELSE
                GOSUB BOX.TEXT.LEFT
            END

            IF PROP.COUNT > 0 AND LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.LINE
            END

        END

* loop through property list and list them out.  we'll try to put them
* on the same line if they're on the same line in the object.  if we have
* no properties add a blank line so that the property lined box won't look
* strange
        IF PROP.COUNT = 0 AND PROPERTY.LINE = 0 THEN
            TEXT = " "
            GOSUB BOX.TEXT
        END

        TEXT = ""
        THIS.COMMENT = ""

        FOR PROP.LOOP = 1 TO PROP.COUNT

            THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
            THIS.LINE = PROP.LINE.LIST<PROP.LOOP>
            THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>
            THIS.LOCAL = PROP.LOCAL.LIST<PROP.LOOP>
            THIS.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
            THIS.COMMENT = RAISE(PROP.COMMENT.LIST<PROP.LOOP>)
            NEXT.LINE = PROP.LINE.LIST<PROP.LOOP + 1>

            IF UPCASE.CODE THEN
                THIS.KEYWORD = DOWNCASE(THIS.KEYWORD)
            END           

            IF LIST.DOT THEN
                THIS.NAME = DOT.NET (THIS.NAME, "", "")
            END ELSE
                IF DOWNCASE.METHODS THEN
                    THIS.NAME = DOWNCASE(THIS.NAME)
                END
            END

* indicate arrays and statics
            BEGIN CASE

                CASE THIS.TYPE = "ARRAY"
                    THIS.NAME := "()"

                CASE THIS.TYPE = "STATIC"
*                   THIS.NAME = THIS.NAME:"*"

                CASE THIS.TYPE = "STATICARRAY"
                    THIS.NAME = THIS.NAME:"()"

            END CASE

* should we display this property?
            IF TEXT = "" THEN
                FIRST.ON.LINE = @TRUE
            END ELSE
                FIRST.ON.LINE = @FALSE
            END

            DEFINE.LINE = THIS.LINE
            ONLY.LINE = PROPERTY.LINE
            GOSUB CHECK.DISPLAY

            IF DISPLAY.COMMENTS THEN
                GOSUB DISPLAY.COMMENTS
            END

            IF DISPLAY.NAME THEN

* if text has a value then we have already accumulated properties to display.
* add this property to the accumulated text.  otherwise start a new text line
                IF TEXT <> "" THEN

                    TEXT := ", "
                    NEW.LINE = @FALSE

                END ELSE

                    IF PROPERTY.LINE <> 0 THEN

                        IF ADD.LINE.BREAK AND NOT(DISPLAY.COMMENTS) THEN
                            TEXT = " "
                            GOSUB BOX.TEXT
                        END

                        IF LIST.DOT THEN
                            TEXT = UPCASE(THIS.KEYWORD [1, 1]):DOWNCASE(THIS.KEYWORD [2, TO.THE.END]):" "
                        END ELSE
                            TEXT = THIS.KEYWORD:" "
                        END

                        IF SHORT.LIST THEN
                            TEXT = TEXT INDENT.MASK
                        END

                    END

                END

                TEXT := THIS.NAME

* if the next entry is from a different line number print out the
* property list we have so far.  if not we'll continue to accumulate
* the property names

* if the next line is more than one line from this one then the
* properties definition skipped a line here.  we'll skip one, too,
* for clarity
                IF PROP.LOOP = PROP.COUNT OR THIS.LINE <> NEXT.LINE THEN

                    GOSUB BOX.TEXT

                    IF PROPERTY.LINE = 0 AND NEXT.LINE - THIS.LINE > 1 THEN
                        TEXT = " "
                        GOSUB BOX.TEXT
                    END

                    TEXT = ""

                END

            END

        NEXT PROP.LOOP

* if we have a last line finish it
        IF TRIM(TEXT) <> "" THEN
            GOSUB BOX.TEXT
        END

* send a line to finish the bottom of the box and a break
        IF PROPERTY.LINE = 0 THEN
            GOSUB BOX.LINE
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

    RETURN

LIST.CONSTANTS: **********************************************************
* list constants.  if constant.line is zero all constants will be        *
* listed with a heading and footing.  if constant.line has a value only  *
* constants from constant.line will be displayed without a heading or    *
* footing.  list.key.string may have a list of constants to list         *
**************************************************************************
    IF OBJECT.METHOD = "" THEN

        IF CONSTANT.LINE = 0 THEN

            IF SEND.TO.WINDOW AND BANNER.NAMES THEN
                BANNER.TEXT = "Constants"
                GOSUB BANNER.TEXT
            END

            IF LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.LINE
            END

            BEGIN CASE
                CASE CONSTANT.COUNT = 0
                    TEXT = "No Constants"
                CASE CONSTANT.COUNT = 1
                    TEXT = "1 Constant:"
                CASE 1
                    TEXT = CONSTANT.COUNT:" Constants:"
            END CASE

            IF LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.TEXT
            END ELSE
                GOSUB BOX.TEXT.LEFT
            END

            IF CONSTANT.COUNT > 0 AND LABELS.OUTSIDE.BOX THEN
                GOSUB BOX.LINE
            END

        END

* go through the constant list and list them out. again, we'll try to put
* them on the same line in the listing if they were on the same line in
* the object
        TEXT = ""

        FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT

            THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
            THIS.LINE = CONSTANT.LINE.LIST<CONSTANT.LOOP>
            THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>
            THIS.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
            THIS.COMMENT = RAISE(CONSTANT.COMMENT.LIST<CONSTANT.LOOP>)

            IF UPCASE.CODE THEN
                THIS.KEYWORD = DOWNCASE(THIS.KEYWORD)
            END

            NEXT.LINE = CONSTANT.LINE.LIST<CONSTANT.LOOP + 1>

            IF LIST.DOT THEN
                THIS.NAME = DOT.NET (THIS.NAME, "", "")
            END ELSE
                IF DOWNCASE.METHODS THEN
                    THIS.NAME = DOWNCASE(THIS.NAME)
                    THIS.VALUE = DOWNCASE.QUOTE(THIS.VALUE)
                END
            END

* should we display this constant?
            IF TEXT = "" THEN
                FIRST.ON.LINE = @TRUE
            END ELSE
                FIRST.ON.LINE = @FALSE
            END

            THIS.LOCAL = @FALSE
            DEFINE.LINE = THIS.LINE
            ONLY.LINE = CONSTANT.LINE
            GOSUB CHECK.DISPLAY

            IF DISPLAY.COMMENTS THEN
                GOSUB DISPLAY.COMMENTS
            END

            IF DISPLAY.NAME THEN

* if text has a value then we've already accumulated constants to display.
* add this constant to the list.  otherwise start a new line
                IF TEXT <> "" THEN

                    TEXT := ", "

                END ELSE

                    IF CONSTANT.LINE <> 0 THEN

                        IF ADD.LINE.BREAK AND NOT(DISPLAY.COMMENTS) THEN
                            TEXT = " "
                            GOSUB BOX.TEXT
                        END

                        IF LIST.DOT THEN
                            TEXT = UPCASE(THIS.KEYWORD [1, 1]):DOWNCASE(THIS.KEYWORD [2, TO.THE.END]):" "
                        END ELSE
                            TEXT = THIS.KEYWORD:" "
                        END

                        IF SHORT.LIST THEN
                            TEXT = TEXT INDENT.MASK
                        END

                    END

                END

                TEXT := THIS.NAME:" = ":THIS.VALUE

* if the next entry is from a different line number print out the
* property list we have so far.  if not we'll continue to accumulate
* the property names

* again, if the next line is more than one line different from this
* one we'll skip a line for clarity
                IF CONSTANT.LOOP = CONSTANT.COUNT OR THIS.LINE <> NEXT.LINE THEN
                    
                    GOSUB BOX.TEXT

                    IF CONSTANT.LINE = 0 AND NEXT.LINE - THIS.LINE > 1 THEN
                        TEXT = " "
                        GOSUB BOX.TEXT
                    END

                    TEXT = ""

                END
            END

        NEXT CONSTANT.LOOP

* if we have a last line display it
        IF TRIM(TEXT) <> "" THEN
            GOSUB BOX.TEXT
        END

* send a line to finish the bottom of the box and a break
        IF CONSTANT.LINE = 0 THEN

            GOSUB BOX.LINE

            TEXT = " "
            GOSUB PRINT.TEXT

            IF SEND.TO.WINDOW THEN
                TEXT = " "
                GOSUB PRINT.TEXT
            END

        END

    END

    RETURN

CHECK.DISPLAY: ***********************************************************
* decide if a property, constant or child should be added to an object   *
* listing.  needs this.name, this.local, this.comment, first.on.line,    *
* define.line, only.line.  returns display.name and display.comments     *
**************************************************************************
    BEGIN CASE

* if we're listing based on a key string don't display unless we match
        CASE LIST.KEY.STRING <> "" AND INDEX(THIS.NAME, LIST.KEY.STRING, 1) = 0
            DISPLAY.NAME = @FALSE
            DISPLAY.COMMENTS = @FALSE

* never display local child objects as outside programs can't see them.
* we might still have comments, though.  if so we'll display them
        CASE THIS.LOCAL AND THIS.COMMENT <> "" AND FIRST.ON.LINE AND ONLY.LINE = 0
            DISPLAY.NAME = @FALSE
            DISPLAY.COMMENTS = @TRUE
        CASE THIS.LOCAL
            DISPLAY.NAME = @FALSE
            DISPLAY.COMMENTS = @FALSE

* if we're displaying the child object for a single code line display
* this child object if it's code line matches don't display comments if
* we're listing child objects for a single code line
        CASE ONLY.LINE <> 0 AND DEFINE.LINE = ONLY.LINE
            DISPLAY.NAME = @TRUE
            DISPLAY.COMMENTS = @FALSE
        CASE ONLY.LINE <> 0
            DISPLAY.NAME = @FALSE
            DISPLAY.COMMENTS = @FALSE

* we don't have any comments
        CASE THIS.COMMENT = ""
            DISPLAY.NAME = @TRUE
            DISPLAY.COMMENTS = @FALSE
            
* only display comments if we're displaying the first child on the code line
        CASE FIRST.ON.LINE
            DISPLAY.NAME = @TRUE
            DISPLAY.COMMENTS = @TRUE

* for anything else display the child but no comments
        CASE 1
            DISPLAY.NAME = @TRUE
            DISPLAY.COMMENTS = @FALSE

    END CASE

    RETURN

DISPLAY.COMMENTS: ********************************************************
* display this.comment as part of a property display                     *
**************************************************************************

* the calling routine is building text so we'll preserve its value
    SAVE.TEXT = TEXT

    COMMENT.COUNT = DCOUNT(THIS.COMMENT, @AM)

    IF COMMENT.COUNT > 0 THEN

        BEGIN CASE

* in "short" lists show a blank line before any comments to break things up
            CASE SHORT.LIST
                TEXT = " "
                GOSUB BOX.TEXT

* if this isn't the first property comment start a box to break things up
            CASE NOT(FIRST.PROPERTY.COMMENT)
                GOSUB BOX.LINE

        END CASE

* display the comment
        FOR COMMENT.LOOP = 1 TO COMMENT.COUNT

            THIS.TEXT = THIS.COMMENT<COMMENT.LOOP>
            GOSUB CONVERT.COMMENT.PROPERTIES

            TEXT = THIS.TEXT
            GOSUB BOX.TEXT

        NEXT COMMENT.LOOP

        FIRST.PROPERTY.COMMENT = @FALSE

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB BOX.TEXT
        END

    END

    TEXT = SAVE.TEXT

    RETURN

LIST.SUBROUTINE: *********************************************************
* list a subroutine to the screen                                        *
**************************************************************************
    PRINT
    PRINT "Subroutine: ":SUBROUTINE.NAME
    PRINT

    MAX.LISTING.WIDTH = 72

* if all program lines are the same as the source lines we won't show
* converted lines
    SHOW.CONVERTED.LINES = @FALSE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES UNTIL SHOW.CONVERTED.LINES

        IF PROGRAM.CODE.FINAL.LIST<LINE.LOOP> <> PROGRAM.CODE.SOURCE.LIST<LINE.LOOP> THEN
            SHOW.CONVERTED.LINES = @TRUE
            MAX.LISTING.WIDTH -= 9
        END

    NEXT LINE.LOOP

    WRAP.INDENT = SPACE(79 - MAX.LISTING.WIDTH)

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

* print the eclipse subroutine program line
        PRINT LINE.LOOP "R%6":" ":

* if our source lines (from the object or object-enabled subroutine) are
* different from the eclipse subroutines lines find original line number
* from object or object-enabled program
        IF SHOW.CONVERTED.LINES THEN

            LOCATE LINE.LOOP IN PROGRAM.CODE.FINAL.LIST SETTING LINE.PTR ELSE
                NULL
            END
            SOURCE.LINE = PROGRAM.CODE.SOURCE.LIST<LINE.PTR>

            PRINT "[":SOURCE.LINE "R%6":"] ":

        END

* print the program line
        THIS.CODE.LINE = PROGRAM.CODE<LINE.LOOP>
        PRINT THIS.CODE.LINE [1, MAX.LISTING.WIDTH]
        THIS.CODE.LINE = THIS.CODE.LINE [MAX.LISTING.WIDTH + 1, TO.THE.END]

* print any wrapped program code
        LOOP UNTIL THIS.CODE.LINE = "" DO
            PRINT WRAP.INDENT:THIS.CODE.LINE [1, MAX.LISTING.WIDTH]
            THIS.CODE.LINE = THIS.CODE.LINE [MAX.LISTING.WIDTH + 1, TO.THE.END]
        REPEAT

    NEXT LINE.LOOP

    GOSUB WAIT

    RETURN

LIST.WRAPPER: ************************************************************
* list a wrapper to the screen                                           *
**************************************************************************
    PRINT
    PRINT "Wrapper: ":SUBROUTINE.NAME
    PRINT

    MAX.LISTING.WIDTH = 72
    WRAP.INDENT = SPACE(79 - MAX.LISTING.WIDTH)

    FOR LINE.LOOP = 1 TO WRAPPER.CODE.LINES

* print the eclipse subroutine program line
        PRINT LINE.LOOP "R%6":" ":

* print the program line
        THIS.CODE.LINE = WRAPPER.CODE<LINE.LOOP>
        PRINT THIS.CODE.LINE [1, MAX.LISTING.WIDTH]
        THIS.CODE.LINE = THIS.CODE.LINE [MAX.LISTING.WIDTH + 1, TO.THE.END]

* print any wrapped program code
        LOOP UNTIL THIS.CODE.LINE = "" DO
            PRINT WRAP.INDENT:THIS.CODE.LINE [1, MAX.LISTING.WIDTH]
            THIS.CODE.LINE = THIS.CODE.LINE [MAX.LISTING.WIDTH + 1, TO.THE.END]
        REPEAT

    NEXT LINE.LOOP

    GOSUB WAIT

    RETURN

SHORTCUT.LIST: ***********************************************************
* list programming shortcuts                                             *
**************************************************************************
    GOSUB INITIALIZE.LISTING

    IF SHORTCUT.COUNT = 0 AND MACRO.COUNT = 0 THEN
        PRINT
        PRINT "No Program Shortcuts or Macros"
        PRINT
        RETURN
    END

    GOSUB FIND.LISTING.WIDTHS

    GOSUB LISTING.TITLE

    GOSUB LIST.DEBUGGING.SHORTCUTS
    GOSUB LIST.SHORTCUTS
    GOSUB LIST.MACROS

    GOSUB SEND.LISTING

* set shortcuts as "not loaded" so the next compile will load them in
* the right order
    SHORTCUTS.LOADED = @FALSE

    RETURN

INITIALIZE.LISTING: ******************************************************
* startup to list shortcuts and macros                                   *
**************************************************************************
    OUT.BUFFER.COUNT = 0
    OUT.BUFFER = ""

    OBJECT.FILENAME = ""
    OBJECT.NAME = ""

    PAD.BOX = @FALSE

    MAX.LEFT.WIDTH = 50

    GOSUB GET.DEBUG.SETTINGS

* rebuild the shortcut list in the same order it appears in compile.setup.
* if shortcuts and macros were already loaded for listing (this happens when
* the shortcut section is prompted for, "SHORTCUTS ASK") we don't need to
* load it again
    IF NOT(SHORTCUTS.LOADED.FOR.LISTING) THEN

        SHORTCUTS.LOADED = @FALSE
        SHORTCUTS.IN.ORDER = @TRUE

        GOSUB GET.SHORTCUT.SETTINGS
        GOSUB GET.MACRO.SETTINGS

    END

    SHORTCUTS.LOADED.FOR.LISTING = @TRUE

    RETURN

FIND.LISTING.WIDTHS: *****************************************************
* determine the widths of listing columns based on the shortcut and      *
* macro lists                                                            *
**************************************************************************

* find width of the widest shortcut
    SHORTCUT.MAX.WIDTH = 10

    FOR SHORT.LOOP = 1 TO SHORTCUT.COUNT

        THIS.WIDTH = LEN(SHORTCUT.KEYWORD.LIST<SHORT.LOOP>)
        IF THIS.WIDTH > SHORTCUT.MAX.WIDTH THEN
            SHORTCUT.MAX.WIDTH = THIS.WIDTH
        END

    NEXT SHORT.LOOP

    IF SHORTCUT.MAX.WIDTH > MAX.LEFT.WIDTH THEN
        SHORTCUT.MAX.WIDTH = MAX.LEFT.WIDTH
    END

* see if the widest macro is wider than the widest shortcut
    FOR MACRO.LOOP = 1 TO MACRO.COUNT

* adjust by width of the longest macro plus the number of characters
* needed to show parameters

* macro parameters need 5 characters for the first parameter ("%0 = "),
* 3 characters for the space after the macro and the parenthesis,
* 2 characters for the second parameter ("%1") and then 3 characters
* for each parameter after that (",%2")
        MACRO.KEYWORD = MACRO.KEYWORD.LIST<MACRO.LOOP>
        MACRO.PARAMETERS = MACRO.PARM.COUNT.LIST<MACRO.LOOP>
        THIS.COUNT = MACRO.PARM.COUNT.LIST<MACRO.LOOP>
        THIS.PARM.LIST = RAISE(MACRO.PARM.LIST<MACRO.LOOP>)
        THIS.DISPLAY.STYLE = MACRO.DISPLAY.STYLE.LIST<MACRO.LOOP>

        PARAMETER.WIDTH = 5 + 3

        IF MACRO.PARAMETERS > 1 THEN
            PARAMETER.WIDTH += 2
        END

        IF MACRO.PARAMETERS > 2 THEN
            PARAMETER.WIDTH += (MACRO.PARAMETERS - 2) * 3
        END

        IF THIS.DISPLAY.STYLE = 1 THEN
            TEXT.LINE = MACRO.KEYWORD:" ("
            PARM.START = 0
        END ELSE
            TEXT.LINE = "%0 = ":MACRO.KEYWORD:" ("
            PARM.START = 1
        END

        FOR PARM.LOOP = PARM.START TO MACRO.PARAMETERS - 1

            TEXT.LINE := "%":PARM.LOOP

            IF PARM.LOOP < MACRO.PARAMETERS - 1 THEN
                TEXT.LINE := ","
            END

        NEXT PARM.LOOP

        TEXT.LINE := ")"

        MACRO.LINE = TEXT.LINE
        GOSUB CONVERT.MACRO.PARAMETERS

        TEXT.LINE = MACRO.LINE

* if the macro definition (the part that appears in the left column)
* is over a reasonable length it will be folded on commas.  fold it
* here so we get the same thing
        IF LEN(TEXT.LINE) > MAX.LEFT.WIDTH THEN

            TEXT.LINE = FOLD.ON.COMMA(TEXT.LINE, MAX.LEFT.WIDTH, 4)
            TEXT.LINE.COUNT = DCOUNT(TEXT.LINE, @AM)

            FOR TEXT.LOOP = 1 TO TEXT.LINE.COUNT

                THIS.LENGTH = LEN(TEXT.LINE<TEXT.LOOP>)

                IF THIS.LENGTH > SHORTCUT.MAX.WIDTH THEN
                    SHORTCUT.MAX.WIDTH = THIS.LENGTH
                END

            NEXT TEXT.LOOP

        END ELSE

* total width needed to display this macro and its parameters
            THIS.WIDTH = LEN(TEXT.LINE)

            IF THIS.WIDTH > SHORTCUT.MAX.WIDTH THEN
                SHORTCUT.MAX.WIDTH = THIS.WIDTH
            END

        END

    NEXT MACRO.LOOP

    SHORTCUT.MASK = "L#":SHORTCUT.MAX.WIDTH

* now that we know how wide the left column will be figure out wide the
* right column is
    IF SEND.TO.WINDOW THEN
        RIGHT.MAX.WIDTH = MAX.LINE.WIDTH.WINDOW - SHORTCUT.MAX.WIDTH
    END ELSE
        RIGHT.MAX.WIDTH = MAX.LINE.WIDTH.SCREEN - SHORTCUT.MAX.WIDTH
    END

    RIGHT.MASK = "L#":RIGHT.MAX.WIDTH

    RETURN

LISTING.TITLE: ***********************************************************
* print the listing title                                                *
**************************************************************************
    IF NOT(SEND.TO.WINDOW) THEN
        PRINT
    END

* if we're not sending to a window do a pretty heading
    IF PAGING AND NOT(SEND.TO.WINDOW) THEN

        TITLE = "Program Shortcut Listing"

        IF MAX.LOAD.LEVEL <> 999 THEN
            TITLE := "Level ":MAX.LOAD.LEVEL
            IF MAX.LOAD.LEVEL > 1 THEN
                TITLE := " and below"
            END
        END

        TITLE = TITLE"L#68":"Page 'P'"
        TITLE [40 - LEN(OBJECT.NAME) / 2,LEN(OBJECT.NAME)] = OBJECT.NAME
        TITLE := "'L'"

        HEADING TITLE

    END

* if we're sending to a window create a title showing what level of
* shortcuts we're displaying
    IF SEND.TO.WINDOW THEN

        BEGIN CASE 
            CASE MAX.LOAD.LEVEL = 1
                SHORTCUT.TITLE = "Quick Shortcut Listing"
            CASE MAX.LOAD.LEVEL = 2
                SHORTCUT.TITLE = "Shortcut Listing"
            CASE MAX.LOAD.LEVEL = 3
                SHORTCUT.TITLE = "Complete Shortcut Listing"
        END CASE

        IF BANNER.NAMES THEN
            BANNER.TEXT = SHORTCUT.TITLE
            GOSUB BANNER.TEXT
        END ELSE
            TEXT = SHORTCUT.TITLE 
            GOSUB PRINT.TEXT
        END

        TEXT = " "
        GOSUB PRINT.TEXT

    END

    RETURN

LIST.DEBUGGING.SHORTCUTS: ************************************************
* list debugging shortcuts                                               *
**************************************************************************

* if we're sending to a window and doing banner names create a
* pretty title
    IF SHORTCUT.COUNT > 0 AND SHORTCUT.LOAD.TYPE = "" THEN

        IF BANNER.NAMES AND SEND.TO.WINDOW THEN

            BANNER.TEXT = "Debugging:"
            GOSUB BANNER.TEXT
            TEXT = " "
            GOSUB PRINT.TEXT
            TEXT = "Debugging Shorts:"
            TEXT := STR("*", MAX.LINE.WIDTH.WINDOW - LEN(TEXT) - 1)
            GOSUB PRINT.TEXT
            TEXT = " "
            GOSUB PRINT.TEXT

        END ELSE

            TEXT = "Debugging:"
            GOSUB PRINT.TEXT

        END

        INDENT = SHORTCUT.MAX.WIDTH + 1

        TEXT = DEBUG.CLEAR.KEYWORD SHORTCUT.MASK:" ":"Clear debug window"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.SEND.TEXT.KEYWORD:" message") SHORTCUT.MASK:" "
        TEXT := "Send message to the debug window"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.SEND.VARIABLE.KEYWORD:" variable") SHORTCUT.MASK:" "
        TEXT := "Send variable name and value to the debug window"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.CLEAR.AND.MESSAGE.KEYWORD:" message") SHORTCUT.MASK:" "
        TEXT := "Clear debug window and send message"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.SEND.ARRAY.KEYWORD:" array") SHORTCUT.MASK:" "
        TEXT := "Send a dynamic array to a view-only window"
        GOSUB PRINT.TEXT
        TEXT = " " SHORTCUT.MASK:" ":"Note that the debug window must be active"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.SET.SOURCE.KEYWORD:" source") SHORTCUT.MASK:" "
        TEXT := "Set Source for all debug messages"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = DEBUG.CLEAR.SOURCE.KEYWORD SHORTCUT.MASK:" ":"Clear Source"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        TEXT = (DEBUG.IDENTIFY.METHOD.KEYWORD) SHORTCUT.MASK:" "
        TEXT := "identify object::method / subroutine"
        GOSUB PRINT.TEXT

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

    RETURN

LIST.SHORTCUTS: **********************************************************
* list program shortcuts                                                 *
**************************************************************************

* if we're sending to a window and doing banner names create a
* pretty title
    IF SHORTCUT.COUNT > 0 THEN

        IF BANNER.NAMES AND SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
            BANNER.TEXT = "Program Shortcuts:"
            GOSUB BANNER.TEXT
        END ELSE
            TEXT = " "
            GOSUB PRINT.TEXT
            TEXT = "Program Shortcuts:"
            GOSUB PRINT.TEXT
        END

    END

    LAST.SECTION = ""

    FOR SHORT.LOOP = 1 TO SHORTCUT.COUNT

        THIS.KEYWORD = SHORTCUT.KEYWORD.LIST<SHORT.LOOP>

        THIS.EXPAND = SHORTCUT.EXPAND.LIST<SHORT.LOOP>
        THIS.VAR.FOLLOW = SHORTCUT.VAR.FOLLOW.LIST<SHORT.LOOP>
        THIS.FOLLOW = SHORTCUT.FOLLOW.LIST<SHORT.LOOP>
        THIS.OPERATOR = SHORTCUT.OPERATOR.LIST<SHORT.LOOP>

        THIS.EMBEDDED = SHORTCUT.EMBEDDED.LIST<SHORT.LOOP>

        THIS.SECTION = SHORTCUT.SECTION.LIST<SHORT.LOOP>

        GOSUB LIST.ONE.SHORTCUT

* if we're sending to a window double space
        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

        LAST.SECTION = MAIN.SECTION

    NEXT SHORT.LOOP

    RETURN

LIST.ONE.SHORTCUT: *******************************************************
* list a single shortcut                                                 *
**************************************************************************

* if there's a shortcut "{}" it was converted to "{ }" in the table so
* that it would process properly.  clean.line converts "{}" to "{ }"
* so it had to be converted in the shortcut table for it to convert
* properly
    IF THIS.KEYWORD = "{ }" THEN
        THIS.KEYWORD = "{}"
    END

* if this shortcut starts a section print the section header.  convert any
* spaces to dots so the section name will appear in the editor view window's
* "Labels" window
    IF THIS.SECTION <> "" THEN

        TEXT = " "
        GOSUB PRINT.TEXT

        GOSUB CONVERT.SECTION

        IF BANNER.NAMES AND SEND.TO.WINDOW THEN

            IF UPCASE(MAIN.SECTION) <> UPCASE(LAST.SECTION) THEN
                TEXT = " "
                GOSUB PRINT.TEXT
                BANNER.TEXT = MAIN.SECTION:":"
                GOSUB BANNER.TEXT
            END

        END

        TEXT.LINE = THIS.SECTION

        IF SEND.TO.WINDOW THEN
            TEXT.LINE := " ":STR("*", MAX.LINE.WIDTH.WINDOW - LEN(TEXT.LINE) - 1)
        END

        GOSUB COMMA.FOLD

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

* add in any variable following and following text if there is any
    BEGIN CASE
        CASE THIS.FOLLOW <> "" AND THIS.VAR.FOLLOW <> ""
            THIS.EXPAND := "{ { . . . }":THIS.VAR.FOLLOW:" . . . }":THIS.FOLLOW
        CASE THIS.FOLLOW <> ""
            THIS.EXPAND := "{ . . . }":THIS.FOLLOW
        CASE THIS.VAR.FOLLOW <> ""
            THIS.EXPAND := "{ . . . }":THIS.VAR.FOLLOW
    END CASE

* if this is an embedded shortcut add a note to the description
    IF THIS.EMBEDDED OR THIS.OPERATOR THEN

        BEGIN CASE
            CASE THIS.OPERATOR AND THIS.EMBEDDED
                EMBEDDED.NOTE = "(embedded operator)"
            CASE THIS.OPERATOR
                EMBEDDED.NOTE = "(operator)"
            CASE THIS.EMBEDDED
                EMBEDDED.NOTE = "(embedded)"
        END CASE

        EMBEDDED.NOTE.LEN = LEN(EMBEDDED.NOTE)

        THIS.KEYWORD = THIS.KEYWORD SHORTCUT.MASK
        THIS.KEYWORD = THIS.KEYWORD [1, LEN(THIS.KEYWORD) - EMBEDDED.NOTE.LEN]:EMBEDDED.NOTE

    END

    INDENT = SHORTCUT.MAX.WIDTH + 1
    TEXT.LINE = THIS.KEYWORD SHORTCUT.MASK:" ":THIS.EXPAND
    GOSUB COMMA.FOLD

    RETURN

LIST.MACROS: *************************************************************
* list macros                                                            *
**************************************************************************

* if we're sending to a window and doing banner names create a
* pretty title
    IF MACRO.COUNT > 0 THEN

        IF BANNER.NAMES AND SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
            BANNER.TEXT = "Macros:"
            GOSUB BANNER.TEXT
        END ELSE
            TEXT = " "
            GOSUB PRINT.TEXT
            TEXT = "Macros:"
            GOSUB PRINT.TEXT
        END

    END

    LAST.MACRO = "******"
    LAST.DISPLAY.STYLE = "******"
    LAST.PARAMETER.ZERO = "******"
    LAST.RETURNED.COUNT = -1
    LAST.SECTION = ""
    LAST.COUNT = -1

    FOR MACRO.LOOP = 1 TO MACRO.COUNT

        THIS.MACRO = MACRO.KEYWORD.LIST<MACRO.LOOP>

        THIS.COUNT = MACRO.PARM.COUNT.LIST<MACRO.LOOP>
        THIS.PARM.LIST = RAISE(MACRO.PARM.LIST<MACRO.LOOP>)
        THIS.RETURNED.COUNT = RAISE(MACRO.RETURNED.COUNT.LIST<MACRO.LOOP>)

        THIS.EXPAND = MACRO.EXPAND.LIST<MACRO.LOOP>
        THIS.END.EXECUTE = MACRO.END.EXECUTE.LIST<MACRO.LOOP>

        THIS.DISPLAY.STYLE = MACRO.DISPLAY.STYLE.LIST<MACRO.LOOP>

        THIS.SECTION = MACRO.SECTION.LIST<MACRO.LOOP>

        GOSUB LIST.ONE.MACRO

        LAST.MACRO = THIS.MACRO
        LAST.PARAMETER.ZERO = PARAMETER.ZERO
        LAST.RETURNED.COUNT = THIS.RETURNED.COUNT
        LAST.DISPLAY.STYLE = THIS.DISPLAY.STYLE
        LAST.COUNT = THIS.COUNT
        LAST.SECTION = MAIN.SECTION

    NEXT MACRO.LOOP

* if sending to a window add a blank after macros
    IF MACRO.COUNT > 0 AND SEND.TO.WINDOW THEN
        TEXT = " "
        GOSUB PRINT.TEXT
    END

    RETURN

LIST.ONE.MACRO: **********************************************************
* list a single macro                                                    *
**************************************************************************

* the count in the control file is the count of ALL parameters, including
* the first one to the left of the equals sign.  this is a bit confusing
* in the listing since "2" parameters means one left and one right of the
* equals.  so, I'll show the count as one less than what's in the control
* file

* additionally a macro can return more than one value.  the count of returned
* values is in this.returned.count.  the list of input parameters starts
* with the parameter after the last returned value
    THIS.COUNT -= 1

* build a display string for the input parameters of the macro
    IF THIS.COUNT - (THIS.RETURNED.COUNT - 1) <= 0 THEN

        DISPLAY.COUNT = "()"

    END ELSE

        DISPLAY.COUNT = ""

        FOR COUNT.LOOP = THIS.RETURNED.COUNT TO THIS.COUNT

            DISPLAY.COUNT := "%":COUNT.LOOP

            IF COUNT.LOOP < THIS.COUNT THEN
                DISPLAY.COUNT := ","
            END

        NEXT COUNT.LOOP

        DISPLAY.COUNT = "(":DISPLAY.COUNT:")"

    END

    INDENT = SHORTCUT.MAX.WIDTH + 1

* if we're sending to a window double space but only if
* this is a new macro name
    IF SEND.TO.WINDOW AND THIS.MACRO <> LAST.MACRO AND MACRO.LOOP > 1 THEN
        TEXT = " "
        GOSUB PRINT.TEXT
    END

* if this shortcut starts a section print the section header.  change any
* spaces in the section name to dots so that the section header will show
* up in the editor window's "Labels" window
    IF THIS.SECTION <> "" THEN

        TEXT = " "
        GOSUB PRINT.TEXT

        GOSUB CONVERT.SECTION

        IF BANNER.NAMES AND SEND.TO.WINDOW THEN

            IF UPCASE(MAIN.SECTION) <> UPCASE(LAST.SECTION) THEN
                TEXT = " "
                GOSUB PRINT.TEXT
                BANNER.TEXT = MAIN.SECTION:":"
                GOSUB BANNER.TEXT
            END

        END

        TEXT.LINE = THIS.SECTION

        IF SEND.TO.WINDOW THEN
            TEXT.LINE := " ":STR("*", MAX.LINE.WIDTH.WINDOW - LEN(TEXT.LINE) - 1)
        END

        GOSUB COMMA.FOLD

        IF SEND.TO.WINDOW THEN
            TEXT = " "
            GOSUB PRINT.TEXT
        END

    END

* display the macro and its definition

* parameter zero may convert to a display variable name.  if so get that name now.
* if the count of returned parameters is more than one build macro.line with
* all the returned parameters
    MACRO.LINE = "%0"

    IF THIS.RETURNED.COUNT > 1 THEN
        FOR RETURNED.LOOP = 1 TO THIS.RETURNED.COUNT - 1
            MACRO.LINE := ",%":RETURNED.LOOP
        NEXT RETURNED.LOOP
    END

    GOSUB CONVERT.MACRO.PARAMETERS
    PARAMETER.ZERO = MACRO.LINE

    BEGIN CASE

* if this macro name is the same as the previous macro and it's displayed
* with the same display style but has a different parameter count we'll
* show it under the last one so it doesn't look like there's a bazillion
* of these things

* show a macro that has no parameters
        CASE THIS.COUNT = -1

            MACRO.PARAMETER.INDENT = 0
            TEXT.LINE = THIS.MACRO:" ()"

* show second+ display for a "function" style with the same zero parameter
* and the same returned count
        CASE THIS.MACRO = LAST.MACRO AND PARAMETER.ZERO = LAST.PARAMETER.ZERO AND LAST.DISPLAY.STYLE = THIS.DISPLAY.STYLE AND LAST.RETURNED.COUNT = THIS.RETURNED.COUNT AND THIS.DISPLAY.STYLE = 0

            MACRO.PARAMETER.INDENT = LEN(THIS.MACRO) + 3 + LEN(PARAMETER.ZERO) + 1
            TEXT.LINE = SPACE(MACRO.PARAMETER.INDENT):DISPLAY.COUNT

* show second+ display for a "statement" style
        CASE THIS.MACRO = LAST.MACRO AND LAST.DISPLAY.STYLE = THIS.DISPLAY.STYLE AND THIS.DISPLAY.STYLE = 1 AND LAST.COUNT <> -1

            MACRO.PARAMETER.INDENT = LEN(THIS.MACRO) + 1

            IF DISPLAY.COUNT = "()" THEN
                TEXT.LINE = SPACE(MACRO.PARAMETER.INDENT):"(":PARAMETER.ZERO:")"
            END ELSE
                TEXT.LINE = SPACE(MACRO.PARAMETER.INDENT):"(":PARAMETER.ZERO:",":DISPLAY.COUNT [2, TO.THE.END]
            END

* display the macro in a "function" style
        CASE THIS.DISPLAY.STYLE = 0

            MACRO.PARAMETER.INDENT = LEN(PARAMETER.ZERO) + 3 + LEN(THIS.MACRO) + 1 
            TEXT.LINE = PARAMETER.ZERO:" = ":THIS.MACRO:" ":DISPLAY.COUNT

* display the macro in a "statement" style
        CASE THIS.DISPLAY.STYLE = 1

            MACRO.PARAMETER.INDENT = LEN(THIS.MACRO) + 1

            IF DISPLAY.COUNT = "()" THEN
                TEXT.LINE = THIS.MACRO:" (":PARAMETER.ZERO:")"
            END ELSE
                TEXT.LINE = THIS.MACRO:" (":PARAMETER.ZERO:",":DISPLAY.COUNT [2, TO.THE.END]
            END

    END CASE

* if we have parameters in this.parameter.list substitute the "%n" values
* with parameter names
    MACRO.LINE = TEXT.LINE
    GOSUB CONVERT.MACRO.PARAMETERS

* if the converted macro line is wider than the maximum width we want to
* allow in the left column (otherwise we might end up without room for the
* right column) fold it on commas
    IF LEN(MACRO.LINE) > SHORTCUT.MAX.WIDTH THEN

        MACRO.DISPLAY.LINE = FOLD.ON.COMMA(MACRO.LINE, SHORTCUT.MAX.WIDTH, MACRO.PARAMETER.INDENT + 1)

* if the fold removed all parameters from the first line there's no point
* in adjusting the indent of the folded lines to the end of the macro
* name.  the parameters don't have much room left and it's more difficult to
* read.  when this happens refold so the parameter indent is even with the
* equals sign if there is one
        FIRST.DISPLAY.LINE = MACRO.DISPLAY.LINE<1>
        IF COUNT(FIRST.DISPLAY.LINE, "(") = 0 AND COUNT(FIRST.DISPLAY.LINE, "=") <> 0 THEN
            EQUALS.INDENT = INDEX(FIRST.DISPLAY.LINE, "=", 1)
            MACRO.DISPLAY.LINE = FOLD.ON.COMMA(MACRO.LINE, SHORTCUT.MAX.WIDTH, EQUALS.INDENT + 1)
        END

        MACRO.DISPLAY.LINE.COUNT = DCOUNT(MACRO.DISPLAY.LINE, @AM)

    END ELSE
        MACRO.DISPLAY.LINE = MACRO.LINE
        MACRO.DISPLAY.LINE.COUNT = 1
    END

* if the expanded macro (displayed in the right column) is wider than the
* right column's maximum width then it will also be folded
    IF THIS.END.EXECUTE <> "" THEN
        MACRO.LINE = THIS.END.EXECUTE
        THIS.EXPAND := " { . . . ":THIS.END.EXECUTE:" } "
    END

    MACRO.LINE = THIS.EXPAND
    GOSUB CONVERT.MACRO.PARAMETERS

    IF LEN(MACRO.LINE) >= RIGHT.MAX.WIDTH THEN
        EXPAND.DISPLAY.LINE = FOLD.ON.COMMA(MACRO.LINE, RIGHT.MAX.WIDTH, 0)
        EXPAND.DISPLAY.LINE.COUNT = DCOUNT(EXPAND.DISPLAY.LINE, @AM)
    END ELSE
        EXPAND.DISPLAY.LINE = MACRO.LINE
        EXPAND.DISPLAY.LINE.COUNT = 1
    END

* both columns are now folded.  display them until all folded lines have
* been printed
    PRINT.TO = MACRO.DISPLAY.LINE.COUNT

    IF EXPAND.DISPLAY.LINE.COUNT > PRINT.TO THEN
        PRINT.TO = EXPAND.DISPLAY.LINE.COUNT
    END

    FOR PRINT.LOOP = 1 TO PRINT.TO
        TEXT = MACRO.DISPLAY.LINE<PRINT.LOOP> SHORTCUT.MASK
        TEXT := " ":EXPAND.DISPLAY.LINE<PRINT.LOOP>
        GOSUB PRINT.TEXT
    NEXT PRINT.LOOP

    RETURN

CONVERT.SECTION: *********************************************************
* convert this.section to its final display output                       *
* sections should be entered in this format:                             *
*       section / subsection                                             *
**************************************************************************
    MAIN.SECTION = THIS.SECTION ["/", 1, 1]
    SUB.SECTION = THIS.SECTION ["/", 2, TO.THE.END]

    THIS.SECTION = DOWNCASE(CHANGE(MAIN.SECTION, " ", "."):": ":SUB.SECTION)

    RETURN

CONVERT.MACRO.PARAMETERS: ************************************************
* if this.parm.list has a value convert "%n" values in the parameter     *
* text to the passed parameter value names so they're easier to read     *
**************************************************************************
    IF THIS.PARM.LIST = "" THEN
        RETURN
    END

    FOR PARM.LOOP = 0 TO THIS.COUNT

        THIS.PARM = DOWNCASE(TRIM(THIS.PARM.LIST<PARM.LOOP + 1>))

        IF THIS.PARM <> "" THEN
            MACRO.LINE = CHANGE(MACRO.LINE, "%%":PARM.LOOP, THIS.PARM)
            MACRO.LINE = CHANGE(MACRO.LINE, "%":PARM.LOOP, THIS.PARM)
        END

    NEXT PARM.LOOP

    RETURN

SEND.LISTING: ************************************************************
* send the shortcut listing to its destination                           *
**************************************************************************

* case conversions before output
    IF SHORTCUT.UPCASE OR SHORTCUT.DOWNCASE THEN

        FOR LINE.LOOP = 1 TO OUT.BUFFER.COUNT

            THIS.LINE = OUT.BUFFER<LINE.LOOP>
            THIS.LENGTH = LEN(THIS.LINE)
            IN.QUOTES = @FALSE
            THIS.QUOTE = ""

            FOR CHAR.PTR = 1 TO THIS.LENGTH

                THIS.CHAR = THIS.LINE [CHAR.PTR, 1]
                BEGIN CASE

    * handle quotes
                    CASE IN.QUOTES AND THIS.QUOTE = THIS.CHAR
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR

    * up / down casing
                    CASE SHORTCUT.UPCASE
                        THIS.LINE [CHAR.PTR, 1] = UPCASE(THIS.CHAR)
                    CASE SHORTCUT.DOWNCASE
                        THIS.LINE [CHAR.PTR, 1] = DOWNCASE(THIS.CHAR)

                END CASE

            NEXT CHAR.PTR

            OUT.BUFFER<LINE.LOOP> = THIS.LINE

        NEXT LINE.LOOP

    END

* send it to an editor window if requested in the command line
    IF SEND.TO.WINDOW THEN

        FOR ADD.LINES = 1 TO 5
            TEXT = " "
            GOSUB PRINT.TEXT
        NEXT ADD.LINES

        UNIQUE.MACRO.LIST = ""

        FOR MACRO.LOOP = 1 TO MACRO.COUNT

            THIS.MACRO = MACRO.KEYWORD.LIST<MACRO.LOOP>

            LOCATE THIS.MACRO IN UNIQUE.MACRO.LIST SETTING THROWAWAY ELSE
                UNIQUE.MACRO.LIST<-1> = THIS.MACRO
            END

        NEXT MACRO.LOOP

        UNIQUE.MACRO.COUNT = DCOUNT(UNIQUE.MACRO.LIST, @AM)

        TEXT = SHORTCUT.COUNT:" shortcuts"
        GOSUB PRINT.TEXT
        TEXT = UNIQUE.MACRO.COUNT:" unique macros"
        GOSUB PRINT.TEXT
        TEXT = MACRO.COUNT:" total macros"
        GOSUB PRINT.TEXT
        TEXT = " "
        GOSUB PRINT.TEXT
        TEXT = SHORTCUT.COUNT + UNIQUE.MACRO.COUNT:" unique expressions"
        GOSUB PRINT.TEXT
        TEXT = SHORTCUT.COUNT + MACRO.COUNT:" total expressions"
        GOSUB PRINT.TEXT

        UD.VIEW.TEXT OUT.BUFFER, 0, 0, "Program", "Shortcuts", DRAW.BOXES

    END ELSE

        UD.CONVERT.BOXES CONVERT.BUFFER, OUT.BUFFER, DRAW.BOXES

        FOR LINE.LOOP = 1 TO OUT.BUFFER.COUNT
            PRINT CONVERT.BUFFER<LINE.LOOP>
        NEXT LINE.LOOP

    END

    RETURN


**************************************************************************
**************************************************************************
** listings / utility routines                                          **
**************************************************************************
**************************************************************************

COMMA.FOLD: **************************************************************
* print text.line, folding at commas and indenting wraparounds           *
**************************************************************************

* set folding width.  if we're displaying to a screen we only get 79
* characters.  if sending to a window we have more room
    IF SEND.TO.WINDOW THEN
        MAX.WIDTH = MAX.LINE.WIDTH.WINDOW
    END ELSE
        MAX.WIDTH = MAX.LINE.WIDTH.SCREEN
    END

    FOLDED.ARRAY = FOLD.ON.COMMA (TEXT.LINE, MAX.WIDTH, INDENT)
    FOLDED.COUNT = DCOUNT(FOLDED.ARRAY, @AM)

    FOR FOLD.LOOP = 1 TO FOLDED.COUNT
        TEXT = FOLDED.ARRAY<FOLD.LOOP>
        GOSUB PRINT.TEXT
    NEXT FOLD.LOOP

    RETURN

BOX.LINE: ****************************************************************
* start or stop a box                                                    *
**************************************************************************
    IF NOT(SHORT.LIST) THEN
        TEXT = STR("*", BOX.WIDTH)
        GOSUB PRINT.TEXT
    END

    RETURN

BOX.TEXT.LEFT: ***********************************************************
* display text left-justified with the top of a box added to it          *
**************************************************************************
    IF NOT(SHORT.LIST) THEN
        TEXT := " "
        TEXT := STR("*", BOX.WIDTH - LEN(TEXT))
    END

    GOSUB PRINT.TEXT

    RETURN


BOX.TEXT: ****************************************************************
* display text boxed.  if text is null we'll print the top or bottom     *
* of the box if we're not doing a short list.  otherwise we'll print     *
* text in the middle of a box that's box.width characters wide           *
**************************************************************************
    IF NOT(SHORT.LIST) THEN
        TEXT = "* ":(TEXT BOX.MASK):" *"
    END

    IF TEXT <> "" THEN
        GOSUB PRINT.TEXT
    END

    RETURN

BANNER.TEXT: *************************************************************
* convert BANNER.TEXT to a banner and print it                           *
**************************************************************************
    SAVE.PAD.BOX = PAD.BOX
    PAD.BOX = @FALSE

    IF NOT(SEND.TO.WINDOW) THEN
        BANNER.MASK = "L#79"
    END ELSE
        BANNER.MASK = "L#300"
    END

* do a fancy case conversion on banner.text
    IF LIST.DOT THEN

        BANNER.TEXT.OUT = BANNER.TEXT

    END ELSE

        BANNER.TEXT.OUT = ""
        WORD.COUNT = DCOUNT(BANNER.TEXT ," ")

        FOR WORD.LOOP = 1 TO WORD.COUNT

             THIS.WORD = BANNER.TEXT [" ", WORD.LOOP, 1]
             THIS.WORD = UPCASE(THIS.WORD [1, 1]):DOWNCASE(THIS.WORD [2, TO.THE.END])

             IF WORD.LOOP = 1 THEN
                 BANNER.TEXT.OUT = THIS.WORD
             END ELSE
                 BANNER.TEXT.OUT := " ":THIS.WORD
             END

        NEXT WORD.LOOP

    END

    BANNER = UD.BANNER (BANNER.TEXT.OUT)

    FOR DOWN = 1 TO 7
        TEXT = BANNER<DOWN> BANNER.MASK
        GOSUB PRINT.TEXT
    NEXT DOWN

    TEXT = " "
    GOSUB PRINT.TEXT

    PAD.BOX = SAVE.PAD.BOX

    RETURN

PRINT.TEXT: **************************************************************
* print text and add it to an output buffer                              *
**************************************************************************
    TEXT = TRIM(TEXT, " ", "T")
    TEXT.LEN = LEN(TEXT)

    BEGIN CASE

* if box padding is turned off don't pad
        CASE NOT(PAD.BOX)

* if this line is shorter than box.width let's pad it out
*     if this line is mostly asterisk at the end pad it out with more asterisks
        CASE TEXT.LEN < BOX.WIDTH AND TEXT [TEXT.LEN - 4, 5] = STR("*", 5)
            TEXT := STR("*", BOX.WIDTH - TEXT.LEN)

*     if this line ends in a single asterisk move it out so the line is
*     padded to the right width
        CASE TEXT.LEN < BOX.WIDTH AND TEXT [TEXT.LEN - 1, 2] = " *"
            TEXT = TEXT [1, TEXT.LEN - 2]:SPACE(BOX.WIDTH - TEXT.LEN):" *"

* line is too long and the extra is asterisks.  chop off the extra asterisks
        CASE TEXT.LEN > BOX.WIDTH AND TEXT [TEXT.LEN - 4, 5] = STR("*", 5)
            LOOP UNTIL TEXT.LEN <= BOX.WIDTH OR TEXT [TEXT.LEN, 1] <> "*" OR TEXT.LEN = 0
                TEXT.LEN -= 1
                TEXT = TEXT [1, TEXT.LEN]
            REPEAT

* line is too long and it's the outside of a box.  remove some of the
* inside text and put the box side back
        CASE TEXT.LEN > BOX.WIDTH AND TEXT [TEXT.LEN - 1, 2] = " *"
            TEXT = TEXT [1, BOX.WIDTH - 2]:" *"

    END CASE

    OUT.BUFFER.COUNT += 1

    IF OUT.BUFFER.COUNT = 1 THEN
        OUT.BUFFER = TEXT
    END ELSE
        OUT.BUFFER := @AM:TEXT
    END

    RETURN

OUTPUT.TEXT: *************************************************************
* send it to an editor window if requested in the command line and       *
* print it out if not                                                    *
**************************************************************************
    IF SEND.TO.WINDOW THEN

        TEXT = " "
        GOSUB PRINT.TEXT
        UD.VIEW.TEXT OUT.BUFFER, 0, 0, "Display.":OBJECT.FILENAME, OBJECT.NAME, DRAW.BOXES

    END ELSE

        UD.CONVERT.BOXES CONVERT.BUFFER, OUT.BUFFER, DRAW.BOXES

        FOR LINE.LOOP = 1 TO OUT.BUFFER.COUNT
            PRINT CONVERT.BUFFER<LINE.LOOP>
        NEXT LINE.LOOP

    END

    RETURN


**************************************************************************
**************************************************************************
** user interface / aborting                                            **
**************************************************************************
**************************************************************************

WAIT: ********************************************************************
* wait for an <enter> to continue                                        *
**************************************************************************
    IF SKIP.WAITS THEN
        RETURN
    END

* if we're running in repair mode we'll use an input statement to get the
* response.  if there's an editor window open and it's closed while waiting
* for this input the editor window won't close properly so we only want
* to do this if we have to.  if we're not in repair mode we'll use ud.inp
* so that editor windows will close properly

    PRINT HOLDOFF$
    PRINT

    LOOP UNTIL @FALSE

        PRINT REV$:'<enter>':NORM$:' to ':REV$:'continue':NORM$:', ':
        PRINT REV$:'"Q"uit':NORM$:' or ':
        PRINT REV$:'"N"o':NORM$:' more pausing: ':

        IF REPAIR.MODE THEN

IN$$1:      INPUT WAIT.RESPONSE

        END ELSE

            WAIT.RESPONSE = UD.INP(-1, -1, 5, "", "", @TRUE)
            PRINT

            WAIT.RESPONSE = UPCASE(WAIT.RESPONSE)

* if there was a mouse click get the word the mouse clicked on
            IF PUSHMENU = 9999 THEN

                UD.GET.MOUSE.POSITION MOUSE.XCOORD, MOUSE.YCOORD
                SYS.SCREEN.CAPTURE SCREEN.TEXT

                SCREEN.LINE = SCREEN.TEXT<MOUSE.YCOORD>

                SPACE.COUNT = COUNT (SCREEN.LINE [1, MOUSE.XCOORD + 1], " ")
                SCREEN.WORD = SCREEN.LINE [" ", SPACE.COUNT + 1, 1]

                PUSHMENU = 0

                BEGIN CASE

                    CASE SCREEN.WORD = "<enter>" OR SCREEN.WORD = "continue"
                        WAIT.RESPONSE = ""

                    CASE SCREEN.WORD = '"Q"uit'
                        WAIT.RESPONSE = "Q"

                    CASE SCREEN.WORD = '"N"o'
                        WAIT.RESPONSE = "N"

                    CASE 1
                        WAIT.RESPONSE = "*****"

                END CASE

            END

        END

* move cursor back up to the "continue" line, blank it out, and move it
* up one more line so that the display continues as if the "wait" message
* was never there
        PRINT CHAR(26):CHAR(13):SPACE(78):CHAR(13):CHAR(26):

* process the response
        WAIT.RESPONSE = UPCASE(TRIM(WAIT.RESPONSE)) [1, 1]

        BEGIN CASE

            CASE PUSHMENU <> 0
                PRINT
                PRINT "Cannot use menu functions from here"
                PRINT

            CASE F12
                PRINT
                GOSUB WRAPUP

            CASE QUIT
                QUIT = @FALSE
                F12 = @FALSE
                RETURN

            CASE WAIT.RESPONSE = ""
                RETURN

            CASE WAIT.RESPONSE = "X" OR WAIT.RESPONSE = "Q"
                PRINT
                GOSUB WRAPUP

            CASE WAIT.RESPONSE = "N"
                SKIP.WAITS = @TRUE
                RETURN

        END CASE

    REPEAT

    RETURN

CHECK.ABORT: *************************************************************
* check for user abort.  check if the user has hit an escape or f12.  if *
* so, validate that they want to exit and exit or not                    *
**************************************************************************
    CHECK.ABORT.START.DATE = DATE()
    CHECK.ABORT.START.TIME = TIME()

    IF CHECK.USER.ABORT THEN

        SINCE.LAST.CHECK.ABORT = (DATE() - LAST.CHECK.ABORT.DATE) * 24 * 60 * 60 + (TIME() - LAST.CHECK.ABORT.TIME)
      
        IF SINCE.LAST.CHECK.ABORT >= CHECK.ABORT.EVERY THEN

            ABORT.MESSAGE = "Are you sure you want to"
            ABORT.MESSAGE<3> = "abort this compile?"

            USER.ABORT = UD.CHECK.ABORT("Compile", ABORT.MESSAGE)

            IF USER.ABORT THEN
                GOSUB WRAPUP
            END

        END

        LAST.CHECK.ABORT.DATE = DATE()
        LAST.CHECK.ABORT.TIME = TIME()

    END

    CHECK.ABORT.END.DATE = DATE()
    CHECK.ABORT.END.TIME = TIME()
    ABORT.ELAPSED.TIME += TIME.ELAPSED (CHECK.ABORT.START.DATE, CHECK.ABORT.START.TIME)

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / main                                                  **
**************************************************************************
**************************************************************************

UPDATE.DOT.NET.OBJECT: ***************************************************
* create class object code for .net for the current object and export    *
* it to the shared eclipse object folder on the client pc                *
**************************************************************************

* in order to export the dotnet class we need to have dot net enabled,
* dot need exports enabled and the object has to exist
    IF NOT(DOT.NET.ENABLED) OR NOT(DO.DOT.NET.EXPORTS) OR NOT(OBJECT.EXISTS) THEN
        RETURN
    END

* if the obj.net file doesn't exist we can't export the dotnet class so
* don't bother to update
    IF NOT(OBJ.NET.EXISTS) THEN
        PRINT "Can't update .net--OBJ.NET file does not exist"
        RETURN
    END

* build the name for the .net class
    DOT.NET.CLASS.NAME = DOT.NET (OBJECT.NAME, "", "")
    DOT.OBJECT = DOT.NET.CLASS.NAME
    DOT.NET.NAME = DOT.NET.CLASS.NAME:DOT.NET.FILE.EXTENSION

    IF NOT(BRIEF) AND DOT.NET.EXPORT.DRIVE <> "" AND DOT.NET.EXPORT.PATH <> "" THEN

        IF NOT(ONLY.DOT.NET.EXPORTS) OR FIRST.DOTNET.EXPORT THEN
            PRINT
        END

    END

    GOSUB CREATE.DOT.NET.CLASS 
    GOSUB EXPORT.DOT.NET.CLASS

    FIRST.DOTNET.EXPORT = @FALSE

    IF DETAILS THEN
        GOSUB LIST.DOT.NET.CODE
    END

* update permissions for the dotnet object in obj.net
* set permissions for the source program
    PERMIT.FILE = "OBJ.NET"
    PERMIT.ITEM = DOT.NET.NAME
    GOSUB SET.PERMISSIONS

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / create class                                          **
**************************************************************************
**************************************************************************

CREATE.DOT.NET.CLASS: ****************************************************
* create net.code with object code for a .net class for the current      *
* object                                                                 *
**************************************************************************
    DOT.NET.START.DATE = DATE()
    DOT.NET.START.TIME = TIME()

    NET.CODE = ""
    NET.CODE.LINES = 0
    NET.INDENT = 0
    EACH.NET.INDENT = 4

    NET.METHOD.COUNT = 0

    NET.COMMENT.START = DOT.NET.COMMENT.PREFIX
    NET.COMMENT.START.LEN = LEN(NET.COMMENT.START)

    BOX.COMMENT.START = CHANGE(NET.COMMENT.START, "*", "")

    GOSUB START.DOT.NET.CLASS

    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTIES

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** public properties.  these properties reside on the uniVerse" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** server and are set and fetched with server data calls" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** through the GetProperty and PutProperty methods which" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** call the get.property and put.property methods in" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** uniVerse" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB CREATE.DOT.NET.PROPERTIES

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** default methods common to all uniVerse objects" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB CREATE.DOT.NET.NEW.METHOD
    GOSUB CREATE.DOT.NET.RESET.METHOD
    GOSUB CREATE.DOT.NET.DESTROY.METHOD
    GOSUB CREATE.DOT.NET.GET.METHOD
    GOSUB CREATE.DOT.NET.PUT.METHOD
    GOSUB CREATE.DOT.NET.COPY.METHOD

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** object methods specific to this object" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB CREATE.DOT.NET.USER.METHODS

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** utilities" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB CREATE.DOT.NET.CHECK.OBJECT

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN
        GOSUB CREATE.DOT.NET.ERROR.DISPLAY
    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN
        GOSUB CREATE.DOT.NET.ERROR.THROW
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** cleanup" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB CREATE.DOT.NET.FINALIZE.METHOD

    GOSUB END.DOT.NET.CLASS

    DOT.NET.END.DATE = DATE()
    DOT.NET.END.TIME = TIME()
    DOT.NET.ELAPSED.TIME += TIME.ELAPSED (DOT.NET.START.DATE, DOT.NET.START.TIME)
    DOT.NET.COUNT += 1

*   IF NOT(BRIEF) THEN
*       PRINT "    Exported ":NET.METHOD.COUNT:" .net methods."
*   END

    RETURN

START.DOT.NET.CLASS: *****************************************************
* code the beginning of the .net class                                   *
**************************************************************************

* add imports
    IF DOT.NET.IMPORT.COUNT > 0 THEN

        FOR IMPORT.LOOP = 1 TO DOT.NET.IMPORT.COUNT

            CODE = "Imports ":DOT.NET.IMPORT.LIST<IMPORT.LOOP>
            GOSUB ADD.NET.CODE

        NEXT IMPORT.LOOP

        CODE = " "
        GOSUB ADD.NET.CODE

    END

* add the namespace structure if set up
    IF CREATE.DOT.NET.NAMESPACE THEN

        IF UPCASE(DOT.NET.NAMESPACE) = "CLASSNAME" THEN
            NAMESPACE = DOT.NET.CLASS.NAME
        END ELSE
            NAMESPACE = DOT.NET.NAMESPACE
        END

        CODE = "Namespace ":NAMESPACE
        GOSUB ADD.NET.CODE
        CODE = " "
        GOSUB ADD.NET.CODE

    END

    CODE = "Public Class ":DOT.NET.CLASS.NAME
    GOSUB ADD.NET.CODE

* add object comments beginning with the first comment line found
    START.PTR = 0
    THIS.LINE = ""
    SETREM 0 ON OBJECT.CODE

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES UNTIL START.PTR <> 0

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        IF TRIM(THIS.LINE) [1, 1] = "*" THEN
            START.PTR = LINE.LOOP
        END

    NEXT LINE.LOOP

* add comment lines to the .net class until we hit a non-comment line
    IF THIS.LINE <> "" THEN
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:THIS.LINE
        GOSUB ADD.NET.CODE
    END

    IF START.PTR <> 0 THEN

        END.PTR = 0

        FOR LINE.LOOP = START.PTR + 1 TO OBJECT.CODE.LINES UNTIL END.PTR <> 0

            REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

            IF TRIM(THIS.LINE) [1, 1] = "*" THEN
                CODE = NET.COMMENT.START:THIS.LINE
                GOSUB ADD.NET.CODE
            END ELSE
                END.PTR = LINE.LOOP - 1
            END

        NEXT LINE.LOOP

    END

    CODE = " "
    GOSUB ADD.NET.CODE

* time / date / exported by stamp
    CODE = NET.COMMENT.START:"exported"
    CODE := " ":OCONV(DATE(), "D4/"):" ":OCONV(TIME(), "MTHS")

    IF USER.NAME <> "" THEN
        CODE := " by ":DOWNCASE(USER.NAME):" (":DOWNCASE(USER.ID):")"
        GOSUB ADD.NET.CODE
    END ELSE
        CODE := " by ":DOWNCASE(USER.ID)
    END

    CODE = NET.COMMENT.START:"from ":UV.HOST.NAME
    IF UV.HOST.NAME <> UNIX.HOST.NAME THEN
        CODE := " (":UNIX.HOST.NAME:")"
    END
    GOSUB ADD.NET.CODE

    CODE = NET.COMMENT.START:"compiler version: ":PRECOMPILER.VERSION
    IF PRECOMPILER.VERSION.DATE <> "" THEN
        CODE := ", ":OCONV(PRECOMPILER.VERSION.DATE, "D4/")
    END
    GOSUB ADD.NET.CODE

* add class properties
    NET.INDENT += 1

    CREATE.TYPE = "Public Property"

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** default public properties.  these properties are local," "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** residing in the local object, not in the uniVerse object" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"data connection object.  handles connecting with uniVerse"
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"as well as all data calls"
    GOSUB ADD.NET.CODE

    CODE = CREATE.TYPE:" DataConnection as UVObjects.UVServer"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"object variables used to reference the uniVerse object"
    GOSUB ADD.NET.CODE

    CODE = CREATE.TYPE:" ObjectName as String"
    GOSUB ADD.NET.CODE
    CODE = CREATE.TYPE:" ObjectHandle as String"
    GOSUB ADD.NET.CODE
    CODE = CREATE.TYPE:" RegistrySourceId as String"
    GOSUB ADD.NET.CODE
    CODE = CREATE.TYPE:" ObjectExists as Boolean"
    GOSUB ADD.NET.CODE

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE OR DOT.NET.INCLUDE.THROW.ERROR.CODE THEN
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"object error message and error handling:"
        GOSUB ADD.NET.CODE
    END ELSE
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"object error message"
        GOSUB ADD.NET.CODE
    END

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN

        CODE = NET.COMMENT.START:"ErrorDisplay:        set to automatically display object"
        GOSUB ADD.NET.CODE

        IF DOT.NET.ERRORS.USE.MESSAGE.BOX THEN
            CODE = NET.COMMENT.START:"                     errors in a MessageBox"
        END ELSE
            CODE = NET.COMMENT.START:"                     errors in an ErrorForm"
        END
        GOSUB ADD.NET.CODE

        CODE = NET.COMMENT.START:"HideErrorSubroutine: set to remove the object and method"
        GOSUB ADD.NET.CODE

        IF DOT.NET.ERRORS.USE.MESSAGE.BOX THEN
            CODE = NET.COMMENT.START:"                     names from the MessageBox error display"
        END ELSE
            CODE = NET.COMMENT.START:"                     names from the ErrorForm error display"
        END
        GOSUB ADD.NET.CODE

    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN
        CODE = NET.COMMENT.START:"ThrowErrors:         set to throw an errors back to the"
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"                     calling routine"
        GOSUB ADD.NET.CODE
    END

    CODE = CREATE.TYPE:" ErrorMessage As String"
    GOSUB ADD.NET.CODE

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = CREATE.TYPE:" ErrorDisplay As Boolean"
        GOSUB ADD.NET.CODE
        CODE = CREATE.TYPE:" HideErrorSubroutine As Boolean"
        GOSUB ADD.NET.CODE
    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN
        CODE = CREATE.TYPE:" ThrowErrors As Boolean"
        GOSUB ADD.NET.CODE
    END

    IF DOT.NET.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"properties recording the last uniVerse call.  LastCallTime"
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"is in milliseconds"
        GOSUB ADD.NET.CODE

        CODE = CREATE.TYPE:" LastMethodCall As String"
        GOSUB ADD.NET.CODE
        CODE = CREATE.TYPE:" LastSubroutineCall As String"
        GOSUB ADD.NET.CODE
        CODE = CREATE.TYPE:" LastCallTime As Integer"
        GOSUB ADD.NET.CODE

    END ELSE

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = CREATE.TYPE:" LastCallTime As Integer"
        GOSUB ADD.NET.CODE

    END

    NET.INDENT -= 1

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / create properties                                     **
**************************************************************************
**************************************************************************

CREATE.DOT.NET.DEFAULT.PROPERTIES: ***************************************
* add code to the .net object to create default public properties        *
**************************************************************************
    IF NOT(GET.SET.DOT.NET.DEFAULT.PROPERTIES) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"** get / puts for default public properties" "L#71":" **"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"data connection object.  handles connecting with uniVerse"
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"as well as all data calls"
    GOSUB ADD.NET.CODE

    THIS.PROPERTY = "DataConnection"
    THIS.TYPE = "UVObjects.UVServer"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"object variables used to reference the uniVerse object"
    GOSUB ADD.NET.CODE

    THIS.PROPERTY = "ObjectName"
    THIS.TYPE = "String"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    THIS.PROPERTY = "ObjectHandle"
    THIS.TYPE = "String"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    THIS.PROPERTY = "RegistrySourceId"
    THIS.TYPE = "String"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    THIS.PROPERTY = "ObjectExists"
    THIS.TYPE = "Boolean"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"object error message and error handling"
    GOSUB ADD.NET.CODE

    THIS.PROPERTY = "ErrorMessage"
    THIS.TYPE = "String"
    GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN
        THIS.PROPERTY = "ErrorDisplay"
        THIS.TYPE = "Boolean"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY
        THIS.PROPERTY = "HideErrorSubroutine"
        THIS.TYPE = "Boolean"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY
    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN
        THIS.PROPERTY = "ThrowErrors"
        THIS.TYPE = "Boolean"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY
    END

    IF DOT.NET.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"properties recording the last uniVerse call.  LastCallTime"
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"is in milliseconds"
        GOSUB ADD.NET.CODE

        THIS.PROPERTY = "LastMethodCall"
        THIS.TYPE = "String"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

        THIS.PROPERTY = "LastSubroutineCall"
        THIS.TYPE = "String"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

        THIS.PROPERTY = "LastCallTime"
        THIS.TYPE = "Integer"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    END ELSE

        CODE = " "
        GOSUB ADD.NET.CODE
        THIS.PROPERTY = "LastCallTime"
        THIS.TYPE = "Integer"
        GOSUB CREATE.DOT.NET.DEFAULT.PROPERTY

    END

    RETURN

CREATE.DOT.NET.DEFAULT.PROPERTY: *****************************************
* add .net code to create this.property                                  *
**************************************************************************
    FOR BLANK.LOOP = 1 TO DOT.NET.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.NET.CODE
    NEXT BLANK.LOOP

    CODE = "Public Property ":THIS.PROPERTY:"() As ":THIS.TYPE
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Get"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = "Return ":THIS.PROPERTY
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End Get"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Set (ByVal NewValue As ":THIS.TYPE:")"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = THIS.PROPERTY:" = NewValue"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End Set"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Property"
    GOSUB ADD.NET.CODE

    RETURN

END.DOT.NET.CLASS: *******************************************************
* end the .net class                                                     *
**************************************************************************
*   NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Class"
    GOSUB ADD.NET.CODE

    IF CREATE.DOT.NET.NAMESPACE THEN
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = "End Namespace"
        GOSUB ADD.NET.CODE
    END

    RETURN

CREATE.DOT.NET.PROPERTIES: ***********************************************
* add code to the .net class to create method properties                 *
**************************************************************************
    IF PROP.COUNT = 0 THEN
        RETURN
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.PROPERTY = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.TYPE = DOT.NET.PARAMETER.TYPE
        THIS.LOCAL = PROP.LOCAL.LIST<PROP.LOOP>
        THIS.COMMENT.LIST = RAISE(PROP.COMMENT.LIST<PROP.LOOP>)

* only build property code for non-local properties that aren't dimensioned.
* we'll worry about dimensioned variables later
        IF NOT(THIS.LOCAL) AND THIS.DIM = "" THEN
            GOSUB CREATE.DOT.NET.PROPERTY
        END

    NEXT PROP.LOOP

    RETURN

CREATE.DOT.NET.PROPERTY: *************************************************
* add code to create a .net property for this.property                   *
**************************************************************************
    FOR BLANK.LOOP = 1 TO DOT.NET.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.NET.CODE
    NEXT BLANK.LOOP

    DOT.PROPERTY = DOT.NET (THIS.PROPERTY, "", "")

* if there are any comments ahead of this property add them to the code
    THIS.COMMENT.COUNT = DCOUNT(THIS.COMMENT.LIST, @AM)

    IF THIS.COMMENT.COUNT > 0 THEN

        FOR COMMENT.LOOP = 1 TO THIS.COMMENT.COUNT

            THIS.COMMENT = THIS.COMMENT.LIST<COMMENT.LOOP>

            IF THIS.COMMENT [1, 2] = "* " THEN
                THIS.COMMENT = THIS.COMMENT [3, TO.THE.END]
            END

            CODE = NET.COMMENT.START:THIS.COMMENT
            GOSUB ADD.NET.CODE

        NEXT COMMENT.LOOP

        CODE = " "
        GOSUB ADD.NET.CODE

    END

    CODE = "Public Property ":DOT.PROPERTY:" ("

    IF GET.SET.DOT.NET.MULTI THEN
        CODE := 'Optional AttrPtr = -999, '
        CODE := 'Optional ValPtr = -999, '
        CODE := 'Optional SubValPtr = -999'
    END

    CODE := ") As ":THIS.TYPE

    IF DOT.NET.FOLD.PARAMETERS AND GET.SET.DOT.NET.MULTI THEN
        THIS.PARM.COUNT = 3
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.NET.CODE
    END ELSE
        GOSUB ADD.NET.CODE
    END

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Get"
    GOSUB ADD.NET.CODE
    
    NET.INDENT += 1

    CODE = "Dim PropertyValue As ":THIS.TYPE:' = ""'
    GOSUB ADD.NET.CODE

    CODE = 'GetProperty (PropertyValue, "':THIS.PROPERTY:'"'

    IF GET.SET.DOT.NET.MULTI THEN
        CODE := ", AttrPtr, ValPtr, SubValPtr"
    END

    CODE := ")"
    GOSUB ADD.NET.CODE
    
    CODE = "Return PropertyValue"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End Get"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Set (ByVal NewValue As ":THIS.TYPE:")"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = 'PutProperty (NewValue, "':THIS.PROPERTY:'"'

    IF GET.SET.DOT.NET.MULTI THEN
        CODE := ", AttrPtr, ValPtr, SubValPtr"
    END

    CODE := ")"

    IF DOT.NET.FOLD.PARAMETERS AND GET.SET.DOT.NET.MULTI THEN
        THIS.PARM.COUNT = 5
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.NET.CODE
    END ELSE
        GOSUB ADD.NET.CODE
    END

    NET.INDENT -= 1

    CODE = "End Set"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Property"
    GOSUB ADD.NET.CODE

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / create methods                                        **
**************************************************************************
**************************************************************************

CREATE.DOT.NET.NEW.METHOD: ***********************************************
* create the "new" method for .net                                       *
**************************************************************************
    THIS.METHOD = NEW.KEYWORD

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"set the uniVerse connection for this object"
    GOSUB ADD.NET.CODE
    CODE = "DataConnection = NewDataConnection"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"initialize object status"
    GOSUB ADD.NET.CODE
    CODE = 'ObjectName = "':DOT.OBJECT:'"'
    GOSUB ADD.NET.CODE
    CODE = "ObjectExists = False"
    GOSUB ADD.NET.CODE
    CODE = "RegistrySourceId = ":'"1"'
    GOSUB ADD.NET.CODE

    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN

        CODE = " "
        GOSUB ADD.NET.CODE

        BEGIN CASE
            CASE DOT.NET.DEFAULT.DISPLAY.ERROR.TO.CONNECTION
                CODE = "ErrorDisplay = DataConnection.ErrorDisplay"
                GOSUB ADD.NET.CODE
            CASE DOT.NET.DEFAULT.DISPLAY.ERROR
                CODE = "ErrorDisplay = True"
                GOSUB ADD.NET.CODE
            CASE 1
                CODE = "ErrorDisplay = False"
                GOSUB ADD.NET.CODE
        END CASE

        CODE = "HideErrorSubroutine = False"
        GOSUB ADD.NET.CODE

    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN

        CODE = " "
        GOSUB ADD.NET.CODE

        BEGIN CASE
            CASE DOT.NET.DEFAULT.THROW.ERROR.TO.CONNECTION
                CODE = "ThrowErrors = DataConnection.ThrowErrors"
                GOSUB ADD.NET.CODE
            CASE DOT.NET.DEFAULT.THROW.ERROR
                CODE = "ThrowErrors = True"
                GOSUB ADD.NET.CODE
            CASE 1
                CODE = "ThrowErrors = False"
                GOSUB ADD.NET.CODE
        END CASE

    END

    GOSUB ADD.DOT.NET.METHOD.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"if ErrorMessage returns null then the new object creation was successful"
    GOSUB ADD.NET.CODE
    CODE = 'If ErrorMessage = "" Then'
    GOSUB ADD.NET.CODE
    CODE = "    ObjectExists = True"
    GOSUB ADD.NET.CODE
    CODE = "End If"
    GOSUB ADD.NET.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.RESET.METHOD: *********************************************
* create the "reset" method for .net                                     *
**************************************************************************
    THIS.METHOD = RESET.KEYWORD

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB ADD.DOT.NET.METHOD.CODE
    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.DESTROY.METHOD: *******************************************
* create the "destroy" method for .net                                   *
**************************************************************************
    THIS.METHOD = "DESTROY"

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB ADD.DOT.NET.METHOD.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "ObjectExists = False"
    GOSUB ADD.NET.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.GET.METHOD: ***********************************************
* create the "get" method for .net                                       *
**************************************************************************
    THIS.METHOD = GET.KEYWORD

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Dim UvAttrPtr As String"
    GOSUB ADD.NET.CODE
    CODE = "Dim UvValPtr As String"
    GOSUB ADD.NET.CODE
    CODE = "Dim UvSubvalPtr As String"
    GOSUB ADD.NET.CODE
    
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"set uv multivalue pointers"
    GOSUB ADD.NET.CODE
    CODE = 'UvAttrPtr = ""'
    GOSUB ADD.NET.CODE
    CODE = 'UvValPtr = ""'
    GOSUB ADD.NET.CODE
    CODE = 'UvSubvalPtr = ""'
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "If AttrPtr <> -999 Then UvAttrPtr = ToString (AttrPtr)"
    GOSUB ADD.NET.CODE
    CODE = "If ValPtr <> -999 Then UvValPtr = ToString (ValPtr)"
    GOSUB ADD.NET.CODE
    CODE = "If SubValPtr <> -999 Then UvSubvalPtr = ToString (SubvalPtr)"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.NET.CODE
    CODE = "CheckObjectExists"
    GOSUB ADD.NET.CODE

    GOSUB ADD.DOT.NET.METHOD.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.PUT.METHOD: ***********************************************
* create the "put" method for .net                                       *
**************************************************************************
    THIS.METHOD = PUT.KEYWORD

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Dim UvAttrPtr As String"
    GOSUB ADD.NET.CODE
    CODE = "Dim UvValPtr As String"
    GOSUB ADD.NET.CODE
    CODE = "Dim UvSubvalPtr As String"
    GOSUB ADD.NET.CODE
    
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"set uv multivalue pointers"
    GOSUB ADD.NET.CODE
    CODE = 'UvAttrPtr = ""'
    GOSUB ADD.NET.CODE
    CODE = 'UvValPtr = ""'
    GOSUB ADD.NET.CODE
    CODE = 'UvSubvalPtr = ""'
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "If AttrPtr <> -999 Then UvAttrPtr = ToString (AttrPtr)"
    GOSUB ADD.NET.CODE
    CODE = "If ValPtr <> -999 Then UvValPtr = ToString (ValPtr)"
    GOSUB ADD.NET.CODE
    CODE = "If SubValPtr <> -999 Then UvSubvalPtr = ToString (SubvalPtr)"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.NET.CODE
    CODE = "CheckObjectExists"
    GOSUB ADD.NET.CODE

    GOSUB ADD.DOT.NET.METHOD.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.COPY.METHOD: **********************************************
* create the "copy" method for .net                                      *
**************************************************************************
    RETURN

    THIS.METHOD = "COPY"

    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.NET.CODE
    CODE = "CheckObjectExists"
    GOSUB ADD.NET.CODE

    GOSUB ADD.DOT.NET.METHOD.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

CREATE.DOT.NET.USER.METHODS: *********************************************
* create the user method for .net                                        *
**************************************************************************
    FOR CREATE.METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<CREATE.METHOD.LOOP>
        THIS.METHOD.TYPE = METHOD.TYPE.LIST<CREATE.METHOD.LOOP>
        THIS.METHOD.LOCAL = METHOD.LOCAL.LIST<CREATE.METHOD.LOOP>

* create .net methods for object methods that aren't local and are
* "normal" methods--ie, no phantom wrappers, tcl wrappers, etc.  "common"
* and "redim" may also be in the method list.  skip those as well.
* default methods have already been build so skip those.
        IF NOT(THIS.METHOD.LOCAL) AND THIS.METHOD.TYPE = METHOD.KEYWORD THEN
            IF THIS.METHOD <> COMMON.ROUTINE.METHOD AND THIS.METHOD <> REDIM.KEYWORD THEN
                LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY ELSE
                    GOSUB CREATE.DOT.NET.USER.METHOD
                END
            END
        END

    NEXT CREATE.METHOD.LOOP

    RETURN

CREATE.DOT.NET.ERROR.DISPLAY: ********************************************
* create the "AutoErrorDisplay" method for a dotnet class.  this method  *
* will display ErrorMessage (ERROR.MESSAGE) via a msgbox window          *
* if the error message is not null                                       *
**************************************************************************
    FOR BLANK.LOOP = 1 TO DOT.NET.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.NET.CODE
    NEXT BLANK.LOOP

    CODE = "Private Sub AutoErrorDisplay()"
    GOSUB ADD.NET.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"* display a method error if there is one" "L#72":" *"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"if there is an error message display it"
    GOSUB ADD.NET.CODE
    CODE = 'If ErrorDisplay and ErrorMessage <> "" Then'
    GOSUB ADD.NET.CODE
    
    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Dim DisplayMessage as String = ErrorMessage"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "If HideErrorSubroutine Then"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = 'Dim ColonPtr as Integer = Instr (ErrorMessage, ": ")'
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "If ColonPtr > 0 Then"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = "DisplayMessage = Mid (DisplayMessage, ColonPtr + 1)"
    GOSUB ADD.NET.CODE
    CODE = 'DisplayMessage = UVObjects.Trim (DisplayMessage, "B")'
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Else"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    IF DOT.NET.UPDATE.LAST.CALL THEN

        CODE = NET.COMMENT.START:"add method information to DisplayMessage"
        GOSUB ADD.NET.CODE
        CODE = "DisplayMessage &= Chr(13) & Chr(13)"
        GOSUB ADD.NET.CODE
        CODE = 'DisplayMessage &= "Object: " & ObjectName & Chr(13)'
        GOSUB ADD.NET.CODE
        CODE = 'DisplayMessage &= "Method: " & LastMethodCall & Chr(13)'
        GOSUB ADD.NET.CODE
        CODE = 'DisplayMessage &= "UV Subroutine: " & LastSubroutineCall & Chr(13)'
        GOSUB ADD.NET.CODE

        CODE = " "
        GOSUB ADD.NET.CODE

    END

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE

* show the error using MessageBox or ShowError (which uses ErrorForm from the
* FormsPrimitives dotnet file)

* the "HideErrorSubroutine" flag is used in the object to display errors
* without the technical information (ie, the object and method, etc).  this
* presents an error that makes more sense to a non-technical (ie, a normal
* human) user.  if HideErrorSubroutine is set we'll use ShowMessage to display
* the error rather than ShowError
    IF DOT.NET.ERRORS.USE.MESSAGE.BOX THEN

        CODE = "MessageBox.Show (DisplayMessage)"
        GOSUB ADD.NET.CODE

    END ELSE

        CODE = "If HideErrorSubroutine Then"
        GOSUB ADD.NET.CODE

        NET.INDENT += 1

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = 'ShowMessage (DisplayMessage)'
        GOSUB ADD.NET.CODE
        CODE = " "
        GOSUB ADD.NET.CODE

        NET.INDENT -= 1

        CODE = "Else"
        GOSUB ADD.NET.CODE

        NET.INDENT += 1

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = 'ShowError (DisplayMessage, ObjectName & " Error")'
        GOSUB ADD.NET.CODE
        CODE = " "
        GOSUB ADD.NET.CODE

        NET.INDENT -= 1

        CODE = "End If"
        GOSUB ADD.NET.CODE

    END

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End If"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Sub"
    GOSUB ADD.NET.CODE

    RETURN

CREATE.DOT.NET.ERROR.THROW: **********************************************
* create the "AutoErrorThrow" method for a dotnet class.  this method    *
* throw an error back to the calling program if the error message is not *
* null                                                                   *
**************************************************************************
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Private Sub AutoErrorThrow()"
    GOSUB ADD.NET.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"* throw a method error if there is one" "L#72":" *"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"if there is an error message throw it"
    GOSUB ADD.NET.CODE
    CODE = 'If ThrowErrors and ErrorMessage <> "" Then'
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = "Throw New ArgumentException(ErrorMessage)"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Sub"
    GOSUB ADD.NET.CODE

    RETURN

CREATE.DOT.NET.CHECK.OBJECT: *********************************************
* create a dotnet method for CheckObjectExists.  if the object hasn't    *
* been created successfully generate an error                            *
**************************************************************************
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Private Sub CheckObjectExists()"
    GOSUB ADD.NET.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"* generate an exception if the object hasn't been created" "L#72":" *"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = 'ErrorMessage = ""'
    GOSUB ADD.NET.CODE

* test to make sure the object has been created
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"set an error if this object hasn't been created"
    GOSUB ADD.NET.CODE
    CODE = "If Not(ObjectExists) Then"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = 'ErrorMessage = ObjectName & ": Object has not been created"'
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

* test to make sure the uv connection is open
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"set an error if the data connection isn't open"
    GOSUB ADD.NET.CODE
    CODE = "If Not(DataConnection.ConnectionOpen) Then"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = 'ErrorMessage = ObjectName & ": UV Data Connection is not open"'
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

* auto error display
    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = "AutoErrorDisplay"
        GOSUB ADD.NET.CODE
    END

* auto error throw
    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN

        IF NOT(DOT.NET.INCLUDE.AUTO.DISPLAY.CODE) THEN
            CODE = " "
            GOSUB ADD.NET.CODE
        END

        CODE = "AutoErrorThrow"
        GOSUB ADD.NET.CODE

    END

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Sub"
    GOSUB ADD.NET.CODE

    RETURN

CREATE.DOT.NET.FINALIZE.METHOD: ******************************************
* create the "finalize" method for a dotnet class.  the "finalize"       *
* method is called when the class object is destroyed.  finalize will    *
* call the universe "destroy" method to remove the object from the       *
* universe object memory tables                                          *
**************************************************************************
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "Protected Overrides Sub Finalize()"
    GOSUB ADD.NET.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:"* clean up before destroying class" "L#72":" *"
    GOSUB ADD.NET.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"if the uniVerse connection is still open destroy uniVerse object"
    GOSUB ADD.NET.CODE
    CODE = "If DataConnection.ConnectionOpen Then"
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    CODE = "Destroy"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = "End If"
    GOSUB ADD.NET.CODE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "MyBase.Finalize()"
    GOSUB ADD.NET.CODE

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Sub"
    GOSUB ADD.NET.CODE

    RETURN

CREATE.DOT.NET.USER.METHOD: **********************************************
* create a single user method for .net                                   *
**************************************************************************
    GOSUB START.DOT.NET.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.NET.CODE
    CODE = "CheckObjectExists"
    GOSUB ADD.NET.CODE

    GOSUB ADD.DOT.NET.METHOD.CODE

    GOSUB END.DOT.NET.METHOD

    RETURN

START.DOT.NET.METHOD: ****************************************************
* add code to net.code to start this.method                              *
**************************************************************************
    STARTED.METHOD = @TRUE

    LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY THEN
        DEFAULT.METHOD = @TRUE
    END ELSE
        DEFAULT.METHOD = @FALSE
    END 

* convert the uv method name to the dotnet method name
    DOT.METHOD = DOT.NET (THIS.METHOD, DOT.NET.FROM.METHOD.LIST, DOT.NET.TO.METHOD.LIST)

    CODE = "Public Sub ":DOT.METHOD
    GOSUB PROCESS.DOT.NET.PARAMETERS
    CODE := PARAMETER.STRING

    FIRST.LINE.CODE = CODE

* if this method has any "special" parameters (file handles, etc) we won't
* export it
    IF HAS.SPECIAL.PARAMETERS THEN
        STARTED.METHOD = @FALSE
        RETURN
    END

* start the code for this dotnet class method
    FOR BLANK.LOOP = 1 TO DOT.NET.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.NET.CODE
    NEXT BLANK.LOOP

    CODE = FIRST.LINE.CODE

    IF DOT.NET.FOLD.PARAMETERS THEN
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.NET.CODE
    END ELSE
        GOSUB ADD.NET.CODE
    END

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.NET.CODE

    GOSUB ADD.DOT.NET.METHOD.COMMENTS

    NET.INDENT += 1

    RETURN

PROCESS.DOT.NET.PARAMETERS: **********************************************
* build parameter.string with the parameter call (with parenthesis) for  *
* this.method.                                                           *
**************************************************************************
    PARAMETER.STRING = ""

* if the method call has one or more parameters that's a "special" parameter
* then it has a file handle or select handle or something in the parameter
* list.  dotnet can't call these methods since we can't build a handle into
* the network message
    HAS.SPECIAL.PARAMETERS = @FALSE

* see if this.method is in method.list.  if it is then we'll get the parameter
* list and comments to add to the .net method code
    BEGIN CASE 

* these methods have no parameters in dotnet
        CASE THIS.METHOD = GET.KEYWORD
            NULL
        CASE THIS.METHOD = PUT.KEYWORD
            NULL

        CASE 1
            LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
                LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY ELSE
                    RETURN
                END
            END

    END CASE

* unload the parameter arrays.  some of the default methods have parameters
* but won't be in this table
    BEGIN CASE

* the reset method won't have any optional parameters
        CASE THIS.METHOD = RESET.KEYWORD
            GOSUB CLEAR.DOT.NET.PARAMETER.LIST

* the new method may have parameters but it has some additional parameters
* that other methods won't have
        CASE THIS.METHOD = NEW.KEYWORD
            GOSUB UNLOAD.DOT.NET.PARAMETER.LIST

* the destroy method won't have a parameter list
        CASE THIS.METHOD = DESTROY.KEYWORD
            GOSUB CLEAR.DOT.NET.PARAMETER.LIST

* calling "get.property" to return a property value    
        CASE THIS.METHOD = GET.KEYWORD
            THIS.PARM.LIST = "PROPERTY.VALUE,PROPERTY.NAME"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"
            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            THIS.OPTIONAL.LIST = "0,0,1,1,1"
            THIS.OPTIONAL.LIST = CHANGE (THIS.OPTIONAL.LIST, ",", @AM)

            THIS.DEFAULT.LIST = ",,-999,-999,-999"
            THIS.DEFAULT.LIST = CHANGE (THIS.DEFAULT.LIST, ",", @AM)

            THIS.SET.LIST = ""

            THIS.BYREF.LIST = "1,0,0,0,0"
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.SPECIAL.LIST = "0,0,0,0,0"
            THIS.SPECIAL.LIST = CHANGE (THIS.SPECIAL.LIST, ",", @AM)

            THIS.TYPE.LIST = DOT.NET.PARAMETER.TYPE:",String,Integer,Integer,Integer"
            THIS.TYPE.LIST = CHANGE (THIS.TYPE.LIST, ",", @AM)

* calling "put.property" to update a property value
        CASE THIS.METHOD = PUT.KEYWORD
            THIS.PARM.LIST = "PROPERTY.VALUE,PROPERTY.NAME"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"
            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            THIS.OPTIONAL.LIST = "0,0,1,1,1"
            THIS.OPTIONAL.LIST = CHANGE (THIS.OPTIONAL.LIST, ",", @AM)

            THIS.DEFAULT.LIST = ",,-999,-999,-999"
            THIS.DEFAULT.LIST = CHANGE (THIS.DEFAULT.LIST, ",", @AM)

            THIS.SET.LIST = ""

            THIS.BYREF.LIST = "0,0,0,0,0"
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.SPECIAL.LIST = "0,0,0,0,0"
            THIS.SPECIAL.LIST = CHANGE (THIS.SPECIAL.LIST, ",", @AM)

            THIS.TYPE.LIST = DOT.NET.PARAMETER.TYPE:",String,Integer,Integer,Integer"
            THIS.TYPE.LIST = CHANGE (THIS.TYPE.LIST, ",", @AM)

* calling any other method
        CASE 1
            GOSUB UNLOAD.DOT.NET.PARAMETER.LIST

    END CASE

* if we have any special parameters we can't export this method
    IF SUM (THIS.SPECIAL.LIST) <> 0 THEN
        HAS.SPECIAL.PARAMETERS = @TRUE
        RETURN
    END

* if this is a "new" method and we have no parameters we still need to add
* a parameter for the data connection
    IF THIS.PARM.COUNT = 0 AND THIS.METHOD = NEW.KEYWORD THEN
        PARAMETER.STRING := " (ByRef NewDataConnection as UVObjects.UVServer)"
    END

* if there are no parameters we can skip out
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

    PARAMETER.STRING = " ("

* the "new" dotnet method has an additional parameter.  this additional
* first parameter is the UVServer database handle
    IF THIS.METHOD = NEW.KEYWORD THEN
        PARAMETER.STRING := "ByRef NewDataConnection as UVObjects.UVServer, "
    END

* add each parameter to parameter.string
    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT 

        THIS.PARM = DOT.NET (THIS.PARM.LIST<PARM.LOOP>, "", "")
        THIS.OPTIONAL = THIS.OPTIONAL.LIST<PARM.LOOP>
        THIS.DEFAULT = THIS.DEFAULT.LIST<PARM.LOOP>

        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>
        THIS.TYPE = THIS.TYPE.LIST<PARM.LOOP>

        IF PARM.LOOP > 1 THEN
            PARAMETER.STRING := ", "
        END

* optional parameter
        IF THIS.OPTIONAL THEN
            PARAMETER.STRING := "Optional "
        END

* byref / byval
        BEGIN CASE
            CASE THIS.BYREF AND DOT.NET.INDICATE.BYREF
                PARAMETER.STRING := "ByRef "
            CASE NOT(THIS.BYREF) AND DOT.NET.INDICATE.BYVAL
                PARAMETER.STRING := "ByVal "
        END CASE

* parameter name
        PARAMETER.STRING := THIS.PARM

* variable type
        IF DOT.NET.PARAMETER.TYPE <> "" THEN
            PARAMETER.STRING := " As ":THIS.TYPE
        END

* specify a null value for optional parameters
        IF THIS.OPTIONAL THEN
            PARAMETER.STRING := ' = ':THIS.DEFAULT
        END

    NEXT PARM.LOOP

    PARAMETER.STRING := ")"

    RETURN

CLEAR.DOT.NET.PARAMETER.LIST: ********************************************
* set the parameters for the current dotnet method to null               *
**************************************************************************
    THIS.PARM.LIST = ""
    THIS.PARM.COUNT = 0

    THIS.OPTIONAL.LIST = ""
    THIS.DEFAULT.LIST = ""
    THIS.SET.LIST = ""
    THIS.BYREF.LIST = ""
    THIS.SPECIAL.LIST = ""
    THIS.TYPE.LIST = ""

    RETURN

UNLOAD.DOT.NET.PARAMETER.LIST: *******************************************
* unload the parameters for the current dotnet method from the method    *
* tables for method method.ptr                                           *
**************************************************************************
    THIS.PARM.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)

    THIS.OPTIONAL.LIST = RAISE(METHOD.PARM.OPTIONAL.LIST<METHOD.PTR>)
    THIS.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
    THIS.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)

    THIS.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
    THIS.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

    THIS.PARM.COUNT = METHOD.PARM.COUNT.LIST<METHOD.PTR>

* build the type and default lists from the dot net settings in the compile
* setup record
    THIS.TYPE.LIST = ""
    THIS.DEFAULT.LIST = ""

    FOR ADD.LOOP = 1 TO THIS.PARM.COUNT
        THIS.TYPE.LIST<ADD.LOOP> = DOT.NET.PARAMETER.TYPE
        THIS.DEFAULT.LIST<ADD.LOOP> = '""'
    NEXT ADD.LOOP

    RETURN

ADD.DOT.NET.METHOD.COMMENTS: *********************************************
* add comments to .net code for this.method                              *
**************************************************************************
    FOUND.COMMENTS = @FALSE 

    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE

        IF DEFAULT.METHOD THEN
            CODE = "* Default method "
        END ELSE
            CODE = "* User method "
        END

        CODE = (CODE:DOT.NET (THIS.METHOD, DOT.NET.FROM.METHOD.LIST, DOT.NET.TO.METHOD.LIST)) "L#72":" *"

        CODE = BOX.COMMENT.START:CODE
        GOSUB ADD.NET.CODE

        CODE = BOX.COMMENT.START:STR("*", 74)
        GOSUB ADD.NET.CODE

        RETURN

    END

* add method comment code into the .net method.  we'll start
* with the method's starting line and stop one line before the program
* code starts
    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR> - 1
    THIS.METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.PTR>

* if this is an inherited method fetch the called code from the object
* the method is inherited from
    IF THIS.METHOD.INHERITED THEN

        THIS.INHERIT.OBJECT = METHOD.INHERIT.OBJECT.LIST<METHOD.PTR>

        READ THIS.CALLED.CODE FROM OBJFILE, THIS.INHERIT.OBJECT ELSE
            THIS.CALLED.CODE = ""
        END

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = THIS.CALLED.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = ""
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = THIS.CALLED.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimiter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(THIS.CALLED.CODE, @AM, START.LINE - 1)
        END

        SETREM START.PTR ON THIS.CALLED.CODE
        FOR ADD.LINE.LOOP = START.LINE TO END.LINE

*           CODE = THIS.CALLED.CODE<ADD.LINE.LOOP>
            REMOVE CODE FROM THIS.CALLED.CODE SETTING THROWAWAY

            IF TRIM(CODE) = "" THEN
                ADD.LINE.LOOP = END.LINE + 1
            END ELSE
                CODE = BOX.COMMENT.START:CODE
                GOSUB ADD.NET.CODE
                FOUND.COMMENTS = @TRUE
            END

        NEXT ADD.LINE.LOOP

    END ELSE

* start.ptr may be on an empty line.  if the "method" statement wrapped
* around object.code<start.line> may be null as the parameters were
* wrapped up to the "method" line.  if start.ptr is on an empty line skip
* ahead until we're on a line that's not null
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL TRIM(THIS.COMMENT) <> "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = OBJECT.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
        END

        SETREM START.PTR ON OBJECT.CODE

        FOR ADD.LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY

* if we hit a null line stop adding comments.  if we hit a code line stop
* adding comments.  otherwise add the comment line to the dotnet code
            BEGIN CASE

                CASE TRIM(CODE) = ""
                    ADD.LINE.LOOP = END.LINE + 1

                CASE IS.CODE(CODE)
                    ADD.LINE.LOOP = END.LINE + 1
            
                CASE 1
                    CODE = BOX.COMMENT.START:CODE
                    GOSUB ADD.NET.CODE
                    FOUND.COMMENTS = @TRUE

            END CASE

        NEXT ADD.LINE.LOOP

    END

    RETURN

ADD.DOT.NET.METHOD.CODE: *************************************************
* add the method body code for the .net method                           *
**************************************************************************
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:THIS.METHOD

* initialize properties and set "last call" properties
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"initialize class properties"
    GOSUB ADD.NET.CODE
    CODE = 'ErrorMessage = ""'
    GOSUB ADD.NET.CODE

    IF DOT.NET.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = NET.COMMENT.START:"set last call properties"
        GOSUB ADD.NET.CODE
        CODE = 'LastMethodCall = "':DOT.METHOD:'"'
        GOSUB ADD.NET.CODE
        CODE = 'LastSubroutineCall = "':SUBROUTINE.NAME:'"'
        GOSUB ADD.NET.CODE

    END

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"call ":DOT.OBJECT:METHOD.DELIMITER
    CODE := DOT.METHOD:" in uniVerse via UVObjects"
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"by calling uniVerse subroutine ":SUBROUTINE.NAME
    GOSUB ADD.NET.CODE

    GOSUB START.DOT.NET.WITH

* build the dotnet call to the eclipse object method
    CODE = NET.COMMENT.START:"build a string array of the passed parameters"
    GOSUB ADD.NET.CODE

    BEGIN CASE

* call to the new method.  this call to the uniVerse subroutine will always
* have three extra parameters.  the first is the object handle, the second is
* error.message and the third is the source id.  after that are any method 
* parameters
        CASE THIS.METHOD = NEW.KEYWORD

            CODE = "Dim Parameters(":(THIS.PARM.COUNT + 3):") As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(":(THIS.PARM.COUNT + 3):") As String"
            GOSUB ADD.NET.CODE            
            CODE = " "
            GOSUB ADD.NET.CODE

* load the first two parameters for the object handle and error message
            CODE = NET.COMMENT.START:"the first three parameters for the subroutine version"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"of the method are always the object handle, the error"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"message and the registry source id"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = 'Parameters(2) = ""'
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(2) = "ErrorMessage"'
            END ELSE
                CODE = 'ParameterNames(2) = ""'
            END

            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = 'Parameters(3) = RegistrySourceId'
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(3) = "RegistryId"'
            END ELSE
                CODE = 'ParameterNames(3) = ""'
            END

            GOSUB ADD.NET.CODE

            EXTRA.PASSED.COUNT = 3

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

* call to the reset method.  this call to the uniVerse subroutine will always
* have one extra parameters,  the the object handle
        CASE THIS.METHOD = RESET.KEYWORD

            CODE = "Dim Parameters(":(THIS.PARM.COUNT + 1):") As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(":(THIS.PARM.COUNT + 1):") As String"
            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE

* load the first two parameters for the object handle and error message
            CODE = NET.COMMENT.START:"the first parameter for the subroutine version"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"of the reset method is the object handle"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

* for the destroy method we'll only have one parameter, the object handle
        CASE THIS.METHOD = DESTROY.KEYWORD

            CODE = "Dim Parameters(1) As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(1) As String"
            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE            

* load the first parameter for the object handle
            CODE = NET.COMMENT.START:"the subroutine version of the destroy method"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"only needs the object handle"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE

            EXTRA.PASSED.COUNT = 0

            TOTAL.PASSED.COUNT = 1

* for the get property method we'll have 10 parameters
        CASE THIS.METHOD = GET.KEYWORD

            CODE = "Dim Parameters(10) As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(10) As String"
            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE            

* load the first three parameters for the object handle, property name
* and returned value
            CODE = NET.COMMENT.START:"the first parameter for the get property call"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"is always the object handle"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE

* the actual call to the uniVerse get.property subroutine requires
* the parameter list in a different order and has some additional
* parameters that will be passed as nulls
            THIS.PARM.LIST = "PROPERTY.NAME,PROPERTY.VALUE"
            THIS.PARM.LIST := ",,,,"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"

            THIS.BYREF.LIST = "0,1,0,0,0,0,0,0,0"

            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.PARM.COUNT = DCOUNT (THIS.PARM.LIST, @AM)

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = 10

* for the put property method we'll have 10 parameters
        CASE THIS.METHOD = PUT.KEYWORD

            CODE = "Dim Parameters(10) As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(10) As String"
            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE            

* load the first two parameters for the object handle, property name
            CODE = NET.COMMENT.START:"the first parameter for the put property call"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"is always the object handle"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE

* the actual call to the uniVerse get.property subroutine requires
* the parameter list in a different order and has some additional
* parameters that will be passed as nulls
            THIS.PARM.LIST = "PROPERTY.NAME,PROPERTY.VALUE"
            THIS.PARM.LIST := ",,,,"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"

            THIS.BYREF.LIST = "0,0,0,0,0,0,0,0,0"

            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = 10

* any other methods we'll have a number of parameters that depends on
* the object method call
        CASE 1

* the call to the object method.  the call to the uniVerse subroutine will always
* have at least two parameters.  the first is the object handle and the second is
* error.message.  after that are any method parameters
            CODE = "Dim Parameters(":(THIS.PARM.COUNT + 2):") As String"
            GOSUB ADD.NET.CODE
            CODE = "Dim ParameterNames(":(THIS.PARM.COUNT + 2):") As String"
            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE

* load the first two parameters for the object handle and error message
            CODE = NET.COMMENT.START:"the first two parameters for the subroutine version"
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"of the method are always the object handle and error message"
            GOSUB ADD.NET.CODE

            CODE = "Parameters(1) = ObjectHandle"
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(1) = "ObjectHandle"'
            END ELSE
                CODE = 'ParameterNames(1) = ""'
            END

            GOSUB ADD.NET.CODE
            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = 'Parameters(2) = ""'
            GOSUB ADD.NET.CODE

            IF DOT.NET.PASS.PARAMETER.NAMES THEN
                CODE = 'ParameterNames(2) = "ErrorMessage"'
            END ELSE
                CODE = 'ParameterNames(2) = "ErrorMessage"'
            END

            GOSUB ADD.NET.CODE

            EXTRA.PASSED.COUNT = 2

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

        END CASE

* load up the method parameters
    GOSUB ADD.DOT.NET.PARAMETER.LOADING

* do the method call
    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = NET.COMMENT.START:"call the uniVerse objects method"
    GOSUB ADD.NET.CODE

* if we're building the "new" dotnet method to call the "new" eclipse method
* we'll usually want to call the "new.short" eclipse method.  the "new" eclipse
* method may have a list of parameters that return the child object handles.  we
* don't need these parameters and at this point we don't know what they are so
* calling the eclipse "new" routine would mean figuring out what these parameters
* are.  if we call the "new.short" we don't need the child handle variable list
* and we still create the object
    IF UPCASE(THIS.METHOD) = NEW.KEYWORD AND DOT.NET.NEW.CALLS.SHORT.NEW THEN
        CODE = '.CallMethod ("':UPCASE(OBJECT.NAME):'", "':UPCASE(NEW.SHORT.KEYWORD):'", '
        CODE := TOTAL.PASSED.COUNT:", Parameters, ParameterNames)"
        GOSUB ADD.NET.CODE
    END ELSE
        CODE = '.CallMethod ("':UPCASE(OBJECT.NAME):'", "':UPCASE(THIS.METHOD):'", '
        CODE := TOTAL.PASSED.COUNT:", Parameters, ParameterNames)"
        GOSUB ADD.NET.CODE
    END

* unload parameters from the call
    BEGIN CASE

* nothing needs to be unloaded for the "destroy" method
        CASE THIS.METHOD = DESTROY.KEYWORD
            NULL

* for the "new" method unload the object handle, error message, registry
* source id and then any other parameters
        CASE THIS.METHOD = NEW.KEYWORD

            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.NET.CODE
            CODE = "ObjectHandle = Parameters(1)"
            GOSUB ADD.NET.CODE
            CODE = "ErrorMessage = Parameters(2)"
            GOSUB ADD.NET.CODE
            CODE = "RegistrySourceId = Parameters(3)"
            GOSUB ADD.NET.CODE

            GOSUB ADD.DOT.NET.PARAMETER.UNLOADING

* for the "reset" method unload the object handle, registry source id and then
* any other parameters
        CASE THIS.METHOD = RESET.KEYWORD

            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.NET.CODE
            CODE = "ObjectHandle = Parameters(1)"
            GOSUB ADD.NET.CODE
*           CODE = "RegistrySourceId = Parameters(2)"
*           GOSUB ADD.NET.CODE

            GOSUB ADD.DOT.NET.PARAMETER.UNLOADING

* the "get" routines only need to unload the error message and property value
* parameters
        CASE THIS.METHOD = GET.KEYWORD
            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"unload the 'get value' parameters from the method call"
            GOSUB ADD.NET.CODE

            BEGIN CASE

                CASE DOT.NET.PARAMETER.TYPE = "Object"
                    CODE = ".PutParameterValue (PropertyValue, Parameters(3))"
                    GOSUB ADD.NET.CODE            

                CASE 1
                    CODE = "PropertyValue = Parameters(3)"
                    GOSUB ADD.NET.CODE            

            END CASE

* the "put" routines only need to unload the error message
        CASE THIS.METHOD = PUT.KEYWORD
            NULL

* any other methods
        CASE 1

            CODE = " "
            GOSUB ADD.NET.CODE
            CODE = NET.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.NET.CODE
            CODE = "ErrorMessage = Parameters(2)"
            GOSUB ADD.NET.CODE

            GOSUB ADD.DOT.NET.PARAMETER.UNLOADING

    END CASE

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "LastCallTime = .CallTime"
    GOSUB ADD.NET.CODE

    GOSUB END.DOT.NET.WITH

    RETURN

ADD.DOT.NET.PARAMETER.LOADING: *******************************************
* add code to the dotnet routine to load parameters into the "dotnet"    *
* array so that dotnet can call the uniVerse method                      *
**************************************************************************
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.NET.CODE

    CODE = NET.COMMENT.START:"set the passed method parameters"
    GOSUB ADD.NET.CODE

    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT

        THIS.PARM = THIS.PARM.LIST<PARM.LOOP>

* special case for get.property and put.property.  attr, val and subval
* pointers are passed as numeric values attr.ptr, val.ptr and subval.ptr.
* since optional parameters must be null they're copied to uv.attr.ptr,
* uv.val.ptr and uv.subval.ptr and called with these variables
        CALL.PARM = THIS.PARM
        IF THIS.METHOD = GET.KEYWORD OR THIS.METHOD = PUT.KEYWORD THEN
            IF THIS.PARM = "ATTR.PTR" OR THIS.PARM = "VAL.PTR" OR THIS.PARM = "SUBVAL.PTR" THEN
                CALL.PARM = "UV.":CALL.PARM
            END
        END

        IF THIS.PARM <> "" THEN
            THIS.PARM = DOT.NET (THIS.PARM, "", "")
            CALL.PARM = DOT.NET (CALL.PARM, "", "")
        END

* add code to load up the dotnet "Parameters" array based on dot.net.parameter.type
        BEGIN CASE

            CASE THIS.PARM = ""

                CODE = "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:") = "
                CODE := '""'

                GOSUB ADD.NET.CODE

* if dotnet parameters are always passed as strings use a simple variable
* assignment
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "STRING"

                CODE = "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:") = "
                CODE := CALL.PARM

                GOSUB ADD.NET.CODE

* if dotnet parameters are always passed as dynamic arrays use the dynamic
* array value
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "DYNAMIC"

                CODE = "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:") = "
                CODE := CALL.PARM
                CODE := ".Value"

                GOSUB ADD.NET.CODE

* if dotnet parameters are passed as objects (ie, they could be any object
* type) use the UVServer GetParameterValue to update the Parameters array
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "OBJECT"

                CODE = "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:") = "
                CODE := ".GetParameterValue ("
                CODE := CALL.PARM
                CODE := ")"

                GOSUB ADD.NET.CODE

* if the parameter object type isn't defined (it really should be!) use
* the GetParameterValue routine just in case   
            CASE 1

                CODE = "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:") = "
                CODE := ".GetParameterValue ("
                CODE := CALL.PARM
                CODE := ")"

                GOSUB ADD.NET.CODE

        END CASE

        IF DOT.NET.PASS.PARAMETER.NAMES THEN
            CODE = "ParameterNames(":PARM.LOOP + EXTRA.PASSED.COUNT:') = "'
            CODE := THIS.PARM
            CODE := '"'
        END ELSE
            CODE = "ParameterNames(":PARM.LOOP + EXTRA.PASSED.COUNT:') = "'
            CODE := '"'
        END

        GOSUB ADD.NET.CODE

        IF PARM.LOOP <> THIS.PARM.COUNT THEN
            CODE = " "
            GOSUB ADD.NET.CODE
        END

    NEXT PARM.LOOP

    RETURN

ADD.DOT.NET.PARAMETER.UNLOADING: *****************************************
* add code to the dotnet routine to unload parameters from the dotnet    *
* "Parameters" array back into the method parameters                     *
**************************************************************************
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

* if there isn't at least one parameter passed by reference we don't need
* to unload any parameters
    BYREF.EXISTS = @FALSE
    LAST.BYREF.PARAMETER = 0

    FOR PARM.LOOP = THIS.PARM.COUNT TO 1 STEP -1 UNTIL BYREF.EXISTS

        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>

        IF THIS.BYREF THEN
            BYREF.EXISTS = @TRUE
            LAST.BYREF.PARAMETER = PARM.LOOP
        END

    NEXT PARM.LOOP

    IF NOT (BYREF.EXISTS) THEN
        RETURN
    END

* add code to unload byref parameters
    CODE = " "
    GOSUB ADD.NET.CODE

    CODE = NET.COMMENT.START:"unload passed method parameters"
    GOSUB ADD.NET.CODE

    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT 

        THIS.PARM = THIS.PARM.LIST<PARM.LOOP>
        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>

        IF THIS.PARM <> "" THEN
            THIS.PARM = DOT.NET (THIS.PARM, "", "")
        END

        BEGIN CASE

            CASE THIS.PARM = ""
                NULL

* if this parameter is not passed by reference there's no need to unload
* the passed parameter
            CASE NOT (THIS.BYREF)
                NULL

* if parameters are always passed as strings we can use a simple variable
* assignment
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "STRING"

                CODE = THIS.PARM
                CODE := " = Parameters("
                CODE := PARM.LOOP + EXTRA.PASSED.COUNT
                CODE := ")"

                GOSUB ADD.NET.CODE

* if parameters are passed as dynamics use the dynamic array value
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "DYNAMIC"

                CODE = THIS.PARM
                CODE := ".Value "
                CODE := " = Parameters("
                CODE := PARM.LOOP + EXTRA.PASSED.COUNT
                CODE := ")"

                GOSUB ADD.NET.CODE

* if dotnet parameters are passed as objects (ie, they could be any object
* type) use the UVServer GetParameterValue to update the Parameters array
            CASE UPCASE (DOT.NET.PARAMETER.TYPE) = "OBJECT"

                CODE = ".PutParameterValue ("
                CODE := THIS.PARM
                CODE := ", "
                CODE := "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:")"
                CODE := ")"

                GOSUB ADD.NET.CODE

* if the parameter object type isn't defined (it really should be!) use
* the GetParameterValue routine just in case   
            CASE 1

                CODE = ".PutParameterValue ("
                CODE := THIS.PARM
                CODE := ", "
                CODE := "Parameters(":PARM.LOOP + EXTRA.PASSED.COUNT:")"
                CODE := ")"

                GOSUB ADD.NET.CODE

        END CASE

        IF THIS.BYREF AND PARM.LOOP <> LAST.BYREF.PARAMETER THEN
            CODE = " "
            GOSUB ADD.NET.CODE
        END

    NEXT PARM.LOOP

    RETURN

START.DOT.NET.WITH: ******************************************************
* start the "with" structure for DataConnection in the dotnet code       *
**************************************************************************
    CODE = "With DataConnection"
    GOSUB ADD.NET.CODE
    CODE = " "
    GOSUB ADD.NET.CODE

    NET.INDENT += 1

    RETURN

END.DOT.NET.WITH: ********************************************************
* end the "with" structure for DataConnection in the dotnet code         *
**************************************************************************
    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End With"
    GOSUB ADD.NET.CODE

    RETURN

END.DOT.NET.METHOD: ******************************************************
* add code to net.code to end this.method                                *
**************************************************************************
    IF DOT.NET.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = " "
        GOSUB ADD.NET.CODE
        CODE = "AutoErrorDisplay"
        GOSUB ADD.NET.CODE
    END

    IF DOT.NET.INCLUDE.THROW.ERROR.CODE THEN

        IF NOT(DOT.NET.INCLUDE.AUTO.DISPLAY.CODE) THEN
            CODE = " "
            GOSUB ADD.NET.CODE
        END

        CODE = "AutoErrorThrow"
        GOSUB ADD.NET.CODE

    END

    NET.INDENT -= 1

    CODE = " "
    GOSUB ADD.NET.CODE
    CODE = "End Sub"
    GOSUB ADD.NET.CODE

    NET.METHOD.COUNT += 1

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / utility routines                                      **
**************************************************************************
**************************************************************************

ADD.FOLDED.NET.CODE: *****************************************************
* add code to net.code folding on commas and indenting to the first      *
* open parenthesis.  needs this.parm.count and use.underscore            *
**************************************************************************

* if this line doesn't have multiple parameters send the line without
* trying to break anything up
    FOLD.PARM.COUNT = COUNT(CODE, ",") + 1

    IF FOLD.PARM.COUNT < 2 THEN

        GOSUB ADD.NET.CODE

    END ELSE

        SUB.LINE = CODE
        SUB.INDENT = INDEX (SUB.LINE, "(", 1) - 1

        CODE = SUB.LINE [",", 1, 1]:","

        IF USE.UNDERSCORE THEN
            CODE := " _"
        END

        GOSUB ADD.NET.CODE
        
        FOR PARM.LOOP = 2 TO FOLD.PARM.COUNT

            CODE = SPACE(SUB.INDENT):SUB.LINE [",", PARM.LOOP, 1]

            IF PARM.LOOP < FOLD.PARM.COUNT THEN
                CODE := ","
            END

            IF USE.UNDERSCORE THEN
                CODE := " _"
            END

            GOSUB ADD.NET.CODE

        NEXT PARM.LOOP

    END
        
    RETURN

ADD.NET.CODE: ************************************************************
* add code to net.code                                                   *
**************************************************************************
    NET.CODE.LINES += 1

    BEGIN CASE

        CASE TRIM(CODE) = ""
            INDENT.SPACES = ""

        CASE CODE [1, NET.COMMENT.START.LEN] <> NET.COMMENT.START
            INDENT.SPACES = SPACE(NET.INDENT * EACH.NET.INDENT)
    
        CASE 1
            INDENT.SPACES = ""

    END CASE

    IF NET.CODE.LINES = 1 THEN
        NET.CODE = INDENT.SPACES:CODE
    END ELSE
        NET.CODE := @AM:INDENT.SPACES:CODE
    END

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / exporting                                             **
**************************************************************************
**************************************************************************

EXPORT.DOT.NET.CLASS: ****************************************************
* export net.code to the shared eclipse object folder on the client pc   *
**************************************************************************

* if the object doesn't exist we can't export it
    IF NOT(OBJ.NET.EXISTS) THEN
        PRINT "    OBJ.NET file does not exists.  Can't export to .net"
        RETURN
    END

* if the dotnet export list is explicitly set to "none" don't export
    LOCATE "NONE" IN UPCASE (DOT.NET.USER.LIST) SETTING THROWAWAY THEN
        RETURN
    END

* only export if the current user id is in the export user list or if the
* export user list is "*" or "all"
    LOCATE UPCASE (USER.ID) IN UPCASE (DOT.NET.USER.LIST) SETTING THROWAWAY ELSE
        LOCATE "ALL" IN UPCASE (DOT.NET.USER.LIST) SETTING THROWAWAY ELSE
            LOCATE "*" IN DOT.NET.USER.LIST SETTING THROWAWAY ELSE
                RETURN
            END
        END
    END

* did this compile change the dot net class in the obj.net file?
    READ OLD.NET.CODE FROM OBJNETFILE, DOT.NET.NAME ELSE
        OLD.NET.CODE = ""
    END

* directly comparing the old code to the new won't give good results since
* there are comments that have the time and date in them.  create copies of
* both the old and new versions with these comment lines removed
    THIS.NET.CODE = OLD.NET.CODE
    GOSUB REMOVE.DOT.NET.COMMENTS
    CHECK.OLD.NET.CODE = THIS.NET.CODE

    THIS.NET.CODE = NET.CODE 
    GOSUB REMOVE.DOT.NET.COMMENTS
    CHECK.NET.CODE = THIS.NET.CODE

* should we do the export?
    BEGIN CASE 

* no old version of the dotnet class exists in obj.net.  we're creating a
* new dotnet class
        CASE OLD.NET.CODE = ""
            DO.DOT.NET.EXPORT = @TRUE

            IF NOT(BRIEF) THEN
                PRINT "Creating new .net class ":DOT.NET.NAME
            END

* "onlydot" was specified on the command line so we're only doing the dotnet
* class export.  always do the export
        CASE ONLY.DOT.NET.EXPORTS
            DO.DOT.NET.EXPORT = @TRUE

* the new version of the dotnet class is different from the old.  export the
* new version
        CASE CHECK.OLD.NET.CODE <> CHECK.NET.CODE
            DO.DOT.NET.EXPORT = @TRUE

            IF NOT(BRIEF) THEN
                PRINT "DotNet class ":DOT.NET.NAME:" has changed"
            END

* "ExportEveryCompile" in the "compile" setup record is set to "Yes".  export
* even if the dotnet class has not changed
        CASE DOT.NET.EXPORT.EVERY.COMPILE
            DO.DOT.NET.EXPORT = @TRUE

* the dotnet class code has not changed due to this compile.  don't export
        CASE CHECK.OLD.NET.CODE = CHECK.NET.CODE
            DO.DOT.NET.EXPORT = @FALSE

            IF NOT(BRIEF) THEN
                PRINT ".net class ":DOT.NET.NAME:" has not changed.  Not exporting"
            END

* catch-all.  don't export
        CASE 1
            DO.DOT.NET.EXPORT = @FALSE

    END CASE

    IF NOT(DO.DOT.NET.EXPORT) THEN
        RETURN
    END

    IF NOT(BRIEF) THEN
        PRINT "Exporting object ":DOWNCASE(OBJECT.NAME):" to ":
        PRINT DOT.NET.EXPORT.DRIVE:":":DOT.NET.EXPORT.PATH:"/":DOT.NET.NAME
    END

* save the .net item to obj.net so we can export it
    WRITE.ERROR = @FALSE
    WRITE NET.CODE ON OBJNETFILE, DOT.NET.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "OBJ.NET"
        ERROR.ITEM = DOT.NET.NAME
        GOSUB WRITE.ERROR
    END

* build the export statement to export the .net code to the shared .net
* folder and export it
    IF DOT.NET.EXPORT.DRIVE <> "" AND DOT.NET.EXPORT.PATH <> "" THEN

        STATEMENT = 'EXPORT OBJ.NET "':DOT.NET.NAME:'"'
        STATEMENT := ' TO "':DOT.NET.EXPORT.DRIVE:':':DOT.NET.EXPORT.PATH:'"'
        STATEMENT := " ASIS QUIET"

        EXECUTE STATEMENT

    END

    RETURN

REMOVE.DOT.NET.COMMENTS: *************************************************
* remove lines from THIS.NET.CODE that have time and dates in them       *
**************************************************************************

* the time and date are recorded in a comment line that begins with
* "' * exported".  two additional lines with the server name and compiler
* version follow that one.  find the "Rem * exported" line and delete it 
* and the two lines following
    DOT.NET.LINES = DCOUNT(THIS.NET.CODE, @AM)

    COMMENT.REMOVED = @FALSE
    COMMENT.SEARCH.LINE = DOT.NET.COMMENT.PREFIX:"* exported"
    COMMENT.SEARCH.LEN = LEN(COMMENT.SEARCH.LINE)

    FOR DOT.NET.LOOP = 1 TO DOT.NET.LINES UNTIL COMMENT.REMOVED

        THIS.LINE = THIS.NET.CODE<DOT.NET.LOOP>

        IF THIS.LINE [1, COMMENT.SEARCH.LEN] = COMMENT.SEARCH.LINE THEN
            DEL THIS.NET.CODE<DOT.NET.LOOP>
            DEL THIS.NET.CODE<DOT.NET.LOOP>
            DEL THIS.NET.CODE<DOT.NET.LOOP>
            COMMENT.REMOVED = @TRUE
        END

    NEXT DOT.NET.LOOP

    RETURN


**************************************************************************
**************************************************************************
** api / dotnet / listing                                               **
**************************************************************************
**************************************************************************

LIST.DOT.NET.CODE: *******************************************************
* list .net code, usually for debugging                                  *
**************************************************************************
    PRINT
    PRINT ".net code for object: ":OBJECT.NAME
    PRINT

    FOR LINE.LOOP = 1 TO NET.CODE.LINES
        PRINT LINE.LOOP "R%4":" ":NET.CODE<LINE.LOOP>
    NEXT LINE.LOOP

    PRINT

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** api / java / main                                                    **
**************************************************************************
**************************************************************************

UPDATE.JAVA.OBJECT: ******************************************************
* create class object code for java for the current object and export    *
* it to the shared eclipse object folder on the client pc                *
**************************************************************************

* in order to export the java class we need to have java enabled,
* java exports enabled and the object has to exist
    IF NOT(JAVA.ENABLED) OR NOT(DO.JAVA.EXPORTS) OR NOT(OBJECT.EXISTS) THEN
        RETURN
    END

* if the obj.java file doesn't exist we can't export the java class so
* don't bother to update
    IF NOT(OBJ.JAVA.EXISTS) THEN
        PRINT "Can't update java--OBJ.JAVA file does not exist"
        RETURN
    END

    END.WITH.SEMICOLON = @TRUE

* build the name for the .net class
    JAVA.CLASS.NAME = JAVA (OBJECT.NAME, "", "")
    JAVA.CLASS.NAME = UPCASE (JAVA.CLASS.NAME [1, 1]):JAVA.CLASS.NAME [2, TO.THE.END]
    JAVA.OBJECT = JAVA.CLASS.NAME
    JAVA.NAME = JAVA.CLASS.NAME:JAVA.FILE.EXTENSION

    IF NOT(BRIEF) AND JAVA.EXPORT.DRIVE <> "" AND JAVA.EXPORT.PATH <> "" THEN

        IF NOT(ONLY.JAVA.EXPORTS) OR FIRST.JAVA.EXPORT THEN
            PRINT
        END

    END

    GOSUB CREATE.JAVA.CLASS 
    GOSUB EXPORT.JAVA.CLASS

    FIRST.JAVA.EXPORT = @FALSE

    IF DETAILS THEN
        GOSUB LIST.JAVA.CODE
    END

* update permissions for the dotnet object in obj.net
    PERMIT.FILE = "OBJ.JAVA"
    PERMIT.ITEM = JAVA.NAME
    GOSUB SET.PERMISSIONS

    RETURN


**************************************************************************
**************************************************************************
** api / java / create class                                            **
**************************************************************************
**************************************************************************

CREATE.JAVA.CLASS: *******************************************************
* create java.code with object code for a java class for the current     *
* object                                                                 *
**************************************************************************
    JAVA.START.DATE = DATE()
    JAVA.START.TIME = TIME()

    JAVA.CODE = ""
    JAVA.CODE.LINES = 0
    JAVA.INDENT = 0
    EACH.JAVA.INDENT = 4

    JAVA.METHOD.COUNT = 0

    JAVA.COMMENT.START = JAVA.COMMENT.PREFIX
    JAVA.COMMENT.START.LEN = LEN(JAVA.COMMENT.START)

    BOX.COMMENT.START = CHANGE(JAVA.COMMENT.START, "*", "")

    CREATE.TYPE = "void"
    CREATE.NULL = ""

    STRING.TYPE = "String"
    STRING.NULL = ' = ""'

    CONNECTION.TYPE = "UVServer"
    CONNECTION.NULL = ""

    BOOLEAN.TYPE = "boolean"

    NUMERIC.TYPE = "float"
    NUMERIC.NULL = " = 0f"
    ZERO.STRING = " = 0f"

    BEGIN CASE
        CASE UPCASE (JAVA.PARAMETER.TYPE) = "DYNAMIC"
            NULL.STRING = " = new Dynamic()"
        CASE UPCASE (JAVA.PARAMETER.TYPE) = "STRING"
            NULL.STRING = ' = ""'
        CASE 1
            NULL.STRING = ""
    END CASE

    GOSUB START.JAVA.CLASS

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** public properties.  these properties reside on the uniVerse" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** server and are set and fetched with server data calls" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** through the GetProperty and PutProperty methods which" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** call the get.property and put.property methods in" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** uniVerse" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB CREATE.JAVA.PROPERTIES

    GOSUB CREATE.JAVA.INITIALIZER

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** default methods common to all uniVerse objects" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB CREATE.JAVA.NEW.METHOD
    GOSUB CREATE.JAVA.RESET.METHOD
    GOSUB CREATE.JAVA.DESTROY.METHOD
    GOSUB CREATE.JAVA.GET.METHOD
    GOSUB CREATE.JAVA.PUT.METHOD
    GOSUB CREATE.JAVA.COPY.METHOD

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** object methods specific to this object" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB CREATE.JAVA.USER.METHODS

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** utilities" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB CREATE.JAVA.CHECK.OBJECT

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN
        GOSUB CREATE.JAVA.ERROR.DISPLAY
    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN
        GOSUB CREATE.JAVA.ERROR.THROW
    END

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** cleanup" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB CREATE.JAVA.FINALIZE.METHOD

    GOSUB END.JAVA.CLASS

    JAVA.END.DATE = DATE()
    JAVA.END.TIME = TIME()
    JAVA.ELAPSED.TIME += TIME.ELAPSED (JAVA.START.DATE, JAVA.START.TIME)
    JAVA.COUNT += 1

*   IF NOT(BRIEF) THEN
*       PRINT "    Exported ":JAVA.METHOD.COUNT:" .JAVA methods."
*   END

    RETURN

START.JAVA.CLASS: ********************************************************
* code the beginning of the java class                                   *
**************************************************************************
    CODE = "public class ":JAVA.CLASS.NAME:" {"
    GOSUB ADD.JAVA.CODE

* add object comments beginning with the first comment line found
    START.PTR = 0
    THIS.LINE = ""
    SETREM 0 ON OBJECT.CODE

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES UNTIL START.PTR <> 0

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        IF TRIM(THIS.LINE) [1, 1] = "*" THEN
            START.PTR = LINE.LOOP
        END

    NEXT LINE.LOOP

* add comment lines to the java class until we hit a non-comment line
    IF THIS.LINE <> "" THEN
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:THIS.LINE
        GOSUB ADD.JAVA.CODE
    END

    IF START.PTR <> 0 THEN

        END.PTR = 0

        FOR LINE.LOOP = START.PTR + 1 TO OBJECT.CODE.LINES UNTIL END.PTR <> 0

            REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

            IF TRIM(THIS.LINE) [1, 1] = "*" THEN
                CODE = JAVA.COMMENT.START:THIS.LINE
                GOSUB ADD.JAVA.CODE
            END ELSE
                END.PTR = LINE.LOOP - 1
            END

        NEXT LINE.LOOP

    END

    CODE = " "
    GOSUB ADD.JAVA.CODE

* time / date / exported by stamp
    CODE = JAVA.COMMENT.START:"exported"
    CODE := " ":OCONV(DATE(), "D4/"):" ":OCONV(TIME(), "MTHS")

    IF USER.NAME <> "" THEN
        CODE := " by ":DOWNCASE(USER.NAME):" (":DOWNCASE(USER.ID):")"
        GOSUB ADD.JAVA.CODE
    END ELSE
        CODE := " by ":DOWNCASE(USER.ID)
    END

    CODE = JAVA.COMMENT.START:"from ":UV.HOST.NAME
    IF UV.HOST.NAME <> UNIX.HOST.NAME THEN
        CODE := " (":UNIX.HOST.NAME:")"
    END
    GOSUB ADD.JAVA.CODE

    CODE = JAVA.COMMENT.START:"compiler version: ":PRECOMPILER.VERSION
    IF PRECOMPILER.VERSION.DATE <> "" THEN
        CODE := ", ":OCONV(PRECOMPILER.VERSION.DATE, "D4/")
    END
    GOSUB ADD.JAVA.CODE

* add class properties
    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** default public properties.  these properties are local," "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** residing in the local object, not in the uniVerse object" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"data connection object.  handles connecting with uniVerse as well as all"
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"data calls"
    GOSUB ADD.JAVA.CODE

    CODE = CONNECTION.TYPE:" dataConnection"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"object variables used to reference the uniVerse object"
    GOSUB ADD.JAVA.CODE

    CODE = JAVA.PARAMETER.TYPE:" objectName":NULL.STRING
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.PARAMETER.TYPE:" objectHandle":NULL.STRING
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.PARAMETER.TYPE:" registrySourceId":NULL.STRING
    GOSUB ADD.JAVA.CODE
    CODE = BOOLEAN.TYPE:" objectExists = false"
    GOSUB ADD.JAVA.CODE

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE OR JAVA.INCLUDE.THROW.ERROR.CODE THEN
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"object error message and error handling:"
        GOSUB ADD.JAVA.CODE
    END ELSE
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"object error message"
        GOSUB ADD.JAVA.CODE
    END

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN

        CODE = JAVA.COMMENT.START:"errorDisplay:        set to automatically display object"
        GOSUB ADD.JAVA.CODE

        IF JAVA.ERRORS.USE.MESSAGE.BOX THEN
            CODE = JAVA.COMMENT.START:"                     errors in a standard box"
        END ELSE
            CODE = JAVA.COMMENT.START:"                     errors in a custom box"
        END
        GOSUB ADD.JAVA.CODE

        CODE = JAVA.COMMENT.START:"hideErrorSubroutine: set to remove the object and method"
        GOSUB ADD.JAVA.CODE

        IF JAVA.ERRORS.USE.MESSAGE.BOX THEN
            CODE = JAVA.COMMENT.START:"                     names from the standard error display"
        END ELSE
            CODE = JAVA.COMMENT.START:"                     names from the custom error display"
        END
        GOSUB ADD.JAVA.CODE

    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN
        CODE = JAVA.COMMENT.START:"throwErrors:         set to throw an errors back to the"
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"                     calling routine"
        GOSUB ADD.JAVA.CODE
    END

    CODE = JAVA.PARAMETER.TYPE:" errorMessage":NULL.STRING
    GOSUB ADD.JAVA.CODE

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = BOOLEAN.TYPE:" errorDisplay = false"
        GOSUB ADD.JAVA.CODE
        CODE = BOOLEAN.TYPE:" hideErrorSubroutine = true"
        GOSUB ADD.JAVA.CODE
    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN
        CODE = BOOLEAN.TYPE:" throwErrors = false"
        GOSUB ADD.JAVA.CODE
    END

    IF JAVA.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"properties recording the last uniVerse call.  LastCallTime is in"
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"milliseconds"
        GOSUB ADD.JAVA.CODE

        CODE = STRING.TYPE:" lastMethodCall":STRING.NULL
        GOSUB ADD.JAVA.CODE
        CODE = STRING.TYPE:" lastSubroutineCall":STRING.NULL
        GOSUB ADD.JAVA.CODE
        CODE = NUMERIC.TYPE:" lastCallTime":ZERO.STRING
        GOSUB ADD.JAVA.CODE

    END ELSE

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = NUMERIC.TYPE:" lastCallTime":ZERO.STRING
        GOSUB ADD.JAVA.CODE

    END

    RETURN


**************************************************************************
**************************************************************************
** api / java / create properties                                       **
**************************************************************************
**************************************************************************

CREATE.JAVA.DEFAULT.PROPERTIES: ******************************************
* add code to the java object to create default public properties        *
**************************************************************************
    IF NOT(GET.SET.JAVA.DEFAULT.PROPERTIES) THEN
        RETURN
    END

    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"** get / sets for default public properties" "L#71":" **"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"data connection object.  handles connecting with uniVerse"
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"as well as all data calls"
    GOSUB ADD.JAVA.CODE

    THIS.PROPERTY = "dataConnection"
    THIS.TYPE = CONNECTION.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"object variables used to reference the uniVerse object"
    GOSUB ADD.JAVA.CODE

    THIS.PROPERTY = "objectName"
    THIS.TYPE = JAVA.PARAMETER.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    THIS.PROPERTY = "objectHandle"
    THIS.TYPE = JAVA.PARAMETER.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    THIS.PROPERTY = "registrySourceId"
    THIS.TYPE = JAVA.PARAMETER.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    THIS.PROPERTY = "objectExists"
    THIS.TYPE = BOOLEAN.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"object error message and error handling"
    GOSUB ADD.JAVA.CODE

    THIS.PROPERTY = "errorMessage"
    THIS.TYPE = JAVA.PARAMETER.TYPE
    GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN

        THIS.PROPERTY = "errorDisplay"
        THIS.TYPE = BOOLEAN.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

        THIS.PROPERTY = "hideErrorSubroutine"
        THIS.TYPE = BOOLEAN.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN
        THIS.PROPERTY = "throwErrors"
        THIS.TYPE = BOOLEAN.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY
    END

    IF JAVA.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"properties recording the last uniVerse call.  LastCallTime"
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"is in milliseconds"
        GOSUB ADD.JAVA.CODE

        THIS.PROPERTY = "lastMethodCall"
        THIS.TYPE = STRING.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

        THIS.PROPERTY = "lastSubroutineCall"
        THIS.TYPE = STRING.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

        THIS.PROPERTY = "lastCallTime"
        THIS.TYPE = STRING.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    END ELSE

        CODE = " "
        GOSUB ADD.JAVA.CODE
        THIS.PROPERTY = "lastCallTime"
        THIS.TYPE = STRING.TYPE
        GOSUB CREATE.JAVA.DEFAULT.PROPERTY

    END

    RETURN

CREATE.JAVA.DEFAULT.PROPERTY: ********************************************
* add java code to create this.property                                  *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    JAVA.PROPERTY = DOT.NET (THIS.PROPERTY, "", "")

* if there are any comments ahead of this property add them to the code
    THIS.COMMENT.COUNT = DCOUNT(THIS.COMMENT.LIST, @AM)

    IF THIS.COMMENT.COUNT > 0 THEN

        FOR COMMENT.LOOP = 1 TO THIS.COMMENT.COUNT

            THIS.COMMENT = THIS.COMMENT.LIST<COMMENT.LOOP>

            IF THIS.COMMENT [1, 2] = "* " THEN
                THIS.COMMENT = THIS.COMMENT [3, TO.THE.END]
            END

            CODE = JAVA.COMMENT.START:THIS.COMMENT
            GOSUB ADD.JAVA.CODE

        NEXT COMMENT.LOOP

        CODE = " "
        GOSUB ADD.JAVA.CODE

    END

* write the "get" routine
    CODE = "public ":JAVA.PARAMETER.TYPE:" ":JAVA.GET.PREFIX
    CODE := UPCASE (JAVA.PROPERTY [1, 1]):JAVA.PROPERTY [2, TO.THE.END]
    CODE := " ("

* java doesn't have optional parameters so we'll have to figure out what
* to do with this later
    IF GET.SET.JAVA.MULTI THEN
        CODE := 'Optional attrPtr = -999, '
        CODE := 'Optional valPtr = -999, '
        CODE := 'Optional subvalPtr = -999'
    END

    CODE := ") {"

    IF JAVA.FOLD.PARAMETERS AND GET.SET.JAVA.MULTI THEN
        THIS.PARM.COUNT = 3
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE

    CODE = THIS.TYPE:" propertyValue As ":JAVA.PARAMETER.TYPE
    GOSUB ADD.JAVA.CODE

    CODE = 'getProperty (propertyValue, "':THIS.PROPERTY:'"'

    IF GET.SET.JAVA.MULTI THEN
        CODE := ", attrPtr, valPtr, subvalPtr"
    END ELSE
        CODE := ", 0, 0, 0"
    END

    CODE := ")"

    GOSUB ADD.JAVA.CODE
    
    CODE = "return propertyValue"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

* write the "set" routine
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "public void ":JAVA.SET.PREFIX
    CODE := UPCASE (JAVA.PROPERTY [1, 1]):JAVA.PROPERTY [2, TO.THE.END]
    CODE := " (":THIS.TYPE:" newValue)"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = 'putProperty (newValue, "':THIS.PROPERTY:'"'

    IF GET.SET.JAVA.MULTI THEN
        CODE := ", attrPtr, valPtr, subvalPtr"
    END ELSE
        CODE := ", 0, 0, 0"
    END

    CODE := ")"

    IF JAVA.FOLD.PARAMETERS AND GET.SET.JAVA.MULTI THEN
        THIS.PARM.COUNT = 5
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

END.JAVA.CLASS: **********************************************************
* end the java class                                                     *
**************************************************************************
    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

CREATE.JAVA.PROPERTIES: **************************************************
* add code to the java class to create method properties                 *
**************************************************************************
    IF PROP.COUNT = 0 THEN
        RETURN
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.PROPERTY = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.TYPE = DOT.NET.PARAMETER.TYPE
        THIS.LOCAL = PROP.LOCAL.LIST<PROP.LOOP>
        THIS.COMMENT.LIST = RAISE(PROP.COMMENT.LIST<PROP.LOOP>)

* only build property code for non-local properties that aren't dimensioned.
* we'll worry about dimensioned variables later
        IF NOT(THIS.LOCAL) AND THIS.DIM = "" THEN
            GOSUB CREATE.JAVA.PROPERTY
        END

    NEXT PROP.LOOP

    RETURN

CREATE.JAVA.PROPERTY: ****************************************************
* add code to create a java property for this.property.  this routine    *
* will create a "get" and a "put" routine for this.property that calls   *
* the GetProperty and PutProperty methods in UVServer to get and set     *
* properties in the uniVerse object on the uniVerse server               *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    JAVA.PROPERTY = JAVA (THIS.PROPERTY, "", "")

* if there are any comments ahead of this property add them to the code
    THIS.COMMENT.COUNT = DCOUNT(THIS.COMMENT.LIST, @AM)

    IF THIS.COMMENT.COUNT > 0 THEN

        FOR COMMENT.LOOP = 1 TO THIS.COMMENT.COUNT

            THIS.COMMENT = THIS.COMMENT.LIST<COMMENT.LOOP>

            IF THIS.COMMENT [1, 2] = "* " THEN
                THIS.COMMENT = THIS.COMMENT [3, TO.THE.END]
            END

            CODE = JAVA.COMMENT.START:THIS.COMMENT
            GOSUB ADD.JAVA.CODE

        NEXT COMMENT.LOOP

        CODE = " "
        GOSUB ADD.JAVA.CODE

    END

* create the get method for this property
    CODE = "public ":JAVA.PARAMETER.TYPE:" ":JAVA.GET.PREFIX
    CODE := UPCASE (JAVA.PROPERTY [1, 1]):JAVA.PROPERTY [2, TO.THE.END]
    CODE := " ("

* java doesn't have optional parameters so we'll have to figure out what
* to do with this later
    IF GET.SET.JAVA.MULTI THEN
        CODE := 'Optional attrPtr = -999, '
        CODE := 'Optional valPtr = -999, '
        CODE := 'Optional subvalPtr = -999'
    END

    CODE := ") {"

    IF JAVA.FOLD.PARAMETERS AND GET.SET.JAVA.MULTI THEN
        THIS.PARM.COUNT = 3
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    JAVA.INDENT += 1
    
    CODE = JAVA.PARAMETER.TYPE:' propertyValue'

* for some parameter types we need to initialize the class
    BEGIN CASE
        CASE JAVA.PARAMETER.TYPE = "Dynamic"
            CODE := " = new ":JAVA.PARAMETER.TYPE:"()"
    END CASE

    GOSUB ADD.JAVA.CODE

    CODE = 'getProperty (propertyValue, "':THIS.PROPERTY:'"'

    IF GET.SET.JAVA.MULTI THEN
        CODE := ", attrPtr, valPtr, subvalPtr"
    END ELSE
        CODE := ", 0, 0, 0"
    END

    CODE := ")"
    GOSUB ADD.JAVA.CODE
    
    CODE = "return propertyValue"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE

* create the set method for this property
    CODE = "public void ":JAVA.SET.PREFIX
    CODE := UPCASE (JAVA.PROPERTY [1, 1]):JAVA.PROPERTY [2, TO.THE.END]
    CODE := " (":JAVA.PARAMETER.TYPE:" newValue) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = 'putProperty (newValue, "':THIS.PROPERTY:'"'

    IF GET.SET.JAVA.MULTI THEN
        CODE := ", attrPtr, valPtr, subvalPtr"
    END ELSE
        CODE := ", 0, 0, 0"
    END

    CODE := ")"

    IF JAVA.FOLD.PARAMETERS AND GET.SET.JAVA.MULTI THEN
        THIS.PARM.COUNT = 5
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

CREATE.JAVA.INITIALIZER: *************************************************
* create the initializer block to call the "new" method.  the "new"      *
* method may have optional parameters.  this routine creates an          *
* initializer that uses use.optional.count of these                      *
*                                                                        *
* the "new" method may have optional parameters.  if it does this        *
* routine will loop from 0 optional parameters to the optional parameter *
* account and create initializing blocks for each optional parameter     *
* count                                                                  *
**************************************************************************
    JAVA.METHOD.TYPE = ""

    THIS.METHOD = NEW.KEYWORD
    JAVA.METHOD = JAVA (THIS.METHOD, JAVA.FROM.METHOD.LIST, JAVA.TO.METHOD.LIST)
    GOSUB PROCESS.JAVA.PARAMETERS

* start the initializer method (constructor)
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    IF TRIM (PARAMETER.STRING) = "()" THEN
        PARAMETER.STRING = " (UVServer newDataConnection)"
    END

    IF JAVA.METHOD.TYPE = "" THEN
        CODE = "public ":JAVA.CLASS.NAME
    END ELSE
        CODE  = "public ":JAVA.METHOD.TYPE:" ":JAVA.CLASS.NAME
    END

    CODE := PARAMETER.STRING
    CODE := " {"

    IF JAVA.FOLD.PARAMETERS THEN
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    CODE = BOX.COMMENT.START:STR ("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"* initialize this object" "L#72":" *"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR ("*", 74)
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

* call the "new" method
    CODE = " "
    GOSUB ADD.JAVA.CODE

* convert parameter.string into a parameter list to pass the values rather
* than to receive them.  each parameter is either a variable or a variable
* type followed by a variable.  if there's a variable type in the parameter
* only use the variable name
    GOSUB BUILD.PASS.PARAMETER.LIST

    IF PASS.PARAMETER.STRING [1] <> ")" THEN
        PASS.PARAMETER.STRING := "()"
    END

* call the "new" method to initialize the object on the uniVerse side
    CODE = JAVA.COMMENT.START:"call the new method in uniVerse to initialize the object"
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"on the uniVerse server"
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.METHOD:PASS.PARAMETER.STRING
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    
    JAVA.INDENT -= 1
    CODE = "}"
    GOSUB ADD.JAVA.CODE

* create overloads for the initializer
    JAVA.OVERLOAD.CALL = JAVA.METHOD
    JAVA.METHOD = JAVA.CLASS.NAME
    GOSUB CREATE.JAVA.OVERLOADS

    RETURN


**************************************************************************
**************************************************************************
** api / java / create methods                                          **
**************************************************************************
**************************************************************************

CREATE.JAVA.NEW.METHOD: **************************************************
* create the "new" method for java                                       *
**************************************************************************
    THIS.METHOD = NEW.KEYWORD

    JAVA.METHOD.TYPE = "void"
    GOSUB START.JAVA.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

* if the java parameter type is "Dynamic" then we'll use the ".value"
* parameter of "Dynamic" to update the property value
    BEGIN CASE
        CASE UPCASE (JAVA.PARAMETER.TYPE) = "DYNAMIC"
            MODIFIER = ".value"
    END CASE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"set the uniVerse connection for this object"
    GOSUB ADD.JAVA.CODE
    CODE = "dataConnection = newDataConnection"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"initialize object status"
    GOSUB ADD.JAVA.CODE
    CODE = 'objectName':JAVA.MODIFIER:' = "':JAVA.OBJECT:'"'
    GOSUB ADD.JAVA.CODE
    CODE = "objectExists = false"
    GOSUB ADD.JAVA.CODE
    CODE = "registrySourceId":JAVA.MODIFIER:" = ":'"1"'
    GOSUB ADD.JAVA.CODE

    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN

        CODE = " "
        GOSUB ADD.JAVA.CODE

        BEGIN CASE
            CASE JAVA.DEFAULT.DISPLAY.ERROR.TO.CONNECTION
                CODE = "errorDisplay = dataConnection.errorDisplay"
                GOSUB ADD.JAVA.CODE
            CASE JAVA.DEFAULT.DISPLAY.ERROR
                CODE = "errorDisplay = true"
                GOSUB ADD.JAVA.CODE
            CASE 1
                CODE = "errorDisplay = false"
                GOSUB ADD.JAVA.CODE
        END CASE

        CODE = "hideErrorSubroutine = false"
        GOSUB ADD.JAVA.CODE

    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN

        CODE = " "
        GOSUB ADD.JAVA.CODE

        BEGIN CASE
            CASE JAVA.DEFAULT.THROW.ERROR.TO.CONNECTION
                CODE = "throwErrors = dataConnection.throwErrors"
                GOSUB ADD.JAVA.CODE
            CASE JAVA.DEFAULT.THROW.ERROR
                CODE = "throwErrors = true"
                GOSUB ADD.JAVA.CODE
            CASE 1
                CODE = "throwErrors = false"
                GOSUB ADD.JAVA.CODE
        END CASE

    END

    GOSUB ADD.JAVA.METHOD.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"if ErrorMessage returns null then the new object creation was successful"
    GOSUB ADD.JAVA.CODE
    CODE = 'if (errorMessage':JAVA.MODIFIER:'.equals ("")) {'
    GOSUB ADD.JAVA.CODE
    CODE = "    objectExists = true"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    GOSUB END.JAVA.METHOD

    JAVA.OVERLOAD.CALL = ""
    GOSUB CREATE.JAVA.OVERLOADS

    RETURN

CREATE.JAVA.RESET.METHOD: ************************************************
* create the "reset" method for java                                     *
**************************************************************************
    THIS.METHOD = RESET.KEYWORD

    JAVA.METHOD.TYPE = "void"
    GOSUB START.JAVA.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB ADD.JAVA.METHOD.CODE
    GOSUB END.JAVA.METHOD

    RETURN

CREATE.JAVA.DESTROY.METHOD: **********************************************
* create the "destroy" method for java                                   *
**************************************************************************
    THIS.METHOD = "DESTROY"

    JAVA.METHOD.TYPE = "void"
    GOSUB START.JAVA.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB ADD.JAVA.METHOD.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "objectExists = false"
    GOSUB ADD.JAVA.CODE

    GOSUB END.JAVA.METHOD

    RETURN

CREATE.JAVA.GET.METHOD: **************************************************
* create the "get" method for java                                       *
**************************************************************************
    THIS.METHOD = GET.KEYWORD

    JAVA.METHOD.TYPE = "void"
    GOSUB START.JAVA.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvAttrPtr = ""'
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvValPtr = ""'
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvSubvalPtr = ""'
    GOSUB ADD.JAVA.CODE
    
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (attrPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "    uvAttrPtr = String.valueOf (attrPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (valPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "    uvValPtr = String.valueOf (valPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (subvalPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "    uvSubvalPtr = String.valueOf (subvalPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.JAVA.CODE
    CODE = "checkObjectExists()"
    GOSUB ADD.JAVA.CODE

    GOSUB ADD.JAVA.METHOD.CODE

    GOSUB END.JAVA.METHOD

*   GOSUB CREATE.JAVA.OVERLOADS

    RETURN

CREATE.JAVA.PUT.METHOD: **************************************************
* create the "put" method for java                                       *
**************************************************************************
    THIS.METHOD = PUT.KEYWORD

    JAVA.METHOD.TYPE = "void"

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB START.JAVA.METHOD

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvAttrPtr = ""'
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvValPtr = ""'
    GOSUB ADD.JAVA.CODE
    CODE = 'String uvSubvalPtr = ""'
    GOSUB ADD.JAVA.CODE
    
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (attrPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "    uvAttrPtr = String.valueOf (attrPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (valPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "uvValPtr = String.valueOf (valPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (subvalPtr != -999) {"
    GOSUB ADD.JAVA.CODE
    CODE = "uvSubvalPtr = String.valueOf (subvalPtr)"
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.JAVA.CODE
    CODE = "checkObjectExists()"
    GOSUB ADD.JAVA.CODE

    GOSUB ADD.JAVA.METHOD.CODE

    GOSUB END.JAVA.METHOD

    RETURN

CREATE.JAVA.COPY.METHOD: *************************************************
* create the "copy" method for java                                      *
**************************************************************************
    RETURN

    THIS.METHOD = "COPY"

    JAVA.METHOD.TYPE = "void"

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    GOSUB START.JAVA.METHOD

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.JAVA.CODE
    CODE = "checkObjectExists()"
    GOSUB ADD.JAVA.CODE

    GOSUB ADD.JAVA.METHOD.CODE

    GOSUB END.JAVA.METHOD

    RETURN

CREATE.JAVA.USER.METHODS: ************************************************
* create the user method for java                                        *
**************************************************************************
    FOR CREATE.METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<CREATE.METHOD.LOOP>
        THIS.METHOD.TYPE = METHOD.TYPE.LIST<CREATE.METHOD.LOOP>
        THIS.METHOD.LOCAL = METHOD.LOCAL.LIST<CREATE.METHOD.LOOP>

* create .net methods for object methods that aren't local and are
* "normal" methods--ie, no phantom wrappers, tcl wrappers, etc.  "common"
* and "redim" may also be in the method list.  skip those as well.
* default methods have already been build so skip those.
        IF NOT(THIS.METHOD.LOCAL) AND THIS.METHOD.TYPE = METHOD.KEYWORD THEN
            IF THIS.METHOD <> COMMON.ROUTINE.METHOD AND THIS.METHOD <> REDIM.KEYWORD THEN
                LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY ELSE
                    GOSUB CREATE.JAVA.USER.METHOD
                END
            END
        END

    NEXT CREATE.METHOD.LOOP

    RETURN

CREATE.JAVA.USER.METHOD: *************************************************
* create a single user method for java                                   *
**************************************************************************
    JAVA.METHOD.TYPE = "void"
    GOSUB START.JAVA.METHOD

    IF NOT(STARTED.METHOD) THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"can't call this method if the object hasn't been created"
    GOSUB ADD.JAVA.CODE
    CODE = "checkObjectExists()"
    GOSUB ADD.JAVA.CODE

    GOSUB ADD.JAVA.METHOD.CODE

    GOSUB END.JAVA.METHOD

    JAVA.OVERLOAD.CALL = ""
    GOSUB CREATE.JAVA.OVERLOADS

    RETURN

CREATE.JAVA.OVERLOADS: ***************************************************
* java does not support optional parameters.  to get the same effect     *
* we'll create overloads of the method for calls where the optional      *
* parameters are omitted.  one overloaded method we'll be created for    *
* removing the last optional parameter, another for removing the last    *
* two parameters, etc.  needs pass.parameter.string with the parameter   *
* list that was called (from the start.java.method routine),             *
* this.optional.count (also from start.java.method), java.class.name     *
* and java.method                                                        *
**************************************************************************

* if there are no optional parameters there are no overloads to build
    IF THIS.OPTIONAL.COUNT = 0 THEN
        RETURN
    END

    GOSUB BUILD.PASS.PARAMETER.LIST

* remove parenthesis from pass.parameter.string
    PASS.PARAMETER.STRING = TRIM (PASS.PARAMETER.STRING)

    IF PASS.PARAMETER.STRING [1, 1] = "(" THEN
        PASS.PARAMETER.STRING = PASS.PARAMETER.STRING[2, TO.THE.END]
    END

    IF PASS.PARAMETER.STRING [1] = ")" THEN
        PASS.PARAMETER.STRING = PASS.PARAMETER.STRING[1, LEN(PASS.PARAMETER.STRING) - 1]
    END

* java.method may be passed with a parenthesis after it.  remove the
* parenthesis
    JAVA.METHOD = JAVA.METHOD ["(", 1, 1]
    JAVA.METHOD = TRIM (JAVA.METHOD)

* if this method has optional parameters generate additional initialer
* blocks for one less optional parameter, two less, until we get to a final
* call that uses no optional parameters
    BLANK.PARAMETER.STRING = ""
    NULL.COUNTER = 0

    FOR INCLUDE.OPTIONAL.LOOP = THIS.OPTIONAL.COUNT - 1 TO 0 STEP -1

        SKIPPED.PARAMETER.COUNT = THIS.OPTIONAL.COUNT - INCLUDE.OPTIONAL.LOOP

* remove the last parameter from parameter.string and pass.parameter.string
* and add a blank parameter to blank.parameter.string
        PARAMETER.COUNT = DCOUNT (PARAMETER.STRING, ",")

        IF PARAMETER.COUNT - SKIPPED.PARAMETER.COUNT = 0 THEN
            PASS.PARAMETER.STRING = ""
        END ELSE
            PASS.PARAMETER.STRING = PARAMETER.STRING [",", 1, PARAMETER.COUNT - SKIPPED.PARAMETER.COUNT]
        END

        NULL.COUNTER += 1
        BLANK.PARAMETER.STRING := ', nullParameter':NULL.COUNTER

* build a parameter string for the calls that has only the variable names
        CALL.PARAMETER.STRING = CHANGE (PASS.PARAMETER.STRING, ",", @AM)

        FOR CALL.LOOP = 1 TO PARAMETER.COUNT - SKIPPED.PARAMETER.COUNT

            THIS.PARAMETER = TRIM(CALL.PARAMETER.STRING<CALL.LOOP>)
            THIS.PARAMETER.SPACES = DCOUNT (THIS.PARAMETER, " ")

            CALL.PARAMETER.STRING<CALL.LOOP> = THIS.PARAMETER [" ", THIS.PARAMETER.SPACES, 1]

        NEXT CALL.LOOP

        CALL.PARAMETER.STRING = CHANGE (CALL.PARAMETER.STRING, @AM, ", ")

* create an initializing block using only the parameters left after removing
* the last optional parameter
        CODE = " "
        GOSUB ADD.JAVA.CODE

        IF JAVA.METHOD.TYPE = "" THEN
            CODE = "public ":JAVA.METHOD
        END ELSE
            CODE = "public ":JAVA.METHOD.TYPE:" ":JAVA.METHOD
        END

        CODE := " (":PASS.PARAMETER.STRING:")"
        CODE := " {"

        IF JAVA.FOLD.PARAMETERS THEN
            USE.UNDERSCORE = @FALSE
            GOSUB ADD.FOLDED.JAVA.CODE
        END ELSE
            GOSUB ADD.JAVA.CODE
        END

* add the comment block for the overload
        OVERLOAD.COMMENT = "Overload of ":JAVA.METHOD:" with "

        IF INCLUDE.OPTIONAL.LOOP = 0 THEN
            OVERLOAD.COMMENT := "no optional parameters"
        END ELSE
            OVERLOAD.COMMENT := INCLUDE.OPTIONAL.LOOP:" of "
            OVERLOAD.COMMENT := THIS.OPTIONAL.COUNT:" optional parameters"
        END

        CODE = BOX.COMMENT.START:STR("*", 74)
        GOSUB ADD.JAVA.CODE
        CODE = BOX.COMMENT.START:("* ":OVERLOAD.COMMENT) "L#72":" *"
        GOSUB ADD.JAVA.CODE
        CODE = BOX.COMMENT.START:STR("*", 74)
        GOSUB ADD.JAVA.CODE

        JAVA.INDENT += 1

* create a null dynamic array to pass null values
        BEGIN CASE 

            CASE UPCASE (JAVA.PARAMETER.TYPE) = "DYNAMIC"
                FOR ADD.NULL = 1 TO SKIPPED.PARAMETER.COUNT
                    CODE = "Dynamic nullParameter":ADD.NULL:" = new Dynamic()"
                    GOSUB ADD.JAVA.CODE
                NEXT ADD.NULL

            CASE UPCASE (JAVA.PARAMETER.TYPE) = "STRING"
                FOR ADD.NULL = 1 TO SKIPPED.PARAMETER.COUNT
                    CODE = 'String nullParameter':ADD.NULL:' = ""'
                    GOSUB ADD.JAVA.CODE
                NEXT ADD.NULL

            CASE 1
                CODE = 'String nullParameter = ""'
                GOSUB ADD.JAVA.CODE

        END CASE

* call the "new" method, passing nulls for the optional parameters that
* are skipped in this call
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"call the complete method with the skipped optional parameters set"
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"to nulls"
        GOSUB ADD.JAVA.CODE

        BEGIN CASE

* if a subroutine for the overload call, different from the java method name,
* has been defined use it for the call
            CASE JAVA.OVERLOAD.CALL <> "" AND CALL.PARAMETER.STRING = ""
                CODE = JAVA.OVERLOAD.CALL:" (":BLANK.PARAMETER.STRING [3, TO.THE.END]:")"
                GOSUB ADD.JAVA.CODE
            CASE JAVA.OVERLOAD.CALL <> ""
                CODE = JAVA.OVERLOAD.CALL:" (":CALL.PARAMETER.STRING:BLANK.PARAMETER.STRING:")"
                GOSUB ADD.JAVA.CODE

* otherwise use the method name
            CASE CALL.PARAMETER.STRING = ""
                CODE = JAVA.METHOD:" (":BLANK.PARAMETER.STRING [3, TO.THE.END]:")"
                GOSUB ADD.JAVA.CODE
            CASE 1
                CODE = JAVA.METHOD:" (":CALL.PARAMETER.STRING:BLANK.PARAMETER.STRING:")"
                GOSUB ADD.JAVA.CODE

        END CASE

        JAVA.INDENT -= 1

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = "}"
        GOSUB ADD.JAVA.CODE

    NEXT INCLUDE.OPTIONAL.LOOP

    RETURN

BUILD.PASS.PARAMETER.LIST: ***********************************************
* build.pass.parameter.list from parameter.list.  parameter.list is a    *
* list of parameters from the method declaration.  this routine builds   *
* build.pass.parameter.list with a list of parameters as would be used   *
* to call the method                                                     *
**************************************************************************

* convert parameter.string into a parameter list to pass the values rather
* than to receive them.  each parameter is either a variable or a variable
* type followed by a variable.  if there's a variable type in the parameter
* only use the variable name
    PARAMETER.STRING = TRIM (PARAMETER.STRING)

* remove parenthesis from parameter.string
    IF PARAMETER.STRING [1, 1] = "(" THEN
        PARAMETER.STRING = PARAMETER.STRING[2, TO.THE.END]
    END

    IF PARAMETER.STRING [1] = ")" THEN
        PARAMETER.STRING = PARAMETER.STRING[1, LEN(PARAMETER.STRING) - 1]
    END

* build pass.parameter.count using only the variable names from parameter.string
    PARAMETER.COUNT = DCOUNT (PARAMETER.STRING, ",")
    PASS.PARAMETER.STRING = ""

    FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT

        THIS.PARAMETER = TRIM (PARAMETER.STRING [",", PARAMETER.LOOP, 1])
        SPACE.COUNT = DCOUNT (THIS.PARAMETER, " ")

        IF SPACE.COUNT <= 1 THEN
            PASS.PARAMETER.STRING := THIS.PARAMETER
        END ELSE
            PASS.PARAMETER.STRING := THIS.PARAMETER [" ", SPACE.COUNT, 1]
        END

        IF PARAMETER.LOOP < PARAMETER.COUNT THEN
            PASS.PARAMETER.STRING := ", "
        END

    NEXT PARAMETER.LOOP

    IF PASS.PARAMETER.STRING <> "" THEN
        PASS.PARAMETER.STRING = " (":PASS.PARAMETER.STRING:")"
    END

    RETURN

CREATE.JAVA.ERROR.DISPLAY: ***********************************************
* create the "AutoErrorDisplay" method for a java class.  this method    *
* will display ErrorMessage (ERROR.MESSAGE) via a msgbox window          *
* if the error message is not null                                       *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = "private void autoErrorDisplay() {"
    GOSUB ADD.JAVA.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"* display a method error if there is one" "L#72":" *"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = 'String displayMessage = ""'
    GOSUB ADD.JAVA.CODE
    CODE = 'int colonPtr = 0'
    GOSUB ADD.JAVA.CODE
    CODE = "String cr = Character.toString ((char) 13)"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"if there is an error message display it"
    GOSUB ADD.JAVA.CODE
    CODE = 'if (errorDisplay && (!errorMessage':JAVA.MODIFIER:'.equals (""))) {'
    GOSUB ADD.JAVA.CODE
    
    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "displayMessage = errorMessage":JAVA.MODIFIER
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (hideErrorSubroutine) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = 'colonPtr = displayMessage.indexOf (": ")'
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "if (colonPtr > -1) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = "displayMessage = displayMessage.substring (colonPtr + 2)"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "} else {"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    IF JAVA.UPDATE.LAST.CALL THEN

        CODE = JAVA.COMMENT.START:"add method information to DisplayMessage"
        GOSUB ADD.JAVA.CODE
        CODE = "displayMessage = displayMessage + cr + cr"
        GOSUB ADD.JAVA.CODE
        CODE = 'displayMessage = displayMessage + "Object: " + objectName + cr'
        GOSUB ADD.JAVA.CODE
        CODE = 'displayMessage = displayMessage + "Method: " + lastMethodCall + cr'
        GOSUB ADD.JAVA.CODE
        CODE = 'displayMessage = displayMessage + "UV Subroutine: " + lastSubroutineCall + cr'
        GOSUB ADD.JAVA.CODE

        CODE = " "
        GOSUB ADD.JAVA.CODE

    END

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    CODE = " "
    GOSUB ADD.JAVA.CODE

* show the error using MessageBox or ShowError (which uses ErrorForm from the
* FormsPrimitives dotJAVA file)

* the "HideErrorSubroutine" flag is used in the object to display errors
* without the technical information (ie, the object and method, etc).  this
* presents an error that makes more sense to a non-technical (ie, a normal
* human) user.  if HideErrorSubroutine is set we'll use ShowMessage to display
* the error rather than ShowError
    IF JAVA.ERRORS.USE.MESSAGE.BOX THEN

        CODE = 'JOptionPane.showMessageDialog (null, displayMessage, "UVObject Error", JOptionPane.ERROR_MESSAGE)'
        GOSUB ADD.JAVA.CODE

    END ELSE

        CODE = "if (hideErrorSubroutine) {"
        GOSUB ADD.JAVA.CODE

        JAVA.INDENT += 1

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"Add call to custom error display routine to display the"
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"error, hiding the subroutine name"
        GOSUB ADD.JAVA.CODE
        CODE = " "
        GOSUB ADD.JAVA.CODE

        JAVA.INDENT -= 1

        CODE = "} else {"
        GOSUB ADD.JAVA.CODE

        JAVA.INDENT += 1

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"Add call to custom error display routine"
        GOSUB ADD.JAVA.CODE
        CODE = " "
        GOSUB ADD.JAVA.CODE

        JAVA.INDENT -= 1

        CODE = "}"
        GOSUB ADD.JAVA.CODE

    END

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

CREATE.JAVA.ERROR.THROW: *************************************************
* create the "AutoErrorThrow" method for a java class.  this method      *
* throw an error back to the calling program if the error message is not *
* null                                                                   *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = "private void autoErrorThrow() {"
    GOSUB ADD.JAVA.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"* throw a method error if there is one" "L#72":" *"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"if there is an error message throw it"
    GOSUB ADD.JAVA.CODE
    CODE = 'if (throwErrors && (!errorMessage':JAVA.MODIFIER:'.equals (""))) {'
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

* dotnet lets me throw an error all the way back to the calling program.
* java doesn't seem to like this.  so, for now we'll comment it out
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:" throw new Exception (errorMessage.value)"
    GOSUB ADD.JAVA.CODE
    CODE = " "
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

CREATE.JAVA.CHECK.OBJECT: ************************************************
* create a java method for CheckObjectExists.  if the object hasn't      *
* been created successfully generate an error                            *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = "private void checkObjectExists() {"
    GOSUB ADD.JAVA.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"* generate an exception if the object hasn't been created" "L#72":" *"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = 'errorMessage':JAVA.MODIFIER:' = ""'
    GOSUB ADD.JAVA.CODE

* test to make sure the object has been created
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"set an error if this object hasn't been created"
    GOSUB ADD.JAVA.CODE
    CODE = "if (!objectExists) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = 'errorMessage':JAVA.MODIFIER:' = objectName + ": Object has not been created"'
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

* test to make sure the uv connection is open
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"set an error if the data connection isn't open"
    GOSUB ADD.JAVA.CODE
    CODE = "if (!dataConnection.connectionOpen) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = 'errorMessage':JAVA.MODIFIER:' = objectName + ": UV Data Connection is not open"'
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

* auto error display
    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = "autoErrorDisplay()"
        GOSUB ADD.JAVA.CODE
    END

* auto error throw
    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN

        IF NOT(JAVA.INCLUDE.AUTO.DISPLAY.CODE) THEN
            CODE = " "
            GOSUB ADD.JAVA.CODE
        END

        CODE = "autoErrorThrow()"
        GOSUB ADD.JAVA.CODE

    END

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

CREATE.JAVA.FINALIZE.METHOD: *********************************************
* create the "finalize" method for a java class.  the "finalize"         *
* method is called when the class object is destroyed.  finalize will    *
* call the universe "destroy" method to remove the object from the       *
* universe object memory tables                                          *
**************************************************************************
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = "public void finalize() {"
    GOSUB ADD.JAVA.CODE

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:"* clean up before destroying object" "L#72":" *"
    GOSUB ADD.JAVA.CODE
    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"if the uniVerse connection is still open destroy uniVerse object"
    GOSUB ADD.JAVA.CODE
    CODE = "if (dataConnection.connectionOpen) {"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT += 1

    CODE = "destroy()"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = "}"
    GOSUB ADD.JAVA.CODE

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    RETURN

START.JAVA.METHOD: *******************************************************
* add code to java.code to start this.method                             *
**************************************************************************
    STARTED.METHOD = @TRUE

    LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY THEN
        DEFAULT.METHOD = @TRUE
    END ELSE
        DEFAULT.METHOD = @FALSE
    END 

* convert the uv method name to the java method name
    JAVA.METHOD = JAVA (THIS.METHOD, JAVA.FROM.METHOD.LIST, JAVA.TO.METHOD.LIST)

    IF JAVA.METHOD.TYPE = "" THEN
        CODE = "public ":JAVA.METHOD
        GOSUB PROCESS.JAVA.PARAMETERS
    END ELSE
        CODE = "public ":JAVA.METHOD.TYPE:" ":JAVA.METHOD
        GOSUB PROCESS.JAVA.PARAMETERS
    END

* add the uvServer instance to the parameter list for the "new" routine
    IF THIS.METHOD = NEW.KEYWORD THEN

        IF TRIM (PARAMETER.STRING) = "()" THEN
            PARAMETER.STRING = " (UVServer newDataConnection)"
        END

    END

    CODE := PARAMETER.STRING:" {"

    FIRST.LINE.CODE = CODE

* if this method has any "special" parameters (file handles, etc) we won't
* export it
    IF HAS.SPECIAL.PARAMETERS THEN
        STARTED.METHOD = @FALSE
        RETURN
    END

* start the code for this java class method
    FOR BLANK.LOOP = 1 TO JAVA.BLANKS.BETWEEN.METHODS
        CODE = " "
        GOSUB ADD.JAVA.CODE
    NEXT BLANK.LOOP

    CODE = FIRST.LINE.CODE

    IF JAVA.FOLD.PARAMETERS THEN
        USE.UNDERSCORE = @FALSE
        GOSUB ADD.FOLDED.JAVA.CODE
    END ELSE
        GOSUB ADD.JAVA.CODE
    END

    CODE = BOX.COMMENT.START:STR("*", 74)
    GOSUB ADD.JAVA.CODE

    GOSUB ADD.JAVA.METHOD.COMMENTS

    JAVA.INDENT += 1

    RETURN

PROCESS.JAVA.PARAMETERS: *************************************************
* build parameter.string with the parameter call (with parenthesis) for  *
* this.method.                                                           *
**************************************************************************
    PARAMETER.STRING = ""

* if the method call has one or more parameters that's a "special" parameter
* then it has a file handle or select handle or something in the parameter
* list.  java can't call these methods since we can't build a handle into
* the network message
    HAS.SPECIAL.PARAMETERS = @FALSE

* see if this.method is in method.list.  if it is then we'll get the parameter
* list and comments to add to the java method code
    BEGIN CASE 

* these methods have no parameters in java
        CASE THIS.METHOD = GET.KEYWORD
            NULL
        CASE THIS.METHOD = PUT.KEYWORD
            NULL

        CASE 1
            LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
                LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY ELSE
                    RETURN
                END
            END

    END CASE

* unload the parameter arrays.  some of the default methods have parameters
* but won't be in this table
    BEGIN CASE

* the reset method won't have any optional parameters
        CASE THIS.METHOD = RESET.KEYWORD
            GOSUB CLEAR.JAVA.PARAMETER.LIST

* the new method may have parameters but it has some additional parameters
* that other methods won't have
        CASE THIS.METHOD = NEW.KEYWORD
            GOSUB UNLOAD.JAVA.PARAMETER.LIST

* the destroy method won't have a parameter list
        CASE THIS.METHOD = DESTROY.KEYWORD
            GOSUB CLEAR.JAVA.PARAMETER.LIST

* calling "get.property" to return a property value    
        CASE THIS.METHOD = GET.KEYWORD
            THIS.PARM.LIST = "PROPERTY.VALUE,PROPERTY.NAME"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"
            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            THIS.OPTIONAL.LIST = "0,0,1,1,1"
            THIS.OPTIONAL.LIST = CHANGE (THIS.OPTIONAL.LIST, ",", @AM)

            THIS.DEFAULT.LIST = ",,-999,-999,-999"
            THIS.DEFAULT.LIST = CHANGE (THIS.DEFAULT.LIST, ",", @AM)

            THIS.SET.LIST = ""

            THIS.BYREF.LIST = "1,0,0,0,0"
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.SPECIAL.LIST = "0,0,0,0,0"
            THIS.SPECIAL.LIST = CHANGE (THIS.SPECIAL.LIST, ",", @AM)

            THIS.TYPE.LIST = JAVA.PARAMETER.TYPE:",String,int,int,int"
            THIS.TYPE.LIST = CHANGE (THIS.TYPE.LIST, ",", @AM)

* calling "put.property" to update a property value
        CASE THIS.METHOD = PUT.KEYWORD
            THIS.PARM.LIST = "PROPERTY.VALUE,PROPERTY.NAME"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"
            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            THIS.OPTIONAL.LIST = "0,0,1,1,1"
            THIS.OPTIONAL.LIST = CHANGE (THIS.OPTIONAL.LIST, ",", @AM)

            THIS.DEFAULT.LIST = ",,-999,-999,-999"
            THIS.DEFAULT.LIST = CHANGE (THIS.DEFAULT.LIST, ",", @AM)

            THIS.SET.LIST = ""

            THIS.BYREF.LIST = "0,0,0,0,0"
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.SPECIAL.LIST = "0,0,0,0,0"
            THIS.SPECIAL.LIST = CHANGE (THIS.SPECIAL.LIST, ",", @AM)

            THIS.TYPE.LIST = JAVA.PARAMETER.TYPE:",String,int,int,int"
            THIS.TYPE.LIST = CHANGE (THIS.TYPE.LIST, ",", @AM)

* calling any other method
        CASE 1
            GOSUB UNLOAD.JAVA.PARAMETER.LIST

    END CASE

* if we have any special parameters we can't export this method
    IF SUM (THIS.SPECIAL.LIST) <> 0 THEN
        HAS.SPECIAL.PARAMETERS = @TRUE
        RETURN
    END

    THIS.OPTIONAL.COUNT = SUM(THIS.OPTIONAL.LIST)

* if we have no parameters we still need to add the parenthesis.  if this
* is a "new" method we need to add the data connection parameter
    IF THIS.PARM.COUNT = 0 THEN
        IF THIS.METHOD = NEW.KEYWORD THEN
            PARAMETER.STRING = " (":CONNECTION.TYPE:" newDataConnection)"
        END ELSE
            PARAMETER.STRING = " ()"
        END
    END

* if there are no parameters we can skip out
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

    PARAMETER.STRING = " ("

* the "new" java method has an additional parameter.  this additional
* first parameter is the UVServer database handle
    IF THIS.METHOD = NEW.KEYWORD THEN
        PARAMETER.STRING := CONNECTION.TYPE:" newDataConnection, "
    END

* add each parameter to parameter.string
    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT 

        THIS.PARM = JAVA (THIS.PARM.LIST<PARM.LOOP>, "", "")

        THIS.OPTIONAL = THIS.OPTIONAL.LIST<PARM.LOOP>
        THIS.DEFAULT = THIS.DEFAULT.LIST<PARM.LOOP>

        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>

        THIS.TYPE = THIS.TYPE.LIST<PARM.LOOP>

        IF PARM.LOOP > 1 THEN
            PARAMETER.STRING := ", "
        END

* optional parameter
*       IF THIS.OPTIONAL THEN
*           PARAMETER.STRING := "optional "
*       END

* byref / byval
*       BEGIN CASE
*           CASE THIS.BYREF AND DOT.NET.INDICATE.BYREF
*               PARAMETER.STRING := "byRef "
*           CASE NOT(THIS.BYREF) AND DOT.NET.INDICATE.BYVAL
*               PARAMETER.STRING := "byVal "
*       END CASE

* variable type
        IF THIS.TYPE <> "" THEN
            PARAMETER.STRING := THIS.TYPE:" "
        END

* parameter name
        PARAMETER.STRING := THIS.PARM

* specify a null value for optional parameters
*       IF THIS.OPTIONAL THEN
*           PARAMETER.STRING := ' = ':THIS.DEFAULT
*       END

    NEXT PARM.LOOP

    PARAMETER.STRING := ")"

    RETURN

CLEAR.JAVA.PARAMETER.LIST: ***********************************************
* set the parameters for the current java method to null                 *
**************************************************************************
    THIS.PARM.LIST = ""
    THIS.PARM.COUNT = 0

    THIS.OPTIONAL.LIST = ""
    THIS.DEFAULT.LIST = ""
    THIS.SET.LIST = ""
    THIS.BYREF.LIST = ""
    THIS.SPECIAL.LIST = ""
    THIS.TYPE.LIST = ""

    RETURN

UNLOAD.JAVA.PARAMETER.LIST: **********************************************
* unload the parameters for the current java method from the method      *
* tables for method method.ptr                                           *
**************************************************************************
    THIS.PARM.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)
    THIS.PARM.COUNT = METHOD.PARM.COUNT.LIST<METHOD.PTR>

    THIS.OPTIONAL.LIST = RAISE(METHOD.PARM.OPTIONAL.LIST<METHOD.PTR>)
    THIS.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
    THIS.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)
    THIS.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
    THIS.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

* build the type and default lists from the java settings in the compile
* setup record
    THIS.TYPE.LIST = ""
    THIS.DEFAULT.LIST = ""

    FOR ADD.LOOP = 1 TO THIS.PARM.COUNT
        THIS.TYPE.LIST<ADD.LOOP> = JAVA.PARAMETER.TYPE
        THIS.DEFAULT.LIST<ADD.LOOP> = '""'
    NEXT ADD.LOOP

    RETURN

ADD.JAVA.METHOD.COMMENTS: ************************************************
* add comments to java code for this.method                              *
**************************************************************************
    FOUND.COMMENTS = @FALSE 

    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE

        IF DEFAULT.METHOD THEN
            CODE = "* Default method "
        END ELSE
            CODE = "* User method "
        END

        CODE = (CODE:JAVA (THIS.METHOD, JAVA.FROM.METHOD.LIST, JAVA.TO.METHOD.LIST)) "L#72":" *"

        CODE = BOX.COMMENT.START:CODE
        GOSUB ADD.JAVA.CODE

        CODE = BOX.COMMENT.START:STR("*", 74)
        GOSUB ADD.JAVA.CODE

        RETURN

    END

* add method comment code into the java method.  we'll start
* with the method's starting line and stop one line before the program
* code starts
    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR> - 1
    THIS.METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.PTR>

* if this is an inherited method fetch the called code from the object
* the method is inherited from
    IF THIS.METHOD.INHERITED THEN

        THIS.INHERIT.OBJECT = METHOD.INHERIT.OBJECT.LIST<METHOD.PTR>

        READ THIS.CALLED.CODE FROM OBJFILE, THIS.INHERIT.OBJECT ELSE
            THIS.CALLED.CODE = ""
        END

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = THIS.CALLED.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = ""
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = THIS.CALLED.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimiter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(THIS.CALLED.CODE, @AM, START.LINE - 1)
        END

        SETREM START.PTR ON THIS.CALLED.CODE
        FOR ADD.LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM THIS.CALLED.CODE SETTING THROWAWAY

            IF TRIM(CODE) = "" THEN
                ADD.LINE.LOOP = END.LINE + 1
            END ELSE
                CODE = BOX.COMMENT.START:CODE
                GOSUB ADD.JAVA.CODE
                FOUND.COMMENTS = @TRUE
            END

        NEXT ADD.LINE.LOOP

    END ELSE

* start.ptr may be on an empty line.  if the "method" statement wrapped
* around object.code<start.line> may be null as the parameters were
* wrapped up to the "method" line.  if start.ptr is on an empty line skip
* ahead until we're on a line that's not null
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL TRIM(THIS.COMMENT) <> "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = OBJECT.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
        END

        SETREM START.PTR ON OBJECT.CODE

        FOR ADD.LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY

* if we hit a null line stop adding comments.  if we hit a code line stop
* adding comments.  otherwise add the comment line to the java code
            BEGIN CASE

                CASE TRIM(CODE) = ""
                    ADD.LINE.LOOP = END.LINE + 1

                CASE IS.CODE(CODE)
                    ADD.LINE.LOOP = END.LINE + 1
            
                CASE 1
                    CODE = BOX.COMMENT.START:CODE
                    GOSUB ADD.JAVA.CODE
                    FOUND.COMMENTS = @TRUE

            END CASE

        NEXT ADD.LINE.LOOP

    END

    RETURN

ADD.JAVA.METHOD.CODE: ****************************************************
* add the method body code for the java method                           *
**************************************************************************
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:THIS.METHOD

* initialize properties and set "last call" properties
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"initialize class properties"
    GOSUB ADD.JAVA.CODE
    CODE = 'errorMessage':JAVA.MODIFIER:' = ""'
    GOSUB ADD.JAVA.CODE

    IF JAVA.UPDATE.LAST.CALL THEN

        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = JAVA.COMMENT.START:"set last call properties"
        GOSUB ADD.JAVA.CODE
        CODE = 'lastMethodCall = "':JAVA.METHOD:'"'
        GOSUB ADD.JAVA.CODE
        CODE = 'lastSubroutineCall = "':SUBROUTINE.NAME:'"'
        GOSUB ADD.JAVA.CODE

    END

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"call ":JAVA.OBJECT:METHOD.DELIMITER
    CODE := JAVA.METHOD:" in uniVerse via UVObjects by calling uniVerse"
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"subroutine ":SUBROUTINE.NAME
    GOSUB ADD.JAVA.CODE

    GOSUB START.JAVA.WITH

* build the java call to the eclipse object method
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"build a string array of the passed parameters"
    GOSUB ADD.JAVA.CODE

    BEGIN CASE

* call to the new method.  this call to the uniVerse subroutine will always
* have three extra parameters.  the first is the object handle, the second is
* error.message and the third is the source id.  after that are any method 
* parameters
        CASE THIS.METHOD = NEW.KEYWORD

            PARAMETER.ARRAY.COUNT = THIS.PARM.COUNT + 3
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first two parameters for the object handle and error message
            CODE = JAVA.COMMENT.START:"the first three parameters for the subroutine version of the method are"
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"always the object handle, the error message and the registry source id"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE
            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = 'parameters[1]':JAVA.MODIFIER:' = ""'
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[1]':JAVA.MODIFIER:' = "errorMessage"'
            END ELSE
                CODE = 'parameterNames[1]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE
            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = 'parameters[2]':JAVA.MODIFIER:' = registrySourceId':JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[2]':JAVA.MODIFIER:' = "registryId"'
            END ELSE
                CODE = 'parameterNames[2]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE

            EXTRA.PASSED.COUNT = 3

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

* call to the reset method.  this call to the uniVerse subroutine will always
* have two extra parameters.  the first is the object handle, the second is
* the source id.  
        CASE THIS.METHOD = RESET.KEYWORD

            PARAMETER.ARRAY.COUNT = THIS.PARM.COUNT + 1
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first two parameters for the object handle and error message
            CODE = JAVA.COMMENT.START:"the first parameter for the subroutine version of the reset method"
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"are always the object handle"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

* for the destroy method we'll only have one parameter, the object handle
        CASE THIS.METHOD = DESTROY.KEYWORD

            PARAMETER.ARRAY.COUNT = 1
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first parameter for the object handle
            CODE = JAVA.COMMENT.START:"the subroutine version of the destroy method only needs the object handle"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE

            EXTRA.PASSED.COUNT = 0

            TOTAL.PASSED.COUNT = 1

* for the get property method we'll have 10 parameters
        CASE THIS.METHOD = GET.KEYWORD

            PARAMETER.ARRAY.COUNT = 10
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first three parameters for the object handle, property name
* and returned value
            CODE = JAVA.COMMENT.START:"the first parameter for the get property call is always the object handle"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE

* the actual call to the uniVerse get.property subroutine requires
* the parameter list in a different order and has some additional
* parameters that will be passed as nulls
            THIS.PARM.LIST = "PROPERTY.NAME,PROPERTY.VALUE"
            THIS.PARM.LIST := ",,,,"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"

            THIS.BYREF.LIST = "0,1,0,0,0,0,0,0,0"

            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.PARM.COUNT = DCOUNT (THIS.PARM.LIST, @AM)

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = 10

* for the put property method we'll have 10 parameters
        CASE THIS.METHOD = PUT.KEYWORD

            PARAMETER.ARRAY.COUNT = 10
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first two parameters for the object handle, property name
            CODE = JAVA.COMMENT.START:"the first parameter for the put property call is always the object handle"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE

* the actual call to the uniVerse get.property subroutine requires
* the parameter list in a different order and has some additional
* parameters that will be passed as nulls
            THIS.PARM.LIST = "PROPERTY.NAME,PROPERTY.VALUE"
            THIS.PARM.LIST := ",,,,"
            THIS.PARM.LIST := ",ATTR.PTR,VAL.PTR,SUBVAL.PTR"

            THIS.BYREF.LIST = "0,0,0,0,0,0,0,0,0"

            THIS.PARM.LIST = CHANGE (THIS.PARM.LIST, ",", @AM)
            THIS.BYREF.LIST = CHANGE (THIS.BYREF.LIST, ",", @AM)

            THIS.PARM.COUNT = DCOUNT(THIS.PARM.LIST, @AM)

            EXTRA.PASSED.COUNT = 1

            TOTAL.PASSED.COUNT = 10

* any other methods we'll have a number of parameters that depends on
* the object method call
        CASE 1

* the call to the object method.  the call to the uniVerse subroutine will always
* have at least two parameters.  the first is the object handle and the second is
* error.message.  after that are any method parameters
            PARAMETER.ARRAY.COUNT = THIS.PARM.COUNT + 2
            GOSUB CREATE.JAVA.PARAMETER.ARRAYS

* load the first two parameters for the object handle and error message
            CODE = JAVA.COMMENT.START:"the first two parameters for the subroutine version of the method are always "
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"the object handle and error message"
            GOSUB ADD.JAVA.CODE

            CODE = "parameters[0]":JAVA.MODIFIER:" = objectHandle":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = "objectHandle"'
            END ELSE
                CODE = 'parameterNames[0]':JAVA.MODIFIER:' = ""'
            END

            GOSUB ADD.JAVA.CODE
            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = 'parameters[1]':JAVA.MODIFIER:' = ""'
            GOSUB ADD.JAVA.CODE

            IF JAVA.PASS.PARAMETER.NAMES THEN
                CODE = 'parameterNames[1]':JAVA.MODIFIER:' = "errorMessage"'
            END ELSE
                CODE = 'parameterNames[1]':JAVA.MODIFIER:' = ""'
            END 

            GOSUB ADD.JAVA.CODE

            EXTRA.PASSED.COUNT = 2

            TOTAL.PASSED.COUNT = THIS.PARM.COUNT + EXTRA.PASSED.COUNT

        END CASE

* load up the method parameters
    GOSUB ADD.JAVA.PARAMETER.LOADING

* do the method call
    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.COMMENT.START:"call the uniVerse objects method"
    GOSUB ADD.JAVA.CODE

* if we're building the "new" java method to call the "new" eclipse method
* we'll usually want to call the "new.short" eclipse method.  the "new" eclipse
* method may have a list of parameters that return the child object handles.  we
* don't need these parameters and at this point we don't know what they are so
* calling the eclipse "new" routine would mean figuring out what these parameters
* are.  if we call the "new.short" we don't need the child handle variable list
* and we still create the object
    IF UPCASE(THIS.METHOD) = NEW.KEYWORD AND JAVA.NEW.CALLS.SHORT.NEW THEN
        CODE = 'dataConnection.callMethod ("':UPCASE(OBJECT.NAME):'", "':UPCASE(NEW.SHORT.KEYWORD):'", '
        CODE := TOTAL.PASSED.COUNT:", parameters, parameterNames)"
        GOSUB ADD.JAVA.CODE
    END ELSE
        CODE = 'dataConnection.callMethod ("':UPCASE(OBJECT.NAME):'", "':UPCASE(THIS.METHOD):'", '
        CODE := TOTAL.PASSED.COUNT:", parameters, parameterNames)"
        GOSUB ADD.JAVA.CODE
    END

* unload parameters from the call
    BEGIN CASE

* nothing needs to be unloaded for the "destroy" method
        CASE THIS.METHOD = DESTROY.KEYWORD
            NULL

* for the "new" method unload the object handle, error message, registry
* source id and then any other parameters
        CASE THIS.METHOD = NEW.KEYWORD

            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.JAVA.CODE
            CODE = "objectHandle":JAVA.MODIFIER:" = parameters[0]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE
            CODE = "errorMessage":JAVA.MODIFIER:" = parameters[1]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE
            CODE = "registrySourceId":JAVA.MODIFIER:" = parameters[2]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            GOSUB ADD.JAVA.PARAMETER.UNLOADING

* for the "reset" method unload the object handle, registry source id and then
* any other parameters
        CASE THIS.METHOD = RESET.KEYWORD

            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.JAVA.CODE
            CODE = "objectHandle":JAVA.MODIFIER:" = parameters[0]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            GOSUB ADD.JAVA.PARAMETER.UNLOADING

* the "get" routines only need to unload the error message and property value
* parameters
        CASE THIS.METHOD = GET.KEYWORD

            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"unload the 'get value' parameters from the method call"
            GOSUB ADD.JAVA.CODE

            CODE = "propertyValue":JAVA.MODIFIER:" = parameters[2]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE            

* the "put" routines only need to unload the error message
        CASE THIS.METHOD = PUT.KEYWORD
            NULL

* any other methods
        CASE 1

            CODE = " "
            GOSUB ADD.JAVA.CODE
            CODE = JAVA.COMMENT.START:"unload default parameters from the method call"
            GOSUB ADD.JAVA.CODE
            CODE = "errorMessage":JAVA.MODIFIER:" = parameters[1]":JAVA.MODIFIER
            GOSUB ADD.JAVA.CODE

            GOSUB ADD.JAVA.PARAMETER.UNLOADING

    END CASE

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "lastCallTime = dataConnection.callTime"
    GOSUB ADD.JAVA.CODE

    GOSUB END.JAVA.WITH

    RETURN

CREATE.JAVA.PARAMETER.ARRAYS: ********************************************
* create the parameter and parameternames arrays for the java method     *
* dimensioned to parameter.array.count elements                          *
**************************************************************************
    CODE = JAVA.PARAMETER.TYPE:" parameters[]"
    GOSUB ADD.JAVA.CODE
    CODE = "parameters = new ":JAVA.PARAMETER.TYPE:"[":PARAMETER.ARRAY.COUNT:"]"
    GOSUB ADD.JAVA.CODE

    FOR PARAMETER.LOOP = 1 TO PARAMETER.ARRAY.COUNT
        CODE = "parameters[":PARAMETER.LOOP - 1:"]":NULL.STRING
        GOSUB ADD.JAVA.CODE
    NEXT PARAMETER.LOOP

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = JAVA.PARAMETER.TYPE:" parameterNames[]"
    GOSUB ADD.JAVA.CODE
    CODE = "parameterNames = new ":JAVA.PARAMETER.TYPE:"[":PARAMETER.ARRAY.COUNT:"]"
    GOSUB ADD.JAVA.CODE

    FOR PARAMETER.LOOP = 1 TO PARAMETER.ARRAY.COUNT
        CODE = "parameterNames[":PARAMETER.LOOP - 1:"]":NULL.STRING
        GOSUB ADD.JAVA.CODE
    NEXT PARAMETER.LOOP

    CODE = " "
    GOSUB ADD.JAVA.CODE

    RETURN

ADD.JAVA.PARAMETER.LOADING: **********************************************
* add code to the java routine to load parameters into the java code     *
* array so that java can call the uniVerse method                        *
**************************************************************************
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.JAVA.CODE

    CODE = JAVA.COMMENT.START:"set the passed method parameters"
    GOSUB ADD.JAVA.CODE

    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT

        THIS.PARM = THIS.PARM.LIST<PARM.LOOP>

* special case for get.property and put.property.  attr, val and subval
* pointers are passed as numeric values attr.ptr, val.ptr and subval.ptr.
* since optional parameters must be null they're copied to uv.attr.ptr,
* uv.val.ptr and uv.subval.ptr and called with these variables
        CALL.PARM = THIS.PARM
        IF THIS.METHOD = GET.KEYWORD OR THIS.METHOD = PUT.KEYWORD THEN
            IF THIS.PARM = "ATTR.PTR" OR THIS.PARM = "VAL.PTR" OR THIS.PARM = "SUBVAL.PTR" THEN
                CALL.PARM = "UV.":CALL.PARM
            END
        END

        IF THIS.PARM <> "" THEN
            THIS.PARM = JAVA (THIS.PARM, "", "")
            CALL.PARM = JAVA (CALL.PARM, "", "")
        END

* add code to load up the dotJAVA "Parameters" array based on JAVA.parameter.type
        BEGIN CASE

            CASE THIS.PARM = ""

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = ":'""'

                GOSUB ADD.JAVA.CODE

* for some parameters for some methods we'll use fixed variable types
            CASE THIS.METHOD = "GET.PROPERTY" AND (THIS.PARM = "propertyName")

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := CALL.PARM

                GOSUB ADD.JAVA.CODE

            CASE THIS.METHOD = "GET.PROPERTY" AND (THIS.PARM = "attrPtr" OR THIS.PARM = "valPtr" OR THIS.PARM = "subvalPtr")

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := CALL.PARM

                GOSUB ADD.JAVA.CODE

            CASE THIS.METHOD = "PUT.PROPERTY" AND (THIS.PARM = "propertyName")

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := CALL.PARM

                GOSUB ADD.JAVA.CODE

            CASE THIS.METHOD = "PUT.PROPERTY" AND (THIS.PARM = "attrPtr" OR THIS.PARM = "valPtr" OR THIS.PARM = "subvalPtr")

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := CALL.PARM

                GOSUB ADD.JAVA.CODE

* if java parameters are always passed as dynamic arrays use the dynamic
* array value
            CASE UPCASE (JAVA.PARAMETER.TYPE) = "DYNAMIC" OR UPCASE (JAVA.PARAMETER.TYPE) = "STRING"

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := CALL.PARM
                CODE := ".value"

                GOSUB ADD.JAVA.CODE

* if java parameters are passed as objects (ie, they could be any object
* type) use the UVServer GetParameterValue to update the Parameters array
            CASE UPCASE (JAVA.PARAMETER.TYPE) = "OBJECT"

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"] = "
                CODE := ".getParameterValue ("
                CODE := CALL.PARM
                CODE := ")"

                GOSUB ADD.JAVA.CODE

* if the parameter object type isn't defined (it really should be!) use
* the GetParameterValue routine just in case   
            CASE 1

                CODE = "parameters[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
                CODE := " = "
                CODE := ".getParameterValue ("
                CODE := CALL.PARM
                CODE := ")"

                GOSUB ADD.JAVA.CODE

        END CASE

        IF JAVA.PASS.PARAMETER.NAMES THEN
            CODE = "parameterNames[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
            CODE := " = ":'"'
            CODE := THIS.PARM
            CODE := '"'
        END ELSE
            CODE = "parameterNames[":PARM.LOOP + EXTRA.PASSED.COUNT - 1:"]":JAVA.MODIFIER
            CODE := " = ":'"'
            CODE := '"'
        END

        GOSUB ADD.JAVA.CODE

        IF PARM.LOOP <> THIS.PARM.COUNT THEN
            CODE = " "
            GOSUB ADD.JAVA.CODE
        END

    NEXT PARM.LOOP

    RETURN

ADD.JAVA.PARAMETER.UNLOADING: ********************************************
* add code to the java routine to unload parameters from the java        *
* "Parameters" array back into the method parameters                     *
**************************************************************************
    IF THIS.PARM.COUNT = 0 THEN
        RETURN
    END

* if there isn't at least one parameter passed by reference we don't need
* to unload any parameters
    BYREF.EXISTS = @FALSE
    LAST.BYREF.PARAMETER = 0

    FOR PARM.LOOP = THIS.PARM.COUNT TO 1 STEP -1 UNTIL BYREF.EXISTS

        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>

        IF THIS.BYREF THEN
            BYREF.EXISTS = @TRUE
            LAST.BYREF.PARAMETER = PARM.LOOP
        END

    NEXT PARM.LOOP

    IF NOT (BYREF.EXISTS) THEN
        RETURN
    END

* add code to unload byref parameters
    CODE = " "
    GOSUB ADD.JAVA.CODE

    CODE = JAVA.COMMENT.START:"unload passed method parameters"
    GOSUB ADD.JAVA.CODE

    FOR PARM.LOOP = 1 TO THIS.PARM.COUNT 

        THIS.PARM = THIS.PARM.LIST<PARM.LOOP>

        THIS.BYREF = THIS.BYREF.LIST<PARM.LOOP>
        THIS.SPECIAL = THIS.SPECIAL.LIST<PARM.LOOP>

        IF THIS.PARM <> "" THEN
            THIS.PARM = JAVA (THIS.PARM, "", "")
        END

        BEGIN CASE

            CASE THIS.PARM = ""
                NULL

* if this parameter is not passed by reference there's no need to unload
* the passed parameter
            CASE NOT (THIS.BYREF)
                NULL

* if parameters are passed as dynamics use the dynamic array value
            CASE UPCASE (JAVA.PARAMETER.TYPE) = "DYNAMIC" OR UPCASE (JAVA.PARAMETER.TYPE) = "STRING"

                CODE = THIS.PARM:JAVA.MODIFIER
                CODE := " = parameters["
                CODE := PARM.LOOP + EXTRA.PASSED.COUNT - 1
                CODE := "]":JAVA.MODIFIER

                GOSUB ADD.JAVA.CODE

* if dotJAVA parameters are passed as objects (ie, they could be any object
* type) use the UVServer GetParameterValue to update the Parameters array
            CASE UPCASE (JAVA.PARAMETER.TYPE) = "OBJECT"

                CODE = ".putParameterValue ("
                CODE := THIS.PARM:JAVA.MODIFIER
                CODE := ", "
                CODE := "parameters["
                CODE := PARM.LOOP + EXTRA.PASSED.COUNT - 1
                CODE := "]"
                CODE := ")"

                GOSUB ADD.JAVA.CODE

* if the parameter object type isn't defined (it really should be!) use
* the GetParameterValue routine just in case   
            CASE 1

                CODE = ".putParameterValue ("
                CODE := THIS.PARM:JAVA.MODIFIER
                CODE := ", "
                CODE := "parameters["
                CODE := PARM.LOOP + EXTRA.PASSED.COUNT - 1
                CODE := "]":JAVA.MODIFIER
                CODE := ")"

                GOSUB ADD.JAVA.CODE

        END CASE

        IF THIS.BYREF AND PARM.LOOP <> LAST.BYREF.PARAMETER THEN
            CODE = " "
            GOSUB ADD.JAVA.CODE
        END

    NEXT PARM.LOOP

    RETURN

START.JAVA.WITH: *********************************************************
* start the "with" structure for DataConnection in the java code.  this  *
* routine was brought over from the dotnet code.  java doesn't support   *
* any kind of "with" structure so this routine is just a place holder    *
**************************************************************************
    NULL

    RETURN

END.JAVA.WITH: ***********************************************************
* end the "with" structure for DataConnection in the java code.  this    *
* routine was brought over from the dotnet code.  java doesn't support   *
* any kind of "with" structure so this routine is just a place holder    *
**************************************************************************
    NULL

    RETURN

END.JAVA.METHOD: *********************************************************
* add code to java.code to end this.method                               *
**************************************************************************
    IF JAVA.INCLUDE.AUTO.DISPLAY.CODE THEN
        CODE = " "
        GOSUB ADD.JAVA.CODE
        CODE = "autoErrorDisplay()"
        GOSUB ADD.JAVA.CODE
    END

    IF JAVA.INCLUDE.THROW.ERROR.CODE THEN

        IF NOT(JAVA.INCLUDE.AUTO.DISPLAY.CODE) THEN
            CODE = " "
            GOSUB ADD.JAVA.CODE
        END

        CODE = "autoErrorThrow()"
        GOSUB ADD.JAVA.CODE

    END

    JAVA.INDENT -= 1

    CODE = " "
    GOSUB ADD.JAVA.CODE
    CODE = "}"
    GOSUB ADD.JAVA.CODE

    JAVA.METHOD.COUNT += 1

    RETURN


**************************************************************************
**************************************************************************
** api / java / utility routines                                        **
**************************************************************************
**************************************************************************

ADD.FOLDED.JAVA.CODE: ****************************************************
* add code to java.code folding on commas and indenting to the first     *
* open parenthesis.  needs this.parm.count and use.underscore            *
**************************************************************************

* if this line doesn't have multiple parameters send the line without
* trying to break anything up
    FOLD.PARM.COUNT = COUNT(CODE, ",") + 1

    IF FOLD.PARM.COUNT < 2 THEN

        GOSUB ADD.JAVA.CODE

    END ELSE

        SUB.LINE = CODE
        SUB.INDENT = INDEX (SUB.LINE, "(", 1) - 1

        CODE = SUB.LINE [",", 1, 1]:","

        IF USE.UNDERSCORE THEN
            CODE := " _"
        END

        END.WITH.SEMICOLON = @FALSE
        GOSUB ADD.JAVA.CODE
        
        FOR PARM.LOOP = 2 TO FOLD.PARM.COUNT

            CODE = SPACE(SUB.INDENT):SUB.LINE [",", PARM.LOOP, 1]

            IF PARM.LOOP < FOLD.PARM.COUNT THEN
                CODE := ","
            END

            IF USE.UNDERSCORE THEN
                CODE := " _"
            END

            IF PARM.LOOP = FOLD.PARM.COUNT THEN
                END.WITH.SEMICOLON = @TRUE
            END

            GOSUB ADD.JAVA.CODE

        NEXT PARM.LOOP

    END

    END.WITH.SEMICOLON = @TRUE
        
    RETURN

ADD.JAVA.CODE: ***********************************************************
* add code to java.code                                                  *
**************************************************************************
    JAVA.CODE.LINES += 1

* if this isn't a comment indent the line.  if not a comment and the line
* doesn't end in a "{" or "}" add a semicolon to end the line
    BEGIN CASE

        CASE TRIM(CODE) = ""

            INDENT.SPACES = ""

        CASE CODE [1, JAVA.COMMENT.START.LEN] <> JAVA.COMMENT.START

            INDENT.SPACES = SPACE(JAVA.INDENT * EACH.JAVA.INDENT)

            IF END.WITH.SEMICOLON THEN

                LAST.CHAR = CODE [1]

                IF LAST.CHAR <> "{" AND LAST.CHAR <> "}" AND LAST.CHAR <> ";" AND LAST.CHAR <> "," AND LAST.CHAR <> "_" THEN
                    CODE := ";"
                END

            END

        CASE 1

            INDENT.SPACES = ""

    END CASE

    IF JAVA.CODE.LINES = 1 THEN
        JAVA.CODE = INDENT.SPACES:CODE
    END ELSE
        JAVA.CODE := @AM:INDENT.SPACES:CODE
    END

    RETURN


**************************************************************************
**************************************************************************
** api / java / exporting                                               **
**************************************************************************
**************************************************************************

EXPORT.JAVA.CLASS: *******************************************************
* export java.code to the shared eclipse object folder on the client pc  *
**************************************************************************

* if the object doesn't exist we can't export it
    IF NOT(OBJ.JAVA.EXISTS) THEN
        PRINT "    OBJ.JAVA file does not exists.  Can't export to java"
        RETURN
    END

* if the dotnet export list is explicitly set to "none" don't export
    LOCATE "NONE" IN UPCASE (JAVA.USER.LIST) SETTING THROWAWAY THEN
        RETURN
    END

* only export if the current user id is in the export user list or if the
* export user list is "*" or "all"
    LOCATE UPCASE (USER.ID) IN UPCASE (JAVA.USER.LIST) SETTING THROWAWAY ELSE
        LOCATE "ALL" IN UPCASE (JAVA.USER.LIST) SETTING THROWAWAY ELSE
            LOCATE "*" IN JAVA.USER.LIST SETTING THROWAWAY ELSE
                RETURN
            END
        END
    END

* did this compile change the dot JAVA class in the obj.JAVA file?
    READ OLD.JAVA.CODE FROM OBJJAVAFILE, JAVA.NAME ELSE
        OLD.JAVA.CODE = ""
    END

* directly comparing the old code to the new won't give good results since
* there are comments that have the time and date in them.  create copies of
* both the old and new versions with these comment lines removed
    THIS.JAVA.CODE = OLD.JAVA.CODE
    GOSUB REMOVE.JAVA.COMMENTS
    CHECK.OLD.JAVA.CODE = THIS.JAVA.CODE

    THIS.JAVA.CODE = JAVA.CODE 
    GOSUB REMOVE.JAVA.COMMENTS
    CHECK.JAVA.CODE = THIS.JAVA.CODE

* should we do the export?
    BEGIN CASE 

* no old version of the java class exists in obj.JAVA.  we're creating a
* new java class
        CASE OLD.JAVA.CODE = ""
            DO.JAVA.EXPORT = @TRUE

            IF NOT(BRIEF) THEN
                PRINT "Creating new java class ":JAVA.NAME
            END

* "onlydot" was specified on the command line so we're only doing the java
* class export.  always do the export
        CASE ONLY.JAVA.EXPORTS
            DO.JAVA.EXPORT = @TRUE

* the new version of the java class is different from the old.  export the
* new version
        CASE CHECK.OLD.JAVA.CODE <> CHECK.JAVA.CODE
            DO.JAVA.EXPORT = @TRUE

            IF NOT(BRIEF) THEN
                PRINT "java class ":JAVA.NAME:" has changed"
            END

* "ExportEveryCompile" in the "compile" setup record is set to "Yes".  export
* even if the java class has not changed
        CASE JAVA.EXPORT.EVERY.COMPILE
            DO.JAVA.EXPORT = @TRUE

* the java class code has not changed due to this compile.  don't export
        CASE CHECK.OLD.JAVA.CODE = CHECK.JAVA.CODE
            DO.JAVA.EXPORT = @FALSE

            IF NOT(BRIEF) THEN
                PRINT "java class ":JAVA.NAME:" has not changed.  Not exporting"
            END

* catch-all.  don't export
        CASE 1
            DO.JAVA.EXPORT = @FALSE

    END CASE

    IF NOT(DO.JAVA.EXPORT) THEN
        RETURN
    END

    IF NOT(BRIEF) THEN
        PRINT "Exporting object ":DOWNCASE(OBJECT.NAME):" to ":
        PRINT JAVA.EXPORT.DRIVE:":":JAVA.EXPORT.PATH:"/":JAVA.NAME
    END

* save the .JAVA item to obj.java so we can export it
    WRITE.ERROR = @FALSE
    WRITE JAVA.CODE ON OBJJAVAFILE, JAVA.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "OBJ.JAVA"
        ERROR.ITEM = JAVA.NAME
        GOSUB WRITE.ERROR
    END

* build the export statement to export the .JAVA code to the shared .JAVA
* folder and export it
    IF JAVA.EXPORT.DRIVE <> "" AND JAVA.EXPORT.PATH <> "" THEN

        STATEMENT = 'EXPORT OBJ.JAVA "':JAVA.NAME:'"'
        STATEMENT := ' TO "':JAVA.EXPORT.DRIVE:':':JAVA.EXPORT.PATH:'"'
        STATEMENT := " ASIS QUIET"

        EXECUTE STATEMENT

    END

    RETURN

REMOVE.JAVA.COMMENTS: ****************************************************
* remove lines from THIS.JAVA.CODE that have time and dates in them      *
**************************************************************************

* the time and date are recorded in a comment line that begins with
* "// * exported".  two additional lines with the server name and compiler
* version follow that one.  find the "Rem * exported" line and delete it 
* and the two lines following
    JAVA.LINES = DCOUNT(THIS.JAVA.CODE, @AM)

    COMMENT.REMOVED = @FALSE
    COMMENT.SEARCH.LINE = JAVA.COMMENT.PREFIX:"* exported"
    COMMENT.SEARCH.LEN = LEN(COMMENT.SEARCH.LINE)

    FOR JAVA.LOOP = 1 TO JAVA.LINES UNTIL COMMENT.REMOVED

        THIS.LINE = THIS.JAVA.CODE<JAVA.LOOP>

        IF THIS.LINE [1, COMMENT.SEARCH.LEN] = COMMENT.SEARCH.LINE THEN
            DEL THIS.JAVA.CODE<JAVA.LOOP>
            DEL THIS.JAVA.CODE<JAVA.LOOP>
            DEL THIS.JAVA.CODE<JAVA.LOOP>
            COMMENT.REMOVED = @TRUE
        END

    NEXT JAVA.LOOP

    RETURN


**************************************************************************
**************************************************************************
** api / java / listing                                                 **
**************************************************************************
**************************************************************************

LIST.JAVA.CODE: **********************************************************
* list java code, usually for debugging                                  *
**************************************************************************

    RETURN


**************************************************************************
**************************************************************************
** user interface / speech                                              **
**************************************************************************
**************************************************************************

SPEAK: *******************************************************************
* use text-to-speech to say "speech" if ud.say is cataloged              *
**************************************************************************

* if speech is disallowed from the command line return
    IF NOT(ALLOW.SPEECH) THEN
        RETURN
    END

* if this is a proc we can't do any speech
    IF SYSTEM(25) THEN
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* if there's no voc record for ud.say we also can't do any speech
    SPEECH.VOC.NAME = "UD.SPEAK"

    READ VOC.RECORD FROM VOC, SPEECH.VOC.NAME ELSE
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* if the voc record for ud.say isn't a verb then something is amiss.
    IF VOC.RECORD<1> [1, 1] <> "V" THEN
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* say the text
    SPEECH.ERROR = UD.SPEAK(SPEECH)

    RETURN

WAIT.AND.SPEAK: **********************************************************
* use text-to-speech to say "speech" if ud.say is cataloged.  waits      *
* until any previous speaking has finished                               *
**************************************************************************

* if speech is disallowed from the command line return
    IF NOT(ALLOW.SPEECH) THEN
        RETURN
    END

* if this is a proc we can't do any speech
    IF SYSTEM(25) THEN
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* if there's no voc record for ud.say we also can't do any speech
    SPEECH.VOC.NAME = "UD.SPEAK"

    READ VOC.RECORD FROM VOC, SPEECH.VOC.NAME ELSE
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* if the voc record for ud.say isn't a verb then something is amiss.
    IF VOC.RECORD<1> [1, 1] <> "V" THEN
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* say the text
    SPEECH.ERROR = UD.SPEAK(SPEECH, "", 1)

    RETURN

MAYBE.WAIT.AND.SPEAK: ****************************************************
* if we're compiling a single program wait and then speak.  if we're     *
* compiling multiple items don't wait so that we don't slow things down  *
**************************************************************************
    IF OBJECT.COUNT > 1 THEN
        GOSUB SPEAK
    END ELSE
        GOSUB WAIT.AND.SPEAK
    END

    RETURN


**************************************************************************
**************************************************************************
** exiting                                                              **
**************************************************************************
**************************************************************************

WRITE.ERROR: *************************************************************
* display a write.error for error.file, error.item and exit              *
**************************************************************************
    IF EXIT.ON.WRITE.ERROR THEN

        PRINT
        PRINT "FATAL ERROR:  Write error:  Could not write to ":ERROR.FILE:" ":ERROR.ITEM
        PRINT "    Aborting compile"
        PRINT

        GOSUB WRAPUP

    END

    PRINT
    PRINT "WARNING:  Write error:  Could not write to ":ERROR.FILE:" ":ERROR.ITEM
    PRINT "    This file update was not performed"
    PRINT

    RETURN

DELETE.ERROR: ************************************************************
* display a write.error for error.file, error.item and exit              *
**************************************************************************
    IF EXIT.ON.WRITE.ERROR THEN

        PRINT
        PRINT "FATAL ERROR:  Delete error:  Could not delete ":ERROR.FILE:" ":ERROR.ITEM
        PRINT "    Aborting compile"
        PRINT

        GOSUB WRAPUP

    END

    PRINT
    PRINT "WARNING:  Delete error:  Could not delete ":ERROR.FILE:" ":ERROR.ITEM
    PRINT "    This file update was not performed"
    PRINT

    RETURN

WRAPUP: ******************************************************************
* clean up and exit                                                      *
**************************************************************************

* if shortcuts and macros were loaded for listings they'll be loaded in
* a different order than when they're loading for compilation.  if this
* happens the named common area with the shortcuts will have them in the
* wrong order for compiling.  in this situation set the shortcuts.loaded
* flag to false so they'll be reloaded the next time the compiler is run
    IF SHORTCUTS.LOADED.FOR.LISTING THEN
        SHORTCUTS.LOADED = @FALSE
    END

* if the user hit <f12> since the last time a check was done for a user
* abort the <f12> will still in in the input stream and will be evaluated
* by the next program.  this can cause unexpected results.  check for
* an abort now to remove any <f12> from the input stream
    IF CHECK.USER.ABORT THEN
        USER.ABORT = UD.CHECK.ABORT("Compile", "*")
    END

POP.RETURN.STACK:
    RETURN TO POP.RETURN.STACK

    END


**************************************************************************
**************************************************************************
** functions                                                            **
**************************************************************************
**************************************************************************

FUNCTION FOLD.ON.COMMA (TEXT.LINE, MAX.WIDTH, INDENT) ; ******************
* fold a string on the rightmost comma, space or colon                   *
**************************************************************************
* text.line            text line to fold                                 *
* max.width            maximum width in characters                       *
* indent               spaces to indent lines 2 and after                *
*                                                                        *
* returns              folded text, delimited by am                      *
**************************************************************************
    TO.THE.END = 1000000
    FIRST.EXTRACT = @TRUE
    DISPLAY.TEXT = TEXT.LINE

    FOLDED.ARRAY = ""
    FOLDED.COUNT = 0

    LOOP UNTIL DISPLAY.TEXT = ""

        IF FIRST.EXTRACT THEN
            TEXT = ""
            USE.WIDTH = MAX.WIDTH
        END ELSE
            TEXT = SPACE(INDENT)
            USE.WIDTH = MAX.WIDTH - INDENT
        END

* make sure we have a reasonable use.width
        IF USE.WIDTH < 2 THEN
            USE.WIDTH = 2
        END

        FIRST.EXTRACT = @FALSE

* if the line is too long break it at the last comma
        IF LEN(DISPLAY.TEXT) > USE.WIDTH THEN

            THIS.PIECE = DISPLAY.TEXT [1, USE.WIDTH]

            COMMA.COUNT = COUNT(THIS.PIECE, ",")
            COMMA.PTR = INDEX(THIS.PIECE, ",", COMMA.COUNT)

            SPACE.COUNT = COUNT(THIS.PIECE, " ")
            SPACE.PTR = INDEX(THIS.PIECE, " ", SPACE.COUNT)

            COLON.COUNT = COUNT(THIS.PIECE, ":")
            COLON.PTR = INDEX(THIS.PIECE, ":", COLON.COUNT)

* set the break character (comma or space) depending on which character
* is rightmost in the displayable text
            BREAK.CHAR = ""
            BREAK.COUNT = 0
            BREAK.PTR = 0

            IF COMMA.COUNT <> 0 THEN
                BREAK.CHAR = ","
                BREAK.COUNT = COMMA.COUNT
                BREAK.PTR = COMMA.PTR
            END

            IF SPACE.COUNT <> 0 AND SPACE.PTR > BREAK.PTR THEN
                BREAK.CHAR = " "
                BREAK.COUNT = SPACE.COUNT
                BREAK.PTR = SPACE.PTR
            END

            IF COLON.COUNT <> 0 AND COLON.PTR > BREAK.PTR THEN
                BREAK.CHAR = ":"
                BREAK.COUNT = COLON.COUNT
                BREAK.PTR = COLON.PTR
            END

* if we have a break character then break this display line on the rightmost
* break character of displayable text.
            IF BREAK.COUNT > 0 THEN
                THIS.PIECE = THIS.PIECE [BREAK.CHAR, 1, BREAK.COUNT]:BREAK.CHAR
            END

* chop out a piece of display.text the same size as this.piece
            DISPLAY.TEXT = TRIM(DISPLAY.TEXT [LEN(THIS.PIECE) + 1, TO.THE.END], " ", "R")
            TEXT := THIS.PIECE

        END ELSE

            TEXT := DISPLAY.TEXT
            DISPLAY.TEXT = ""

        END

        FOLDED.COUNT += 1
        IF FOLDED.COUNT = 1 THEN
            FOLDED.ARRAY = TEXT
        END ELSE
            FOLDED.ARRAY := @AM:TEXT
        END

    REPEAT

    RETURN (FOLDED.ARRAY)

FUNCTION FORMAT.ARRAY (ARRAY.VALUE) ; ************************************
* display a dynamic array with delimiters translated into printable      *
* characters.  am's, vm's and sm's are printed as printable strings so   *
* they can be converted back upon reading.  any extra trailing           *
* delimiters are removed                                                 *
**************************************************************************
* array.value            dynamic array to reformat                       *
*                                                                        *
* returns                formatted array.value                           *
**************************************************************************
    DISPLAY.ARRAY = ARRAY.VALUE

* if there are any extra trailing delimiters remove then
    AM.COUNT = DCOUNT(DISPLAY.ARRAY, @AM)

    FOR AM.LOOP = 1 TO AM.COUNT

        VM.COUNT = DCOUNT(DISPLAY.ARRAY<AM.LOOP>, @VM)

        FOR VM.LOOP = 1 TO VM.COUNT
            DISPLAY.ARRAY<AM.LOOP, VM.LOOP> = TRIM(DISPLAY.ARRAY<AM.LOOP, VM.LOOP>, @SM, "T")
        NEXT VM.LOOP

        DISPLAY.ARRAY<AM.LOOP> = TRIM(DISPLAY.ARRAY<AM.LOOP>, @VM, "T")

    NEXT AM.LOOP

    DISPLAY.ARRAY = TRIM(DISPLAY.ARRAY, @AM, "T")

* convert delimiters
    DISPLAY.ARRAY = CHANGE(DISPLAY.ARRAY, @AM, "%am%")
    DISPLAY.ARRAY = CHANGE(DISPLAY.ARRAY, @VM, "%vm%")
    DISPLAY.ARRAY = CHANGE(DISPLAY.ARRAY, @SM, "%sm%")

* if array is null show something
    IF DISPLAY.ARRAY = "" THEN
        DISPLAY.ARRAY = "<null>"
    END

    RETURN (DISPLAY.ARRAY)

FUNCTION CONVERT.BYVAL (VARIABLE.NAME, ONLY.CONVERT.SINGLE.VARIABLES) ; **
* return a variable in a form that will pass its value in a subroutine   *
* call by value, rather than by reference.  this will prevent the        *
* changing of a value in a subroutine from changing the value in the     *
* main routine                                                           *
*                                                                        *
* "variable.name" is a parameter expression in a subroutine call so it   *
* may be a variable or it may be a more complex expression.  if it's     *
* a variable then 'variable:""' will be returned.  this turns the        *
* variable into an expression and uniVerse will be forced to send the    *
* result of the expression byval.  if "variable.name" is already an      *
* expression it's already being sent byval and nothing needs to be       *
* done                                                                   *
*                                                                        *
* if only.convert.single.variables is true and variable name is an       *
* expression (as opposed to a single variable) no conversion will be     *
* done                                                                   *
**************************************************************************
* variable.name                  variable name to convert to a byval     *
*                                reference                               *
* only.convert.single.variables  if true variable.name will only be      *
*                                converted if it's a single variable     *
*                                name.  if it's a more complicated       *
*                                expression it will be returned          *
*                                unchanged                               *
*                                                                        *
* returns                        converted variable.name                 *
**************************************************************************

* the variable reference may be one variable or it may be an expression
* containing other operations.  if it's an expression then it's already
* passed by value and we don't need to do anything.  if it's just a
* variable, and not an expression, we need to turn it into an expression
* so that it will be passed by value.
    OPERATOR.LIST = "+-/*:<>=#\'[],":'"'

    IS.EXPRESSION = @FALSE

    BEGIN CASE

* if the variable is null it can't be a byref expression so treat it as
* if it's already a byval expression
        CASE VARIABLE.NAME = ""
            IS.EXPRESSION = @TRUE

* if the "variable" is purely numeric then it can't be a byref expression
* so treat it as already being a byval expression
        CASE NUM(VARIABLE.NAME)
            IS.EXPRESSION = @TRUE

* if any operators exist in the variable name we'll consider this an
* expression
        CASE CONVERT(OPERATOR.LIST, "", VARIABLE.NAME) <> VARIABLE.NAME
            IS.EXPRESSION = @TRUE

    END CASE

* if the "variable" isn't an expression add a null string so that it is
    IF IS.EXPRESSION AND ONLY.CONVERT.SINGLE.VARIABLES THEN
        BYVAL.VARIABLE = VARIABLE.NAME
    END ELSE
        BYVAL.VARIABLE = VARIABLE.NAME:':""'
    END

    RETURN (BYVAL.VARIABLE)

FUNCTION IS.VARIABLE (EXPRESSION) ; **************************************
* returns true if expression is a simple variable (one name, no operands *
* or anything), false if it's an expression                              *
**************************************************************************
* expression             expression to evaluate                          *
*                                                                        *
* returns                true if expression is a single variable, false  *
*                        otherwise                                       *
**************************************************************************

* the variable reference may be one variable or it may be an expression
* containing other operations.  if it's an expression then it's already
* passed by value and we don't need to do anything.  if it's just a
* variable, and not an expression, we need to turn it into an expression
* so that it will be passed by value.
    OPERATOR.LIST = "+-/*:<>=#\'[],":'"'
    VARIABLE.EXPRESSION = @TRUE

    BEGIN CASE

* if the variable is null it's not a variable
        CASE EXPRESSION = ""
            VARIABLE.EXPRESSION = @FALSE

* if the "variable" is purely numeric it's not a variable
        CASE NUM(EXPRESSION)
            VARIABLE.EXPRESSION = @FALSE

* if the variable has any operators in it then it's not a variable, it's 
* a more complex expression
        CASE CONVERT(OPERATOR.LIST, "", EXPRESSION) <> EXPRESSION
            VARIABLE.EXPRESSION = @FALSE
  
    END CASE

    RETURN (VARIABLE.EXPRESSION)

FUNCTION CONVERT.LITERAL.SPACES (PARAMETER.STRING) ; *********************
* Eclipse's precompiler does a trim() on program lines before it         *
* converts to if there are multiple spaces inside of quotes Eclipse's    *
* precompiler removes all but one of these spaces.  very annoying.  this *
* routine scans all the parameters and, if there is more than one space  *
* in a row it replaces the duplicate spaces with a space() function.     *
*                                                                        *
* if a literal string is broken up into a space() expression             *
* concatenated with a literal string the two will be enclosed in         *
* parenthesis to make sure any following formatting code will still      *
* work.  ie, this:                                                       *
*                                                                        *
*         variable = "    literal string" "L#20"                         *
*                                                                        *
* converts to this:                                                      *
*                                                                        *
*         variable = (space(4):"literal string") "L#20"                  *
**************************************************************************
* parameter.string         string containing parameters from a method or *
*                          subroutine call.                              *
*                                                                        *
* returns                  converted parameter string                    *
**************************************************************************
    TO.THE.END = 1000000

    CONVERTED.STRING = PARAMETER.STRING
    CONVERTED.STRING.LEN = LEN(CONVERTED.STRING)

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""
    OPEN.QUOTE.PTR = 0

* if the has no quotes in it there won't be any literal spaces
    SKIP.CHECK = 0

    IF COUNT(CONVERTED.STRING, "'") = 0 AND COUNT(CONVERTED.STRING, '"') = 0 THEN
        SKIP.CHECK = 1
    END

    FOR CHAR.LOOP = 1 TO CONVERTED.STRING.LEN UNTIL SKIP.CHECK

        THIS.CHAR = CONVERTED.STRING [CHAR.LOOP, 1]

* handle quotes
        BEGIN CASE
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR
                OPEN.QUOTE.PTR = CHAR.LOOP
        END CASE

* if we're in quotes and we've hit a space see how many spaces we have
* in a row before hitting another character
        IF IN.QUOTES AND THIS.CHAR = " " THEN

            SPACE.COUNT = 0

            LOOP
                SPACE.COUNT += 1
            UNTIL CONVERTED.STRING [CHAR.LOOP + SPACE.COUNT, 1] <> " "
            REPEAT

* if we have more than one space close the quote, add the space()
* function and then open the quote again
            IF SPACE.COUNT > 1 THEN

* before.string is the code text up to, but not including, the open quote
* leading text is code text from the open quote up to the redundant
* spaces we're replacing
* following.string is everything after the redundant spaces, including
* the closing quote if there is one
                BEFORE.STRING = CONVERTED.STRING [1, OPEN.QUOTE.PTR - 1]
                LEADING.STRING = CONVERTED.STRING [OPEN.QUOTE.PTR, CHAR.LOOP - OPEN.QUOTE.PTR]
                FOLLOWING.STRING = CONVERTED.STRING [CHAR.LOOP + SPACE.COUNT, TO.THE.END]

                SPACE.STRING = "SPACE(":SPACE.COUNT:")"

                LAST.CHAR = LEADING.STRING [1]
                NEXT.CHAR = FOLLOWING.STRING [1, 1]

* replace the spaces with a "space(n)" expression
                BEGIN CASE

* if the character before the spaces is a quote and the character after
* the spaces is also a quote we want to remove both the outside quotes
* and substitute the "space(n)" expression for the spaces
                    CASE LAST.CHAR = THIS.QUOTE AND NEXT.CHAR = THIS.QUOTE
                        CONVERTED.STRING = BEFORE.STRING:SPACE.STRING:FOLLOWING.STRING [2, TO.THE.END]

* if only the character before the spaces is a quote and the characer
* after is not a quote then we want to remove that quote before the spaces,
* substitute "space(n)" for the spaces, and open a quote following the
* "space(n)" expression.  we need to enclose the entire thing in parenthesis
* so it still functions the same if a formatting mask is used
                    CASE LAST.CHAR = THIS.QUOTE
                        CLOSE.QUOTE.PTR = INDEX(FOLLOWING.STRING, THIS.QUOTE, 1)
                        IF CLOSE.QUOTE.PTR > 0 THEN
                            FOLLOWING.STRING = FOLLOWING.STRING [1, CLOSE.QUOTE.PTR]:")":FOLLOWING.STRING [CLOSE.QUOTE.PTR + 1, TO.THE.END]
                        END

                        CONVERTED.STRING = BEFORE.STRING:"(":LEADING.STRING [1, LEN(LEADING.STRING) - 1]
                        CONVERTED.STRING := SPACE.STRING:":":THIS.QUOTE:FOLLOWING.STRING

* if only the character after the spaces is a quote and the character
* before is not a quote then we want to close the quote before the
* "space(n)" expression, replaced the spaces with the "space(n)" expression,
* and remove the following quote.  we need to enclose the entire thing in parenthesis
* so it still functions the same if a formatting mask is used
                    CASE NEXT.CHAR = THIS.QUOTE
                        CONVERTED.STRING = BEFORE.STRING:"(":LEADING.STRING:THIS.QUOTE:":"
                        CONVERTED.STRING := SPACE.STRING:")":FOLLOWING.STRING [2, TO.THE.END]

* if neither the character before the spaces or the one after the spaces
* is a quote then we want to close the leading literal expression,
* substitute the "space(n)" expression for the spaces, and then open
* a quote for the following literal expression.  we need to enclose the
* entire thing in parenthesis so it still functions the same if a formatting
* mask is used
                    CASE 1
                        CLOSE.QUOTE.PTR = INDEX(FOLLOWING.STRING, THIS.QUOTE, 1)
                        IF CLOSE.QUOTE.PTR > 0 THEN
                            FOLLOWING.STRING = FOLLOWING.STRING [1, CLOSE.QUOTE.PTR]:")":FOLLOWING.STRING [CLOSE.QUOTE.PTR + 1, TO.THE.END]
                        END

                        CONVERTED.STRING = BEFORE.STRING:"(":LEADING.STRING:THIS.QUOTE:":"
                        CONVERTED.STRING := SPACE.STRING:":":THIS.QUOTE:FOLLOWING.STRING

                END CASE

                CONVERTED.STRING.LEN = LEN(CONVERTED.STRING)

* reset current pointer to the beginning of the string and try again
                CHAR.LOOP = 0
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""

            END

        END

    NEXT CHAR.LOOP

* if the first character wasn't an open parenthesis before but it is
* now this variable / parameter list may confuse the object calls.  the
* leading open parenthesis will make the compiler think it has a reference
* to an object array.

* so, if we didn't start with an open parenthesis before but we do now
* let's start with a null string so that we don't have an open parenthesis
* right away
    IF PARAMETER.STRING [1, 1] <> "(" AND CONVERTED.STRING [1, 1] = "(" THEN
        CONVERTED.STRING = '"":':CONVERTED.STRING
    END

    RETURN (CONVERTED.STRING)

FUNCTION FIND.INDENT.COUNT (LINE.LABEL, PROGRAM.LINE) ; ******************
* given the label from a program line and the program line (with the     *
* label) return the number of spaces between the label and the start of  *
* the code.  if the line.label is null returns the number of spaces (the *
* indent) before the code starts                                         *
**************************************************************************
* line.label          line label in program.line.  find.indent.count     *
*                     will skip over line.label when counting spaces.    *
*                     it will still count any spaces before and after    *
*                     the line.label but before the code                 *
*                                                                        *
* returns             count of spaces before the code                    *
**************************************************************************
    TO.THE.END = 1000000

    INDENT.COUNT = 0
    CHECK.PROGRAM.LINE = PROGRAM.LINE

* if there are any spaces before the label we'll count those as well
    IF CHECK.PROGRAM.LINE [1, 1] = " " THEN
        TRIM.PROGRAM.LINE = TRIM(CHECK.PROGRAM.LINE, " ", "L")
        INDENT.COUNT += LEN(CHECK.PROGRAM.LINE) - LEN(TRIM.PROGRAM.LINE)
        CHECK.PROGRAM.LINE = TRIM.PROGRAM.LINE
    END

* if we have a label add in any spaces after the label
    IF LINE.LABEL <> "" THEN
        CODE.LINE = CHECK.PROGRAM.LINE [LEN(LINE.LABEL) + 1, TO.THE.END]
        INDENT.COUNT += LEN(CODE.LINE) - LEN(TRIM(CODE.LINE, " ", "L"))
    END

    RETURN (INDENT.COUNT)

FUNCTION SMART.TRIM (TRIM.STRING) ; **************************************
* remove any redundant spaces in trim.string that aren't enclosed by     *
* quotes.  all leading and trailing spaces are also removed              *
**************************************************************************
* trim.string         string to be trimmed                               *
*                                                                        *
* returns             trimmed string                                     *
**************************************************************************
    TO.THE.END = 1000000

* trim leading and trailing blanks
    TRIMMED.STRING = TRIM(TRIM.STRING, " ", "B")

* if there aren't any double spaces anywhere we don't need to clean this
* up
    IF INDEX(TRIMMED.STRING, "  ", 1) > 0 THEN

* if there are no quotes in trimmed.string we can use a simple trim 
* statement 
        IF COUNT(TRIMMED.STRING, '"') = 0 AND COUNT(TRIMMED.STRING, "'") = 0 THEN

            TRIMMED.STRING = TRIM(TRIMMED.STRING)

        END ELSE

* remove any redundant spaces that aren't in quote
            TRIMMED.STRING.LEN = LEN(TRIMMED.STRING)
            IN.QUOTES = @FALSE
            THIS.QUOTE = ""

            FOR CHAR.LOOP = 1 TO TRIMMED.STRING.LEN

                THIS.CHAR = TRIMMED.STRING [CHAR.LOOP, 1]

                BEGIN CASE

* handle quotes
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR

* check for redundant spaces
                    CASE TRIMMED.STRING [CHAR.LOOP, 2] = "  "
                        TRIMMED.STRING = TRIMMED.STRING [1, CHAR.LOOP]:TRIMMED.STRING [CHAR.LOOP + 2, TO.THE.END]
                        TRIMMED.STRING.LEN -= 1
                        CHAR.LOOP -= 1

                END CASE

            NEXT CHAR.LOOP

        END

    END

    RETURN (TRIMMED.STRING)

FUNCTION SMART.TRIM.ALL (TRIM.STRING) ; **********************************
* remove any and all spaces in trim.string that aren't enclosed by       *
* quotes.  all leading and trailing spaces are also removed              *
**************************************************************************
* trim.string         string to be trimmed                               *
*                                                                        *
* returns             trimmed string                                     *
**************************************************************************
    TO.THE.END = 1000000

* trim leading and trailing blanks
    TRIMMED.STRING = TRIM(TRIM.STRING, " ", "B")

* if there aren't any spaces anywhere we don't need to clean this up
    IF COUNT(TRIMMED.STRING, " ") <> 0 THEN

* if there aren't any quotes in trimmed.string then we can use a simple
* change statement 
        IF COUNT(TRIMMED.STRING, '"') = 0 AND COUNT(TRIMMED.STRING, "'") = 0 THEN

            TRIMMED.STRING = CHANGE(TRIMMED.STRING, " ", "")

        END ELSE

* remove any spaces that aren't in quotes
            TRIMMED.STRING.LEN = LEN(TRIMMED.STRING)
            IN.QUOTES = @FALSE
            THIS.QUOTE = ""

            FOR CHAR.LOOP = 1 TO TRIMMED.STRING.LEN

                THIS.CHAR = TRIMMED.STRING [CHAR.LOOP, 1]

                BEGIN CASE

* handle quotes
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR

* check for any space
                    CASE THIS.CHAR = " "
                        TRIMMED.STRING = TRIMMED.STRING [1, CHAR.LOOP - 1]:TRIMMED.STRING [CHAR.LOOP + 1, TO.THE.END]
                        TRIMMED.STRING.LEN -= 1
                        CHAR.LOOP -= 1

                END CASE

            NEXT CHAR.LOOP

        END

    END

    RETURN (TRIMMED.STRING)

FUNCTION LINE.WITHOUT.LABEL (PROGRAM.LINE) ; *****************************
* return a program line, with leading and trailing spaces removed,       *
* without the statement label (if there is one).                         *
**************************************************************************
* program.line          program line, possibly but not necessarily with  *
*                       a label                                          *
*                                                                        *
* returns               program line, with leading and trailing spaces   *
*                       removed and without the label if one exists      *
**************************************************************************
    DEFFUN LINE.LABEL (PROGRAM.LINE.STRING)

    TO.THE.END = 1000000

    SCAN.LINE = TRIM(PROGRAM.LINE, " ", "B")
    LABEL = LINE.LABEL (SCAN.LINE)

    IF LABEL <> "" THEN
        PROGRAM.LINE.WITHOUT.LABEL = SCAN.LINE [LEN(LABEL) + 1, TO.THE.END]
        PROGRAM.LINE.WITHOUT.LABEL = TRIM(PROGRAM.LINE.WITHOUT.LABEL, " ", "B")
    END ELSE
        PROGRAM.LINE.WITHOUT.LABEL = SCAN.LINE
    END

    RETURN (PROGRAM.LINE.WITHOUT.LABEL)

FUNCTION LINE.LABEL (PROGRAM.LINE) ; *************************************
* if program.line has a label on it return the label.  otherwise return  *
* null                                                                   *
**************************************************************************
* program.line          program line, possibly but not necessarily with  *
*                       a label                                          *
*                                                                        *
* returns               the line label or null if there is no label      *
**************************************************************************
    PROGRAM.LABEL = ""
    INVALID.LABEL.CHARS = "<>=();'":'"'

* check for a comment line beginning with an asterisk or exclaimation point.
* obvious comments won't have a label.  we'll treat blank lines as comment
* lines  
    SCAN.LINE = TRIM(PROGRAM.LINE, " ", "L")
    FIRST.CHAR = SCAN.LINE [1, 1]

    IF FIRST.CHAR <> "!" AND FIRST.CHAR <> "*" AND FIRST.CHAR <> "" THEN

        TEST.LABEL = SCAN.LINE [" ", 1, 1]

        IF TEST.LABEL <> "" THEN

* if there are any invalid characters in the label then it isn't a
* label.  we'll delete any bad characters in the label.  if this
* didn't change the value then we probably have a valid label
            CONVERT.LABEL = TEST.LABEL
            CONVERT INVALID.LABEL.CHARS TO "" IN CONVERT.LABEL

            IF CONVERT.LABEL = TEST.LABEL THEN

* if it ends in a colon, but only 1, then it's a label.  we're using
* double colons as a default for an object delimiter and sometimes we use
* double colons by themselves in "with" constructs.  we don't want this to
* trip as a label
                IF TEST.LABEL [1] = ":" AND TEST.LABEL [2] <> "::" THEN

                    PROGRAM.LABEL = TEST.LABEL

                END ELSE

* if it's numeric it's a label.  does anyone still use numeric labels
* any more?  maybe.
                    IF NUM(TEST.LABEL) THEN
                        PROGRAM.LABEL = TEST.LABEL
                    END

                END

            END

        END

    END

    RETURN (PROGRAM.LABEL)

FUNCTION IS.CODE (PROGRAM.LINE) ; ****************************************
* return true if program.line is a code line, ie, not blank and not a    *
* comment.  lines beginning with a label are considered to be code       *
* lines since they can't be removed without affecting the program's      *
* execution.  returns false otherwise                                    *
**************************************************************************
* program.line            program line to be checked as to whether it's  *
*                         a code line vs a comment line or blank line    *
*                                                                        *
* returns                 true if program.line is code, false otherwise  *
**************************************************************************
    CODE.STATUS = @FALSE

* check for a comment line beginning with an asterisk or exclaimation point
* or a blank line.  anything else we'll consider a code line 
    FIRST.CHAR = TRIM(PROGRAM.LINE, " ", "L") [1, 1]

    IF FIRST.CHAR <> "!" AND FIRST.CHAR <> "*" AND FIRST.CHAR <> "" THEN
        CODE.STATUS = @TRUE
    END

    RETURN (CODE.STATUS)

FUNCTION IS.COMMENT (PROGRAM.LINE) ; *************************************
* return true if program.line is a comment, false otherwise.  lines      *
* beginning with a label are considered to be code lines since they      *
* can't be removed without affecting the program's execution.            *
**************************************************************************
* program.line            program line to be checked as to whether it's  *
*                         a comment line vs a code line or blank line    *
*                                                                        *
* returns                 true if program.line is a comment line, false  *
*                         otherwise                                      *
**************************************************************************
    COMMENT.STATUS = @FALSE

* check for a line beginning with an asterisk or exclaimation point
    FIRST.CHAR = TRIM(PROGRAM.LINE, " ", "L") [1, 1]

    IF FIRST.CHAR = "!" OR FIRST.CHAR = "*" THEN
        COMMENT.STATUS = @TRUE
    END

    RETURN (COMMENT.STATUS)

FUNCTION FIRST.SPACE (STRING.VALUE) ; ************************************
* return a pointer to the first space in string.value that's not in      *
* quotes or parenthesis                                                  *
**************************************************************************
* string            string to examine                                    *
*                                                                        *
* returns           zero if no space is found that isn't inside quotes.  *
*                   returns the space position + ptr.offset if a space   *
*                   is found                                             *
**************************************************************************
    STRING.VALUE.LENGTH = LEN(STRING.VALUE)
    SPACE.PTR = 0

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    PREN.DEPTH = 0

    FOR PTR = 1 TO STRING.VALUE.LENGTH UNTIL SPACE.PTR <> 0

        THIS.CHAR = STRING.VALUE [PTR, 1]

        BEGIN CASE

* quotes
            CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* parenthesis
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH < 0 THEN
                    PREN.DEPTH = 0
                END
            CASE PREN.DEPTH > 0
                NULL

* outside of quotes, hit a space
            CASE THIS.CHAR = " "
                SPACE.PTR = PTR

        END CASE

    NEXT PTR

    RETURN (SPACE.PTR)

FUNCTION FIND.CHAR.PTR (STRING.VALUE, CHAR.VALUE) ; **********************
* return a pointer to the first position where char.value is found in    *
* string.value respecting quotes                                         *
**************************************************************************
* string            string to examine                                    *
* char.value        character to search for                              *
*                                                                        *
* returns           zero if char.vlaue is not found outside of quotes.   *
*                   returns the space position + ptr.offset if           *
*                   char.value is found                                  *
**************************************************************************

* if string.value has no quotes we can just do a simple index statement.
* if there are quotes in there we have to search through the string
* character by character.
    IF COUNT(STRING.VALUE, "'") = 0 AND COUNT(STRING.VALUE, '"') = 0 THEN

        CHAR.VALUE.PTR = INDEX(STRING.VALUE, CHAR.VALUE, 1)

    END ELSE

        STRING.VALUE.LEN = LEN(STRING.VALUE)
        CHAR.VALUE.PTR = 0

        IN.QUOTES = @FALSE
        THIS.QUOTE = ""

        FOR CHAR.PTR = 1 TO STRING.VALUE.LEN UNTIL CHAR.VALUE.PTR <> 0

            THIS.CHAR = STRING.VALUE [CHAR.PTR, 1]

            BEGIN CASE

* handle quotes
                CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                    IN.QUOTES = @FALSE
                    THIS.QUOTE = ""
                CASE IN.QUOTES
                    NULL
                CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                    IN.QUOTES = @TRUE
                    THIS.QUOTE = THIS.CHAR

* we're not in quotes.  did we hit the target character?
                CASE THIS.CHAR = CHAR.VALUE
                    CHAR.VALUE.PTR = CHAR.PTR

            END CASE

        NEXT CHAR.PTR

    END

    RETURN (CHAR.VALUE.PTR)

FUNCTION REMOVE.SPACES (STRING.VALUE) ; **********************************
* remove any spaces from string.value that aren't inside quotes          *
**************************************************************************
* string.value      string to examine                                    *
*                                                                        *
* returns           string with all non-quoted spaces removed            *
**************************************************************************
    TO.THE.END = 100000

    TRIMMED.STRING.VALUE = TRIM(STRING.VALUE, " ", "B")
    STRING.VALUE.LENGTH = LEN(TRIMMED.STRING.VALUE)

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

* if this line has no spaces don't bother looping through it
    IF COUNT(TRIMMED.STRING.VALUE, " ") > 0 THEN

* remove any spaces that aren't inside quotes
        FOR PTR = STRING.VALUE.LENGTH TO 1 STEP -1

            THIS.CHAR = TRIMMED.STRING.VALUE [PTR, 1]

            BEGIN CASE

* quotes
                CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                    IN.QUOTES = @FALSE
                    THIS.QUOTE = ""
                CASE IN.QUOTES
                    NULL
                CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                    IN.QUOTES = @TRUE
                   THIS.QUOTE = THIS.CHAR

* outside of quotes, hit a space
                CASE THIS.CHAR = " "
                   TRIMMED.STRING.VALUE = TRIMMED.STRING.VALUE [1, PTR - 1]:TRIMMED.STRING.VALUE [PTR + 1, TO.THE.END]

            END CASE

        NEXT PTR

    END

    RETURN (TRIMMED.STRING.VALUE)

FUNCTION END.OF.STATEMENT (CODE.STRING) ; ********************************
* return a pointer to the character that marks the end of a statement.   *
* if code.string has a semi-colon that isn't in quotes a pointer will    *
* be returned to the semi-colon.  if there are no semi-colons outside    *
* of quotes a pointer will be returned one more than the length of the   *
* string                                                                 *
**************************************************************************
* code.string          program code line examine                         *
**************************************************************************

* start by defaulting the pointer to after the end of the code string
    CODE.STRING.LEN = LEN(CODE.STRING)
    END.PTR = CODE.STRING.LEN + 1

* if the code string has no semi-colons in it the end of the line will
* always be the end of the string.  if there is a semi-colon it may be
* within quotes so we'll have to look through the string one character at
* a time
    IF COUNT(CODE.STRING, ";") > 0 THEN

        IN.QUOTES = @FALSE
        THIS.QUOTE = ""

        END.FOUND = @FALSE

        FOR PTR = 1 TO CODE.STRING.LEN UNTIL END.FOUND

            THIS.CHAR = CODE.STRING [PTR, 1]

            BEGIN CASE

* quotes
                CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                    IN.QUOTES = @FALSE
                    THIS.QUOTE = ""
                CASE IN.QUOTES
                    NULL
                CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                    IN.QUOTES = @TRUE
                    THIS.QUOTE = THIS.CHAR

* semi-colon, not in quotes
                CASE THIS.CHAR = ";"
                    END.PTR = PTR
                    END.FOUND = @TRUE

            END CASE

        NEXT PTR

    END

    RETURN (END.PTR)

FUNCTION SPLIT.PARAMETERS (PARAMETER.STRING) ; ***************************
* take a string and separate it into a parameter list, mv'ed by am,      *
* respecting quotes, parenthesis, dynamic array references and text      *
* extraction references.  if a closing pren without an open is hit       *
* that's considered the end of parameters.  the same if a closing        *
* dynamic array reference (">") is hit without an open or if a closing   *
* brace is hit without an open.                                          *
*                                                                        *
* if any of the parameters are of the form "nn1...nn2", where "nn1" and  *
* "nn2" are numeric, that parameter will explode into parameters         *
* starting with nn1 and counting up (or down) to nn2.  this is used for  *
* some of the associated field operations                                * 
**************************************************************************
* parameter.string     string to extract parameters from                 *
*                                                                        *
* returns              parameter list, mv'ed by am                       *
**************************************************************************

* clean up parameter.string
    SCAN.STRING = TRIM(PARAMETER.STRING, " ", "B")

    PARAMETER.LIST = SCAN.STRING
    SCAN.STRING.LEN = LEN(SCAN.STRING)

* keep track of how deep we are in a dynamic array reference
    IN.DYNAMIC = @FALSE
    DYNAMIC.DEPTH = 0
    DYNAMIC.PTR = 0
    DYNAMIC.SPLIT = @FALSE

* are we in quotes?
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

* are we in parenthesis?
    IN.PREN = @FALSE
    PREN.DEPTH = 0

* are we in a text extraction reference?
    IN.EXTRACT = @FALSE
    EXTRACT.DEPTH = 0

* brace expression?
    IN.BRACE = @FALSE
    BRACE.DEPTH = 0

* work across parameter string and turn any commas that are not inside
* other structures into attribute marks
    PARAMETER.LIST.COMPLETE = @FALSE

    FOR PTR = 1 TO SCAN.STRING.LEN UNTIL PARAMETER.LIST.COMPLETE

        THIS.CHAR = SCAN.STRING [PTR, 1]

        BEGIN CASE

* quotes
            CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* pren
            CASE THIS.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END
            CASE IN.PREN
                NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                IN.DYNAMIC = @TRUE
                DYNAMIC.DEPTH += 1
            CASE THIS.CHAR = ">"
                DYNAMIC.DEPTH -= 1
                IF DYNAMIC.DEPTH = 0 THEN
                    IN.DYNAMIC = @FALSE
                END
            CASE IN.DYNAMIC
                NULL

* text extract reference
            CASE THIS.CHAR = "["
                IN.EXTRACT = @TRUE
                EXTRACT.DEPTH += 1
            CASE THIS.CHAR = "]"
                EXTRACT.DEPTH -= 1
                IF EXTRACT.DEPTH = 0 THEN
                    IN.EXTRACT = @FALSE
                END
            CASE IN.EXTRACT
                NULL

* brace reference
            CASE THIS.CHAR = "{"
                IN.BRACE = @TRUE
                BRACE.DEPTH += 1
            CASE THIS.CHAR = "}"
                BRACE.DEPTH -= 1
                IF BRACE.DEPTH = 0 THEN
                    IN.BRACE = @FALSE
                END
            CASE IN.BRACE
                NULL

* we hit a comma and we aren't inside any other structures
            CASE THIS.CHAR = ","
                PARAMETER.LIST [PTR, 1] = @AM

* we hit a semi colon and we aren't in any other structures
            CASE THIS.CHAR = ";"
                PARAMETER.LIST.COMPLETE = @TRUE
                PARAMETER.LIST = PARAMETER.LIST [1, PTR - 1]

        END CASE

* the parenthesis depth variable has gone negative.  we've
* hit one more closing parenthesis than we had opening.  we must
* have hit the closing parenthesis of a call or something
        IF PREN.DEPTH < 0 OR DYNAMIC.DEPTH < 0 OR BRACE.DEPTH < 0 THEN
            PARAMETER.LIST.COMPLETE = @TRUE
            PARAMETER.LIST = PARAMETER.LIST [1, PTR - 1]
        END

    NEXT PTR

* check for parameters to explode
    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST, @AM)
    FOR PARAMETER.LOOP = PARAMETER.COUNT TO 1 STEP -1

        THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>

* look for "num...num" to create a list of numbers
        IF INDEX(THIS.PARAMETER, "...", 1) <> 0 THEN

            START.NUMBER = THIS.PARAMETER [".", 1, 1]
            END.NUMBER = THIS.PARAMETER [".", 4, 1]

            SEQUENCE.GOOD = @TRUE

            BEGIN CASE

* verify that this sequence expression is "good".  it should start and end
* with a number and neither can be null
                CASE NOT(NUM(START.NUMBER))
                    SEQUENCE.GOOD = @FALSE
                CASE NOT(NUM(END.NUMBER))
                    SEQUENCE.GOOD = @FALSE
                CASE START.NUMBER = ""
                    SEQUENCE.GOOD = @FALSE
                CASE END.NUMBER = ""
                    SEQUENCE.GOOD = @FALSE

* set the increment to get from the start to the end of the expression
                CASE END.NUMBER > START.NUMBER
                    INCREMENT = 1
                CASE END.NUMBER < START.NUMBER
                    INCREMENT = -1
                CASE 1
                    INCREMENT = 1

            END CASE

* if we have a good sequence delete this parameter and insert numbers
* from the start to the end number
            IF SEQUENCE.GOOD THEN

                DEL PARAMETER.LIST<PARAMETER.LOOP>
                PTR = PARAMETER.LOOP

                FOR NUMBER.LOOP = START.NUMBER TO END.NUMBER STEP INCREMENT
                    INS NUMBER.LOOP BEFORE PARAMETER.LIST<PTR>
                    PTR += 1
                NEXT NUMBER.LOOP

            END

        END

    NEXT PARAMETER.COUNT

 * clean up each parameter
    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST, @AM)
    FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT
        PARAMETER.LIST<PARAMETER.LOOP> = TRIM(PARAMETER.LIST<PARAMETER.LOOP>, " ", "B")
    NEXT PARAMETER.LOOP

    RETURN (PARAMETER.LIST)

FUNCTION SPLIT.METHOD.PARAMETERS (PARAMETER.STRING, MODE) ; **************
* take a string and separate it into a parameter list, mv'ed by am,      *
* respecting quotes, parenthesis, dynamic array references and text      *
* extraction references.  if a closing pren without an open is hit       *
* that's considered the end of parameters.  the same if a closing        *
* dynamic array reference (">") is hit without an open or if a closing   *
* brace is hit without an open                                           *
*                                                                        *
* this function is like split.parameters except that it recognizes a     *
* semi-colon as a parameter delimiter (the same as a comma) and uses     *
* it as the delimiter between input and output parameters. for any       *
* parameters after the semi-colon that do not have a "byref", "byval"    *
* or "handle" modify a "byval" modifier will be added.  this ensures     *
* that all parameters after the semi-colon are passed byval unless       *
* defined otherwise.  parameters before the semi-colon are unchanged     *
* as uniVerse passes parameters as byref normally                        *
*                                                                        *
* this should be used ONLY when analyzing "method" declarations          *
**************************************************************************
* parameter.string     string to extract parameters from                 *
* mode                 mode for returned value                           *
*                          LIST     returns parameter list               *
*                          COUNT    returns the parameter count          *
*                          OUT      output (returned) parameters only    *
*                          OUTCOUNT returns count of output parameters   *
*                          IN       returns input (passed-in) parameters *
*                          INCOUNT  returns count of input parameters    *
*                          CHECK    check parameter list for errors and  *
*                                   return error message if there's a    *
*                                   problem                              *
*                          MANDATORY.CHECK the same as check except that *
*                                   at least one semi-colon is required  *
*                                   to separate input from output        *
*                                   parameters                           *
*                                                                        *
* returns              parameter list or count depending on mode, mv'ed  *
*                      by am.                                            *
*                                                                        *
*                      for anything "IN..." or "OUT..." if the method    *
*                      definition doesn't have a semicolon to separate   *
*                      output parameters from input parameters "?" is    *
*                      returned                                          *
*                                                                        *
*                      if the parameter list has more than one semi-     *
*                      colon "!" is returned                             *
**************************************************************************

* named common so we can get the parameter type keywords from the main
* program
    COMMON /COMPILER.KEYWORDS/ OPTIONAL.KEYWORD
    COMMON /COMPILER.KEYWORDS/ BYVAL.KEYWORD, BYVAL.SPECIAL.KEYWORD, BYREF.KEYWORD

    TO.THE.END = 1000000

* clean up parameter.string
    SCAN.STRING = TRIM(PARAMETER.STRING, " ", "B")

    PARAMETER.LIST = SCAN.STRING
    SCAN.STRING.LEN = LEN(SCAN.STRING)

* error message if there's a problem
    ERROR.MESSAGE = ""

* count if input and output parameters if a semi-colon is used between
* two parameters
    PARAMETER.PTR = 1
    OUTPUT.PARAMETER.COUNT = -1

* keep track of how deep we are in a dynamic array reference
    IN.DYNAMIC = @FALSE
    DYNAMIC.DEPTH = 0
    DYNAMIC.PTR = 0
    DYNAMIC.SPLIT = @FALSE

* are we in quotes?
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

* are we in parenthesis?
    IN.PREN = @FALSE
    PREN.DEPTH = 0

* are we in a text extraction reference?
    IN.EXTRACT = @FALSE
    EXTRACT.DEPTH = 0

* brace expression?
    IN.BRACE = @FALSE
    BRACE.DEPTH = 0

* we'll keep a count of semi-colons we run into.  more than 1 and
* there's a problem with the parameter list
    SEMI.COLON.COUNT = 0

* if the parameter list starts with a semicolon this means that all
* of the parameters are input parameters and should be set up as
* byval
    IF PARAMETER.LIST [1, 1] = ";" THEN

        SCAN.STRING = TRIM(SCAN.STRING [2, TO.THE.END], " ", "B")
        PARAMETER.LIST = SCAN.STRING

        SCAN.STRING.LEN = LEN(SCAN.STRING)
        OUTPUT.PARAMETER.COUNT = 0

        SEMI.COLON.COUNT += 1

    END

* work across parameter string and turn any commas that are not inside
* other structures into attribute marks
    PARAMETER.LIST.COMPLETE = @FALSE

    FOR PTR = 1 TO SCAN.STRING.LEN UNTIL PARAMETER.LIST.COMPLETE

        THIS.CHAR = SCAN.STRING [PTR, 1]

        BEGIN CASE

* quotes
            CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* pren
            CASE THIS.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END
            CASE IN.PREN
                NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                IN.DYNAMIC = @TRUE
                DYNAMIC.DEPTH += 1
            CASE THIS.CHAR = ">"
                DYNAMIC.DEPTH -= 1
                IF DYNAMIC.DEPTH = 0 THEN
                    IN.DYNAMIC = @FALSE
                END
            CASE IN.DYNAMIC
                NULL

* text extract reference
            CASE THIS.CHAR = "["
                IN.EXTRACT = @TRUE
                EXTRACT.DEPTH += 1
            CASE THIS.CHAR = "]"
                EXTRACT.DEPTH -= 1
                IF EXTRACT.DEPTH = 0 THEN
                    IN.EXTRACT = @FALSE
                END
            CASE IN.EXTRACT
                NULL

* brace reference
            CASE THIS.CHAR = "{"
                IN.BRACE = @TRUE
                BRACE.DEPTH += 1
            CASE THIS.CHAR = "}"
                BRACE.DEPTH -= 1
                IF BRACE.DEPTH = 0 THEN
                    IN.BRACE = @FALSE
                END
            CASE IN.BRACE
                NULL

* we hit a comma and we aren't inside any other structures
            CASE THIS.CHAR = ","
                PARAMETER.LIST [PTR, 1] = @AM
                PARAMETER.PTR += 1

* we hit a semi colon and we aren't in any other structures
            CASE THIS.CHAR = ";"
                OUTPUT.PARAMETER.COUNT = PARAMETER.PTR
                PARAMETER.LIST [PTR, 1] = @AM
                PARAMETER.PTR += 1
                SEMI.COLON.COUNT += 1

        END CASE

* the parenthesis depth variable has gone negative.  we've
* hit one more closing parenthesis than we had opening.  we must
* have hit the closing parenthesis of a call or something
        IF PREN.DEPTH < 0 OR DYNAMIC.DEPTH < 0 OR BRACE.DEPTH < 0 THEN
            PARAMETER.LIST.COMPLETE = @TRUE
            PARAMETER.LIST = PARAMETER.LIST [1, PTR - 1]
        END

    NEXT PTR

    PARAMETER.LIST = TRIM(PARAMETER.LIST, @AM, "B")
    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST, @AM)

* if the last character is a semi-colon then all of the parameters
* are output parameters.  this will also leave an extra empty parameter
* at the end of the parameter list.  if this is the case remove the
* empty parameter and set the output.parameter.count to all parameters
*   IF PARAMETER.LIST<PARAMETER.COUNT> = "" THEN
*       DEL PARAMETER.LIST<PARAMETER.COUNT>
*       PARAMETER.COUNT -= 1
*       OUTPUT.PARAMETER.COUNT = PARAMETER.COUNT
*   END

* if the output.parameter count is less than zero then we didn't hit any
* semi-colons as parameter delimiters.  don't do any checking of
* input vs output parameters
    IF OUTPUT.PARAMETER.COUNT < 0 THEN
IN$$2:  INPUT.PARAMETER.COUNT = -1
    END ELSE
IN$$3:    INPUT.PARAMETER.COUNT = PARAMETER.COUNT - OUTPUT.PARAMETER.COUNT
    END

* if input vs output parameters were defined make all the input parameters
* "byval".  and input parameters already set as "byref" will be ignored
    IF INPUT.PARAMETER.COUNT > 0 THEN

        FOR PARAMETER.LOOP = OUTPUT.PARAMETER.COUNT + 1 TO PARAMETER.COUNT

            THIS.PARAMETER = TRIM(PARAMETER.LIST<PARAMETER.LOOP>, " ", "B")

* if there's already a "byref", "handle" or "byval" for this parameter we'll leave
* it alone--it's overriding these default values for "byref" and "byval".
* otherwise we'll add a "byval".  if the parameter has an "optional" keyword
* add the "byval" after the "optional" keyword.  otherwise add it as the
* first keyword in the parameter
            HAVE.BY.SOMETHING = @FALSE
            FIRST.WORD = UPCASE (THIS.PARAMETER [" ", 1, 1])
            SECOND.WORD = UPCASE (THIS.PARAMETER [" ", 2, 1])

            BEGIN CASE
                CASE FIRST.WORD = BYREF.KEYWORD OR SECOND.WORD = BYREF.KEYWORD
                    HAVE.BY.SOMETHING = @TRUE
                CASE FIRST.WORD = BYVAL.KEYWORD OR SECOND.WORD = BYVAL.KEYWORD
                    HAVE.BY.SOMETHING = @TRUE
                CASE FIRST.WORD = BYVAL.SPECIAL.KEYWORD OR SECOND.WORD = BYVAL.SPECIAL.KEYWORD
                    HAVE.BY.SOMETHING = @TRUE
            END CASE

            IF NOT(HAVE.BY.SOMETHING) THEN

                IF FIRST.WORD = OPTIONAL.KEYWORD THEN
                    THIS.PARAMETER = OPTIONAL.KEYWORD:" ":BYVAL.KEYWORD:" ":THIS.PARAMETER [" ", 2, TO.THE.END]
                END ELSE
                    THIS.PARAMETER = BYVAL.KEYWORD:" ":TRIM(THIS.PARAMETER, " ", "L")
                END

                PARAMETER.LIST<PARAMETER.LOOP> = THIS.PARAMETER

            END

        NEXT PARAMETER.LOOP

    END

* clean up each parameter
    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST, @AM)
    FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT
        PARAMETER.LIST<PARAMETER.LOOP> = TRIM(PARAMETER.LIST<PARAMETER.LOOP>, " ", "B")
    NEXT PARAMETER.LOOP

* return final parameter depending on mode
    RETURN.VALUE = ""

    BEGIN CASE

* list mode:  return the extracted parameter list
        CASE MODE = "LIST" OR MODE = ""
            RETURN.VALUE = PARAMETER.LIST

* count mode:  return a count of the extracted parameters
        CASE MODE = "COUNT"
            RETURN.VALUE = PARAMETER.COUNT

* out mode:  return only the output (returned) parameters.  this is determined
* by where the semicolon is in the parameter list.  if the parameter list has
* no semicolon anywhere "?" will be returned to show that it can't be
* determined
        CASE MODE = "OUT" AND OUTPUT.PARAMETER.COUNT = -1
            RETURN.VALUE = "?"
        CASE MODE = "OUT" AND OUTPUT.PARAMETER.COUNT = 0
            RETURN.VALUE = ""
        CASE MODE = "OUT"
            RETURN.VALUE = PARAMETER.LIST [@AM, 1, OUTPUT.PARAMETER.COUNT]

* out count:  return a count of the output (returned) parameters
        CASE MODE = "OUTCOUNT" AND OUTPUT.PARAMETER.COUNT = -1
            RETURN.VALUE = "?"
        CASE MODE = "OUTCOUNT"
            RETURN.VALUE = OUTPUT.PARAMETER.COUNT

* in mode:  return only the input (passed in) parameters.  this is also
* determined by where the semicolon is in the parameter list.
        CASE MODE = "IN" AND INPUT.PARAMETER.COUNT = -1
            RETURN.VALUE = "?"
        CASE MODE = "IN" AND INPUT.PARAMETER.COUNT = 0
            RETURN.VALUE = ""
        CASE MODE = "IN"
            RETURN.VALUE = PARAMETER.LIST [@AM, PARAMETER.COUNT - INPUT.PARAMETER.COUNT + 1, TO.THE.END]

* incount mode:  return only the count of the input (passed in) parameters.
* determined by the semicolon, like everything else
        CASE MODE = "INCOUNT" AND INPUT.PARAMETER.COUNT = -1
            RETURN.VALUE = "?"
        CASE MODE = "INCOUNT"
            RETURN.VALUE =  INPUT.PARAMETER.COUNT

* check parameter list for errors.  if there's more than one semi-colon we
* have an error
        CASE MODE = "CHECK" 

            ERROR.MESSAGE = ""

            IF SEMI.COLON.COUNT > 1 THEN
                ERROR.MESSAGE = "Parameter List has ":SEMI.COLON.COUNT:" semi-colons.  "
                ERROR.MESSAGE := "Only 1 is valid: ":PARAMETER.STRING
            END

            RETURN.VALUE = ERROR.MESSAGE

* check parameter list for errors and it's mandatory to separate input from
* output parameters.  if there's more than one semi-colon we have an error.
* if there are no semi-colons we have an error
        CASE MODE = "MANDATORY.CHECK" 

            ERROR.MESSAGE = ""

            IF SEMI.COLON.COUNT > 1 THEN
                ERROR.MESSAGE = "Parameter List has ":SEMI.COLON.COUNT:" semi-colons.  "
                ERROR.MESSAGE := "Only 1 is valid: ":PARAMETER.STRING
            END

            IF PARAMETER.COUNT > 0 AND SEMI.COLON.COUNT = 0 THEN
                ERROR.MESSAGE = "Input and output parameters are not separated"
                ERROR.MESSAGE := " by a semi-colon: ":PARAMETER.STRING
            END

            RETURN.VALUE = ERROR.MESSAGE

* anything else . . . return the parameter list
        CASE 1
            RETURN.VALUE = PARAMETER.LIST
            
    END CASE

    RETURN (RETURN.VALUE)

FUNCTION SPLIT.CODE.LINE (CODE.STRING) ; *********************************
* take a string and separate each expression, delimited by spaces, into  *
* an expession list mv'ed by am.  respects quotes, parenthesis,          *
* dynamic array references and text extraction references.               *
**************************************************************************
* code.string          string to extract expressions from                *
*                                                                        *
* returns              parameter list, mv'ed by am                       *
**************************************************************************

* clean up CODE.string
    SCAN.CODE = TRIM(CODE.STRING, " ", "B")

    CODE.LIST = SCAN.CODE
    SCAN.CODE.LEN = LEN(SCAN.CODE)

* keep track of how deep we are in a dynamic array reference
    IN.DYNAMIC = @FALSE
    DYNAMIC.DEPTH = 0
    DYNAMIC.PTR = 0
    DYNAMIC.SPLIT = @FALSE

* are we in quotes?
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

* are we in parenthesis?
    IN.PREN = @FALSE
    PREN.DEPTH = 0

* are we in a text extraction reference?
    IN.EXTRACT = @FALSE
    EXTRACT.DEPTH = 0

* brace expression?
    IN.BRACE = @FALSE
    BRACE.DEPTH = 0

* work across CODE string and turn any commas that are not inside
* other structures into attribute marks
    CODE.LIST.COMPLETE = @FALSE

    FOR PTR = 1 TO SCAN.CODE.LEN UNTIL CODE.LIST.COMPLETE

        THIS.CHAR = SCAN.CODE [PTR, 1]

        BEGIN CASE

* quotes
            CASE THIS.CHAR = THIS.QUOTE AND IN.QUOTES
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* pren
            CASE THIS.CHAR = "("
                IN.PREN = @TRUE
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH = 0 THEN
                    IN.PREN = @FALSE
                END
            CASE IN.PREN
                NULL

* dynamic array reference
            CASE THIS.CHAR = "<"
                IN.DYNAMIC = @TRUE
                DYNAMIC.DEPTH += 1
            CASE THIS.CHAR = ">"
                DYNAMIC.DEPTH -= 1
                IF DYNAMIC.DEPTH <= 0 THEN
                    IN.DYNAMIC = @FALSE
                    DYNAMIC.DEPTH = 0
                END
            CASE IN.DYNAMIC
                NULL

* text extract reference
            CASE THIS.CHAR = "["
                IN.EXTRACT = @TRUE
                EXTRACT.DEPTH += 1
            CASE THIS.CHAR = "]"
                EXTRACT.DEPTH -= 1
                IF EXTRACT.DEPTH = 0 THEN
                    IN.EXTRACT = @FALSE
                END
            CASE IN.EXTRACT
                NULL

* brace reference
            CASE THIS.CHAR = "{"
                IN.BRACE = @TRUE
                BRACE.DEPTH += 1
            CASE THIS.CHAR = "}"
                BRACE.DEPTH -= 1
                IF BRACE.DEPTH = 0 THEN
                    IN.BRACE = @FALSE
                END
            CASE IN.BRACE
                NULL

* we hit a space and we aren't inside any other structures
            CASE THIS.CHAR = " "
                CODE.LIST [PTR, 1] = @AM

* we hit a semi-colon and we aren't in some other construct.  stop
* scanning this line
            CASE THIS.CHAR = ";"
                CODE.LIST.COMPLETE = @TRUE
                CODE.LIST = TRIM(CODE.LIST [1, PTR - 1], " ", "T")

        END CASE

* the parenthesis depth variable has gone negative.  we've
* hit one more closing parenthesis than we had opening.  we must
* have hit the closing parenthesis of a call or something
        IF PREN.DEPTH < 0 OR DYNAMIC.DEPTH < 0 OR BRACE.DEPTH < 0 THEN
            CODE.LIST.COMPLETE = @TRUE
            CODE.LIST = TRIM(CODE.LIST [1, PTR - 1], " ", "T")
        END

    NEXT PTR

    RETURN (CODE.LIST)

FUNCTION DOWNCASE.QUOTE (TEXT) ; *****************************************
* convert a string to lower case, skipping over any text inside quotes   *
**************************************************************************
* text             string to convert to lower case                       *
*                                                                        *
* returns          text with everything outside of quotes in lower case  *
**************************************************************************
    TEXT.LEN = LEN(TEXT)
    DOWNCASE.TEXT = TEXT

    IN.QUOTES = @FALSE
    THIS.QUOTE = ""

    FOR CHAR.PTR = 1 TO TEXT.LEN

        THIS.CHAR = TEXT [CHAR.PTR, 1]

        BEGIN CASE

 * handle quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR
            CASE IN.QUOTES
                NULL

* if we're not in quotes downcase the character
            CASE 1
                DOWNCASE.TEXT [CHAR.PTR, 1] = DOWNCASE(THIS.CHAR)

        END CASE

    NEXT CHAR.PTR

    RETURN (DOWNCASE.TEXT)

FUNCTION SPLIT.COMPOUND.LINE (PROGRAM.LINE) ; ****************************
* split up a compound line into an array of single lines, mv'ed by am.   *
* any label should have already been removed from the line               *
**************************************************************************
* program.line            code line, possibly a compound code line       *
*                                                                        *
* returns                 program.line split into multiple code lines,   *
*                         mv'ed by am                                    *
**************************************************************************

* initialize my program line array
    PROGRAM.LINE.LIST = ""
    PROGRAM.LINE.COUNT = 0

* if the program line has no semicolons in it at all it can't have compound
* lines.  just return it as is
    SEMI.COUNT = DCOUNT(PROGRAM.LINE, ";")

* if the line is an obvious comment we won't bother with it
    TRIM.PROGRAM.LINE = TRIM(PROGRAM.LINE)
    FIRST.CHAR = TRIM.PROGRAM.LINE [1, 1]

    BEGIN CASE

* line is blank
        CASE TRIM.PROGRAM.LINE = ""

            PROGRAM.LINE.LIST = ""
            PROGRAM.LINE.COUNT = 1

* line is an obvious comment
        CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"

            PROGRAM.LINE.LIST = PROGRAM.LINE
            PROGRAM.LINE.COUNT = 1            

* line has no semicolons
        CASE SEMI.COUNT = 0

            PROGRAM.LINE.LIST = PROGRAM.LINE
            PROGRAM.LINE.COUNT = 1

* line has semi colons in it and it's not a comment line.  scan across it
* and change any semi colon that's not in quotes and not in parenthesis to
* an am
        CASE 1

            PROGRAM.LINE.LENGTH = LEN(PROGRAM.LINE)
            PROGRAM.LINE.LIST = PROGRAM.LINE

            PROGRAM.LINE.COUNT = 1

            IN.QUOTES = @FALSE
            THIS.QUOTE = ""

            IN.PREN = @FALSE
            PREN.DEPTH = 0

            FOR CHAR.PTR = 1 TO PROGRAM.LINE.LENGTH

                THIS.CHAR = PROGRAM.LINE [CHAR.PTR, 1]

                BEGIN CASE

* handle quotes
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        THIS.QUOTE = THIS.CHAR
                        IN.QUOTES = @TRUE

* handle parenthesis
                    CASE THIS.CHAR = "("
                        PREN.DEPTH += 1
                        IN.PREN = @TRUE
                    CASE THIS.CHAR = ")"
                        PREN.DEPTH -= 1
                        IF PREN.DEPTH < 0 THEN
                            PREN.DEPTH = 0
                        END
                        IF PREN.DEPTH = 0 THEN
                            IN.PREN = @FALSE
                        END
                    CASE IN.PREN
                        NULL

* semi colon, not in quotes or parenthesis
                    CASE THIS.CHAR = ";"
                        PROGRAM.LINE.LIST [CHAR.PTR, 1] = @AM

                END CASE

            NEXT CHAR.PTR

    END CASE

    RETURN (PROGRAM.LINE.LIST)

FUNCTION CHECK.PARENTHESIS (PROGRAM.LINE) ; ******************************
* check a program line to make sure every open pren has a close, every   *
* open bracket has a close, and every open quote has a close quote       *
**************************************************************************
* program.line             code line to check                            *
*                                                                        *
* returns                  error message if all opened parenthesis are   *
*                          not closed                                    *
**************************************************************************
    DEFFUN LINE.WITHOUT.LABEL (CODE.LINE)

    SCAN.LINE = LINE.WITHOUT.LABEL (PROGRAM.LINE)
    RESPONSE = ""

* is this an obvious comment line?  if so we'll skip this check
    IF SCAN.LINE [1, 1] <> "*" AND SCAN.LINE [1, 1] <> "!" THEN

* loop across line, skipping text inside quotes, and count the number
* of pren, bracket and quote characters
        OPEN.PREN.COUNT = 0
        CLOSE.PREN.COUNT = 0

        OPEN.BRACKET.COUNT = 0
        CLOSE.BRACKET.COUNT = 0

        OPEN.QUOTE.COUNT = 0
        CLOSE.QUOTE.COUNT = 0

        IN.QUOTES = @FALSE
        THIS.QUOTE = ""

        NEW.LINE = @FALSE
        END.OF.LINE = @FALSE

        LINE.LENGTH = LEN(SCAN.LINE)

        FOR PTR = 1 TO LINE.LENGTH UNTIL END.OF.LINE

            THIS.CHAR = SCAN.LINE [PTR, 1]

            BEGIN CASE

* quotes
                CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                    CLOSE.QUOTE.COUNT += 1
                    IN.QUOTES = @FALSE

                CASE IN.QUOTES
                    NULL
                CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                    OPEN.QUOTE.COUNT += 1
                    IN.QUOTES = @TRUE
                    THIS.QUOTE = THIS.CHAR

* parenthesis
                CASE THIS.CHAR = "("
                    OPEN.PREN.COUNT += 1
                CASE THIS.CHAR = ")"
                    CLOSE.PREN.COUNT += 1

* brackets
                CASE THIS.CHAR = "["
                    OPEN.BRACKET.COUNT += 1
                CASE THIS.CHAR = "]"
                    CLOSE.BRACKET.COUNT += 1

* crossed a semi-colon.  start of a new line
                CASE THIS.CHAR = ";"
                    NEW.LINE = @TRUE

* crossed an asterisk while at the start of a line.  this is a comment so
* end the line scan
                CASE NEW.LINE AND THIS.CHAR = "*"
                    END.OF.LINE = @TRUE

* crossed a non-space, non-semicolon at the start of a line.  this isn't
* a comment
                CASE NEW.LINE AND THIS.CHAR <> " " AND THIS.CHAR <> "*"
                    NEW.LINE = @FALSE

            END CASE

        NEXT PTR

* now that we have our totals set response if we have any count mismatches
        BEGIN CASE

            CASE OPEN.QUOTE.COUNT <> CLOSE.QUOTE.COUNT
                RESPONSE = "Mismatched quotes"

            CASE OPEN.PREN.COUNT <> CLOSE.PREN.COUNT
                RESPONSE = "Mismatched parenthesis"

            CASE OPEN.BRACKET.COUNT <> CLOSE.BRACKET.COUNT
                RESPONSE = "Mismatched brackets"

        END CASE

    END

    RETURN (RESPONSE)

FUNCTION CONVERT.DYNAMIC.DUPE (PROGRAM.LINE) ; ***************************
* scan a program line for any "dynamic duplicates", like this:           *
*                                                                        *
*     variable <1><1, x>                                                 *
*                                                                        *
* and convert them to:                                                   *
*                                                                        *
*     variable <1, x>                                                    *
*                                                                        *
* these references can be generated by some shortcuts and macros.  the   *
* dynamic duplicates compile just fine but they run a bit slow           *
**************************************************************************
* program.line              code line to examine                         *
*                                                                        *
* returns                   code line with any duplicate dynamic array   *
*                           references merged into a single dynamic      *
*                           array reference                              *
**************************************************************************

* not finished yet
    DEFFUN SPLIT.PARAMETERS (PARAMETER.STRING)

    CONVERTED.LINE = PROGRAM.LINE
    TO.THE.END = 10000000

* look for a "><1," to indicate a dynamic duplicate
    DUPLICATE.STRING = "><1,"
    DUPLICATE.STRING.LEN = LEN(DUPLICATE.STRING)
    SEARCH.PTR = 1

    LOOP

        DUPLICATE.PTR = INDEX(CONVERTED.LINE, DUPLICATE.STRING, SEARCH.PTR)

    UNTIL DUPLICATE.PTR < 1

* extract the dynamic array references for the dynamic extractions before and
* after the duplicate string
        PART.BEFORE = PROGRAM.LINE [1, DUPLICATE.PTR - 1]
        OPEN.COUNT = DCOUNT(PART.BEFORE, "<")
        PARAMETERS.BEFORE = PART.BEFORE ["<", OPEN.COUNT, 1]
        PART.BEFORE = PART.BEFORE ["<", 1, OPEN.COUNT - 1]

        PART.AFTER = PROGRAM.LINE [DUPLICATE.PTR + 2, TO.THE.END]
        PARAMETERS.AFTER = PART.AFTER [">", 1, 1]
        PART.AFTER = PART.AFTER [">", 2, TO.THE.END]

* if we don't find any parameters before or after (?) somethings amiss so 
* we'll leave it alone
        IF PARAMETERS.BEFORE = "" OR PARAMETERS.AFTER = "" THEN

            SEARCH.PTR += 1

        END ELSE

* separate parameters for each dynamic array reference
            PARAMETERS.BEFORE = SPLIT.PARAMETERS(PARAMETERS.BEFORE)
            BEFORE.AM = PARAMETERS.BEFORE<1>
            BEFORE.VM = PARAMETERS.BEFORE<2>
            BEFORE.SM = PARAMETERS.BEFORE<3>

            PARAMETERS.AFTER = SPLIT.PARAMETERS(PARAMETERS.AFTER)
            AFTER.AM = PARAMETERS.AFTER<1>
            AFTER.VM = PARAMETERS.AFTER<2>
            AFTER.SM = PARAMETERS.AFTER<3>

* decide on parameters to use for the dynamic array reference.  in order
* to do the merge the am, vm and sm must either be null for both
* references or 1 for at least one
            FINAL.AM = ""
            FINAL.VM = ""
            FINAL.SM = ""

            BEGIN CASE
                CASE BEFORE.AM = "" AND AFTER.AM = ""
                    NULL
                CASE BEFORE.AM = ""
                    FINAL.AM = AFTER.AM
                CASE AFTER.AM = ""
                    FINAL.AM = BEFORE.AM
                CASE BEFORE.AM = "1" AND AFTER.AM <> "1"
                    FINAL.AM = AFTER.AM
                CASE AFTER.AM = "1" AND BEFORE.AM <> "1"
                    FINAL.AM = BEFORE.AM
                CASE AFTER.AM = "1" AND BEFORE.AM = "1"
                    FINAL.AM = "1"
            END CASE

            BEGIN CASE
                CASE BEFORE.VM = "" AND AFTER.VM = ""
                    NULL
                CASE BEFORE.VM = ""
                    FINAL.VM = AFTER.VM
                CASE AFTER.VM = ""
                    FINAL.VM = BEFORE.VM
                CASE BEFORE.VM = "1" AND AFTER.VM <> "1"
                    FINAL.VM = AFTER.VM
                CASE AFTER.VM = "1" AND BEFORE.VM <> "1"
                    FINAL.VM = BEFORE.VM
                CASE AFTER.VM = "1" AND BEFORE.VM = "1"
                    FINAL.VM = "1"
                CASE 1
                    FINAL.AM = ""
            END CASE

            BEGIN CASE
                CASE BEFORE.SM = "" AND AFTER.SM = ""
                    NULL
                CASE BEFORE.SM = ""
                    FINAL.SM = AFTER.SM
                CASE AFTER.SM = ""
                    FINAL.SM = BEFORE.SM
                CASE BEFORE.SM = "1" AND AFTER.SM <> "1"
                    FINAL.SM = AFTER.SM
                CASE AFTER.SM = "1" AND BEFORE.SM <> "1"
                    FINAL.SM = BEFORE.SM
                CASE AFTER.SM = "1" AND BEFORE.SM = "1"
                    FINAL.SM = "1"
                CASE 1
                    FINAL.AM = ""
            END CASE

* if we don't have a final am parameter something's amiss.  don't
* convert anything
            IF FINAL.AM = "" THEN

                SEARCH.PTR += 1

            END ELSE

                PARAMETERS.FINAL = FINAL.AM

                IF FINAL.VM <> "" THEN

                    PARAMETERS.FINAL := ",":FINAL.VM

                    IF FINAL.SM <> "" THEN
                        PARAMETERS.FINAL := ",":FINAL.SM
                    END

                END

* build a new program line with the simplified expression
                CONVERTED.LINE = PART.BEFORE:"<":PARAMETERS.FINAL:">":PART.AFTER

            END

        END

    REPEAT

    RETURN (CONVERTED.LINE)

FUNCTION TIME.ELAPSED (START.DATE, START.TIME) ; *************************
* return elapsed time, in seconds, from a start date and time            *
**************************************************************************
    SECONDS.ELAPSED = (DATE() - START.DATE) * 24 * 60 * 60 + (TIME() - START.TIME)

    RETURN (SECONDS.ELAPSED)

FUNCTION DOT.NET (VARIABLE.NAME, FROM.CONVERT.LIST, TO.CONVERT.LIST) ; ***
* convert a variable name from a uniVerse name to a valid .net name.     *
* converts to lowercase except for the first character and any character *
* after a dot.  dots are then removed                                    *
**************************************************************************
    TO.THE.END = 10000000

* build the name for the dotnet method.  some method names that are used
* a lot are reserved keywords in dotnet.  for these methods we'll convert
* them to something else until such time (?) as the code can be corrected
    DOT.NET.NAME = VARIABLE.NAME

    LOCATE UPCASE(DOT.NET.NAME) IN UPCASE(FROM.CONVERT.LIST) SETTING DOT.NET.PTR THEN
        DOT.NET.NAME = TO.CONVERT.LIST<DOT.NET.PTR>
    END

* capitalize the first character and downcase the rest
    DOT.NET.NAME = UPCASE(DOT.NET.NAME [1, 1]):DOWNCASE(DOT.NET.NAME [2, TO.THE.END])

* upcase the first character after any dots
    DOT.COUNT = COUNT(DOT.NET.NAME, ".")

    FOR DOT.LOOP = 1 TO DOT.COUNT

        CHAR.PTR = INDEX(DOT.NET.NAME, ".", DOT.LOOP) + 1
        THIS.CHAR = UPCASE(DOT.NET.NAME [CHAR.PTR, 1])

        IF THIS.CHAR <> "" THEN
            DOT.NET.NAME = DOT.NET.NAME [1, CHAR.PTR - 1]:THIS.CHAR:DOT.NET.NAME [CHAR.PTR + 1, TO.THE.END]
        END

    NEXT DOT.LOOP

* remove any dots
    DOT.NET.NAME = CHANGE(DOT.NET.NAME, ".", "")

    RETURN (DOT.NET.NAME)

FUNCTION JAVA (VARIABLE.NAME, FROM.CONVERT.LIST, TO.CONVERT.LIST) ; ******
* convert a variable name from a uniVerse name to a valid java name.     *
* converts to lowercase except for any character after a dot.  dots are  *
* then removed.                                                          *
**************************************************************************
    TO.THE.END = 10000000

* build the name for the java method.  some method names that are used
* a lot are reserved keywords in java.  for these methods we'll convert
* them to something else until such time (?) as the code can be corrected
    JAVA.NAME = VARIABLE.NAME

    LOCATE UPCASE(JAVA.NAME) IN UPCASE(FROM.CONVERT.LIST) SETTING JAVA.PTR THEN
        JAVA.NAME = TO.CONVERT.LIST<JAVA.PTR>
    END

* downcase the name
    JAVA.NAME = DOWNCASE(JAVA.NAME)

* upcase the first character after any dots
    DOT.COUNT = COUNT(JAVA.NAME, ".")

    FOR DOT.LOOP = 1 TO DOT.COUNT

        CHAR.PTR = INDEX(JAVA.NAME, ".", DOT.LOOP) + 1
        THIS.CHAR = UPCASE(JAVA.NAME [CHAR.PTR, 1])

        IF THIS.CHAR <> "" THEN
            JAVA.NAME = JAVA.NAME [1, CHAR.PTR - 1]:THIS.CHAR:JAVA.NAME [CHAR.PTR + 1, TO.THE.END]
        END

    NEXT DOT.LOOP

* remove any dots
    JAVA.NAME = CHANGE(JAVA.NAME, ".", "")

    RETURN (JAVA.NAME)
