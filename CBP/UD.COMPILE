    SUBROUTINE UD.COMPILE

**************************************************************************
* Programs are meant to be read by humans and only incidentally for      *
* computers to execute.                                                  *
*                           - Donald Knuth                               *
*                                                                        *
* For every minute spent in organizing an hour is earned.                *
*                           - Benjamin Franklin                          *
*                                                                        *
* Always code as if the guy who ends up maintaining your code will be a  *
* violent psychopath who knows where you live.                           *
*                           - John Woods                                 *
*                                                                        *
* Meep!                                                                  *
*                           - Beaker                                     *
**************************************************************************
* THE OBJECT PRECOMPILER:                                                *
*                                                                        *
* - precompiles an object from the OBJ file into separate external       *
*   Eclipse-compatible subroutines in the CBP file                       *
*                                                                        *
* - precompiles an object-enabled subroutine from the OBP file into an   *
*   Eclipse-compatible subroutine in the CBP file                        *
*                                                                        *
**************************************************************************
* INVOKING THE PRECOMPILER:                                              *
*                                                                        *
* UD.COMPILE {filename} program1 program2 . . . option1 option2 . . .    *
* COMPILE {filename} program1 program2 . . . option1 option2 . . .       *
*                                                                        *
*     filename:    usually OBJ or OBP.  if the filename isn't given the  *
*                  compiler will usually find it for you.                *
*                                                                        *
*                  if the program is not in OBJ or OBP the object        *
*                  compiler will pass it through to the eclipse compiler *
*                  unchanged.                                            *
*                                                                        *
*     program:     program names to compile.  "*" to compile an entire   *
*                  file.  is sensitive to an existing active select list *
*                                                                        *
*     options:  listings:                                                *
*                  SHORT        short method listing for objects         *
*                  LIST         long method listing for objects          *
*                  NOPAGE       no paging for listings                   *
*                  SHORTCUTS {n} list program shortcuts                  *
*                               n = 1 or "QUICK" for most used shortcuts *
*                               n = 2 for most shortcuts (default)       *
*                               n = 3 or "ALL" for all shortcuts         *
*                  AUTOCOMPLETE use with SHORTCUTS.  prints shortcuts    *
*                               and macros in an xml format to be used   *
*                               with notepad++ auto completes and        *
*                               calltips                                 *
*                  BOXES        change asterisk boxes to line boxes      *
*                  NOBOXES      override to never use boxes              *
*                                                                        *
*               compiling:                                               *
*                  BRIEF        suppresses most output messages during   *
*                               a compile                                *
*                  DETAILS      shows everything going on during a       *
*                               compile, more than you'd ever want to    *
*                               know.  usually used for debugging        *
*                  BUILD        build routines but don't compile         *
*                  COMPILE      always recompile methods, even if they   *
*                               haven't changed                          *
*                  ALWAYS       always recompile methods, even if they   *
*                               haven't changed.  same as COMPILE        *
*                  NOCOMPILE    same as BUILD                            *
*                  NOSAVE       build but don't save or compile          *
*                                                                        *
*                  DELETE       delete all CBP subroutines that were     *
*                               previously built for this object before  *
*                               compiling this object.  cleans things up *
*                               if method names have been changed or     *
*                               methods have been removed                *
*                                                                        *
*                  SOURCE       insert the object-enabled source code as *
*                               comments before the converted code       *
*                  VIEW         display converted code in a view-only    *
*                               editor window                            *
*                  BREAK        break up compound lines into single      *
*                               lines.  very handy when debugging macros *
*                  LOOK         same as source + view + break + nosave   *
*                                                                        *
*                  USING object1,object2 . . .                           *
*                               compile all items using one or more of   *
*                               these objects                            *
*                                                                        *
*                  WIN          if there are compile errors send them    *
*                               to a view-only editor window             *
*                  NOWIN        Suppress sending errors to a view-only   *
*                               editor window                            *
*                                                                        *
*                  WAIT         wait after each compile so we can see    *
*                               how it went                              *
*                  WAITERROR    wait after a compile for any error that  *
*                               is encountered.                          *
*                  NOWAIT       don't wait on anything, ever.  this      *
*                               suppreses all input routines.  handy     *
*                               when compiling inside of an execute      *
*                                                                        *
*                  FROM file.name object.name                            *
*                               Override the "Created from" file name    *
*                               and object name in the cbp comments that *
*                               tell where the cbp came from             *
*                                                                        *
*                  CTIME        show compile times                       *
*                                                                        *
*                  INEXEC       running in an execute, suppress input.   *
*                               same as "NOWAIT NOPTS REPAIR NOSPEECH    *
*                               NOABORT NOAPI"                           *
*                                                                        *
*                  OPTS         prompt for compiler options              *
*                  NOPTS        do not prompt for compiler options       *
*                                                                        *
*               API creation:                                            *
*                  NOAPI        don't do any API exports (.net or java)  *
*                  ONLYAPI      only do the API exports (both .net and   *
*                               java) but don't recompile the universe   *
*                               object(s)                                *
*                                                                        *
*                  NODOT        don't do any .net class exports          *
*                  ONLYDOT      only do the .net class exports but don't *
*                               compile the universe object              *
*                                                                        *
*                  NOJAVA       don't do any java class exports          *
*                  ONLYJAVA     only do the java class exports butdon't  *
*                               compile the universe object              *
*                                                                        *
*               information fetching:                                    *
*                  OBJECTS      display tables and compile information.  *
*                               used by other programs to retrieve       *
*                               compiler tables and information.         *
*                               objects object.code and object.sub, for  *
*                               for example, do this                     *
*                                                                        *
*               help:                                                    *
*                  HELP         displays these comments as help          *
*                                                                        *
*               misc:                                                    *
*                  NOSPEECH     don't attempt any speech.  this is handy *
*                               for when the compiler is being run       *
*                               remotely and the speech routines may     *
*                               cause things to hang                     *
*                  NOABORT      don't check for a user abort during      *
*                               compilation                              *
*                                                                        *
*                               Compiling with both NOSPEECH and NOABORT *
*                               prevents the compiler from creating any  *
*                               objects.  If recompiling the entire OBJ  *
*                               file and the number of properties have   *
*                               changed in some objects this prevents    *
*                               crashing due to mismatched named common. *
*                                                                        *
*                  NOADD        compile but don't add to the list of     *
*                               "last compiled"                          *
*                                                                        *
*                  REPAIR       runs the object compile so that it       *
*                               avoids calling any objects.  normally it *
*                               calls a few objects.  if one or more of  *
*                               those objects is damaged or missing      *
*                               the object compiler would crash if it    *
*                               tried to call any of them.  "repair"     *
*                               runs without calling ANYTHING so that    *
*                               it can recompile any object, even the    *
*                               ones it normally calls, cleanly.         *
*                               "repair" is the same as using all of     *
*                               these options together:                  *
*                                                                        *
*                                   ALWAYS WAITERROR RELOAD NOWIN NOAPI  *
*                                   NOSPEECH NOABORT                     *
*                                                                        *
*                  CHECK        do a "check" compile.  converts the      *
*                               object code, displaying any object       *
*                               but does not save or compile the eclipse *
*                               code.  "check" is the same as using      *
*                               all of these options together:           *
*                                                                        *
*                                   ALWAYS WAITERROR NOWIN NOPTS NOSAVE  *
*                                                                        *
*                  RELOAD       reload shortcuts and macros from the     *
*                               setup record.  shortcuts and macros are  *
*                               cached in named common since they take   *
*                               awhile to load.  this option forces a    *
*                               reload even if they're already in memory *
*                                                                        *
*                  WARNECLIPSE  warn if there are any "eclipse-style"    *
*                               method calls.  these are calls where     *
*                               the method (or subroutine) has returned  *
*                               parameters but the call has no           *
*                               parameters left of the equals sign but   *
*                               does have parameters to the right        *
*                  NOECLIPSE    do not allow eclipse-style calls         *
*                                                                        *
*                                                                        *
* Examples:                                                              *
*                                                                        *
* :COMPILE PROMPT               precompile the "PROMPT" object.  the     *
*                               precompiler will search through the      *
*                               program file hierarchy and find "PROMPT" *
*                               in OBJ.  it will then create CBP         *
*                               subroutines that are compatible with     *
*                               eclipse.  these subroutines are then     *
*                               compiled down to OC using Eclipse's      *
*                               precompiler                              *
* :COMPILE PROMPT::CLEAR        compile only the "CLEAR" method in the   *
*                               "PROMPT" object                          *
* :COMPILE OBJ *                recompile all object methods that need   *
*                               to be recompiled                         *
* :COMPILE OBJ * ALWAYS         recompile all objects, all methods       *
*                                                                        *
* :COMPILE OBJ *::NEW           recompie the "NEW" method for all        *
*                               objects                                  *
*                                                                        *
* :COMPILE UD.TEST              compile the "UD.TEST" subroutine in OBP. *
*                               the precompiler will search through the  *
*                               program file heirarchy and find          *
*                               "UD.TEST" in OBP.  it will then create   *
*                               CBP UD.TEST with all object references   *
*                               converted to Eclipse-style calls.  it    *
*                               will then call Eclipse's precompiler to  *
*                               compile the CBP version down to OC       *
* :COMPILE OBP *                recompile all OBP programs               *
*                                                                        *
* :COMPILE UD.CBP.PROGRAM       if a CBP program is compiled the pre-    *
*                               compiler again searches through the      *
*                               program file hierarchy.  if it finds the *
*                               program in CBP it invokes the Eclipse    *
*                               precompiler to compile the CBP program   *
*                               down to OC                               *
*                                                                        *
* :COMPILE UD.BP.PROGRAM        BP programs are also passed to the       *
*                               Eclipse precompiler unchanged            *
*                                                                        *
* :COMPILE OC OC.PROGRAM        evaluate an OC program for possible      *
*                               aliasing problems                        *
*                                                                        *
* :COMPILE SCREEN MYSCREEN      Screens, CMPs, and any other "standard"  *
*                               Eclipse files are passed to the Eclipse  *
*                               precompiler unchanged                    *
*                                                                        *
* :COMPILE HELP                 displays this overview in eterm          *
* :COMPILE HELP WIN             displays this overview in a view-only    *
*                               editor window                            *
*                                                                        *
* the "C" command from TCL will bring up a menu of the last 50           *
* previously compiled programs.  choose one with the arrows and it will  *
* be compiled with the "WIN" option:                                     *
*                                                                        *
* :C                                                                     *
*                                                                        *
**************************************************************************
* PROGRAM NAME MATCHING:                                                 *
*                                                                        *
* if the program file is not declared in the command line and the        *
* program name is not found anywhere the object compiler will build a    *
* list of matches and present a menu from which a program may be chosen  *
*                                                                        *
* Program Name        Matching Method                                    *
* partialname]        programs with names beginning with "partialname"   *
*                     will be found                                      *
* [partialname        programs with names ending with "partialname"      *
*                     will be found                                      *
* [partialname]       programs with "partialname" anywhere in the        *
*                     name will be found                                 *
* partialname         Programs with "partialname" anywhere in the name   *
*                     will be found                                      *
* partial1.partial2   programs with dot-delimited fields "partial1" and  *
*                     "partial2" in the name will be found.  any number  *
*                     of dot-delimited partial fields may be specified   *
* partial1.partial2]  programs beginning with "partial1.partial2" will   *
*                     be found.  any number of dot-delimited partial     *
*                     fields may be specified                            *
* [partial1.partial2  programs ending with "partial1.partial2" will be   *
*                     found.  any number of dot-delimited partial fields *
*                     may be specified                                   *
* [partial1.partial2] programs with "partial1.partial2" anywhere in the  *
*                     name will be found                                 *
* .partial.           programs with dot-delimited field "partial"        *
*                     anywhere in the name will be return.  this gets    *
*                     around partials where the partial is a program     *
*                     name, ie, "INP".                                   *
* .partial            programs ending with dot-delimited field           *
*                     "partial" will be returned                         *
* partial.            programs beginning with a dot-delimited field      *
*                     "partial" will be returned                         *
* .partial1.partial2. programs with dot-delimited fields "partial1" and  *
*                     "partial2" anywhere in the name will be returned.  *
*                     this gets around partials where                    *
*                     "partial1.partial2" is a program name.  any number *
*                     of partial names may be specified                  *
* .partial1.partial2  programs with dot-delimited field "partial1"       *
*                     anywhere in the name and ending with dot-delimited *
*                     field "partial2" will be returned.  any number of  *
*                     partial names may be specified                     *
* partial1.partial2.  programs beginning with dot-delimited field        *
*                     "partial1" and dot-delimited field "partial2"      *
*                     anywhere in the name will be returned.  any number *
*                     of partial names may be specified                  *
*                                                                        *
* for example:                                                           *
* UD.DVR              finds all programs with a dot-delimited "UD" and   *
*                     "DVR"                                              *
* UD.DVR]             finds all programs begining with "UD.DVR"          *
* DVR                 finds all programs with a dot-delimited "DVR"      *
* DVR]                finds all programs beginning with "DVR"            *
* [DVR]               finds all programs with "DVR" somewhere in the     *
*                     name                                               *
* [DVR                finds all programs ending with "DVR"               *
* .INP.               finds all programs with a dot-delimited "INP" in   *
*                     the name                                           *
* UD.                 finds all programs beginning with dot-delimited    *
*                     "UD"                                               *
* .REPORT             finds all programs ending with dot-delimited       *
*                     "REPORT"                                           *
* UD.PHR.             finds all programs beginning with dot-delimited    *
*                     "UD" and dot-delimited "PHR" anywhere in the name  *
* .PHR.REPORT         finds all programs with dot-delimited "PHR"        *
*                     anywhere in the name and ending with dot-delimited *
*                     "REPORT"                                           *
**************************************************************************
* CREATING OBJECTS:                                                      *
*                                                                        *
* objects are created in the OBJ file as follows:                        *
*                                                                        *
* the first line should be:                                              *
*                                                                        *
*     OBJECT objectname {option1 {option2 { . . . }}                     *
*                                                                        *
* options:    INSTANCES n     maximum instances of this object           *
*             (n)             the same as "INSTANCES n"                  *
*                                                                        *
*             ALL.SUBS        create all instance-handling subroutines   *
*                             even if not needed                         *
*                                                                        *
*             RESIDENT        this is an object with a single instance   *
*                             that should never be destroyed             *
*                                                                        *
*             FIXED           the maximum number of instances is fixed.  *
*                             dimensions for multi-instance properties   *
*                             will not be redimensioned.  if all         *
*                             available instances are used then a new    *
*                             instance will generate an error            *
*             EXPAND          the maximum number of instances are not    *
*                             fixed.  if the maximum number of instances *
*                             are filled the multi-instance properties   *
*                             will be redimensioned to allow for the     *
*                             additional object instances                *
*             STATUS status   object development status:                 *
*                             EXPERIMENTAL   object is only in the       *
*                                            experimental stages.  it is *
*                                            not ready to move out of    *
*                                            dev                         *
*                             SANDBOX        object will never be needed *
*                                            outside of dev and should   *
*                                            not be installed outside    *
*                                            of dev                      *
*                             DEVELOP        development has started on  *
*                                            the object but it isn't     *
*                                            ready to be pushed to       *
*                                            testing                     *
*                             TEST           object is ready to be       *
*                                            pushed to testing but is    *
*                                            not ready for production    *
*                             PRODUCTION     object is ready for or has  *
*                                            already been pushed to      *
*                                            production                  *
*                             ABANDONED      object is not used or being *
*                                            developed                   *
*                                                                        *
*             TYPE type1, type2, etc                                     *
*                             this declares this object to be part of    *
*                             one or more object "types".  objects are   *
*                             grouped by type in the object viewer       *
*                                                                        *
*             EXTERNAL        include this object when building external *
*                             classes (ie, .net classes) to access       *
*                             objects from outside of uniVerse           *
*                                                                        *
*             NO.DEBUG        this object should not update the object   *
*                             debug file if object debugging is turned   *
*                             on.  this is necessary for some objects    *
*                             (eg, object.debug) that end up in infinite *
*                             calls if they try to update object         *
*                             debugging                                  *
*                                                                        *
* the defaults for FIXED and EXPAND are defined in the ud.compile        *
* compile.setup record                                                   *
*                                                                        *
**************************************************************************
* DECLARING PROPERTIES:                                                  *
*                                                                        *
* properties, statics, constants and child objects are declared up top   *
* like this:                                                             *
*                                                                        *
* properties:                                                            *
*                                                                        *
*     PROPERTY name1, name2, name3(n), name4(n,n)                        *
*     LOCAL.PROPERTY name1, name2, name3(n), name4(n,n)                  *
*                                                                        *
*     FILE.PROPERTY file.handle1, file.handle2                           *
*     LIST.PROPERTY list.handle1, list.handle2                           *
*                                                                        *
*     LOCAL.FILE.PROPERTY file.handle1, file.handle2                     *
*     LOCAL.LIST.PROPERTY list.handle1, list.handle2                     *
*                                                                        *
*  static properties:                                                    *
*                                                                        *
*     STATIC name1, name2, name3(n), name5(n,n)                          *
*     LOCAL.STATIC name1, name2, name3(n), name5(n,n)                    *
*                                                                        *
*     FILE.STATIC file.handle1, file.handle2                             *
*     LIST.STATIC list.handle1, list.handle2                             *
*                                                                        *
*     LOCAL.FILE.STATIC file.handle1, file.handle2                       *
*     LOCAL.LIST.STATIC list.handle1, list.handle2                       *
*                                                                        *
* constants:                                                             *
*                                                                        *
*     CONSTANT name1 = value1, name2 = value2, name3 = value3            *
*     LOCAL.CONSTANT name1 = value1, name2 = value2, name3 = value3      *
*                                                                        *
* child objects:                                                         *
*                                                                        *
*     CHILD childobjecthandle = new (objectname)                         *
*     LOCAL.CHILD childobjecthandle = new (objectname)                   *
*                                                                        *
*     INTIME.CHILD childobjecthandle = new (objectname)                  *
*     LOCAL.INTIME.CHILD childobjecthandle = new (objectname)            *
*                                                                        *
* a "PROPERTY" will have a unique value for each instance of the object. *
* when the object is destroyed all Properties are lost.  changing a      *
* property in one object instance changes the value for that object      *
* instance only.                                                         *
*                                                                        *
* a "STATIC" will have the same value for all instances of the object.   *
* if all object instances are destroyed Statics will retain their        *
* values.  changing a static value in one object instance changes it for *
* all instances of the object.                                           *
*                                                                        *
* a "CONSTANT" will have the same value for all instances of the object. *
* it may be used but not changed.                                        *
*                                                                        *
* a "CHILD" is another object contained within the current object.  it   *
* may be used from the calling object-enabled subroutine.  some objects  *
* may be written with additional parameters in the "new" method.  for    *
* these objects the CHILD statement would look like this:                *
*                                                                        *
*     CHILD childobjecthandle = new (objectname, parm1, parm2 . . .)     *
*                                                                        *
* eg:                                                                    *
*                                                                        *
*     CHILD setting = new (setting, "EMAIL.SETUP")                       *
*     CHILD file.handle = new (file, "INITIALS")                         *
*                                                                        *
* "LOCAL" keywords define properties and child objects that are only     *
* visible within the local object.  they may not be referenced from the  *
* calling subroutine.                                                    *
*                                                                        *
* "FILE" keywords define properties that are file handles.  FILE         *
* properties are handled a bit differently in some situations            *
*                                                                        *
* "LIST" keywords define properties that are list handles.  These are    *
* also handled differently in some situations                            *
*                                                                        *
* "INTIME" child objects ("INTIME.CHILD" and "LOCAL.INTIME.CHILD") are   *
* NOT created / initialized when the new object is created.  they are    *
* created / initialized the first time they are referenced.  use         *
* "INTIME" child objects when you have a child object that isn't likely  *
* to be used for every instance of the object.                           *
*                                                                        *
* Also: an "INTIME" child object can't only be called from outside the   *
* parent object.  Since the "INTIME" child isn't created whent he parent *
* object is created it has no object handle to pass back to the program  *
* creating the parent object.  At this time, then, "INTIME" child        *
* chile objects are always local child objects, even if the              *
* "INTIME.CHILD" keyword is used.                                        *
*                                                                        *
*                                                                        *
* IMPORTANT:                                                             *
*                                                                        *
* object properties are stored in a named common area unique to each     *
* object name.  properties for all instances of an object are stored     *
* in the same named common area.  if a property is added or removed      *
* from an object and the object is recompiled this changes the number    *
* and order of variables in this named common area                       *
*                                                                        *
* uniVerse has no way to delete or reinitialize a named common area      *
* once it has been created.  so, calling an object method after adding   *
* or removing a property will crash with an error since the current      *
* named common area no longer matches the previously created named       *
* common area                                                            *
*                                                                        *
* if a property is added or removed from an object that is active or     *
* has been active at any time during the current session you'll get this *
* error.  log off and back on again                                      *
*                                                                        *
**************************************************************************
* DECLARING METHODS:                                                     *
*                                                                        *
* methods start with:                                                    *
*     METHOD methodname:                                                 *
*     METHOD methodname (out.parameter1, out.parameter2; in.parameter1,  *
*        in.parameter.2, etc):                                           *
*     LOCAL.METHOD methodname:                                           *
*     LOCAL.METHOD methodname (out.parameter1, out.parameter2;           *
*        in.parameter1, in.parameter.2, etc):                            *
*                                                                        *
*     INLINE.METHOD methodname:                                          *
*     INLINE.METHOD methodname (out.parameter1, out.parameter2;          *
*        in.parameter1, in.parameter.2, etc):                            *
*     LOCAL.INLINE.METHOD methodname:                                    *
*     LOCAL.INLINE.METHOD methodname (out.parameter1, out.parameter2;    *
*        in.parameter1, in.parameter.2, etc):                            *
*                                                                        *
*     WRAPPER methodname, subroutinename:                                *
*     WRAPPER methodname, subroutinename (out.parameter1,                *
*        out.parameter2; in.parameter1, in.parameter.2, etc):            *
*                                                                        *
*     TCL.WRAPPER methodname, subroutinename:                            *
*                                                                        *
*     DRIVER.WRAPPER methodname, driverroutinename:                      *
*                                                                        *
*     PHANTOM.WRAPPER methodname, phantomname:                           *
*     PHANTOM.WRAPPER methodname, phantomname (parameter1, parameter2,   *
*         etc):                                                          *
*                                                                        *
*     ROUTINE methodname, subroutinename:                                *
*     ROUTINE methodname, subroutinename (out.parameter1,                *
*         out.parameter2; in.parameter1, in.parameter.2, etc):           *
*                                                                        *
*     INHERITED methodname = objectname::inheritedmethodname             *
*     INHERITED methodname = objectname::                                *
*     INHERITED methodname = objectname                                  *
*     INHERITED methodname = ::inheritedmethodname                       *
*     INHERITED methodname                                               *
*                                                                        *
* "LOCAL" methods ("LOCAL.METHOD" and "LOCAL.INLINE.METHOD") may be      *
* called from within the same object but will not be visible to any      *
* subroutines or objects outside of the current object                   *
*                                                                        *
* if the "INLINE" keyword is used the method will be inlined (included)  *
* into any subroutine that uses the method.  the subroutine code         *
* generate from the method will be $INCLUDEd into the subroutine so that *
* the subroutine call will be an internal call rather than an external   *
* one.                                                                   *
*                                                                        *
* note:  if an inlined program is changed any object or object-enabled   *
* subroutine that uses that method must be recompiled.                   *
*                                                                        *
* if the "WRAPPER" keyword is used the method will be compiled a little  *
* differently.  sometimes a method is created that calls other methods   *
* to perform a complete task.  once this method is created it may be     *
* useful to create a "wrapper" subroutine that can call this "wrapper"   *
* method from a subroutine that may not be subroutine-enabled.  or,      *
* maybe this "wrapper" subroutine would just be more convenient.         *
*                                                                        *
* when a "WRAPPER" method is compiled a subroutine is created the same   *
* as the "METHOD" and "INLINE" methods.  in addition a subroutine is     *
* created in OBP that will call only the wrapper routine and return      *
* without the calling program having to create objects or even know      *
* about objects.  "subroutinename" will be used as the subroutine name.  *
* the OBP routine is then compiled down to a CBP routine that may be     *
* called like any other CBP subroutine.                                  *
*                                                                        *
* the first parameter of the subroutine will always be "ERROR.MESSAGE"   *
* to pass back any fatal errors from the wrapper method call.  the       *
* parameters following "ERROR.MESSAGE" will be the same as the           *
* parameters for the wrapper method.                                     *
*                                                                        *
* a "TCL.WRAPPER" is like a wrapper except that the compiled subroutine  *
* created in the OBP file is designed to be invoked from TCL.  tcl       *
* wrappers have no parameters since TCL-callable subroutines have no     *
* parameters.  once compiled typing the subroutinename from TCL will     *
* run the tcl.wrapper.                                                   *
*                                                                        *
* a "DRIVER.WRAPPER" is a wrapper that creates a driver.  the subroutine *
* created in the OBP file will have the same calling format as standard  *
* eclipse drivers.  it will be a subroutine with a single parameters,    *
* "PASSER"                                                               *
*                                                                        *
* a "PHANTOM.WRAPPER" will create a phantom in the OBP file.  the        *
* phantom process will have a parameter for each parameter in the        *
* phantom.wrapper method.                                                *
*                                                                        *
* a "ROUTINE" wrapper will create an external subroutine name with the   *
* of "subroutinename".  the calling parameters for "subroutinename" will *
* be the same as the parameters for "methodname" and a new instance      *
* of the object will NOT be created as in other wrappers.  the idea is   *
* to be able to create an external subroutine that relates strongly to   *
* this object but still be able to find / maintain the subroutine code   *
* from within the object.  this avoids having a bunch of external        *
* subroutines that are related to this object but can't be found in all  *
* of the other external subroutines.                                     *
*                                                                        *
* note that for all these "wrapper" methods the "subroutinename",        *
* "driverroutinename" and "phantomname" are optional.  if omitted the    *
* method will be exported and compiled without exporting the second      *
* "wrapper" routine.                                                     *
*                                                                        *
* an "INHERITED" method creates a method that passes a call to another   *
* object::method.  the created method will have the same parameters as   *
* the inherited method that is called.  methods cannot be inherited      *
* from "intime" objects.                                                 *
*                                                                        *
* if "objectname" isn't provided the object name from the last INHERITED *
* method is used.  if "inheritedmethodname" isn't provided "methodname"  *
* is used.                                                               *
*                                                                        *
* for example:                                                           *
*                                                                        *
*     INHERITED GET.DESCRIPTION = PRODUCT.FILE::GET.DESCRIPTION          *
*     INHERITED GET.PRICE.LINE = PRODUCT.FILE::GET.PRICE.LINE            *
*     INHERITED GET.PRICE.GROUP = PRODUCT.FILE::GET.PRICE.GROUP          *
*                                                                        *
* could be done this way:                                                *
*                                                                        *
*     INHERITED GET.DESCRIPTION = PRODUCT.FILE::                         *
*     INHERITED GET.PRICE.LINE = ::GET.PRICE.LINE                        *
*     INHERITED GET.PRICE.GROUP = ::GET.PRICE.GROUP                      *
*                                                                        *
* or this way:                                                           *
*                                                                        *
*     INHERITED GET.DESCRIPTION = PRODUCT.FILE::                         *
*     INHERITED GET.PRICE.LINE = ::                                      *
*     INHERITED GET.PRICE.GROUP = ::                                     *
*                                                                        *
* or this way:                                                           *
*                                                                        *
*     INHERITED GET.DESCRIPTION = PRODUCT.FILE                           *
*     INHERITED GET.PRICE.LINE                                           *
*     INHERITED GET.PRICE.GROUP                                          *
*                                                                        *
* the inherited object may be declared with the "INHERIT.FROM" keyword.  *
* leave the "objectname" unpopulated in the "INHERITED" statements that  *
* follow and they will use the object name from the "INHERIT.FROM"       *
* statement.  this may be easier to read:                                *
*                                                                        *
*     INHERIT.FROM PRODUCT.FILE                                          *
*     INHERITED GET.PRICE.LINE                                           *
*     INHERITED GET.PRICE.GROUP                                          *
*                                                                        *
*                                                                        *
* OPTIONAL METHOD PARAMETERS:                                            *
*                                                                        *
* a default value for each parameter may be set with the "OPTIONAL"      *
* keyword:                                                               *
*     METHOD methodname (OPTIONAL parameter1 = default.expression):      *
*                                                                        *
*     METHOD mymethod (OPTIONAL parm1 = "DEFAULT", parm2, parm3):        *
*     METHOD mymethod (OPTIONAL parm1 = parm2, parm2, parm3):            *
*                                                                        *
* if parameter1 is passed null (or left off the call) then it will       *
* be set to default.expression.                                          *
*                                                                        *
* if parameter1 is passed in as @NULL it will be set to ""               *
*                                                                        *
* a default value with update my be set using the "==" operator:         *
*                                                                        *
*     METHOD methodname (OPTIONAL parameter1 == default.expression):     *
*                                                                        *
* if this method is used parameter1 will be set to the default as in the *
* previous example but then default.expression will be set to the final  *
* result.  use this when you want a parameter to be optionally set to    *
* a property but you then want the property to be set to the final       *
* result                                                                 *
*                                                                        *
*                                                                        *
* BYVAL AND BYREF METHOD PARAMETERS:                                     *
*                                                                        *
* parameters may also be defined in the METHOD statement to be passed    *
* by value rather than the default of by reference                       *
*                                                                        *
* parameters that are passed BYVAL will not be changed in the calling    *
* program even if they're changed in the method.  the default in         *
* uniVerse is a BYREF passing--if the value changes in the method the    *
* changed value will be passed back to the calling routine               *
*                                                                        *
* parameters may be declared BYVAL or BYREF in the method or inline      *
* statement.  parameters are BYREF by default:                           *
*                                                                        *
*     METHOD methodname (BYVAL parameter1):                              *
*                                                                        *
* this passes parameter1 by value rather than by reference.  if the      *
* method changes the value of parameter1 the new value will not be       *
* passed back to the calling routine.                                    *
*                                                                        *
* if OPTIONAL and BYVAL are used together use OPTIONAL first:            *
*                                                                        *
*     METHOD mymethod (parm1, OPTIONAL BYVAL parm2 = "DEFAULT"):         *
*                                                                        *
* when writing a method for an object that calls a method in the same    *
* object, same instance use "LOCAL" as the object handle, ie,            *
* "LOCAL::mymethod"                                                      *
*                                                                        *
*                                                                        *
* HANDLE METHOD PARAMETERS:                                              *
*                                                                        *
* passing "handle" variables (file handles, select handles, etc) as      *
* BYVAL parameters presents a special case.  the parameter needs to be   *
* BYVAL but the code produced by the object compiler for BYVAL           *
* parameters won't work with "handle" variables                          *
*                                                                        *
* in these situations use the "HANDLE" option like this:                 *
*                                                                        *
*     METHOD mymethod (parm1, HANDLE select.handle):                     *
*                                                                        *
* the variable will be treated as BYVAL but will be passed with code     *
* compatible with "handle" variables                                     *
*                                                                        *
*                                                                        *
* INPUT VS OUTPUT PARAMETERS:                                            *
*                                                                        *
* method parameters may be defined as "input" (BYVAL) parameters vs      *
* output (BYREF).  as a rule it's handy to have all output (returned)    *
* parameters first followed by all input (passed in) parameters.         *
*                                                                        *
* a method's parameters, in the simplest form, are defined like this:    *
*                                                                        *
* METHOD methodname (parameter1, parameter2; parameter3, parameter4):    *
*                                                                        *
* if a semicolon is used between two parameters that indicates the break *
* between output parameters and input parameters.  all parameters after  *
* the semicolon are considered input parameters will be passed "BYVAL".  *
* in the above example parameter1 and parameter2 are input parameters    *
* and will be called "BYREF" as a default.  parameter3 and parameter4    *
* are output parameters and will be called "BYVAL".  if the called       *
* method changes parameter3 and/or parameter4 the changes will not       *
* propagate back to the calling program                                  *
*                                                                        *
* this behavior can still be overridden with BYVAL and BYREF:            *
*                                                                        *
* METHOD methodname (parameter1, parameter2; parameter3,                 *
*     BYREF parameter4):                                                 *
*                                                                        *
* this would pass parameter4 as a BYREF parameter even though it's after *
* the semi-colon                                                         *
*                                                                        *
* if all parameters are input parameters put the semi-colon first:       *
*                                                                        *
* METHOD methodname (; parameter1, parameter2, parameter3, parameter4):  *
*                                                                        *
* if all parameters are output parameters put the semi-colon last:       *
*                                                                        *
* METHOD methodname (parameter1, parameter2, parameter3, parameter4;):   *
*                                                                        *
*                                                                        *
* note: it's usually a good idea to define optional parameters even when *
* the default value is null.  when the METHOD and METHODS tcl commands   *
* list out an object's methods it lists up to four possible ways of      *
* calling the method:                                                    *
*                                                                        *
*     1. a "subroutine" style call with only the mandatory parameters.   *
*        this is the shortest possible call for this method              *
*     2. a "subroutine" style call with all parameters.  this is the     *
*        most "complete" possible call for this method                   *
*     3. a "function" style call with only the mandatory parameters.     *
*     4. a "function" style call with all parameters                     *
*                                                                        *
* this listing style works best when all input parameters after the      *
* first optional parameter are also optional.                            *
*                                                                        *
* note:  file handles and select list handles must always be passed      *
* BYREF.  to create a BYVAL the precompiler concatenates a null to a     *
* variable to force the compiler to pass a temporary variable in place   *
* of the actual variable.  this renders a file handle unusable           * 
*                                                                        *
* Note:  each property, static or constant assignment requires a call    *
* to an external subroutine.  this is okay for setting things up but     *
* don't get too carried away inside critical loops or things can be slow *
*                                                                        *
**************************************************************************
* CALLING METHODS IN THE SAME OBJECT:                                    *
*                                                                        *
* To call a method that's in the same object use the "LOCAL" keyword:    *
*                                                                        *
* method method1:                                                        *
*     variable = LOCAL::method2                                          *
*                                                                        *
* method method2 (answer):                                               *
*     answer = "whatever"                                                *
*                                                                        *
* if not inside a "with" structure the "LOCAL" keyword is optional.  in  *
* the above example method "method1" could look like this:               *
*                                                                        *
* method method1:                                                        *
*     variable = ::method2                                               *
*                                                                        *
**************************************************************************
* USING OBJECTS IN SUBROUTINES:                                          *
*                                                                        *
* Subroutines that are object-enabled are saved in the OBP file.  when   *
* compiled they create an Eclipse-compatible subroutine in CBP with the  *
* same name.                                                             *
*                                                                        *
* a BP or CBP program may be copied into the OBP file with an updated    *
* format using UD.FORMAT:                                                *
*                                                                        *
*    :UD.FORMAT BP program.name SAVE                                     *
*    :UD.FORMAT CBP program.name SAVE                                    *
*                                                                        *
* this allows a custom version of a BP program, via the formatted copy   *
* in OBP, to use objects and enhanced program structures.                *
*                                                                        *
* "UD.FORMAT" without the "SAVE" option will display the converted       *
* program but will not save it in OBP.                                   *
*                                                                        *
* "UD.FORMAT HELP" for more information.                                 *
*                                                                        *
**************************************************************************
* CREATING OBJECT INSTANCES:                                             *
*                                                                        *
* object-enabled subroutines are created in the OBP file.  objects may   *
* also create objects on the fly, as opposed to creating them as child   *
* objects.  to create objects:                                           *
*                                                                        *
* initializing an object:                                                *
*                                                                        *
*     objecthandle = new (objectname)    create a new object/handle      *
*                                        for an "objectname" object      *
*     objecthandle = old (objectname)    use an existing object handle   *
*                                        as a handle for an "objectname" *
*                                        object                          *
*                                                                        *
* initializing an object array:                                          *
*                                                                        *
*     objecthandle(size) = new (objectname) create a dimensioned object  *
*                                        with "size" elements for an     *
*                                        "objectname" object             *
*     objecthandle(size) = old (objectname) use an existing dimensioned  *
*                                        object handle with "size"       *
*                                        elements for an "objectname"    *
*                                        object                          *
*                                                                        *
* initializing an object, alternate syntax:                              *
*                                                                        *
*     new objectname objecthandle        create a new object/handle      *
*     old objectname objecthandle        use an existing object handle   *
*                                                                        *
*     new objectname objecthandle(size)  create a dimensioned object     *
*     old objectname objecthandle(size)  use an existing dimensioned     *
*                                        object handle                   *
*                                                                        *
* for example:                                                           *
*                                                                        *
*     invoice = new (ledger)             create an instance of the       *
*                                        "ledger" object with "invoice"  *
*                                        as the handle                   *
*     invoice = old (ledger)             invoice is already a handle     *
*                                        for a pre-existing "ledger"     *
*                                        object, ie, it was passed in    *
*                                        as a subroutine parameters.     *
*                                        this informs the precompiler    *
*                                        that "invoice" is a "ledger"    *
*                                        object handle                   *
*                                                                        *
* objects may be written to accept additional parameters in the "new"    *
* method.  if they are the "new" statement would look like this:         *
*                                                                        *
*     objecthandle = new (objectname, parm1, parm2 . . .)                *
*                                                                        *
* eg:                                                                    *
*                                                                        *
*     objecthandle = new (file, "INITIALS")                              *
*     objecthandle = new (setting, "EMAIL.SETUP")                        *
*                                                                        *
**************************************************************************
* CREATING OTHER OBJECT TYPES                                            *
*                                                                        *
* special types of objects may be created with these commands:           *
*                                                                        *
* creating a resident object:                                            *
*                                                                        *
*     objecthandle = new.resident (objectname) create a new resident     *
*                                        object/handle for an            *
*                                        "objectname" object             *
*                                                                        *
*     resident objects aren't automatically destroyed when a subroutine  *
*     or method terminates.  they remain alive so they may be used by    *
*     other subroutines or methods                                       *
*                                                                        *
* creating a multi-threaded object:                                      *
*                                                                        *
*     objecthandle = new.thread (objectname) create a new multi-threaded *
*                                        object/handle of an             *
*                                        "objectname" object             *
*                                                                        *
*     a multi-threaded object is launched as a phantom.  method calls    *
*     communicate with the object through messages allowing methods to   *
*     be processed in parallel in another thread                         *
*                                                                        *
*     objecthandle = old.thread (objectname) create a new multi-threaded *
*                                        object/handle of an             *
*                                        "objectname" object             *
*                                                                        *
*     "old.thread" assumes the object is already defined (ie, it's been  *
*     passed as a subroutine parameter) and alerts the compiler to       *
*     treat objecthandle as a multi-threaded object handle               *
*                                                                        *
**************************************************************************
* DESTROYING AN OBJECT:                                                  *
*                                                                        *
*     objecthandle::destroy                                              *
*     objecthandle(ptr)::destroy                                         *
*                                                                        *
* for example:                                                           *
*                                                                        *
*     invoice = new(ledger)                                              *
*     . . . do things . . .                                              *
*     invoice::destroy                                                   *
*                                                                        *
*                                                                        *
* Automatic Object Destroying:                                           *
*                                                                        *
* if AutoDestroyObjects is true objects created in object-enabled        *
* subroutines are automatically destroyed with the exit.sub.             *
*                                                                        *
* if AutoDestroyMethodObjects is true object created in object methods   *
* will automatically be destroyed with the exit.method.                  *
*                                                                        *
* Child objects of an object are automatically destroyed when the object *
* is destroyed.                                                          *
*                                                                        *
* If AutoDestroyObjects and AutoDestroyMethodObjects are true it's rare  *
* that the "destroy" method will need to be used to manually destroy an  *
* object.                                                                *
*                                                                        *
*                                                                        *
* Manual Object Destroying:                                              *
*                                                                        *
* if AutoDestroyObjects and AutoDestroyMethodObjects are not true then   *
* created objects will not be automatically destroyed when a subroutine  *
* or method has completed.  objects will remain in memory, even after    *
* the subroutine or object method has finished, until explicitly         *
* destroyed.                                                             *
*                                                                        *
* objects are manually destroyed with the "destroy" method call or by    *
* using the "DESTROY.MY.OBJECTS" macro.                                  *
*                                                                        *
* Destroying all objects created in a subroutine or object method in one *
* shot:                                                                  *
*                                                                        *
* the "DESTROY.MY.OBJECTS" macro will destroy all objects created by     *
* the current object-enabled subroutine.  it's not needed if             *
* AutoDestroyObjects is set.                                             *
*                                                                        *
* the "DESTROY.ALL.OBJECTS" macro destroys ALL objects (except for       *
* RESIDENT objects), even if created by other subroutines including the  *
* subroutines that called the current one.  it won't be used very often  *
*                                                                        *
* note: the "destroy" method for a RESIDENT object will not destroy the  *
* object.  RESIDENT objects remain in memory until the user logs off.    *
* for a single-instance object the "destroy" method will only destroy    *
* the object if the current program is the first one to create the       *
* object.  if multiple subroutines or methods create the same single-    *
* instance object a counter is incremented with each create.  the        *
* counter is decremented with each destroy.  the object is only          *
* destroyed when the counter reaches zero.                               *
*                                                                        *
**************************************************************************
* RESETTING AN OBJECT INSTANCE:                                          *
*                                                                        *
* resetting an object will delete the instance of the object and create  *
* a new one.  this restores all the object instance's properties to the  *
* default values of a newly-created object:                              *
*                                                                        *
*     objecthandle::reset                                                *
*                                                                        *
* is equivilant to:                                                      *
*                                                                        *
*     objecthandle::destroy                                              *
*     objecthandle = new(objectname)                                     *
*                                                                        *
* important: when reset destroys and recreates the object the handle     *
* of the object may change.  the handle of the new instance of the       *
* object may be different from the old instance.  because of this any    *
* time an object handle is passed to a method or subroutine it should be *
* passed by reference in case the method or subroutine does a reset on   *
* the object.  that way the new object handle is passed back to the      *
* calling program                                                        *
*                                                                        *
**************************************************************************
* INVOKING (CALLING) A METHOD:                                           *
*                                                                        *
* an object's method is referenced using the object handle (from the     *
* new statement), the method name and any passed parameters:             *
*                                                                        *
*     objecthandle::method (parameter1, parameter2, etc)                 *
*     objecthandle(ptr)::method (parameter1, parameter2, etc)            *
*                                                                        *
* if the method returns a value the call would look like this:           *
*                                                                        *
*     variable = objecthandle::method (parameter1, parameter2, etc)      *
*                                                                        *
*     variable = objecthandle(ptr)::method (parameter1, parameter2, etc) *
*                                                                        *
* if a method returns multiple values all the output (returned) values   *
* may be placed left of the equals sign.  multiple output values may     *
* be enclosed in optional parenthesis:                                   *
*                                                                        *
*     returned1, returned2 = objecthandle::method (passed1, passed2)     *
*     (returned1, returned2) = objecthandle::method (passed1, passed2)   *
*                                                                        *
* if a returned parameter isn't needed it may be passed into a null,     *
* like this:                                                             *
*                                                                        *
*     "", returned2 = objecthandle::method (passed1, passed2)            *
*                                                                        *
* if a method returns multiple values and fewer values are placed left   *
* of the equals sign than are returned by the method the returned        *
* parameters will be padded with nulls during compilation to fill the    *
* missing output parameters.  eg, if "method" returns two values then    *
* this:                                                                  *
*                                                                        *
*     returned1 = objecthandle::method (passed1, passed2)                *
*                                                                        *
* would be compiled as if it had been written like this:                 *
*                                                                        *
*     returned1, "" = objecthandle::method (passed1, passed2)            *
*                                                                        *
* if a method is called that returns values but none of those values are *
* needed call the routine like this:                                     *
*                                                                        *
*     "" = objecthandle::method (passed1, passed2)                       *
*                           or                                           *
*     void = objecthandle::method (passed1, passed2)                     *
*                                                                        *
* without the null or "void" to the left of the equals sign the object   *
* will assume that a "statement" type of call is being used and the      *
* returned values are within the parenthesis to the right of the equals  *
* sign, like this:                                                       *
*                                                                        *
*     objecthandle::method (returned1, returned2, passed1, passed2)      *
*                                                                        *
* this call is also valid but placing the returned values to the left    *
* of the equals sign is easier to read.                                  *
*                                                                        *
* the parenthesis to the right of the equals sign aren't mandatory but   *
* without them the call is occasionally parsed incorrectly.  using the   *
* parenthesis is safer                                                   *
*                                                                        *
*                                                                        *
* CALLING A METHOD FOR ALL OBJECTS IN A DIMENSIONED OBJECT ARRAY:        *
*                                                                        *
* a method may be called for all objects in a dimensioned array, like    *
* this:                                                                  *
*                                                                        *
*     object.handle(*)::method (parameter1, parameter2)                  *
*                                                                        *
* the "*" indicates that all objects in the object.handle array should   *
* be called for "method".                                                *
*                                                                        *
* if the object array is an "intime" object only array objects that have *
* already been initialized will be called.  this form of method call     *
* does NOT initialize any "intime" objects.  this is handy for calling   *
* setup methods in an array of multi.threaded objects.  none, one, or    *
* all of the multi-threaded objects may have been initialized.  we only  *
* want to call the setup method for the objects in the array that have   *
* already been initialized                                               *
*                                                                        *
* for example, we have an array of objects.  we want to call the         *
* "set.date" method for all objects in the array.  we could do this:     *
*                                                                        *
*     object.loop = each (array.size) {                                  *
*         if object.handle(object.loop) <> "" {                          *
*             object.handle(object.loop)::set.date (new.date)            *
*         }                                                              *
*     }                                                                  *
*                                                                        *
* but this is much more convenient:                                      *
*                                                                        *
*     object.handle(*)::set.date (new.date)                              *
*                                                                        *
**************************************************************************
* INVOKING (CALLING) A METHOD USING "ECLIPSE-STYLE" PARAMETERS:          *
*                                                                        *
* note: this is only true if the "AllowAllParametersOnRight" setting     *
* in the compile setup is true                                           *
*                                                                        *
* methods may also be invoked in a style similar to eclipse and uniVerse *
* standard subroutine calls.  if a method returns a value the call       *
* would look like this from the previous section:                        *
*                                                                        *
*     variable = objecthandle::method (parameter1, parameter2, etc)      *
*                                                                        *
* this method may also be called in a "eclipse" style like this:         *
*                                                                        *
*     objecthandle::method (variable, parameter1, parameter2)            *
*                                                                        *
* the downside to enabling "eclipse-style" calls is when you have a      *
* method that returns a value that isn't useful.  all method calls       *
* must have the returned variables defined, even if they aren't needed.  *
* for example, say we have the first example and we don't need           *
* "variable."  if we did a call like this:                               *
*                                                                        *
*     object.handle::method (parameter1, parameter2)                     *
*                                                                        *
* the compiler would interpret this as an "eclipse-style" call.  the     *
* method has three parameters (one returned and two passed) so the       *
* compiler would pass three parameters, "parameter1", "parameter2", and  *
* a null parameter.  this passes the parameters in the wrong positions   *
* unless we do the call like this:                                       *
*                                                                        *
*     void = object.handle::method (parameter1, parameter2)              *
*                                                                        *
* then the compiler passes the three parameters as a null parameter,     *
* "parameter1" and "parameter2" as intended                              *
*                                                                        *
* this can be annoying when a method returns a variable that's not used  *
* very often.  it's easy to forget to supply the void parameter and the  *
* method doesn't execute as intended.  for this reason "eclipse-style"   *
* calls may be disabled:                                                 *
*                                                                        *
* DISABLING "ECLIPSE-STYLE" METHOD CALLS:                                *
*                                                                        *
* if the "AllowAllParametersOnRight" setting is set to false "eclipse-   *
* style" calls are no longer permitted.  if a method returns a value     *
* and there are no parameters to the left of the equals sign it's NOT    *
* assumed to be an "eclipse-style" call.  it's assumed to be a method    *
* call where ALL returned values are ignored.  in this case this:        *
*                                                                        *
*     void = object.handle::method (parameter1, parameter2)              *
*                                                                        *
* compiles the same as this:                                             *
*                                                                        *
*     object.handle::method (parameter1, parameter2)                     *
*                                                                        *
* the downside to this is "eclipse-style" calls may no longer be used.   *
* a call like this:                                                      *
*                                                                        *
*     objecthandle::method (variable, parameter1, parameter2)            *
*                                                                        *
* would generate an error.  it would be compiled equivilant to this:     *
*                                                                        *
*     void = objecthandle::method (variable, parameter1, parameter2)     *
*                                                                        *
* and would have four parameters (one returned and three passed)         *
* rather than the three (one returned and two passed) intended           *
*                                                                        *
**************************************************************************
* PASSING PARAMETERS BY NAME:                                            *
*                                                                        *
* parameters in method calls may be passed by name.  this can be handy   *
* if a method has a lot of parameters and you don't want to specify a    *
* bunch of blank parameters in a row.  a named parameter looks like      *
* this:                                                                  *
*                                                                        *
*    object::method (parametername = passedparameter, etc)               *
*                                                                        *
* where:                                                                 *
*                                                                        *
*    parametername     name of the parameter variable in the method      *
*                      definition                                        *
*    passedparameter   value to pass to this variable                    *
*                                                                        *
* the object precompiler will find the position of parametername in the  *
* parameter list of the method definition and place passedparameter      *
* in the associated position in the final subroutine call:               *
*                                                                        *
*     MYOBJECT::MYMETHOD (THIS.PARAMETER = "string")                     *
*     MYOBJECT::MYMETHOD (THIS.PARAMETER = 100)                          *
*     MYOBJECT::MYMETHOD (THIS.PARAMETER = MY.VARIABLE)                  *
*                                                                        *
*                                                                        *
* the named parameter doesn't have to be the complete name of the        *
* passed parameter for it to be matched to the passed parameter.         *
* partial matches may be used.  partial matches work like this:          *
*                                                                        *
*      - if an exact match is found it's used                            *
*      - each field in the named parameter's name, delimited by dots,    *
*        is matched against each field in the passed parameter's name.   *
*        if one passed parameter has more field matches than all the     *
*        rest that parameter is used.                                    *
*      - if the field in the named parameter matches the beginning       *
*        characters of a field in the passed parameter it's considered   *
*        a field match as well.                                          *
*      - if the named parameter matches more than one passed parameter   *
*        a warning is produced.                                          *
*                                                                        *
* for example, we have this method:                                      *
*                                                                        *
*    OBJECT::METHOD (first.parameter, second.parameter, third.parameter) *
*                                                                        *
* a parameter call like this would be an exact match:                    *
*                                                                        *
*    OBJECT::METHOD (third.parameter = "X")                              *
*                                                                        *
* and would be equivilant to this:                                       *
*                                                                        *
*    OBJECT::METHOD ("", "", "X")                                        *
*                                                                        *
* the parameter call could also be done like this and the named          *
* "third" would match "third.parameter":                                 *
*                                                                        *
*    OBJECT::METHOD (third = "X")                                        *
*                                                                        *
* it could also be done like this.  however, using the entire field is   *
* preferred as it's more descriptive:                                    *
*                                                                        *
*    OBJECT::METHOD (thi = "X")                                          *
*                                                                        *
* a method call like this, however, would generate a warning.  it        *
* matches all three parameters in the method so the correct parameter    *
* can't be determined:                                                   *
*                                                                        *
*    OBJECT::METHOD (parameter = "X")                                    *
*                                                                        *
* as would this:                                                         *
*                                                                        *
*    OBJECT::METHOD (para = "X")                                         *
*                                                                        *
*                                                                        *
* parameters may also be defined directly by position.  if parametername *
* is numeric the parameter expression will be dropped into the call      *
* parameter position pointed to by the numeric "name".  for example:     *
*                                                                        *
*     OBJECT::METHOD (3 = "string")                                      *
*                                                                        *
* would place the literal parameter "string" into the fourth parameter   *
* of the "METHOD" call.  it would be equivilant to this:                 *                                 
*                                                                        *
*    OBJECT::METHOD ("", "", "X")                                        *
*                                                                        *
*                                                                        *
* parameters may also be defined relative to the current parameter       *
* position by using a "+" or "-" before the parameter number.  this:     *
*                                                                        *
*    OBJECT::METHOD ("Y", +1 = "X")                                      *
*                                                                        *
* is equivilant to this:                                                 *
*                                                                        *
*    OBJECT::METHOD ("Y", "", "X")                                       *
*                                                                        *
*                                                                        *
* named parameters may be in any order.  this:                           *
*                                                                        *
*    OBJECT::METHOD (third = "X", first = "Y", second = "Z")             *
*                                                                        *
* is equivilant to:                                                      *
*                                                                        *
*    OBJECT::METHOD ("Y", "Z", "X")                                      *
*                                                                        *
*                                                                        *
* parameters after a named parameter will be placed beginning with the   *
* parameter after the named parameter.  for example:                     *
*                                                                        *
*    OBJECT::METHOD (second = "X", "Y")                                  *
*                                                                        *
* is equivilant to this:                                                 *
*                                                                        *
*    OBJECT::METHOD ("", "X", "Y")                                       *
*                                                                        *
* 'second = "X"' corresponds to the second parameter so "X" is passed    *
* in the second parameter.  the next parameter, "Y", would be placed in  *
* the next parameter, the third.                                         *
*                                                                        *
*                                                                        *
* note: when creating new methods choose the passed parameter names      *
* carefully and then don't change them.  a method call that uses named   *
* parameters may fail if the parameter names change.                     *
*                                                                        *
**************************************************************************
* GETTING AND SETTING A PROPERTY, STATIC OR CONSTANT:                    *
*                                                                        *
*     properties:                                                        *
*                                                                        *
*         variable = objecthandle::propertyname                          *
*         objecthandle::propertyname = variable                          *
*                                                                        *
*     dimensioned properties:                                            *
*                                                                        *
*         array = objecthandle::propertyname                             *
*         objecthandle::propertyname = array                             *
*                                                                        *
*         variable = objecthandle::propertyname(ptr1)                    *
*         objecthandle::propertyname(ptr1) = variable                    *
*                                                                        *
*         variable = objecthandle::propertyname(ptr1,ptr2)               *
*         objecthandle::propertyname(ptr1,ptr2) = variable               *
*                                                                        *
*                                                                        *
*     dimensioned object properties:                                     *
*                                                                        *
*         array = objecthandle(ptr)::propertyname                        *
*         objecthandle(ptr)::propertyname = array                        *
*                                                                        *
*     dimensioned object dimensioned properties:                         *
*                                                                        *
*         variable = objecthandle(ptr)::propertyname(ptr1)               *
*         objecthandle(ptr)::propertyname(ptr1) = variable               *
*                                                                        *
*         variable = objecthandle(ptr)::propertyname(ptr1,ptr2)          *
*         objecthandle(ptr)::propertyname(ptr1,ptr2) = variable          *
*                                                                        *
**************************************************************************
* WRAPPING A PROPERTY:                                                   *
*                                                                        *
* sometimes a property get or put requires additional code to do other   *
* processes.  it may be required to updated other properties, for        *
* when a property value is changed.  in these cases the property get or  *
* put may be "wrapped."                                                  *
*                                                                        *
* to wrap a property "get" create a method with a name of                *
* "get.property.propertyname".  for example, to wrap property            *
* "update.mode" gets create a method like this:                          *
*                                                                        *
*     method get.property.update.mode (value):                           *
*                                                                        *
* in the code for this method update the returned value ("value" in the  *
* preceeding example) and add any additional code here.                  *
*                                                                        *
* to wrap a property "put" create a method with a name of                *
* "put.property.propertyname".  for property "update.mode" it would look *
* like this:                                                             *
*                                                                        *
*     method put.property.update.mode (value, attr, val, subval):        *
*                                                                        *
* attr, value and subval will usually be zero but may be populated if    *
* the calling program is requesting a single field.                      *
*                                                                        *
* in the code for this method update the property with the "value"       *
* passed in and add any additional code here.                            *
*                                                                        *
* for any property "put" or "get" if the associated wrapper method       *
* exists the "put" or "get" will be redirected to that method.           *
*                                                                        *
* it's not required to have both a "put" and a "get" for a property.     *
* for example, a property may have a "put" wrapper without a "get"       *
* wrapper or vice versa                                                  *
*                                                                        *
**************************************************************************
* PASSING PARAMETERS IN A "NEW" STATEMENT:                               *
*                                                                        *
* Parameters may be passed in a "new" statement.  Developer code in the  *
* "new" method may then use those parameters.  These parameters may use  *
* the byref and byval options as well as the "optional" option:          *
*                                                                        *
*     method new (; optional new.control.id = ""):                       *
*                                                                        *
*     * load settings for control.id if passed in                        *
*         ifnotnull new.control.id {                                     *
*             local::set.name (new.control.id)                           *
*         }                                                              *
*                                                                        *
* In the calling program:                                                *
*                                                                        *
*        my.setting = new(setting, "SETTING.NAME.SETUP")                 *
*                                                                        *
* A method name may also be used as a parameter.  If a method name is    *
* used the and a parameters is passed and is not null the method         *
* will be called at the end of the "new" method, passing the parameter   *
* from the same position:                                                *
*                                                                        *
*     method new (; set.name()):                                         *
*                                                                        *
* Multiple parameters may be passed and multiple methods may be called   *
* and any mix of the two is valid.                                       *
*                                                                        *
**************************************************************************
* COPYING AN OBJECT:                                                     *
*                                                                        *
* To copy all properties, constants and child object properties from     *
* one instance of an object to another use the "COPY.OBJECT" method:     *
*                                                                        *
*     object1 = NEW(OBJECT.NAME)                                         *
*     object2 = NEW(OBJECT.NAME)                                         *
*            .  .  .                                                     *
*                                                                        *
* To copy all properties, constants and child object properties from     *
* object1 to object 2:                                                   *
*                                                                        *
*     object1::COPY.OBJECT (object2)                                     *
*                                                                        *
**************************************************************************
* VIEWING CURRENT OBJECTS AND PROPERTIES:                                *
*                                                                        *
* "UD.OBJECT.VIEW" display objects by type and allows drilling down from *
* type to object to method sections to method and more.                  *
*                                                                        *
* object methods may also be display in a view-only editor window with   *
* the "METHODS" command:                                                 *
*                                                                        *
* :METHODS object.name                                                   *
*                                                                        *
* a more condensed method listing may be viewed on screen with the       *
* "SHORT" command:                                                       *
*                                                                        *
* :SHORT object.name                                                     *
*                                                                        *
* if either command is run without an object.name a window is presented  *
* with a list of all objects to choose from.                             *
*                                                                        *
**************************************************************************
* "WITH" STRUCTURES:                                                     *
*                                                                        *
* WITH structures are supported.  WITH specifies the default object      *
* handle to use inside the structure when the object handle is omitted.  *
* END WITH ends the range for the WITH definition.                       *
*                                                                        *
* object references can then be specified without the object handle.     *
* for example:                                                           *
*                                                                        *
*     WITH myobject                                                      *
*         ::RESET                                                        *
*         ::property1 = value1                                           *
*         ::property2 = value2                                           *
*     END WITH                                                           *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     myobject::RESET                                                    *
*     myobject::property1 = value1                                       *
*     myobject::property2 = value2                                       *
*                                                                        *
*                                                                        *
* WITHs may also be defined using braces:                                *
*                                                                        *
*     WITH myobject {                                                    *
*         ::RESET                                                        *
*         ::property1 = value1                                           *
*         ::property2 = value2                                           *
*     }                                                                  *
*                                                                        *
*                                                                        *
* WITHs may be nested.  nested WITHs may begin with a child delimiter    *
* to indicate a child inside of the original WITH object.  ie:           *
*                                                                        *
*     WITH object1 {                                                     *
*         ::property2 = value2                                           *
*         WITH ::object2 {                                               *
*             ::property2 = value2                                       *
*         }                                                              *
*         ::property3 = value3                                           *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     object1::property2 = value2                                        *
*     object1::object2::property2 = value2                               *
*     object1:property3 = value3                                         *
*                                                                        *
* or, the nested WITH may refer to a different object entirely:          *
*                                                                        *
*     WITH object1 {                                                     *
*         ::property2 = value2                                           *
*         WITH object2 {                                                 *
*             ::property2 = value2                                       *
*         }                                                              *
*         ::property3 = value3                                           *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     object1::property2 = value2                                        *
*     object2::object2::property2 = value2                               *
*     object1:property3 = value3                                         *
*                                                                        *
*                                                                        *
* a WITH statement may also define the object reference all the way down *
* to the method name.  this is handy if a method must be called over and *
* over.  the method may then be called using only "::":                  *
*                                                                        *
*     WITH myobject::methodname {                                        *
*         :: (parameter1, parameter2)                                    *
*         :: (parameter3, parameter4)                                    *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     myobject::methodname (parameter1, parameter2)                      *
*     myobject::methodname (parameter3, parameter4)                      *
*                                                                        *
* or:                                                                    *
*                                                                        *
*     WITH myobject::methodname {                                        *
*         parameter1 = :: (parameter2)                                   *
*         parameter3 = :: (parameter4)                                   *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     parameter1 = myobject::methodname (parameter2)                     *
*     parameter3 = myobject::methodname (parameter4)                     *
*                                                                        *
*                                                                        *
* a nested WITH may also be additive if it begins with "::":             *
*                                                                        *
*     WITH object1 {                                                     *
*         ::property2 = value2                                           *
*         WITH ::method {                                                *
*             value3 = :: (parameter3)                                   *
*             value4 = :: (parameter4)                                   *
*         }                                                              *
*         ::property3 = value3                                           *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     object1::property2 = value2                                        *
*     value3 = object1::method (parameter3)                              *
*     value4 = object1::method (parameter4)                              *
*     object1::property3 = value3                                        *
*                                                                        *
*                                                                        *
* an object may be created in a "WITH" statement:                        *
*                                                                        *
*     WITH myobject = new (objectname) {                                 *
*         ::method1 (parameter1, parameter2)                             *
*         ::method2 (parameter3)                                         *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     myobject = new (objectname)                                        *
*     myobject::method1 (parameter1, parameter2)                         *
*     myobject::method2 (parameter3)                                     *
*                                                                        *
*     WITH myobject::method = new (objectname) {                         *
*         :: (parameter1, parameter2)                                    *
*         :: (parameter3)                                                *
*     }                                                                  *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     myobject = new (objectname)                                        *
*     myobject::method (parameter1, parameter2)                          *
*     myobject::method (parameter3)                                      *
*                                                                        *
**************************************************************************
* BRACE STRUCTURES                                                       *
*                                                                        *
* braces may be used in place of some keywords to define program         *
* structures.  this looks vaguely c-like and can be much easier to       *
* read.                                                                  *
*                                                                        *
*    if/then expressions:                                                *
*                                                                        *
*            IF expression {                                             *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            IF expression {                                             *
*                do.something                                            *
*            }{                                                          *
*                do.something.else                                       *
*            }                                                           *
*                                                                        *
*    for/next and for/next/else expressions:                             *
*                                                                        *
*            FOR x = 1 to 10 {                                           *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            FOR x = 1 to 10 until expression {                          *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            FOR x = 1 to 10 until expression {                          *
*                do.something                                            *
*            }{                                                          *
*                do.something.if.loop.terminated.early                   *
*            }                                                           *
*                                                                        *
*    locate expressions:                                                 *
*                                                                        *
*            LOCATE VAR IN VAR.LIST SETTING PTR {                        *
*                do.something                                            *
*            }{                                                          *
*                do.something.else                                       *
*            }                                                           *
*                                                                        *
*            LOCATE VAR IN VAR.LIST SETTING PTR }{                       *
*                do.something.else                                       *
*            }                                                           *
*                                                                        *
*            LOCATE VAR IN VAR.LIST SETTING PTR {}                       *
*                                                                        *
*    case structures:                                                    *
*                                                                        *
*            BEGIN CASE {                                                *
*                CASE expression                                         *
*                    do.something                                        *
*                CASE expression                                         *
*                    do.something.else                                   *
*                OTHER                                                   *
*                    catch.all.code                                      *
*            }                                                           *
*                                                                        *
*            CASES {                                                     *
*                CASE expression                                         *
*                    do.something                                        *
*                CASE expression                                         *
*                    do.something.else                                   *
*                OTHER                                                   *
*                    catch.all.code                                      *
*            }                                                           *
*                                                                        *
*    switch structures:                                                  *
*                                                                        *
*            SWITCH expression {                                         *
*                ? value1                                                *
*                    do.something                                        *
*                ? value2                                                *
*                    do.something.else                                   *
*                OTHER                                                   *
*                    catch.all.code                                      *
*            }                                                           *
*                                                                        *
*    loop structures:                                                    *
*                                                                        *
*            LOOP UNTIL {                                                *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            LOOP                                                        *
*                set.conditions                                          *
*            UNTIL {                                                     *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            FOREVER {                                                   *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*    anything with a then/else clause:                                   *
*                                                                        *
*            OPEN file.name TO file.handle }{                            *
*                do.something.when.couldn't.open                         *
*            }                                                           *
*                                                                        *
*            OPEN file.name TO file.handle {                             *
*                do.something.with.good.open                             *
*            }{                                                          *
*                do.something.when.couldn't.open                         *
*            }                                                           *
*                                                                        *
*            OPEN file.name TO file.handle {}                            *
*                                                                        *
*            READ file.record FROM file.handle }{                        *
*                do.something.not.on.file                                *
*            }                                                           *
*                                                                        *
*            READ file.record FROM file.handle {                         *
*                do.something.when.on.file                               *
*            }{                                                          *
*                do.something.not.on.file                                *
*            }                                                           *
*                                                                        *
*            READ file.record FROM file.handle {}                        *
*                                                                        *
*    handle a statement that needs an "else" but we don't need it:       *
*                                                                        *
*            OPEN file.name to file.handle {}                            *
*                                                                        *
*            READNEXT id from select.handle {}                           *
*                                                                        *
*            READ test.record from file.handle {}                        *
*                                                                        *
* there are a lot of macros for looping through dynamic array, delimited *
* strings, using the "remove" statement and looping through select       *
* lists.  see the macros with "each" in them (each, each.am, each.vm,    *
* etc) in the macro list using the "SHORTCUTS" command.                  *
*                                                                        *
* each of these looping macros has multiple forms and is converted       *
* differently depending on the number of parameters defined in the       *
* macro call:                                                            *
*                                                                        *
* loop forward:                                                          *
*                                                                        *
*     EACH.AM         loop through am-delimited fields                   *
*     EACH.VM         loop through vm-delimited fields                   *
*     EACH.SM         loop through sm-delimited fields                   *
*     EACH.CHAR       loop through each character in a string            *
*     EACH.COMMA      loop through comma-delimited fields                *
*     EACH.SPACE      loop through space-delimited fields                *
*     EACH.DOT        loop through dot-delimited fields                  *
*     EACH.FIELD      loop through character-delimited fields            *
*     EACH.NEXT       loop through a select list                         *
*     EACH.REM        loop through string using a remove loop            *
*     EACH.VALUE      loop through a hard-coded list of values           *
*                                                                        *
* loop backwards:                                                        *
*                                                                        *
*     BACK.AM         loop through am-delimited fields                   *
*     BACK.VM         loop through vm-delimited fields                   *
*     BACK.SM         loop through sm-delimited fields                   *
*     BACK.CHAR       loop through BACK character in a string            *
*     BACK.COMMA      loop through comma-delimited fields                *
*     BACK.SPACE      loop through space-delimited fields                *
*     BACK.DOT        loop through dot-delimited fields                  *
*     BACK.FIELD      loop through character-delimited fields            *
*     BACK.REM        loop through string using a remove loop            *
*     BACK.VALUE      loop through a hard-coded list of values           *
*                                                                        *
*                                                                        *
* examples:                                                              *
*                                                                        *
*     forward looping:                                                   *
*                                                                        *
*            this.field = EACH.AM (am.array, loop.index) {               *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = EACH.REM (am.array, loop.index) {              *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.word = EACH.SPACE (string, space.index) {              *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = EACH.AM (am.array, loop.index, start) {        *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = EACH.AM (am.array, loop.index, start, end) {   *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = EACH.AM (am.array, loop.index, start, end,     *
*                increment) {                                            * 
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = EACH.VALUE (1, 2, "abc", "def", x, y, z) {     *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*     looping through select lists:                                      *
*                                                                        *
*            this.id = EACH.NEXT (select.handle) {                       *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.id = EACH.NEXT (select.handle, index) {                *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*                                                                        *
*     backwards looping:                                                 *
*                                                                        *
*            this.field = BACK.AM (am.array, loop.index) {               *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = BACK.REM (am.array, loop.index) {              *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.word = BACK.SPACE (string, space.index) {              *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = BACK.AM (am.array, loop.index, start) {        *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = BACK.AM (am.array, loop.index, start, end) {   *
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = BACK.AM (am.array, loop.index, start, end,     *
*                increment) {                                            * 
*                do.something                                            *
*            }                                                           *
*                                                                        *
*            this.field = BACK.VALUE (1, 2, "abc", "def", x, y, z) {     *
*                do.something                                            *
*            }                                                           *
*                                                                        *
**************************************************************************
* INLINING SUBROUTINES AND METHODS                                       *
*                                                                        *
* methods that aren't declared "inline" in the object can be inlined     *
* in an object-enabled subroutine on a case-by-case basis                *
*                                                                        *
* the $INLINE directive will "inline" a subroutine, object method or     *
* an entire object.  the subroutine or object methods will be $included  *
* in the subroutine / object code so that calls to the subroutines /     *
* methods are local calls rather than external calls.                    *
*                                                                        *
* this makes things MUCH faster but be careful, the object code size     *
* can grow very large                                                    *
*                                                                        *
* to inline an external subroutine use the "sub" pseudo-object:          *
*                                                                        *
*     $INLINE SUB::MY.SUBROUTINE                                         *
*                                                                        *
* the "ALL" keyword can be used to inline all subroutines called from    *
* this routine:                                                          *
*                                                                        *
*     $INLINE SUB::ALL                                                   *
*                                                                        *
* inline a single object method by using the object name (not the object *
* handle) and the method name:                                           *
*                                                                        *
*     $INLINE MY.OBJECT::MY.METHOD                                       *
*                                                                        *
* additional methods for the same object may be added by omitting the    *
* object name:                                                           *
*                                                                        *
*     $INLINE MY.OBJECT::MY.METHOD, ANOTHER.METHOD, YET.ANOTHER.METHOD   *
*                                                                        *
* to inline an entire object use the "ALL" keyword again:                *
*                                                                        *
*     $INLINE MY.OBJECT::ALL                                             *
*                                                                        *
* to inline property gets and puts to make them faster use the           *
* "PROPERTIES" keyword:                                                  *
*                                                                        *
*     $INLINE MY.OBJECT::PROPERTIES                                      *
*                                                                        *
* to inline a method for all object use the "ALL" keyword again:         *
*                                                                        *
*     $INLINE ALL::NEW                                                   *
*                                                                        *
* to inline everything, subroutines and objects, use the "ALL" keyword   *
* twice:                                                                 *
*                                                                        *
*     $INLINE ALL::ALL                                                   *
*                                                                        *
* or, use the "EVERYTHING" keyword:                                      *
*                                                                        *
*     $INLINE EVERYTHING                                                 *
*                                                                        *
* if UseExternalRedim is set then the redimensioning routine (used to    *
* increase or decrease the dimensions of the multiple instances named    *
* common variables to allow for more or fewer objects) will be created   *
* as a separate external subroutine.  To $inline this subroutine use     *
* "REDIM" as the method name.  It will also be linked in with "::ALL"    *
* or "EVERYTHING"                                                        *
*                                                                        *
*                                                                        *
* METHODS THAT ARE ALWAYS INLINED:                                       *
*                                                                        *
* if a method is defined with the "INLINE" keyword rather than the       *
* "METHOD" keyword it will always be inlined.                            *
*                                                                        *
*                                                                        *
* METHODS ARE INCLUDED IN THE CBP CODE WHEN:                             *
*                                                                        *
*     1. a specific object::method is listed in an $INLINE statement.    *
*        any methods specifically listed will always be inlined, even    *
*        if the precompiler can't find a call to the method              *
*     2. an object::ALL is listed in an $INLINE statement and the method *
*        is called somewhere in the subroutine.  this will (hopefully)   *
*        keep the code size reasonable                                   *
*     3. an ALL:ALL or EVERYTHING is in an $INLINE statement and the     *
*        method is called somewhere in the subroutine                    *
*     4. a method is defined with the INLINE keyword and is called       *
*        somewhere in the subroutine                                     *
*                                                                        *
*                                                                        *
* note: when using "ALL" objects, "ALL" methods and/or "PROPERTIES"      *
* each method's subroutine will be added or not depending on the setting *
* for OnlyInlineIfCalled in ud.control compile.setup.                    *
*                                                                        *
* if OnlyInlineIfCalled is set true then each method's subroutine will   *
* only be inlined if the compiled program containsd a call to that       *
* method.  the "get" and "put" subroutine (for properties) will only be  *
* inlined if there is at least one statement in the program that gets or *
* puts a property to that object.  this is to keep the program size      *
* down.                                                                  *
*                                                                        *
* if OnlyInlineIfCalled is false then EVERY method's subroutine will     *
* be added whether it's called or not.  this makes sure every routine    *
* that could possibly be needed is inlined but it can result in very     *
* huge programs.                                                         *
*                                                                        *
* also note:  if the inlined object or subroutine is changed you MUST    *
* also recompile any object or object-enabled subroutine that uses the   *
* inlined object.  since the inlined object's code is included at        *
* compile time it's called locally rather than externally.  the change   *
* to the inlined object will not be realized by any routine that has     *
* inlined the routine unless that routine is recompiled.  so, use        *
* inlined code with care                                                 *
*                                                                        *
* if the inlined code is still being changed a lot it's better to NOT    *
* inline the code until it's stable and only inline it when it's not     *
* going to change very often                                             *
*                                                                        *
**************************************************************************
* INSTANCE MATCHING                                                      *
*                                                                        *
* in some cases an object instance may be created that could service     *
* many calling programs.  An example may be found in the distributed     *
* object.  the distributed object has an array of 60 partition objects.  *
* each partition object has a setting child object and they all read the *
* same setup record.  this would result in the same setup record being   *
* read, initialized and processed 60 times creating 60 setting           *
* setting instances.  it would be more efficient and faster if all 60    *
* partition objects could share the same instance.                       *
*                                                                        *
* instance matching allows this.  most objects have one property that    *
* defines what the object applies to.  for setting, for example, the     *
* control.id defines the setting record that is read and processed.      *
* instance matching allows all programs that create a setting object     *
* with the same control.id to use the same object instance.              *
*                                                                        *
* this is done with the "match.instance" macro:                          *
*                                                                        *
*     match.instance (matching.property, already.matched)                *
*                                                                        *
* "matching.property" is the property that is used to determine if       *
* another instance of the object has already been created with the same  *
* "matching.property" value.                                             *
*                                                                        *
* "already.matched" is a property used to record whether or not this     *
* object instanced has performed this matching.  this matching should    *
* only be performed once per instance.  create a property for            *
* "already.matched" and leave it null.  the match.instance macro will    *
* check "already.matched" and skip the matching if set.  if not set      *
* match.instance will perform the object matching and set                *
* "already.matched" so that the matching will not be performed a second  *
* time.                                                                  *
*                                                                        *
* for example, for the setting object it looks like this.  control.id    *
* and already.matched are properties:                                    *
*                                                                        *
*     match.instance (control.id, already.matched)                       *
*                                                                        *
* this is placed in an object method just before the matching.property   *
* is used to load up the object.                                         *
*                                                                        *
* when match.instance is executed it checks the already.matched property *
* to see if matching has already been performed.  if already.matched     *
* is @true match.instance does nothing and execution of the method       *
* continues.                                                             *
*                                                                        *
* if already.matched is not @true match.instance looks through the other *
* object instances for an instance whose matching.property matches the   *
* current instance's matching.property.  for example, if setting was     *
* called with a control.id of "EMAIL.SETUP" if would search for another  *
* setting instance where control.id has a value of "EMAIL.SETUP".        *
*                                                                        *
* if a matching instance is found the current instance is modified to    *
* point to the matching instance.  the object handle passed back to the  *
* calling program will be the matching instance's handle, not the        *
* original handle.  the rest of the method will not be executed.  it's   *
* assumed that the rest of the method uses the matching.property to      *
* initialize / load up the object.  this will not be needed since the    *
* matched instance has already done this.  from there the calling        *
* program uses the same (but modified) object handle.                    *
*                                                                        *
* if a matching instance is not found then this is the first time that   *
* the object has encountered the matching.property value.  the current   *
* instance will be changed to a "resident" instance.  this will prevent  *
* the current instance from being destroyed even if the destroy method   *
* is called.                                                             *
*                                                                        *
* in either case already.matched is set to @true so that this matching   *
* will not be performed again for this object instance.                  *
*                                                                        *
* the rest of the method containing the match.instance statement is      *
* executed to initialize / load up the current object.  the current      *
* object is now available for other programs to match should they create *
* an instance with the same matching.property.                           *
*                                                                        *
* these object instances will remain in memory for the rest of the       *
* session.  this allows the object to be used with the same              *
* matching.property over and over while only needing to initialize the   *
* object instance once.                                                  *
*                                                                        *
* important:  method calls, external subroutine calls and calls to       *
* child objects often do some extra checking in case the called          *
* subroutines change the active instance of the object.  if any of the   *
* downstream routines changes the active instance this code will restore *
* the proper instance.  this usually keeps everything safe but it's not  *
* compatible with instance matching.  the instance matching subroutines  *
* WILL change the current instance and it needs to stay changed.         *
*                                                                        *
* so, if you're adding instance matching to an object this checking must *
* be turned off for the "new" method and any methods that the "new"      *
* method may call.  to turn the instancing checking off add this line    *
* to "new" and any method in the same object that "new" may call:        *
*                                                                        *
*     $obj.option AllInstanceChecking = No                               *
*                                                                        *
* this reset a number of settings so that, if instance matching changes  *
* the object's active instance, it won't be changed back.                *
*                                                                        *
* for example, "setting" uses instance matching.  once it creates an     *
* instance that loads a particular setup record it keeps that instance   *
* alive even after the calling program terminates.  if another process   *
* needs the same setup record a new "setting" instance is not created.   *
* the calling process ends up pointing to the first instance that was    *
* previously created for the same setup record.                          *
*                                                                        *
* so, in "setting" the $obj.option line is added to the "new" method.    *
* "new may call "load.settings" and "set.name".  "set.name" calls        *
* "load" and load has the instancing matching code.  "Load" calls        *
* "get.list"  all of these routines need to have the obj.option line in  *
* or the instance matching may not work properly.                        *
*                                                                        *
* this is quite a bit of complexity, but in many situations (like with   *
* the "setting" object) it can result in a considerable increase in      *
* speed.                                                                 *
*                                                                        *
**************************************************************************
* MULTI-THREADED OBJECTS:                                                *
*                                                                        *
* a multi-threaded object is an object created with the "new.thread"     *
* keyword rather than the "new" keyword:                                 *
*                                                                        *
*      my.multi.object = new.thread (object.name)                        *
*                                                                        *
* when a multi-threaded object is created a phantom is started for that  *
* object.  when the "destroy" is executed the phantom is stopped.        *
* this effective turns an object into a phantom controlled by the        *
* calling program                                                        *
*                                                                        *
* all method / property / constant / whatever calls to that object will  *
* be sent as messages to the phantom.  The phantom will process the      *
* requests and send the results back as messages to the calling program. *
* this allows the multi-thread object to process requests while the main *
* program does other things.  it also allows multiple multi-thread       *
* objects to process requests in parallel.                               *
*                                                                        *
* if a method has no returned parameters the main program sends the      *
* request to the object's phantom but does not wait for a response.      *
* this is a "blind" call.  the same thing happens with property          *
* updates--the request goes to the object's phantom but the main program *
* doesn't wait for a response                                            *
*                                                                        *
* method calls that do return parameters are handled differently.        *
* method calls like this:                                                *
*                                                                        *
*     value1, value2 = my.multi.object::method (parameter1, parameter2)  *
*                                                                        *
* will send a message to the phantom, wait for the phantom to process    *
* it, fetch the response and save the response's values in value1 and    *
* value2.  conceptually this works the same as if the object was created *
* with the "new" keyword and is not multi-threaded.  with multi-threaded *
* objects it will be a little slower due to messaging between the main   *
* program and the multi-threaded object's phantom                        *
*                                                                        *
* setting and changing properties still works.  they also go through     *
* a messaging process.  when getting a property value a message will     *
* be sent to the object's phantom and the main routine will wait for     *
* the reply.  if a property value is changed the main program sends the  *
* request but, since there's no returned value, the main program doesn't *
* wait for a response                                                    *
*                                                                        *
*                                                                        *
* FORKED METHOD CALLS:                                                   *
*                                                                        *
* the advantage to multi-threaded objects is that a method call may be   *
* "forked."  calling the method and updating the returned variables      *
* can be slit into two separate steps using the "fork" keyword.  the     *
* main program is free to do other tasks while the method call is        *
* executing in the multi-threaded object's phantom:                      *
*                                                                        *
* * start a multi-threaded object's method call                          *
*    fork(request.handle) =                                              *
*                       my.multi.object::method (parameter1, parameter2) *
*                                                                        *
*              . . . code doing other things . . .                       *
*                                                                        *
* * get the response from the multi-threaded object's method call        *
*    value1, value2 = fork(request.handle)::response                     *
*                                                                        *
*        or just:                                                        *
*                                                                        *
*    value1, value2 = my.multi.object::fork(request.handle)              *
*                                                                        *
* "request.handle" is a variable name unique to this "forked" request.   *
* it's set in the request (the first line above) and is used in later    *
* forked functions to identify the request.  the request.handle must be  *
* in both the request (the first line) and the response-fetching (the    *
* last one)                                                              *
*                                                                        *
* the first line sends the request to the multi-threaded object's        *
* phantom but does not wait for the result.  the multi-threaded object   *
* phantom will execute the request.  meanwhile, the main program is free *
* to do other things                                                     *
*                                                                        *
* in the second "fork" line above the program is getting the results of  *
* the forked method call.  it waits until the result is available,       *
* fetches the returned parameters.  in the above example this updates    *
* variables value1 and value2                                            *
*                                                                        *
* requests may be nested.  requests to the same multi-threaded object    *
* are processed in the order they're requested.  if multiple requests    *
* are made before older requests are processed the new requests will be  *
* buffered and executed in the order they're requested.  responses do    *
* not have to be fetched in the same order that the requests were sent   *
*                                                                        *
*                                                                        *
* CHECKING A FORKED CALL IN PROCESS:                                     *
*                                                                        *
* after a forked call has been made the calling program can check to see *
* if the call has been completed with the "finished" method.  "finished" *
* returns true if the call has been completed:                           *
*                                                                        *
*     fork.complete = my.multi.object::fork(request.handle)::ready       *
*                                                                        *
*                                                                        *
* CHECKING A MULTI-THREADED OBJECT TO SEE IF IT'S BUSY:                  *
*                                                                        *
* a multi-threaded object may be working on a forked call or it may have *
* one or more blind calls in its queue to process.  to find out if the   *
* multi-threaded object is working on either of these:                   *
*                                                                        *
*     thread.busy = my.multi.object::fork::busy                          *
*                                                                        *
*                                                                        *
* BLIND FORKED REQUESTS:                                                 *
*                                                                        *
* a forked call may be made as a "blind" call.  a blind call executes    *
* a multi-threaded object method but ignores the response.  this can be  *
* faster when the returned variables aren't needed but has the           *
* disadvantage of losing any errors that may return from the call        *
* via the error.message variable:                                        *
*                                                                        *
*    fork(blind) = my.multi.object::method (parameter1, parameter2)      *
*                                                                        *
*                                or:                                     *
*                                                                        *
*    blind = my.multi.object::method (parameter1, parameter2)            *
*                                                                        *
*          . . . code continues without waiting for result . . .         *
*                                                                        *
*                                                                        *
* OTHER MULTI-THREADED FUNCTIONS:                                        *
*                                                                        *
* get the multi-threaded object phantom's pid:                           *
*                                                                        *
*     phantom.pid = my.multi.object::fork::pid                           *
*                                                                        *
* flush any current and/or buffered call requests:                       *
*                                                                        *
*     my.multi.object::fork::flush                                       *
*                                                                        *
**************************************************************************
* Unary expressions:                                                     *
*                                                                        *
* basic functions may also be used as unary expressions.  for example,   *
* this:                                                                  *
*                                                                        *
*     TRIM(variable)                                                     *
*                                                                        *
* will expand to this:                                                   *
*                                                                        *
*     variable = trim(variable)                                          *
*                                                                        *
* if there are additional parameters in the basic function they will     *
* be copied to the expanded function call.  this:                        *
*                                                                        *
*      TRIM(variable, " ", "B")                                          *
*                                                                        *
* will expand to this:                                                   *
*                                                                        *
*      variable = TRIM(variable, " ", "B")                               *
*                                                                        *
* this:                                                                  *
*                                                                        *
*      FIELD(variable, " ", 1)                                           *
*                                                                        *
* will expand to this:                                                   *
*                                                                        *
*      variable = FIELD(variable, " ", 1)                                *
*                                                                        *
*                                                                        *
* unary functions may be nested.  this:                                  *
*                                                                        *
*      TRIM(FIELD(variable, " ", 1))                                     *
*                                                                        *
* will expand to this:                                                   *
*                                                                        *
*      variable = TRIM(FIELD(variable, " ", 1))                          *
*                                                                        *
* a list of unary functions may be found in UD.CONTROL UNARY.KEYWORDS    *
*                                                                        *
*                                                                        *
* unary text extracts and field extracts are also supported.  for        *
* example, this:                                                         *
*                                                                        *
*     variable [1, 2]                                                    *
*                                                                        *
* converts to this:                                                      *
*                                                                        *
*     variable = variable [1, 2]                                         *
*                                                                        *
* and this:                                                              *
*                                                                        *
*     variable [".", 1, 1]                                               *
*                                                                        *
* converts to this:                                                      *
*                                                                        *
*     variable = variable [".", 1, 1]                                    *
*                                                                        *
*                                                                        *
* a text extract or field extract may be nested inside unary functions   *
* and text extracts may follow unary functions.  for example, this:      *                                               *
*                                                                        *
*     TRIM(variable [2, 10])                                             *
*                                                                        *
* converts to:                                                           *
*                                                                        *
*     variable = TRIM(variable [2, 10])                                  *
*                                                                        *
* and this:                                                              *
*                                                                        *
*     TRIM(variable) [2, 10]                                             *
*                                                                        *
* converts to this:                                                      *
*                                                                        *
*     variable = TRIM(variable) [2, 10]                                  *
*                                                                        *
**************************************************************************
* Embedded assignments:                                                  *
*                                                                        *
* embedded assignments may be used with the "~=" operator.  for example: *
*                                                                        *
*     var1 = var2 ~= 1                                                   *
*                                                                        *
* will set var2 to 1 and then set var1 to var2.                          *
*                                                                        *
*     var1 = var2 ~= var3 + 3 + var4                                     *
*                                                                        *
* will set var2 to var3 + 3 + var4 and set var1 to var2                  *
*                                                                        *
*     var1 = (var2 ~= var3) + 3 + var4                                   *
*                                                                        *
* will set var2 to var3 and then set var1 to var2 + 3 + var4             *
*                                                                        *
*     IF var1 ~= var2 = var3 {                                           *
*         do.something                                                   *
*     }                                                                  *
*                                                                        *
* will set var1 to var2 and compare var1 to var3 for the "IF" statement  *
*                                                                        *
**************************************************************************
* ASSOCIATEd variables:                                                  *
*                                                                        *
* an ASSOCIATEd variable links an associated variable name to a list of  *
* variable names.  When the ASSOCIATEd variable name is used in a line   *
* of code that line is unrolled into multiple program lines.  each       *
* unrolled program line will use one of the variables declared to be     *
* ASSOCIATEd with the associated variable.  this can be handy when there *
* is a group of variables that will always be used together.             *
*                                                                        *
* declare an associated variable like this:                              *
*                                                                        *
*    ASSOCIATE table.name = var1, {var2, {var3, { . . . } } }            *
*                                                                        *
* in any code line where "table.name" is used it will be unrolled into   *
* multiple program lines, one for each "var".  ie:                       *
*                                                                        *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*                                                                        *
*    MYTABLE = ""                                                        *
*                                                                        *
* compiles to:                                                           *
*                                                                        *
*    VAR1 = "" ; VAR2 = "" ; VAR3 = ""                                   *
*                                                                        *
* or:                                                                    *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*                                                                        *
*    DEL MYTABLE<1,1>                                                    *
*                                                                        *
* compiles to:                                                           *
*                                                                        *
*    DEL VAR1<1,1> ; DEL VAR2<1,1> ; DEL VAR3<1,1>                       *
*                                                                        *
* this:                                                                  *
*                                                                        *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*    ASSOCIATE HISTABLE = VAR(1), VAR(2), VAR(3)                         *
*                                                                        *
*    MYTABLE = HISTABLE                                                  *
*                                                                        *
* compiles to:                                                           *
*                                                                        *
*    VAR1 = VAR(1) ; VAR2 = VAR(2) ; VAR3 = VAR(3)                       *
*                                                                        *
* or:                                                                    *
*                                                                        *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*    ASSOCIATE HISTABLE = VAR(1), VAR(2), VAR(3)                         *
*                                                                        *
*    MYTABLE = RAISE(HISTABLE)                                           *
*    HISTABLE = LOWER(MYTABLE)                                           *
*                                                                        *
* compiles to:                                                           *
*                                                                        *
*    VAR1 = RAISE(VAR(1)) ; VAR2 = RAISE(VAR(2)) ; VAR3 = RAISE(VAR(3))  *
*    VAR(1) = LOWER(VAR1) ; VAR(2) = LOWER(VAR2) ; VAR(3) = LOWER(VAR3)  *
*                                                                        *
* an output conversion may be added for any field in the association     *
* list after a bar ("|") character, ie:                                  *
*                                                                        *
*    ASSOCIATE MYTABLE = NUM.VAR | "MD2", DATE.VAR | "D2/", VAR3         *
*                                                                        *
* if MYTABLE is used left of the equals sign (assigning "to") all        *
* variables will be ICONVS'ed before being copied into MYTABLE's         *
* variables.  if MYTABLE is on the right all of MYTABLE's variables      *
* will be OCONVS'ed before the copy                                      *
*                                                                        *
* this can be handy for unloading a record's contents into variables:    *
*                                                                        *
*    ASSOCIATE RECORD.FIELDS = REC<1> | "MD2", REC<2> "D2/", REC<3>      *
*    ASSOCIATE PROPERTY.FIELDS = COST, DATE, DESCRIPTION                 *
*                                                                        *
* this:                                                                  *
*                                                                        *
*    PROPERTY.FIELDS = RECORD.FIELDS                                     *
*                                                                        *
* unrolls to this:                                                       *
*                                                                        *
*    COST = OCONVS(REC<1>, "MD2")                                        *
*    DATE = OCONVS(REC<2>, "D2/")                                        *
*    DESCRIPTION = REC<3>                                                *
*                                                                        *
* and this:                                                              *
*                                                                        *
*    RECORD.FIELDS = PROPERTY.FIELDS                                     *
*                                                                        *
* unrolls to this:                                                       *
*                                                                        *
*    REC<1> = ICONVS(COST, "MD2")                                        *
*    REC<2> = ICONVS(DATE, "D2/")                                        *
*    REC<3> = DESCRIPTION                                                *
*                                                                        *
*                                                                        *
* if there is more than one associated variable reference in a line then *
* both associations must have the same number of variables or an error   *
* will be produced.  if these assocations were defined:                  *
*                                                                        *
*    ASSOCIATE RECORD.FIELDS = REC<1> | "MD2", REC<2> "D2/", REC<3>      *
*    ASSOCIATE PROPERTY.FIELDS = COST, DATE, DESCRIPTION, EXTRA.VALUE    *
*                                                                        *
* then this expression would generate an error since RECORD.FIELDS       *
* has three variables and PROPERTY.FIELDS has four:                      *
*                                                                        *
*    RECORD.FIELDS = PROPERTY.FIELDS                                     *
*                                                                        *
*                                                                        *
* associations may also be defined on the fly for one-offs.  for one-off *
* association definitions like this don't leave a space between the      *
* braces and variables.  this is to define association braces as         *
* separate from structure braces:                                        *
*                                                                        *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*                                                                        *
*    MYTABLE = {1, 2, 3}                                                 *
*    {NEW.VAR1, NEW.VAR2, NEW.VAR3} = MYTABLE                            *
*    {VAR1, VAR2, VAR3} = {1, 2, 3}                                      *
*                                                                        *
* associations with numeric values may be defined over ranges or as a    *
* list of values:                                                        *
*                                                                        *
*    MY.ARRAY<{1...5}> = 0                                               *
*    MY.ARRAY<{1...3}> = {VALUE1, VALUE2, VALUE3}                        *
*    MY.ARRAY<{1,2,3}> = {VALUE1, VALUE2, VALUE3}                        *
*    MY.ARRAY<{1...3,10}> = {VALUE1, VALUE2, VALUE3, VALUE4}             *
*                                                                        *
*    {VALUE1, VALUE2, VALUE3} = MY.ARRAY<{1...3}>                        *
*    {VALUE1, VALUE2, VALUE3} = MY.ARRAY<{1,2,3}>                        *
*    {VALUE1, VALUE2, VALUE3, VALUE4} = MY.ARRAY<{1...3,10}>             *
*                                                                        *
*    DEL MY.ARRAY<1, {1...3}>                                            *
*    DEL MY.ARRAY<1, {1,2,3}>                                            *
*    DEL MY.ARRAY<1, {1...3,10}>                                         *
*                                                                        *
*    INS "" BEFORE MY.ARRAY<{1...3}, 1>                                  *
*    INS "" BEFORE MY.ARRAY<{1,2,3}, 1>                                  *
*    INS "" BEFORE MY.ARRAY<{1...3,10}, 1>                               *
*    INS {VAR1, VAR2, VAR3} BEFORE MY.ARRAY<1...3, 1>                    *
*                                                                        *
* associations can be used for object handles, with both defined         *
* associations and on-the-fly associations:                              *
*                                                                        *
*    {OBJECT1, OBJECT2, OBJECT.3}::method.name                           *
*                                                                        *
*    ASSOCIATE OBJECT.LIST = OBJECT1, OBJECT2, OBJECT3                   *
*    OBJECT.LIST::method.name                                            *
*                                                                        *
*    {OBJECT1, OBJECT2, OBJECT3} = NEW (object.name)                     *
*                                                                        *
*    ASSOCIATE OBJECT.LIST = OBJECT1, OBJECT2, OBJECT3                   *
*    OBJECT.LIST = NEW (object.name)                                     *
*                                                                        *
*    ASSOCIATE OBJECT.LIST = OBJECT1, OBJECT2, OBJECT3                   *
*    {VALUE1, VALUE2, VALUE3} = OBJECT.LIST::property                    *
*                                                                        *
*    ASSOCIATE OBJECT.LIST = OBJECT1, OBJECT2, OBJECT3                   *
*    ASSOCIATE VALUE.LIST = VALUE1, VALUE2, VALUE3                       *
*    VALUE.LIST = OBJECT.LIST::property                                  *
*                                                                        *
*    OBJECT::{PROPERTY1, PROPERTY2, PROPERTY3} = {VALUE1, VALUE2,        *
*        VALUE3}                                                         *
*                                                                        *
*    ASSOCIATE VALUE.LIST = VALUE1, VALUE2, VALUE3                       *
*    OBJECT::{PROPERTY1, PROPERTY2, PROPERTY3} = VALUE.LIST              *
*                                                                        *
*    ASSOCIATE VALUE.LIST = VALUE1, VALUE2, VALUE3                       *
*    ASSOCIATE PROPERTY.LIST = PROPERTY1, PROPERTY2, PROPERTY3           *
*    OBJECT::PROPERTY.LIST = VALUE.LIST                                  *
*                                                                        *
*                                                                        *
* associations are smart enough to merge dynamic array references.       *
* for example, given this assocation:                                    *
*                                                                        *
*    ASSOCIATE MYTABLE = REC<1>, REC<2>, REC<3>                          *
*                                                                        *
* this:                                                                  *
*                                                                        *
*    DEL MYTABLE<1, X>                                                   *
*                                                                        *
* unrolls to this:                                                       *
*                                                                        *
*    DEL MYTABLE<1, X>                                                   *
*    DEL MYTABLE<2, X>                                                   *
*    DEL MYTABLE<3, X>                                                   *
*                                                                        *
**************************************************************************
* Using ASSOCIATEd Variables in method / subroutine calls:               *
*                                                                        *
* associated variables can be used in method and subroutine calls and    *
* be exploded so that each associated variable becomes a method /        *
* subroutine parameter.  to do this enclose the associated table name    *
* in braces and add it to the parameter list.                            *
*                                                                        *
* For example, we have this associated variable:                         *
*                                                                        *
*    ASSOCIATE MYTABLE = VAR1, VAR2, VAR3                                *
*                                                                        *
* we want to call a method or subroutine and pass the variables in       *
* MYTABLE--VAR1, VAR2 and VAR3.  we enclose MYTABLE in braces and use    *
* it as a parameter in a method call:                                    *
*                                                                        *
*     MYOBJECT::MYMETHOD ({MYTABLE})                                     *
*                                                                        *
* the {MYTABLE} reference will be exploded into four method parameters.  *
* the first exploded parameter will be a count of the variables in the   *
* MYTABLE associated variable.  following this count will be the         *
* associated variables.  the call would then look like this:             *
*                                                                        *
*    MYOBJECT::MYMETHOD (3, VAR1, VAR2, VAR3)                            *
*                                                                        *
* calls like this are usually do methods that expect a variable number   *
* of parameters.  to accept a variable number of parameters the method   *
* needs to have a large number of parameters so that it can accept any   *
* number of parameters up to a limit.  MYMETHOD, for example, may accept *
* up to 10 parameters:                                                   *
*                                                                        *
*     METHOD MYMETHOD (VARIABLE.COUNT, VAR1, VAR2, VAR3, VAR4, VAR5,     *
*         VAR6, VAR7, VAR8, VAR9, VAR10)                                 *
*                                                                        *
* the method should only process parameters that are passed.  in the     *
* preceeding example MYMETHOD can receive 10 parameters but we're only   *
* sending 3.  The "count" parameters allows MYMETHOD to know how many    *
* parameters to process                                                  *
*                                                                        *
**************************************************************************
* ECLIPSE-STYLE SUBROUTINE CALLS:                                        *
*                                                                        *
* Eclipse-style calls are normally passed through to the Eclipse         *
* precompiler without modification or processing by the object           *
* precompiler.  However, they can also be called using the "SUB" object  *
* so that they are processed by the object precompiler:                  * 
*                                                                        *
*     SUB::ECLIPSE.ROUTINE (PARAMETER1, PARAMETER2)                      *
*                                                                        *
* If the "SUB" object is used the parameters in the call will be checked *
* like parameters in method calls.  Warnings will be displayed for       *
* parameters that may generate aliasing problems--ie, a common value     *
* being passed or the same variable passed twice in the same call.       *
* Eclipse subroutines called this way don't need to be the only          *
* statement in the line, etc                                             *
*                                                                        *
**************************************************************************
*                                                                        *
* OTHER PRECOMPILER FEATURES:                                            *
*                                                                        *
**************************************************************************
* WRAPPED LINES:                                                         *
*                                                                        *
* wrapped lines are supported for long subroutine calls.  if a line      *
* ends with one of these characters or words it will be merged with the  *
* line after it:                                                         *
*                                                                        *
*       ,     =     +     -     *     /     _     &     &+    |     [    *
*       and   or    andalso                                              *
*                                                                        *
* this allows long subroutine calls or lines with long functions to      *
* be broken up into multiple lines for readability but merged into a     *
* single line before compiling.  if the underscore is used it will be    *
* removed before merging the line.                                       *
*                                                                        *
* examples:                                                              *
*                                                                        *
*     variable1, variable2, variable3, variable4 =                       *
*         objectname::methodname (input1, input2, input3)                *
*     my.value = very.long.variable.name * another.long.name +           *
*         yet.another.very.long.name +                                   *
*         still.another.very.long.name                                   *
*     if this.really.long.thing = another.really.long.thing and          *
*         this.other.thing.is.true {                                     *
*     locate this.really.long.variable.name in another.long.name _       *
*         setting really.long.ptr {                                      *
*                                                                        *
* method definition lines may also be wrapped:                           *
*                                                                        *
*     METHOD mymethod (variable1, variable2, variable3, variable4,       *
*         variable5, variable6)                                          *
*     METHOD mymethod (variable1, variable2, variable3, variable4;       *
*         variable5, variable6)                                          *
*                                                                        *
* if a line begins with one of these characters or words it will be      *
* merged with the line before it:                                        *
*                                                                        *
*        :     =     +     -     /     _     &     &+    |     ]         *
*        and   or    andalso                                             *
*                                                                        *
*                                                                        *
* examples:                                                              *
*                                                                        *
*    this.variable = "    "                                              *
*        :another.variable                                               *
*        :still.another.long.variable                                    *
*        :", "                                                           *
*        :final.variable.in.this.gigantic.line                           *  
*    if this.really.long.thing = another.really.long.thing               *
*        and this.other.thing.is.true                                    *
*        and yet.another.long.thing = 1 {                                *  
*                                                                        * 
* see LineWrapping, LineWrapCharacters, LineWrapRemoveCharacters,        *
* etc in the ud.compile compile.setup                                    *
*                                                                        *
**************************************************************************
* INITIALIZING DYNAMIC ARRAYS:                                           *
*                                                                        *
* Dynamic arrays may be initialized to a list of attribute values like   *
* this:                                                                  *
*                                                                        *
*     variable = [attr1, attr2, attr3 . . . ]                            *
*     variable<n> = [val1, val2, val3 . . . ]                            *
*     variable<n,m> = [subval1, subval2, subval3 . . . ]                 *
*                                                                        *
* ie:                                                                    *
*     MYARRAY = ["VALUE1", "VALUE2", "VALUE3", "VALUE4"]                 *
*     MYARRAY<10> = ["MULTVAL1", "MULVAL2"]                              *
*     MYARRAY<10,2> = ["SUBVAL1", "SUBVAL2", "SUBVAL3"]                  *
*                                                                        *
* Additional fields may be added to the end of existing dynamic arrays   *
* like this:                                                             *
*                                                                        *
*     variable := [attr1, attr2, attr3 . . . ]                           *
*     variable<n> := [val1, val2, val3 . . . ]                           *
*     variable<n,m> := [subval1, subval2, subval3 . . . ]                *
*                                                                        *
* ie:                                                                    *
*                                                                        *
*     MYARRAY := ["VALUE1", "VALUE2", "VALUE3", "VALUE4"]                *
*     MYARRAY<10> := ["MULTVAL1", "MULVAL2"]                             *
*     MYARRAY<10,2> := ["SUBVAL1", "SUBVAL2", "SUBVAL3"]                 *
*                                                                        *
**************************************************************************
* SHORT GOSUBS:                                                          *
*                                                                        *
* if short gosubs is turned on (EnableShortGosubs in the compiler setup) *
* then gosubs may be done with only the subroutine name, with the        *
* "GOSUB" keyword.  the short gosub must be the only statement on the    *
* program line.  ie, instead of this:                                    *
*                                                                        *
*    GOSUB mysubroutine                                                  *
*                                                                        *
* this can be used for the same result:                                  *
*                                                                        *
*    mysubroutine                                                        *
*                                                                        *
* note: if the subroutine name conflicts with an external subroutine     *
* name the internal gosub will take precedence.                          *
*                                                                        *
* CONDITIONAL SHORT GOSUBS:                                              *
*                                                                        *
* short gosubs may be defined conditionally by adding ".IF" after the    *
* subroutine name.  ie, instead of this:                                 *
*                                                                        *
*    IF conditional THEN                                                 *
*        GOSUB mysubroutine                                              *
*    END                                                                 *
*                                                                        *
* this can be used for the same result:                                  *
*                                                                        *
*    mysubroutine.if expression                                          *
*                                                                        *
* for example:                                                           *
*                                                                        *
*    MY.SUBROUTINE.NAME.IF ENTRY.COUNT > 10                              *
*                                                                        *
* add ".IFNOT" after the subroutine name to call the subroutine name if  *
* the conditional statement is NOT true:                                 *
*                                                                        *
*    mysubroutine.ifnot expression                                       *
*                                                                        *
* additional conditionals:                                               *
*                                                                        *
*    mysubroutine.ifzero expression                                      *
*    mysubroutine.ifnotzero expression                                   *
*    mysubroutine.ifnull expression                                      *
*    mysubroutine.ifnotnull expression                                   *
*    mysubroutine.ifnum expression                                       *
*    mysubroutine.ifnotnum expression                                    *
*    mysubroutine.ifalpha expression                                     *
*    mysubroutine.ifnotalpha expression                                  *
*                                                                        *
**************************************************************************
* MACROS AND SHORTCUTS:                                                  *
*                                                                        *
* a library of macros and shortcuts is defined in ud.control             *
* compile.setup.  these macros and shortcuts can make code more clear    *
* as well as replacing often used code sequences                         *
*                                                                        *
*                                                                        *
* SHORTCUTS:                                                             *
*                                                                        *
* shortcuts perform direct replacements on code.  the "++" shortcut,     *
* for example, is replaced with " += 1".  this line:                     *
*                                                                        *
*     myvariable++                                                       *
*                                                                        *
* is converted to:                                                       *
*                                                                        *
*     myvariable += 1                                                    *
*                                                                        *
* some shortcuts can be "embedded" within other functions.  "++, "--",   *
* "~~" and "~" may be embedded.  For example:                            *
*                                                                        *
*     array.list<++array.count> = value                                  *
*                                                                        *
* will increment array.count and save "value" at the result.             *
*                                                                        *
*     array.list<array.count++> = value                                  *
*                                                                        *
* will save value at array.count and then increment array.count.         *
*                                                                        *
* other examples are:                                                    *
*                                                                        *
*     if ++this.count > max.count {                                      *
*         do something                                                   *
*     }                                                                  *
*                                                                        *
*     this.ptr = ++max.ptr                                               *
*                                                                        *
*     this.boolean = ~that.boolean                                       *
*                                                                        *
*     save.boolean = that.boolean~~                                      *
*                                                                        *
* this can be useful when looping until a variable is set true or false. *
* the initial state of the variable may be defined in the loop statement *
* like this:                                                             *
*                                                                        *
*     loop until ~finished.looping {                                     *
*         do something                                                   *
*         if something {                                                 *
*             finished.looping~~                                         *
*         }                                                              *
*     }                                                                  *
*                                                                        *
* "~finished.looping" will set finished.looping false before the loop    *
* statement is executed.  the loop will end when finished.looping is     *
* true.  finished.looping will be set true somewhere in the loop         *
* structure.                                                             *
*                                                                        *
*                                                                        *
* MACROS:                                                                *
*                                                                        *
* MACROS perform parameter-by-parameter conversions.  Many macros are    *
* defined multiple times.  Each definition is for a number of            *
* parameters.  "EACH.AM", for example, has three definitions.  one is    *
* for when the macro is used with 2 parameters, another for when it's    *
* used with 3 parameters and another when it's used with 4.  depending   *
* on how many parameters are defined with the macro is used the          *
* appropriate definition is selected and used to convert the code.       *
*                                                                        *
* for example:                                                           *
*                                                                        *
*     myloopvariable = EACH.AM (my.array) {                              *
*                                                                        *
* has two parameters, one before the equals sign and one after.  this    *
* macro starts a FOR / NEXT loop.  "myloopvariable" is the index of the  *
* loop and "DCOUNT(my.array, @am)" will be the end of the loop.  the     *
* code will be converted to:                                             *
*                                                                        *
*     myloopvariable.am.count = dcount(my.array,@AM) ;                   *
*     for myloopvariable = 1 to myloopvariable.am.count                  * 
*                                                                        *
* this expression of EACH.AM has three parameters:                       *
*                                                                        *
*     this.value = EACH.AM (my.array, myloopvariable) {                  *
*                                                                        *
* it starts a FOR / NEXT loop that goes from 1 to DCOUNT(my.array,@AM).  *
* myloopvariable is the index for the loop.  this.value is automatically *
* extracted from my.array<myloopvariable> with each loop iteration.      *
* this macro is converted to:                                            *
*                                                                        *
*     myloopvariable.am.count = dcount(my.array,@AM) ;                   *
*     for myloopvariable = 1 to myloopvariable.am.count ;                *
*     this.value = my.array<myloopvariable>                              * 
*                                                                        *
*                                                                        *
* macros may also be defined on the fly for use in a single program or   *
* object:                                                                *
*                                                                        *
*     macro addupdelims %0 = dcount(%1, @am) + dcount(%2, @am)           *
*                                                                        *
* could then be used as:                                                 *
*                                                                        *
*     total.delims = addupdelims (variable1, variable2)                  *
*                                                                        *
* the "SHORTCUTS" tcl command will list out macros and shortcuts in a    *
* view-only editor window.  if notepad++ is installed SHORTCUTS will     *
* also update the shortcut and macro setups on the client pc             *
*                                                                        *
*                                                                        *
* shortcuts and macros can be mixed together.  the "set.if" macro, for   *
* example, sets a variable to true based on a condition being true and   *
* leaves the value alone otherwise.  this is handy for doing multiple    *
* tests where the variable is set true if any test is successful:        *
*                                                                        *
*     ~boolean.var = SET.IF (x > y)                                      *
*     boolean.var = SET.IF (z = 10)                                      *
*                                                                        *
**************************************************************************
* The SECTION keyword                                                    *
*                                                                        *
* For object with many methods or an object-enabled subroutine with      *
* many subroutines it can be helpful to group them together by function. *
* The SECTION keyword provides a name for each of these groups:          *
*                                                                        *
*     SECTION section description:                                       *
*                                                                        *
* These lines will not be compiled.  If there is text on the line that   *
* shouldn't be included in the section description put it after the      *
* colon                                                                  *
*                                                                        *
* Notepad++ will look for the SECTION keyword and build a listing of     *
* sections in the method / subroutine window.  The Object Viewer will    *
* also use these sections to group the objects methods.                  *
*                                                                        *
* in CBP programs a comment beginning with two asterisks ("**") will     *
* indicate a section for Notepad++                                       *
**************************************************************************
* DEBUGGING SHORTCUTS:                                                   *
*                                                                        *
* debugging shortcuts are very short commands, only one or two           *
* characters, that send data to the debugging window.  this debugging    *
* information is visible using UD.VIEW.DEBUG.                            *
*                                                                        *
* these debugging functions have the following parameters used to send   *
* data to the debugging window.  all parameters are optional:            *
*                                                                        *
*     debug.stmt message, {source, {array, {start.attr, {end.attr}}}}    *
*                                                                        *
*     where:                                                             *
*                                                                        *
*         message         message to display in the debugging window     *
*         source          optional "source" code to display in the       *
*                         debugging window.  debugging views may be      *
*                         filtered by source                             *
*         array           optional dynamic array to display for          *
*                         debugging.  arrays displayed here will be      *
*                         broken out into attributes, values and         *
*                         subvalues in the debug monitor                 *
*         start.attr      optional first attribute in array to display.  *
*                         defaults to 1                                  *
*         end.attr        optional last attribute in array to display.   *
*                         defaults to the last attribute in array        *
*                                                                        *
* debugging commands are:                                                *
*                                                                        *
*     ##                  clear the debugging viewer window              *
*                                                                        *
*     ###                 for objects display the object name / method   *
*                         name and object pointer in the debugging       *
*                         window.  for object-enabled programs display   *
*                         the program name                               *
*                                                                        *
*     << message          send a message to the debug viewer.  syntax is *
*                         the same as a print or crt statement.          *
*     << message, source  send a message with a source string defined.   *
*                         the debugging information may be filtered by   *
*                         the source in UD.VIEW.DEBUG                    *
*                                                                        *
*     <<# message         clear debugging window and send a message to   *
*                         the debug window.  syntax is the same as a     *
*                         print or crt statement                         *
*     <<# message, source clear debugging window and send a message to   *
*                         the debug window with a source.  syntax is the *
*                         same as a print or crt statement               *
*                                                                        *
*     <<< var             displays a variable in the debugging window    *
*                         as "variable.name: variable.value"             *
*     <<< var1, var2+     displays each variable in the debugging window *
*                         as "variable.name: variable.value"             *
*                                                                        *
*     <<<< var           displays a multivalued variable in a view-only  *
*                        editor window via the debugging viewer.  handy  *
*                        to display a very long array or script or       *
*                        whatever when in a subroutine that is buried    *
*                        multiple layers deep.  the debugging viewer     *
*                        will spawn a view-only editor window to         *
*                        display the array                               *
*                                                                        *
*     +++ source         set the "source" value for all subsequent       *
*                        debugging statements.  easier than passing the  *
*                        source value over and over                      *
*                                                                        *
*     ---                clear the "source" value for all subsequent     *
*                        debugging statements                            *
*                                                                        *
**************************************************************************
* VIEWING PROPERTY VALUES DURING RUNTIME:                                *
*                                                                        *
* the object i/o routines have their own versions of the Eclipse input   *
* subroutines.  if the user is set up as a programmer in the INITIALS    *
* file <f11> will have a different function.  hitting <f11> will bring   *
* up a list of all active object instances.  Select the object name      *
* and instance and the current property values will be displayed in a    *
* view-only editor window                                                *
*                                                                        *
* active objects may also be listed from tcl with the "LIST.ACTIVE"      *
* command                                                                *
*                                                                        *
**************************************************************************
* OVERRIDING DEFAULT PRECOMPILER SETTINGS:                               *
*                                                                        *
* default precompiler options are defined in the setup record UD.CONTROL *
* COMPILE.SETUP.                                                         *
*                                                                        *
* BE VERY CAREFUL ABOUT CHANGING ANYTHING IN THIS SETUP RECORD!  If you  *
* don't know what you're doing do NOT change any of the settings here.   *
* if you decide to try be sure you back up the UD.CONTROL COMPILE.SETUP  *
* record so that you can restore it if you get unexpected results!       *
*                                                                        *
* in unusual circumstances it may be necessary to override one or more   *
* of the COMPILE.SETUP options for a single program, an object or a      *
* method within an object.  individual compiler settings may be          *
* overridden with the $OBJ.OPTION directive:                             *
*                                                                        *
*    $OBJ.OPTION settingname1 = value1, settingname2 = value2 . . .      *
*                                                                        *
* where:                                                                 *
*                                                                        *
*    settingname      setting name from the compile setup to override    *
*    value            new value for the setting                          *
*                                                                        *
* value may be:                                                          *
*                                                                        *
*    Yes              sets to 1                                          *
*    No               sets to 0                                          *
*                                                                        *
*    On               sets to 1                                          *
*    Off              sets to 0                                          *
*                                                                        *
*    True             sets to 1                                          *
*    True             sets to 1                                          *
*    False            sets to 0                                          *
*                                                                        *
*    numeric value    sets to numeric value                              *
*    string value     sets to a string value                             *
*                                                                        *
* options are evaluated at compile time so settings may not be           *
* variables.  value names and values are case-insensitive.               *
*                                                                        *
* for object-enabled subroutines (the obp file) the $OBJ.OPTION          *
* will change the compiler setup value for the entire subroutine.        *
*                                                                        *
* for objects, if the $OBJ.OPTION directive is in a method the compiler  *
* setup value will be changed only for that method.  if the &OBJ.OPTION  *
* directive it outside of the method code (ie, with the properties)      *
* the option applies globally to all methods in the object.  if the same *
* option is declared globally and inside a method the setting inside the *
* method will override the global option                                 *
*                                                                        *
* for example:                                                           *
*                                                                        *
*    $OBJ.OPTION EnableAssociatedTables = Off                            *
*                                                                        *
* would disable associated tables for only the current object or         *
* subroutine                                                             *
*                                                                        *
* most of the settings in ud.control compile.setup are supported.        *
* see the PROCESS.THIS.OPTION local subroutine in UD.COMPILE for         *
* supported settings.                                                    *
*                                                                        *
**************************************************************************
* ENHANCED POST-ECLIPSE SYNTAX:                                          *
*                                                                        *
* the FixUnresolvedReferences setting:                                   *
*                                                                        *
* if FixUnresolvedReferences is turned off in the control record the     *
* usual Eclipse subroutine call syntax limitations apply--one converted  *
* statement per program line, only one subroutine per statement, etc.    *
* each converted program line will be in the same line number as the     *
* original source line.                                                  *
*                                                                        *
* if FixUnresolved References is turned on more complex syntax can be    *
* used that what Eclipse allows in its precompiler. for example, there   *
* can be multiple object references in the same line like these:         *
*                                                                        *
* object1::method1 object2::property1, object2::property2                *
* variable = object1::property1 + object2:property2                      *
* object1::property1 = object2:method (object1::constant1)               *
*                                                                        *
* in these situations, however, one source code line may break out       *
* into multiple program lines in the CBP version.  if there is a         *
* compile error ud.compile will show both the source code line number    *
* and the CBP line number to make debugging easier                       *
*                                                                        *
* FixUnresolvedReferences is normally on to allow this more flexible     *
* syntax                                                                 *
*                                                                        *
**************************************************************************
* "COMPILING" OC PROGRAMS                                                *
*                                                                        *
* Compiling an OC program will test subroutine calls in the program for  *
* aliasing problems.  The OC program won't be changed and nothing        *
* will be written so it's more "processing" than "compiling."  this can  *
* be helpful for finding aliasing problems in programs that are not      *
* from obp or obj                                                        *
*                                                                        *
**************************************************************************
* KNOWN ISSUES / FUTURE ENHANCEMENTS:                                    *
*                                                                        *
* 1. When showing the error table after compiling it would be more       *
*    effective to merge the warning table with the error table to show   *
*    both errors and warnings in line number order                       *
*                                                                        *       
* 2. Setting "ObsubPickFlavor", pick flavor for object-enabled           *
*    subroutines automatically.  this is already done in objects.  it    *
*    would be nice to automatically do it in object-enabled subroutines. *
*    this runs into the same thing with CBP vs OBP line numbers as in    *
*    the optional parameters . . . maybe trying to keep CBP and OBP line *
*    numbers the same is a lost cause.                                   *
*                                                                        *
* 3. Dimensioned objects with child objects:  dimensioned objects        *
*    cannot currently have child objects, though they can have           *
*    local.child objects.  the problem comes with passing the child      *
*    object handles back to the calling program.  dimensioned objects    *
*    can create a whole slew of child objects and it gets messy to pass  *
*    the all back to the calling program, especially if the child        *
*    are dimensioned.                                                    *
*                                                                        *
*    Need to implement some way for all the child objects to be          *
*    dimensioned along with the parent object.  especially fun if the    *
*    child object itself is also dimensioned.  this might require a      *
*    rethinking of how child object handles are passed back from a "new" *
*    call.  currently each child object is passed back as a separate     *
*    subroutine parameters.  maybe have a (large?) dimensioned array so  *
*    that one dimensioned parameter can return all child object handles? *
*                                                                        *
*    not sure if it's worth it.  local.child objects could be used and   *
*    methods in the dimensioned object could address them.  it would be  *
*    handy to be able to dimension anything anywhere but the complexity  *
*    may not be worth it                                                 *
*                                                                        *
* 4. a "fork" expression left of the equals sign can't compile if the    *
*    request.id variable is dimensioned                                  *
*                                                                        *
* 5. a "fork" expression right of the equals sign can't compile if the   *
*    request.id variable is dimensioned                                  *
*                                                                        *
* 6. complete additional "fork" functions both at the starting and       *
*    ending "fork" expressions                                           *
*                                                                        *
* 7. "intime" objects don't work for dimensioned objects                 *
*                                                                        *
**************************************************************************
* Useful TCL commands                                                    *
*                                                                        *
* The OBPROC file contains procs for tcl commands.  the "VERBS" TCL      *
* command will list additional TCL commands.                             *
*                                                                        *
* some useful ones are:                                                  *
*                                                                        *
* ABORT.ME             display server / developer information            *
* ALAYOUT              display a file's dictionaries, both real fields   *
*                      and i-descriptors                                 *
* ASCII                display an ascii table                            *
* AUTO.COMPILE         run the auto compiler                             *
*                                                                        *
* CAT filename         view a "catalog" list of items in a file          *
* CLOSE.MY.PROGRAMS    close programs open to the current user           *
* CODE                 perform code-splitting functions                  *
* COMPARE.PROGRAM      compare a program to another file or environment  *
* COMPILE              compile a program or object                       *
* COMPILE.WIN          compile a program with errors in an editor window *
*                                                                        *
* D                    bring up the object development menu              *
* DAISY                view daisy-chained subroutine help                *
*                                                                        *
* E                    edit a program with eclipse's editor              *
* ETERM.CONFIG         configure eterm from presets                      *
* EXPORT.DOT           export the dotnet and java classes for an object  *
*                      without compiling                                 *
* EXPORT.ALL.DOTNET    export all dotnet and java classes for all        *
*                      dotnet / java enabled objects                     *
*                                                                        *
* FILESIZE             view a file's parameters                          *
* FILE.RESIZER         file resizing utility                             *
* FORMAT.CODE          reformat a program                                *
* FREE                 display free disk space                           *
*                                                                        *
* ILAYOUT              display a file's i-descriptors in a window        *
* INSTALL              run the installer                                 *
*                                                                        *
* LAST                 run the installer for the last install package    *
* LATENCY              display current eterm latency                     *
* LAYOUT               display a file layout for actual fields (no       *
*                      i-descriptors) in a window                        *
* LIST.ACTIVE          list active objects                               *
* LIST.SETTINGS        display settings for a setup record               *
*                                                                        *
* MAN                  display unix / linux help for a command           *
* METHOD               display methods for an object on the screen       *
* METHODS              display methods for an object in a window         *
* MINE                 display processes for the current user            *
* MONITOR              display logged information for a monitor          *
* MORE                 execute a tcl command and display with pages      *
*                                                                        *
* OBJECTS              run the object viewer                             *
* OBJECT.ERRORS        display recent object method errors               *
* OBJECT.MAP           display a map of an object with its child objects *
*                                                                        *
* PAINT                paint an eclipse background screen                *
* PH.ERRORS            display or clear phantom errors                   *
* PROCESSES            display all current unix / linux processes        *
* PROGRAMS             view and search programs in all program files     *
* PSEF                 display 'psef' output                             *
*                                                                        *
* R                    run a program that is run from a menu             *
* READ.LOCKS           display read locks by uniVerse file name          *
* RECOMPILE            recompile a program.  compiles with options       *
*                      ALWAYS NOPTS                                      *
* RECOMPILE.ALL.OBJECTS recompile everything in OBJ and OBP              *
* REFRESH              refresh a setting object's values in memory       *
* REFRESH.ALL          refresh all settng objects' values in memory      *
* REMOVE.DEBUG         remove debugging code from a program or object    *
* RESET.SOLAR          reset Solar's subroutine caching                  *
* RESIZE.FILE          resize a file to optimal settings                 *
*                                                                        *
* SAY                  speak with text-to-speech converter               *
* SEARCH.PROGRAMS      program / object search and display utility       *
* SEND.EMAIL           send an email from the tcl line                   *
* SETUP                edit a setup record                               *
* SHORT                short method listing                              *
* SHORTCUTS            display shortcuts in an editor window             *
*                                                                        *
* T                    run the enhanced tcl shell                        *
* TAKE                 take linux ownership of a program                 *
* TOUCH                update the time stamp on a program in linux       *
*                                                                        *
* UNIX                 execute a unix (linux) command and display the    *
*                      captured output in a window                       *
* UPDATE.AUTOCOMPLETE  update notepad++'s autocomplete file              *
* UPDATE.DEFAULT.PP    update the default notepad++ definition setup     *
* UPDATE.PP.DEFINITION update notepad++'s language definition file       *
*                                                                        *
* VERBS                list additional TCL commands                      *
*                                                                        *
* VIEW                 view a file / item in an editor window            *
* VIEW.CODE            view a reformatted program in an editor windown   *
* VIEW.COMO            view a como in an editor window                   *
* VIEW.DEBUG           run the debugging viewer                          *
* VIEW.ITEM            view a file / item in an editor window with dict  *
* VIEW.OBJECT.DEBUG    run the object debugger                           *
* VIEW.OBJECTS         run the object viewer utility                     *
* VIEW.SETTINGS        view settings for a setup record                  *
* VIEW.THREAD          view thread information                           *
*                                                                        *
**************************************************************************
* Author: Don Rider wrote this monstrosity.  Bother him with any         *
* questions or difficulties.  also see him for Notepad++ definitions     *
* that give OBP and OBJ code color highlighting and help setting up      *
* WinSCP to make it easier to edit these programs                        *
*                                                                        *
**************************************************************************

**************************************************************************
*                     I M P O R T A N T   N O T E !                      *
*                                                                        *
* this program is in CBP for a reason.  while it would be handy to be    *
* able to use all the new object functionality we can't.  this program   *
* is needed to compile all that new functionality.  if this program      *
* was in OBP and a change didn't compile then there would be no          *
* executable UD.COMPILE to compile the corrected program.  THEN what     *
* are you going to do?                                                   *
*                                                                        *
* DO NOT CHANGE THIS PROGRAM UNLESS YOU REALLY KNOW WHAT YOU'RE DOING!   *
**************************************************************************

**************************************************************************
* SPECIAL NOTE IF SUDDENLY THE COMPILER CRASHES SAYING IT CAN'T OPEN     *
* A SUBROUTINE BUILT FROM AN OBJECT METHOD:                              *
*                                                                        *
* the compiler normally calls a few objects.  the speech object, for     *
* example.  if an object called by the compiler wasn't already compiled  *
* or if there's a problem with the object the call to that object can    *
* crash.  one option would be to never have the compiler call any        *
* objects but where's the fun in that?                                   *
*                                                                        *
* if the low-level objects are working it's (usually) okay if the        *
* object compiler calls them.  if one of them gets messed up, recompile  *
* it with the "REPAIR" option.  the "REPAIR" option forces the compiler  *
* to skip any object calls and to recompile every method whether it      *
* needs to be compiled or not.                                           *
*                                                                        *
* COMPILE object.to.fix REPAIR                                           *
*                                                                        *
* the "RECOMPILE.ALL.OBJECTS" routine always compiles in "REPAIR" mode   *
*                                                                        *
**************************************************************************

**************************************************************************
* Modifications in progress:                                             *
**************************************************************************
* PASSING CHILD HANDLES AS A DIMENSIONED ARRAY RATHER THAN INDIVIDUAL    *
* VARIABLES                                                              *
*                                                                        *
* when passing child objects back from a "new" method the original       *
* method was to pass back a separate variable for each child object.     *
* this generated very long parameter lists.  if dimensioned child        *
* handles are used each child object is passed back as an element in a   *
* dimensioned array to make things a bit tidier                          *
*                                                                        *
* [x] add settings for:                                                  *
*     [x] UseDimensionedChildHandles                                     *
*     [x] ChildHandleArraySize                                           *
*     [x] ChildHandleArrayName                                           *
* [x] when creating "NEW" subroutine, if using dimensioned child         *
*     handles:                                                           *
*     [x] create dimensioned array for child handles                     *
*     [x] replace child names in subroutine statement with array.        *
*         dimensioned child handles must still be passed singly          *
*     [x] replace child assignments for sending child handles back to    *
*         calling program with child handle array elements               *
* [ ] when scanning other objects and building child handle tables       *
*     also build a table of child handle ptrs.  this will be an          *
*     incrementing value, starting at 1 for each new object and          *
*     incrementing for each new child handle.  if the child handle is    *
*     dimensioned skip the ptr updating and incrementing.  this table    *
*     will be used in calls and property references to get to the        *
*     array elementing with the child object handle                      *
* [ ] if child.handles updates create.child.handles or vice versa also   *
*     update this new table of child handle ptrs                         *
* [ ] when creating "NEW" calls from routines using an object:           *
*     [ ] dimension handle.array.name                                    *
*     [ ] replace child names in call with handle.array.name             *
*     [ ] build xref table of child handles to child array names /       *
*         elements                                                       *
* [ ] when creating a call to an child object                            *
*     [ ] replace child handle in call with dimensioned child handle     *
*         from xref                                                      *
*     [ ] do the same for property references                            *
**************************************************************************

**************************************************************************
* Future enhancements:                                                   *
**************************************************************************
* [ ] DOTNET AND JAVA GET.PROPERTY AND PUT.PROPERTY CALLS                *
*     [ ] Dotnet and Java calls to get and put properties call           *
*         UVServer.CallMethod.  UVServer has a method to handle          *
*         properties, UVServer.GetProperty and UVServer.PutProperty.     *
*         Change building Dotnet and Java classes to call UVServer's     *
*         routines instead of calling UVServer.CallMethod directly       *
*                                                                        *
* [ ] JAVA LIBRARY CLASSES                                               *
*     [ ] Write UVServer class for Java                                  *
*     [ ] Write Primitives class for Java                                *
*     [ ] Write Dynamic class for Java                                   *
*                                                                        *
* [ ] C# CLASSES                                                         *
*     [ ] Build C# classes the same way Dotnet and Java classes are      *
*         built                                                          *
*     [ ] Write UVServer class for C#                                    *
*     [ ] Write Primitives class for C#                                  *
*     [ ] Write Dynamic class for C#                                     *
**************************************************************************
                                  
    $OPTIONS DEFAULT

* functions
    DEFFUN FOLD.ON.COMMA (TEXT.LINE, MAX.WIDTH, INDENT)
    DEFFUN FORMAT.ARRAY (ARRAY.VALUE)
    DEFFUN CONVERT.BYVAL (VARIABLE, ONLY.CONVERT.SINGLE.VARIABLES)
    DEFFUN IS.VARIABLE (EXPRESSION)
    DEFFUN CONVERT.LITERAL.SPACES (PARAMETER.STRING)
    DEFFUN FIND.INDENT.COUNT (PROGRAM.LINE.LABEL, PROGRAM.LINE)
    DEFFUN SMART.TRIM (TRIM.STRING)
    DEFFUN SMART.TRIM.ALL (TRIM.STRING)
    DEFFUN LINE.WITHOUT.LABEL (PROGRAM.LINE)
    DEFFUN LINE.LABEL (PROGRAM.LINE)
    DEFFUN IS.CODE (PROGRAM.LINE)
    DEFFUN IS.COMMENT (PROGRAM.LINE)
    DEFFUN END.OF.STATEMENT (CODE.STRING)
    DEFFUN SPLIT.PARAMETERS (PARAMETER.STRING)
    DEFFUN SPLIT.CODE.LINE (CODE.STRING)
    DEFFUN SPLIT.METHOD.PARAMETERS (PARAMETER.STRING, MODE)
    DEFFUN REMOVE.SPACES (STRING.VALUE)
    DEFFUN FIRST.SPACE (STRING.VALUE)
    DEFFUN FIND.CHAR.PTR (STRING.VALUE, CHAR.VALUE)
    DEFFUN DOWNCASE.QUOTE (STRING.VALUE)
    DEFFUN SPLIT.COMPOUND.LINE (PROGRAM.LINE)
    DEFFUN CHECK.PARENTHESIS (PROGRAM.LINE)
    DEFFUN CONVERT.DYNAMIC.DUPE (PROGRAM.LINE)
    DEFFUN TIME.ELAPSED (START.DATE, START.TIME)
    DEFFUN DOT.NET (VARIABLE.NAME, FROM.CONVERT.LIST, TO.CONVERT.LIST) 
    DEFFUN JAVA (VARIABLE.NAME, FROM.CONVERT.LIST, TO.CONVERT.LIST) 

* named area for shortcuts and macros so we don't have to reload them every
* time
    COMMON /COMPILER/ SHORTCUTS.LOADED

    COMMON /COMPILER/ ENABLE.PROGRAM.SHORTCUTS
    COMMON /COMPILER/ SHORTCUT.CASE, SHORTCUT.UPCASE, SHORTCUT.DOWNCASE
    COMMON /COMPILER/ TEST.DYNAMIC.REFERENCES, SHORTCUT.SPECIAL.KEYWORD.LIST

    COMMON /COMPILER/ SHORTCUT.KEYWORD.LIST, SHORTCUT.DESCRIPTION.LIST
    COMMON /COMPILER/ SHORTCUT.EXPAND.LIST, SHORTCUT.VAR.FOLLOW.LIST, SHORTCUT.FOLLOW.LIST
    COMMON /COMPILER/ SHORTCUT.OPERATOR.LIST
    COMMON /COMPILER/ SHORTCUT.SPACE.BEFORE.LIST, SHORTCUT.SPACE.AFTER.LIST
    COMMON /COMPILER/ SHORTCUT.EMBEDDED.LIST
    COMMON /COMPILER/ SHORTCUT.SECTION.LIST
    COMMON /COMPILER/ SHORTCUT.LENGTH.LIST
    COMMON /COMPILER/ SHORTCUT.COUNT, SHORTCUT.COUNTER

    COMMON /COMPILER/ ENABLE.MACROS, ENABLE.EMBEDDED.MACROS, ENABLE.TEMPORARY.MACROS
    COMMON /COMPILER/ MACRO.KEYWORD

    COMMON /COMPILER/ MACRO.KEYWORD.LIST, MACRO.DESCRIPTION.LIST
    COMMON /COMPILER/ MACRO.PARM.COUNT.LIST, MACRO.PARM.LIST, MACRO.RETURNED.COUNT.LIST
    COMMON /COMPILER/ MACRO.EXPAND.LIST, MACRO.END.EXECUTE.LIST, MACRO.DISPLAY.STYLE.LIST
    COMMON /COMPILER/ MACRO.EMBEDDED.LIST
    COMMON /COMPILER/ MACRO.TEMPORARY.LIST, MACRO.TEMPORARY.LINE.LIST
    COMMON /COMPILER/ MACRO.SECTION.LIST
    COMMON /COMPILER/ MACRO.COUNT, MACRO.COUNTER

    COMMON /COMPILER.KEYWORDS/ OPTIONAL.KEYWORD
    COMMON /COMPILER.KEYWORDS/ BYVAL.KEYWORD, BYVAL.SPECIAL.KEYWORD, BYREF.KEYWORD

    IF UNASSIGNED(SHORTCUTS.LOADED) THEN
        SHORTCUTS.LOADED = @FALSE
    END

* start everything up
    TOTAL.START.DATE = DATE()
    TOTAL.START.TIME = TIME()

    GOSUB MAIN.INITIALIZE
    IF ABORT.PROGRAM THEN
        GOSUB WRAPUP
    END

    GOSUB INITIALIZE
    GOSUB LOAD.COMMAND.LINE

    INIT.END.DATE = DATE()
    INIT.END.TIME = TIME()

    IF ABORT.PROGRAM THEN
        GOSUB WRAPUP
    END

* main compile processing
    BEGIN CASE

* we're listing shortcuts in an auto complete html file for notepad++
        CASE SHORTCUT.LIST AND AUTOCOMPLETE.LIST
            GOSUB LOAD.SHORTCUT.SETTINGS
            GOSUB NOTEPAD.PP.AUTOCOMPLETE

* we're only listing shortcuts
        CASE SHORTCUT.LIST
            GOSUB SHORTCUT.LIST

* we're doing dotnet and java class exports but not compiling
        CASE ONLY.DOT.NET.EXPORTS AND ONLY.JAVA.EXPORTS
            GOSUB ALL.API.EXPORTS

* we're only doing dotnet class exports
        CASE ONLY.DOT.NET.EXPORTS
            GOSUB ONLY.DOT.NET.EXPORTS

* we're only doing java class exports
        CASE ONLY.JAVA.EXPORTS
            GOSUB ONLY.JAVA.EXPORTS

* no object specified in the command line so there's nothing too compile.
* show help information
        CASE OBJECT.COUNT = 0
            GOSUB NO.OBJECTS.SPECIFIED

* we're compiling something
        CASE 1
            GOSUB MAIN.COMPILE

    END CASE

    GOSUB WRAPUP

    RETURN


**************************************************************************
**************************************************************************
** compiling / main compile routine                                     **
**************************************************************************
**************************************************************************

MAIN.COMPILE: ************************************************************
* compile programs                                                       *
**************************************************************************

* put up option selections menu if requested
    OBJECT.NAME = OBJECT.LIST<1>
    GOSUB GET.OBJECT.FILENAME
    IF ABORT.PROGRAM THEN
        GOSUB WRAPUP
    END

    BEGIN CASE
        CASE OBJECT.FILENAME = "OBJ" AND ASK.FOR.OBJ.OPTIONS
            RUN.OPTIONS.MENU = @TRUE
        CASE OBJECT.FILENAME = "OBP" AND ASK.FOR.OBP.OPTIONS
            RUN.OPTIONS.MENU = @TRUE
        CASE ASK.FOR.OPTIONS
            RUN.OPTIONS.MENU = @TRUE
        CASE 1
            RUN.OPTIONS.MENU = @FALSE
    END CASE

    IF RUN.OPTIONS.MENU THEN
        GOSUB OPTION.MENU
        IF ABORT.PROGRAM THEN
            GOSUB WRAPUP
        END
    END

    GOSUB PRINT.STARTUP.MESSAGE

    GOSUB LOAD.SHORTCUT.SETTINGS

    COMPILE.START.DATE = DATE()
    COMPILE.START.TIME = TIME()

    GOSUB PROCESS.OBJECT.LIST

    COMPILE.END.DATE = DATE()
    COMPILE.END.TIME = TIME()
    COMPILE.ELAPSED.TIME += TIME.ELAPSED (COMPILE.START.DATE, COMPILE.START.TIME)

    TOTAL.END.DATE = DATE()
    TOTAL.END.TIME = TIME()
    TOTAL.ELAPSED.TIME += TIME.ELAPSED (TOTAL.START.DATE, TOTAL.START.TIME)

    GOSUB REPORT.PROCESSED

    IF DISPLAY.COMPILE.TIMES THEN
        GOSUB REPORT.PROCESSING.TIMES
    END

    RETURN

ONLY.DOT.NET.EXPORTS: ****************************************************
* do just the dot net exports without recompiling                        *
**************************************************************************
    GOSUB GET.DEBUG.SETTINGS

* if no objects were specified prompt for one
    IF OBJECT.COUNT = 0 THEN

        GOSUB CHOOSE.OBJECT.FROM.MENU

        IF PROGRAM.NAME = "" THEN
            RETURN
        END

        OBJECT.LIST = PROGRAM.NAME
        OBJECT.COUNT = 1

    END

* export the object(s)
    OBJECT.FILENAME = "OBJ"

    FOR OBJECT.LOOP = 1 TO OBJECT.COUNT

        COMPILE.NAME = OBJECT.LIST<OBJECT.LOOP>
        OBJECT.NAME = COMPILE.NAME

        GOSUB GET.OBJECT
        GOSUB UNWRAP.LINES
        GOSUB BUILD.OBJECT.TABLES

        GOSUB UPDATE.DOT.NET.OBJECT

    NEXT OBJECT.LOOP

    RETURN

ONLY.JAVA.EXPORTS: *******************************************************
* do just the java exports without recompiling                           *
**************************************************************************
    GOSUB GET.DEBUG.SETTINGS

* if no objects were specified prompt for one
    IF OBJECT.COUNT = 0 THEN

        GOSUB CHOOSE.OBJECT.FROM.MENU

        IF PROGRAM.NAME = "" THEN
            RETURN
        END

        OBJECT.LIST = PROGRAM.NAME
        OBJECT.COUNT = 1

    END

* export the object(s)
    OBJECT.FILENAME = "OBJ"

    FOR OBJECT.LOOP = 1 TO OBJECT.COUNT

        COMPILE.NAME = OBJECT.LIST<OBJECT.LOOP>
        OBJECT.NAME = COMPILE.NAME

        GOSUB GET.OBJECT
        GOSUB UNWRAP.LINES
        GOSUB BUILD.OBJECT.TABLES

        GOSUB UPDATE.JAVA.OBJECT

    NEXT OBJECT.LOOP

    RETURN

ALL.API.EXPORTS: *********************************************************
* do just the dotnet and java exports without recompiling                *
**************************************************************************
    GOSUB GET.DEBUG.SETTINGS

* if no objects were specified prompt for one
    IF OBJECT.COUNT = 0 THEN

        GOSUB CHOOSE.OBJECT.FROM.MENU

        IF PROGRAM.NAME = "" THEN
            RETURN
        END

        OBJECT.LIST = PROGRAM.NAME
        OBJECT.COUNT = 1

    END

* export the object(s)
    OBJECT.FILENAME = "OBJ"

    FOR OBJECT.LOOP = 1 TO OBJECT.COUNT

        COMPILE.NAME = OBJECT.LIST<OBJECT.LOOP>
        OBJECT.NAME = COMPILE.NAME

        GOSUB GET.OBJECT
        GOSUB UNWRAP.LINES
        GOSUB BUILD.OBJECT.TABLES

        GOSUB UPDATE.DOT.NET.OBJECT
        GOSUB UPDATE.JAVA.OBJECT

    NEXT OBJECT.LOOP

    RETURN


**************************************************************************
**************************************************************************
** initialization / startup                                             **
**************************************************************************
**************************************************************************

MAIN.INITIALIZE: *********************************************************
* initialize variables when the program starts.  this 'initialize'       *
* routine is only run once, when the precompiler starts up               *
**************************************************************************
    OPEN.STANDARD.FILES

    GOSUB RESET.TIME.STAMPS

    CURRENT.SETTING.NAME = ""

    PROMPT ""

    TO.THE.END = 1000000

    SKIP.WAITS = @FALSE

* initialize counts
    CHILD.COUNT = 0
    CREATED.COUNT = 0
    CREATE.COUNT = 0
    CREATE.CHILD.COUNT = 0
    OBJECT.USED.COUNT = 0
    NEW.CHILD.COUNT = 0
    CHILD.DEL.COUNT = 0

* checking for <12> (abort)
    LAST.CHECK.ABORT.DATE = DATE()
    LAST.CHECK.ABORT.TIME = TIME()
    CHECK.ABORT.EVERY = 2

* initialize type of compile
    COMPILE.OBJECT = @FALSE
    COMPILE.SUBROUTINE = @FALSE
    COMPILE.CBP = @FALSE
    COMPILE.CORE = @FALSE
    COMPILE.OC = @FALSE

* initialize all the object tables
    GOSUB CLEAR.METHOD.LIST
    GOSUB CLEAR.PROPERTY.LIST
    GOSUB CLEAR.CONSTANT.LIST
    GOSUB CLEAR.CHILD.LIST

* list to keep programs that didn't compile correctly
    BAD.COMPILE.LIST = ""
    BAD.COMPILE.COUNT = 0

* grand totals for everything compiled in one session
    GRAND.TOTAL.COMPILED = 0
    GRAND.TOTAL.LINES = 0
    GRAND.TOTAL.BYTES = 0

    GRAND.TOTAL.ERRORS = 0
    GRAND.TOTAL.WARNINGS = 0

* initialize eclipse common variable tables
    ECLIPSE.COMMON.NAME.LIST = ""
    ECLIPSE.COMMON.CC.LIST = ""
    ECLIPSE.COMMON.COUNT = 0

    EQUATE.CONSTANT.LIST = ""
    EQUATE.CONSTANT.COUNT = 0

* keyword decoding
    DECODE.KEYWORD = ""

* shortcuts and macros loaded for shortcut listing
    SHORTCUTS.LOADED.FOR.LISTING = @FALSE

* maximum level of shortcuts / macros to load.  used when listing
* shortcuts / macros
    MAX.LOAD.LEVEL = 999
    SHORTCUT.LOAD.TYPE = ""

* startup--get all settings and command line options and things
    ABORT.PROGRAM = @FALSE

    GOSUB OPEN.FILES
    IF ABORT.PROGRAM THEN
        RETURN
    END

    GOSUB LOAD.COMPILE.SETTINGS
    IF ABORT.PROGRAM THEN
        RETURN
    END

* get the short and long host names
    EXECUTE "HOSTNAME" CAPTURING TEXT
    UV.HOST.NAME = TEXT<2>

    EXECUTE 'SH -c "hostname"' CAPTURING TEXT
    UNIX.HOST.NAME = TEXT<1>

* if we're checking eclipse common variable against subroutine parameters
* build a table of eclipse common variables
    IF CHECK.ECLIPSE.COMMON.VARIABLES THEN
        GOSUB GET.ECLIPSE.COMMON.VARIABLES
    END

* comments for before and after user code in the methods
    BEFORE.USER.CODE = "* start of user code * * * * * * * * * * * * * * * * * * * * * * * * * * * *"
    AFTER.USER.CODE =  "* end of user code * * * * * * * * * * * * * * * * * * * * * * * * * * * * *"
    NO.USER.CODE =     "* this method has no user code * * * * * * * * * * * * * * * * * * * * * * *"

* comments for before and after code to check for calling a split routine
    BEFORE.SPLIT.CODE = "* before split checking code"
    AFTER.SPLIT.CODE = "* after split checking code"

    SELECT.METHOD = ""

    EXECUTE "WHO" CAPTURING WHO.TEXT
    PORT.NO = WHO.TEXT<1> [" ", 1, 1]

* variable for parallel compiling
    COMO.COUNTER = 0
    COMO.PREFIX = "PARALLEL.COMPILE.":PORT.NO:"."

    PARALLEL.OBJECT.LIST = ""
    PARALLEL.METHOD.LIST = ""
    PARALLEL.COMO.LIST = ""
    PARALLEL.STARTED.LIST = ""
    PARALLEL.COMPLETE.LIST = ""
    PARALLEL.SUCCESSFUL.LIST = ""
    PARALLEL.COUNT = 0

* dotnet / java exports
    FIRST.DOTNET.EXPORT = @TRUE
    FIRST.JAVA.EXPORT = @TRUE

* get a list of basic keywords
    READ BASIC.KEYWORD.LIST FROM CONTROL.HANDLE, "BASIC.KEYWORDS" ELSE
        BASIC.KEYWORD.LIST = ""
    END

    MAIN.INIT.END.DATE = DATE()
    MAIN.INIT.END.TIME = TIME()
    MAIN.INIT.ELAPSED.TIME += TIME.ELAPSED (MAIN.INIT.START.DATE, MAIN.INIT.START.TIME)

* get a list of unary keywords
    READ UNARY.KEYWORD.LIST FROM CONTROL.HANDLE, "UNARY.KEYWORDS" ELSE
        UNARY.KEYWORD.LIST = ""
    END

* get user name
    READ INITIALS.RECORD FROM INIFILE, USER.ID ELSE
        INITIALS.RECORD = ""
    END

    USER.NAME = INITIALS.RECORD<3>

    GOSUB INITIALIZE.CODE.SPLITTING

    RETURN

OPEN.FILES: **************************************************************
* open files                                                             *
**************************************************************************

* the "OBJ" file holds source code for objects
    OPEN "OBJ" TO OBJFILE ELSE
        PRINT
        PRINT "Can't open OBJ!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

* the "OBP" file holds source code for object-enabled ruoutines
    OPEN "OBP" TO OBPFILE ELSE
        PRINT
        PRINT "Can't open OBP!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

* ud.control is a control file for non-eclipse modules
    OPEN "UD.CONTROL" TO CONTROL.HANDLE ELSE
        PRINT
        PRINT "Can't open UD.CONTROL!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

* ud.compile.dates is an optional file where method compile dates
* are saved
    UD.COMPILE.DATES.EXISTS = @FALSE
    OPEN "UD.COMPILE.DATES" TO COMPILEDATESFILE THEN
        UD.COMPILE.DATES.EXISTS = @TRUE
    END

* eclipse files
    OPEN "CBP" TO CBPFILE ELSE
        PRINT
        PRINT "Can't open CBL!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "BP" TO BPFILE ELSE
        PRINT
        PRINT "Can't open BP!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "OC" TO OCFILE ELSE
        PRINT
        PRINT "Can't open OC!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "OC.O" TO OCOFILE ELSE
        PRINT
        PRINT "Can't open OC.O!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "PGM.VERSION" TO PROGRAM.VERSION ELSE
        PRINT
        PRINT "Can't open PGM.VERSION!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "VOC" TO VOC ELSE
        PRINT
        PRINT "Can't open VOC!"
        PRINT
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    OPEN "&COMO&" TO COMOFILE ELSE
        PRINT
        PRINT "Can't open &COMO&!" 
        PRINT
        RETURN
    END

    OBJ.NET.EXISTS = @FALSE 
    OPEN "OBJ.NET" TO OBJNETFILE THEN
        OBJ.NET.EXISTS = @TRUE
    END

    OBJ.JAVA.EXISTS = @FALSE
    OPEN "OBJ.JAVA" TO OBJJAVAFILE THEN
        OBJ.JAVA.EXISTS = @TRUE
    END

    RETURN

