**************************************************************************
**************************************************************************
** initialization / shortcuts / loading                                 **
**************************************************************************
**************************************************************************

GET.SHORTCUT.SETTINGS: ***************************************************
* load shortcut settings from the compile.setting control record.  if    *
* shortcuts.in.order is set shortcuts are added in the same order they   *
* appear in compile.setup, which works better for listing.  if false     *
* they're sorted in descending alpha order, which works better for the   *
* compiler.                                                              *
*                                                                        *
* max.load.level determines the maximum "Level" of shortcuts to load.    *
* this is used when listing shortcuts to provide a filter for often-used *
* shortcuts vs rarely-used.  1 = most often used                         *
**************************************************************************

* shortcuts are entered into the setup record like this, where "Number"
* is a counter starting with 1:

*    ShortcutNumber:
*        Name = "ShortcutName"
*        Expand = "ExpandedExpression"
*        VarFollow = "VariableFollowingExpression"
*        Follow = "FollowingExpression"
*        SpaceBefore = Yes/No
*        SpaceAfter = Yes/No
*        Level = ShortcutLoadLevel

* The macro name is converted to the Expanded expression.  There are no
* parameters--if you need parameters make it a macro.

* "VarFollow" is an optional expression added to the end of the next
* variable expression after the shortcut

* "Follow" is an optional expression added to the end of the line with
* the macro in it, ie, to close a quote at the end of an expression or
* add some additional code or something

* SpaceBefore indicates whether a space before the shortcut is required
* for the shortcut to be converted.  defaults to Yes if SpaceBefore is
* not defined

* Spaceafter indicates whether a space after the shortcut is required.
* also defaults to Yes

* Level determines the "level" of the shortcut for the purposes of listing
* shortcuts with the "METHOD" and "METHODS command 

* load up our settings record unless we're in a mode (ie, listing objects)
* that doesn't need them
    IF LOAD.SHORTCUTS THEN
        SETTING.NAME = "SHORTCUT.SETUP"
        GOSUB LOAD.SETTING.RECORD
    END

* enable programming shortcuts?
    ENABLE.PROGRAM.SHORTCUTS = UD.GET.SETTING("EnableProgramShortcuts", 1, 1)

* convert case when showing shortcuts?
    SHORTCUT.CASE = UD.GET.SETTING("ShortcutCase", "None")
    SHORTCUT.UPCASE = @FALSE
    SHORTCUT.DOWNCASE = @FALSE
    IF SHORTCUT.CASE = "DownCase" THEN
        SHORTCUT.DOWNCASE = @TRUE
    END
    IF SHORTCUT.CASE = "UpCase" THEN
        SHORTCUT.UPCASE = @TRUE
    END

* when converting shortcuts and macros the precompiler often has to search
* ahead of the shortcut / macro to find the next complete expression.  this
* expression may be a dynamic array reference indicated with "<" and ">".
* as "<" and ">" may also be less-than and greater-than signs it's necessary
* to determine if they're dynamic array references or if they're less-than
* and greater-than signs.  should a test be done on the expression to try
* to determine the status of the "<" and ">" signs or should a "safe"
* method, that doesn't try to determine the status, be used?
    TEST.DYNAMIC.REFERENCES = UD.GET.SETTING("TestDynamicReferences", 1, 1)

* list of "not embedded" keywords for embedded shortcuts.  if one of these
* keywords is before the usage of a shortcut the shortcut will not be
* considered an "embedded" shortcut and will be processed in place.  this
* is so shortcuts like ". . . on error write.error~~" will process the
* shortcut in place and not treat the shortcut as embedded and move it to
* its own code line
    SHORTCUT.SPECIAL.KEYWORD.LIST = UD.GET.SETTING("ShortcutSpecialKeywordList")
    SHORTCUT.SPECIAL.KEYWORD.LIST = CHANGE(SHORTCUT.SPECIAL.KEYWORD.LIST, ",", @AM)

* build a table of shortcuts from the setup record
    SHORTCUT.KEYWORD.LIST = ""

    SHORTCUT.DESCRIPTION.LIST = ""

    SHORTCUT.EXPAND.LIST = ""
    SHORTCUT.VAR.FOLLOW.LIST = ""
    SHORTCUT.FOLLOW.LIST = ""
    SHORTCUT.OPERATOR.LIST = ""

    SHORTCUT.SPACE.BEFORE.LIST = ""
    SHORTCUT.SPACE.AFTER.LIST = ""

    SHORTCUT.EMBEDDED.LIST = ""

    SHORTCUT.SECTION.LIST = ""

    SHORTCUT.LENGTH.LIST = ""

    SHORTCUT.COUNT = 0
    SHORTCUT.COUNTER = 0
    DONE = @FALSE
    LAST.SECTION = ""

* if we're only listing objects skip loading the shortcut table.  this will
* make things faster because, first, the shortcut table takes awhile to build.
* second, it also skips the shortcut conversions since there won't be anything
* in the macro table
    IF LIST.OBJECTS.ONLY THEN
        DONE = @TRUE
    END

    LOOP UNTIL DONE DO

        SHORTCUT.COUNTER += 1

        SETTING.TAG = "Shortcut":SHORTCUT.COUNTER:"."

        THIS.SHORTCUT = UD.GET.SETTING(SETTING.TAG:"Name")

* if a shortcut is defined for "{}" it won't work because clean.line changes
* "{}" to "{ }".  if we have a macro with this name change it to "{ }"
        IF THIS.SHORTCUT = "{}" THEN
            THIS.SHORTCUT = "{ }"
        END

        IF THIS.SHORTCUT <> "" THEN

            THIS.DESCRIPTION = UD.GET.SETTING(SETTING.TAG:"Description")

            THIS.EXPAND = UD.GET.SETTING(SETTING.TAG:"Expand")
            THIS.VAR.FOLLOW = UD.GET.SETTING(SETTING.TAG:"VarFollow")
            THIS.FOLLOW = UD.GET.SETTING(SETTING.TAG:"Follow")
            THIS.OPERATOR = UD.GET.SETTING(SETTING.TAG:"Operator", 0, 1)

            THIS.SPACE.BEFORE = UD.GET.SETTING(SETTING.TAG:"SpaceBefore", 1, 1)
            THIS.SPACE.AFTER = UD.GET.SETTING(SETTING.TAG:"SpaceAfter", 1, 1)

            THIS.EMBEDDED = UD.GET.SETTING(SETTING.TAG:"Embedded", 0, 1)

            THIS.SECTION = UD.GET.SETTING(SETTING.TAG:"Section")

            THIS.LENGTH = LEN(THIS.SHORTCUT)

            THIS.LOAD.LEVEL = UD.GET.SETTING(SETTING.TAG:"Level", 3)

            IF THIS.SECTION <> "" AND THIS.SECTION <> LAST.SECTION THEN
                LAST.SECTION = THIS.SECTION
            END

            MAJOR.SECTION = TRIM(LAST.SECTION ["/", 1, 1])

            IF THIS.LOAD.LEVEL <= MAX.LOAD.LEVEL THEN
                IF SHORTCUT.LOAD.TYPE = "" OR SHORTCUT.LOAD.TYPE = LAST.SECTION OR SHORTCUT.LOAD.TYPE = MAJOR.SECTION THEN
                    GOSUB ADD.SHORTCUT.TO.LIST
                END
            END

        END ELSE

            DONE = @TRUE

        END

    REPEAT

    RETURN

ADD.SHORTCUT.TO.LIST: ****************************************************
* add the currently loaded shortcut to the shortcut list                 *
**************************************************************************

* we want to keep the shortcut list in descending name length order so that if
* a longer shortcut has a shorter shortcut inside it the longer shortcuts will
* be evaluated first
    LOCATE THIS.LENGTH IN SHORTCUT.LENGTH.LIST BY "DR" SETTING SHORTCUT.PTR ELSE
        NULL
    END

    SHORTCUT.COUNT += 1

* if we're adding shortcuts in order reset the shortcut pointer.  this is 
* usually a bad idea.  if a shortcut has another shortcut that's embedded in
* it's name but earlier in the list the first shortcut will be processed first
* when the longer shortcut should be processed.  sorting by descending length
* takes care of this
    IF SHORTCUTS.IN.ORDER THEN
        SHORTCUT.PTR = SHORTCUT.COUNT
    END

    INS THIS.SHORTCUT BEFORE SHORTCUT.KEYWORD.LIST<SHORTCUT.PTR>

    INS THIS.DESCRIPTION BEFORE SHORTCUT.DESCRIPTION.LIST<SHORTCUT.PTR>

    INS THIS.EXPAND BEFORE SHORTCUT.EXPAND.LIST<SHORTCUT.PTR>
    INS THIS.VAR.FOLLOW BEFORE SHORTCUT.VAR.FOLLOW.LIST<SHORTCUT.PTR>
    INS THIS.FOLLOW BEFORE SHORTCUT.FOLLOW.LIST<SHORTCUT.PTR>
    INS THIS.OPERATOR BEFORE SHORTCUT.OPERATOR.LIST<SHORTCUT.PTR>

    INS THIS.SPACE.BEFORE BEFORE SHORTCUT.SPACE.BEFORE.LIST<SHORTCUT.PTR>
    INS THIS.SPACE.AFTER BEFORE SHORTCUT.SPACE.AFTER.LIST<SHORTCUT.PTR>

    INS THIS.EMBEDDED BEFORE SHORTCUT.EMBEDDED.LIST<SHORTCUT.PTR>

    INS THIS.SECTION BEFORE SHORTCUT.SECTION.LIST<SHORTCUT.PTR>

    INS THIS.LENGTH BEFORE SHORTCUT.LENGTH.LIST<SHORTCUT.PTR>

    RETURN


**************************************************************************
**************************************************************************
** initialization / macros / loading                                    **
**************************************************************************
**************************************************************************

GET.MACRO.SETTINGS: ******************************************************
* load macro settings from the compile.setting control record            *
**************************************************************************

* macros are entered into the setup record like this, where "Number"
* is a counter starting with 1 and incrementing.  once the routine
* can't find a "MacroNumber" tag it stops looking:

*    MacroNumber:
*        Name = "MacroName"
*        Parameters = ParameterCount
*        Expand = "MacroExpandedExpression"
*        EndExecute = "EndExecuteExpression"
*        DisplayStyle = n
*        Embedded = n

* a macro expression in code is always in this form:

*    Parameter0 = MacroName(Parameter1, Parameter2, etc)

* MacroName is matched in the macro table for a macro definition
* with the same number of parameters as in the Macro statement.
* Parameter0 is always assumed to be there.  1 parameters means
* only Parameter0 is there, 2 means Parameter0 and Parameter1 are
* there, etc

* in the Macro definition %0 is Parameter0, %1 is Parameter1, etc.
* each "%" expression is replaced with the expression from the
* macro definition

* EndExecute is optional.  It's an expression that is executed at
* the end of the current programming structure.  ie, if the
* macro starts a "LOOP / REPEAT" structure and something should
* be executed before the "REPEAT" it could be put in the EndExecute.

* DisplayStyle is also optional.  if "1" the macro will be displayed 
* in the shortcuts listing as macro.name (%0,%1).  if not defined it
* will appear as %0 = macro.name (%1)

* Embedded is optional.  if "1" and the macro is used in a larger
* expression the macro will be extracted from the expression and
* put in its own program line ahead of the expression.  this allows
* macros to be used in the middle of other expressions.  if not defined
* it will be assumed to be "0" (false).

* load up our settings record unless we're in a mode that doesn't need
* them, ie, listing objects
    IF LOAD.MACROS THEN
        SETTING.NAME = "SHORTCUT.SETUP"
        GOSUB LOAD.SETTING.RECORD
    END

* macro settings
    TAG = "MacroSettings."

* enable macro conversions?
    ENABLE.MACROS = UD.GET.SETTING(TAG:"EnableMacros", 1, 1)

* enable embedded macros?
    ENABLE.EMBEDDED.MACROS = UD.GET.SETTING(TAG:"EnableEmbeddedMacros", 1, 1)

* enable temporary macros defined in the code?
    ENABLE.TEMPORARY.MACROS = UD.GET.SETTING(TAG:"EnableTemporaryMacros", 1, 1)
    MACRO.KEYWORD = UD.GET.SETTING(TAG:"MacroKeyword", "MACRO")

* build a table of macros from the setup record
    MACRO.KEYWORD.LIST = ""

    MACRO.DESCRIPTION.LIST = ""

    MACRO.PARM.COUNT.LIST = ""
    MACRO.PARM.LIST = ""
    MACRO.RETURNED.COUNT.LIST = ""

    MACRO.EXPAND.LIST = ""

    MACRO.END.EXECUTE.LIST = ""

    MACRO.DISPLAY.STYLE.LIST = ""

    MACRO.EMBEDDED.LIST = ""

    MACRO.TEMPORARY.LIST = ""
    MACRO.TEMPORARY.LINE.LIST = ""

    MACRO.SECTION.LIST = ""

    MACRO.COUNT = 0
    MACRO.COUNTER = 0

    DONE = @FALSE

* if we're only listing objects skip loading the macro table.  this will
* make things faster because, first, the macro table takes awhile to build.
* second, it also skips the macro conversions since there won't be anything
* in the macro table
    IF LIST.OBJECTS.ONLY THEN
        DONE = @TRUE
    END

    LOOP UNTIL DONE DO

        MACRO.COUNTER += 1

        SETTING.TAG = "Macro":MACRO.COUNTER:"."

        THIS.MACRO = UD.GET.SETTING(SETTING.TAG:"Name")

        IF THIS.MACRO <> "" THEN

            THIS.DESCRIPTION = UD.GET.SETTING(SETTING.TAG:"Description")

            THIS.COUNT = UD.GET.SETTING(SETTING.TAG:"Parameters")
            THIS.PARM.LIST = UD.GET.SETTING(SETTING.TAG:"Passed")
            THIS.RETURNED.COUNT = UD.GET.SETTING(SETTING.TAG:"Returned", 1)

            THIS.EXPAND = UD.GET.SETTING(SETTING.TAG:"Expand")
            THIS.END.EXECUTE = UD.GET.SETTING(SETTING.TAG:"EndExecute")
            THIS.DISPLAY.STYLE = UD.GET.SETTING(SETTING.TAG:"DisplayStyle", 0)

            THIS.EMBEDDED = UD.GET.SETTING(SETTING.TAG:"Embedded", 0)

            THIS.SECTION = UD.GET.SETTING(SETTING.TAG:"Section")

            IF THIS.SECTION <> "" AND THIS.SECTION <> LAST.SECTION THEN
                LAST.SECTION = THIS.SECTION
            END

            THIS.LOAD.LEVEL = UD.GET.SETTING(SETTING.TAG:"Level", 3)

            MAJOR.SECTION = TRIM(LAST.SECTION ["/", 1, 1])

            IF THIS.LOAD.LEVEL <= MAX.LOAD.LEVEL THEN
                IF SHORTCUT.LOAD.TYPE = "" OR SHORTCUT.LOAD.TYPE = LAST.SECTION OR SHORTCUT.LOAD.TYPE = MAJOR.SECTION THEN
                    GOSUB ADD.MACRO.TO.LIST
                END
            END

        END ELSE

            DONE = @TRUE

        END

    REPEAT

    RETURN

ADD.MACRO.TO.LIST: *******************************************************
* add the current macro to the macro list                                *
**************************************************************************
    MACRO.COUNT += 1

    MACRO.KEYWORD.LIST<MACRO.COUNT> = THIS.MACRO

    MACRO.DESCRIPTION.LIST<MACRO.COUNT> = THIS.DESCRIPTION

    MACRO.PARM.COUNT.LIST<MACRO.COUNT> = THIS.COUNT
    MACRO.PARM.LIST<MACRO.COUNT> = CHANGE(THIS.PARM.LIST, ",", @VM)
    MACRO.RETURNED.COUNT.LIST<MACRO.COUNT> = THIS.RETURNED.COUNT

    MACRO.EXPAND.LIST<MACRO.COUNT> = THIS.EXPAND
    MACRO.END.EXECUTE.LIST<MACRO.COUNT> = THIS.END.EXECUTE

    MACRO.DISPLAY.STYLE.LIST<MACRO.COUNT> = THIS.DISPLAY.STYLE

    MACRO.EMBEDDED.LIST<MACRO.COUNT> = THIS.EMBEDDED

    MACRO.TEMPORARY.LIST<MACRO.COUNT> = ""
    MACRO.TEMPORARY.LINE.LIST<MACRO.COUNT> = ""

    MACRO.SECTION.LIST<MACRO.COUNT> = THIS.SECTION

    RETURN

GET.DEBUG.SETTINGS: ******************************************************
* get debug settings                                                     *
**************************************************************************

* load up our settings record unless in a mode that doesn't need them, ie,
* listing objects
    IF LOAD.SHORTCUTS THEN
        SETTING.NAME = "SHORTCUT.SETUP"
        GOSUB LOAD.SETTING.RECORD
    END

* enable debugging shortcuts?
    ENABLE.DEBUG.SHORTCUTS = UD.GET.SETTING("EnableDebugShortcuts", 1, 1)

* debugging keywords
    DEBUG.SEND.ARRAY.KEYWORD = UD.GET.SETTING("DebugSendArrayKeyword", "<<<<")
    DEBUG.CLEAR.AND.MESSAGE.KEYWORD = UD.GET.SETTING("DebugClearAndMessageKeyword", "<<#")
    DEBUG.SEND.VARIABLE.KEYWORD = UD.GET.SETTING("DebugSendVariableKeyword", "<<<")
    DEBUG.SEND.TEXT.KEYWORD = UD.GET.SETTING("DebugSendTextKeyword", "<<")
    DEBUG.SET.SOURCE.KEYWORD = UD.GET.SETTING("DebugSetSourceKeyword", "+++")
    DEBUG.CLEAR.SOURCE.KEYWORD = UD.GET.SETTING("DebugClearSourceKeyword", "---")
    DEBUG.CLEAR.KEYWORD = UD.GET.SETTING("DebugClearKeyword", "##")
    DEBUG.IDENTIFY.METHOD.KEYWORD = UD.GET.SETTING("DebugIdentifyMethodKeyword", "###")

* lengths of debugging keywords
    DEBUG.SEND.ARRAY.KEYWORD.LEN = LEN(DEBUG.SEND.ARRAY.KEYWORD)
    DEBUG.CLEAR.AND.MESSAGE.KEYWORD.LEN = LEN(DEBUG.CLEAR.AND.MESSAGE.KEYWORD)
    DEBUG.SEND.VARIABLE.KEYWORD.LEN = LEN(DEBUG.SEND.VARIABLE.KEYWORD)
    DEBUG.SEND.TEXT.KEYWORD.LEN = LEN(DEBUG.SEND.TEXT.KEYWORD)
    DEBUG.SET.SOURCE.KEYWORD.LEN = LEN(DEBUG.SET.SOURCE.KEYWORD)
    DEBUG.CLEAR.SOURCE.KEYWORD.LEN = LEN(DEBUG.CLEAR.SOURCE.KEYWORD)
    DEBUG.CLEAR.KEYWORD.LEN = LEN(DEBUG.CLEAR.KEYWORD)
    DEBUG.IDENTIFY.METHOD.KEYWORD.LEN = LEN(DEBUG.IDENTIFY.METHOD.KEYWORD)

* debugging conversions
    DEBUG.ON.TEXT = UD.GET.SETTING("DebugOnText")
    DEBUG.OFF.TEXT = UD.GET.SETTING("DebugOffText")

    DEBUG.SEND.TEXT = UD.GET.SETTING("DebugSendText")
    DEBUG.SEND.MESSAGE.TEXT = UD.GET.SETTING("DebugSendMessageText")
    DEBUG.CLEAR.SEND.TEXT = UD.GET.SETTING("DebugClearSendText")

    DEBUG.VARIABLE.TEXT = UD.GET.SETTING("DebugVariableText") 
    DEBUG.VARIABLE.LITERAL.TEXT = UD.GET.SETTING("DebugVariableLiteralText")
    DEBUG.VARIABLE.VALUE.TEXT = UD.GET.SETTING("DebugVariableValueText")

    DEBUG.CLEAR.TEXT = UD.GET.SETTING("DebugClearText")

    DEBUG.IDENTIFY.METHOD.TEXT = UD.GET.SETTING("DebugIdentifyMethodText")

    DEBUG.METHOD.TRAIL = UD.GET.SETTING("DebugMethodTrail", 0, 1)
    DEBUG.METHOD.PARAMETERS = UD.GET.SETTING("DebugMethodParameters", 0, 1)

* build debugging shortcut table
    DEBUG.SHORTCUT.LIST = DEBUG.SET.SOURCE.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.CLEAR.SOURCE.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.SEND.TEXT.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.CLEAR.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.SEND.ARRAY.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.CLEAR.AND.MESSAGE.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.SEND.VARIABLE.KEYWORD:AM
    DEBUG.SHORTCUT.LIST := DEBUG.IDENTIFY.METHOD.KEYWORD

    RETURN

LOAD.SETTING.RECORD: *****************************************************
* load settings from setting.name.  if setting.name is the same as the   *
* current settings loaded no load will be performed                      *
**************************************************************************
    IF SETTING.NAME <> CURRENT.SETTING.NAME THEN
        UD.LOAD.SETTINGS SETTING.NAME
        CURRENT.SETTING.NAME = SETTING.NAME
    END

    RETURN


**************************************************************************
**************************************************************************
** initialization / object initialization                               **
**************************************************************************
**************************************************************************

INITIALIZE: **************************************************************
* initialize variables and tables and things.  this 'initialize' routine *
* is run before each program or object is compiled                       *
**************************************************************************
    INIT.START.DATE = DATE()
    INIT.START.TIME = TIME()

    UD.GETACCOUNT ACCOUNT, LOGIN
    UD.HOSTDIR LOCAL.DIRECTORY

* usage table buffering
    BUFFERED.OBJECT.NAME = ""

* subroutine being created
    SUBROUTINE.NAME = ""

* property and child lists
    PROP.NAME.LIST = ""
    CONSTANT.NAME.LIST = ""
    CHILD.HANDLE.LIST = ""

* clean line indexes
    CLEAN.SOURCE.INDEX = ""
    CLEAN.FINAL.INDEX = ""
    CLEAN.INDEX.COUNT = 0

* methods created and their associated eclipse subroutine names
    CREATED.METHOD.LIST = ""
    CREATED.SUBROUTINE.LIST = ""

    CREATED.SOURCE.START.LIST = ""
    CREATED.TARGET.START.LIST = ""
    CREATED.SOURCE.COUNT.LIST = ""

    CREATED.SOURCE.COMMON.START.LIST = ""
    CREATED.TARGET.COMMON.START.LIST = ""
    CREATED.SOURCE.COMMON.COUNT.LIST = ""

    CREATED.SUBROUTINE.COUNT.LIST = ""
    CREATED.SUBROUTINE.BYTE.LIST = ""

    CREATED.METHOD.SOURCE.LIST = ""
    CREATED.METHOD.FINAL.LIST = ""

    CREATED.METHOD.COUNT = 0

* returned child list from the "new" method creation
    RETURNED.CHILD.LIST = ""
    RETURNED.CHILD.DIM.LIST = ""
    RETURNED.CHILD.COUNT = 0
    RETURNED.CHILD.LIST.BUILT = @FALSE

    ALL.CHILD.LIST = ""
    ALL.CHILD.DIM.LIST = ""
    ALL.CHILD.COUNT = 0
    ALL.CHILD.LIST.BUILT = @FALSE

* subroutines that compiled with errors
    BAD.SUBROUTINE.LIST = ""
    BAD.SUBROUTINE.COUNT = 0

* counts for a pretty display later
    METHOD.CREATE.COUNT = 0
    METHOD.LINE.COUNT = 0
    METHOD.BYTE.COUNT = 0

    WRAPPER.CREATE.LIST = ""
    WRAPPER.CREATE.COUNT = 0
    WRAPPER.LINE.COUNT = 0
    WRAPPER.BYTE.COUNT = 0

    ONLY.DOT.NET.EXPORTS = @FALSE
    ONLY.JAVA.EXPORTS = @FALSE

* eclipse subroutine code
    GOSUB INITIALIZE.PROGRAM.CODE

* wrapper code
    WRAPPER.CREATED = 0
    WRAPPER.CODE = ""
    WRAPPER.CODE.LINES = 0

* program error table
    OBJECT.ERROR.DESC = ""
    OBJECT.ERROR.LINE = ""

    ERROR.SUBROUTINE.LIST = ""
    ERROR.METHOD.LIST = ""
    ERROR.SOURCE.LINE.LIST = ""
    ERROR.ECLIPSE.LINE.LIST = ""
    ERROR.DESC.LIST = ""
    ERROR.LIST.COUNT = 0
    ERROR.SUBROUTINE.COUNT = 0

* program warning table
    OBJECT.WARNING.DESC = ""
    OBJECT.WARNING.LINE = ""

    WARNING.SUBROUTINE.LIST = ""
    WARNING.METHOD.LIST = ""
    WARNING.SOURCE.LINE.LIST = ""
    WARNING.ECLIPSE.LINE.LIST = ""
    WARNING.DESC.LIST = ""
    WARNING.LIST.COUNT = 0
    WARNING.SUBROUTINE.COUNT = 0

* redimensioning code
    REDIM.CODE = ""
    REDIM.LINE.COUNT = 0

* flags
    FILTER.BLANK.LINES = @TRUE
    FILTER.BLANK.DEFAULT = @TRUE

* error counts
    TOTAL.COMPILE.ERRORS = 0
    TOTAL.COMPILE.WARNINGS = 0
    TOTAL.OBJECT.ERRORS = 0
    TOTAL.OBJECT.WARNINGS = 0

* program line xrefs
    PROGRAM.CODE.SOURCE.LIST = ""
    PROGRAM.CODE.FINAL.LIST = ""

* indent added to every converted program line
    PROGRAM.CODE.INDENT = ""

* table of included file / items
    CODE.INSERT.FILE.LIST = ""
    CODE.INSERT.ITEM.LIST = ""
    CODE.INSERT.COUNT = 0

* eclipse program files
    ECLIPSE.PROGRAM.FILES = "OC,CC,SP,BP,UBP,FBP,XBP,CBP"
    ECLIPSE.PROGRAM.FILES = CHANGE(ECLIPSE.PROGRAM.FILES, ",", @AM)

    ECLIPSE.OTHER.FILES = "SCREEN,MENUS,CMP,UD.FORMS,OE.VIEWS,OE.VIEW.ELEMENTS,PROMPTS,REPORT.FORMATS"
    ECLIPSE.OTHER.FILES = CHANGE(ECLIPSE.OTHER.FILES, ",", @AM)

    HIERARCHY.LIST = TRIM(ECLIPSE.OTHER.FILES:AM:ECLIPSE.PROGRAM.FILES:AM:"OBP":AM:"OBJ", AM)
    HIERARCHY.COUNT = DCOUNT(HIERARCHY.LIST,AM)

    PROGRAM.FILE.HIERARCHY.LIST = TRIM(ECLIPSE.PROGRAM.FILES:AM:"OBP":AM:"OBJ", AM)
    PROGRAM.FILE.HIERARCHY.COUNT = DCOUNT(PROGRAM.FILE.HIERARCHY.LIST, AM)

    ECLIPSE.PROGRAM.FILES = ECLIPSE.OTHER.FILES:AM:ECLIPSE.PROGRAM.FILES
    ECLIPSE.PROGRAM.FILE.COUNT = DCOUNT(ECLIPSE.PROGRAM.FILES,AM)

* table xref for (too) long variables names to shortened names
    LONG.VARIABLE.NAME.LIST = ""
    SHORT.VARIABLE.NAME.LIST = ""
    VARIABLE.NAME.COUNT = 0

* does debugging code exist in this program or object?
    DEBUG.CODE.EXISTS = @FALSE

* temporary associated variable name counter
    TEMPORARY.ASSOCIATED.COUNTER = 0

* associated variables table
    ASSOCIATED.NAME.LIST = ""
    ASSOCIATED.VARIABLE.LIST = ""
    ASSOCIATED.VARIABLE.COUNT.LIST = ""
    ASSOCIATED.OCONV.LIST = ""
    ASSOCIATED.LINE.LIST = ""
    ASSOCIATED.COUNT = 0

* label table
    LABEL.LIST = ""
    LABEL.LINE.LIST = ""
    LABEL.CALLED.LIST = ""
    LABEL.COUNT = 0

* function table
    FUNCTION.LIST = ""
    FUNCTION.LINE.LIST = ""
    FUNCTION.COUNT = 0

* brace conversions
    BRACE.START.STACK = ""
    BRACE.ELSE.STACK = ""
    BRACE.END.STACK = ""
    BRACE.DEPTH = 0

* optional parameter table for object-enabled subroutines
    OPTIONAL.PARAMETER.LIST = ""
    OPTIONAL.VALUE.LIST = ""
    OPTIONAL.COUNT = 0

* codes to use for "start execute" and "end execute" statements
    END.EXECUTE.START = "@START@"
    END.EXECUTE.END = "@END@"

* list of constants automatically added to each object
    DEFAULT.CONSTANT.LIST = ""
    DEFAULT.CONSTANT.VALUE.LIST = ""

    DEFAULT.CONSTANT.LIST<1> = "MAX.INSTANCES"
    DEFAULT.CONSTANT.VALUE.LIST<1> = "MAX.INSTANCES"

    DEFAULT.CONSTANT.LIST<2> = "AVAIL.INSTANCES"
    DEFAULT.CONSTANT.VALUE.LIST<2> = "MAX.INSTANCES - SUM(ACTIVE.OBJECT.HANDLE)"

    DEFAULT.CONSTANT.LIST<3> = "USED.INSTANCES"
    DEFAULT.CONSTANT.VALUE.LIST<3> = "SUM(ACTIVE.OBJECT.HANDLE)"

    DEFAULT.CONSTANT.COUNT = DCOUNT(DEFAULT.CONSTANT.LIST, AM)

* list of objects used for "USING" compiles
    COMPILE.USING = @FALSE
    OBJECT.USING.LIST = ""
    OBJECT.USING.COUNT = 0

* list of source lines from the object
    OBJECT.CODE.SOURCE.LIST = ""

* number of "error.throw" lines added when routine is converted
    ERROR.THROW.ADDED.COUNT = 0

* if run in "list objects only" mode, this is a list of objects that have
* had their used object list printed out already
    LISTED.OBJECTS.FOR.LIST = ""

    OBJECT.LINE.PTR = ""

    SHOW.EXPORTED.METHOD.NAME = @TRUE

* inline routines tables
    GOSUB CLEAR.INLINE.TABLE

* line counts for code blocks
    INSTANCE.LINE.COUNT = 0
    REDIM.LINE.COUNT = 0

* was the "ASSIGN" option used?
    ASSIGN.OPTION.USED = @FALSE
    PASS.ASSIGN.OPTION.USED = @FALSE

* macro variable counter
    MACRO.VARIABLE.COUNTER = 0

* for non-objects the "method" will always be "main".  initialize method
* to "main" as a default
    METHOD = "MAIN"
    METHOD.TYPE = ""

    INIT.END.DATE = DATE()
    INIT.END.TIME = TIME()
    INIT.ELAPSED.TIME += TIME.ELAPSED (INIT.START.DATE, INIT.START.TIME)

* dot net exporting
    EXTERNAL.OBJECT = @FALSE

* error text
    ERROR.TEXT = ""
    ERROR.TEXT.COUNT = 0

* dynamic reference checking
    DYNAM.CHECK.LINE = ""

* permissions setting
    PERMIT.ITEM = ""
    PERMIT.FILE = ""

* old versions of the source code
    ORIGINAL.SOURCE.CODE = ""
    ORIGINAL.POST.CLEANUP.OBJECT.CODE = ""

    RETURN


**************************************************************************
**************************************************************************
** initialization / command line settings                               **
**************************************************************************
**************************************************************************

LOAD.COMMAND.LINE: *******************************************************
* get command line options and object name(s)                            *
**************************************************************************
    UD.GETCOMMAND COMMAND.LINE, COMMAND.COUNT
    UD.GETOPTION COMMAND.OPTION

    SAVE.COMMAND.LINE = COMMAND.LINE
    SAVE.COMMAND.COUNT = COMMAND.COUNT
    SAVE.COMMAND.OPTION = COMMAND.OPTION

    INITIAL.COMMAND.LINE.LOAD = @TRUE
    GOSUB SET.COMMAND.LINE.OPTIONS

    GOSUB BUILD.COMPILE.LIST

    RETURN

RELOAD.COMMAND.LINE.OPTIONS: *********************************************
* set options based on the saved command line from load.command.line.    *
* this is for when we reset options for each method or object-enabled    *
* subroutine.  does not fetch the command line again but uses the saved  *
* command line settings from load.command.line                           *
**************************************************************************
    COMMAND.LINE = SAVE.COMMAND.LINE
    COMMAND.COUNT = SAVE.COMMAND.COUNT
    COMMAND.OPTION = SAVE.COMMAND.OPTION

    INITIAL.COMMAND.LINE.LOAD = @FALSE
    GOSUB SET.COMMAND.LINE.OPTIONS

    RETURN

SET.COMMAND.LINE.OPTIONS: ************************************************
* set options from the command line.  this may overwrite options from    *
* the ud.compile compile.setup record                                    *
**************************************************************************

* rset values if this is the initial command line read
    IF INITIAL.COMMAND.LINE.LOAD THEN
        GIVEN.OBJECT.FILENAME = ""
    END

* initialize other flags to defaults.  the command line may change
* these
    GOSUB INITIALIZE.MODE
    GOSUB GET.COMMAND.LINE.FILE.NAME

* look for the nopaging option
    KEY.WORD = "NOPAGE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        PAGING = @FALSE
    END

* look for the window option
    KEY.WORD = "WIN"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        SEND.TO.WINDOW = @TRUE
    END

    KEY.WORD = "NOWIN"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        SEND.TO.WINDOW = @FALSE
    END

* convert asterisk boxes to lines for pretty outputs
    KEY.WORD = "BOXES"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DRAW.BOXES = @TRUE
    END

    KEY.WORD = "NOBOXES"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DRAW.BOXES = @FALSE
    END

* look for command line display options
    KEY.WORD = "DETAILS"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DETAILS = @TRUE
    END

    KEY.WORD = "BRIEF"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        BRIEF = @TRUE
    END

    KEY.WORD = "HELP"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DISPLAY.OVERVIEW = @TRUE
        ALLOW.SPEECH = @FALSE
        RETURN
    END

* look for the "USING" option.  build a list of used objects if found.  
* later we'll recompile all programs in this file that use one or more of
* these objects
    KEY.WORD = "USING"
    GOSUB CHECK.COMMAND.KEYWORD.WITH.ONE
    IF KEY.WORD.FOUND THEN
        USING.OBJECTS = OPERAND
        OBJECT.USING.LIST = CHANGE(USING.OBJECTS, ",", @AM)
        OBJECT.USING.COUNT = DCOUNT(OBJECT.USING.LIST, @AM)
        IF OBJECT.USING.COUNT > 0 THEN
            COMPILE.USING = @TRUE
        END

    END

* look for compile option.  this lets us compile, overriding the control
* record settings
    KEY.WORD = "COMPILE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DO.COMPILE = @TRUE
    END

    KEY.WORD = "NOCOMPILE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DO.COMPILE = @FALSE
    END

    KEY.WORD = "BUILD"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DO.COMPILE = @FALSE
    END

    KEY.WORD = "DELETE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.DELETE.MODE
    END

    KEY.WORD = "NOSAVE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.NOSAVE.MODE
    END

* "source" option to add the source code into the converted code as comments
    KEY.WORD = "SOURCE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ADD.SOURCE.COMMENTS = @TRUE
    END

* "break" option to break all compound lines up into single lines.  this can
* be slow but it's handy for debugging
    KEY.WORD = "BREAK"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        REFORMAT.COMPOUND.LINES = @TRUE
    END

* "view" option to display the converted code in a view-only editor window
    KEY.WORD = "VIEW"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        VIEW.CONVERTED.CODE = @TRUE
    END

* "look" option.  the same as view + source + break + nosave
    KEY.WORD = "LOOK"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.LOOK.MODE
    END

* wait keyword, to pause after each compile
    KEY.WORD = "WAIT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        WAIT.AFTER.COMPILE = @TRUE
    END

* wait after errors keyword.  pause if there's an error in the compile
    KEY.WORD = "WAITERROR"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.WAITERROR.MODE
    END

* don't wait for anything
    KEY.WORD = "NOWAIT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.NOWAIT.MODE
    END

* if listing methods show the dotnet methods / variable names?
    KEY.WORD = "DOT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        LIST.DOT = @TRUE
    END

* look for the list options.  do this last since the key string may or may
* not be there
    KEY.WORD = "LIST"
    GOSUB CHECK.COMMAND.KEYWORD.WITH.ONE
    IF KEY.WORD.FOUND THEN
        LIST.KEY.STRING = OPERAND
        LIST.METHODS = @TRUE
        ALLOW.SPEECH = @FALSE
    END

    KEY.WORD = "SHORT"
    GOSUB CHECK.COMMAND.KEYWORD.WITH.ONE
    IF KEY.WORD.FOUND THEN
        LIST.KEY.STRING = OPERAND
        SHORT.LIST = @TRUE
        LIST.METHODS = @TRUE
        ALLOW.SPEECH = @FALSE
        BANNER.NAMES = @FALSE
    END

* if the "list" string is "*" (for all) set it to null that the compiler will
* interpret as "all"
    IF LIST.KEY.STRING = "*" THEN
        LIST.KEY.STRING = ""
    END

* always recompile methods, even if they haven't changed?
    KEY.WORD = "ALWAYS"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ALWAYS.RECOMPILE.METHODS = @TRUE
    END

    KEY.WORD = "SNAPE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ALWAYS.RECOMPILE.METHODS = @TRUE
    END

* display compile times?
    KEY.WORD = "CTIME"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DISPLAY.COMPILE.TIMES = @TRUE
    END

* list shortcuts?  if we are check for a maximum load level (a number 1-3, 
* or "ALL", or "QUICK", or "ASK") following the keyword  
    LOCATE "SHORTCUTS" IN COMMAND.LINE SETTING SHORTCUT.PTR THEN

        DEL COMMAND.LINE<SHORTCUT.PTR>
        CHECK.LOAD.LEVEL = COMMAND.LINE<SHORTCUT.PTR>

        BEGIN CASE

            CASE NUM(CHECK.LOAD.LEVEL) AND CHECK.LOAD.LEVEL <> ""
                MAX.LOAD.LEVEL = CHECK.LOAD.LEVEL
                DEL COMMAND.LINE<SHORTCUT.PTR>

            CASE UPCASE(CHECK.LOAD.LEVEL) = "ALL"
                MAX.LOAD.LEVEL = 3
                DEL COMMAND.LINE<SHORTCUT.PTR>

            CASE UPCASE(CHECK.LOAD.LEVEL) = "QUICK"
                MAX.LOAD.LEVEL = 1
                DEL COMMAND.LINE<SHORTCUT.PTR>

            CASE UPCASE(CHECK.LOAD.LEVEL) = "ASK"
                GOSUB GET.LOAD.TYPE
                MAX.LOAD.LEVEL = 3

            CASE 1
                MAX.LOAD.LEVEL = 2

        END CASE

        SHORTCUT.LIST = @TRUE
        ALLOW.SPEECH = @FALSE

    END

* when listing shortcuts should the shortcuts be listed in an xml format
* suitable for NOTEPAD++'s auto complete?
    KEY.WORD = "AUTOCOMPLETE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        AUTOCOMPLETE.LIST = @TRUE
    END

* list object used without compiling / saving?
    KEY.WORD = "OBJECTS"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.LIST.OBJECTS.MODE
    END

* warn if there are any "eclipse-style" method calls.  these are calls where
* the method (or subroutine) has returned parameters but the call has no
* parameters left of the equals sign but does have parameters to the right
* suppress speech
    KEY.WORD = "WARNECLIPSE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        WARN.ECLIPSE.CALLS = @TRUE
    END

* do not allow eclipse-style calls, where all parameters are on the right
* of the equals sign and there are output (returned) parameters
    KEY.WORD = "NOECLIPSE"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        NO.ECLIPSE.CALLS = @TRUE
    END

* suppress checking for user abort during compile
    KEY.WORD = "NOABORT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        CHECK.USER.ABORT = @FALSE
    END

* skip adding these objects / programs to the "last compiled" list?
    KEY.WORD = "NOADD"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ADD.TO.LAST.LIST = @FALSE
    END

* from filename objectname, override the "Created from" filename and object
* name in the cbp comments telling where the original code came from
    KEY.WORD = "FROM"
    GOSUB CHECK.COMMAND.KEYWORD.WITH.TWO
    IF KEY.WORD.FOUND THEN
        BUILT.FROM.FILE = OPERAND1
        BUILT.FROM.OBJECT = OPERAND2
    END

* do .net exports?
    KEY.WORD = "NODOT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DO.DOT.NET.EXPORTS = @FALSE
    END

* only do .net exports?  ie, don't recompile uniVerse routines?
    KEY.WORD = "ONLYDOT"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ONLY.DOT.NET.EXPORTS = @TRUE
    END

* do java exports?
    KEY.WORD = "NOJAVA"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        DO.JAVA.EXPORTS = @FALSE
    END

* only do java exports?  ie, don't recompile uniVerse routines?
    KEY.WORD = "ONLYJAVA"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ONLY.JAVA.EXPORTS = @TRUE
    END

* no api exports of any kind?
    KEY.WORD = "NOAPI"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.NO.API.MODE
    END

* do only the api exports, don't recompile uniVerse routines?
    KEY.WORD = "ONLYAPI"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.ONLY.API.MODE
    END

* don't allow speech
    KEY.WORD = "NOSPEECH"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ALLOW.SPEECH = @FALSE
    END

* force reloading shortcuts and macros?
    KEY.WORD = "RELOAD"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        FORCE.SHORTCUT.RELOAD = @TRUE
    END

* the "repair" option is the same as "NOSPEECH NOABORT ALWAYS WAITERROR"
* it shuts off any possible object calls from the object compiler
    KEY.WORD = "REPAIR"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.REPAIR.MODE
    END

* open an option menu or not
    KEY.WORD = "OPTS"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ASK.FOR.OPTIONS = @TRUE
    END

    KEY.WORD = "NOPTS"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        ASK.FOR.OPTIONS = @FALSE
        ASK.FOR.OBJ.OPTIONS = @FALSE
        ASK.FOR.OBP.OPTIONS = @FALSE
    END

* the "check option is the same as "NOSAVE WAITERROR ALWAYS NOPTS NOWIN"
* and is used to check for object errors without saving / compiling
* cbp code
    KEY.WORD = "CHECK"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.CHECK.MODE
    END

* parallel compiling mode
    KEY.WORD = "PARALLEL"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        PARALLEL.MODE = @TRUE
    END

* if we're listing object only, are in repair mode, are listing methods,
* or are producing an auto-complete list then don't prompt for objects
    IF LIST.OBJECTS.ONLY OR REPAIR.MODE OR LIST.METHODS OR AUTOCOMPLETE.LIST THEN
        ASK.FOR.OPTIONS = @FALSE
        ASK.FOR.OBJ.OPTIONS = @FALSE
        ASK.FOR.OBP.OPTIONS = @FALSE
    END

* if we're running in an execute set flags to shut off all i/o
    KEY.WORD = "INEXEC"
    GOSUB CHECK.COMMAND.KEYWORD
    IF KEY.WORD.FOUND THEN
        GOSUB SET.INEXEC.MODE

    END

    RETURN

INITIALIZE.MODE: *********************************************************
* set all compilation flags to default settings                          *
**************************************************************************
    DETAILS = @FALSE

    LIST.METHODS = @FALSE
    SHORT.LIST = @FALSE
    LIST.KEY.STRING = ""
    SHORTCUT.LIST = @FALSE
    AUTOCOMPLETE.LIST = @FALSE
    LIST.DOT = @FALSE

    SEND.TO.WINDOW = @FALSE

    PAGING = @TRUE

    LIST.OBJECTS.ONLY = @FALSE
    LOAD.MACROS = @TRUE
    LOAD.SHORTCUTS = @TRUE
    CONVERT.ROUTINES = @TRUE

    DISPLAY.OVERVIEW = @FALSE

    WARN.ECLIPSE.CALLS = @FALSE
    NO.ECLIPSE.CALLS = @FALSE

    ALLOW.SPEECH = @TRUE
    CHECK.USER.ABORT = @TRUE

    ADD.TO.LAST.LIST = @TRUE

    REPAIR.MODE = @FALSE
    CHECK.MODE = @FALSE
    PARALLEL.MODE = @FALSE
    INEXEC.MODE = @FALSE

    WAITERROR.MODE = @FALSE
    NOWAIT.MODE = @FALSE
    NOSAVE.MODE = @FALSE

    LOOK.MODE = @FALSE
    DELETE.MODE = @FALSE

    NO.API.MODE = @FALSE
    ONLY.API.MODE = @FALSE

    FORCE.SHORTCUT.RELOAD = @FALSE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE

    DO.DOT.NET.EXPORTS = @TRUE
    ONLY.DOT.NET.EXPORTS = @FALSE

    DO.JAVA.EXPORTS = @TRUE
    ONLY.JAVA.EXPORTS = @FALSE

    WAIT.AFTER.COMPILE = @FALSE

    COMPILE.ECLIPSE = @FALSE

* overrides for the "Created from" file and object that goes in the comments
* of the cbp version telling where the source code for the cbp came from
    BUILT.FROM.FILE = ""
    BUILT.FROM.OBJECT = ""

    RETURN

GET.COMMAND.LINE.FILE.NAME: **********************************************
* get the filename from the command line                                 *
**************************************************************************

* "WIN" may be the first keyword in some odd cases.  if it is set the
* window flag and remove it so we'll find the program file correctly
* also, if AlwaysWinCompileErrors is set in the control record set to
* send errors to a view-only editor window
    IF COMMAND.LINE<1> = "WIN" THEN
        SEND.TO.WINDOW = @TRUE
        DEL COMMAND.LINE<1>
    END

    IF ALWAYS.WIN.COMPILE.ERRORS THEN
        SEND.TO.WINDOW = @TRUE
    END

    IF COMMAND.LINE<1> = "NOWIN" THEN
        SEND.TO.WINDOW = @FALSE
        DEL COMMAND.LINE<1>
    END

* is a filename defined that's an eclipse program file?  if so we just
* want to pass it through.  this could be more than just programs.  it
* could also be screens, menus, cmps, and others
    ECLIPSE.FILE = ""
    LOCATE COMMAND.LINE<1> IN ECLIPSE.PROGRAM.FILES SETTING ECLIPSE.PTR THEN
        COMPILE.ECLIPSE = @TRUE
        ECLIPSE.FILE = COMMAND.LINE<1>
    END

* get filename from the command line, if given
    TEST.FILENAME = COMMAND.LINE<1>
    LOCATE TEST.FILENAME IN HIERARCHY.LIST SETTING TEST.FILE.PTR THEN

        GIVEN.OBJECT.FILENAME = TEST.FILENAME
        DEL COMMAND.LINE<1>

    END ELSE

* it may not be in the hierarchy but it may still be another eclipse
* file (screens, menus, etc).  if so we still need to remove the file
* from the command line
        LOCATE TEST.FILENAME IN ECLIPSE.PROGRAM.FILES SETTING ECLIPSE.PTR THEN
            GIVEN.OBJECT.FILENAME = TEST.FILENAME
            DEL COMMAND.LINE<1>
        END

    END

    RETURN

SET.NOSAVE.MODE: *********************************************************
* set the "no save" mode where cbps are not saved or compiled            *
**************************************************************************
    NOSAVE.MODE = @TRUE

    SAVE.CBPS = @FALSE
    DO.COMPILE = @FALSE

    RETURN

RESET.NOSAVE.MODE: *******************************************************
* reset the "no save" mode where cbps are not saved or compiled          *
**************************************************************************
    NOSAVE.MODE = @FALSE

    SAVE.CBPS = @TRUE
    DO.COMPILE = @TRUE

    RETURN

SET.WAITERROR.MODE: ******************************************************
* set "waiterror" mode, where the compiler will wait after each error    *
* or warning encountered                                                 *
**************************************************************************
    WAITERROR.MODE = @TRUE

    WAIT.AFTER.ERROR = @TRUE
    WAIT.AFTER.WARNING = @TRUE

    RETURN

RESET.WAITERROR.MODE: ****************************************************
* reset "waiterror" mode, where the compiler will wait after each error  *
* or warning encountered                                                 *
**************************************************************************
    WAITERROR.MODE = @FALSE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE

    RETURN

SET.NOWAIT.MODE: *********************************************************
* set "nowait" mode, where the compiler will not pause for errors,       *
* warnings, or anything else during the compile                          *
**************************************************************************
    NOWAIT.MODE = @TRUE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE
    SKIP.WAITS = @TRUE

    RETURN

RESET.NOWAIT.MODE: *******************************************************
* reset "nowait" mode, where the compiler will not pause for errors,     *
* warnings, or anything else during the compile                          *
**************************************************************************
    NOWAIT.MODE = @FALSE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE
    SKIP.WAITS = @FALSE

    RETURN

SET.LOOK.MODE: ***********************************************************
* set the "look" mode, where the compiled code will be displayed with    *
* the original object code as comments                                   *
**************************************************************************
    LOOK.MODE = @TRUE

    VIEW.CONVERTED.CODE = @TRUE
    ADD.SOURCE.COMMENTS = @TRUE
    REFORMAT.COMPOUND.LINES = @TRUE

    SAVE.CBPS = @FALSE
    DO.COMPILE = @FALSE

    RETURN

RESET.LOOK.MODE: *********************************************************
* set the "look" mode, where the compiled code will be displayed with    *
* the original object code as comments                                   *
**************************************************************************
    LOOK.MODE = @FALSE

    VIEW.CONVERTED.CODE = @FALSE
    ADD.SOURCE.COMMENTS = @FALSE
    REFORMAT.COMPOUND.LINES = @FALSE

    SAVE.CBPS = @TRUE
    DO.COMPILE = @TRUE

    RETURN

SET.DELETE.MODE: *********************************************************
* set the "delete" mode, where all cbp / oc records are removed before   *
* the compile                                                            *
**************************************************************************
    DELETE.MODE = @TRUE
    
    DELETE.CBP = @TRUE
    DELETE.OC = @TRUE
    DECATALOG.CBP = @TRUE

    RETURN

RESET.DELETE.MODE: *******************************************************
* reset the "delete" mode, where all cbp / oc records are removed before *
* the compile                                                            *
**************************************************************************
    DELETE.MODE = @FALSE
    
    DELETE.CBP = @FALSE
    DELETE.OC = @FALSE
    DECATALOG.CBP = @FALSE

    RETURN

SET.LIST.OBJECTS.MODE: ***************************************************
* set "objects" mode, where data for the object is to be listed but      *
* no compilation is to take place.  this is used as a sort of export     *
* for other routines that need data about the object                     *
**************************************************************************
    LIST.OBJECTS.ONLY = @TRUE

    ALLOW.SPEECH = @FALSE

    LOAD.MACROS = @FALSE
    LOAD.SHORTCUTS = @FALSE

    CONVERT.ROUTINES = @FALSE

    CHECK.USER.ABORT = @FALSE

    NO.API.MODE = @TRUE

    DO.DOT.NET.EXPORTS = @FALSE
    DO.JAVA.EXPORTS = @FALSE

    RETURN

SET.NO.API.MODE: *********************************************************
* set "no api" mode, where no api routines will be exported              *
**************************************************************************
    NO.API.MODE = @TRUE

    DO.DOT.NET.EXPORTS = @FALSE
    DO.JAVA.EXPORTS = @FALSE

    RETURN

RESET.NO.API.MODE: *******************************************************
* reset "no api" mode, where no api routines will be exported            *
**************************************************************************
    NO.API.MODE = @FALSE

    DO.DOT.NET.EXPORTS = @TRUE
    DO.JAVA.EXPORTS = @TRUE

    RETURN

SET.ONLY.API.MODE: *******************************************************
* set "only api" mode, where we only want to export the api routines     *
* for dotnet and java                                                    *
**************************************************************************
    ONLY.API.MODE = @TRUE

    ONLY.DOT.NET.EXPORTS = @TRUE
    ONLY.JAVA.EXPORTS = @TRUE

    RETURN

RESET.ONLY.API.MODE: *****************************************************
* reset "only api" mode, where we only want to export the api routines   *
* for dotnet and java                                                    *
**************************************************************************
    ONLY.API.MODE = @FALSE

    ONLY.DOT.NET.EXPORTS = @FALSE
    ONLY.JAVA.EXPORTS = @FALSE

    RETURN

SET.REPAIR.MODE: *********************************************************
* set flags for "repair" mode, where the compiler runs with minimal      *
* support from other subroutines                                         *
**************************************************************************
    REPAIR.MODE = @TRUE

    ALLOW.SPEECH = @FALSE
    CHECK.USER.ABORT = @FALSE

    ALWAYS.RECOMPILE.METHODS = @TRUE

    DO.DOT.NET.EXPORTS = @FALSE
    DO.JAVA.EXPORTS = @FALSE

    FORCE.SHORTCUT.RELOAD = @TRUE

    SEND.TO.WINDOW = @FALSE

    RETURN

RESET.REPAIR.MODE: *******************************************************
* reset flags for "repair" mode, where the compiler runs with minimal    *
* support from other subroutines                                         *
**************************************************************************
    REPAIR.MODE = @FALSE

    ALLOW.SPEECH = @TRUE
    CHECK.USER.ABORT = @TRUE

    ALWAYS.RECOMPILE.METHODS = @FALSE

    DO.DOT.NET.EXPORTS = @TRUE
    DO.JAVA.EXPORTS = @TRUE

    FORCE.SHORTCUT.RELOAD = @FALSE

    IF ALWAYS.WIN.COMPILE.ERRORS THEN
        SEND.TO.WINDOW = @TRUE
    END ELSE
        SEND.TO.WINDOW = @FALSE
    END

    RETURN

SET.CHECK.MODE: **********************************************************
* set flags for "check" mode, where the object / subroutine code is      *
* checked for object errors but the cbp is not produced or compiled      *
**************************************************************************
    CHECK.MODE = @TRUE

    SAVE.CBPS = @FALSE
    DO.COMPILE = @FALSE

    WAIT.AFTER.ERROR = @TRUE
    WAIT.AFTER.WARNING = @TRUE

    ALWAYS.RECOMPILE.METHODS = @TRUE

    DO.DOT.NET.EXPORTS = @FALSE
    DO.JAVA.EXPORTS = @FALSE

    ASK.FOR.OPTIONS = @FALSE
    ASK.FOR.OBJ.OPTIONS = @FALSE
    ASK.FOR.OBP.OPTIONS = @FALSE

    SEND.TO.WINDOW = @FALSE

    RETURN

RESET.CHECK.MODE: ********************************************************
* reset flags for "check" mode, where the object / subroutine code is    *
* checked for object errors but the cbp is not produced or compiled      *
**************************************************************************
    CHECK.MODE = @FALSE

    SAVE.CBPS = @TRUE
    DO.COMPILE = @TRUE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE

    ALWAYS.RECOMPILE.METHODS = @FALSE

    DO.DOT.NET.EXPORTS = @TRUE
    DO.JAVA.EXPORTS = @TRUE

    ASK.FOR.OPTIONS = @TRUE
    ASK.FOR.OBJ.OPTIONS = @TRUE
    ASK.FOR.OBP.OPTIONS = @TRUE

    IF ALWAYS.WIN.COMPILE.ERRORS THEN
        SEND.TO.WINDOW = @TRUE
    END ELSE
        SEND.TO.WINDOW = @FALSE
    END

    RETURN

SET.INEXEC.MODE: *********************************************************
* set flags for "inexec" mode, for when the compiler is run from an      *
* execute statement                                                      *
**************************************************************************
    INEXEC.MODE = @TRUE

    WAIT.AFTER.ERROR = @FALSE
    WAIT.AFTER.WARNING = @FALSE
    SKIP.WAITS = @TRUE

    ALLOW.SPEECH = @FALSE
    CHECK.USER.ABORT = @FALSE

    DO.DOT.NET.EXPORTS = @FALSE
    DO.JAVA.EXPORTS = @FALSE

    ASK.FOR.OPTIONS = @FALSE
    ASK.FOR.OBJ.OPTIONS = @FALSE
    ASK.FOR.OBP.OPTIONS = @FALSE

    SEND.TO.WINDOW = @FALSE

    RETURN

CHECK.COMMAND.KEYWORD: ***************************************************
* remove all instances of a keyword from the command line.  returns      *
* key.word.found true if the keyword was found                           *
**************************************************************************
    KEY.WORD.FOUND = @FALSE

    LOOP

        LOCATE KEY.WORD IN COMMAND.LINE SETTING DELETE.PTR THEN
            ALL.DELETED = @FALSE
            KEY.WORD.FOUND = @TRUE
            DEL COMMAND.LINE<DELETE.PTR>
        END ELSE
            ALL.DELETED = @TRUE
        END

    UNTIL ALL.DELETED 
    REPEAT

    RETURN

CHECK.COMMAND.KEYWORD.WITH.ONE: ******************************************
* remove all instances of a keyword with an operand from the command     *
* line.  returns key.word.found true if the keyword was found and        *
* operand with the operand value                                         *
**************************************************************************
    KEY.WORD.FOUND = @FALSE
    OPERAND = ""

    LOOP

        LOCATE KEY.WORD IN COMMAND.LINE SETTING DELETE.PTR THEN
            OPERAND = COMMAND.LINE<DELETE.PTR + 1>
            ALL.DELETED = @FALSE
            KEY.WORD.FOUND = @TRUE
            DEL COMMAND.LINE<DELETE.PTR>
            DEL COMMAND.LINE<DELETE.PTR>
        END ELSE
            ALL.DELETED = @TRUE
        END

    UNTIL ALL.DELETED 
    REPEAT

    RETURN

CHECK.COMMAND.KEYWORD.WITH.TWO: ******************************************
* remove all instances of a keyword with two operands from the command   *
* line.  returns key.word.found true if the keyword was found and        *
* operand1 and operand2 with the operand values                          *
**************************************************************************
    KEY.WORD.FOUND = @FALSE
    OPERAND1 = ""
    OPERAND2 = ""

    LOOP

        LOCATE KEY.WORD IN COMMAND.LINE SETTING DELETE.PTR THEN
            OPERAND1 = COMMAND.LINE<DELETE.PTR + 1>
            OPERAND2 = COMMAND.LINE<DELETE.PTR + 2>
            ALL.DELETED = @FALSE
            KEY.WORD.FOUND = @TRUE
            DEL COMMAND.LINE<DELETE.PTR>
            DEL COMMAND.LINE<DELETE.PTR>
            DEL COMMAND.LINE<DELETE.PTR>
        END ELSE
            ALL.DELETED = @TRUE
        END

    UNTIL ALL.DELETED 
    REPEAT

    RETURN

BUILD.COMPILE.LIST: ******************************************************
* build a list of objects / subroutines to compile                       *
**************************************************************************
    OBJECT.LIST = ""
    OBJECT.COUNT = 0

    BEGIN CASE

* filename is "*" for we're only doing dotnet exports.  build a list of all
* objects
        CASE COMMAND.LINE<1> = "*" AND ONLY.DOT.NET.EXPORTS

            GIVEN.OBJECT.FILENAME = "OBJ"
            GOSUB SELECT.ENTIRE.FILE

* filename is "*" but we're listing methods.  put up a list of all
* objects
        CASE (COMMAND.LINE<1> = "*" OR COMMAND.LINE<1> = "") AND LIST.METHODS

            GIVEN.OBJECT.FILENAME = "OBJ"
            GOSUB SELECT.ENTIRE.FILE

            IF SHORT.LIST THEN
                TITLE = "List Methods--Summary"
            END ELSE
                TITLE = "List Methods--Detailed"
            END

            CHOICE = UD.GET.CHOICE(DOWNCASE(OBJECT.LIST), "", TITLE, "", "", "", "", "", "", "", "*")

            IF CHOICE = 0 OR F12 THEN
                ABORT.PROGRAM = @TRUE
            END ELSE
                OBJECT.LIST = OBJECT.LIST<CHOICE>
                OBJECT.COUNT = 1
            END

* there's an active select list and we're only doing dotnet exports.  build
* a list of objects to compile from the active list
        CASE SYSTEM(11) AND ONLY.DOT.NET.EXPORTS

            GIVEN.OBJECT.FILENAME = "OBJ"
            GOSUB SELECT.OUTSIDE.SELECT

* filename is "*".  get a program name from the list of last edited
* programs
        CASE COMMAND.LINE<1> = "*" AND GIVEN.OBJECT.FILENAME = ""

            GOSUB CHOOSE.PROGRAM.FROM.MENU

            IF PROGRAM.NAME <> "" THEN
                GIVEN.OBJECT.FILENAME = PROGRAM.FILE
                OBJECT.LIST = PROGRAM.NAME
                OBJECT.COUNT = 1
            END ELSE
                ABORT.PROGRAM = @TRUE
            END

* compile all objects / programs in a file
        CASE COMMAND.LINE<1> = "*"

            GOSUB SELECT.ENTIRE.FILE

* compile one method for all programs in a file
        CASE COMMAND.LINE<1> [1, METHOD.DEL.LENGTH + 1] = "*":METHOD.DELIMITER

            METHOD.PTR = INDEX(COMMAND.LINE<1>, METHOD.DELIMITER, 1) + METHOD.DEL.LENGTH
            SELECT.METHOD = COMMAND.LINE<1> [METHOD.PTR, TO.THE.END]

            GOSUB SELECT.ENTIRE.FILE.FOR.METHOD

* compile all objects in the file using one or more objects
        CASE COMPILE.USING

            GOSUB SELECT.USING.FILE

* anything else, pull object list in from the command line
        CASE 1

            COMMAND.COUNT = DCOUNT(COMMAND.LINE, @AM)

            FOR PTR = 1 TO COMMAND.COUNT

                IF COMMAND.LINE<PTR> <> "" THEN
                    OBJECT.COUNT += 1
                    OBJECT.LIST<OBJECT.COUNT> = COMMAND.LINE<PTR>
                END

            NEXT PTR

    END CASE

* if we have an active select list and no objects on the command line
* work from the active list
    IF SYSTEM(11) AND OBJECT.COUNT = 0 THEN
        GOSUB SELECT.OUTSIDE.SELECT
    END

    RETURN


**************************************************************************
**************************************************************************
** initialization / misc                                                **
**************************************************************************
**************************************************************************

GET.LOAD.TYPE: ***********************************************************
* put up a selection screen to get the type of shortcuts / macros to     *
* load                                                                   *
**************************************************************************
    GOSUB INITIALIZE.LISTING

* build a list of shortcut and macro types
    TYPE.LIST = ""
    TYPE.COUNT = 0

* add an "ALL" option at the top
    TYPE.LIST = "All"   
    TYPE.COUNT = 1

* add shortcut sections to the tables after the first "ALL" entry
    FOR SHORTCUT.LOOP = 1 TO SHORTCUT.COUNT

        THIS.SHORTCUT = SHORTCUT.KEYWORD.LIST<SHORTCUT.LOOP>
        THIS.SECTION = SHORTCUT.SECTION.LIST<SHORTCUT.LOOP>

        IF THIS.SECTION <> "" THEN

            LOCATE THIS.SECTION IN TYPE.LIST, 2 BY "AL" SETTING SECTION.PTR ELSE
                INS THIS.SECTION BEFORE TYPE.LIST<SECTION.PTR>
                TYPE.COUNT += 1
            END

        END

    NEXT SHORTCUT.LOOP
    
* add in macro sections to the tables, also after the first "ALL" entry
    FOR MACRO.LOOP = 1 TO MACRO.COUNT

        THIS.MACRO = MACRO.KEYWORD.LIST<MACRO.LOOP>
        THIS.SECTION = MACRO.SECTION.LIST<MACRO.LOOP>

        IF THIS.SECTION <> "" THEN

            LOCATE THIS.SECTION IN TYPE.LIST, 2 BY "AL" SETTING SECTION.PTR ELSE
                INS THIS.SECTION BEFORE TYPE.LIST<SECTION.PTR>
                TYPE.COUNT += 1
            END

        END

    NEXT MACRO.LOOP

* reformat for sections that have a major / minor section.  the major
* section is left of a slash and the minor is to the right, ie, "major/minor".
* for each major section we'll add another line for the entire section
    TYPE.PROMPT.LIST = ""
    LAST.MAJOR.TYPE = "****"

    FOR TYPE.LOOP = 1 TO TYPE.COUNT

        THIS.TYPE = TYPE.LIST<TYPE.LOOP>

        IF COUNT(THIS.TYPE, "/") = 0 THEN

            TYPE.PROMPT.LIST<TYPE.LOOP> = THIS.TYPE
            LAST.MAJOR.TYPE = ""

        END ELSE

            MAJOR.TYPE = TRIM(THIS.TYPE ["/", 1, 1])
            MINOR.TYPE = TRIM(THIS.TYPE ["/", 2, 100])

            IF MAJOR.TYPE = LAST.MAJOR.TYPE THEN
                MAJOR.TYPE = SPACE(LEN(MAJOR.TYPE))
            END ELSE
                INS MAJOR.TYPE BEFORE TYPE.LIST<TYPE.LOOP>
                TYPE.PROMPT.LIST<TYPE.LOOP> = MAJOR.TYPE
                TYPE.LOOP += 1
                TYPE.COUNT += 1
                LAST.MAJOR.TYPE = MAJOR.TYPE
            END

            TYPE.PROMPT.LIST<TYPE.LOOP> = MAJOR.TYPE:" / ":MINOR.TYPE

        END

    NEXT TYPE.LOOP

* put up a menu of shortcut / macro types
    TYPE.CHOICE = UD.GET.CHOICE(TYPE.PROMPT.LIST, "", "Shortcut/Macro Types", "", "", "", "", "", "", "", "*")

    BEGIN CASE

* the first choice will always be for "all" types.  for "all" types leave
* the shortcut load type null
        CASE TYPE.CHOICE = 1
            SHORTCUT.LOAD.TYPE = ""

* another shortcut type was selected
        CASE TYPE.CHOICE <> 0
            SHORTCUT.LOAD.TYPE = TYPE.LIST<TYPE.CHOICE>

* anything else, abort
        CASE 1
            ABORT.PROGRAM = @TRUE

    END CASE

    RETURN

SELECT.ENTIRE.FILE: ******************************************************
* select an entire programming file for processing and build a list in   *
* object.list                                                            *
**************************************************************************
    IF GIVEN.OBJECT.FILENAME = "" THEN
        PRINT
        PRINT "No filename"
        RETURN
    END

* build the select statement for this file.  if this is the obj file and
* method edits are allowed don't select any of the temporary method
* records
    STATEMENT = "SSELECT ":GIVEN.OBJECT.FILENAME

    IF GIVEN.OBJECT.FILENAME = "OBJ" AND ALLOW.METHOD.EDITS THEN
        STATEMENT:= ' WITH @ID <> "':METHOD.EDIT.PREFIX:']"'
    END

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST
    ITEM.COUNT = TEXT<2> [" ", 1, 1]

    IF NOT(LIST.METHODS) THEN
        PRINT
        PRINT "Compiling ":ITEM.COUNT "L,":" items from ":GIVEN.OBJECT.FILENAME
    END

    LOOP WHILE READNEXT OBJECT.NAME FROM SLIST DO
        OBJECT.COUNT += 1
        OBJECT.LIST<OBJECT.COUNT> = OBJECT.NAME
    REPEAT

    GOSUB CHECK.OBJECT.COUNT

    RETURN

SELECT.ENTIRE.FILE.FOR.METHOD: *******************************************
* select an entire programming file for processing and build a list in   *
* object.list of the selected object names but only for select.method    *
**************************************************************************
    IF GIVEN.OBJECT.FILENAME = "" THEN
        GIVEN.OBJECT.FILENAME = "OBJ"
    END

* build the select statement for this file.  if this is the obj file and
* method edits are allowed don't select any of the temporary method
* records
    STATEMENT = "SSELECT ":GIVEN.OBJECT.FILENAME

    IF GIVEN.OBJECT.FILENAME = "OBJ" AND ALLOW.METHOD.EDITS THEN
        STATEMENT:= ' WITH @ID <> "':METHOD.EDIT.PREFIX:']"'
    END

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST
    ITEM.COUNT = TEXT<2> [" ", 1, 1]

    PRINT
    PRINT "Compiling ":ITEM.COUNT "L,":" items from ":GIVEN.OBJECT.FILENAME

    LOOP WHILE READNEXT OBJECT.NAME FROM SLIST DO
        OBJECT.COUNT += 1
        OBJECT.LIST<OBJECT.COUNT> = OBJECT.NAME:"::":SELECT.METHOD
    REPEAT

    GOSUB CHECK.OBJECT.COUNT

    RETURN

SELECT.OUTSIDE.SELECT: ***************************************************
* take items from an outside select and save them in object.list         *
**************************************************************************
    SELECTE TO SLIST

    LOOP WHILE READNEXT OBJECT.NAME FROM SLIST DO
        OBJECT.COUNT += 1
        OBJECT.LIST<OBJECT.COUNT> = OBJECT.NAME
    REPEAT

    GOSUB CHECK.OBJECT.COUNT

    RETURN

SELECT.USING.FILE: *******************************************************
* select a programming file for all programs using any of the objects    *
* in object.using.list and build a list in object.list                   *
**************************************************************************

* first make sure that all the object names are valid
    ALL.OBJECTS.VALID = @TRUE

    FOR USING.LOOP = 1 TO OBJECT.USING.COUNT

        CHECK.OBJECT = OBJECT.USING.LIST<USING.LOOP>

        READV TEST.READ FROM OBJFILE, CHECK.OBJECT, 0 ELSE

            IF ALL.OBJECTS.VALID THEN
                PRINT
            END

            PRINT CHECK.OBJECT:" is not a valid Object"
            ALL.OBJECTS.VALID = @FALSE

        END

    NEXT USING.LOOP

    IF NOT(ALL.OBJECTS.VALID) THEN
        OBJECT.COUNT = 0
        GOSUB CHECK.OBJECT.COUNT
    END

* select programs using those objects
    PRINT
    PRINT "Selecting ":GIVEN.OBJECT.FILENAME:" for items using these objects:"

    FOR USING.LOOP = 1 TO OBJECT.USING.COUNT

        USE.OBJECT = OBJECT.USING.LIST<USING.LOOP>

        IF UPCASE.CODE THEN
            USE.OBJECT = DOWNCASE(USE.OBJECT)
        END

        PRINT "    ":USE.OBJECT

    NEXT USING.LOOP

* build select statement, selecting for programs using one or more
* of the objects in object.using.list.  we'll make the selection based
* on the object.using.list case insensitive
    STATEMENT = "SSELECT ":GIVEN.OBJECT.FILENAME:" WITH OBJECT.USED ="

    FOR USING.LOOP = 1 TO OBJECT.USING.COUNT
        THIS.USED.OBJECT = OBJECT.USING.LIST<USING.LOOP>
        STATEMENT := ' "':THIS.USED.OBJECT:'"'
        STATEMENT := ' "':DOWNCASE(THIS.USED.OBJECT):'"'
        STATEMENT := ' "':UPCASE(THIS.USED.OBJECT):'"'
    NEXT USING.LOOP

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST
    ITEM.COUNT = TEXT<2> [" ", 1, 1]

* build the compilation list from the selected programs
    PRINT
    PRINT "Compiling ":ITEM.COUNT "L,":" items from ":GIVEN.OBJECT.FILENAME

    LOOP WHILE READNEXT OBJECT.NAME FROM SLIST DO
        OBJECT.COUNT += 1
        OBJECT.LIST<OBJECT.COUNT> = OBJECT.NAME
    REPEAT

    GOSUB CHECK.OBJECT.COUNT

    RETURN


**************************************************************************
**************************************************************************
** user interface / option screens                                      **
**************************************************************************
**************************************************************************

OPTION.MENU: *************************************************************
* put up a menu to get command line options                              *
**************************************************************************

* button captions for the options screen
    ALL.DESC = "All Methods"

    DELETE.DESC = "Delete Old CBPs"

    VIEW.DESC = "View New CBP"
    SOURCE.DESC = "Source Comments"
    BREAK.DESC = "Split Compound"

    SAVE.DESC = "Save CBP"
    COMPILE.DESC = "Compile CBP"
    DOT.NET.DESC = "Export DotNet"

    LOOK.DESC = "View Only"

    WAIT.DESC = "Wait on Errors"

    REPAIR.DESC = "Repair Mode"
    CHECK.DESC = "Check Only"

* build a table of options and current settings
    OPTION.LIST = ""
    OPTION.SETTING = ""
    OPTION.COUNT = 0

* first line of options:

* always recompile all methods
    IF OBJECT.FILENAME = "OBJ" THEN
        NEW.OPTION = ALL.DESC
        NEW.SETTING = ALWAYS.RECOMPILE.METHODS
        GOSUB ADD.OPTION
    END

    IF OBJECT.FILENAME = "OBJ" OR OBJECT.FILENAME = "OBP" THEN

* wait on errors
        NEW.OPTION = WAIT.DESC
        NEW.SETTING = WAIT.AFTER.ERROR
        GOSUB ADD.OPTION

* check-only mode.  checks compile without saving cbp
        NEW.OPTION = CHECK.DESC
        NEW.SETTING = CHECK.MODE
        GOSUB ADD.OPTION

    END ELSE

        GOSUB BLANK.OPTION

    END

    IF OBJECT.FILENAME = "OBP" THEN
        GOSUB BLANK.OPTION
    END

* second line of options:

    IF OBJECT.FILENAME = "OBJ" OR OBJECT.FILENAME = "OBP" THEN

* view new cbp
        NEW.OPTION = VIEW.DESC
        NEW.SETTING = VIEW.CONVERTED.CODE
        GOSUB ADD.OPTION

* source comments
        NEW.OPTION = SOURCE.DESC
        NEW.SETTING = ADD.SOURCE.COMMENTS
        GOSUB ADD.OPTION

* split compound lines
        NEW.OPTION = BREAK.DESC
        NEW.SETTING = REFORMAT.COMPOUND.LINES
        GOSUB ADD.OPTION

* third line of options

* save cbp
        NEW.OPTION = SAVE.DESC
        NEW.SETTING = SAVE.CBPS
        GOSUB ADD.OPTION

* compile cbp
        NEW.OPTION = COMPILE.DESC
        NEW.SETTING = DO.COMPILE
        GOSUB ADD.OPTION

* export dotnet
        IF OBJECT.FILENAME = "OBJ" THEN
            NEW.OPTION = DOT.NET.DESC
            NEW.SETTING = DO.DOT.NET.EXPORTS
            GOSUB ADD.OPTION
        END ELSE
            GOSUB BLANK.OPTION
        END

* fourth line of options

* view only (look mode)
        NEW.OPTION = LOOK.DESC
        IF LOOK.MODE THEN
            NEW.SETTING = @TRUE
        END ELSE
            NEW.SETTING = @FALSE
        END
        GOSUB ADD.OPTION

    END

* delete old cbps
    IF OBJECT.FILENAME = "OBJ" THEN
        NEW.OPTION = DELETE.DESC
        NEW.SETTING = DELETE.CBP
        GOSUB ADD.OPTION
    END

* repair mode
    NEW.OPTION = REPAIR.DESC
    NEW.SETTING = REPAIR.MODE
    GOSUB ADD.OPTION

* set up push button screen
    TITLE = "uniVerse Object Compiler"

    BEGIN CASE
        CASE DOT.NET.ENABLED AND OBJ.NET.EXISTS AND JAVA.ENABLED AND OBJ.JAVA.EXISTS
            TITLE = " with Dotnet+Java"
        CASE DOT.NET.ENABLED AND OBJ.NET.EXISTS
            TITLE := " with DotNet"
        CASE JAVA.ENABLED AND OBJ.JAVA.EXISTS
            TITLE := " with Java"
    END CASE

    IF PRECOMPILER.VERSION <> "" THEN
        TITLE := ", Version ":PRECOMPILER.VERSION
    END

*   IF PRECOMPILER.VERSION.DATE <> "" THEN
*       TITLE := ", ":OCONV(PRECOMPILER.VERSION.DATE, "D4/")
*   END

    OBJECT.LIST.DESC = CHANGE(OBJECT.LIST, @AM, ", ")
    IF UPCASE.CODE THEN
        OBJECT.LIST.DESC = DOWNCASE(OBJECT.LIST.DESC)
    END

    BEGIN CASE
        CASE OBJECT.FILENAME = "OBJ"
            OBJECT.FILE.DESC = "Object"
        CASE OBJECT.FILENAME = "OBP"
            OBJECT.FILE.DESC = "Subroutine"
        CASE 1
            OBJECT.FILE.DESC = OBJECT.FILENAME
    END CASE

    MESSAGE = "Select Compiler Options:"

    BEGIN CASE
        CASE OBJECT.COUNT = 1
            MESSAGE<3> = "Compile ":OBJECT.FILE.DESC:": ":OBJECT.LIST.DESC
        CASE LEN(OBJECT.LIST.DESC) <= 30
            MESSAGE<3> = "Compile ":OBJECT.FILE.DESC:"s: ":OBJECT.LIST.DESC
        CASE 1
            MESSAGE<3> = "Compile ":OBJECT.COUNT "L,":" ":OBJECT.FILE.DESC:"s"
    END CASE

    CONTINUE.BUTTON = "Execute"
    CANCEL.BUTTON = "Cancel"
    BACK.CAPTION = "*"
    CLOSE.CAPTION = "cancel"

    NEW.OPTION.SETTING = UD.PUSH.BUTTON(OPTION.LIST:"", OPTION.SETTING:"", TITLE:"", MESSAGE:"", CONTINUE.BUTTON, CANCEL.BUTTON, BACK.CONTROL.CAPTION=BACK.CAPTION, CLOSE.CONTROL.CAPTION=CLOSE.CAPTION

    OPTION.SETTING = NEW.OPTION.SETTING

    IF F12 OR QUIT THEN
        ABORT.PROGRAM = @TRUE
        RETURN
    END

* process modes that set multiple flags first
    LOCATE DELETE.DESC IN OPTION.LIST SETTING PTR THEN
        BEGIN CASE
            CASE OPTION.SETTING<PTR> AND NOT(DELETE.MODE)
                GOSUB SET.DELETE.MODE
            CASE NOT(OPTION.SETTING<PTR>) AND DELETE.MODE
                GOSUB RESET.DELETE.MODE
        END CASE
    END

    LOCATE WAIT.DESC IN OPTION.LIST SETTING PTR THEN
        BEGIN CASE
            CASE OPTION.SETTING<PTR> AND NOT(WAITERROR.MODE)
                GOSUB SET.WAITERROR.MODE
            CASE NOT(OPTION.SETTING<PTR>) AND WAITERROR.MODE
                GOSUB RESET.WAITERROR.MODE
        END CASE
    END

    LOCATE REPAIR.DESC IN OPTION.LIST SETTING PTR THEN
        BEGIN CASE
            CASE OPTION.SETTING<PTR> AND NOT(REPAIR.MODE)
                GOSUB SET.REPAIR.MODE
            CASE NOT(OPTION.SETTING<PTR>) AND REPAIR.MODE
                GOSUB RESET.REPAIR.MODE
        END CASE
    END

    LOCATE CHECK.DESC IN OPTION.LIST SETTING PTR THEN
        BEGIN CASE
            CASE OPTION.SETTING<PTR> AND NOT(CHECK.MODE)
                GOSUB SET.CHECK.MODE
            CASE NOT(OPTION.SETTING<PTR>) AND CHECK.MODE
                GOSUB RESET.CHECK.MODE
        END CASE
    END

    LOCATE LOOK.DESC IN OPTION.LIST SETTING PTR THEN
        BEGIN CASE
            CASE OPTION.SETTING<PTR> AND NOT(LOOK.MODE)
                GOSUB SET.LOOK.MODE
            CASE NOT(OPTION.SETTING<PTR>) AND LOOK.MODE
                GOSUB RESET.LOOK.MODE
        END CASE
    END

* some modes are incompatible
    IF REPAIR.MODE THEN

        IF CHECK.MODE THEN
            GOSUB RESET.CHECK.MODE
        END

        IF LOOK.MODE THEN
            GOSUB RESET.LOOK.MODE
        END

    END

    IF CHECK.MODE THEN

        IF DELETE.MODE THEN
            GOSUB RESET.DELETE.MODE
        END

    END

* process modes that set single flags.  some modes already set these flags.
* if we're in one of those modes we'll skip all these checks
    IF NOT(LOOK.MODE) AND NOT(REPAIR.MODE) AND NOT(CHECK.MODE) THEN

        LOCATE VIEW.DESC IN OPTION.LIST SETTING PTR THEN
            VIEW.CONVERTED.CODE = OPTION.SETTING<PTR>
        END

        LOCATE SOURCE.DESC IN OPTION.LIST SETTING PTR THEN
            ADD.SOURCE.COMMENTS = OPTION.SETTING<PTR>
        END

        LOCATE BREAK.DESC IN OPTION.LIST SETTING PTR THEN
            REFORMAT.COMPOUND.LINES = OPTION.SETTING<PTR>
        END

        LOCATE SAVE.DESC IN OPTION.LIST SETTING PTR THEN
            SAVE.CBPS = OPTION.SETTING<PTR>
        END

        LOCATE COMPILE.DESC IN OPTION.LIST SETTING PTR THEN
            DO.COMPILE = OPTION.SETTING<PTR>
        END

        LOCATE DOT.NET.DESC IN OPTION.LIST SETTING PTR THEN
            DO.DOT.NET.EXPORTS = OPTION.SETTING<PTR>
            DO.JAVA.EXPORTS = OPTION.SETTING<PTR>
        END

    END

    IF NOT(REPAIR.MODE) THEN 

        LOCATE ALL.DESC IN OPTION.LIST SETTING PTR THEN
            ALWAYS.RECOMPILE.METHODS = OPTION.SETTING<PTR>
        END

    END

    RETURN

BLANK.OPTION: ************************************************************
* add a blank option                                                     *
**************************************************************************
    NEW.OPTION = ""
    NEW.SETTING = ""
    GOSUB ADD.OPTION

    RETURN

ADD.OPTION: **************************************************************
* add new.option and new.setting to the table of options                 *
**************************************************************************
    OPTION.COUNT += 1

    OPTION.LIST<OPTION.COUNT> = NEW.OPTION
    OPTION.SETTING<OPTION.COUNT> = NEW.SETTING

    RETURN

CHECK.OBJECT.COUNT: ******************************************************
* if object.count is zero, meaning no programs were selected, dump out   *
**************************************************************************
    IF OBJECT.COUNT > 0 THEN
        RETURN
    END

    PRINT
    PRINT "No items selected."
    PRINT

    GOSUB WRAPUP

    RETURN

UPDATE.LAST.PROGRAM.LIST: ************************************************
* update control record with the program edited                          *
**************************************************************************
    LAST.ITEM.COUNT = 50
    CONTROL.ID = "EDIT.":UPCASE(USER.ID)

* save file and program name in the previously edited items stack in
* ud.control
    TRY.COUNT = 1

    LOOP

        CONTROL.LOCKED = @FALSE
        READU CONTROL.RECORD FROM CONTROL.HANDLE, CONTROL.ID LOCKED CONTROL.LOCKED = @TRUE ELSE
            CONTROL.RECORD = "Last Edited List for ":USER.ID
        END

    UNTIL NOT(CONTROL.LOCKED) OR TRY.COUNT > 3

        TRY.COUNT += 1
        SLEEP 1

    REPEAT

    IF CONTROL.LOCKED THEN
        PRINT "Can't update Last Edit List.  Record locked."
        PRINT
        RETURN
    END

* if the file and item are already in the list remove them
    THIS.FILE.VM.COUNT = DCOUNT(CONTROL.RECORD<2>, @VM)

    FOR ENTRY.LOOP = THIS.FILE.VM.COUNT TO 1 STEP -1

        THIS.FILE = CONTROL.RECORD<2><1,ENTRY.LOOP>
        THIS.PROGRAM = CONTROL.RECORD<3, ENTRY.LOOP>

        IF THIS.FILE = PROGRAM.FILE AND THIS.PROGRAM = PROGRAM.NAME THEN
            DEL CONTROL.RECORD<2,ENTRY.LOOP>
            DEL CONTROL.RECORD<3,ENTRY.LOOP>
            DEL CONTROL.RECORD<4,ENTRY.LOOP>
            DEL CONTROL.RECORD<5,ENTRY.LOOP>
        END

    NEXT ENTRY.LOOP

* add the file, item, time and date to the top of the list
    INS PROGRAM.FILE BEFORE CONTROL.RECORD<2,1>
    INS PROGRAM.NAME BEFORE CONTROL.RECORD<3,1>
    INS DATE() BEFORE CONTROL.RECORD<4,1>
    INS INT (TIME()) BEFORE CONTROL.RECORD<5,1>

* remove any entries past the limit of what we're keeping in the stack
    LOOP UNTIL CONTROL.RECORD<2, LAST.ITEM.COUNT + 1> = "" AND CONTROL.RECORD<3, LAST.ITEM.COUNT + 1> = ""
        DEL CONTROL.RECORD<2,LAST.ITEM.COUNT + 1>
        DEL CONTROL.RECORD<3,LAST.ITEM.COUNT + 1>
        DEL CONTROL.RECORD<4,LAST.ITEM.COUNT + 1>
        DEL CONTROL.RECORD<5,LAST.ITEM.COUNT + 1>
    REPEAT

    WRITE CONTROL.RECORD ON CONTROL.HANDLE, CONTROL.ID

    RETURN

CHOOSE.PROGRAM.FROM.MENU: ************************************************
* choose program to edit from a menu of previously edited programs       *
**************************************************************************
    CONTROL.ID = "EDIT.":UPCASE(USER.ID)

    READ CONTROL.RECORD FROM CONTROL.HANDLE, CONTROL.ID ELSE
        CONTROL.RECORD = ""
    END

    LAST.FILE.LIST = RAISE(CONTROL.RECORD<2>)
    LAST.ITEM.LIST = RAISE(CONTROL.RECORD<3>)
    LAST.DATE.LIST = RAISE(CONTROL.RECORD<4>)
    LAST.TIME.LIST = RAISE(CONTROL.RECORD<5>)

* build choice.list
    CHOICE.LIST = ""
    CHOICE.COUNT = 0

    TITLE = "Compile from Edited Programs, ":"(":USER.ID:")"

* find width of the largest program name and remove any that aren't
* in a program file
    MAX.PROGRAM.LENGTH = 8
    MAX.FILE.LENGTH = 4
    LAST.COUNT = DCOUNT(LAST.ITEM.LIST ,@AM)

    FOR PROGRAM.LOOP = LAST.COUNT TO 1 STEP -1

        THIS.PROGRAM.FILE = LAST.FILE.LIST<PROGRAM.LOOP>
        THIS.PROGRAM.NAME = LAST.ITEM.LIST<PROGRAM.LOOP>

* is this file a program file?  if so check the length for formatting the
* choice window.  if not remove from the list
        LOCATE THIS.PROGRAM.FILE IN HIERARCHY.LIST SETTING THROWAWAY THEN

            IF LEN(THIS.PROGRAM.FILE) > MAX.FILE.LENGTH THEN
                MAX.FILE.LENGTH = LEN(THIS.PROGRAM.FILE)
            END
            IF LEN(THIS.PROGRAM.NAME) > MAX.PROGRAM.LENGTH THEN
                MAX.PROGRAM.LENGTH = LEN(THIS.PROGRAM.NAME)
            END

        END ELSE

            DEL LAST.FILE.LIST<PROGRAM.LOOP>
            DEL LAST.ITEM.LIST<PROGRAM.LOOP>
            DEL LAST.DATE.LIST<PROGRAM.LOOP>
            DEL LAST.TIME.LIST<PROGRAM.LOOP>

        END

    NEXT PROGRAM.LOOP

    FILE.MASK = "L#":MAX.FILE.LENGTH
    PROGRAM.MASK = "L#":MAX.PROGRAM.LENGTH

* build heading line
    CHOICE.LINE = "File" FILE.MASK:" ":"Program" PROGRAM.MASK:" ":"Last Changed"
    CHOICE.LIST<1> = CHOICE.LINE

* add a choice for each entry in the "last entries" edited control record
    LAST.COUNT = DCOUNT(LAST.ITEM.LIST, @AM)

    FOR PROGRAM.LOOP = 1 TO LAST.COUNT

        THIS.PROGRAM.FILE = LAST.FILE.LIST<PROGRAM.LOOP>
        THIS.PROGRAM.NAME = LAST.ITEM.LIST<PROGRAM.LOOP>

        IF DOWNCASE.METHODS THEN
            THIS.PROGRAM.FILE = DOWNCASE(THIS.PROGRAM.FILE)
            THIS.PROGRAM.NAME = DOWNCASE(THIS.PROGRAM.NAME)
        END

        THIS.DATE = LAST.DATE.LIST<PROGRAM.LOOP>
        THIS.TIME = LAST.TIME.LIST<PROGRAM.LOOP>

        CHOICE.LINE = THIS.PROGRAM.FILE FILE.MASK:" ":THIS.PROGRAM.NAME PROGRAM.MASK:" "
        CHOICE.LINE := "(":OCONV(THIS.DATE, "D2/") [1, 5] "L#5":" "
        CHOICE.LINE := OCONV(THIS.TIME, "MTH") "L#7":")"

        CHOICE.COUNT += 1
        CHOICE.LIST<CHOICE.COUNT + 1> = CHOICE.LINE

    NEXT PROGRAM.LOOP

* add a selection for "new".  we'll add this to the end of the list since
* it won't be used as often as getting a "last" program name
    CHOICE.LINE = "***" FILE.MASK:" ":"new program" PROGRAM.MASK:" "
    CHOICE.LINE := " ":SPACE(5):" ":SPACE(7):" "

    CHOICE.COUNT += 1
    CHOICE.LIST<CHOICE.COUNT + 1> = CHOICE.LINE
    NEW.SELECTION = CHOICE.COUNT + 1

* put up a choice window (or not) depending on how many programs are
* in the filtered last-edited list
    BEGIN CASE

* if we have no programs dump out
        CASE CHOICE.COUNT = 0
            CHOICE = 0

* if we only have one program choose that one
        CASE CHOICE.COUNT = 1
            CHOICE = 2

* more than one program present the menu
        CASE 1
            CHOICE = UD.GET.CHOICE(CHOICE.LIST, 2, TITLE, "", "", "", "", 2, "", "", "*")

    END CASE

    BEGIN CASE

* user exits
        CASE CHOICE = 0 OR F12 OR QUIT
            PROGRAM.FILE = ""
            PROGRAM.NAME = ""

* "new" program selected
        CASE CHOICE = NEW.SELECTION

            GOSUB CHOOSE.FILE.FROM.MENU
            IF PROGRAM.FILE = "" THEN
                PROGRAM.NAME = ""
                RETURN
            END

            GOSUB CHOOSE.PROGRAM.FROM.PROMPT
            IF PROGRAM.NAME = "" THEN
                PROGRAM.FILE = ""
                RETURN
            END

* a program was selected
        CASE 1
            CHOICE -= 1
            PROGRAM.FILE = LAST.FILE.LIST<CHOICE>
            PROGRAM.NAME = LAST.ITEM.LIST<CHOICE>

    END CASE

    RETURN

CHOOSE.FILE.FROM.MENU: ***************************************************
* choose a program file name from a scrolling menu                       *
**************************************************************************
    TITLE = "Chose Program File"
    PROGRAM.FILE = ""
    PROGRAM.NAME = ""

* reverse the hierarchy list for the choice list
    PROGRAM.FILE.LIST = ""
    PROGRAM.FILE.COUNT = 0

    FOR PROGRAM.LOOP = PROGRAM.FILE.HIERARCHY.COUNT TO 1 STEP -1
        PROGRAM.FILE.COUNT += 1
        PROGRAM.FILE.LIST<PROGRAM.FILE.COUNT> = PROGRAM.FILE.HIERARCHY.LIST<PROGRAM.LOOP>
    NEXT PROGRAM.LOOP

* insert some breaks after certain files
    LOCATE "OBP" IN PROGRAM.FILE.LIST SETTING FILE.PTR THEN
        INS "" BEFORE PROGRAM.FILE.LIST<FILE.PTR + 1>
        PROGRAM.FILE.COUNT += 1
    END

    LOCATE "CBP" IN PROGRAM.FILE.LIST SETTING FILE.PTR THEN
        INS "" BEFORE PROGRAM.FILE.LIST<FILE.PTR + 1>
        PROGRAM.FILE.COUNT += 1
    END

* build choice list
    CHOICE.LIST = ""
    CHOICE.PTR = 0
    MAX.FILE.LENGTH = 6

    FOR CHOICE.LOOP = 1 TO PROGRAM.FILE.COUNT

        THIS.PROGRAM.FILE = PROGRAM.FILE.LIST<CHOICE.LOOP>

        IF LEN(THIS.PROGRAM.FILE) > MAX.FILE.LENGTH THEN
            MAX.FILE.LENGTH = LEN(THIS.PROGRAM.FILE)
        END

        IF UPCASE.CODE THEN
            THIS.PROGRAM.FILE = DOWNCASE(THIS.PROGRAM.FILE)
        END

        CHOICE.PTR += 1
        CHOICE.LIST<CHOICE.PTR> = THIS.PROGRAM.FILE

    NEXT CHOICE.LOOP

    FILE.MASK = "L#":MAX.FILE.LENGTH
    TYPE.MASK = "L#24"

* add a "type" description
    FOR CHOICE.LOOP = 1 TO PROGRAM.FILE.COUNT

        THIS.FILE = UPCASE(CHOICE.LIST<CHOICE.LOOP>)

        BEGIN CASE

            CASE THIS.FILE = "OBJ"
                TYPE = "object code"
            CASE THIS.FILE = "OBP"
                TYPE = "object subroutines"
            CASE THIS.FILE = "CBP"
                TYPE = "custom code"


            CASE THIS.FILE = "BP"
                TYPE = "eclipse core code"
            CASE THIS.FILE = "XBP"
                TYPE = "eclipse conversion code"

            CASE THIS.FILE = "SP"
                TYPE = "eclipse utilities"
            CASE THIS.FILE = "OC"
                TYPE = "precompiled code"
            CASE THIS.FILE = "CC"
                TYPE = "eclipse includes"

            CASE THIS.FILE = ""
                TYPE = ""

            CASE 1
                TYPE = "eclipse code"

        END CASE

        CHOICE.LIST<CHOICE.LOOP> = CHOICE.LIST<CHOICE.LOOP> FILE.MASK:" ":TYPE TYPE.MASK

    NEXT CHOICE.LOOP

* build heading line and insert at top of list
    MIN.CHOICE = 1

* these lines will add a heading but it looks better without
*   CHOICE.LINE = "File" FILE.MASK:" ":"Type" TYPE.MASK
*   INS CHOICE.LINE BEFORE CHOICE.LIST<1>
*   MIN.CHOICE = 2

* set default
    DEFAULT.PROGRAM.FILE = "OBP"
    LOCATE DEFAULT.PROGRAM.FILE IN UPCASE(PROGRAM.FILE.LIST) SETTING DEFAULT.CHOICE ELSE
        DEFAULT.CHOICE = 1
    END

    CHOICE = UD.GET.CHOICE(CHOICE.LIST, DEFAULT.CHOICE, TITLE, "", "", "", "", MIN.CHOICE, "", "", "", "*")

    IF CHOICE = 0 OR F12 OR QUIT THEN
        RETURN
    END

    CHOICE -= (MIN.CHOICE - 1)
    PROGRAM.FILE = PROGRAM.FILE.LIST<CHOICE>

    IF UPCASE.CODE THEN
        PROGRAM.FILE = UPCASE(PROGRAM.FILE)
    END

    RETURN

CHOOSE.OBJECT.FROM.MENU: *************************************************
* choose an object name from a menu from the previously compiled         *
* program list                                                           *
**************************************************************************
    CONTROL.ID = "EDIT.":UPCASE(USER.ID)

    READ CONTROL.RECORD FROM CONTROL.HANDLE, CONTROL.ID ELSE
        CONTROL.RECORD = ""
    END

    LAST.FILE.LIST = RAISE(CONTROL.RECORD<2>)
    LAST.ITEM.LIST = RAISE(CONTROL.RECORD<3>)
    LAST.DATE.LIST = RAISE(CONTROL.RECORD<4>)
    LAST.TIME.LIST = RAISE(CONTROL.RECORD<5>)

* remove any entries that aren't for the obj file
    LAST.COUNT = DCOUNT(LAST.ITEM.LIST ,@AM)

    FOR PROGRAM.LOOP = LAST.COUNT TO 1 STEP -1

        IF LAST.FILE.LIST<PROGRAM.LOOP> <> "OBJ" THEN
            DEL LAST.FILE.LIST<PROGRAM.LOOP>
            DEL LAST.ITEM.LIST<PROGRAM.LOOP>
            DEL LAST.DATE.LIST<PROGRAM.LOOP>
            DEL LAST.TIME.LIST<PROGRAM.LOOP>
            LAST.COUNT -= 1
        END

    NEXT PROGRAM.LOOP

* build choice.list
    CHOICE.LIST = ""
    CHOICE.COUNT = 0

    TITLE = "Export DotNet from Edited Objects, ":"(":USER.ID:")"

* find width of the largest program name and remove any that aren't
* in a program file
    MAX.PROGRAM.LENGTH = 8
    MAX.FILE.LENGTH = 4
    LAST.COUNT = DCOUNT(LAST.ITEM.LIST ,@AM)

    FOR PROGRAM.LOOP = LAST.COUNT TO 1 STEP -1

        THIS.PROGRAM.FILE = LAST.FILE.LIST<PROGRAM.LOOP>
        THIS.PROGRAM.NAME = LAST.ITEM.LIST<PROGRAM.LOOP>

* is this file a program file?  if so check the length for formatting the
* choice window.  if not remove from the list
        LOCATE THIS.PROGRAM.FILE IN HIERARCHY.LIST SETTING THROWAWAY THEN

            IF LEN(THIS.PROGRAM.FILE) > MAX.FILE.LENGTH THEN
                MAX.FILE.LENGTH = LEN(THIS.PROGRAM.FILE)
            END
            IF LEN(THIS.PROGRAM.NAME) > MAX.PROGRAM.LENGTH THEN
                MAX.PROGRAM.LENGTH = LEN(THIS.PROGRAM.NAME)
            END

        END ELSE

            DEL LAST.FILE.LIST<PROGRAM.LOOP>
            DEL LAST.ITEM.LIST<PROGRAM.LOOP>
            DEL LAST.DATE.LIST<PROGRAM.LOOP>
            DEL LAST.TIME.LIST<PROGRAM.LOOP>

        END

    NEXT PROGRAM.LOOP

    FILE.MASK = "L#":MAX.FILE.LENGTH
    PROGRAM.MASK = "L#":MAX.PROGRAM.LENGTH

* build heading line
    CHOICE.LINE = "Object" PROGRAM.MASK:" ":"Last Changed"
    CHOICE.LIST<1> = CHOICE.LINE

* add a choice for each entry in the "last entries" edited control record
    LAST.COUNT = DCOUNT(LAST.ITEM.LIST, @AM)

    FOR PROGRAM.LOOP = 1 TO LAST.COUNT

        THIS.PROGRAM.FILE = LAST.FILE.LIST<PROGRAM.LOOP>
        THIS.PROGRAM.NAME = LAST.ITEM.LIST<PROGRAM.LOOP>

        IF DOWNCASE.METHODS THEN
            THIS.PROGRAM.FILE = DOWNCASE(THIS.PROGRAM.FILE)
            THIS.PROGRAM.NAME = DOWNCASE(THIS.PROGRAM.NAME)
        END

        THIS.DATE = LAST.DATE.LIST<PROGRAM.LOOP>
        THIS.TIME = LAST.TIME.LIST<PROGRAM.LOOP>

        CHOICE.LINE = THIS.PROGRAM.NAME PROGRAM.MASK:" "
        CHOICE.LINE := "(":OCONV(THIS.DATE, "D2/") [1, 5] "L#5":" "
        CHOICE.LINE := OCONV(THIS.TIME, "MTH") "L#7":")"

        CHOICE.COUNT += 1
        CHOICE.LIST<CHOICE.COUNT + 1> = CHOICE.LINE

    NEXT PROGRAM.LOOP

* put up a choice window (or not) depending on how many programs are
* in the filtered last-edited list
    BEGIN CASE

* if we have no programs dump out
        CASE CHOICE.COUNT = 0
            CHOICE = 0

* if we only have one program choose that one
        CASE CHOICE.COUNT = 1
            CHOICE = 2

* more than one program present the menu
        CASE 1
            CHOICE = UD.GET.CHOICE(CHOICE.LIST, 2, TITLE, "", "", "", "", 2, "", "", "*")

    END CASE

    BEGIN CASE

* user exits
        CASE CHOICE = 0 OR F12 OR QUIT
            PROGRAM.FILE = ""
            PROGRAM.NAME = ""

* an object was selected
        CASE 1
            CHOICE -= 1
            PROGRAM.FILE = LAST.FILE.LIST<CHOICE>
            PROGRAM.NAME = LAST.ITEM.LIST<CHOICE>

    END CASE

    RETURN

CHOOSE.PROGRAM.FROM.PROMPT: **********************************************
* get a new program name from a window prompt.  if the program name      *
* doesn't exist in program.file the user will be asked if they're sure   *
* they want to create a new program                                      *
**************************************************************************

* build a list of possible program names for this program file.  if
* we're looking at the cbp file don't select any subroutines built from
* methods
    PROGRAM.LIST = ""
    PROGRAM.LIST.COUNT = 0

    STATEMENT = "SSELECT ":PROGRAM.FILE
    IF PROGRAM.FILE = "CBP" THEN
        STATEMENT := ' WITH @ID <> "':ECLIPSE.PREFIX:']"'
    END

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    LOOP WHILE READNEXT THIS.PROGRAM.NAME FROM SLIST DO

        PROGRAM.LIST.COUNT += 1

        IF PROGRAM.LIST.COUNT = 1 THEN
            PROGRAM.LIST = THIS.PROGRAM.NAME
        END ELSE
            PROGRAM.LIST := @AM:THIS.PROGRAM.NAME
        END

    REPEAT

* window prompt for the new program name
    TITLE = "Enter Program Name"

    MESSAGE = "Enter program name from the "
    IF UPCASE.CODE THEN
        DISPLAY.PROGRAM.FILE = DOWNCASE(PROGRAM.FILE)
    END

    MESSAGE<2> = DISPLAY.PROGRAM.FILE:" program file"

    UT.OPEN.FILE PROGRAM.FILE, TEST.FILE.HANDLE, ERROR.MESSAGE, 1
    IF ERROR.MESSAGE <> "" THEN
        PROGRAM.FILE = ""
        PROGRAM.NAME = ""
        RETURN
    END

* prompt until a good filename is entered
    PROGRAM.NAME.GOOD = @FALSE

    LOOP UNTIL PROGRAM.NAME.GOOD OR F12 OR QUIT DO

        PROGRAM.NAME = UD.WINDOW.PROMPT(TITLE, MESSAGE, 40, "", "", PROGRAM.LIST)

        BEGIN CASE

            CASE PROGRAM.NAME = ""
                NULL

* if the program.name doesn't exist in the program.file file we won't
* have anything to compile
            CASE 1

                READV TEST.PROGRAM FROM TEST.FILE.HANDLE, PROGRAM.NAME, 0 THEN
                    PROGRAM.NAME.GOOD = @TRUE
                END ELSE

                    READV TEST.PROGRAM FROM TEST.FILE.HANDLE, UPCASE(PROGRAM.NAME), 0 THEN
                        PROGRAM.NAME = UPCASE(PROGRAM.NAME)
                        PROGRAM.NAME.GOOD = @TRUE
                    END ELSE
                        MESSAGE = PROGRAM.NAME:" is not in"
                        MESSAGE<2> = "the ":DISPLAY.PROGRAM.FILE:" file"
                        UD.MESSAGE TITLE, "", MESSAGE
                        F12 = @FALSE
                        QUIT = @FALSE
                    END

                END

        END CASE

    REPEAT

* user exit, no program name selected
    IF F12 OR QUIT OR PROGRAM.NAME = "" THEN
        PROGRAM.NAME = ""
        PROGRAM.FILE = ""
        RETURN
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / main routines                            **
**************************************************************************
**************************************************************************

PROCESS.OBJECT.LIST: *****************************************************
* compile all objects from the command line or select lists or whatever. *
* this routine builds the cbp record(s) from the object or object-       *
* enabled subroutine and compiles it/them                                *
**************************************************************************
    FOR OBJECT.LOOP = 1 TO OBJECT.COUNT

        COMPILE.NAME = OBJECT.LIST<OBJECT.LOOP>

        GOSUB PROCESS.ONE.OBJECT

        GOSUB CHECK.ABORT

    NEXT OBJECT.LOOP

    RETURN

PROCESS.ONE.OBJECT: ******************************************************
* process object compile.name                                            *
**************************************************************************

* are compiling one method of an object or an entire object/subroutine?
* if we're only compiling a method recompile even if the checksums
* say that it doesn't need to be compiled
    PTR = INDEX(COMPILE.NAME, METHOD.DELIMITER, 1)

* if we're listing objects add the "new" method to the end of the
* compile name.  for OBP programs this won't do anything.  for OBJ
* objects it will compile only one method and that's all we need
* to get an object listing
    IF LIST.OBJECTS.ONLY AND PTR = 0 THEN
        COMPILE.NAME := METHOD.DELIMITER:NEW.KEYWORD
        PTR = INDEX(COMPILE.NAME, METHOD.DELIMITER, 1)
    END

    IF PTR > 0 THEN
        OBJECT.NAME = COMPILE.NAME [1, PTR - 1]
        OBJECT.METHOD = COMPILE.NAME [PTR + METHOD.DEL.LENGTH, TO.THE.END]
        ALWAYS.RECOMPILE.METHODS = @TRUE
    END ELSE
        OBJECT.NAME = COMPILE.NAME
        OBJECT.METHOD = ""
    END

* convert object into eclipse subroutines
    GOSUB PRECOMPILE.OBJECT

* compile subroutines built from methods
    BEGIN CASE
        CASE LIST.METHODS
            DO.ALL.COMPILES = @FALSE
        CASE SHORTCUT.LIST
            DO.ALL.COMPILES = @FALSE
        CASE LIST.OBJECTS.ONLY
            DO.ALL.COMPILES = @FALSE
        CASE DO.COMPILE
            DO.ALL.COMPILES = @TRUE
        CASE 1
            DO.ALL.COMPILES = @FALSE
    END CASE

* compile eclipse subroutines
    IF DO.ALL.COMPILES THEN

        GOSUB COMPILE.ALL.METHODS

* wait after compilation?
        BEGIN CASE

            CASE WAIT.AFTER.ERROR AND NOT(COMPILE.SUCCESSFUL)

                IF COMPILE.OBJECT THEN
                    SPEECH = "An error was encountered in method ":METHOD
                    SPEECH := " of object ":OBJECT.NAME:". "
                END ELSE
                    SPEECH = "An error was encountered in subroutine ":OBJECT.NAME:". "
                END

                SPEECH := OBJECT.ERROR.DESC
                GOSUB WAIT.AND.SPEAK
                GOSUB WAIT

            CASE WAIT.AFTER.COMPILE
                GOSUB WAIT

        END CASE

* if the compile was successful and this object is exported to .net build
* and export the .net code.  if there were compile errors anywhere we won't
* do the export--we could be exporting a class that won't work
        IF CREATED.METHOD.COUNT <> 0 AND BAD.SUBROUTINE.COUNT = 0 THEN
            IF COMPILE.SUCCESSFUL THEN
                IF EXTERNAL.OBJECT THEN

                    GOSUB UPDATE.DOT.NET.OBJECT
                    GOSUB UPDATE.JAVA.OBJECT

                END
            END
        END

    END

    RETURN

ANNOUNCE.COMPILED.OBJECT: ************************************************
* say the name of the object / subroutine we're compiling                *
**************************************************************************
    BEGIN CASE

* compiling multiple items and this is the first one
        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "OBJ" AND SELECT.METHOD <> ""
            SAY.TEXT = "Compiling method ":SELECT.METHOD:" of multiple objects"
        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "OBJ"
            SAY.TEXT = "Compiling multiple objects"
        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "OBP"
            SAY.TEXT = "Compiling multiple subroutines"

        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "CBP"
            SAY.TEXT = "Compiling multiple CBP routines"

        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "BP"
            SAY.TEXT = "Compiling multiple core routines"
        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1 AND OBJECT.FILENAME = "SP"
            SAY.TEXT = "Compiling multiple core subroutines"
        CASE OBJECT.LOOP = 1 AND OBJECT.COUNT > 1
            SAY.TEXT = "Compiling multiple core routines"

* compiling multiple routines and this isn't the first one
        CASE OBJECT.LOOP > 1 AND OBJECT.COUNT > 1
            SAY.TEXT = OBJECT.NAME

* single item
        CASE OBJECT.FILENAME = "OBJ" AND OBJECT.METHOD <> ""
            SAY.TEXT = "Compiling method ":OBJECT.METHOD:" of object ":OBJECT.NAME
        CASE OBJECT.FILENAME = "OBJ"
            SAY.TEXT = "Compiling object ":OBJECT.NAME
        CASE OBJECT.FILENAME = "OBP"
            SAY.TEXT = "Compiling subroutine ":OBJECT.NAME

        CASE OBJECT.FILENAME = "CBP"
            SAY.TEXT = "Compiling user routine ":OBJECT.NAME

        CASE OBJECT.FILENAME = "BP"
            SAY.TEXT = "Compiling core routine ":OBJECT.NAME
        CASE OBJECT.FILENAME = "SP"
            SAY.TEXT = "Compiling core subroutine ":OBJECT.NAME
        CASE 1
            SAY.TEXT = "Compiling core routine ":OBJECT.NAME

    END CASE

    SPEECH = SAY.TEXT
    GOSUB SPEAK

    RETURN

REPORT.PROCESSED: ********************************************************
* display a final status for the entire compilation process              *
**************************************************************************

* if we're doing the OC file we "processed" the records.  anything else
* and we "compiled" them
    IF COMPILE.OC THEN
        VERB = "processed"
    END ELSE
        VERB = "compiled"
    END

* if we're compiling an object we'll talk about processing "methods."
* otherwise we'll talk about "subroutines"
    BEGIN CASE
        CASE COMPILE.OBJECT AND WRAPPER.CREATE.COUNT = 0
            COMPILED.NAME = "method"
        CASE COMPILE.OBJECT
            COMPILED.NAME = "methods and wrapper"
        CASE 1
            COMPILED.NAME = "subroutine"
    END CASE

* if we compiled more than one subroutine and we had bad compiles
* list them out
    GOOD.COMPILE.COUNT = GRAND.TOTAL.COMPILED - BAD.COMPILE.COUNT

    IF GRAND.TOTAL.COMPILED = 1 THEN
        GOSUB REPORT.SINGLE.PROCESSED
    END ELSE
        GOSUB REPORT.MULTIPLE.PROCESSED
    END

    RETURN

REPORT.PROCESSING.TIMES: *************************************************
* report on elapsed time for different phases of the compile             *
**************************************************************************
    DATE.MASK = "R#10"
    TIME.MASK = "R#10"
    ELAPSED.MASK = "R,4#12"
    DESC.MASK = "L#30"

    TEXT.LINE = ""
    TEXT = ""
    TEXT.COUNT = 0

    TEXT.LINE := "" DESC.MASK:" ":"           Compile processing times"
    GOSUB ADD.TEXT

    GOSUB ADD.TEXT

    TEXT.LINE := "" DESC.MASK:" ":"StartDate. StartTime. EndDate... EndTime... "
    TEXT.LINE := "ElapsedSec.. Notes..................................."
    GOSUB ADD.TEXT

    GOSUB ADD.TEXT

* main initialization time
    TEXT.LINE := "Main Initialization" DESC.MASK:" "
    TEXT.LINE := OCONV(MAIN.INIT.START.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(MAIN.INIT.START.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := OCONV(MAIN.INIT.END.DATE, "D4/") TIME.MASK:" "
    TEXT.LINE := OCONV(MAIN.INIT.END.TIME, "MTHS") DATE.MASK:" "
    TEXT.LINE := MAIN.INIT.ELAPSED.TIME ELAPSED.MASK
    GOSUB ADD.TEXT

* initialization time
    TEXT.LINE := "Method Initialization" DESC.MASK:" "
    TEXT.LINE := OCONV(INIT.START.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(INIT.START.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := OCONV(INIT.END.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(INIT.END.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := INIT.ELAPSED.TIME ELAPSED.MASK
    GOSUB ADD.TEXT

* shortcut loading time time
    TEXT.LINE := "Shortcut/Macro Loading" DESC.MASK:" "
    TEXT.LINE := OCONV(SHORTCUT.LOAD.START.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(SHORTCUT.LOAD.START.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := OCONV(SHORTCUT.LOAD.END.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(SHORTCUT.LOAD.END.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := SHORTCUT.LOAD.ELAPSED.TIME ELAPSED.MASK
    GOSUB ADD.TEXT

    GOSUB ADD.TEXT

* time spent in clean.line.  this time will also be part of the compilation
* times listed below so we'll break it out into its own section
    TEXT.LINE := "Code Line Cleaning" DESC.MASK:" "
    TEXT.LINE := OCONV(CLEAN.LINE.START.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(CLEAN.LINE.START.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := OCONV(CLEAN.LINE.END.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(CLEAN.LINE.END.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := CLEAN.LINE.ELAPSED.TIME ELAPSED.MASK:" "
    TEXT.LINE := CLEAN.LINE.COUNT "L,":" lines"
    IF CLEAN.LINE.COUNT > 0 THEN
        DISPLAY.TIME = CLEAN.LINE.ELAPSED.TIME / CLEAN.LINE.COUNT * 1000
        TEXT.LINE := ", ":DISPLAY.TIME "L4":" ms/line"
    END
    GOSUB ADD.TEXT

    GOSUB ADD.TEXT

* total compilation time
    IF COMPILE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "Total Compilation" DESC.MASK:" "
        TEXT.LINE := OCONV(COMPILE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(COMPILE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(COMPILE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(COMPILE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := COMPILE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

* method building time
    IF TABLE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Table Builds" DESC.MASK:" "
        TEXT.LINE := OCONV(TABLE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(TABLE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(TABLE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(TABLE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := TABLE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* method building time
    IF METHOD.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Method List Build" DESC.MASK:" "
        TEXT.LINE := OCONV(METHOD.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(METHOD.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(METHOD.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(METHOD.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := METHOD.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* property list building time
    IF PROPERTY.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Property List Build" DESC.MASK:" "
        TEXT.LINE := OCONV(PROPERTY.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(PROPERTY.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(PROPERTY.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(PROPERTY.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := PROPERTY.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* constant list building time
    IF CONSTANT.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Constant List Build" DESC.MASK:" "
        TEXT.LINE := OCONV(CONSTANT.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONSTANT.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(CONSTANT.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONSTANT.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := CONSTANT.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* child list building time
    IF CHILD.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Child List Build" DESC.MASK:" "
        TEXT.LINE := OCONV(CHILD.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CHILD.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(CHILD.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CHILD.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := CHILD.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

    IF TABLE.ELAPSED.TIME <> 0 THEN
        GOSUB ADD.TEXT
    END

* other code scanning time
    IF SCAN.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Outside Code Scans" DESC.MASK:" "
        TEXT.LINE := OCONV(SCAN.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SCAN.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(SCAN.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SCAN.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := SCAN.ELAPSED.TIME ELAPSED.MASK:" "
        TEXT.LINE := SCAN.COUNT "L,":" objects scanned"
        IF SCAN.COUNT > 0 THEN
            DISPLAY.TIME = INT(SCAN.ELAPSED.TIME / SCAN.COUNT * 1000 * 10 + .5) / 10
            TEXT.LINE := ", ":DISPLAY.TIME "L1":" ms/obj"
        END
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

* line unwrapping time
    IF UNWRAP.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Line Unwrapping" DESC.MASK:" "
        TEXT.LINE := OCONV(UNWRAP.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(UNWRAP.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(UNWRAP.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(UNWRAP.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := UNWRAP.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* inline option scan time
    IF OPTION.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Inline Option Scan" DESC.MASK:" "
        TEXT.LINE := OCONV(OPTION.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(OPTION.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(OPTION.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(OPTION.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OPTION.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* initialize method build time
    IF STARTUP.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Init Method Code" DESC.MASK:" "
        TEXT.LINE := OCONV(STARTUP.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(STARTUP.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(STARTUP.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(STARTUP.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := STARTUP.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* method creation time
    IF INSTANCE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Create Instance Code" DESC.MASK:" "
        TEXT.LINE := OCONV(INSTANCE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(INSTANCE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(INSTANCE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(INSTANCE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := INSTANCE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* method creation time
    IF CREATE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Create Method Code" DESC.MASK:" "
        TEXT.LINE := OCONV(CREATE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CREATE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(CREATE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CREATE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := CREATE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

* code conversion time
    IF CONVERT.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Code Conversion" DESC.MASK:" "
        TEXT.LINE := OCONV(CONVERT.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONVERT.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(CONVERT.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONVERT.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := CONVERT.ELAPSED.TIME ELAPSED.MASK:" "
        GOSUB ADD.TEXT
    END

* convert object creation lines
    IF OBJ.CREATE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Object Creation Code" DESC.MASK:" "
        TEXT.LINE := OCONV(OBJ.CREATE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(OBJ.CREATE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(OBJ.CREATE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(OBJ.CREATE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OBJ.CREATE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* ASSOC conversion time
    IF ASSOC.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Associations" DESC.MASK:" "
        TEXT.LINE := OCONV(ASSOC.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(ASSOC.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(ASSOC.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(ASSOC.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := ASSOC.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* unary functions conversion time
    IF UNARY.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Unary Functions" DESC.MASK:" "
        TEXT.LINE := OCONV(UNARY.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(UNARY.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(UNARY.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(UNARY.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := UNARY.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* shortcut conversion time
    IF SHORTCUT.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Shortcuts" DESC.MASK:" "
        TEXT.LINE := OCONV(SHORTCUT.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SHORTCUT.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(SHORTCUT.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SHORTCUT.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := SHORTCUT.ELAPSED.TIME ELAPSED.MASK:" "
        TEXT.LINE := TOTAL.SHORTCUTS.CONVERTED "L,":" shortcuts converted"
        IF TOTAL.SHORTCUTS.CONVERTED > 0 THEN
            DISPLAY.TIME = INT(SHORTCUT.ELAPSED.TIME / TOTAL.SHORTCUTS.CONVERTED * 1000 * 10 + .5) / 10
            TEXT.LINE := ", ":DISPLAY.TIME "L1":" ms/shortcut"
        END
        GOSUB ADD.TEXT
    END

* macro conversion time
    IF MACRO.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Macros" DESC.MASK:" "
        TEXT.LINE := OCONV(MACRO.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(MACRO.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(MACRO.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(MACRO.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := MACRO.ELAPSED.TIME ELAPSED.MASK:" "
        TEXT.LINE := TOTAL.MACROS.CONVERTED "L,":" macros converted"
        IF TOTAL.MACROS.CONVERTED > 0 THEN
            DISPLAY.TIME = INT(MACRO.ELAPSED.TIME / TOTAL.MACROS.CONVERTED * 1000 * 10 + .5) / 10
            TEXT.LINE := ", ":DISPLAY.TIME "L1":" ms/macro"
        END
        GOSUB ADD.TEXT
    END

* usage table building time
    IF USAGE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Usage Tables" DESC.MASK:" "
        TEXT.LINE := OCONV(USAGE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(USAGE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(USAGE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(USAGE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := USAGE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* brace conversion time
    IF BRACE.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Brace Conversions" DESC.MASK:" "
        TEXT.LINE := OCONV(BRACE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(BRACE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(BRACE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(BRACE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := BRACE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* short gosub conversion time
    IF GOSUB.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Short Gosubs" DESC.MASK:" "
        TEXT.LINE := OCONV(GOSUB.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(GOSUB.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(GOSUB.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(GOSUB.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := GOSUB.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* common variable table build time
    IF COMMON.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Common Variable Table" DESC.MASK:" "
        TEXT.LINE := OCONV(COMMON.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(COMMON.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(COMMON.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(COMMON.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := COMMON.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* literal text conversion time
    IF LITERAL.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Literal Text Conversions" DESC.MASK:" "
        TEXT.LINE := OCONV(LITERAL.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(LITERAL.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(LITERAL.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(LITERAL.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := LITERAL.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
    END

* object call conversion time
    IF CONVERT.CALL.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "        Call Conversions" DESC.MASK:" "
        TEXT.LINE := OCONV(CONVERT.CALL.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONVERT.CALL.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(CONVERT.CALL.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(CONVERT.CALL.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := CONVERT.CALL.ELAPSED.TIME ELAPSED.MASK:" "
        TEXT.LINE := CONVERT.LINE.COUNT "L,":" lines converted"
        IF CONVERT.LINE.COUNT > 0 THEN
            DISPLAY.TIME = INT(CONVERT.CALL.ELAPSED.TIME / CONVERT.LINE.COUNT * 1000 * 10 + .5) / 10
            TEXT.LINE := ", ":DISPLAY.TIME "L1":" ms/line"
        END
        GOSUB ADD.TEXT
    END

* object saving time
    IF SAVE.ELAPSED.TIME <> 0 THEN

        GOSUB ADD.TEXT

        TEXT.LINE := "    Saving" DESC.MASK:" "
        TEXT.LINE := OCONV(SAVE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SAVE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(SAVE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(SAVE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := SAVE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT

        IF USE.ECLIPSE.VERSION.UPDATES THEN
            STAMP.DESCRIPTION = "        Eclipse Stamping"
        END ELSE
            STAMP.DESCRIPTION = "        Manual Stamping"
        END

        TEXT.LINE := STAMP.DESCRIPTION DESC.MASK:" "
        TEXT.LINE := OCONV(STAMP.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(STAMP.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(STAMP.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(STAMP.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := STAMP.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT

        TEXT.LINE := "        Reformatting" DESC.MASK:" "
        TEXT.LINE := OCONV(REFORMAT.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(REFORMAT.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(REFORMAT.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(REFORMAT.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := REFORMAT.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT

        TEXT.LINE := "        Writing" DESC.MASK:" "
        TEXT.LINE := OCONV(WRITE.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(WRITE.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(WRITE.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(WRITE.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := WRITE.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT

    END

    IF DOT.NET.ELAPSED.TIME <> 0 OR JAVA.ELAPSED.TIME <> 0 THEN
        GOSUB ADD.TEXT
    END

    IF DOT.NET.ELAPSED.TIME <> 0 THEN

        TEXT.LINE := "    DotNet Creation" DESC.MASK:" "
        TEXT.LINE := OCONV(DOT.NET.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(DOT.NET.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(DOT.NET.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(DOT.NET.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := DOT.NET.ELAPSED.TIME ELAPSED.MASK:" "
        IF DOT.NET.COUNT > 0 THEN
            DISPLAY.TIME = INT(DOT.NET.ELAPSED.TIME / DOT.NET.COUNT * 1000 * 10 + .5) / 10
            TEXT.LINE := DOT.NET.COUNT:" classes, ":DISPLAY.TIME "L1":" ms/class"
        END
        GOSUB ADD.TEXT

    END

    IF JAVA.ELAPSED.TIME <> 0 THEN

        TEXT.LINE := "    Java Creation" DESC.MASK:" "
        TEXT.LINE := OCONV(JAVA.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(JAVA.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(JAVA.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(JAVA.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := JAVA.ELAPSED.TIME ELAPSED.MASK:" "
        IF JAVA.COUNT > 0 THEN
            DISPLAY.TIME = INT(JAVA.ELAPSED.TIME / JAVA.COUNT * 1000 * 10 + .5) / 10
            TEXT.LINE := JAVA.COUNT:" classes, ":DISPLAY.TIME "L1":" ms/class"
        END
        GOSUB ADD.TEXT

    END

    IF CONVERT.ELAPSED.TIME <> 0 THEN
        GOSUB ADD.TEXT
    END

* BA compile time
    IF BA.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Eclipse / Uv Compilation" DESC.MASK:" "
        TEXT.LINE := OCONV(BA.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(BA.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(BA.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(BA.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := BA.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

* time spent checking for abort
    IF ABORT.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Checking for Abort" DESC.MASK:" "
        TEXT.LINE := "" DATE.MASK:" "
        TEXT.LINE := "" TIME.MASK:" "
        TEXT.LINE := "" DATE.MASK:" "
        TEXT.LINE := "" TIME.MASK:" "
        TEXT.LINE := ABORT.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

* total compilation time
    TEXT.LINE := "Total" DESC.MASK:" "
    TEXT.LINE := OCONV(TOTAL.START.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(TOTAL.START.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := OCONV(TOTAL.END.DATE, "D4/") DATE.MASK:" "
    TEXT.LINE := OCONV(TOTAL.END.TIME, "MTHS") TIME.MASK:" "
    TEXT.LINE := TOTAL.ELAPSED.TIME ELAPSED.MASK
    GOSUB ADD.TEXT

    GOSUB ADD.TEXT

    IF MISC.ELAPSED.TIME <> 0 THEN
        TEXT.LINE := "    Misc" DESC.MASK:" "
        TEXT.LINE := OCONV(MISC.START.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(MISC.START.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := OCONV(MISC.END.DATE, "D4/") DATE.MASK:" "
        TEXT.LINE := OCONV(MISC.END.TIME, "MTHS") TIME.MASK:" "
        TEXT.LINE := MISC.ELAPSED.TIME ELAPSED.MASK
        GOSUB ADD.TEXT
        GOSUB ADD.TEXT
    END

    UD.VIEW.TEXT TEXT, 0, 0, OBJECT.FILENAME, OBJECT.NAME

    RETURN

START.MISC.TIME: *********************************************************
* set the starting "misc" time for timing a section of code for          *
* debugging                                                              *
**************************************************************************
    MISC.START.DATE = DATE()
    MISC.START.TIME = TIME()

    RETURN

END.MISC.TIME: ***********************************************************
* end a period of "misc" time for timing a section of code for debugging *
**************************************************************************
    MISC.END.DATE = DATE()
    MISC.END.TIME = TIME()

    MISC.ELAPSED.TIME += TIME.ELAPSED (MISC.START.DATE, MISC.START.TIME)

    RETURN

ADD.TEXT: ****************************************************************
* add text.line to text                                                  *
**************************************************************************
    TEXT.COUNT += 1
    TEXT<TEXT.COUNT> = TEXT.LINE
    TEXT.LINE = ""

    RETURN

REPORT.SINGLE.PROCESSED: *************************************************
* display a final progress report for when only one thing has been       *
* compiled                                                               *
**************************************************************************
    IF OBJECT.COUNT <> 1 THEN
        RETURN
    END 

    IF ERROR.LIST.COUNT = 0 AND WARNING.LIST.COUNT = 0 THEN

        GOSUB PRINT.SUCCESS.MESSAGE

        IF COMPILE.OBJECT THEN
            SPEECH = "Compile successful"
            GOSUB MAYBE.WAIT.AND.SPEAK
            PRINT
        END

    END ELSE

        SPEECH = "Compile has errors"
        GOSUB SPEAK

        BEGIN CASE
            CASE ERROR.LIST.COUNT <> 0 AND WARNING.LIST.COUNT <> 0
                SPEECH = ERROR.LIST.COUNT:" errors and ":WARNING.LIST.COUNT:" warnings."
            CASE ERROR.LIST.COUNT <> 0
                SPEECH = ERROR.LIST.COUNT:" errors."
            CASE WARNING.LIST.COUNT <> 0
                SPEECH = WARNING.LIST.COUNT:" warnings."
        END CASE
        GOSUB WAIT.AND.SPEAK

    END

    PRINT
    
    RETURN

REPORT.MULTIPLE.PROCESSED: ***********************************************
* display a final process report for when more than one thing is         *
* compiled                                                               *
**************************************************************************

* display number of routines, lines and bytes exported
    IF NOT(BRIEF) AND GRAND.TOTAL.COMPILED > 0 THEN

        PRINT
        PRINT GRAND.TOTAL.COMPILED "L,":" ":COMPILED.NAME:"s ":
        IF COMPILE.OBJECT OR COMPILE.SUBROUTINE THEN
            PRINT "exported/":
        END
        PRINT VERB:

        IF SHOW.LINE.COUNTS THEN
            PRINT ", ":
            PRINT GRAND.TOTAL.LINES "L,":" lines, ":
            PRINT GRAND.TOTAL.BYTES "L,":" bytes."
        END ELSE
            IF GOOD.COMPILE.COUNT = GRAND.TOTAL.COMPILED THEN
                PRINT " successfully."
            END
        END

        PRINT
        GOSUB PRINT.SUCCESS.MESSAGE

        SPEECH = GRAND.TOTAL.COMPILED:" ":COMPILED.NAME:"s compiled successfully"
        GOSUB MAYBE.WAIT.AND.SPEAK

    END

* display a happy message if everything compiled cleanly
    IF GOOD.COMPILE.COUNT = GRAND.TOTAL.COMPILED THEN

        IF SHOW.LINE.COUNTS THEN

            PRINT
            PRINT "All ":COMPILED.NAME:"s ":VERB:" successfully."

            SPEECH = "All ":COMPILED.NAME:"s ":VERB:" successfully"
            GOSUB MAYBE.WAIT.AND.SPEAK

        END

    END ELSE

        PRINT
        PRINT GOOD.COMPILE.COUNT "L,":" ":COMPILED.NAME:"s ":VERB:" successfully."

        SPEECH = GOOD.COMPILE.COUNT:" ":COMPILED.NAME:"s ":VERB:" successfully"
        GOSUB MAYBE.WAIT.AND.SPEAK

    END

* sad message if some didn't compile
    IF BAD.COMPILE.COUNT > 0 THEN

        PRINT
        PRINT BAD.COMPILE.COUNT "L,":" ":COMPILED.NAME:"s had errors:"

        FOR BAD.LOOP = 1 TO BAD.COMPILE.COUNT
            PRINT "    ":BAD.COMPILE.LIST<BAD.LOOP>
        NEXT BAD.LOOP

        SPEECH = BAD.COMPILE.COUNT:" ":COMPILED.NAME:"s had errors"
        GOSUB WAIT.AND.SPEAK

    END

* if we had errors display a count of all errors encountered this compile
* session
    IF GRAND.TOTAL.ERRORS <> 0 OR GRAND.TOTAL.WARNINGS <> 0 THEN

        PRINT

        IF GRAND.TOTAL.ERRORS > 0 THEN

            PRINT GRAND.TOTAL.ERRORS "L,":" total errors."

            SPEECH = GRAND.TOTAL.ERRORS:" total errors."
            GOSUB SPEAK

        END

        IF GRAND.TOTAL.WARNINGS > 0 THEN

            PRINT GRAND.TOTAL.WARNINGS "L,":" total warnings."

            SPEECH = GRAND.TOTAL.WARNINGS:" total warnings."
            GOSUB SPEAK

        END

    END

    PRINT

    RETURN

PRINT.SUCCESS.MESSAGE: ***************************************************
* print a message to the screen indicating a successful compile.         *
*                                                                        *
* note:  this message HAS to be printed for a successful compile.  don't *
* change the message, case, punctuation, or anything.  many processes    *
* run the compiler in an "execute" and look for this string to know that *
* the compile finished successfully or had errors.  change this message  *
* and it will cause problems with these processes!                       *
**************************************************************************
    PRINT "Compilation Successful"

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines                                    **
**************************************************************************
**************************************************************************

PRECOMPILE.OBJECT: *******************************************************
* compile a single object into multiple cbp subroutines.  this is a      *
* wrapper for the compile object / compile program using objects /       *
* compile program routines                                               *
**************************************************************************
    GOSUB INITIALIZE

    STARTUP.START.DATE = DATE()
    STARTUP.START.TIME = TIME()

* reload settings in case any were changed for this object
    GOSUB RELOAD.IF.CHANGED

* find the program file to use for this object
    GOSUB GET.OBJECT.FILENAME

    IF OBJECT.FILENAME = "" OR ABORT.PROGRAM THEN

        ABORT.PROGRAM = @FALSE

        IF NOT(BRIEF) THEN
            PRINT OBJECT.NAME:" does not exist"
        END

        SPEECH = "Warning: ":OBJECT.NAME:" does not exist"
        GOSUB SPEAK

        RETURN

    END

    GOSUB ANNOUNCE.COMPILED.OBJECT

* fetch the code to compile
    GOSUB GET.OBJECT

* if code is missing don't continue
    IF NOT(OBJECT.EXISTS) THEN

        IF NOT(BRIEF) THEN
            PRINT DOWNCASE(OBJECT.FILENAME):" ":DOWNCASE(OBJECT.NAME):" does not exist"
        END

        SPEECH = "Warning: ":OBJECT.FILENAME:" ":OBJECT.NAME:" does not exist"
        GOSUB SPEAK

        RETURN

    END

* update the last program list.  if we're only listing objects don't update
* this list
    IF NOT(LIST.OBJECTS.ONLY) AND ADD.TO.LAST.LIST THEN
        PROGRAM.FILE = OBJECT.FILENAME
        PROGRAM.NAME = OBJECT.NAME
        GOSUB UPDATE.LAST.PROGRAM.LIST
    END

    STARTUP.END.DATE = DATE()
    STARTUP.END.TIME = TIME()
    STARTUP.ELAPSED.TIME += TIME.ELAPSED (STARTUP.START.DATE, STARTUP.START.TIME)

* if line wrapping is enabled unwrap wrapped lines.  if we're doing listings
* leave everything unwrapped
    IF LINE.WRAPPING AND (COMPILE.OBJECT OR COMPILE.SUBROUTINE) THEN
        GOSUB UNWRAP.LINES
    END

* save the original object code after the cleanup
    ORIGINAL.POST.CLEANUP.OBJECT.CODE = OBJECT.CODE

* get first-line options
    GOSUB GET.OPTIONS

* display what we're doing if we're compiling a program.  if we're just
* listing methods we don't need this
    IF NOT(LIST.METHODS) AND NOT(SHORTCUT.LIST) THEN

* if we're compiling an object and we're compile the entire object (not
* just one method) delete cbp and oc versions and decatalog them if set to
* do so
        IF COMPILE.OBJECT AND OBJECT.METHOD = "" THEN
            GOSUB DELETE.CBP.VERSIONS
        END

* when compiling multiple object for a select method put a break between
* object::methods
        IF SELECT.METHOD <> "" THEN
            PRINT
        END

* display what we're working on
        BEGIN CASE

* if we have a cbp or a core program and we're not supposed to compile them
* return without doing anything
            CASE COMPILE.CBP AND NOT(COMPILE.CBP.PROGRAMS)
                RETURN
            CASE COMPILE.CORE AND NOT(COMPILE.CORE.PROGRAMS)
                RETURN

            CASE BRIEF
                NULL

        END CASE

* add a break for second and later compiles
        IF NOT(BRIEF) AND OBJECT.LOOP > 1 THEN
            PRINT
        END

        BEGIN CASE

* if we're just doing an objects listing just show the source name
            CASE LIST.OBJECTS.ONLY
                PRINT "Program:"

* objects
            CASE COMPILE.OBJECT AND OBJECT.METHOD = ""
                PRINT "Exporting object ":
            CASE COMPILE.OBJECT
                PRINT "Exporting method ":

* object-enabled subroutines
            CASE COMPILE.SUBROUTINE
                PRINT "Exporting subroutine ":

* cbp programs
            CASE COMPILE.CBP AND COMPILE.CBP.PROGRAMS
                PRINT "Compiling CBP subroutine ":

* core programs
            CASE COMPILE.CORE AND COMPILE.CORE.PROGRAMS AND OBJECT.FILENAME = "SCREEN"
                PRINT "Compiling Screen ":
            CASE COMPILE.CORE AND COMPILE.CORE.PROGRAMS AND OBJECT.FILENAME = "MENUS"
                PRINT "Compiling Menu ":
            CASE COMPILE.CORE AND COMPILE.CORE.PROGRAMS AND OBJECT.FILENAME = "CMP"
                PRINT "Compiling Cmp ":
            CASE COMPILE.CORE AND COMPILE.CORE.PROGRAMS
                PRINT "Compiling ":OBJECT.FILENAME:" subroutine ":

        END CASE

        IF NOT(BRIEF) THEN

            BEGIN CASE

                CASE COMPILE.CORE
                    PRINT OBJECT.NAME:

                CASE COMPILE.CBP
                    PRINT OBJECT.NAME:

                CASE UPCASE.CODE AND COMPILE.OBJECT
                    PRINT DOWNCASE(OBJECT.NAME):
                CASE UPCASE.CODE AND COMPILE.SUBROUTINE
                    PRINT DOWNCASE(OBJECT.NAME):

                CASE COMPILE.OBJECT
                    PRINT OBJECT.NAME:
                CASE COMPILE.SUBROUTINE
                    PRINT OBJECT.NAME:

                CASE 1
                    PRINT OBJECT.FILENAME:" ":OBJECT.NAME:

            END CASE

* display for compiling a single method of an object
            BEGIN CASE

                CASE UPCASE.CODE AND COMPILE.OBJECT AND OBJECT.METHOD <> "" AND NOT(LIST.OBJECTS.ONLY)
                    PRINT METHOD.DELIMITER:DOWNCASE(OBJECT.METHOD):

                CASE COMPILE.OBJECT AND OBJECT.METHOD <> "" AND NOT(LIST.OBJECTS.ONLY)
                    PRINT METHOD.DELIMITER:OBJECT.METHOD:

            END CASE

* if compiling multiple objects show count of current object
            IF OBJECT.COUNT > 1 THEN
                PRINT " (":OBJECT.LOOP:" of ":OBJECT.COUNT:")":
            END

            IF NOT(LIST.OBJECTS.ONLY) THEN
                PRINT ":":
            END

            PRINT

        END

    END

* there was an error with the code
    IF OBJECT.ERROR THEN
        RETURN
    END

* if we're compiling an object explode it out into all its subroutines
    BEGIN CASE

* if we're listing methods we aren't compiling anything, we're just
* listing things out
        CASE LIST.METHODS
            GOSUB LIST.METHODS

* list shortcuts
        CASE SHORTCUT.LIST
            GOSUB SHORTCUT.LIST

* we have an object with methods and things
        CASE COMPILE.OBJECT
            GOSUB PROCESS.OBJECT

* we have a subroutine that may be using objects
        CASE COMPILE.SUBROUTINE
            GOSUB PROCESS.SUBROUTINE

* we have an OC item.  check it for errors
        CASE COMPILE.OC
            GOSUB PROCESS.OC

* we have a cbp routine.  it can't use objects, we just want to to pass
* it on to ba
        CASE COMPILE.CBP
            GOSUB PROCESS.CBP

* core routine.  it also won't use objects so we pass it on to ba
        CASE COMPILE.CORE
            GOSUB PROCESS.CORE

    END CASE

* if processing this routine created in wrappers process them now. 
    IF WRAPPER.CREATE.COUNT > 0 THEN
        GOSUB PROCESS.ALL.WRAPPERS
    END

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / objects                          **
**************************************************************************
**************************************************************************

PROCESS.OBJECT: **********************************************************
* compile object.text as an object                                       *
**************************************************************************

* check for usage of thrown errors
    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES
    GOSUB CHECK.THROWN.ERRORS

* build tables and common code
    GOSUB BUILD.OBJECT.TABLES

    GOSUB BUILD.SHARED.COMMON.CODE

    IF ALLOW.EXPANDING.INSTANCES AND MAX.INSTANCES > 1 THEN
        GOSUB BUILD.REDIM.CODE
    END

    IF CHECK.METHOD.PARAMETER.PROPERTY THEN
        GOSUB CHECK.METHOD.PARAMETERS
    END

    GOSUB CHECK.OBJECT.LISTS

    GOSUB BUILD.COMPILE.TABLE
    GOSUB UPDATE.COMMON.CHECKSUM

    IF USE.EXTERNAL.REDIM THEN
        GOSUB UPDATE.REDIM.CHECKSUM
    END

    GOSUB FIND.NEW.CHECKSUMS

    METHOD = ""
    GOSUB BUILD.INSTANCE.CODE

    IF DETAILS THEN
        PRINT
        PRINT "Creating Default Methods"
    END

* build default methods if they need to be recompiled
    GOSUB PROCESS.NEW.METHODS
    GOSUB PROCESS.DEFAULT.METHODS
    GOSUB PROCESS.USER.METHODS
    GOSUB PROCESS.LIST.METHODS

* if compiling in parallel mode wait for the compiling phantoms to finish
    IF PARALLEL.MODE THEN
        GOSUB WAIT.FOR.PARALLEL.COMPILES
        GOSUB DELETE.PARALLEL.COMOS
    END

    GOSUB PROCESS.OBJECT.SUMMARY

* if this is an object update the object text with the compile table
* and save it back to the obj file if we're saving the cbp
    IF NOT(LIST.OBJECTS.ONLY) AND SAVE.CBPS THEN

        IF UPDATE.COMPILE.TABLE.IN.CODE THEN
            GOSUB SAVE.COMPILE.TABLE
        END

        IF UPDATE.COMPILE.TABLE.IN.FILE THEN
            GOSUB SAVE.COMPILE.TABLE.IN.FILE
        END

    END

* set permissions for the source program
    PERMIT.FILE = "OBJ"
    PERMIT.ITEM = OBJECT.NAME
    GOSUB SET.PERMISSIONS

    RETURN

PROCESS.NEW.METHODS: *****************************************************
* process the new and short new methods for the object                   *
**************************************************************************
    NEW.CHANGED = @FALSE

* new method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = NEW.KEYWORD THEN

        THIS.METHOD = NEW.KEYWORD
        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN

            NEW.CHANGED = @TRUE

            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.NEW.METHOD
            GOSUB AFTER.METHOD.BUILD

        END

    END


* short new method.  the short new method will be rebuilt any time the
* new method needs to be recompiled
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = NEW.SHORT.KEYWORD OR OBJECT.METHOD = NEW.KEYWORD OR NEW.CHANGED THEN

* if the new method needed to be compiled recompile the short new method
        NEED.COMPILE = NEW.CHANGED

        THIS.METHOD = NEW.SHORT.KEYWORD

        IF NOT(NEED.COMPILE) THEN
            GOSUB CHECK.NEED.COMPILE
        END

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.NEW.SHORT.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END

    RETURN

PROCESS.DEFAULT.METHODS: *************************************************
* process all default methods for the object                             *
**************************************************************************

* destroy method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = DESTROY.KEYWORD THEN

        THIS.METHOD = DESTROY.KEYWORD

        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.DESTROY.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END

* reset method.  if the "new" method was recompiled the "reset" will
* always be recompiled as it contains the "new" user code.  if this
* object has no properties we won't create this method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = RESET.KEYWORD THEN

        IF PROPERTIES.EXIST THEN

            THIS.METHOD = RESET.KEYWORD
            GOSUB CHECK.NEED.COMPILE

            IF NOT(NEED.COMPILE) THEN

                THIS.METHOD = NEW.KEYWORD
                GOSUB CHECK.NEED.COMPILE

                THIS.METHOD = RESET.KEYWORD

            END

            IF PARALLEL.MODE AND NEED.COMPILE THEN
                GOSUB COMPILE.IN.PARALLEL
                NEED.COMPILE = @FALSE
            END

            IF NEED.COMPILE THEN

                GOSUB RELOAD.IF.CHANGED

* if we're building the "reset" method we also need to make sure we processed
* options lines for the "new" method as this code will be included with the
* "reset" method.  if the "new" or "short.new" methods were created they've
* commented out any option lines in object.code.  we need them uncommented for
* our check so we'll reset object.code to original.object.code
                OBJECT.CODE = ORIGINAL.POST.CLEANUP.OBJECT.CODE

* process options from the "new" method code
                THIS.METHOD = NEW.KEYWORD
                GOSUB GET.METHOD.RANGE
                GOSUB PROCESS.OPTION.LINES
                THIS.METHOD = RESET.KEYWORD

* process options for the "reset" method
                GOSUB GET.METHOD.RANGE
                GOSUB PROCESS.OPTION.LINES

                GOSUB CREATE.RESET.METHOD

                GOSUB AFTER.METHOD.BUILD

            END

            GOSUB CHECK.ABORT

        END

    END


* get properties
    IF (OBJECT.METHOD = "" OR OBJECT.METHOD = GET.KEYWORD) AND PROPERTIES.EXIST THEN

        THIS.METHOD = GET.KEYWORD

        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.GET.PROPERTY.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END


* save properties
    IF (OBJECT.METHOD = "" OR OBJECT.METHOD = PUT.KEYWORD) AND PROPERTIES.EXIST THEN

        THIS.METHOD = PUT.KEYWORD

        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.PUT.PROPERTY.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END


* copy object instance.  if the object has no properties we won't ceate
* this method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = COPY.OBJECT.KEYWORD THEN

        IF PROPERTIES.EXIST THEN

            THIS.METHOD = COPY.OBJECT.KEYWORD

            GOSUB CHECK.NEED.COMPILE

            IF NEED.COMPILE THEN
                GOSUB BEFORE.METHOD.BUILD
                GOSUB CREATE.COPY.OBJECT.METHOD
                GOSUB AFTER.METHOD.BUILD
            END

            GOSUB CHECK.ABORT

        END

    END


* get property by name method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = GET.PROPERTY.BY.NAME.KEYWORD THEN

        THIS.METHOD = GET.PROPERTY.BY.NAME.KEYWORD

        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.GET.PROPERTY.BY.NAME.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END


* put property by name method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = PUT.PROPERTY.BY.NAME.KEYWORD THEN

        THIS.METHOD = PUT.PROPERTY.BY.NAME.KEYWORD

        GOSUB CHECK.NEED.COMPILE

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.PUT.PROPERTY.BY.NAME.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END

* if we're using an external redimensioning routine we'll build
* it as an external subroutine.  allow.expanding.instances must be
* set and the object can't be a single-instance object
    IF USE.EXTERNAL.REDIM AND PROPERTIES.EXIST THEN
        IF OBJECT.METHOD = "" OR OBJECT.METHOD = REDIM.KEYWORD THEN
            IF ALLOW.EXPANDING.INSTANCES AND MAX.INSTANCES > 1 THEN

                THIS.METHOD = REDIM.KEYWORD
                GOSUB CHECK.NEED.COMPILE

                IF NEED.COMPILE THEN
                    GOSUB BEFORE.METHOD.BUILD
                    GOSUB CREATE.REDIM.METHOD
                    GOSUB AFTER.METHOD.BUILD
                END

            END
        END
    END

    RETURN

PROCESS.USER.METHODS: ****************************************************
* process all user methods for the object                                *
**************************************************************************
    IF DETAILS THEN
        PRINT
        PRINT "Creating ":METHOD.COUNT:" User Methods"
    END

    USER.METHOD.CHANGED = @FALSE

    FOR CREATE.METHOD.LOOP = 1 TO METHOD.COUNT

        METHOD = METHOD.LIST<CREATE.METHOD.LOOP>

        IF OBJECT.METHOD = "" OR OBJECT.METHOD = METHOD THEN

            THIS.METHOD = METHOD
            THIS.INHERITED = METHOD.INHERIT.LIST<CREATE.METHOD.LOOP>

            GOSUB CHECK.NEED.COMPILE

            IF NEED.COMPILE THEN

                GOSUB BEFORE.METHOD.BUILD
                GOSUB CREATE.METHOD

                IF METHOD.CREATED THEN

* build the eclipse subroutine name for the cbp version of this
* this method.  we'll write the cbp code to this program name
                    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
                    GOSUB AFTER.METHOD.BUILD

                    USER.METHOD.CHANGED = @TRUE

                END

                GOSUB CHECK.ABORT

            END

        END

    NEXT CREATE.METHOD.LOOP

    RETURN

PROCESS.LIST.METHODS: ****************************************************
* process default methods that return lists of methods / properties      *
**************************************************************************

* get property list method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = GET.PROPERTY.LIST.KEYWORD OR NEW.CHANGED THEN

        THIS.METHOD = GET.PROPERTY.LIST.KEYWORD

* if the new method was recomiled the property list may have changed
        NEED.COMPILE = NEW.CHANGED

        IF NOT(NEED.COMPILE) THEN
            GOSUB CHECK.NEED.COMPILE
        END

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.GET.PROPERTY.LIST.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END


* get method list method
    IF OBJECT.METHOD = "" OR OBJECT.METHOD = GET.METHOD.LIST.KEYWORD OR USER.METHOD.CHANGED THEN

        THIS.METHOD = GET.METHOD.LIST.KEYWORD

* if any user methods were changed or created recompile the get method list
* method
        NEED.COMPILE = USER.METHOD.CHANGED

        IF NOT(NEED.COMPILE) THEN
            GOSUB CHECK.NEED.COMPILE
        END

        IF NEED.COMPILE THEN
            GOSUB BEFORE.METHOD.BUILD
            GOSUB CREATE.GET.METHOD.LIST.METHOD
            GOSUB AFTER.METHOD.BUILD
        END

    END

    RETURN

BEFORE.METHOD.BUILD: *****************************************************
* initialize before building a method                                    *
**************************************************************************
    IF PARALLEL.MODE THEN
        GOSUB COMPILE.IN.PARALLEL
        NEED.COMPILE = @FALSE
        RETURN
    END

    GOSUB RELOAD.IF.CHANGED
    GOSUB GET.METHOD.RANGE
    GOSUB PROCESS.OPTION.LINES

    RETURN

AFTER.METHOD.BUILD: ******************************************************
* finish up after building a method                                      *
**************************************************************************
    GOSUB SAVE.METHOD

    PERMIT.FILE = TARGET.FILENAME
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

    GOSUB CREATE.SPLIT.METHOD.VERSION

    GOSUB CHECK.ABORT

    RETURN

PROCESS.OBJECT.SUMMARY: **************************************************
* print a summary of object methods processed                            *
**************************************************************************
    BEGIN CASE

        CASE BRIEF
            NULL

        CASE LIST.OBJECTS.ONLY
            NULL

        CASE NOT(ALWAYS.RECOMPILE.METHODS) AND METHOD.CREATE.COUNT = 0
            PRINT "No new or changed Methods in Object."
            PRINT

            SPEECH = "No new or changed Methods in Object"
            GOSUB MAYBE.WAIT.AND.SPEAK

        CASE NOT(SAVE.CBPS)
            PRINT
            PRINT "No methods exported, SaveCBPs is disabled."

            SPEECH = "No methods exported.  Save is disabled"
            GOSUB MAYBE.WAIT.AND.SPEAK

        CASE 1
            PRINT
            PRINT METHOD.CREATE.COUNT:" Method":
            IF METHOD.CREATE.COUNT <> 1 THEN
                PRINT "s":
            END
            PRINT " exported to ":TARGET.FILENAME:" subroutines":

            IF SHOW.LINE.COUNTS THEN
                PRINT ", ":
                PRINT METHOD.LINE.COUNT "L,":" lines, ":
                PRINT METHOD.BYTE.COUNT "L,":" bytes"
            END ELSE
                PRINT "."
            END

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / wrappers                         **
**************************************************************************
**************************************************************************

PROCESS.ALL.WRAPPERS: ****************************************************
* process all wrappers that have been created                            *
**************************************************************************
    IF WRAPPER.CREATE.COUNT = 0 THEN
        RETURN
    END

* process any wrappers built from the object
    PRINT
    PRINT "Exporting ":WRAPPER.CREATE.COUNT:" Wrapper":
    IF WRAPPER.CREATE.COUNT <> 1 THEN
        PRINT "s":
    END
    PRINT ":"

    WRAPPER.TARGET.FILENAME = "OBP / CBP"

    FOR WRAPPER.LOOP = 1 TO WRAPPER.CREATE.COUNT
        WRAPPER.NAME = UPCASE(WRAPPER.CREATE.LIST<WRAPPER.LOOP>)
        WRAPPER.TYPE = METHOD.TYPE.LIST<WRAPPER.LOOP>
        GOSUB PROCESS.WRAPPER
    NEXT WRAPPER.LOOP

    PRINT
    PRINT WRAPPER.CREATE.COUNT:" Wrapper":
    IF WRAPPER.CREATE.COUNT <> 1 THEN
        PRINT "s":
    END
    PRINT " exported to ":WRAPPER.TARGET.FILENAME:" subroutines":

    IF SHOW.LINE.COUNTS THEN
        PRINT ", ":
        PRINT WRAPPER.LINE.COUNT "L,":" lines, ":
        PRINT WRAPPER.BYTE.COUNT "L,":" bytes"
    END ELSE
        PRINT "."
    END

    RETURN

PROCESS.WRAPPER: *********************************************************
* process a wrapper as a subroutine.   there are waaaaaay too many flags *
* to reset if, say, the wrapper was created by a method and the wrapper  *
* itself is a subroutine.  switching from compiling an object to         *
* compiling a subroutine in the same run could easily create a huge      *
* mess.  so, we're going to execute another instance of the compiler to  *
* convert the wrapper from a obp version into a cbp version              *
*                                                                        *
* if an object has a lot of wrappers and we add every individually       *
* compiled program to the "last program" list we'll end up with all the  *
* wrappers first and the object name at the end.  this isn't very handy  *
* so we'll compile with the "NOADD" option                               *
**************************************************************************
    GOSUB RELOAD.IF.CHANGED

    DISPLAY.WRAPPER = WRAPPER.NAME
    IF UPCASE.CODE THEN
        DISPLAY.WRAPPER = DOWNCASE(DISPLAY.WRAPPER)
    END

    WRAPPER.SUBROUTINE.NAME = UPCASE(WRAPPER.NAME)

    COMPILING.TEXT = "    ":DISPLAY.WRAPPER
    IF DISPLAY.COMPILE.CBP.NAME THEN
        COMPILING.TEXT := " -> [":WRAPPER.TARGET.FILENAME:" ":WRAPPER.SUBROUTINE.NAME:"]"
    END
    GOSUB DISPLAY.COMPILING

* compile the wrapper subroutine but instruct the compiler to compile it as
* if it came from the object file
    STATEMENT = "UD.COMPILE OBP ":UPCASE(WRAPPER.NAME):" BUILD NOSPEECH NOABORT NOADD NOPTS"
    STATEMENT := " FROM ":OBJECT.FILENAME:" ":OBJECT.NAME

* some options should be passed to the wrapper compile
    IF WARN.ECLIPSE.CALLS THEN
        STATEMENT := " WARNECLIPSE"
    END
    IF NO.ECLIPSE.CALLS THEN
        STATEMENT := " NOECLIPSE"
    END
    IF NOT(ADD.TO.LAST.LIST) THEN
        STATEMENT := " NOADD"
    END
    IF NOT(SAVE.CBPS) THEN
        STATEMENT := " NOSAVE"
    END
    IF NOT(DO.COMPILE) THEN
        STATEMENT := " NOCOMPILE"
    END
    IF WAIT.AFTER.ERROR THEN
        STATEMENT := " WAITERROR"
    END
    IF WAIT.AFTER.COMPILE THEN
        STATEMENT := " WAIT"
    END
    IF REPAIR.MODE THEN
        STATEMENT := " REPAIR"
    END
    IF CHECK.MODE THEN
        STATEMENT := " CHECK"
    END

    EXECUTE STATEMENT CAPTURING TEXT

* get compiled wrapper, lines and bytes
    READ CBP.WRAPPER.CODE FROM CBPFILE, WRAPPER.SUBROUTINE.NAME ELSE
        CBP.WRAPPER.CODE = ""
    END

    WRAPPER.CODE.LINES = DCOUNT(CBP.WRAPPER.CODE, @AM)
    WRAPPER.BYTES = LEN(CBP.WRAPPER.CODE)

    WRAPPER.LINE.COUNT += WRAPPER.CODE.LINES
    WRAPPER.BYTE.COUNT += WRAPPER.BYTES
    
* show results of processing the wrapper
    IF NOT(BRIEF) THEN

        IF SHOW.SAVING.ITEMS THEN
            PRINT "    ":TARGET.FILENAME:" ":SUBROUTINE.NAME:" saved"
        END

        IF SHOW.LINE.COUNTS THEN
            PRINT "        Exported ":WRAPPER.CODE.LINES "L,":" lines, ":
            PRINT WRAPPER.BYTES "L,":" bytes"
        END

    END

* update the created subroutine.list.  all cbps are compiled from this list
    LOCATE WRAPPER.SUBROUTINE.NAME IN CREATED.SUBROUTINE.LIST SETTING SUB.PTR ELSE

        CREATED.METHOD.COUNT += 1

        CREATED.METHOD.LIST<CREATED.METHOD.COUNT> = WRAPPER.SUBROUTINE.NAME
        CREATED.SUBROUTINE.LIST<CREATED.METHOD.COUNT> = WRAPPER.SUBROUTINE.NAME

        CREATED.SOURCE.START.LIST<CREATED.METHOD.COUNT> = ""
        CREATED.TARGET.START.LIST<CREATED.METHOD.COUNT> = ""
        CREATED.SOURCE.COUNT.LIST<CREATED.METHOD.COUNT> = ""

        CREATED.SOURCE.COMMON.START.LIST<CREATED.METHOD.COUNT> = ""
        CREATED.TARGET.COMMON.START.LIST<CREATED.METHOD.COUNT> = ""
        CREATED.SOURCE.COMMON.COUNT.LIST<CREATED.METHOD.COUNT> = ""

        CREATED.SUBROUTINE.COUNT.LIST<CREATED.METHOD.COUNT> = WRAPPER.CODE.LINES
        CREATED.SUBROUTINE.BYTE.LIST<CREATED.METHOD.COUNT> = WRAPPER.BYTES

        CREATED.METHOD.SOURCE.LIST<CREATED.METHOD.COUNT> = LOWER(PROGRAM.CODE.SOURCE.LIST)
        CREATED.METHOD.FINAL.LIST<CREATED.METHOD.COUNT> = LOWER(PROGRAM.CODE.FINAL.LIST)

    END

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / subroutines                      **
**************************************************************************
**************************************************************************

PROCESS.SUBROUTINE: ******************************************************
* compile object.code as a subroutine                                    *
**************************************************************************
    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES
    SUBROUTINE.NAME = OBJECT.NAME
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES

    UPDATE.COMMENT.TABLE = @FALSE

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INIT.LINE.XREF

    GOSUB CHECK.SUBROUTINE.SPLIT

* rebuild subroutine statement for byval and byref parameters
    THIS.SUBROUTINE.STATEMENT = PROGRAM.CODE<1>
    GOSUB CONVERT.SUBROUTINE.STATEMENT
    PROGRAM.CODE<1> = NEW.SUBROUTINE.STATEMENT

    GOSUB ADD.SUBROUTINE.STAMP
    GOSUB ADD.STAMP

    USER.CODE.START.PTR = 2

    GOSUB INSERT.OBSUB.OPTIONAL.PARAMETER.CODE
    USER.CODE.START.PTR += OPTIONAL.CODE.COUNT

    GOSUB ADD.SPECIAL.SUBROUTINE.CALL
    USER.CODE.START.PTR += SPECIAL.CALL.LINE.COUNT

    IF IS.SPLIT THEN
        GOSUB ADD.SUBROUTINE.SPLITTING.CODE
    END

    USER.CODE.END.PTR = PROGRAM.CODE.LINES

    GOSUB CHECK.THROWN.ERRORS

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB BUILD.LABEL.TABLE

    IF ENABLE.SHORT.GOSUBS THEN
        GOSUB CONVERT.SHORT.GOSUBS
    END

    GOSUB BUILD.OBJECT.SUB.CODE
    GOSUB ADD.INSTANCE.CODE
    GOSUB ADD.SPECIAL.SUBROUTINE.CODE

* we don't have a method here so we'll call it "main"
    METHOD = "MAIN"

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB ADD.FINAL.END
    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB SAVE.METHOD

    PERMIT.FILE = TARGET.FILENAME
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

* if this is a subroutine update ud.compile.dates
    IF NOT(LIST.OBJECTS.ONLY) AND SAVE.CBPS THEN

        OBJECT.NAME = UPCASE (SUBROUTINE.CALL.KEYWORD)
        THIS.METHOD = SUBROUTINE.NAME

        THIS.DATE = DATE()
        THIS.TIME = INT(TIME())
        THIS.USER = UPCASE(USER.ID)
        THIS.CHECKSUM = CHECKSUM(PROGRAM.CODE)

        CBP.RECORD = PROGRAM.CODE

        THIS.PROPERTY.LIST = ""
        THIS.DIM.LIST = ""
        THIS.TYPE.LIST = ""
        THIS.LOCAL.LIST = ""

        THIS.EXTERNAL.OBJECT = @FALSE

        THIS.PARAMETER = LOWER (SUB.PARAMETER.LIST)
        THIS.BYREF = LOWER (SUB.BYREF.LIST)
        THIS.DEFAULT = LOWER (SUB.VALUE.LIST)
        THIS.SET = LOWER (SUB.SET.LIST)
        THIS.IN = LOWER (SUB.IN.LIST)
        THIS.OPTIONAL = LOWER (SUB.OPTIONAL.LIST)

* version number will be formed from the number of years after 01/15,
* days into the current year and the last change time in 5 minute breaks
        CURRENT.YEAR = OCONV(DATE(), "D4/") ["/", 3, 1]
        CURRENT.YEAR.START = ICONV("01/01/":CURRENT.YEAR, "D")
        OBJECT.TIME = INT(TIME() / 300 + 1)

        OBJECT.YEARS = CURRENT.YEAR - 2015
        OBJECT.DAYS = DATE() - CURRENT.YEAR.START + 1
        OBJECT.VERSION = OBJECT.YEARS:".":OBJECT.DAYS:"[":OBJECT.TIME:"]"

        IF UPDATE.COMPILE.TABLE.IN.FILE THEN
            GOSUB UPDATE.COMPILE.DETAIL
            GOSUB UPDATE.COMPILE.MASTER
        END

    END

* set permissions for the source program
    PERMIT.FILE = "OBP"
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

* if this subroutine is split create the split version
    GOSUB CREATE.SPLIT.SUBROUTINE.VERSION

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / oc routines                      **
**************************************************************************
**************************************************************************

PROCESS.OC: **************************************************************
* process an oc program                                                  *
**************************************************************************
    GOSUB RELOAD.IF.CHANGED

    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES
    SUBROUTINE.NAME = OBJECT.NAME
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES

* reset some program flags for processing oc program
    SAVE.CBPS = @FALSE

    SHOW.SAVING.ITEMS = @TRUE

    CHECK.METHOD.PARAMETER.PROPERTY = @TRUE
    CHECK.ASSIGNMENT.PROPERTY = @TRUE
    CHECK.ECLIPSE.COMMON.VARIABLES = @TRUE

    SHOW.PROPERTY.PARAMETERS = @TRUE

    FIX.PROPERTY.PARAMETERS = @FALSE

    LINE.WRAPPING = @FALSE

    SAME.OBJECT.CALL.CHECKS.INSTANCE = @FALSE
    SAME.OBJECT.CALL.LOADS.INSTANCE = @FALSE

    ALWAYS.CHECK.INSTANCE = @FALSE
    ALWAYS.LOAD.INSTANCE = @FALSE

    NON.LOCAL.ALWAYS.CHECKS.INSTANCE = @FALSE
    NON.LOCAL.ALWAYS.LOADS.INSTANCE = @FALSE

    SAME.OBJECT.CALL.CHECKS.INSTANCE = @FALSE
    SAME.OBJECT.CALL.LOADS.INSTANCE = @FALSE

    SUB.CALL.CHECKS.INSTANCE = @FALSE
    SUB.CALL.LOADS.INSTANCE = @FALSE

    ENABLE.ASSOCIATED.TABLES = @FALSE

    ADD.CATCH.ERROR.ROUTINE = @FALSE
    UPDATE.OBJECT.ERROR.LOG = @FALSE
    AUTO.DESTROY.OBJECTS = @FALSE

    ENABLE.ERROR.THROWS = @FALSE

    UPDATE.OBJECT.REGISTRY = @FALSE

    DO.COMPILE = @FALSE

    DELETE.CBP = @FALSE
    DELETE.OC = @FALSE
    DECATALOG.CBP = @FALSE

    ADD.SOURCE.COMMENTS = @FALSE

    COMPILE.CBP.PROGRAMS = @FALSE
    COMPILE.CORE.PROGRAMS = @FALSE

* we don't really have a method here so we'll call it "main"
    METHOD = "MAIN"

* display what we're compiling
    GOSUB SHOW.METHOD

* convert all the external subroutine calls in the oc program to sub-type
* object calls and save the converted code in object.code as if it was read
* from the source file that way.  this will allow us to process the program
* for calling errors as if it was an object-enabled subroutine
    GOSUB CONVERT.OC.CALLS

    OBJECT.CODE = PROGRAM.CODE
    OBJECT.CODE.LINES = PROGRAM.CODE.LINES

* change flags to make the oc program appear to be an obp and process
* as if it was an obp program.  save.cbps is turned off so the converted
* oc won't be written to cbp.  after we're done reset the flags so we're
* set up for the oc again
    PROCESS.OC = @FALSE
    PROCESS.SUBROUTINE = @TRUE

    GOSUB PROCESS.SUBROUTINE

    PROCESS.OC = @TRUE
    PROCESS.SUBROUTINE = @FALSE

* update totals
    GRAND.TOTAL.COMPILED += 1
    GRAND.TOTAL.LINES += PROGRAM.CODE.LINES
    GRAND.TOTAL.BYTES += LEN(PROGRAM.CODE)

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / cbp routines                     **
**************************************************************************
**************************************************************************

PROCESS.CBP: *************************************************************
* compile cbp program                                                    *
**************************************************************************
    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES
    SUBROUTINE.NAME = OBJECT.NAME

* we don't really have a method here so we'll call it "main"
    METHOD = "MAIN"

* display what we're compiling
    GOSUB SHOW.METHOD

* cbp's won't be converted so make up an xref of source code to final
* code to pass the error number through
    GOSUB INIT.LINE.XREF

    GOSUB SAVE.METHOD

    PERMIT.FILE = "CBP"
    PERMIT.ITEM = SUBROUTINE.NAME
    GOSUB SET.PERMISSIONS

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / core routines                    **
**************************************************************************
**************************************************************************

PROCESS.CORE: ************************************************************
* compile cbp program                                                    *
**************************************************************************
    PROGRAM.CODE = OBJECT.CODE
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES
    SUBROUTINE.NAME = OBJECT.NAME
    PROGRAM.CODE.LINES = OBJECT.CODE.LINES

* we don't really have a method here so we'll call it "main"
    METHOD = "MAIN"

* display what we're compiling
    GOSUB SHOW.METHOD

* cbp's won't be converted so make up an xref of source code to final
* code to pass the error number through
    GOSUB INIT.LINE.XREF

    GOSUB SAVE.METHOD

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / utility routines                 **
**************************************************************************
**************************************************************************

BUILD.OBJECT.TABLES: *****************************************************
* build property, constant, child and method tables                      *
**************************************************************************
    TABLE.START.DATE = DATE()
    TABLE.START.TIME = TIME()

    PROPERTY.LINE.LIST = ""
    PROPERTY.TYPE.LIST = ""
    PROPERTY.LINE.COUNT = 0

    UPDATE.COMMENT.TABLE = @TRUE
    GOSUB BUILD.PROPERTY.LIST
    GOSUB BUILD.CONSTANT.LIST
    GOSUB BUILD.CHILD.LIST
    GOSUB BUILD.METHOD.LIST

    TABLE.END.DATE = DATE()
    TABLE.END.TIME = TIME()
    TABLE.ELAPSED.TIME += TIME.ELAPSED (TABLE.START.DATE, TABLE.START.TIME)

* total number of properties declared.  if there are no properties a lot
* of instance code can be skipped
    TOTAL.PROPERTY.COUNT = PROP.COUNT + CONSTANT.COUNT + CHILD.COUNT

* if the total property count is the same as the constant.default.count
* then there are no properties defined.  this is a function-only object
    IF TOTAL.PROPERTY.COUNT = DEFAULT.CONSTANT.COUNT THEN
        PROPERTIES.EXIST = @FALSE
    END ELSE
        PROPERTIES.EXIST = @TRUE
    END

    RETURN

GET.METHOD.RANGE: ********************************************************
* given METHOD find START.LINE and END.LINE                              *
**************************************************************************
    START.LINE = 0
    END.LINE = 0

    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

    RETURN

DISPLAY.COMPILING: *******************************************************
* prints compiling.text.  if compiling.text is too long reformat it to   *
* fit on a single line                                                   *
**************************************************************************
    MAX.LENGTH = 76

    IF LEN(COMPILING.TEXT) <= MAX.LENGTH THEN
        PRINT COMPILING.TEXT
        RETURN
    END

* we need to shorten compiling.text to 73 so that we have room to add the
* "..." to show we've truncated it.  we'll remove this text from just before
* the closing bracket
    BRACKET.PTR = INDEX(COMPILING.TEXT, "]", 1)

    IF BRACKET.PTR = 0 THEN
        BRACKET.PTR = LEN(COMPILING.TEXT)
    END

    REMOVE.COUNT = LEN(COMPILING.TEXT) - MAX.LENGTH + 3
    COMPILING.TEXT = COMPILING.TEXT [1, BRACKET.PTR - REMOVE.COUNT - 1]:"...":COMPILING.TEXT [BRACKET.PTR, TO.THE.END]

    PRINT COMPILING.TEXT

    RETURN

SAVE.PROCESS.FLAGS: ******************************************************
* save process flags for processing the current type of routine          *
**************************************************************************
    SAVE.COMPILE.OBJECT = COMPILE.OBJECT
    SAVE.COMPILE.SUBROUTINE = COMPILE.SUBROUTINE
    SAVE.COMPILE.OC = COMPILE.OC
    SAVE.COMPILE.CBP = COMPILE.CBP
    SAVE.COMPILE.CORE = COMPILE.CORE

    RETURN

SET.SUB.PROCESS.FLAGS: ***************************************************
* set process flags for processing an object-enabled subroutine          *
**************************************************************************
    SAVE.COMPILE.OBJECT = @FALSE
    SAVE.COMPILE.SUBROUTINE = @TRUE
    SAVE.COMPILE.OC = @FALSE
    SAVE.COMPILE.CBP = @FALSE
    SAVE.COMPILE.CORE = @FALSE

    RETURN

RESTORE.PROCESS.FLAGS: ***************************************************
* restore the process flags for processing the original type of routine  *
**************************************************************************
    COMPILE.OBJECT = SAVE.COMPILE.OBJECT
    COMPILE.SUBROUTINE = SAVE.COMPILE.SUBROUTINE
    COMPILE.OC = SAVE.COMPILE.OC
    COMPILE.CBP = SAVE.COMPILE.CBP
    COMPILE.CORE = SAVE.COMPILE.CORE

    RETURN


**************************************************************************
**************************************************************************
** compiling / wrappers and routines / delete cbp versions              **
**************************************************************************
**************************************************************************

DELETE.CBP.VERSIONS: *****************************************************
* remove all cbp and oc versions of methods for an object.  hopefully    *
* the eclipse subroutine prefix has been chosen wisely so that there     *
* are no other subroutines that begin with the prefix/object name        *
* combination.                                                           *
**************************************************************************

* if we aren't deleting cbp versions dump out
    IF NOT(DECATALOG.CBP) AND NOT(DELETE.CBP) AND NOT(DELETE.OC) THEN
        RETURN
    END

* sanity check . . . if any of these variables are null somehow (?) this
* could do a lot of damage
    BEGIN CASE

        CASE ECLIPSE.PREFIX = ""
            PRINT
            PRINT "Eclipse Prefix is (somehow?) null.  Not deleting CBP versions"
            PRINT
            RETURN

        CASE OBJECT.NAME = ""
            PRINT
            PRINT "Object Name is (somehow?) null.  Not deleting CBP versions"
            PRINT
            RETURN

        CASE ECLIPSE.DELIMITER = ""
            PRINT
            PRINT "Eclipse Delimiter is (somehow?) null.  Not deleting CBP versions"
            PRINT
            RETURN

    END CASE

    IF NOT(BRIEF) THEN

        PRINT "Selecting CBP Subroutines for Object ":
        IF UPCASE.CODE THEN
            PRINT DOWNCASE(OBJECT.NAME)
        END ELSE
            PRINT OBJECT.NAME
        END

    END

* build a list of cbp programs to delete
    CBP.DELETE.LIST = ""
    CBP.DELETE.COUNT = 0
    CBP.WIDTH = 25

* select all cbp method routines for this object

* all cbp subroutine names from an object will begin with the eclipse
* prefix, then the object name and the eclipse delimiter.
    SUBROUTINE.PREFIX = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER

* first we'll select for cbp programs that begin with the subroutine
* prefix.  this may pick up too many if we have two object names where
* one is part of another.  for these we'll do a second select to make
* sure we only have cbp programs for the right object
    STATEMENT = 'SELECT ':TARGET.FILENAME:' = "':SUBROUTINE.PREFIX:']"'
    STATEMENT<2> = 'SSELECT ':TARGET.FILENAME:' WITH OBJECT.NAME = "':DOWNCASE(OBJECT.NAME):'"'

    EXECUTE STATEMENT RTNLIST SUB.LIST CAPTURING TEXT
    CBP.COUNT = TEXT<2> [" ", 1, 1]

    IF CBP.COUNT = 0 THEN
        PRINT "No ":TARGET.FILENAME:" routines found"
    END ELSE
        PRINT CBP.COUNT:" ":TARGET.FILENAME:" routines found"
    END

    LOOP WHILE READNEXT CBP.NAME FROM SUB.LIST DO

        CBP.DELETE.COUNT += 1
        CBP.DELETE.LIST<CBP.DELETE.COUNT> = CBP.NAME

        IF LEN(CBP.NAME) > CBP.WIDTH THEN
            CBP.WIDTH = LEN(CBP.NAME)
        END

    REPEAT

* next select any subroutines built from wrappers for this object.  all
* wrappers for the object will have the striing "created from object obj
* object.name at" in them
    WRAPPER.SEARCH.STRING = "* created from object obj ":DOWNCASE (OBJECT.NAME):" at":@AM
    STATEMENT = "ESEARCH ":TARGET.FILENAME

    DATA WRAPPER.SEARCH.STRING
    EXECUTE STATEMENT RTNLIST WRAPPER.LIST CAPTURING TEXT
    WRAPPER.COUNT = TEXT<2> [" ", 1, 1]

    IF WRAPPER.COUNT = 0 THEN
        PRINT "No wrapper routines found"
    END ELSE
        PRINT WRAPPER.COUNT:" wrapper routines found"
    END

    LOOP WHILE READNEXT WRAPPER.NAME FROM WRAPPER.LIST DO

        LOCATE WRAPPER.NAME IN CBP.DELETE.LIST BY "AL" SETTING WRAPPER.PTR ELSE
            CBP.DELETE.COUNT += 1
            INS WRAPPER.NAME BEFORE CBP.DELETE.LIST<WRAPPER.PTR>
        END

    REPEAT

* display list of cbp subroutines we'll be deleting
    PRINT
    PRINT "Ready to delete these ":CBP.DELETE.COUNT:" ":TARGET.FILENAME:" subroutines:"
    PRINT

    CBP.COLUMNS = INT(79 / CBP.WIDTH)
    IF CBP.COLUMNS < 2 THEN
        CBP.COLUMNS = 2
    END

    CBP.LINES = INT(CBP.DELETE.COUNT / CBP.COLUMNS) + 1
    CBP.COLUMN.WIDTH = INT(79 / CBP.COLUMNS) - 1
    CBP.MASK = "L#":(CBP.COLUMN.WIDTH)

    FOR CBP.DOWN = 1 TO CBP.LINES

        FOR CBP.ACROSS = 1 TO CBP.COLUMNS

            CBP.PTR = (CBP.ACROSS - 1) * CBP.LINES + CBP.DOWN
            THIS.CBP = CBP.DELETE.LIST<CBP.PTR>

            IF LEN(THIS.CBP) > CBP.COLUMN.WIDTH THEN
                THIS.CBP = THIS.CBP [1, CBP.COLUMN.WIDTH - 3]:"..."
            END

            PRINT THIS.CBP CBP.MASK:" ":

        NEXT CBP.ACROSS
        PRINT

    NEXT CBP.DOWN

    PRINT

* make sure it's okay to delete these cbp entries.  we don't want to
* clobber the wrong thing
    PRINT HOLDOFF$
    DELETE.ANSWER = ""

    IF ASK.FOR.OPTIONS THEN

        LOOP UNTIL DELETE.ANSWER = "YES" DO

            PRINT "Delete these ":CBP.DELETE.COUNT:" ":TARGET.FILENAME:" subroutines? (YES/N/Q): ":

VALINP:     INPUT DELETE.ANSWER

            DELETE.ANSWER = UPCASE(DELETE.ANSWER)

            BEGIN CASE

* the answer was "N", so don't delete these cbps but continue with the
* compile
                CASE DELETE.ANSWER = "N" OR DELETE.ANSWER = "NO" 
                    PRINT
                    PRINT TARGET.FILENAME:" subroutines will NOT be deleted"
                    PRINT
                    RETURN

* the answer was "Q" or "QUIT" then dump out
                CASE DELETE.ANSWER = "Q" OR DELETE.ANSWER = "QUIT"
                    PRINT
                    PRINT "Aborting compile"
                    PRINT
                    GOSUB WRAPUP

                CASE DELETE.ANSWER <> "YES"
                    DELETE.ANSWER = ""

            END CASE

        REPEAT

    END 

    PRINT
    PRINT "Deleting ":CBP.DELETE.COUNT:" ":TARGET.FILENAME:" subroutines:"
    PRINT

* delete catalog entries
    IF DECATALOG.CBP THEN

        FOR CBP.LOOP = 1 TO CBP.DELETE.COUNT

            THIS.CBP = CBP.DELETE.LIST<CBP.LOOP>
            IF DETAILS THEN
                PRINT "Decataloging ":TARGET.FILENAME:" ":THIS.CBP
            END

            STATEMENT = "DECATALOG OC ":THIS.CBP
            EXECUTE STATEMENT CAPTURING TEXT

        NEXT CBP.LOOP

        IF NOT(DETAILS) AND NOT(BRIEF) THEN
            PRINT "    Decataloged ":CBP.DELETE.COUNT:" ":TARGET.FILENAME:" subroutines"
        END

    END

* delete cbp routines
    IF DELETE.CBP THEN

        FOR CBP.LOOP = 1 TO CBP.DELETE.COUNT

            THIS.CBP = CBP.DELETE.LIST<CBP.LOOP>

            IF DETAILS THEN
                PRINT "Deleting ":TARGET.FILENAME:" ":THIS.CBP
            END

            WRITE.ERROR = @FALSE
            DELETE CBPFILE, THIS.CBP ON ERROR WRITE.ERROR = @TRUE

            IF WRITE.ERROR THEN
                ERROR.FILE = "CBP"
                ERROR.ITEM = THIS.CBP
                GOSUB DELETE.ERROR
            END

        NEXT CBP.LOOP

        IF NOT(DETAILS) AND NOT(BRIEF) THEN
            PRINT "    Deleted ":CBP.DELETE.COUNT:" subroutines"
        END

    END

* delete oc and oc.o versions
    IF DELETE.OC THEN

        FOR CBP.LOOP = 1 TO CBP.DELETE.COUNT

            THIS.CBP = CBP.DELETE.LIST<CBP.LOOP>

            IF DETAILS THEN
                PRINT "Deleting OC ":THIS.CBP
            END

            WRITE.ERROR = @FALSE
            DELETE OCFILE, THIS.CBP ON ERROR WRITE.ERROR = @TRUE

            IF WRITE.ERROR THEN
                ERROR.FILE = "OC"
                ERROR.ITEM = THIS.CBP
                GOSUB DELETE.ERROR
            END

            WRITE.ERROR = @FALSE
            DELETE OCOFILE, THIS.CBP ON ERROR WRITE.ERROR = @TRUE

            IF WRITE.ERROR THEN
                ERROR.FILE = "OC.O"
                ERROR.ITEM = THIS.CBP
                GOSUB DELETE.ERROR
            END

        NEXT CBP.LOOP

        IF NOT(DETAILS) AND NOT(BRIEF) THEN
            PRINT "    Deleted ":CBP.DELETE.COUNT:" OC / OC.O subroutines"
        END

    END

    IF NOT(BRIEF) THEN
        PRINT
    END

    RETURN


**************************************************************************
**************************************************************************
** code / loading and saving                                            **
**************************************************************************
**************************************************************************

GET.OBJECT.FILENAME: *****************************************************
* set object.filename given given.object.filename and object.name        *
**************************************************************************
    OBJECT.FILENAME = ""

* if we were given a filename on the command line use that file
    IF GIVEN.OBJECT.FILENAME <> "" THEN
        OBJECT.FILENAME = GIVEN.OBJECT.FILENAME
        RETURN
    END

* if the object name is a method reference extract the object name to
* search for
    CHECK.METHOD.PTR = INDEX(OBJECT.NAME, METHOD.DELIMITER, 1)

    IF CHECK.METHOD.PTR > 0 THEN
        CHECK.OBJECT.NAME = OBJECT.NAME [1, CHECK.METHOD.PTR - 1]
    END ELSE
        CHECK.OBJECT.NAME = OBJECT.NAME
    END

    CHECK.OBJECT.NAME = UPCASE(CHECK.OBJECT.NAME)

* we weren't given a filename on the command line.  start at the top of
* the program file hierarchy and find the first file that contains this
* object / program
    OBJECT.FILENAME = ""

    FOR FILE.LOOP = HIERARCHY.COUNT TO 1 STEP -1 UNTIL OBJECT.FILENAME <> ""

        THIS.FILE = HIERARCHY.LIST<FILE.LOOP>
        UT.OPEN.FILE THIS.FILE, THIS.FILE.HANDLE, ERROR.MESSAGE, 1

        IF ERROR.MESSAGE = "" THEN

            READV TEST.REC FROM THIS.FILE.HANDLE, OBJECT.NAME, 0 THEN
                OBJECT.FILENAME = THIS.FILE
            END ELSE
                READV TEST.REC FROM THIS.FILE.HANDLE, CHECK.OBJECT.NAME, 0 THEN
                    OBJECT.NAME = UPCASE(OBJECT.NAME)
                    OBJECT.FILENAME = THIS.FILE
                END
            END

        END

    NEXT FILE.LOOP

* if we didn't find the program in the normal files look for partial
* matches
    IF OBJECT.FILENAME = "" THEN
        GOSUB CHECK.FOR.PARTIAL.MATCHES
    END

* if we can't find a program file default to cbp.  the program won't be there
* but we'll catch it later
    IF OBJECT.FILENAME = "" THEN
        OBJECT.FILENAME = "CBP"
    END

    RETURN

CHECK.FOR.PARTIAL.MATCHES: ***********************************************
* search for partial matches to object.name.  if any are found put up    *
* a menu to get a choice                                                 *
**************************************************************************
    GOSUB GET.PARTIAL.MATCHES

    IF MATCH.ITEM.COUNT = 0 THEN
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    GOSUB PARTIAL.MATCH.MENU 

    IF OBJECT.FILENAME = "" OR OBJECT.NAME = "" OR F12 THEN
        ABORT.PROGRAM = @TRUE
        RETURN
    END

    RETURN

GET.PARTIAL.MATCHES: *****************************************************
* build a table of program filenames and itemnames that are partial      *
* matches to object.name                                                 *
**************************************************************************
    MATCH.FILE.LIST = ""
    MATCH.ITEM.LIST = ""
    MATCH.SORT.LIST = ""
    MATCH.ITEM.COUNT = 0

    MATCH.LEADING = @TRUE
    MATCH.MIDDLE = @TRUE
    MATCH.ENDING = @TRUE
    MATCH.EXACT = @TRUE
    MATCH.WHOLE = @FALSE

    GOSUB BUILD.MATCH.SELECT.WITH

    ECLIPSE.PREFIX.LEN = LEN(ECLIPSE.PREFIX)

    FOR MATCH.LOOP = 1 TO PARTIAL.MATCH.FILE.COUNT

        MATCH.FILE = PARTIAL.MATCH.FILE.LIST<MATCH.LOOP>

        LOCATE MATCH.FILE IN ECLIPSE.PROGRAM.FILES SETTING THROWAWAY THEN
            MATCH.IS.PROGRAM.FILE = @TRUE
        END ELSE
            MATCH.IS.PROGRAM.FILE = @FALSE
        END

        STATEMENT = "SSELECT ":MATCH.FILE:SELECT.WITH

        EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

        LOOP WHILE READNEXT MATCH.ITEM FROM SLIST

            ADD.PARTIAL.MATCH = @TRUE

            BEGIN CASE

* for the obj and obp fileS we'll always include the item name
                CASE MATCH.FILE = "OBJ" OR MATCH.FILE = "OBP"
                    NULL

* if the program file is CBP don't add it to the list if an
* obp program exists or if it was built from an object
                CASE MATCH.FILE = "CBP"

                    LOCATE "OBP ":MATCH.ITEM IN MATCH.SORT.LIST SETTING THROWAWAY THEN
                        ADD.PARTIAL.MATCH = @FALSE
                    END

                    IF MATCH.ITEM [1, ECLIPSE.PREFIX.LEN] = ECLIPSE.PREFIX THEN
                        ADD.PARTIAL.MATCH = @FALSE
                    END

* for any other program file we won't include the item name if it's in the
* list for a cbp or obp
                CASE MATCH.IS.PROGRAM.FILE

                    LOCATE "CBP ":MATCH.ITEM IN MATCH.SORT.LIST SETTING THROWAWAY THEN
                        ADD.PARTIAL.MATCH = @FALSE
                    END

                    LOCATE "OBP ":MATCH.ITEM IN MATCH.SORT.LIST SETTING THROWAWAY THEN
                        ADD.PARTIAL.MATCH = @FALSE
                    END

                    IF MATCH.ITEM [1, ECLIPSE.PREFIX.LEN] = ECLIPSE.PREFIX THEN
                        ADD.PARTIAL.MATCH = @FALSE
                    END

            END CASE

            IF ADD.PARTIAL.MATCH THEN
                MATCH.ITEM.COUNT += 1
                MATCH.FILE.LIST<MATCH.ITEM.COUNT> = MATCH.FILE 
                MATCH.ITEM.LIST<MATCH.ITEM.COUNT> = MATCH.ITEM
                MATCH.SORT.LIST<MATCH.ITEM.COUNT> = MATCH.FILE:" ":MATCH.ITEM
            END

        REPEAT

    NEXT MATCH.LOOP

    RETURN

BUILD.MATCH.SELECT.WITH: *************************************************
* build select.with with a "with" select phrase to select matching       *
* programs from a program file                                           *
**************************************************************************
    SELECT.WITH = ""

    BEGIN CASE 

* if the object.name was passed in as something to match on purpose
* it will begin with "[" and/or end with "]":

*    begins and ends with "[" and "]".  find programs with the string
*    anywhere in the name
        CASE OBJECT.NAME [1, 1] = "[" AND OBJECT.NAME [1] = "]"
            OBJECT.NAME = OBJECT.NAME [2, LEN(OBJECT.NAME) - 2]
            MATCH.WHOLE = @TRUE

*    begins with "[".  find programs with names ending with the string
        CASE OBJECT.NAME [1, 1] = "["
            OBJECT.NAME = OBJECT.NAME [2, TO.THE.END]
            MATCH.WHOLE = @TRUE

*    ends with "]".  find programs with names beginning with the string
        CASE OBJECT.NAME [1] = "]"
            OBJECT.NAME = OBJECT.NAME [1, LEN(OBJECT.NAME) - 1]
            MATCH.WHOLE = @TRUE

* if object name was passed in with a leading dot, trailing dot or
* both this also changes how the matching is done:

*    begins and ends with ".".  find programs with the dot-delimited
*    field anywhere in the name
        CASE OBJECT.NAME [1, 1] = "." AND OBJECT.NAME [1] = "."
            OBJECT.NAME = OBJECT.NAME [2, LEN(OBJECT.NAME) - 2]

*    begins with ".".  find programs with names ending with the
*    dot-delimited string
        CASE OBJECT.NAME [1, 1] = "."
            MATCH.LEADING = @FALSE
            MATCH.MIDDLE = @FALSE

*    ends with ".".  find programs with names beginning with the
*    dot-delimited string
        CASE OBJECT.NAME [1] = "."
            MATCH.MIDDLE = @FALSE
            MATCH.ENDING = @FALSE

    END CASE

* if the "object.name" (we're assuming this is something to find matches
* for) is delimited by dots we'll search for any program containing one
* or more of the dot-delimited fields
    IF MATCH.WHOLE THEN

            SELECT.WITH := ' WITH @ID = '

            IF MATCH.LEADING THEN
                SELECT.WITH := ' "':OBJECT.NAME:']"'
            END

            IF MATCH.MIDDLE THEN
                SELECT.WITH := ' "[':OBJECT.NAME:']"'
            END

            IF MATCH.ENDING THEN
                SELECT.WITH := ' "[':OBJECT.NAME:'"'
            END

    END ELSE

        FIRST.DOT.FIELD = @TRUE
        DOT.COUNT = DCOUNT(OBJECT.NAME, ".")

        FOR DOT.LOOP = 1 TO DOT.COUNT

            DOT.FIELD = OBJECT.NAME [".", DOT.LOOP, 1]

            IF DOT.FIELD <> "" THEN

                IF NOT(FIRST.DOT.FIELD) THEN
                    SELECT.WITH := " AND"
                END

                SELECT.WITH := " WITH @ID ="

                IF MATCH.EXACT THEN
                    SELECT.WITH := ' "':DOT.FIELD:'"'
                END

                IF MATCH.LEADING THEN
                    SELECT.WITH := ' "':DOT.FIELD:'.]"'
                END

                IF MATCH.MIDDLE OR (DOT.LOOP > 1 AND DOT.LOOP < DOT.COUNT) THEN
                    SELECT.WITH := ' "[.':DOT.FIELD:'.]"'
                END

                IF MATCH.ENDING THEN
                    SELECT.WITH := ' "[.':DOT.FIELD:'"'
                END

                FIRST.DOT.FIELD = @FALSE

            END

        NEXT DOT.LOOP

    END

    RETURN

PARTIAL.MATCH.MENU: ******************************************************
* put up a menu with partial matches and allow selection                 *
**************************************************************************

* build a list of choices from the partial match file names and item names
    CHOICE.LIST = ""

    FOR MATCH.LOOP = 1 TO MATCH.ITEM.COUNT 
        CHOICE.LIST<MATCH.LOOP> = MATCH.FILE.LIST<MATCH.LOOP> "L#3":" ":MATCH.ITEM.LIST<MATCH.LOOP>
    NEXT MATCH.LOOP

    CHOICE = UD.GET.CHOICE(CHOICE.LIST, "", "Partial Name Matches", "", "", "", "", "", "", "", "*")

    IF CHOICE = 0 OR F12 OR QUIT THEN

        F12 = @TRUE

    END ELSE

        OBJECT.FILENAME = MATCH.FILE.LIST<CHOICE>
        OBJECT.NAME = MATCH.ITEM.LIST<CHOICE>

        OBJECT.LIST = OBJECT.NAME
        OBJECT.COUNT = 1

    END

    RETURN

GET.OBJECT: **************************************************************
* read object text from program file                                     *
**************************************************************************

* we'll return a a bunch of flags defining what this "object" is
    OBJECT.CODE.LINES = 0

    COMPILE.OBJECT = @FALSE
    COMPILE.SUBROUTINE = @FALSE
    COMPILE.CBP = @FALSE
    COMPILE.CORE = @FALSE
    COMPILE.OC = @FALSE

    ALL.SUBROUTINES = @FALSE
    COMPILE.TYPE = ""

    OBJECT.ERROR = @FALSE
    OBJECT.EXISTS = @FALSE

* reset default maximum instances value and the "allow expanding instances"
* value.  these values can be changed by keyword on the "object" line of
* object definitions so we need to reset them if compiling more than one
* method
    MAX.INSTANCES = DEFAULT.MAX.INSTANCES
    ALLOW.EXPANDING.INSTANCES = DEFAULT.ALLOW.EXPANDING.INSTANCES
    ALLOW.REDUCING.INSTANCES = DEFAULT.ALLOW.REDUCING.INSTANCES

* open program file
    UT.OPEN.FILE OBJECT.FILENAME, FILE.HANDLE, ERROR.MESSAGE, 1

    IF ERROR.MESSAGE THEN
        PRINT
        PRINT "Can't open ":OBJECT.FILENAME:"!"
        PRINT
        RETURN
    END
 
* try to read object code.  if we can't read it try again using all
* upper case.
    READ OBJECT.CODE FROM FILE.HANDLE, OBJECT.NAME ELSE

        READ OBJECT.CODE FROM FILE.HANDLE, UPCASE(OBJECT.NAME) THEN
            OBJECT.NAME = UPCASE(OBJECT.NAME)
        END ELSE
            PRINT
            PRINT "Can't read ":OBJECT.NAME:" from OBJ / OBP / CBP file!"
            PRINT
            RETURN
        END

    END

* save original object text.  we'll update it with last change dates and
* compile checksums later and return it to the file
    ORIGINAL.OBJECT.CODE = OBJECT.CODE

* clean off any blank trailing lines so we don't junk up the subroutines
* we're building
    OBJECT.CODE.LINES = DCOUNT(OBJECT.CODE, @AM)
    OBJECT.EXISTS = @TRUE

    LOOP UNTIL TRIM(OBJECT.CODE<OBJECT.CODE.LINES>) <> "" OR OBJECT.CODE.LINES = 0 DO
        DEL OBJECT.CODE<OBJECT.CODE.LINES>
        OBJECT.CODE.LINES -= 1
    REPEAT

* test program filename to see if we should look at this program for object
* references.  for cbp programs or core programs we're done
    BEGIN CASE

* for cbp records don't look any further.  it's just a cbp program and
* all we'll do for it (later) is pass it on to ba.
        CASE OBJECT.FILENAME = "CBP"

            COMPILE.CBP = @TRUE
            COMPILE.TYPE = "CBP Program"

* obj file, an object
        CASE OBJECT.FILENAME = "OBJ"

            COMPILE.OBJECT = @TRUE
            COMPILE.TYPE = "Object"

            IF ALLOW.METHOD.EDITS THEN
                IF NOT(LIST.METHODS) AND NOT(SHORTCUT.LIST) AND NOT(LIST.OBJECTS.ONLY) THEN
                    GOSUB MERGE.EDIT.METHOD.CODE
                END
            END

            IF ADD.SOURCE.COMMENTS THEN
                GOSUB ADD.SOURCE.CODE.COMMENTS
            END

            IF UPCASE.CODE THEN
                GOSUB UPCASE.OBJECT.CODE
            END

            IF PROCESS.DEFINES THEN
                GOSUB PROCESS.DEFINES
            END

* obp file, an object-enabled subroutine
        CASE OBJECT.FILENAME = "OBP"

            COMPILE.SUBROUTINE = @TRUE
            COMPILE.TYPE = "Subroutine"

            IF ADD.SOURCE.COMMENTS THEN
                GOSUB ADD.SOURCE.CODE.COMMENTS
            END

            IF UPCASE.CODE THEN
                GOSUB UPCASE.OBJECT.CODE
            END

            IF PROCESS.DEFINES THEN
                GOSUB PROCESS.DEFINES
            END

* oc file.  we won't compile oc programs (that's for eclipse's precompiler
* to handle) but we will check the program for problems
        CASE OBJECT.FILENAME = "OC"

            COMPILE.OC = @TRUE
            COMPILE.TYPE = "OC Version"

* any other program file is a core program.
        CASE 1

            COMPILE.CORE = @TRUE
            COMPILE.TYPE = "Core Program"

    END CASE

* save the original object code after the cleanup
    ORIGINAL.POST.CLEANUP.OBJECT.CODE = OBJECT.CODE

    IF DETAILS THEN

        PRINT "Loaded ":COMPILE.TYPE:" ":UPCASE(OBJECT.NAME):", ":
        PRINT OBJECT.CODE.LINES "L,":" lines, ":
        PRINT LEN(OBJECT.CODE) "L,":" bytes"
        PRINT

    END

    RETURN

GET.OPTIONS: *************************************************************
* get options from the first line of an object or an object-enabled      *
* subroutine                                                             *
**************************************************************************
    OPTION.START.DATE = DATE()
    OPTION.START.TIME = TIME()

    BEGIN CASE

        CASE COMPILE.OBJECT
            GOSUB SET.OBJECT.OPTIONS

        CASE COMPILE.SUBROUTINE
            GOSUB SET.SUBROUTINE.OPTIONS

    END CASE

    OPTION.END.DATE = DATE()
    OPTION.END.TIME = TIME()
    OPTION.ELAPSED.TIME += TIME.ELAPSED (OPTION.START.DATE, OPTION.START.TIME)

    RETURN

MERGE.EDIT.METHOD.CODE: **************************************************
* check the OBJ file for any methods that were edited individually.      *
* if any are found merge them into the object code and delete the        *
* individual method edit code                                            *
*                                                                        *
* if ud.edit edits an individual method is creates a temporary method    *
* record in obj with an id of:                                           *
*                                                                        *
*     method.edit.prefix . object.name . method.name                     *
*                                                                        *
* and edits the method there.  during the next compile the compiler      *
* checks for the temporary method record.  if it finds one it merges     *
* this method code into the object code and removes the temporary method *
* record.                                                                *
**************************************************************************

* probably unnecessary but let's be safe
    IF METHOD.EDIT.PREFIX = "" OR OBJECT.NAME = "" THEN
        RETURN
    END

* select the obj file for any method edit records for this object
    MERGE.PREFIX = METHOD.EDIT.PREFIX:OBJECT.NAME:"."

    STATEMENT = 'SSELECT OBJ = "':MERGE.PREFIX:']"'
    EXECUTE STATEMENT RTNLIST SELECT.METHOD.LIST CAPTURING TEXT
    TEMP.COUNT = TEXT<2> [" ", 1, 1]

    IF TEMP.COUNT = 0 THEN
        RETURN
    END

* merge each temporary method record
    LOOP WHILE READNEXT TEMP.METHOD.NAME FROM SELECT.METHOD.LIST DO
        GOSUB MERGE.ONE.METHOD
    REPEAT

    RETURN

MERGE.ONE.METHOD: ********************************************************
* merge code for temp.method.name into object.code                       *
**************************************************************************

* see if the method text exists at all without creating a lock.  if it 
* doesn't exist we can skip out
    READV NEW.METHOD.TEXT FROM OBJFILE, TEMP.METHOD.NAME, 0 ELSE
        RETURN
    END

* method text exists.  read it with a lock so we can merge it
    READU NEW.METHOD.TEXT FROM OBJFILE, TEMP.METHOD.NAME ELSE
        RELEASE OBJFILE, TEMP.METHOD.NAME
        RETURN
    END

    IF NEW.METHOD.TEXT = "" THEN
        RELEASE OBJFILE, TEMP.METHOD.NAME
        RETURN
    END

    MERGE.METHOD.NAME = TEMP.METHOD.NAME [LEN(MERGE.PREFIX) + 1, TO.THE.END]
    NEW.METHOD.LINES = DCOUNT(NEW.METHOD.TEXT, @AM)

* find the start and end line for the old method in code.text
    START.LINE = 0
    END.LINE = 0

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES UNTIL START.LINE <> 0

        THIS.LINE = TRIM(OBJECT.CODE<LINE.LOOP>)

        FIRST.WORD = UPCASE(THIS.LINE [" ", 1, 1])
        DECODE.KEYWORD = FIRST.WORD
        GOSUB DECODE.METHOD

        IF IS.METHOD THEN
            SECOND.WORD = UPCASE(THIS.LINE [" ", 2, 1]) ["(", 1, 1] [":", 1, 1] [",", 1, 1]
            IF SECOND.WORD = MERGE.METHOD.NAME THEN
                START.LINE = LINE.LOOP
            END

        END

    NEXT LINE.LOOP

    IF START.LINE = 0 THEN
        RELEASE OBJFILE, TEMP.METHOD.NAME
        RETURN
    END

* find the last line of this method.  this will be the start of the next
* method or section
    FOR LINE.LOOP = START.LINE + 1 TO OBJECT.CODE.LINES UNTIL END.LINE <> 0

        THIS.LINE = TRIM(OBJECT.CODE<LINE.LOOP>)

        FIRST.WORD = UPCASE(THIS.LINE [" ", 1, 1])
        DECODE.KEYWORD = FIRST.WORD
        GOSUB DECODE.METHOD

        IF IS.METHOD OR IS.SECTION THEN
            END.LINE = LINE.LOOP - 1
        END

    NEXT LINE.LOOP

    IF END.LINE = 0 THEN
        END.LINE = OBJECT.CODE.LINES
    END

* if we ended on a "section" statement back up so we don't remove any
* pretty comment lines above the "section" statement
    IF IS.SECTION THEN

        LOOP
            CHECK.LINE = TRIM(OBJECT.CODE<END.LINE>)
            FIRST.CHAR = CHECK.LINE [1, 1]
        UNTIL END.LINE = START.LINE OR (FIRST.CHAR <> "*" AND FIRST.CHAR <> "!")
            END.LINE -= 1
        REPEAT

    END

* back up the end pointer until it's not on a blank line or a comment line
    LOOP
        CHECK.LINE = TRIM(OBJECT.CODE<END.LINE>)
        FIRST.CHAR = CHECK.LINE [1, 1]
    UNTIL END.LINE = START.LINE OR (CHECK.LINE <> "" AND FIRST.CHAR <> "*" AND FIRST.CHAR <> "!")
        END.LINE -= 1
    REPEAT

* delete the old method from object.code
    FOR DELETE.LINE = START.LINE TO END.LINE
        DEL OBJECT.CODE<START.LINE>
        OBJECT.CODE.LINES -= 1
    NEXT DELETE.LINE

* add in the new method code
    FOR ADD.LINE = NEW.METHOD.LINES TO 1 STEP -1
        INS NEW.METHOD.TEXT<ADD.LINE> BEFORE OBJECT.CODE<START.LINE>
        OBJECT.CODE.LINES += 1
    NEXT ADD.LINE

* save the updated object record in obj but keep the lock active
    WRITE.ERROR = @FALSE
    WRITEU OBJECT.CODE ON OBJFILE, OBJECT.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the obj record something is amiss somewhere.  otherwise
* delete the temporary record method from obj
    IF WRITE.ERROR THEN
        ERROR.FILE = "OBJ"
        ERROR.ITEM = OBJECT.NAME
        GOSUB WRITE.ERROR
    END

    WRITE.ERROR = @FALSE
    DELETE OBJFILE, TEMP.METHOD.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "OBJ"
        ERROR.ITEM = TEMP.METHOD.NAME
        GOSUB DELETE.ERROR
    END
 
    RETURN

SHOW.METHOD: *************************************************************
* display the method we're compiling and the Eclipse cbp routine we're   *
* creating from it                                                       *
**************************************************************************

* if we're just listing objects don't show anything
    IF LIST.OBJECTS.ONLY THEN
        RETURN
    END

* if displaying the method being exporting is suppressed don't do anything
    IF NOT(SHOW.EXPORTED.METHOD.NAME) THEN
        RETURN
    END

    BEGIN CASE

* in "brief" mode.  don't display anything
        CASE BRIEF
            NULL

* compiling an object method, display method and eclipse subroutine name
        CASE COMPILE.OBJECT

            DISPLAY.METHOD = OBJECT.NAME:METHOD.DELIMITER:METHOD
            IF UPCASE.CODE THEN
                DISPLAY.METHOD = DOWNCASE(DISPLAY.METHOD)
            END

            COMPILING.TEXT = "    ":DISPLAY.METHOD
            IF DISPLAY.COMPILE.CBP.NAME THEN
                COMPILING.TEXT := " -> [":TARGET.FILENAME:" ":SUBROUTINE.NAME:"]"
            END
            GOSUB DISPLAY.COMPILING

* compiling a subroutine that uses object.  show subroutine name
        CASE COMPILE.SUBROUTINE

            DISPLAY.SUBROUTINE = OBJECT.NAME
            IF UPCASE.CODE THEN
                DISPLAY.SUBROUTINE = DOWNCASE(DISPLAY.SUBROUTINE)
            END

            COMPILING.TEXT = "    ":DISPLAY.SUBROUTINE
            IF DISPLAY.COMPILE.CBP.NAME THEN
                COMPILING.TEXT := " -> [":TARGET.FILENAME:" ":SUBROUTINE.NAME:"]"
            END
            GOSUB DISPLAY.COMPILING

* compiling cbp.  don't show anything
        CASE COMPILE.CBP
            NULL

* compiling core.  don't show anything
        CASE COMPILE.CORE
            NULL

    END CASE

    RETURN

SAVE.METHOD: *************************************************************
* write completed method to the cbp file                                 *
**************************************************************************

* if we're compiling in "list objects only" mode we need to go through
* the compilation process to find all the objects used but we don't want
* to overwrite the current cbp or compile anything
    IF LIST.OBJECTS.ONLY THEN
        RETURN
    END

    SAVE.START.DATE = DATE()
    SAVE.START.TIME = TIME()

* keep a grand total of all errors encountered during this compilation
* session
    TOTAL.ERRORS = ERROR.SUBROUTINE.COUNT + WARNING.SUBROUTINE.COUNT

    GRAND.TOTAL.ERRORS += ERROR.SUBROUTINE.COUNT
    GRAND.TOTAL.WARNINGS += WARNING.SUBROUTINE.COUNT

* depending on what we're compiling indent messages so they stay lined
* up on the screen
    LINE.INDENT = "    "
    IF COMPILE.OBJECT OR COMPILE.SUBROUTINE THEN
        LINE.INDENT = "         "
    END

    PROGRAM.BYTES = LEN(PROGRAM.CODE)

    BEGIN CASE

* compile and object method but save.cbps is turned off
        CASE COMPILE.OBJECT AND NOT(SAVE.CBPS)
            GOSUB DISPLAY.NOT.SAVING

* compiling an object method, display method and eclipse subroutine name
        CASE COMPILE.OBJECT
            GOSUB DISPLAY.COMPILE.OBJECT.METHOD

* compiling a subroutine that uses object.  show subroutine name
        CASE COMPILE.SUBROUTINE
            GOSUB DISPLAY.COMPILE.OBJECT.SUBROUTINE

* compiling an oc record.
        CASE COMPILE.OC
            GOSUB DISPLAY.COMPILE.OC

* compiling cbp.  don't show anything
        CASE COMPILE.CBP
            GOSUB DISPLAY.COMPILE.CBP

* compiling core.  don't show anything
        CASE COMPILE.CORE
            GOSUB DISPLAY.COMPILE.CORE

    END CASE

* if "reformat compound lines" is on reformat the program, breaking
* up compound lines
    REFORMAT.START.DATE = DATE()
    REFORMAT.START.TIME = TIME()

    IF REFORMAT.COMPOUND.LINES THEN
        GOSUB REFORMAT.ECLIPSE.CODE
    END

    REFORMAT.END.DATE = DATE()
    REFORMAT.END.TIME = TIME()

    REFORMAT.ELAPSED.TIME += TIME.ELAPSED (REFORMAT.START.DATE, REFORMAT.START.TIME)

* the only writes we do to the program file is for compiling objects
* and object-enabled subrouties.  for those we write the converted
* code out to the target file.  for cbp programs and core programs
* we don't do any writes anywhere, we just pass things on to ba to
* compile the program through eclipse's precompiler
    IF (COMPILE.OBJECT OR COMPILE.SUBROUTINE) AND SAVE.CBPS THEN

        GOSUB UPDATE.COMPILE.STAMP

        WRITE.START.DATE = DATE()
        WRITE.START.TIME = TIME()

        WRITE.ERROR = @FALSE
        WRITE PROGRAM.CODE ON TARGETFILE, SUBROUTINE.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the obj record something is amiss somewhere.  otherwise
* delete the temporary record method from obj
        IF WRITE.ERROR THEN
            ERROR.FILE = TARGET.FILENAME
            ERROR.ITEM = SUBROUTINE.NAME
            GOSUB WRITE.ERROR
        END

        WRITE.END.DATE = DATE()
        WRITE.END.TIME = TIME()

        WRITE.ELAPSED.TIME += TIME.ELAPSED (WRITE.START.DATE, WRITE.START.TIME)

    END

* if the "view" option is on display the converted program in a view-only
* editor window
    IF (COMPILE.OBJECT OR COMPILE.SUBROUTINE) AND VIEW.CONVERTED.CODE THEN

        IF SAVE.CBPS THEN
            STATEMENT = "VIEW ":TARGET.FILENAME:" ":SUBROUTINE.NAME
            EXECUTE STATEMENT
        END ELSE
            UD.VIEW.TEXT PROGRAM.CODE, 0, 0, TARGET.FILENAME, SUBROUTINE.NAME:" (not saved)"
        END

    END

    GOSUB UPDATE.COMPILED.TABLE

    SAVE.END.DATE = DATE()
    SAVE.END.TIME = TIME()

    SAVE.ELAPSED.TIME += TIME.ELAPSED (SAVE.START.DATE, SAVE.START.TIME)

    RETURN

DISPLAY.NOT.SAVING: ******************************************************
* display that we compiled a program but we're not saving the cbp        *
* and we won't be doing the eclipse compile                              *
**************************************************************************
    IS.SPLIT = @FALSE

    PRINT "        ":TARGET.FILENAME:" ":SUBROUTINE.NAME:" *not* saved."

    METHOD.CREATE.COUNT += 1
    METHOD.LINE.COUNT += PROGRAM.CODE.LINES
    METHOD.BYTE.COUNT += PROGRAM.BYTES

    RETURN

DISPLAY.COMPILE.OBJECT.METHOD: *******************************************
* display that we're going to do the eclipse compilation for a           *
* subroutine created from an object / method                             *
**************************************************************************

* see if this method has changed and needs to be compiled
    THIS.METHOD = METHOD
    GOSUB CHECK.NEED.COMPILE

    IF NOT(BRIEF) THEN

        IF SHOW.SAVING.ITEMS THEN
            PRINT "    ":TARGET.FILENAME:" ":SUBROUTINE.NAME:" saved"
        END

        IF SHOW.LINE.COUNTS THEN
            PRINT "        Exported ":PROGRAM.CODE.LINES "L,":" lines, ":
            PRINT PROGRAM.BYTES "L,":" bytes"
        END

    END

    METHOD.CREATE.COUNT += 1
    METHOD.LINE.COUNT += PROGRAM.CODE.LINES
    METHOD.BYTE.COUNT += PROGRAM.BYTES

    RETURN

DISPLAY.COMPILE.OBJECT.SUBROUTINE: ***************************************
* display that we're gonig to do the eclipse compilation for a           *
* subroutine created from an object-enabled subroutine                   *
**************************************************************************
    IF NOT(BRIEF) THEN

        IF SHOW.SAVING.ITEMS THEN
            PRINT "    ":TARGET.FILENAME:" ":SUBROUTINE.NAME:" saved"
        END

        IF SHOW.LINE.COUNTS THEN
            PRINT "        Exported ":PROGRAM.CODE.LINES "L,":" lines, ":
            PRINT PROGRAM.BYTES "L,":" bytes"
        END

    END

    SOURCE.START = 1
    TARGET.START = 1
    SOURCE.LINE.COUNT = OBJECT.CODE.LINES

    SOURCE.COMMON.START = ""
    TARGET.COMMON.START = ""
    SOURCE.COMMON.COUNT = ""

    PROGRAM.CODE.LINES = SOURCE.LINE.COUNT

    RETURN

DISPLAY.COMPILE.OC: ******************************************************
* display that we're going to "compile" an oc program.  we won't         *
* actually do a compile on an oc program.  being able to "compile" an oc *
* allows us to do all the subroutine checking (and more) on oc record    *
* that is normally done for object-enabled routines                      *
**************************************************************************
    IS.SPLIT = @FALSE

    IF NOT(BRIEF) THEN

        IF SHOW.SAVING.ITEMS THEN
            PRINT "    OC ":SUBROUTINE.NAME:" processed"
        END

        IF SHOW.LINE.COUNTS THEN
            PRINT "        ":LINE.INDENT:PROGRAM.CODE.LINES "L,":" lines, ":
            PRINT PROGRAM.BYTES "L,":" bytes"
        END

    END

* if this oc generated any errors or warnings print a message
    IF ERROR.SUBROUTINE.COUNT > 0 THEN
        PRINT "    ":ERROR.SUBROUTINE.COUNT:" error":
        IF ERROR.SUBROUTINE.COUNT <> 1 THEN
            PRINT "s":
        END
    END

    IF WARNING.SUBROUTINE.COUNT > 0 THEN
        PRINT "    ":WARNING.SUBROUTINE.COUNT:" warning":
        IF WARNING.SUBROUTINE.COUNT <> 1 THEN
            PRINT "s":
        END
    END

    IF TOTAL.ERRORS = 0 THEN
        PRINT "    No warnings or errors found"
    END

    PRINT

    SOURCE.START = 1
    TARGET.START = 1
    SOURCE.LINE.COUNT = OBJECT.CODE.LINES

    SOURCE.COMMON.START = ""
    TARGET.COMMON.START = ""
    SOURCE.COMMON.COUNT = ""

    PROGRAM.CODE.LINES = SOURCE.LINE.COUNT

    RETURN

DISPLAY.COMPILE.CBP: *****************************************************
* display that we're going to do an eclipse compile for a cbp program    *
**************************************************************************
    IS.SPLIT = @FALSE

    SOURCE.START = 1
    TARGET.START = 1
    SOURCE.LINE.COUNT = OBJECT.CODE.LINES

    SOURCE.COMMON.START = ""
    TARGET.COMMON.START = ""
    SOURCE.COMMON.COUNT = ""

    PROGRAM.CODE.LINES = SOURCE.LINE.COUNT

    RETURN

DISPLAY.COMPILE.CORE: ****************************************************
* display that we're going to do an eclipse compile on a core program    *
**************************************************************************
    IS.SPLIT = @FALSE

    SOURCE.START = 1
    TARGET.START = 1
    SOURCE.LINE.COUNT = OBJECT.CODE.LINES

    SOURCE.COMMON.START = ""
    TARGET.COMMON.START = ""
    SOURCE.COMMON.COUNT = ""

    PROGRAM.CODE.LINES = SOURCE.LINE.COUNT

    RETURN

UPDATE.COMPILED.TABLE: ***************************************************
* update table of created items.  this list will be used later to        *
* compile everything in one shot                                         *
**************************************************************************

* if already in the compiled table don't add it again
    LOCATE SUBROUTINE.NAME IN CREATED.SUBROUTINE.LIST SETTING SUB.PTR THEN
        RETURN
    END

    CREATED.METHOD.COUNT += 1

* if we're adding a split routine to the compile list we want to add it
* so that the split routine is compiled first.  the normal routine calls
* the split routine so eclipse's compiler will kick back an error if the
* split routine isn't there before the normal compile is performed

* if we're adding a split routine find the normal routine and insert the
* split routine before the normal routine.  if the normal routine isn't
* in the list (it should always be but who knows?) we'll just add to the
* end of the compile table
    CREATED.METHOD.PTR = CREATED.METHOD.COUNT

    IF IS.SPLIT AND SUBROUTINE.NAME [LEN(SPLIT.SUFFIX)] = SPLIT.SUFFIX THEN

        NORMAL.SUBROUTINE.NAME = SUBROUTINE.NAME [1, LEN(SUBROUTINE.NAME) - LEN(SPLIT.SUFFIX)]

        LOCATE NORMAL.SUBROUTINE.NAME IN CREATED.SUBROUTINE.LIST SETTING NORMAL.PTR THEN

* we found the normal subroutine for this split routine.  insert a blank
* spot before the normal subroutine.  we'll put the split routine there
            INS "" BEFORE CREATED.METHOD.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.SUBROUTINE.LIST<NORMAL.PTR>

            INS "" BEFORE CREATED.SOURCE.START.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.TARGET.START.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.SOURCE.COUNT.LIST<NORMAL.PTR>

            INS "" BEFORE CREATED.SOURCE.COMMON.START.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.TARGET.COMMON.START.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.SOURCE.COMMON.COUNT.LIST<NORMAL.PTR>

            INS "" BEFORE CREATED.SUBROUTINE.COUNT.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.SUBROUTINE.BYTE.LIST<NORMAL.PTR>

            INS "" BEFORE CREATED.METHOD.SOURCE.LIST<NORMAL.PTR>
            INS "" BEFORE CREATED.METHOD.FINAL.LIST<NORMAL.PTR>

            CREATED.METHOD.PTR = NORMAL.PTR

        END

    END

    CREATED.METHOD.LIST<CREATED.METHOD.PTR> = METHOD
    CREATED.SUBROUTINE.LIST<CREATED.METHOD.PTR> = SUBROUTINE.NAME

    CREATED.SOURCE.START.LIST<CREATED.METHOD.PTR> = SOURCE.START
    CREATED.TARGET.START.LIST<CREATED.METHOD.PTR> = TARGET.START
    CREATED.SOURCE.COUNT.LIST<CREATED.METHOD.PTR> = SOURCE.LINE.COUNT

    CREATED.SOURCE.COMMON.START.LIST<CREATED.METHOD.PTR> = SOURCE.COMMON.START
    CREATED.TARGET.COMMON.START.LIST<CREATED.METHOD.PTR> = TARGET.COMMON.START
    CREATED.SOURCE.COMMON.COUNT.LIST<CREATED.METHOD.PTR> = SOURCE.COMMON.COUNT

    CREATED.SUBROUTINE.COUNT.LIST<CREATED.METHOD.PTR> = PROGRAM.CODE.LINES
    CREATED.SUBROUTINE.BYTE.LIST<CREATED.METHOD.PTR> = LEN(PROGRAM.CODE)

    CREATED.METHOD.SOURCE.LIST<CREATED.METHOD.PTR> = LOWER(PROGRAM.CODE.SOURCE.LIST)
    CREATED.METHOD.FINAL.LIST<CREATED.METHOD.PTR> = LOWER(PROGRAM.CODE.FINAL.LIST)

    RETURN

SAVE.OBP.WRAPPER: ********************************************************
* save a wrapper object-enabled source code to the obp file              *
**************************************************************************
    IF NOT(WRAPPER.CREATED) OR WRAPPER.SUBROUTINE.NAME = "" OR WRAPPER.CODE.LINES = 0 THEN
        RETURN
    END
    IF LIST.OBJECTS.ONLY THEN
        RETURN
    END

* if we aren't saving cbps (ie, "NOSAVE" is turned on) don't save wrappers
* either
    IF NOT(SAVE.CBPS) THEN
        RETURN
    END

    WRITE.ERROR = @FALSE
    WRITE WRAPPER.CODE ON OBPFILE, UPCASE(WRAPPER.SUBROUTINE.NAME) ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the obp subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "OBP"
        ERROR.ITEM = UPCASE(WRAPPER.SUBROUTINE.NAME)
        GOSUB WRITE.ERROR
    END

* update the list of created wrappers
    WRAPPER.CREATE.COUNT += 1
    WRAPPER.CREATE.LIST<WRAPPER.CREATE.COUNT> = UPCASE(WRAPPER.SUBROUTINE.NAME)

    RETURN

UPDATE.COMPILE.STAMP: ****************************************************
* get the compile stamp from the target file for an eclipse-style        *
* subroutine                                                             *
**************************************************************************
    STAMP.START.DATE = DATE()
    STAMP.START.TIME = TIME()

* initialize everybody
    OLD.STAMP.TEXT = ""
    OLD.STAMP.LINE = ""
    OLD.STAMP.DATE = ""
    OLD.STAMP.TIME = ""
    OLD.STAMP.USER = ""
    OLD.STAMP.ACCOUNT = ""

    NEW.STAMP.TEXT = ""
    NEW.STAMP.LINE = ""
    NEW.STAMP.DATE = ""
    NEW.STAMP.TIME = ""
    NEW.STAMP.USER = ""
    NEW.STAMP.ACCOUNT = ""

    OBJECT.STAMP.LINE = ""

    STAMP.PREFIX = "** Version# "

    VERSION = ""
    EDIT = ""

* read original program
    READ STAMP.REC FROM TARGETFILE, SUBROUTINE.NAME ELSE
        STAMP.REC = ""
    END

* find stamp line in original program
    STAMP.REC.LINES = DCOUNT(STAMP.REC,@AM)
    SETREM 0 ON STAMP.REC.LINES

    FOR STAMP.LOOP = 1 TO STAMP.REC.LINES UNTIL OLD.STAMP.TEXT <> ""

*       THIS.STAMP = STAMP.REC<STAMP.LOOP>
        REMOVE THIS.STAMP FROM STAMP.REC SETTING THROWAWAY
        IF THIS.STAMP [1, LEN(STAMP.PREFIX)] = STAMP.PREFIX THEN
            OLD.STAMP.TEXT = TRIM(THIS.STAMP)
            OLD.STAMP.LINE = STAMP.LOOP
        END

    NEXT STAMP.LOOP

* get version and edit number
    OLD.VERSION = ""

    IF OLD.STAMP.TEXT <> "" THEN

        OLD.VERSION = OLD.STAMP.TEXT [" ", 3, 1]
        VERSION = OLD.VERSION ["[", 1, 1]
        EDIT = OLD.VERSION ["[", 2, 1] ["]", 1, 1]
        OLD.STAMP.DATE = OLD.STAMP.TEXT [" ", 5, 1]
        OLD.STAMP.TIME = OLD.STAMP.TEXT [" ", 7, 1]
        OLD.STAMP.USER = OLD.STAMP.TEXT [" ", 9, 1]
        OLD.STAMP.ACCOUNT = OLD.STAMP.TEXT [" ", 11, 1]

    END

* if we're flagged to use eclipse's version updates call pe.open.edit to
* update the compile stamp
    IF USE.ECLIPSE.VERSION.UPDATES THEN
        GOSUB DO.ECLIPSE.VERSION.STAMP
    END ELSE
        GOSUB DO.MANUAL.VERSION.STAMP
    END

    STAMP.END.DATE = DATE()
    STAMP.END.TIME = TIME()
    STAMP.ELAPSED.TIME += TIME.ELAPSED (STAMP.START.DATE, STAMP.START.TIME)

    IF DETAILS THEN

        PRINT
        PRINT "Updating Stamp for ":SUBROUTINE.NAME:":"

        PRINT "    Old Stamp Line: ":
        IF OBJECT.STAMP.LINE = "" THEN
            PRINT OBJECT.STAMP.LINE
        END ELSE
            PRINT "Not found"
            PRINT "    Insert Stamp Line: ":INSERT.STAMP.LINE
        END

        PRINT "    Old Stamp: ":'"':OLD.STAMP.TEXT:'"'
        PRINT "    New Stamp: ":'"':NEW.STAMP.TEXT:'"'

        GOSUB WAIT

    END

    RETURN

DO.ECLIPSE.VERSION.STAMP: ************************************************
* version stamp subroutine.name using eclipse routines                   *
**************************************************************************
    PE.VERSION.ID = TARGET.FILENAME:"~":SUBROUTINE.NAME
    EDIT.USER.ID = USER.ID
    TRACKING.NUMBER = ""
    CREATE.LOG = ""
    NEW.VERSION = OLD.VERSION
    PRE.LINE.COUNT = DCOUNT(PROGRAM.CODE, @AM)

    PE.OPEN.EDIT PE.VERSION.ID, PROGRAM.CODE, STAMP.REC, 1, EDIT.USER.ID, "", NEW.VERSION, CREATE.LOG

    VERSION = NEW.VERSION ["[", 1, 1]
    EDIT = NEW.VERSION ["[", 2, 1] ["]", 1, 1]
    POST.LINE.COUNT = DCOUNT(PROGRAM.CODE, @AM)

* how many lines did pe.open.edit insert?  one will be added to the end
* of the program and we don't care about that one.  only the lines added
* at the top of the program
    LINES.ADDED = POST.LINE.COUNT - PRE.LINE.COUNT - 1

* if the program didn't already have a stamp pe.open.edit will add a
* new line for the stamp and bump all the later lines down.  this will make
* error lines displays off by one line.  if this is the case find the first
* null or comment line (that isn't a compile stamp) in the program and
* delete it to fix the line counts
    IF LINES.ADDED > 0 THEN

        FOR REMOVE.ADDED.LINES = 1 TO LINES.ADDED

            FIX.STAMP.LINE = 3
            
            LOOP
                FIRST.CHAR = TRIM(PROGRAM.CODE<FIX.STAMP.LINE>) [1, 1]
            UNTIL FIRST.CHAR = "*" OR FIRST.CHAR = "" OR FIRST.CHAR = "!"
                FIX.STAMP.LINE += 1
            REPEAT

            DEL PROGRAM.CODE<FIX.STAMP.LINE>

        NEXT REMOVE.ADDED.LINES

    END

    RETURN

DO.MANUAL.VERSION.STAMP: *************************************************
* version stamp subroutine.name with manual code                         *
**************************************************************************
    IF VERSION = "" THEN
        VERSION = "0.0001"
    END

    IF EDIT = "" THEN
        EDIT = 0
    END

* increment edit number
    EDIT += 1

* build new time stamp line
    NEW.STAMP.DATE = OCONV(DATE(), "D2/")
    NEW.STAMP.TIME = OCONV(TIME(), "MTH")
    NEW.STAMP.USER = USER.ID
    NEW.STAMP.ACCOUNT = ACCOUNT

    NEW.STAMP.TEXT = STAMP.PREFIX:VERSION:"[":EDIT:"]"
    NEW.STAMP.TEXT := " - ":NEW.STAMP.DATE:" - ":NEW.STAMP.TIME
    NEW.STAMP.TEXT := "  - ":NEW.STAMP.USER:" - ":NEW.STAMP.ACCOUNT

* see if we can find the time stamp in the new program
    SETREM 0 ON PROGRAM.CODE
    FOR STAMP.LOOP = 1 TO PROGRAM.CODE.LINES UNTIL OBJECT.STAMP.LINE <> ""

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY
        IF THIS.LINE [1, LEN(STAMP.PREFIX)] = STAMP.PREFIX THEN
            OBJECT.STAMP.LINE = STAMP.LOOP
        END

    NEXT STAMP.LOOP

* if we didn't find a time stamp insert it as the second program line.
* if we did find one we'll replace it

* if we have to insert a new line we don't want to actually add a line.
* this will make the source / final line xref off by 1 and all the
* error messages will point to the wrong program line.  find the first
* comment or null line in the program and save the stamp there
    IF OBJECT.STAMP.LINE = "" THEN

        INSERT.STAMP.LINE = 2
        LOOP
            FIRST.CHAR = TRIM(PROGRAM.CODE<INSERT.STAMP.LINE>) [1, 1]
        UNTIL FIRST.CHAR = "*" OR FIRST.CHAR = "" OR FIRST.CHAR = "!"
            INSERT.STAMP.LINE += 1
        REPEAT

        PROGRAM.CODE<INSERT.STAMP.LINE> = NEW.STAMP.TEXT

    END ELSE

        PROGRAM.CODE<OBJECT.STAMP.LINE> = NEW.STAMP.TEXT

    END

    RETURN

SET.PERMISSIONS: *********************************************************
* set permissions for PERMIT.FILE, PERMIT.ITEM based on settings loaded  *
* from the compile setup record                                          *
**************************************************************************
    IF LIST.OBJECTS.ONLY THEN
        RETURN
    END

    IF NOT(SET.PERMISSIONS) THEN
        RETURN
    END

    IF UPCASE(PERMIT.FILE) <> "OBJ.NET" THEN
        PERMIT.FILE = UPCASE(PERMIT.FILE)
        PERMIT.ITEM = UPCASE(PERMIT.ITEM)
    END

    PERMIT.PATHNAME = LOCAL.DIRECTORY:"/":PERMIT.FILE:"/":PERMIT.ITEM

    BEGIN CASE

        CASE PERMIT.FILE = "OBJ"
            USE.PERMISSIONS = PERMISSIONS.OBJ
            CHECK.FILE.HANDLE = OBJFILE

        CASE PERMIT.FILE = "OBP"
            USE.PERMISSIONS = PERMISSIONS.OBP
            CHECK.FILE.HANDLE = OBPFILE

        CASE PERMIT.FILE = "CBP"
            USE.PERMISSIONS = PERMISSIONS.CBP
            CHECK.FILE.HANDLE = CBPFILE

        CASE PERMIT.FILE = "BP"
            USE.PERMISSIONS = PERMISSIONS.BP
            CHECK.FILE.HANDLE = BPFILE

        CASE PERMIT.FILE = "OC"
            USE.PERMISSIONS = PERMISSIONS.OC
            CHECK.FILE.HANDLE = OCFILE

        CASE PERMIT.FILE = "OBJ.NET"
            USE.PERMISSIONS = PERMISSIONS.NET
            CHECK.FILE.HANDLE = OBJNETFILE

        CASE PERMIT.FILE = "OBJ.JAVA"
            USE.PERMISSIONS = PERMISSIONS.NET
            CHECK.FILE.HANDLE = OBJJAVAFILE

        CASE 1
            USE.PERMISSIONS = ""

    END CASE

    IF USE.PERMISSIONS = "" THEN
        RETURN
    END

    IF NOT(NUM(USE.PERMISSIONS)) THEN
        RETURN
    END

* make sure the file exists before we try to change permissions.  for some
* file (like OC) the file may not exist yet
    READV CHECK.ON.FILE FROM CHECK.FILE.HANDLE, PERMIT.ITEM, 0 ELSE
        RETURN
    END

* set permissions for the saved program
    UNIX.COMMAND = "chmod ":USE.PERMISSIONS:" ":PERMIT.PATHNAME
    UV.COMMAND = 'SH -c "':UNIX.COMMAND:'"'

    EXECUTE UV.COMMAND CAPTURING PERMIT.TEXT

    GOSUB DISPLAY.PERMISSION.ERROR

* set permissions for the OC version of the program
    IF PERMISSIONS.OC <> "" THEN

        IF PERMIT.FILE = "OBP" OR PERMIT.FILE = "CBP" OR PERMIT.FILE = "BP" THEN

            PERMIT.PATHNAME = LOCAL.DIRECTORY:"/OC/":PERMIT.ITEM

* if this program name exists in bp then it's either a core code program or a
* core code program that was hijacked from bp.  either way we want to leave the
* oc permissions open so that eclipse upgrades can be compiled in the future
            READV TEST.REC FROM BPFILE, PERMIT.ITEM, 0 THEN
                USE.PERMISSIONS = PERMISSIONS.BP
            END ELSE
                USE.PERMISSIONS = PERMISSIONS.OC
            END

* make sure the oc version exists
            READV CHECK.ON.FILE FROM OCFILE, PERMIT.ITEM, 0 THEN

* set the permissions for the oc version of the program
                UNIX.COMMAND = "chmod ":USE.PERMISSIONS:" ":PERMIT.PATHNAME
                UV.COMMAND = 'SH -c "':UNIX.COMMAND:'"'

                EXECUTE UV.COMMAND CAPTURING PERMIT.TEXT

                GOSUB DISPLAY.PERMISSION.ERROR

            END

        END

    END

    RETURN

DISPLAY.PERMISSION.ERROR: ************************************************
* if there's an error changing the permissions of a program display      *
* the error                                                              *
**************************************************************************
    IF PERMIT.TEXT = "" THEN
        RETURN
    END

    IF NOT(SHOW.PERMISSION.ERRORS) THEN
        RETURN
    END

    PERMIT.MAX.WIDTH = 63

    PRINT
    PRINT "Warning: Cannot change permissions on ":PERMIT.PATHNAME:":"

    PERMIT.TEXT = CHANGE(PERMIT.TEXT, CHAR(13), @AM)
    PERMIT.TEXT = CHANGE(PERMIT.TEXT, CHAR(10), "")

    PERMIT.TEXT.LEN = LEN(PERMIT.TEXT)
    FOR CHAR.PTR = PERMIT.TEXT.LEN TO 1 STEP -1

        THIS.ASCII = SEQ(PERMIT.TEXT [CHAR.PTR, 1])

        IF THIS.ASCII < 254 THEN
            IF THIS.ASCII > 127 OR THIS.ASCII < 32 THEN
                PERMIT.TEXT = PERMIT.TEXT [1, CHAR.PTR - 1]:PERMIT.TEXT [CHAR.PTR + 1, 1000000]
            END
        END

    NEXT CHAR.PTR

    TEXT.COUNT = DCOUNT(PERMIT.TEXT, @AM)
    FOR TEXT.LOOP = TEXT.COUNT TO 1 STEP -1

        IF LEN(PERMIT.TEXT<TEXT.LOOP>) > PERMIT.MAX.WIDTH THEN
            PERMIT.FOLDED = "":FOLD(PERMIT.TEXT<TEXT.LOOP>, PERMIT.MAX.WIDTH)
            PERMIT.TEXT<TEXT.LOOP> = PERMIT.FOLDED
        END

    NEXT TEXT.LOOP

    TEXT.COUNT = DCOUNT(PERMIT.TEXT, @AM)
    FOR TEXT.LOOP = 1 TO TEXT.COUNT 
        PRINT "    ":PERMIT.TEXT<TEXT.LOOP>
    NEXT TEXT.LOOP

    RETURN


**************************************************************************
**************************************************************************
** eclipse / formatting code                                            **
**************************************************************************
**************************************************************************

REFORMAT.ECLIPSE.CODE: ***************************************************
* reformat program.code to break up compound lines                       *
**************************************************************************
    NEW.PROGRAM.CODE = ""
    NEW.PROGRAM.CODE.LINES = 0

    PROGRAM.CODE.LINES = DCOUNT(PROGRAM.CODE, @AM)

    PROGRAM.CODE.INDENT.COUNT = LEN(PROGRAM.CODE.INDENT)

    SETREM 0 ON PROGRAM.CODE

    INDENT.ALL = 0
    CLOSE.WITH.NEXT.END = 0

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

        IF IS.CODE (THIS.LINE) THEN

            GOSUB PROCESS.ECLIPSE.CODE.LINE

            BEGIN CASE

                CASE MULTI.COUNT = 1
                    GOSUB ADD.REFORMAT.LINE

                CASE LABEL <> ""
                    THIS.CODE = MULTI.LINE<1>
                    GOSUB ADD.REFORMAT.LINE
                    DEL MULTI.LINE<1>
                    NEW.PROGRAM.CODE := @AM:MULTI.LINE
                    NEW.PROGRAM.CODE.LINES += MULTI.COUNT - 1

                CASE 1
                    NEW.PROGRAM.CODE := @AM:MULTI.LINE
                    NEW.PROGRAM.CODE.LINES += MULTI.COUNT

            END CASE

        END ELSE

            GOSUB PROCESS.ECLIPSE.COMMENT.LINE
            GOSUB ADD.REFORMAT.LINE

        END

    NEXT LINE

* if we have more than one blank line in a row, usually from lines that
* wrapped up, remove the extra blanks
    NEXT.LINE = TRIM(NEW.PROGRAM.CODE<NEW.PROGRAM.CODE.LINES>)

    FOR LINE.LOOP = PROGRAM.CODE.LINES - 1 TO 1 STEP -1

        THIS.LINE = TRIM(NEW.PROGRAM.CODE<LINE.LOOP>)

        IF THIS.LINE = "" AND NEXT.LINE = "" THEN
            DEL NEW.PROGRAM.CODE<LINE.LOOP + 1>
            NEW.PROGRAM.CODE.LINES -= 1
        END

        NEXT.LINE = THIS.LINE

    NEXT LINE.LOOP

    PROGRAM.CODE = NEW.PROGRAM.CODE
    PROGRAM.CODE.LINES = NEW.PROGRAM.CODE.LINES

    RETURN

PROCESS.ECLIPSE.COMMENT.LINE: ********************************************
* process a comment (non-code) line to adjust indents                    *
**************************************************************************
    LABEL = LINE.LABEL (THIS.LINE)

    IF LABEL <> "" THEN
        THIS.CODE = LINE.WITHOUT.LABEL (THIS.LINE)
    END ELSE
        THIS.CODE = TRIM(THIS.LINE, " ", "B")
    END

    INDENT.COUNT = FIND.INDENT.COUNT (LABEL, THIS.LINE)
    LABEL.SPACE = SPACE(LEN(LABEL))

    RETURN

PROCESS.ECLIPSE.CODE.LINE: ***********************************************
* multi.line for compound if/thens/elses                                 *
**************************************************************************
    LABEL = LINE.LABEL (THIS.LINE)

    IF LABEL <> "" THEN
        THIS.CODE = LINE.WITHOUT.LABEL (THIS.LINE)
    END ELSE
        THIS.CODE = TRIM(THIS.LINE, " ", "B")
    END

    INDENT.COUNT = FIND.INDENT.COUNT(LABEL, THIS.LINE)
    MULTI.LINE = SPLIT.COMPOUND.LINE (THIS.CODE)

    MULTI.COUNT = DCOUNT(MULTI.LINE, @AM)
    LABEL.SPACE = SPACE(LEN(LABEL))

* if this line is just an "end" or "end else" and close.with.next.end indicates
* that we have to close some if's add the "end" statements
    IF THIS.CODE = "END ELSE" OR THIS.CODE = "END" AND CLOSE.WITH.NEXT.END > 0 THEN

        FOR CLOSE.LOOP = 1 TO CLOSE.WITH.NEXT.END

            CLOSE.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT.ALL * 4):"END"
            MULTI.COUNT += 1
            INS CLOSE.LINE BEFORE MULTI.LINE <CLOSE.LOOP>
            INDENT.ALL -= 1

        NEXT CLOSE.LOOP 

        MULTI.LINE<MULTI.COUNT> = SPACE(INDENT.COUNT + INDENT.ALL * 4):THIS.CODE

        CLOSE.WITH.NEXT.END = 0

        RETURN

    END

* loop through code lines and break up if/thens/else/etc
    INDENT = 0
    HIT.THEN = @FALSE
    IGNORE.INDENT.COUNT = 0
    INDENT.ALL.AFTER = 0
    EXTRA.CLOSES = 0

    STOP.REFORMATTING = @FALSE

    FOR MULTI.LOOP = 1 TO MULTI.COUNT UNTIL STOP.REFORMATTING

        REFORMATTED = @FALSE

        ORIGINAL.MULTI.LINE = MULTI.LINE<MULTI.LOOP>
        THIS.MULTI = SPLIT.CODE.LINE(ORIGINAL.MULTI.LINE)
        ORIGINAL.MULTI.LINE = TRIM(ORIGINAL.MULTI.LINE, " ", "B")
        WORD.COUNT = DCOUNT(THIS.MULTI, @AM)

        FIRST.CHAR = ORIGINAL.MULTI.LINE [1, 1]
        IF FIRST.CHAR = "*" OR FIRST.CHAR = "!" THEN
            STOP.REFORMATTING = @TRUE
        END

        INDENT.AFTER = 0

*       FOR WORD.LOOP = 1 TO WORD.COUNT UNTIL REFORMATTED OR STOP.REFORMATTING
        FOR WORD.LOOP = 1 TO WORD.COUNT UNTIL STOP.REFORMATTING

            THIS.WORD = THIS.MULTI<WORD.LOOP>
            TWO.WORDS = THIS.MULTI<WORD.LOOP>:" ":THIS.MULTI<WORD.LOOP + 1>

            BEGIN CASE

* the entire line is an "else" or "end else"
                CASE ORIGINAL.MULTI.LINE = "END ELSE"
                    INDENT -= 1
                    INDENT.AFTER += 1
                CASE ORIGINAL.MULTI.LINE = "END"
                    INDENT -= 1
                    IF INDENT.ALL > 0 THEN
                        INDENT.ALL -= 1
                    END

* case statements
                CASE ORIGINAL.MULTI.LINE = "BEGIN CASE"
                    INDENT += 1
                    IGNORE.INDENT.COUNT += 1
                CASE THIS.WORD = "CASE" AND WORD.LOOP = 1
                    INDENT += 1
                    INDENT.AFTER += 1
                    IGNORE.INDENT.COUNT += 2
                CASE ORIGINAL.MULTI.LINE = "END CASE"
                    INDENT -= 2
                    IGNORE.INDENT.COUNT -= 2

* for loops
                CASE THIS.WORD = "FOR" AND WORD.LOOP = 1
                    INDENT.AFTER += 1
                    IGNORE.INDENT.COUNT += 1
                CASE THIS.WORD = "NEXT" AND WORD.LOOP = 1
                    INDENT -= 1
                    IGNORE.INDENT.COUNT -= 1

* loop / repeats
                CASE THIS.WORD = "LOOP" AND WORD.LOOP = 1 
                    INDENT.AFTER += 1
                    IGNORE.INDENT.COUNT += 1
                CASE THIS.WORD = "REPEAT"
                    GOSUB CLOSE.SAME.LINE.IFS
                    INDENT -= 1
                    IGNORE.INDENT.COUNT -= 1

* until
                CASE THIS.WORD = "UNTIL"
                    GOSUB CLOSE.SAME.LINE.IFS
                    GOSUB PROCESS.ECLIPSE.UNTIL
                    REFORMATTED = @TRUE
                    INDENT -= 1
                    IGNORE.INDENT.COUNT += 1
                    INDENT.AFTER = 1

* then if
                CASE TWO.WORDS = "THEN IF"
                    GOSUB PROCESS.ECLIPSE.THEN
                    HIT.THEN = @TRUE
                    REFORMATTED = @TRUE
                    IGNORE.INDENT.COUNT += 1
                    INDENT.ALL.AFTER += 1

* else if
                CASE TWO.WORDS = "ELSE IF" AND NOT(HIT.THEN)
                    GOSUB PROCESS.ECLIPSE.ELSE.WITHOUT.THEN
                    REFORMATTED = @TRUE
                    IGNORE.INDENT.COUNT += 1
                CASE TWO.WORDS = "ELSE IF"
                    GOSUB PROCESS.ECLIPSE.ELSE
                    REFORMATTED = @TRUE
                    IGNORE.INDENT.COUNT += 1
                
* then / else at the end of the last compound line
                CASE THIS.WORD = "THEN" AND WORD.LOOP = WORD.COUNT AND MULTI.LOOP = MULTI.COUNT
                    INDENT.AFTER += 1
                    IGNORE.INDENT.COUNT += 1
                CASE THIS.WORD = "ELSE" AND WORD.LOOP = WORD.COUNT AND MULTI.LOOP = MULTI.COUNT
                    INDENT.AFTER += 1
                    IGNORE.INDENT.COUNT += 1

* then / else at the end of a line that's not the last of a compound line
                CASE THIS.WORD = "THEN" AND WORD.LOOP = WORD.COUNT
                    INDENT.AFTER += 1
                CASE THIS.WORD = "ELSE" AND WORD.LOOP = WORD.COUNT
                    INDENT.AFTER += 1

* then that's not at the end of a line
                CASE THIS.WORD = "THEN"
                    GOSUB PROCESS.ECLIPSE.THEN
                    HIT.THEN = @TRUE
                    REFORMATTED = @TRUE
                    IF IGNORE.INDENT.COUNT > 0 THEN
                        IGNORE.INDENT.COUNT -= 1
                    END

* else that's not at the end of a line and we haven't hit a "then" yet
                CASE THIS.WORD = "ELSE" AND NOT(HIT.THEN)
                    GOSUB PROCESS.ECLIPSE.ELSE.WITHOUT.THEN
                    REFORMATTED = @TRUE
                    IF IGNORE.INDENT.COUNT > 0 THEN
                        IGNORE.INDENT.COUNT -= 1
                    END

* else that's not at the end of a line and we've hit a "then" already
                CASE THIS.WORD = "ELSE"
                    GOSUB PROCESS.ECLIPSE.ELSE                    
                    REFORMATTED = @TRUE
                    IF IGNORE.INDENT.COUNT > 0 THEN
                        IGNORE.INDENT.COUNT -= 1
                    END

            END CASE

        NEXT WORD.LOOP

* if we didn't reformat this line set the indention
        IF NOT(REFORMATTED) THEN
            INDENTED.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
            INDENTED.LINE := ORIGINAL.MULTI.LINE
            MULTI.LINE<MULTI.LOOP> = INDENTED.LINE
        END

        INDENT += INDENT.AFTER

    NEXT MULTI.LOOP

* if we still have open indents then we have to add "end" statements
* to close everything
    INDENT -= IGNORE.INDENT.COUNT
    INDENT.ALL += INDENT.ALL.AFTER
    CLOSE.WITH.NEXT.END += INDENT.ALL.AFTER

    IF INDENT > 0 THEN

        INDENT += CLOSE.WITH.NEXT.END
        INDENT.ALL -= CLOSE.WITH.NEXT.END
        CLOSE.WITH.NEXT.END = 0

        FOR CLOSE.LOOP = INDENT TO 1 STEP -1

            CLOSE.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + (CLOSE.LOOP - 1) * 4 + INDENT.ALL * 4):"END"
            MULTI.COUNT += 1
            MULTI.LINE := @AM:CLOSE.LINE

        NEXT CLOSE.LOOP

    END

    RETURN

PROCESS.ECLIPSE.THEN: ****************************************************
* modify this.multi based on a "then" in this word at word.loop          *
**************************************************************************

* build the part of this.multi to keep in the current line
    IF MULTI.LOOP = 1 THEN
        KEEP.LINE = LABEL:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END ELSE
        KEEP.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END

    KEEP.LINE := CHANGE(THIS.MULTI [@AM, 1, WORD.LOOP], @AM, " ")

* the rest will go into the next line
    NEXT.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + 4 + INDENT.ALL * 4)
    NEXT.LINE := CHANGE(THIS.MULTI [@AM, WORD.LOOP + 1, TO.THE.END], @AM, " ")

* if there's nothing on the next line there's nothing to reformat
    IF TRIM(NEXT.LINE) = "" THEN
        RETURN
    END

* indent one level
    INDENT.AFTER += 1

* put everything back into multi-line
    MULTI.LINE<MULTI.LOOP> = KEEP.LINE:@AM:NEXT.LINE
    MULTI.COUNT += 1

    RETURN

PROCESS.ECLIPSE.ELSE.WITHOUT.THEN: ***************************************
* modify this.multi based on a "then" in this word at word.loop when a   *
* "then" hasn't been encountered                                         *
**************************************************************************

* build the part of this.multi to keep in the current line
    IF MULTI.LOOP = 1 THEN
        KEEP.LINE = LABEL:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END ELSE
        KEEP.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END

    KEEP.LINE := CHANGE(THIS.MULTI [@AM, 1, WORD.LOOP], @AM, " ")

* the rest will go into the next line
    NEXT.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + 4 + INDENT.ALL * 4)
    NEXT.LINE := CHANGE(THIS.MULTI [@AM, WORD.LOOP + 1, TO.THE.END], @AM, " ")

* if there's nothing on the next line there's nothing to reformat
    IF TRIM(NEXT.LINE) = "" THEN
        RETURN
    END

* indent one level
    INDENT.AFTER += 1

* put everything back into multi-line
    MULTI.LINE<MULTI.LOOP> = KEEP.LINE:@AM:NEXT.LINE
    MULTI.COUNT += 1

    RETURN

PROCESS.ECLIPSE.ELSE: ****************************************************
* modify this.multi based on a "else" in this word at word.loop          *
**************************************************************************

* build the part of this.multi to keep in the current line
    IF MULTI.LOOP = 1 THEN
        KEEP.LINE = LABEL:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END ELSE
        KEEP.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END

    KEEP.LINE := CHANGE(THIS.MULTI [@AM, 1, WORD.LOOP - 1], @AM, " ")

* the rest will go into the next line
    NEXT.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    NEXT.LINE := CHANGE(THIS.MULTI [@AM, WORD.LOOP + 1, TO.THE.END], @AM, " ")

* if there's nothing on the next line there's nothing to reformat
    IF TRIM(NEXT.LINE) = "" THEN
        RETURN
    END

* build the "end else" line
    ELSE.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 - 4 + INDENT.ALL * 4)
    ELSE.LINE := "END ELSE"

* put everything back into multi-line
    MULTI.LINE<MULTI.LOOP> = KEEP.LINE:@AM:ELSE.LINE:@AM:NEXT.LINE
    MULTI.COUNT += 2
    MULTI.LOOP += 1

    RETURN

PROCESS.ECLIPSE.UNTIL: ***************************************************
* modify this.multi based on an "until" in this word at word.loop        *
**************************************************************************

* build the part of this.multi to keep in the current line
    IF MULTI.LOOP = 1 THEN
        KEEP.LINE = LABEL:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END ELSE
        KEEP.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    END

    KEEP.LINE := CHANGE(THIS.MULTI [@AM, 1, WORD.LOOP - 1], @AM, " ")

* everything from the "until" on will go into the next line
    NEXT.LINE = CHANGE(THIS.MULTI [@AM, WORD.LOOP, TO.THE.END], @AM, " ")

* build the "until" line
    UNTIL.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT * 4 + INDENT.ALL * 4)
    UNTIL.LINE := NEXT.LINE

* put everything back into multi-line
    MULTI.LINE<MULTI.LOOP> = KEEP.LINE:@AM:UNTIL.LINE
    MULTI.COUNT += 1
    MULTI.LOOP += 1

    RETURN

CLOSE.SAME.LINE.IFS: *****************************************************
* some keywords, like "until" used with "loop" and "repeat", will close  *
* any "if" constructs started in the same line.  look at the brace stack *
* entry before the current one.  if it's for an "if" construct and it    *
* started on the same line delete it from the stack.  repeat until there *
* are no more "if" constructs before the current one in the stack        *
**************************************************************************
    IF.PURGE.FINISHED = @FALSE

    LOOP UNTIL IF.PURGE.FINISHED OR BRACE.DEPTH <= 1

        BEFORE.PTR = BRACE.DEPTH - 1

        PREV.START.KEYWORD = BRACE.KEYWORD.STACK<BEFORE.PTR>
        PREV.START.LINE = BRACE.KEYWORD.LINE.STACK<BEFORE.PTR>

        IF.PURGE.FINISHED = @TRUE

        IF PREV.START.KEYWORD = "IF" AND PREV.START.LINE = LINE.LOOP THEN

            DEL BRACE.KEYWORD.STACK<BEFORE.PTR>
            DEL BRACE.KEYWORD.LINE.STACK<BEFORE.PTR>

            DEL BRACE.START.STACK<BEFORE.PTR>
            DEL BRACE.ALT.START.STACK<BEFORE.PTR>
            DEL BRACE.START.LINE.STACK<BEFORE.PTR>
            DEL BRACE.HIT.START.STACK<BEFORE.PTR>

            DEL BRACE.ELSE.STACK<BEFORE.PTR>
            DEL BRACE.ELSE.LINE.STACK<BEFORE.PTR>
            DEL BRACE.HIT.ELSE.STACK<BEFORE.PTR>

            DEL BRACE.END.STACK<BEFORE.PTR>
            DEL BRACE.END.EXECUTE.STACK<BEFORE.PTR>

            DEL BRACE.LOOP.START.STACK<BEFORE.PTR>
            DEL BRACE.LOOP.END.STACK<BEFORE.PTR>
            DEL BRACE.LOOP.INDEX.STACK<BEFORE.PTR>
            DEL BRACE.LOOP.INCREMENT.STACK<BEFORE.PTR>

            DEL BRACE.CODE.AFTER.START<BEFORE.PTR>
            DEL BRACE.CODE.AFTER.ELSE<BEFORE.PTR>

            BRACE.DEPTH -= 1
            INDENT -= 1
            IF.PURGE.FINISHED = @FALSE

        END

    REPEAT

    RETURN

ADD.REFORMAT.LINE: *******************************************************
* add this.line to new.program.code                                      *
**************************************************************************

* build a new line with the new indentations
    BEGIN CASE

* line with a label
        CASE LABEL <> ""
            THIS.INDENT = SPACE(INDENT.COUNT + INDENT.ALL * 4 - PROGRAM.CODE.INDENT.COUNT)
            NEW.LINE = PROGRAM.CODE.INDENT:LABEL:THIS.INDENT:THIS.CODE

* comment line built from the object source code
        CASE THIS.LINE [1, 1] = "*" AND NUM(THIS.LINE [" ", 2, 1])
            NEW.LINE = THIS.LINE [" ", 1, 2]:" ":SPACE(INDENT.COUNT + INDENT.ALL * 4):THIS.LINE [" ", 3, TO.THE.END]

* any other line
        CASE 1
            NEW.LINE = LABEL.SPACE:SPACE(INDENT.COUNT + INDENT.ALL * 4):THIS.CODE

    END CASE

    NEW.PROGRAM.CODE.LINES += 1

    IF NEW.PROGRAM.CODE.LINES = 1 THEN
        NEW.PROGRAM.CODE = NEW.LINE
    END ELSE
        NEW.PROGRAM.CODE := @AM:NEW.LINE
    END

    RETURN

DISPLAY.MULTI.LINE: ******************************************************
* display multi.line for debugging                                       *
**************************************************************************
    FOR DISP.LOOP = 1 TO MULTI.COUNT
        CRT DISP.LOOP "R%3":" ":MULTI.LINE<DISP.LOOP>
    NEXT DISP.LOOP

    RETURN



**************************************************************************
**************************************************************************
** code conversion / wrapped lines                                      **
**************************************************************************
**************************************************************************

UNWRAP.LINES: ************************************************************
* look for any program lines ending in a comma or an equals sign.  these *
* lines will be merged with the line after them so that we can have long *
* subroutine call broken cleanly over multiple program lines.            *
**************************************************************************
    UNWRAP.START.DATE = DATE()
    UNWRAP.START.TIME = TIME()

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES

* if this isn't a comment line and the line ends with a comma or an equals
* sign then wrap the next line up to this one
        FIRST.LINE.PTR = LINE.LOOP
        NEXT.LINE.PTR = LINE.LOOP + 1
        IN.METHOD.DEFINITION = @FALSE
        GOSUB CHECK.LINE.WRAPPING

        IN.METHOD.DEFINITION = FOUND.METHOD.DEFINITION

* if this line wraps with the next one find out how many total lines should
* be wrapped up to the current line
        IF THIS.LINE.WRAPS THEN
            GOSUB UNWRAP.THIS.LINE
        END

    NEXT LINE.LOOP

    UNWRAP.END.DATE = DATE()
    UNWRAP.END.TIME = TIME()
    UNWRAP.ELAPSED.TIME += TIME.ELAPSED (UNWRAP.START.DATE, UNWRAP.START.TIME)

    RETURN

UNWRAP.THIS.LINE: ********************************************************
* determine how many lines after object.code<line.loop> should be        *
* wrapped up to the current line and unwrap them                         *
**************************************************************************
    GOSUB FIND.WRAP.LINES
    GOSUB MERGE.WRAPPED.LINES

    RETURN

FIND.WRAP.LINES: *********************************************************
* determine how many lines are wrapped after the current line            *
**************************************************************************
    WRAP.LINES = 1

    LOOP

        FIRST.LINE.PTR = LINE.LOOP + WRAP.LINES
        NEXT.LINE.PTR = LINE.LOOP + WRAP.LINES + 1
        GOSUB CHECK.LINE.WRAPPING

    UNTIL NOT(THIS.LINE.WRAPS) OR WRAP.LINES >= OBJECT.CODE.LINES DO

        WRAP.LINES += 1

    REPEAT

    RETURN

MERGE.WRAPPED.LINES: *****************************************************
* merge "wrap.lines" into the current program line                       *
**************************************************************************

* merge the wrapped lines into the first one and null out the wrapped line
    THIS.LINE = TRIM(OBJECT.CODE<LINE.LOOP>, " ", "T")

* is the last character in the line (the one that indicates the line is
* wrapped) a wrapping character that should be removed?
    IF COUNT(LINE.WRAP.REMOVE.CHARACTERS, THIS.LINE "R#1") <> 0 THEN
        THIS.LINE = TRIM(THIS.LINE [1, LEN(THIS.LINE) - 1], " ", "T")
    END

    FOR WRAP.LOOP = 1 TO WRAP.LINES

        WRAP.LINE = TRIM(OBJECT.CODE<LINE.LOOP + WRAP.LOOP>, " ", "B")

* if the last character or the first character in the wrapped line is a "remove"
* character remove it from the wrapped line
        IF COUNT(LINE.WRAP.REMOVE.CHARACTERS, WRAP.LINE [1]) <> 0 THEN
            WRAP.LINE = WRAP.LINE [1, LEN(WRAP.LINE) - 1]
        END

        IF COUNT(LINE.WRAP.REMOVE.CHARACTERS, WRAP.LINE [1, 1]) <> 0 THEN
            WRAP.LINE = WRAP.LINE [2, TO.THE.END]
        END

* merge the current line with the wrapped line and null out the wrapped line
        THIS.LINE := " ":WRAP.LINE
        OBJECT.CODE<LINE.LOOP + WRAP.LOOP> = ""

    NEXT WRAP.LOOP

* put the merged line back into the program
    OBJECT.CODE<LINE.LOOP> = THIS.LINE

    RETURN

CHECK.LINE.WRAPPING: *****************************************************
* check the current program line (pointed to first.line.ptr) against a   *
* later program line (pointed to by next.line.ptr to see if the two      *
* lines should be unwrapped.  returns this.line.wraps true if it should  *
* be unwrapped                                                           *
**************************************************************************
    THIS.LINE.WRAPS = @FALSE
    FOUND.METHOD.DEFINITION = @FALSE

* if this isn't a comment line and the line ends with a "wrapping character"
* then the second line is a continuation of the first
    THIS.LINE = TRIM(OBJECT.CODE<FIRST.LINE.PTR>, " ", "T")
    TRIM.THIS.LINE = TRIM(THIS.LINE, " ", "B")

* cases where this line can't be wrapped.  do an early return to
* speed things up--line is blank or a comment or a debug directive
* or we just don't have any wrapping characters defined
    BEGIN CASE
        CASE TRIM.THIS.LINE = ""
            RETURN
        CASE IS.COMMENT(LINE.WITHOUT.LABEL(THIS.LINE))
            RETURN
        CASE TRIM.THIS.LINE = "+" OR TRIM.THIS.LINE = "-"
            RETURN
    END CASE

    LAST.CHAR = TRIM.THIS.LINE [1]
    LAST.TWO.CHARS = TRIM.THIS.LINE [2]

    FIRST.WORD = TRIM.THIS.LINE [" ", 1, 1]
    LAST.WORD = UPCASE(TRIM.THIS.LINE [" ", DCOUNT(TRIM.THIS.LINE, " "), 1])

    LAST.KEYWORD.MATCH = @FALSE
    LOCATE LAST.WORD IN LINE.WRAP.KEYWORDS SETTING LAST.KEYWORD.PTR THEN
        LAST.KEYWORD.MATCH = @TRUE
    END

* if the first word in this line starts a method we'll do things a little
* differently

* if this line defines a method or an inline method set a flag for the
* calling routine.  if the calling program passes in.method.definition true
* then we're evaluating wrapped lines after a method definition so we need
* to treat this line as if it's declaring the method.  we also want to do
* this for subroutines
    DECODE.KEYWORD = UPCASE(FIRST.WORD)
    GOSUB DECODE.METHOD

    IF IS.METHOD OR IS.SUBROUTINE THEN
        FOUND.METHOD.DEFINITION = @TRUE
    END

    BEGIN CASE

* annoying special fix for objects.  the method definition doesn't look
* like a label so, if it has comments after it, it will trigger a
* line unwrap if an asterisk is defined as a wrappable character.
        CASE COMPILE.OBJECT AND FOUND.METHOD.DEFINITION
            USE.LINE.WRAP.CHARACTERS = CHANGE(LINE.WRAP.CHARACTERS, "*", "")

        CASE IS.SECTION
            USE.LINE.WRAP.CHARACTERS = CHANGE(LINE.WRAP.CHARACTERS, "*", "")

* normal case--use all the line wrap characters
        CASE 1
            USE.LINE.WRAP.CHARACTERS = LINE.WRAP.CHARACTERS

    END CASE

* if this line begins or ends with a "--" (decrement) or "++"
* (increment) don't wrap it.  also if the entire line is a "+" (for "debug
* on") or "-" (for "debug off") we don't want to wrap

* special case:  for "method" lines a semicolon delimits between input
* and output parameters.  if the first word is "method" and it ends in ability
* semicolon then the line will be wrapped
    BEGIN CASE

* cases where this line is definitely not wrapped
        CASE USE.LINE.WRAP.CHARACTERS = ""
            NULL

* special trap for incrementing and decrementing
        CASE LAST.TWO.CHARS = "++" OR LAST.TWO.CHARS = "--"
            NULL

* the last character is one of the "wrapping" characters
        CASE COUNT(USE.LINE.WRAP.CHARACTERS, LAST.CHAR) <> 0
            THIS.LINE.WRAPS = @TRUE

* the last word in the current line is a "before" wrapping keyword
        CASE LAST.KEYWORD.MATCH
            THIS.LINE.WRAPS = @TRUE

* a semicolon isn't usually a wrapping character but in a method or inline
* definition it can be used as a separator between keywords, like a comma.
* in this case we'll use it as a wrapping character
        CASE (FOUND.METHOD.DEFINITION OR IN.METHOD.DEFINITION) AND LAST.CHAR = ";"
            THIS.LINE.WRAPS = @TRUE

    END CASE

* if the next line starts with any of the line.wrap.next.characters then
* we also want to wrap that line onto the end of this one.  the previous
* code may have already set this.line.wraps so we'll only change it if
* we find that the next line indicates a wrapped line
    NEXT.LINE = TRIM(OBJECT.CODE<NEXT.LINE.PTR>, " ", "T")
    TRIM.NEXT.LINE = TRIM(NEXT.LINE, " ", "B")

* cases where the second line won't affect wrapping.  dump out early
* to speed things up a bit--blank next line, no next wrapping characters
    BEGIN CASE
        CASE TRIM.NEXT.LINE = ""
            RETURN
        CASE LINE.WRAP.NEXT.CHARACTERS = ""
            RETURN
    END CASE

    FIRST.CHAR = TRIM.NEXT.LINE [1, 1]
    FIRST.TWO.CHARS = TRIM.NEXT.LINE [1, 2]

    FIRST.WORD = UPCASE(TRIM.NEXT.LINE [" ", 1, 1])

    FIRST.KEYWORD.MATCH = @FALSE
    LOCATE FIRST.WORD IN LINE.WRAP.NEXT.KEYWORDS SETTING FIRST.KEYWORD.PTR THEN
        FIRST.KEYWORD.MATCH = @TRUE
    END

    BEGIN CASE

* special trap for incrementing and decrementing
        CASE FIRST.TWO.CHARS = "++" OR FIRST.TWO.CHARS = "--"
            NULL

* special case: if the code in the next line starts with any of the object
* delimiters don't wrap it
        CASE FIRST.WORD [1, METHOD.DEL.LENGTH] = METHOD.DELIMITER
            NULL
        CASE FIRST.WORD [1, PROPERTY.DEL.LENGTH] = PROPERTY.DELIMITER
            NULL
        CASE FIRST.WORD [1, CONSTANT.DEL.LENGTH] = CONSTANT.DELIMITER
            NULL
        CASE FIRST.WORD [1, CHILD.DEL.LENGTH] = CHILD.DELIMITER
            NULL
        CASE FIRST.WORD [1, LEN(REPLACE.WITH.KEYWORD)] = REPLACE.WITH.KEYWORD
            NULL

* also, if the line begins with a debuggin keyword don't wrap it
        CASE FIRST.WORD = DEBUG.SEND.ARRAY.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.CLEAR.AND.MESSAGE.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.SEND.VARIABLE.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.SEND.TEXT.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.SET.SOURCE.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.CLEAR.SOURCE.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.CLEAR.KEYWORD
            NULL
        CASE FIRST.WORD = DEBUG.IDENTIFY.METHOD.KEYWORD
            NULL

* the next line starts with one of the "next wrapping characters"
        CASE COUNT(LINE.WRAP.NEXT.CHARACTERS, FIRST.CHAR) <> 0
            THIS.LINE.WRAPS = @TRUE

* the next line starts with one of the "next wrapping keywords"
        CASE FIRST.KEYWORD.MATCH
            THIS.LINE.WRAPS = @TRUE

    END CASE

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / options setting                          **
**************************************************************************
**************************************************************************

SET.OBJECT.OPTIONS: ******************************************************
* set options for objects given first.line                               *
*                                                                        *
* the OBJECT statement looks like this:                                  *
*                                                                        *
* OBJECT objectname {option {option { . . . } }  { (instances) }         *
*     options:    INSTANCES n     set maximum instances to "n"           *
*                 INSTANCES +n    set maximum instances to "n" more than *
*                                 the default                            *
*                 INSTANCES -n    set maximum instances to "n" less than *
*                                 the default                            *
*                 INSTANCES *n    set maximum instances to "n" times     *
*                                 the default                            *
*                 INSTANCES /n    set maximum instances to the defualt   *
*                                 divided by "n"                         *
*                                                                        *
*                 ALL.SUBS        add all instance-handling subroutines  *
*                                 whether they're needed or not          *
*                                                                        *
*                 FIXED           the allowable number of instances for  *
*                                 fixed and won't be expanded            *
*                 EXPAND          the number of instances may expand     *
*                                 if additional instances are needed.    *
*                                 This is usually the default            *
*                                                                        *
*                 RESIDENT        set instances to 1 and object should   *
*                                 never be destroyed                     *
*                                                                        *
*                 EXTERNAL        this object should build a .net class  *
*                                 for access from outside uniVerse       *
*                                                                        *
*                 TYPE type1, type2, etc                                 *
*                                 attach one or more "types" to this     *
*                                 object.  "types" are used to group     *
*                                 objects together in the object viewer  *
*                                                                        *
*                 NO.DEBUG        this object should not update the      *
*                                 ud.object.debug file                   *
*                                                                        *
* it may then be followed by "other" options.  see the                   *
* process.other.options subroutine                                       *
**************************************************************************

* get the "object" line from the program to check for options
    FIRST.LINE = TRIM(OBJECT.CODE<1>)
    FIRST.LINE = CHANGE(FIRST.LINE, " ", @AM)

* some parameters (like the parameters for "TYPE" can have multiple operands
* separated by spaces.  if there are any commas that are followed by spaces
* these operands will be spread among multiple attributes in first.line.
* look through first.line and for any entry that ends in a comma append the
* next entry so that all comma-delimited options are in the same attribute
* in first line
    FIRST.LINE.COUNT = DCOUNT(FIRST.LINE, @AM)

    FOR FIRST.LOOP = FIRST.LINE.COUNT - 1 TO 1 STEP -1

        IF FIRST.LINE<FIRST.LOOP> [1] = "," THEN
            FIRST.LINE<FIRST.LOOP> := FIRST.LINE<FIRST.LOOP + 1>
            DEL FIRST.LINE<FIRST.LOOP + 1>
        END

        FIRST.LINE<FIRST.LOOP> = TRIM(FIRST.LINE<FIRST.LOOP>, ",")

    NEXT FIRST.LOOP

* extract the first keyword in the line.  the first would should be "object".
    FIRST.KEYWORD = FIRST.LINE<1>

    IF FIRST.KEYWORD = "OBJECT" THEN
        OBJECT.OPTIONS = UPCASE(FIRST.LINE [@AM, 3, TO.THE.END])
    END ELSE
        OBJECT.OPTIONS = ""
    END

* look for object options:

* if there's a number in parenthesis right after the object name we'll
* use that for the maximum instance count
    THIS.NAME = FIRST.LINE<2>

    IF COUNT(THIS.NAME, "(") <> 0 THEN
        MAX.FIELD = THIS.NAME ["(", 2, 1] [")", 1, 1]
        IF NUM(MAX.FIELD) AND MAX.FIELD <> "" THEN
            MAX.INSTANCES = MAX.FIELD
        END
    END

* there may be a space between the object name and the max instances
* in parenthesis so look at the next field as well
    MAX.FIELD = OBJECT.OPTIONS<1>

    IF MAX.FIELD [1, 1] = "(" AND MAX.FIELD [1] = ")" THEN
        MAX.FIELD = TRIM(MAX.FIELD [2, LEN(MAX.FIELD) - 2])
        IF NUM(MAX.FIELD) AND MAX.FIELD <> "" THEN
            MAX.INSTANCES = MAX.FIELD
            DEL OBJECT.OPTIONS<1>
        END
    END

*    INSTANCE instance.count - set maximum instance count
    LOCATE INSTANCE.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        MAX.INSTANCES = OBJECT.OPTIONS<PTR + 1>
        DEL OBJECT.OPTIONS<PTR>
        DEL OBJECT.OPTIONS<PTR>
    END

*    EXPAND or FIXED - enable or disable redimming
*    check for keywords to enable or disable redimming properties
*    to allow for expanding instances
    LOCATE FIXED.DIM.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        ALLOW.EXPANDING.INSTANCES = @FALSE
        ALLOW.REDUCING.INSTANCES = @FALSE
        DEL OBJECT.OPTIONS<PTR>
    END

    LOCATE EXPAND.DIM.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        ALLOW.EXPANDING.INSTANCES = @TRUE
        ALLOW.REDUCING.INSTANCES = @TRUE
        DEL OBJECT.OPTIONS<PTR>
    END

*    RESIDENT - make an object resident
*    check for the "resident" keyword.  this is for single-instance objects
*    that we want to stay around forever.  for resident objects the "destroy"
*    object won't really destroy it.  if an object is resident max.instances
*    is always set to 1.  if a multi-instance object was resident it would
*    keep expanding forever
    RESIDENT.OBJECT = @FALSE

    LOCATE RESIDENT.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        RESIDENT.OBJECT = @TRUE
        MAX.INSTANCES = 1
        DEL OBJECT.OPTIONS<PTR>
    END

*    EXTERNAL - enable creating external classes
*    check for the "external" keyword.  this is used when building external
*    (.net) classes to access objects from outside of universe.  if the
*    external option is not specified an external class will not be built
*    for this object
    EXTERNAL.OBJECT = @FALSE

    LOCATE EXTERNAL.OBJECT.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        EXTERNAL.OBJECT = @TRUE 
        DEL OBJECT.OPTIONS<PTR>
    END

* if this object has only one instance but it's not a resident object
* then it's a "single-instance" object.  these are special, like the
* resident objects.  they will all be created with the same variable
* memory space.  a counter is kept for each time "another" single-instance
* object is closed.  as instances are "destroyed" the counter is decremented.
* when the counter gets back to zero the instance is actually destroyed
    SINGLE.OBJECT = @FALSE

    IF MAX.INSTANCES = 1 AND NOT(RESIDENT.OBJECT) THEN
        SINGLE.OBJECT = @TRUE
    END

*    TYPE - declare an object as a member of a "type"
*    check for a "type" keyword.  it doesn't affect compilation but it can
*    be used to sort objects into a "type" to group them together.
*    the "type" keyword will be followed by a name.  if we find "type"
*    we'll remove two keywords
    OBJECT.TYPE = ""

    LOCATE OBJECT.TYPE.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        OBJECT.TYPE = UPCASE(OBJECT.OPTIONS<PTR + 1>)
        DEL OBJECT.OPTIONS<PTR>
        DEL OBJECT.OPTIONS<PTR>
    END

* check for the "assign" keyword
    INITIALIZE.ASSIGN = ""
    INITIALIZE.ASSIGN.DEFAULT = ""

    LOCATE ASSIGN.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        INITIALIZE.ASSIGN = SPLIT.PARAMETERS (OBJECT.OPTIONS<PTR + 1>)
        DEL OBJECT.OPTIONS<PTR>
        DEL OBJECT.OPTIONS<PTR>
        ASSIGN.OPTION.USED = @TRUE
    END

*    STATUS - object development status
    OBJECT.STATUS = "UNKNOWN"

    LOCATE STATUS.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        OBJECT.STATUS = UPCASE(OBJECT.OPTIONS<PTR + 1>)
        DEL OBJECT.OPTIONS<PTR>
        DEL OBJECT.OPTIONS<PTR>
    END

* check for the "no.debug" keyword.  this keyword shuts off updates to the
* ud.object.debug file when object debugging is turned on
    UPDATE.OBJECT.DEBUG = @TRUE

    LOCATE NO.OBJECT.DEBUG.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        DEL OBJECT.OPTIONS<PTR>
        UPDATE.OBJECT.DEBUG = @FALSE
    END

* if max.instances starts with a "+" or a "*" then it's
* calculated from the default maximum instances
    FIRST.INSTANCE.CHAR = MAX.INSTANCES [1, 1]

    IF NOT(NUM(FIRST.INSTANCE.CHAR)) THEN

        INSTANCE.OPERAND = MAX.INSTANCES [2, TO.THE.END]

        BEGIN CASE

            CASE NOT(NUM(INSTANCE.OPERAND))
                PRINT "Instances not numeric.  Defaulting to ":DEFAULT.MAX.INSTANCES
                MAX.INSTANCES = DEFAULT.MAX.INSTANCES

            CASE FIRST.INSTANCE.CHAR = "+"
                MAX.INSTANCES = INT(DEFAULT.MAX.INSTANCES + INSTANCE.OPERAND)

            CASE FIRST.INSTANCE.CHAR = "*"
                MAX.INSTANCES = INT(DEFAULT.MAX.INSTANCES * INSTANCE.OPERAND)

            CASE FIRST.INSTANCE.CHAR = "/"
                MAX.INSTANCES = INT(DEFAULT.MAX.INSTANCES / INSTANCE.OPERAND)

            CASE FIRST.INSTANCE.CHAR = "-"
                MAX.INSTANCES = INT(DEFAULT.MAX.INSTANCES - INSTANCE.OPERAND)

        END CASE

    END

* if, somehow, max.instances is null set it to the default
    IF MAX.INSTANCES = "" THEN
        MAX.INSTANCES = DEFAULT.MAX.INSTANCES
    END

* at this point max.instances should be numeric
    IF NOT(NUM(MAX.INSTANCES)) THEN
        OBJECT.ERROR = @TRUE
        PRINT
        PRINT "Invalid ":INSTANCE.KEYWORD:" option '":MAX.INSTANCES:"' in Line 1"
        RETURN
    END

* max instances can never be less than 1
    IF MAX.INSTANCES < 1 THEN
        PRINT "Warning: Maximum Instances less than one.  Defaulting to 1"
        MAX.INSTANCES = 1
    END

*     ALL.SUBS - add all instance subroutines whether needed or not
    LOCATE ALL.SUBROUTINES.KEYWORD IN OBJECT.OPTIONS SETTING PTR THEN
        ALL.SUBROUTINES = @TRUE
        DEL OBJECT.OPTIONS<PTR>
    END

* if CompileSingleAsResident is set and we have max.instances = 1 reset
* everything as if it's a resident object
    IF COMPILE.SINGLE.AS.RESIDENT AND MAX.INSTANCES = 1 THEN
        RESIDENT.OBJECT = @TRUE
        SINGLE.OBJECT = @FALSE
    END

    GOSUB PROCESS.OTHER.OPTIONS

    RETURN

SET.SUBROUTINE.OPTIONS: **************************************************
* set options for a subroutine given first.line                          *
**************************************************************************

* check for options overridden in the program code
    START.LINE = 1
    END.LINE = OBJECT.CODE.LINES
    GOSUB PROCESS.OPTION.LINES

    RETURN

PROCESS.OPTION.LINES: ****************************************************
* go through object.code from start.line to end.line and look for lines  *
* that begin with option.keyword.  these lines will have compile options *
* in them like the object statement can.  set objects based on these     *
* lines and then comment them out                                        *
*                                                                        *
* also makes up the inline routines list                                 *
*                                                                        *
* option lines should look like this:                                    *
*                                                                        *
*    $obj.option optionname1 = value1, optionname2 = value2 . . .        *
*                                                                        *
* inline routines look like this:                                        *
*                                                                        *
*    $inline object::method, object, sub::subroutine . . .               *
*                                                                        *
* needs start.line and end.line.  scans through object.code from         *
* start.line to end.line                                                 *
**************************************************************************
    OPTION.LINE.LIST = ""
    OPTION.LINE.LIST.COUNT = 0

    GOSUB PROCESS.OBJECT.OPTIONS
    GOSUB PROCESS.METHOD.OPTIONS

* now that we've processed all the option lines go back and comment out
* lines that are inside the code range.  option lines outside of the code
* range are global options from process.object.options.  we don't want to
* comment those lines out.  if we don't have a line range there's no code
* in the code range to comment out
    IF START.LINE > 0 AND END.LINE > 0 THEN

        FOR OPTION.LINE = 1 TO OPTION.LINE.LIST.COUNT

            LINE.PTR = OPTION.LINE.LIST<OPTION.LINE>

            IF LINE.PTR >= START.LINE AND LINE.PTR <= END.LINE THEN
                GOSUB COMMENT.ONE.LINE
            END

        NEXT OPTION.LINE

* comment out the inline lines
        FOR INLINE.LINE = 1 TO INLINE.COUNT

            LINE.PTR = INLINE.LINE.LIST<INLINE.LINE>

            IF LINE.PTR >= START.LINE AND LINE.PTR <= END.LINE THEN
                GOSUB COMMENT.ONE.LINE
            END

        NEXT INLINE.LINE

    END

    RETURN

PROCESS.OBJECT.OPTIONS: **************************************************
* if we're compiling an object check for global options outside of       *
* any method code                                                        *
**************************************************************************
    IF NOT(COMPILE.OBJECT) THEN
        RETURN
    END

* for objects check for option lines from the first code line to the first
* method definition.  this allows us to define options for the entire
* object
    HIT.METHOD.STATEMENT = @FALSE

    SETREM 0 ON OBJECT.CODE

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES UNTIL HIT.METHOD.STATEMENT

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)

* ignore lines that obviously won't apply
        IF THIS.LINE <> "" AND THIS.LINE [1, 1] <> "*" THEN

            FIRST.WORD = UPCASE(THIS.LINE [" ", 1, 1])

            DECODE.KEYWORD = FIRST.WORD
            GOSUB DECODE.METHOD

            BEGIN CASE

* this line is starting a new method.  stop searching
                CASE IS.METHOD OR IS.INHERITED.FROM
                    HIT.METHOD.STATEMENT = @TRUE

* if this line starts with the option keyword update our option.line.list
* then process the options
                CASE FIRST.WORD = OPTION.KEYWORD
                    GOSUB PROCESS.ONE.OPTION.LINE

* if this line starts with the inline keyword update the inline tables
                CASE FIRST.WORD = INLINE.KEYWORD
                    GOSUB PROCESS.ONE.INLINE.LINE

            END CASE

        END

    NEXT LINE.LOOP

    RETURN

PROCESS.METHOD.OPTIONS: **************************************************
* process code within a method for options                               *
**************************************************************************

* if there's no code in our method code range don't scan anything
    IF START.LINE = 0 OR END.LINE = 0 THEN
        RETURN
    END

* find the location of the character after the delimiter before
* start.line and point object.code's remove pointer there
    IF START.LINE = 1 THEN
        START.PTR = 0
    END ELSE
        START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
    END

    SETREM START.PTR ON OBJECT.CODE

    FOR LINE.LOOP = START.LINE TO END.LINE

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)

* ignore lines that obviously won't apply
        IF THIS.LINE <> "" AND THIS.LINE [1, 1] <> "*" THEN

            FIRST.WORD = UPCASE(THIS.LINE [" ", 1, 1])

            BEGIN CASE

* if this line starts with the option keyword update our option.line.list
* then process the options
                CASE FIRST.WORD = OPTION.KEYWORD
                    GOSUB PROCESS.ONE.OPTION.LINE

* if this line starts with the inline keyword update the inline tables
                CASE FIRST.WORD = INLINE.KEYWORD
                    GOSUB PROCESS.ONE.INLINE.LINE

            END CASE

        END

    NEXT LINE.LOOP

    RETURN

PROCESS.ONE.OPTION.LINE: *************************************************
* process a program line that has an option statement                    *
**************************************************************************
    OPTION.LINE.LIST.COUNT += 1
    OPTION.LINE.LIST<OPTION.LINE.LIST.COUNT> = LINE.LOOP

    OPTION.LIST = THIS.LINE [" ", 2, TO.THE.END]
    OBJECT.OPTIONS = CHANGE(OPTION.LIST, " ", @AM)
    GOSUB PROCESS.OTHER.OPTIONS

    RETURN

PROCESS.ONE.INLINE.LINE: *************************************************
* process a program line with an inline statement                        *
**************************************************************************
    INLINE.LIST = TRIM(THIS.LINE [" ", 2, TO.THE.END], " ", "A")
    INLINE.LIST = CHANGE(INLINE.LIST, ",", @AM)
    ENTRY.COUNT = DCOUNT(INLINE.LIST, @AM)

* pull out each object or object::method entry from the inline statement
* and update the inline tables
    FOR ENTRY.LOOP = 1 TO ENTRY.COUNT

        THIS.ENTRY = INLINE.LIST<ENTRY.LOOP>

        METHOD.PTR = INDEX(THIS.ENTRY, METHOD.DELIMITER, 1)

        BEGIN CASE

* if the expression is "everything" assume it's "ALL:ALL" 
* ie: $insert everything
            CASE THIS.ENTRY = INLINE.EVERYTHING.KEYWORD
                INLINE.OBJECT = INLINE.ALL.OBJECTS.KEYWORD
                INLINE.METHOD = INLINE.ALL.METHODS.KEYWORD

* if the method delimiter doesn't appear in the inline expression then only
* the method name (we assume) was entered.  if we have a "last" object name
* used used it
            CASE METHOD.PTR < 1 AND LAST.INLINE.OBJECT <> ""
                INLINE.OBJECT = LAST.INLINE.OBJECT
                INLINE.METHOD = THIS.ENTRY

* if the method delimiter doesn't appear in the inline expression and we
* don't have a "last" object name we can't do anything with this
            CASE METHOD.PTR < 1
                INLINE.OBJECT = ""
                INLINE.METHOD = ""

                OBJECT.WARNING.DESC = "Inline expression ":'"':THIS.ENTRY:'"'
                OBJECT.WARNING.DESC := " has no Object name"
                OBJECT.WARNING.LINE = LINE.LOOP
                GOSUB PRINT.OBJECT.WARNING

* otherwise we have an object::method expression.  extract the inlined object
* name and the inlined method from the expression.  
* ie, $inline myobject::mymethod
            CASE 1
                INLINE.OBJECT = THIS.ENTRY [1, METHOD.PTR - 1]
                INLINE.METHOD = THIS.ENTRY [METHOD.PTR + METHOD.DEL.LENGTH, TO.THE.END]

        END CASE

* if the inline method isn't "all", but is a specific method, add
* with the "inline.always" flag in the inline.table set true so that
* the method will alweays be inlined.  otherwise we'll only inline
* the method depending on the setting for only.inline.if.called
        IF INLINE.METHOD = INLINE.ALL.METHODS.KEYWORD THEN
            INLINE.ALWAYS = @FALSE
        END ELSE
            INLINE.ALWAYS = @TRUE
        END

* make sure the object name is valid
        BEGIN CASE

            CASE INLINE.OBJECT = ""
                NULL
            CASE INLINE.OBJECT = SUBROUTINE.CALL.KEYWORD
                NULL
            CASE INLINE.OBJECT = LOCAL.KEYWORD
                NULL

            CASE 1
                READV TEST.OBJECT FROM OBJFILE, INLINE.OBJECT, 0 ELSE

                    OBJECT.WARNING.DESC = "Inlined Object reference ":'"':INLINE.OBJECT:'"'
                    OBJECT.WARNING.DESC := " is not a valid Object"
                    OBJECT.WARNING.LINE = LINE.LOOP
                    GOSUB PRINT.OBJECT.WARNING

                    INLINE.OBJECT = ""
                    INLINE.METHOD = ""

                END

        END CASE

* if everything checks out add this routine to the inlined routine list
        IF INLINE.OBJECT <> "" AND INLINE.METHOD <> "" THEN
            INLINE.LINE = LINE.LOOP
            GOSUB ADD.INLINE.ENTRY
        END

    NEXT ENTRY.COUNT

    RETURN

COMMENT.ONE.LINE: ********************************************************
* comment out line.ptr                                                   *
**************************************************************************
    THIS.LINE = OBJECT.CODE<LINE.PTR>

    THIS.LINE.LABEL = LINE.LABEL(THIS.LINE)

* if this line has no label replace the first character with an asterisk.
* if the line does have a label leave the label but comment out the line
    IF THIS.LINE.LABEL = "" THEN
        THIS.LINE = "*":THIS.LINE [2, TO.THE.END]
    END ELSE
        INDENT.COUNT = FIND.INDENT.COUNT(THIS.LINE.LABEL, THIS.LINE)
        THIS.LINE = THIS.LINE.LABEL:" *":SPACE(INDENT.COUNT - 2):LINE.WITHOUT.LABEL(THIS.LINE)
    END

    OBJECT.CODE<LINE.PTR> = THIS.LINE

    RETURN

PROCESS.OTHER.OPTIONS: ***************************************************
* process options defined in the object.options dynamic array            *
*                                                                        *
* if there are any other options check to see if they're setup           *
* parameters.  if they are then change the parameters.  these changes    *
* will only be valid for this object / subroutine.  they'll be lost when *
* reload.settings is called for the next object.  multiple settings may  *
* be separated by a space or comma                                       *
*                                                                        *
* to set an option for only this object / subroutine add an option like  *
* this:                                                                  *
*                                                                        *
*   $obj.option optionname = setting                                     *
*                                                                        *
* where:                                                                 *
*                                                                        *
* optionname is the option name to change.  it's the same as the option  *
* name in ud.control compile.setup.  multiple options may be separated   *
* by commas                                                              *
*                                                                        *
* setting is the new setting value.  it can be:                          *
*     1 or 0                                                             *
*     Yes or No                                                          *
*     True or False                                                      *
*     On or Off                                                          *
*                                                                        *
* each element of the options delay was delimited by spaces.  that's     *
* fine, but the options may be defined by commas as well.  look for any  *
* commas in the options and break those up as well.  then we'll clean up *
* any empty options spots that may result                                *
**************************************************************************
    OBJECT.OPTIONS = CHANGE(OBJECT.OPTIONS, ",", @AM)
    OBJECT.OPTIONS = TRIM(OBJECT.OPTIONS, @AM)

* merge any options where a space was entered before or after an option
    OBJECT.OPTIONS.COUNT = DCOUNT(OBJECT.OPTIONS, @AM)

    FOR OPTION.LOOP = OBJECT.OPTIONS.COUNT TO 1 STEP -1

        IF OBJECT.OPTIONS<OPTION.LOOP> [1] = "=" THEN
            OBJECT.OPTIONS<OPTION.LOOP> := OBJECT.OPTIONS<OPTION.LOOP + 1>
            DEL OBJECT.OPTIONS<OPTION.LOOP + 1>
        END

        IF OPTION.LOOP > 1 AND OBJECT.OPTIONS<OPTION.LOOP> [1, 1] = "=" THEN
            OBJECT.OPTIONS<OPTION.LOOP - 1> := OBJECT.OPTIONS<OPTION.LOOP>
            DEL OBJECT.OPTIONS<OPTION.LOOP>
        END

    NEXT OPTION.LOOP

* process any options
    OBJECT.OPTIONS.COUNT = DCOUNT(OBJECT.OPTIONS, @AM)

    FOR OPTION.LOOP = OBJECT.OPTIONS.COUNT TO 1 STEP -1

        THIS.OPTION = OBJECT.OPTIONS<OPTION.LOOP>
        GOSUB PROCESS.THIS.OPTION
        IF OPTION.VALID THEN
            DEL OBJECT.OPTIONS<OPTION.LOOP>
            OBJECT.OPTIONS.COUNT -= 1
        END

    NEXT OPTION.LOOP

* if there are any options left they're invalid.  flag an error
    IF OBJECT.OPTIONS <> "" THEN

        OBJECT.ERROR = @TRUE

        PRINT
        PRINT "Invalid Options ":CHANGE(OBJECT.OPTIONS, @AM, ", "):" in Line 1"

        RETURN

    END

    RETURN

PROCESS.THIS.OPTION: *****************************************************
* update current object / subroutine settings with this.option.          *
* statements overriding standard options should be entered on a line     *
* beginning with "$obj.option" like this:                                *
*                                                                        *
*   $obj.option optionname = setting                                     *
*                                                                        *
* where:                                                                 *
*                                                                        *
* optionname is the option name to change.  it's the same as the option  *
* name in ud.control compile.setup                                       *
*                                                                        *
* setting is the new setting value.  it can be:                          *
*     1           or      0                                              *
*     Yes         or      No                                             *
*     True        or      False                                          *
*     On          or      Off                                            *
*     Enabled     or      Disabled                                       *
*                                                                        *
* ie:                                                                    *
*                                                                        *
*     ScanDebugSpaces = Yes                                              *
*     PadNullParameters = Off                                            *
*     LineWrapping = Enabled                                             *
*                                                                        *
* if an option has a numeric value the setting will be the number.  ie:  *
*                                                                        *
*     MaxCallParameters = 10                                             *
*                                                                        *
* an optionname can also be set on or off using the "set" and "unset"    *
* shortcuts or "+" or "-":                                               *
*                                                                        *
*     optionname~~              set an option true                       *
*     optionname~               set an option false                      *
*     optionname+               set an option true                       *
*     optionname-               set an option false                      *
*                                                                        *
* if an option name appears on a line by itself it's assumed that this   *
* is setting the option true.  ie:                                       *
*                                                                        *
*     AllOnOneLine                                                       *
*                                                                        *
* sets the "all on one line" option true                                 *
*                                                                        *
* both the option name and the option value are case insensitive         *
*                                                                        *
* at this point only true/false flags can be set this way.  if an        *
* attempt is made to set a value to something that's not true/false      *
* an error will be flagged                                               *
**************************************************************************
    OPTION.NAME = TRIM(UPCASE(THIS.OPTION ["=", 1, 1]), " ", "B")
    OPTION.VALUE = TRIM(UPCASE(THIS.OPTION ["=", 2, 1]), " ", "B")
    OPTION.VALID = @FALSE

* all of the option names in the compile setup record are set up using
* camel case but in uniVerse a lot of developers are used to dots.  we'll
* support both by removing all the dots from the option name
    OPTION.NAME = CHANGE(OPTION.NAME, ".", "")

* check for set/unset options in option.name
    OPTION.LAST.CHAR = OPTION.NAME [1]
    OPTION.TWO.CHAR = OPTION.NAME [2]

    BEGIN CASE

* suffixes that set an option true
        CASE OPTION.TWO.CHAR = "~~"
            OPTION.VALUE = @TRUE
            OPTION.NAME = OPTION.NAME [1, LEN(OPTION.NAME) - 2]
        CASE OPTION.LAST.CHAR = "+"
            OPTION.VALUE = @TRUE
            OPTION.NAME = OPTION.NAME [1, LEN(OPTION.NAME) - 1]

* suffixes that set an option false
        CASE OPTION.LAST.CHAR = "~"
            OPTION.VALUE = @FALSE
            OPTION.NAME = OPTION.NAME [1, LEN(OPTION.NAME) - 1]
        CASE OPTION.LAST.CHAR = "-"
            OPTION.VALUE = @FALSE
            OPTION.NAME = OPTION.NAME [1, LEN(OPTION.NAME) - 1]

* if there's no suffix and nothing was defined using an equals sign
* assume we're setting this option
        CASE OPTION.VALUE = ""
            OPTION.VALUE = @TRUE

    END CASE

* convert option.value to a true/false value based on the option value
* after the equals sign
    BEGIN CASE

* option is set true
        CASE OPTION.VALUE = "YES" OR OPTION.VALUE = "TRUE" OR OPTION.VALUE = "ON" OR OPTION.VALUE = "ENABLED"
            OPTION.VALUE = @TRUE

* option is set false
        CASE OPTION.VALUE = "NO" OR OPTION.VALUE = "FALSE" OR OPTION.VALUE = "OFF" OR OPTION.VALUE = "DISABLED"
            OPTION.VALUE = @FALSE

* option was specified "1" or "0"
        CASE OPTION.VALUE = "1" OR OPTION.VALUE = "0"
            NULL

* if it's a number let it go.  some options are set to a number
        CASE OPTION.VALUE <> "" AND NUM(OPTION.VALUE)
            NULL

* if it's in quotes accept the value within the quotes
        CASE OPTION.VALUE [1, 1] = '"' AND OPTION.VALUE[1] = '"'
            OPTION.VALUE = OPTION.VALUE [2, LEN(OPTION.VALUE) - 2]
        CASE OPTION.VALUE[1,1] = "'" AND OPTION.VALUE[1] = "'"
            OPTION.VALUE = OPTION.VALUE [2, LEN(OPTION.VALUE) - 2]

* option value is null.  show an error
        CASE OPTION.VALUE = ""
            PRINT 'Warning: Option "':OPTION.NAME:'" is defined but not set'
            RETURN

* option is invalid.  show a warning and return
        CASE 1
            PRINT 'Warning: Option "':OPTION.NAME:'" is set to an invalid setting, ':
            PRINT '"':OPTION.VALUE:'"'
            RETURN

    END CASE

* set option based on option.name
    OPTION.VALID = @TRUE

    BEGIN CASE

* auto debugging options
        CASE OPTION.NAME = "DEBUGMETHODTRAIL"
            DEBUG.METHOD.TRAIL = OPTION.VALUE
        CASE OPTION.NAME = "DEBUGMETHODPARAMETERS"
            DEBUG.METHOD.PARAMETERS = OPTION.VALUE

* maximum number of instances
        CASE OPTION.NAME = "MAXINSTANCES"
            IF OPTION.VALUE < 1 THEN
                PRINT "Warning: Maximum Instances less than one.  Defaulting to 1"
                OPTION.VALUE = 1
            END
            MAX.INSTANCES = OPTION.VALUE

* absolute max instances
        CASE OPTION.NAME = "ABSOLUTEMAXINSTANCES"
            IF OPTION.VALUE < 1 THEN
                PRINT "Warning: Absolute Maximum Instances less than 1.  Defaulting to 1"
                OPTION.VALUE = 1
            END
            ABSOLUTE.MAX.INSTANCES = OPTION.VALUE

* checking object instance after creating child objects
        CASE OPTION.NAME = "CHECKOBJECTHANDLEBEFORECHILD"
            CHECK.OBJECT.HANDLE.BEFORE.CHILD = OPTION.VALUE
        CASE OPTION.NAME = "CHECKOBJECTHANDLEAFTERCHILD"
            CHECK.OBJECT.HANDLE.AFTER.CHILD = OPTION.VALUE

* allowing adding or reducing the number of instances
        CASE OPTION.NAME = "ALLOWEXPANDINGINSTANCES"
            ALLOW.EXPANDING.INSTANCES = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWREDUCINGINSTANCES"
            ALLOW.REDUCING.INSTANCES = OPTION.VALUE

* generate all multi-instance subroutines for every method, whether it
* needs it or not?
        CASE OPTION.NAME = "ALLSUBS"
            ALL.SUBROUTINES = OPTION.VALUE

* flags for getting properties
        CASE OPTION.NAME = "ALLOWGETCONSTANTS"
            ALLOW.GET.CONSTANTS = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWPUTCONSTANTS"
            ALLOW.PUT.CONSTANTS = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWGETCHILDHANDLES"
            ALLOW.GET.CHILD.HANDLES = OPTION.VALUE

* use eclipse version updates?
        CASE OPTION.NAME = "USEECLIPSEVERSIONUPDATES"
            USE.ECLIPSE.VERSION.UPDATES = OPTION.VALUE

* pass object handles to subroutine byval?
        CASE OPTION = "PASSOBJECTHANDLESBYVAL"
            PASS.OBJECT.HANDLES.BYVAL = OPTION.VALUE
        CASE OPTION = "PASSSUBHANDLESBYVAL"
            PASS.SUB.HANDLES.BYVAL = OPTION.VALUE
        CASE OPTION = "PASSLOCALHANDLESBYVAL"
            PASS.LOCAL.HANDLES.BYVAL = OPTION.VALUE
        CASE OPTION = "PASSREGISTRYHANDLESBYVAL"
            PASS.REGISTRY.HANDLES.BYVAL = OPTION.VALUE

* convert code to upper case?
        CASE OPTION.NAME = "UPCASECODE"
            UPCASE.CODE = OPTION.VALUE

* scan literal spaces and change to space() functions?
        CASE OPTION.NAME = "SCANPARAMETERSPACES"
            SCAN.PARAMETER.SPACES = OPTION.VALUE
        CASE OPTION.NAME = "SCANDEBUGSPACES"
            SCAN.DEBUG.SPACES = OPTION.VALUE
        CASE OPTION.NAME = "SCANMACROSPACES"
            SCAN.MACRO.SPACES = OPTION.VALUE
        CASE OPTION.NAME = "SCANSHORTCUTSPACES"
            SCAN.SHORTCUT.SPACES = OPTION.VALUE
        CASE OPTION.NAME = "SCANALLLITERALTEXT"
            SCAN.ALL.LITERAL.TEXT = OPTION.VALUE

* enable byval parameter passing?
        CASE OPTION.NAME = "ENABLEBYVAL"
            ENABLE.BYVAL = OPTION.VALUE
        CASE OPTION.NAME = "ONLYBYVALNONEXPRESSIONS"
            ONLY.BYVAL.NON.EXPRESSIONS = OPTION.VALUE

* enable byname parameter passing?
        CASE OPTION.NAME = "ENABLEBYNAME"
            ENABLE.BY.NAME = OPTION.VALUE

* pad undefined method parameters to ""?
        CASE OPTION.NAME = "PADNULLPARAMETERS"
            PAD.NULL.PARAMETERS = OPTION.VALUE
            IF PAD.NULL.PARAMETERS THEN
                ENABLE.BY.NAME = @TRUE
            END
        CASE OPTION.NAME = "PADOUTPUTPARAMETERS"
            PAD.OUTPUT.PARAMETERS = OPTION.VALUE
            IF PAD.OUTPUT.PARAMETERS THEN
                ENABLE.BY.NAME = @TRUE
            END

* warn / allow all parameters for method and subroutine calls to the
* right of the equals sign?
        CASE OPTION.NAME = "WARNALLPARAMETERSONRIGHT"
            WARN.ALL.PARAMETERS.ON.RIGHT = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWALLPARAMETERSONRIGHT"
            ALLOW.ALL.PARAMETERS.ON.RIGHT = OPTION.VALUE

* parameter checking
        CASE OPTION.NAME = "CHECKIOPARAMETERS"
            CHECK.IO.PARAMETERS = OPTION.VALUE
        CASE OPTION.NAME = "CHECKSUBIOPARAMETERS"
            CHECK.SUB.IO.PARAMETERS = OPTION.VALUE
        CASE OPTION.NAME = "MANDATORYIOPARAMETERS"
            MANDATORY.IO.PARAMETERS = OPTION.VALUE
        CASE OPTION.NAME = "MANDATORYSUBIOPARAMETERS"
            MANDATORY.SUB.IO.PARAMETERS = OPTION.VALUE

* string pseudo-object settings
        CASE OPTION.NAME = "ENABLESTRINGOBJECTCALLS"
            ENABLE.STRING.OBJECT.CALLS = OPTION.VALUE
        CASE OPTION.NAME = "AUTOADDSTRINGOBJECT"
            AUTO.ADD.STRING.OBJECT = OPTION.VALUE
        CASE OPTION.NAME = "STRINGOBJECTHANDLE"
            STRING.OBJECT.HANDLE = OPTION.VALUE
        CASE OPTION.NAME = "STRINGOBJECTNAME"
            STRING.OBJECT.NAME = OPTION.VALUE

* inlining settings
        CASE OPTION.NAME = "INLINEBYMERGINGCODE"
            INLINE.BY.MERGING.CODE = OPTION.VALUE
        CASE OPTION.NAME = "INLINEINCLUDEKEYWORD"
            INLINE.INCLUDE.KEYWORD = OPTION.VALUE
        CASE OPTION.NAME = "INLINECODEFILE"
            INLINE.CODE.FILE = OPTION.VALUE

        CASE OPTION.NAME = "ENDBEFOREINLINECODE"
            END.BEFORE.INLINE.CODE = OPTION.VALUE

        CASE OPTION.NAME = "ONLYINLINEIFCALLED"
            ONLY.INLINE.IF.CALLED = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWINLINEINSUBROUTINES"
            ALLOW.INLINE.IN.SUBROUTINES = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWINLINEINMETHODS"
            ALLOW.INLINE.IN.METHODS = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWINLINEOWNMETHODS"
            ALLOW.INLINE.OWN.METHODS = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWNESTEDINLINEROUTINES"
            ALLOW.NESTED.INLINE.ROUTINES = OPTION.VALUE
        CASE OPTION.NAME = "ALLOWINLINEDAISYCHAINED"
            ALLOW.INLINE.DAISY.CHAINED = OPTION.VALUE

* automatic command used by methods to clean up and exit
        CASE OPTION.NAME = "EXITMETHODKEYWORD"
            EXIT.METHOD.KEYWORD = OPTION.VALUE

* convert method calls all the way to external CALL statements?
        CASE OPTION.NAME = "CONVERTMETHODSTOCALLS"
            CONVERT.METHODS.TO.CALLS = OPTION.VALUE
            IF CONVERT.METHODS.TO.CALLS THEN
                ENABLE.BY.NAME = @TRUE
                PAD.NULL.PARAMETERS = @TRUE
            END

* check mismatched child objects
        CASE OPTION.NAME = "CHECKMISMATCHEDCHILDOBJECTS"
            CHECK.MISMATCHED.CHILD.OBJECTS = OPTION.VALUE

* use equates for properties instead of assigning from the object instance
* arrays
        CASE OPTION.NAME = "USEEQUATEDPROPERTIES"
            USE.EQUATED.PROPERTIES = OPTION.VALUE
        CASE OPTION.NAME = "USEEQUATEDCHILDOBJECTS"
            USE.EQUATED.CHILD.OBJECTS = OPTION.VALUE

* use an externam redimensioning array vs making it a local subroutine
        CASE OPTION.NAME = "USEEXTERNALREDIM"
            USE.EXTERNAL.REDIM = OPTION.VALUE

* save cbp program screated?
        CASE OPTION.NAME = "SAVECBPS"
            SAVE.CBPS = OPTION.VALUE

* put property code at the end of the program
        CASE OPTION.NAME = "PROPERTYCOMMONCODEATEND"
            PROPERTY.COMMON.CODE.AT.END = OPTION.VALUE

* maximum number of calling parameters for Eclipse subroutine conversions
        CASE OPTION.NAME = "MAXCALLPARAMETERS"
            MAX.CALL.PARAMETERS = OPTION.VALUE

* number of properties to put on a line for common statements
        CASE OPTION.NAME = "PROPERTIESPERLINE"
            PROPS.PER.LINE = OPTION.VALUE

* child objects.  it's probably a bad idea to change these two settings
* for only a single object.  if the other objects have the values from
* the compile.setup record the subroutine calls to create a new object
* ("NEW") will probably be incompatible
        CASE OPTION.NAME = "MAXCHILDOBJECTS"
            MAX.CHILD.OBJECTS = OPTION.VALUE
        CASE OPTION.NAME = "MAXCHILDDEPTH"
            MAX.CHILD.DEPTH = OPTION.VALUE
        CASE OPTION.NAME = "BUILDCHILDDEPTH"
            BUILD.CHILD.DEPTH = OPTION.VALUE

* line wrapping on/off
        CASE OPTION.NAME = "LINEWRAPPING"
            LINE.WRAPPING = OPTION.VALUE

* multivalued properties on/off
        CASE OPTION.NAME = "MULTIVALUEPROPERTIES"
            MULTIVALUE.PROPERTIES = OPTION.VALUE

* if an object reference can't be found using the "easy" way (like the
* Eclipse subroutine calls) can we add additional program lines to
* resolve them?
        CASE OPTION.NAME = "FIXUNRESOLVEDREFERENCES"
            FIX.UNRESOLVED.REFERENCES = OPTION.VALUE

* validate "with" objects
        CASE OPTION.NAME = "VALIDATEWITHOBJECTS"
            VALIDATE.WITH.OBJECTS = OPTION.VALUE

* special option just for instance matching.  turns off all calls to 
* check.object.instance after subroutine calls and child object creation
        CASE OPTION.NAME = "ALLINSTANCECHECKING"

            ALWAYS.LOAD.INSTANCE = OPTION.VALUE

            ALWAYS.CHECK.INSTANCE = OPTION.VALUE
            NON.LOCAL.ALWAYS.CHECKS.INSTANCE = OPTION.VALUE
            NON.LOCAL.ALWAYS.LOADS.INSTANCE = OPTION.VALUE

            SAME.OBJECT.CALL.CHECKS.INSTANCE = OPTION.VALUE
            SAME.OBJECT.CALL.LOADS.INSTANCE = OPTION.VALUE

            SUB.CALL.CHECKS.INSTANCE = OPTION.VALUE
            SUB.CALL.LOADS.INSTANCE = OPTION.VALUE

            CHECK.OBJECT.HANDLE.BEFORE.CHILD = OPTION.VALUE
            CHECK.OBJECT.HANDLE.AFTER.CHILD = OPTION.VALUE

* if an object does a call that results in the same type of object
* being called, possibly a different instance, do we reload the
* original instance upon return?
        CASE OPTION.NAME = "ALWAYSLOADINSTANCE"
            ALWAYS.LOAD.INSTANCE = OPTION.VALUE
        CASE OPTION.NAME = "ALWAYSCHECKINSTANCE"
            ALWAYS.CHECK.INSTANCE = OPTION.VALUE

        CASE OPTION.NAME = "NONLOCALALWAYSCHECKSINSTANCE"
            NON.LOCAL.ALWAYS.CHECKS.INSTANCE = OPTION.VALUE
        CASE OPTION.NAME = "NONLOCALALWAYSLOADSINSTANCE"
            NON.LOCAL.ALWAYS.LOADS.INSTANCE = OPTION.VALUE

        CASE OPTION.NAME = "SAMEOBJECTCALLCHECKSINSTANCE"
            SAME.OBJECT.CALL.CHECKS.INSTANCE = OPTION.VALUE
        CASE OPTION.NAME = "SAMEOBJECTCALLLOADSINSTANCE"
            SAME.OBJECT.CALL.LOADS.INSTANCE = OPTION.VALUE

        CASE OPTION.NAME = "SUBCALLCHECKSINSTANCE"
            SUB.CALL.CHECKS.INSTANCE = OPTION.VALUE
        CASE OPTION.NAME = "SUBCALLLOADSINSTANCE"
            SUB.CALL.LOADS.INSTANCE = OPTION.VALUE

* if we explode a line into multiple lines do we still keep all the
* code on one program line with compound statements?
        CASE OPTION.NAME = "ALLONONELINE"
            ALL.ON.ONE.LINE = OPTION.VALUE

* build method table dynamic array for objects?
        CASE OPTION.NAME = "BUILDMETHODTABLES"
            BUILD.METHOD.TABLES = OPTION.VALUE

* always recompile all methods when compiling this object, even if
* other methods didn't change?
        CASE OPTION.NAME = "ALWAYSRECOMPILEMETHODS"
            ALWAYS.RECOMPILE.METHODS = OPTION.VALUE

* show line counts when compiling?
        CASE OPTION.NAME = "SHOWLINECOUNTS"
            SHOW.LINE.COUNTS = OPTION.VALUE

* show uncalled subroutines?
        CASE OPTION.NAME = "SHOWUNCALLEDSUBROUTINES"
            SHOW.UNCALLED.SUBROUTINES = OPTION.VALUE

* remove uncalled subroutines
        CASE OPTION.NAME = "REMOVEUNCALLEDSUBROUTINES"
            REMOVE.UNCALLED.SUBROUTINES = OPTION.VALUE
        CASE OPTION.NAME = "REMOVEUNCALLEDINWRAPPERS"
            REMOVE.UNCALLED.IN.WRAPPERS = OPTION.VALUE

* show catalog message when compiling?
        CASE OPTION.NAME = "SHOWCATALOGEDMESSAGE"
            SHOW.CATALOGED.MESSAGE = OPTION.VALUE

* parameter aliasing checking
        CASE OPTION.NAME = "CHECKMETHODPARAMETERPROPERTY"
            CHECK.METHOD.PARAMETER.PROPERTY = OPTION.VALUE
        CASE OPTION.NAME = "CHECKASSIGNMENTPROPERTY"
            CHECK.ASSIGNMENT.PROPERTY = OPTION.VALUE
        CASE OPTION.NAME = "SHOWPROPERTYPARAMETERS"
            SHOW.PROPERTY.PARAMETERS = OPTION.VALUE
        CASE OPTION.NAME = "FIXPROPERTYPARAMETERS"
            SHOW.PROPERTY.PARAMETERS = OPTION.VALUE

* allow associated tables?
        CASE OPTION.NAME = "ENABLEASSOCIATEDTABLES"
            ENABLE.ASSOCIATED.TABLES = OPTION.VALUE

* enable thrown errors?
        CASE OPTION.NAME = "ENABLETHROWNERRORS"
            ENABLE.ERROR.THROWS = OPTION.VALUE

* disable thrown errors if none are used?
        CASE OPTION.NAME = "DISABLETHROWNIFUNUSED"
            DISABLE.THROWN.IF.UNUSED = OPTION.VALUE

* automatically add the "catch error" subroutine?
        CASE OPTION.NAME = "ADDCATCHERRORROUTINE"
            ADD.CATCH.ERROR.ROUTINE = OPTION.VALUE

* update the object error log?
        CASE OPTION.NAME = "UPDATEOBJECTERRORLOG"
            UPDATE.OBJECT.ERROR.LOG = OPTION.VALUE

* auto destroy objects?
        CASE OPTION.NAME = "AUTODESTROYOBJECTS"
            AUTO.DESTROY.OBJECTS = OPTION.VALUE
        CASE OPTION.NAME = "AUTODESTROYMETHODOBJECTS"
            AUTO.DESTROY.METHOD.OBJECTS = OPTION.VALUE
        CASE OPTION.NAME = "AUTODESTROYIFNOOBJECTS"
            AUTO.DESTROY.IF.NO.OBJECTS = OPTION.VALUE

* update the object registry?
        CASE OPTION.NAME = "UPDATEOBJECTREGISTRY"
            UPDATE.OBJECT.REGISTRY = OPTION.VALUE

* compile the cbp program(s) after they're created?
        CASE OPTION.NAME = "DOCOMPILE"
            DO.COMPILE = OPTION.VALUE

* delete cbp, oc programs, decatalog subroutines?
        CASE OPTION.NAME = "DELETECBPSUBROUTINES"
            DELETE.CBP = OPTION.VALUE
        CASE OPTION.NAME = "DELETEOCSUBROUTINES"
            DELETE.OC = OPTION.VALUE
        CASE OPTION.NAME = "DECATALOGCBPSUBROUTINES"
            DECATALOG.CBP = OPTION.VALUE

* enable debugging shortcuts, program shortcuts, and braces?
        CASE OPTION.NAME = "ENABLEDEBUGSHORTCUTS"
            ENABLE.DEBUG.SHORTCUTS = OPTION.VALUE
        CASE OPTION.NAME = "ENABLESHORTGOSUBS"
            ENABLE.SHORT.GOSUBS = OPTION.VALUE
        CASE OPTION.NAME = "ENABLEPROGRAMSHORTCUTS"
            ENABLE.PROGRAM.SHORTCUTS = OPTION.VALUE
        CASE OPTION.NAME = "ENABLEBRACES"
            ENABLE.BRACES = OPTION.VALUE

* when creating cbp subroutines the compile normally puts a space after the
* comma in the parameter list.  this can cause problems with some Eclipse / 
* Solar routines that look at the subroutine statement before calling.  this
* setting allows suppressing those spaces
        CASE OPTION.NAME = "NOSPACESINSUBDEFINITION"
            NO.SPACES.IN.SUB.DEFINITION = OPTION.VALUE

* add common subroutines to wrappers
        CASE OPTION.NAME = "ADDCOMMONROUTINESTOWRAPPERS"
            ADD.COMMON.ROUTINES.TO.WRAPPERS = OPTION.VALUE

* invalid option
        CASE 1
            PRINT 'Warning: Option "':OPTION.NAME:'" is not a valid option setting'
            OPTION.VALID = @FALSE

    END CASE

* if we changed a setting set a flag so we can restore everything later
    IF OPTION.VALID THEN
        SETTINGS.MODIFIED = @TRUE
    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / build tables                             **
**************************************************************************
**************************************************************************

CLEAR.PROPERTY.LIST: *****************************************************
* clear all variables used to build the property list                    *
**************************************************************************
    PROP.NAME.LIST = ""
    PROP.DIM.LIST = ""
    PROP.LINE.LIST = ""
    PROP.TYPE.LIST = ""
    PROP.KEYWORD.LIST = ""
    PROP.LOCAL.LIST = ""
    PROP.COMMENT.LIST = ""
    PROP.COUNT = 0

    RETURN

BUILD.PROPERTY.LIST: *****************************************************
* build a table of properties in an object                               *
**************************************************************************
* property statements in the code look like:                             *
*    PROPERTY var1, var2, var3, var4(n)                                  *
*    STATIC var1, var2, var3, var4(n)                                    *
*    CHILD handle1, handle2, handle3(n)                                  *
**************************************************************************
    PROPERTY.START.DATE = DATE()
    PROPERTY.START.TIME = TIME()

    GOSUB CLEAR.PROPERTY.LIST

    IF DETAILS THEN
        PRINT
        PRINT "Building Property List"
        PRINT
    END

* we'll stop looking when we hit the first method
    HIT.FIRST.METHOD = @FALSE
    SETREM 0 ON OBJECT.CODE

    FOR PTR = 1 TO OBJECT.CODE.LINES UNTIL HIT.FIRST.METHOD

* look for property or static keyword as first word in the line
        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)

        FIRST.WORD = THIS.LINE [" ", 1, 1]
        NEXT.WORD = THIS.LINE [" ", 2, 1]
        NEXT.WORD.ALPHA = @FALSE

        IF UPCASE(NEXT.WORD [1, 1]) >= "A" AND UPCASE(NEXT.WORD [1, 1]) <= "Z" THEN
            NEXT.WORD.ALPHA = @TRUE
        END

* does this keyword start a method?
        DECODE.KEYWORD = FIRST.WORD

        GOSUB IS.METHOD.KEYWORD

        IF IS.METHOD THEN
            HIT.FIRST.METHOD = @TRUE
        END

* does this first keyword indicate a line with properties that should be
* added to the property table?
        GOSUB IS.PROPERTY.KEYWORD

        IF (IS.PROPERTY OR IS.STATIC) AND NEXT.WORD.ALPHA THEN

            GOSUB DECODE.PROPERTY

            THIS.LOCAL = IS.LOCAL

* remove property keyword and clean up property name list
            THIS.LINE = TRIM(THIS.LINE [" ", 2, TO.THE.END]," ","A")
            FIRST.PROPERTY = @TRUE

* add each property into the table
            LOOP UNTIL THIS.LINE = "" DO

* extract property name.  it may be dimensioned
                THIS.NAME = ""
                LOOP UNTIL (THIS.LINE [1, 1] = "," AND COUNT(THIS.NAME,"(") = COUNT(THIS.NAME,")")) OR THIS.LINE = ""
                    THIS.NAME := THIS.LINE [1, 1]
                    THIS.LINE = THIS.LINE [2, TO.THE.END]
                REPEAT

* remove trailing comma and pull off variable dimensions, if there are any
                THIS.LINE = THIS.LINE [2, TO.THE.END]
                THIS.DIM = THIS.NAME ["(", 2, 1] [")", 1, 1]

* determine type of property
                BEGIN CASE

* static properties.  one value for all object instances
                    CASE IS.STATIC AND THIS.DIM = ""
                        THIS.TYPE = "STATIC"

                    CASE IS.STATIC
                        THIS.TYPE = "STATICARRAY"

* normal properties.  each instance has its own value
                    CASE THIS.DIM = ""
                        THIS.TYPE = "PROPERTY"

                    CASE 1
                        THIS.TYPE = "ARRAY"

                END CASE

                GOSUB ADD.PROPERTY

                FIRST.PROPERTY = @FALSE

            REPEAT
        END

    NEXT PTR

    IF DETAILS THEN
        GOSUB PRINT.PROPERTY.LIST
    END

    PROPERTY.END.DATE = DATE()
    PROPERTY.END.TIME = TIME()
    PROPERTY.ELAPSED.TIME += TIME.ELAPSED (PROPERTY.START.DATE, PROPERTY.START.TIME)

    RETURN

ADD.PROPERTY: ************************************************************
* add a property to the property table                                   *
**************************************************************************
    PROP.COUNT += 1

    PROP.NAME.LIST<PROP.COUNT> = THIS.NAME ["(", 1, 1]
    PROP.LINE.LIST<PROP.COUNT> = PTR
    PROP.DIM.LIST<PROP.COUNT> = CHANGE(THIS.DIM, ",", @VM)
    PROP.LOCAL.LIST<PROP.COUNT> = THIS.LOCAL
    PROP.TYPE.LIST<PROP.COUNT> = THIS.TYPE
    PROP.KEYWORD.LIST<PROP.COUNT> = FIRST.WORD

* add comments to the property table
    IF FIRST.PROPERTY THEN
        COMMENT.PTR = PTR
        CHILD.COMMENTS = @FALSE
        GOSUB GET.PREVIOUS.COMMENTS
        PROP.COMMENT.LIST<PROP.COUNT> = LOWER(COMMENT.LIST)
    END

* update the master list of property lines
    PROPERTY.LINE.TYPE = "PROPERTY"
    PROPERTY.LINE = PTR
    GOSUB UPDATE.PROPERTY.LINE.LIST

* check property variable against eclipse commons
    IF CHECK.ECLIPSE.COMMON.VARIABLES THEN
        CHECK.LINE = PTR
        CHECK.VARIABLE = THIS.NAME ["(", 1, 1]
        CHECK.TYPE = "Property"
        GOSUB CHECK.ECLIPSE.COMMON
    END

    RETURN

PRINT.PROPERTY.LIST: *****************************************************
* display the property list for debugging                                *
**************************************************************************
    PRINT
    PRINT "Property...................... Type....... Keyword........ ":
    PRINT "Local Dimensions..... Line...."

    FOR PTR = 1 TO PROP.COUNT

        PRINT PROP.NAME.LIST<PTR> "L#30":" ":
        PRINT PROP.TYPE.LIST<PTR> "L#11":" ":
        PRINT PROP.KEYWORD.LIST<PTR> "l#15":" ":
        PRINT PROP.LOCAL.LIST<PTR> "L#5":" ":
        PRINT CHANGE(PROP.DIM.LIST<PTR>,@VM,", ") "L#15":" ":
        PRINT PROP.LINE.LIST<PTR> "R#8"

    NEXT PTR

    GOSUB WAIT

    RETURN

CLEAR.CONSTANT.LIST: *****************************************************
* clear all variables used to build the constant table                   *
**************************************************************************
    CONSTANT.NAME.LIST = ""

    CONSTANT.VALUE.LIST = ""

    CONSTANT.LINE.LIST = ""
    CONSTANT.COMMENT.LIST = ""
    CONSTANT.KEYWORD.LIST = ""

    CONSTANT.LOCAL.LIST = ""

    CONSTANT.COUNT = 0

    RETURN

BUILD.CONSTANT.LIST: *****************************************************
* build a table of constant definitions                                  *
**************************************************************************
* constant statements in the code look like:                             *
*    CONSTANT constant1 = var1, constant2 = var2, constant3 = var3       *
**************************************************************************
    CONSTANT.START.DATE = DATE()
    CONSTANT.START.TIME = TIME()

    GOSUB CLEAR.CONSTANT.LIST

    IF DETAILS THEN
        PRINT
        PRINT "Building Constant List"
        PRINT
    END

* we'll stop looking when we hit the first method
    HIT.FIRST.METHOD = @FALSE

    SETREM 0 ON OBJECT.CODE

    FOR PTR = 1 TO OBJECT.CODE.LINES UNTIL HIT.FIRST.METHOD

* look for property keyword as first word in the line
        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)

        FIRST.WORD = THIS.LINE [" ", 1, 1]
        NEXT.WORD = THIS.LINE [" ", 2, 1]

        NEXT.WORD.ALPHA = @FALSE

        IF UPCASE(NEXT.WORD [1, 1]) >= "A" AND UPCASE(NEXT.WORD [1, 1]) <= "Z" THEN
            NEXT.WORD.ALPHA = @TRUE
        END

* does this keyword start the first method?
        DECODE.KEYWORD = FIRST.WORD

        GOSUB IS.METHOD.KEYWORD

        IF IS.METHOD THEN
            HIT.FIRST.METHOD = @TRUE
        END

* the first word has to be CONSTANT and the next word has to start
* with an alpha.  if it doesn't it could be an assignment with the
* variable "CONSTANT" or something
        GOSUB IS.CONSTANT.KEYWORD

        IF IS.CONSTANT AND NEXT.WORD.ALPHA THEN

            GOSUB DECODE.PROPERTY

* remove constant keyword and clean up property name list.  remove any
* space not inside quotes
            THIS.LINE = THIS.LINE [" ", 2, TO.THE.END]
            THIS.LINE = REMOVE.SPACES(THIS.LINE)
            FIRST.CONSTANT = @TRUE

* add each constant into the table
            LOOP UNTIL THIS.LINE = "" DO

* extract constant expression, "name = value"
                THIS.EXPRESSION = ""
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""

                LOOP

                    THIS.CHAR = THIS.LINE [1, 1]

                    BEGIN CASE
                        CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                            IN.QUOTES = @FALSE
                        CASE IN.QUOTES
                            NULL
                        CASE THIS.CHAR = "'" OR THIS.CHAR = '"'
                            IN.QUOTES = @TRUE
                            THIS.QUOTE = THIS.CHAR
                    END CASE

                UNTIL (THIS.CHAR = "," AND NOT(IN.QUOTES)) OR THIS.LINE = ""

                    THIS.EXPRESSION := THIS.LINE [1, 1]
                    THIS.LINE = THIS.LINE [2, TO.THE.END]

                REPEAT

* remove trailing comma
                THIS.LINE = THIS.LINE [2, TO.THE.END]

* separate constant name and constant value
                THIS.NAME = TRIM(THIS.EXPRESSION ["=", 1, 1])
                THIS.VALUE = TRIM(THIS.EXPRESSION ["=", 2, TO.THE.END], " ", "B")

* if they didn't use an equals sign we'll pull out the value by spaces
                IF THIS.VALUE = "" THEN
                    THIS.VALUE = TRIM(THIS.EXPRESSION [" ", 2, TO.THE.END], " ", "B")
                END

* if we still don't have a value it must be null
                IF THIS.VALUE = "" THEN
                    THIS.VALUE = '""'
                END

                THIS.LINE.PTR = PTR
                GOSUB ADD.CONSTANT

                FIRST.CONSTANT = 0

            REPEAT
        END

    NEXT PTR

* add default constants:
    FOR DEFAULT.LOOP = 1 TO DEFAULT.CONSTANT.COUNT

        FIRST.CONSTANT = 0
        THIS.NAME = DEFAULT.CONSTANT.LIST<DEFAULT.LOOP>
        THIS.VALUE = DEFAULT.CONSTANT.VALUE.LIST<DEFAULT.LOOP>
        FIRST.WORD = "DEFAULT"
        THIS.LINE.PTR = 0

        IS.LOCAL = @FALSE
        GOSUB ADD.CONSTANT

    NEXT DEFAULT.LOOP

    IF DETAILS THEN
        GOSUB PRINT.CONSTANT.LIST
    END

    CONSTANT.END.DATE = DATE()
    CONSTANT.END.TIME = TIME()
    CONSTANT.ELAPSED.TIME += TIME.ELAPSED (CONSTANT.START.DATE, CONSTANT.START.TIME)

    RETURN

ADD.CONSTANT: ************************************************************
* add this.name and this.value to the constant list                      *
**************************************************************************
    CONSTANT.COUNT += 1

    CONSTANT.NAME.LIST<CONSTANT.COUNT> = THIS.NAME
    CONSTANT.VALUE.LIST<CONSTANT.COUNT> = THIS.VALUE
    CONSTANT.LINE.LIST<CONSTANT.COUNT> = THIS.LINE.PTR
    CONSTANT.KEYWORD.LIST<CONSTANT.COUNT> = FIRST.WORD
    CONSTANT.LOCAL.LIST<CONSTANT.COUNT> = IS.LOCAL

* add comments
    IF FIRST.CONSTANT THEN
        COMMENT.PTR = PTR
        CHILD.COMMENTS = 0
        GOSUB GET.PREVIOUS.COMMENTS
        CONSTANT.COMMENT.LIST<COMMENT.COUNT> = LOWER(COMMENT.LIST)
    END

* update the master list of property lines
    PROPERTY.LINE.TYPE = "CONSTANT"
    PROPERTY.LINE = THIS.LINE.PTR
    GOSUB UPDATE.PROPERTY.LINE.LIST

* check property variable against eclipse commons
    IF CHECK.ECLIPSE.COMMON.VARIABLES THEN
        CHECK.LINE = PTR
        CHECK.VARIABLE = THIS.NAME ["(", 1, 1]
        CHECK.TYPE = "Constant"
        GOSUB CHECK.ECLIPSE.COMMON
    END

    RETURN

PRINT.CONSTANT.LIST: *****************************************************
* print out the constant list for debugging                              *
**************************************************************************
    PRINT
    PRINT "Constant...................... Value................................... ":
    PRINT "Local Line.."

    FOR PTR = 1 TO CONSTANT.COUNT
        PRINT CONSTANT.NAME.LIST<PTR> "L#30":" ":
        PRINT CONSTANT.VALUE.LIST<PTR> "L#40":" ":
        PRINT CONSTANT.LOCAL.LIST<PTR> "L#5":" ":
        PRINT CONSTANT.LINE.LIST<PTR> "R#6"
    NEXT PTR

    GOSUB WAIT

    RETURN

CLEAR.CHILD.LIST: ********************************************************
* clear all variables used to build the child objects table              *
**************************************************************************
    CHILD.NAME.LIST = ""
    CHILD.HANDLE.LIST = ""
    CHILD.VARIABLE.LIST = ""
    CHILD.DIM.LIST = ""

    CHILD.KEYWORD.LIST = ""
    CHILD.CREATED.WITH.LIST = ""

    CHILD.ADDITIONAL.LIST = ""

    CHILD.LOCAL.LIST = ""
    CHILD.DEFINED.LOCAL.LIST = ""

    CHILD.LINE.LIST = ""

    CHILD.DEPTH.LIST = ""

    CHILD.COMMENT.LIST = ""

    CHILD.COUNT = 0

    RETURN

BUILD.CHILD.LIST: ********************************************************
* build a table of child definitions for an object                       *
**************************************************************************
* constant statements in the code look like:                             *
*    CHILD child.handle = NEW(object.name), child.handle =               *
*        NEW(object.name)                                                *
* or                                                                     *
*    LOCAL.CHILD child.handle = NEW(object.name), child.handle =         *
*        NEW(object.name)                                                *
**************************************************************************
    CHILD.START.DATE = DATE()
    CHILD.START.TIME = TIME()

    INDENT.COUNT = 0

    GOSUB CLEAR.CHILD.LIST
    IF DETAILS THEN
        PRINT
        PRINT "Building Child List"
        PRINT
    END

    SEARCH.SUBCHILDREN = @TRUE
    UPDATE.OBJECT.CREATION.LIST = @FALSE
    ADD.LOCAL.CHILD.OBJECTS = @TRUE
    THIS.CHILD.OBJECT.NAME = OBJECT.NAME
    THIS.CHILD.OBJECT.HANDLE = ""

    GOSUB CHECK.FOR.CHILD.OBJECTS

    CHILD.NAME.LIST = CREATE.CHILD.NAME.LIST
    CHILD.HANDLE.LIST = CREATE.CHILD.HANDLE.LIST
    CHILD.KEYWORD.LIST = CREATE.CHILD.KEYWORD.LIST
    CHILD.CREATED.WITH.LIST = CREATE.CHILD.CREATED.WITH.LIST
    CHILD.VARIABLE.LIST = CREATE.CHILD.VARIABLE.LIST
    CHILD.DIM.LIST = CREATE.CHILD.DIM.LIST

    CHILD.ADDITIONAL.LIST = CREATE.CHILD.ADDITIONAL.LIST

    CHILD.LOCAL.LIST = CREATE.CHILD.LOCAL.LIST
    CHILD.DEFINED.LOCAL.LIST = CREATE.CHILD.DEFINED.LOCAL.LIST

    CHILD.DEPTH.LIST = CREATE.CHILD.DEPTH.LIST

    CHILD.LINE.LIST = CREATE.CHILD.LINE.LIST

    CHILD.COMMENT.LIST = CREATE.CHILD.COMMENT.LIST

    CHILD.COUNT = CREATE.CHILD.COUNT

* update the master list of property lines for the child objects that
* are defined in this object.  NOT updating with child objects of child
* objects.  this master list is used for object / method / property
* listings.  also, don't add local child objects as outside processes
* won't be able to see them
    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>
        THIS.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>
        THIS.LINE = CHILD.LINE.LIST<CHILD.LOOP>

        IF THIS.DEPTH = 1 AND NOT(THIS.LOCAL) THEN
            PROPERTY.LINE.TYPE = "CHILD"
            PROPERTY.LINE = THIS.LINE
            GOSUB UPDATE.PROPERTY.LINE.LIST
        END

    NEXT CHILD.LOOP

* check child object names for eclipse common conflicts
    IF CHECK.ECLIPSE.COMMON.VARIABLES THEN

        FOR CHECK.CHILD.LOOP = 1 TO CHILD.COUNT

            CHECK.LINE = PTR
            CHECK.VARIABLE = CHILD.VARIABLE.LIST<CHECK.CHILD.LOOP> ["(", 1, 1]
            CHECK.TYPE = "Child Object"
            GOSUB CHECK.ECLIPSE.COMMON

        NEXT CHECK.CHILD.LOOP

    END

    IF DETAILS THEN
        GOSUB PRINT.CHILD.LIST
    END

    CHILD.END.DATE = DATE()
    CHILD.END.TIME = TIME()
    CHILD.ELAPSED.TIME += TIME.ELAPSED (CHILD.START.DATE, CHILD.START.TIME)

    RETURN

PRINT.CHILD.LIST: ********************************************************
* print out the child list for debugging                                 *
**************************************************************************
    PRINT
    PRINT "Child Objects for ":OBJECT.NAME
    PRINT "ChildHandle....................................... ChildObject.... ":
    PRINT "Local DefLocal ":
    PRINT "Variable.......................................... Dimension. ":
    PRINT "Depth Line......"

    FOR PTR = 1 TO CHILD.COUNT

        BEGIN CASE
            CASE CHILD.DEFINED.LOCAL.LIST<PTR>
                PRINT (CHILD.HANDLE.LIST<PTR>:" (def local)") "L#50":" ":
            CASE CHILD.LOCAL.LIST<PTR>
                PRINT (CHILD.HANDLE.LIST<PTR>:" (parent local)") "L#50":" ":
            CASE 1
                PRINT CHILD.HANDLE.LIST<PTR> "L#50":" ":
        END CASE

        PRINT CHILD.NAME.LIST<PTR> "L#15":" ":
        PRINT CHILD.LOCAL.LIST<PTR> "R#5":" ":
        PRINT CHILD.DEFINED.LOCAL.LIST<PTR> "R#8":" ":
        PRINT CHILD.VARIABLE.LIST<PTR> "L#50":" ":
        PRINT CHANGE(CHILD.DIM.LIST<PTR>,VM,",") "R#10":" ":
        PRINT CHILD.DEPTH.LIST<PTR> "R#5":" ":
        PRINT CHILD.LINE.LIST<PTR> "R#10"

    NEXT PTR

    GOSUB WAIT

    RETURN

CHECK.FOR.CHILD.OBJECTS: *************************************************
* check for child objects in this.child.object.name, an OBJ object name, *
* and this.child.object.handle, its handle.                              *
* updates create.child tables using obj code from THIS.CHILD.OBJECT.NAME *
*                                                                        *
* needs:  search.subchildren, update.object.creation.list,               *
* this.child.object.name, this.child.object.handle,                      *
* add.local.child.objects                                                *
**************************************************************************
    PARENT.OBJECT.NAME = THIS.CHILD.OBJECT.NAME
    PARENT.OBJECT.HANDLE = THIS.CHILD.OBJECT.HANDLE

* this table will be build from the object code of objects used by this
* program.  it will be all children of objects used by this program
    CREATE.CHILD.NAME.LIST = ""
    CREATE.CHILD.PARENT.HANDLE.LIST = ""
    CREATE.CHILD.HANDLE.LIST = ""
    CREATE.CHILD.KEYWORD.LIST = ""
    CREATE.CHILD.CREATED.WITH.LIST = ""

    CREATE.CHILD.VARIABLE.LIST = ""
    CREATE.CHILD.DIM.LIST = ""

    CREATE.CHILD.ADDITIONAL.LIST = ""

    CREATE.CHILD.DEPTH.LIST = ""
    CREATE.CHILD.LOCAL.LIST = ""
    CREATE.CHILD.DEFINED.LOCAL.LIST = ""

    CREATE.CHILD.LINE.LIST = ""

    CREATE.CHILD.COMMENT.LIST = ""

    CREATE.CHILD.COUNT = 0

* this first search will be at a child depth of 1.  these child objects
* will be set "local" if the local child keyword is used
    THIS.CHILD.DEPTH = 1
    SET.CHILD.OBJECTS.LOCAL = @FALSE

    GOSUB CHECK.ONE.FOR.CHILD.OBJECTS

* if we're not searching subchildren we're done
    IF NOT(SEARCH.SUBCHILDREN) THEN
        RETURN
    END

    ADD.LOCAL.CHILD.OBJECTS = @FALSE

* each of these child objects could have other child objects.  loop deeper and
* deeper and add compound object references.  we already have the first level
* of child objects (depth = 1) so we only search deeper starting with depth = 2

* at present we can only handled dimensioned child objects if only the last
* child in the handle is dimensioned.  we won't look for subchildren for
* children that are dimensioned
    FOR CHILD.DEPTH = 1 TO MAX.CHILD.DEPTH - 1

* go through the child list and find subchildren for any child object at
* the current child depth
        FOR CHILD.LOOP = 1 TO CREATE.CHILD.COUNT

            THIS.PARENT.DEPTH = CREATE.CHILD.DEPTH.LIST<CHILD.LOOP>
            THIS.PARENT.DIM = CREATE.CHILD.DIM.LIST<CHILD.LOOP>

            IF THIS.PARENT.DEPTH = CHILD.DEPTH AND THIS.PARENT.DIM = "" THEN

                THIS.PARENT.HANDLE = CREATE.CHILD.HANDLE.LIST<CHILD.LOOP>
                THIS.PARENT.NAME = CREATE.CHILD.NAME.LIST<CHILD.LOOP>
                THIS.PARENT.DIM = CREATE.CHILD.DIM.LIST<CHILD.LOOP>

                THIS.PARENT.LOCAL = CREATE.CHILD.LOCAL.LIST<CHILD.LOOP>
                THIS.PARENT.DEFINED.LOCAL = CREATE.CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

                THIS.PARENT.DEPTH = CREATE.CHILD.DEPTH.LIST<CHILD.LOOP>

* we have a child object at our search depth.  get the object name and get
* a list of child objects it creates
                THIS.CHILD.OBJECT.NAME = THIS.PARENT.NAME
                THIS.CHILD.OBJECT.HANDLE = THIS.PARENT.HANDLE
                THIS.CHILD.DEPTH = THIS.PARENT.DEPTH + 1

* these child objects will be set local if the parent object was set local
                SET.CHILD.OBJECTS.LOCAL = THIS.PARENT.LOCAL

                GOSUB CHECK.ONE.FOR.CHILD.OBJECTS

            END

        NEXT CHILD.LOOP

    NEXT CHILD.DEPTH

    IF DETAILS THEN
        GOSUB PRINT.CHILD.OBJECT.LIST
    END

    RETURN

CHECK.ONE.FOR.CHILD.OBJECTS: *********************************************
* check a single obj file for child objects and update the child.object  *
* tables.  needs this.child.object.name and this.child.object.handle.    *
* if add.local.child is false local child objects will not be added      *
**************************************************************************

* fetch code for the object used
    READ CALLED.CODE FROM OBJFILE, THIS.CHILD.OBJECT.NAME ELSE
        RETURN
    END

    CALLED.CODE.COUNT = DCOUNT(CALLED.CODE,AM)

* if we're upcasing code just upcase the entire record.  we're only
* searching for child objects so it doesn't matter if we upcase code
* in quotes
    IF UPCASE.CODE THEN
        CALLED.CODE = UPCASE(CALLED.CODE)
    END

* look through code for any "child" statements.  when we hit the first method
* we can stop looking
    HIT.FIRST.METHOD = @FALSE
    SETREM 0 ON CALLED.CODE

    FOR CALLED.LOOP = 1 TO CALLED.CODE.COUNT UNTIL HIT.FIRST.METHOD

        REMOVE CALLED.LINE FROM CALLED.CODE SETTING THROWAWAY

        CALLED.LINE = TRIM(CALLED.LINE)

* pull out the first word from the statement.  if this line is creating
* a child object the first word should be "child" or "local.child"
        CALLED.FIRST.WORD = CALLED.LINE [" ", 1, 1]

        DECODE.KEYWORD = CALLED.FIRST.WORD

        GOSUB IS.METHOD.KEYWORD

        IF IS.METHOD THEN
            HIT.FIRST.METHOD = @TRUE
        END

* if the first line in the code defines a child object add it to the
* child handle list
        GOSUB IS.CHILD.KEYWORD

        IF IS.CHILD THEN

            GOSUB DECODE.PROPERTY

            IF ADD.LOCAL.CHILD.OBJECTS OR NOT(IS.LOCAL) THEN
                LOCAL.CHILD = IS.LOCAL
                GOSUB ADD.CHILD.HANDLE.LIST
            END

        END

    NEXT CALLED.LOOP

    RETURN

ADD.CHILD.HANDLE.LIST: ***************************************************
* build a list of child handles from called.line and add each child      *
* object to the child object tables.  needs local.child defined true/    *
* false to signify if this is a local child object or not                *
**************************************************************************

* get list of child handles from "child" line
    CHILD.DEFINE.LIST = SPLIT.PARAMETERS (CALLED.LINE [" ", 2, TO.THE.END])

    CHILD.DEFINE.COUNT = DCOUNT(CHILD.DEFINE.LIST, @AM)

    FOR DEFINE.LOOP = 1 TO CHILD.DEFINE.COUNT

        THIS.DEFINE = CHILD.DEFINE.LIST<DEFINE.LOOP>
        GOSUB ADD.ONE.CHILD.OBJECT

    NEXT DEFINE.LOOP

    RETURN

ADD.ONE.CHILD.OBJECT: ****************************************************
* extract child object information from this.define and update child     *
* object table and handle table                                          *
**************************************************************************
    ADDITIONAL.PARAMETERS = ""

* break child name and handle out of "child" statement
    THIS.CHILD.HANDLE = TRIM(THIS.DEFINE ["=", 1, 1], " ", "B")
    THIS.CHILD.NAME = TRIM(THIS.DEFINE ["=", 2, 1], " ", "B")

* get the type of object (old, new, etc) created
    THIS.CHILD.CREATED.WITH = TRIM(THIS.DEFINE ["=", 2, 1] ["(", 1, 1], " ", "B")

* check handle for a dimensioned child object
    THIS.CHILD.DIM = ""
    THIS.CHILD.DIMENSIONED = @FALSE

    IF COUNT(THIS.CHILD.HANDLE, "(") <> 0 THEN

        THIS.CHILD.DIM = THIS.CHILD.HANDLE ["(", 2, 1] [")", 1, 1]
        THIS.CHILD.DIM = CHANGE(THIS.CHILD.DIM, ",", VM)
        THIS.CHILD.HANDLE = TRIM(THIS.CHILD.HANDLE ["(", 1, 1])
        THIS.CHILD.DIMENSIONED = @TRUE

    END

    CREATED.WITH = ""

* remove the object name from the "new" expression in this.child.name
    CHECK.NEW.KEYWORD = NEW.KEYWORD
    GOSUB CHECK.NEW.KEYWORD

    IF NOT(FOUND.NEW) THEN
        CHECK.NEW.KEYWORD = NEW.MULTI.THREAD.KEYWORD
        GOSUB CHECK.NEW.KEYWORD
    END

    IF NOT(FOUND.NEW) THEN
        CHECK.NEW.KEYWORD = NEW.RESIDENT.KEYWORD
        GOSUB CHECK.NEW.KEYWORD
    END

    IF NOT(FOUND.NEW) THEN
        CHECK.NEW.KEYWORD = OLD.KEYWORD
        GOSUB CHECK.NEW.KEYWORD
    END

    IF NOT(FOUND.NEW) THEN
        CHECK.NEW.KEYWORD = OLD.MULTI.THREAD.KEYWORD
        GOSUB CHECK.NEW.KEYWORD
    END

* if additional parameters are specified in the "new" statement there
* will be a comma in the child name.  extract all the parameters off
* the end and leave the child name by itself
* BEFORE.CHILD.NAME = THIS.CHILD.NAME
    THIS.CHILD.NAME = SMART.TRIM (THIS.CHILD.NAME)

    IF COUNT(THIS.CHILD.NAME, ",") <> 0 THEN
        ADDITIONAL.PARAMETERS = TRIM(THIS.CHILD.NAME [",", 2, TO.THE.END], " ", "B")
        THIS.CHILD.NAME = TRIM(THIS.CHILD.NAME [",", 1, 1], " ", "B")
    END

* build the object handle for the child object as we'll see it in
* this program and also the child handle variable as we'll see it
* used

* if this.child.object.handle is null then we're finding objects
* inside object code.  don't add this.child.object to the usage
* child handle
    IF THIS.CHILD.OBJECT.HANDLE = "" THEN
        USAGE.CHILD.HANDLE = THIS.CHILD.HANDLE
        USAGE.CHILD.VARIABLE = CHANGE(THIS.CHILD.HANDLE, CHILD.DELIMITER, ".")
    END ELSE
        USAGE.CHILD.HANDLE = THIS.CHILD.OBJECT.HANDLE:CHILD.DELIMITER:THIS.CHILD.HANDLE
        USAGE.CHILD.VARIABLE = CHILD.VARIABLE.PREFIX:CHANGE(USAGE.CHILD.HANDLE, CHILD.DELIMITER, ".")
    END

* the internal variable name used for child objects can get pretty long
* if we have lots of nested child objects.  reduce its length if necessary
    LONG.VARIABLE = USAGE.CHILD.VARIABLE
    GOSUB CHECK.VARIABLE.NAME
    USAGE.CHILD.VARIABLE = SHORT.VARIABLE

* if all child objects discovered should be set local (ie, we're
* finding child objects for a local child object) force local.child
* to true

* defined.local.child will have whether or not the child was defined
* as local in the object definition.  local.child will have if the
* child is (sometimes) treated as local because its parent object is
* local
    DEFINED.LOCAL.CHILD = LOCAL.CHILD
    IF SET.CHILD.OBJECTS.LOCAL THEN
        LOCAL.CHILD = @TRUE
    END

* add this child to the child object list
    CREATE.CHILD.COUNT += 1

    CREATE.CHILD.NAME.LIST<CREATE.CHILD.COUNT> = THIS.CHILD.NAME
    CREATE.CHILD.PARENT.HANDLE.LIST<CREATE.CHILD.COUNT> = THIS.CHILD.OBJECT.HANDLE
    CREATE.CHILD.HANDLE.LIST<CREATE.CHILD.COUNT> = USAGE.CHILD.HANDLE
    CREATE.CHILD.KEYWORD.LIST<CREATE.CHILD.COUNT> = CALLED.FIRST.WORD
    CREATE.CHILD.CREATED.WITH.LIST<CREATE.CHILD.COUNT> = THIS.CHILD.CREATED.WITH

    CREATE.CHILD.VARIABLE.LIST<CREATE.CHILD.COUNT> = USAGE.CHILD.VARIABLE
    CREATE.CHILD.DIM.LIST<CREATE.CHILD.COUNT> = THIS.CHILD.DIM

    CREATE.CHILD.ADDITIONAL.LIST<CREATE.CHILD.COUNT> = ADDITIONAL.PARAMETERS

    CREATE.CHILD.DEPTH.LIST<CREATE.CHILD.COUNT> = THIS.CHILD.DEPTH

    CREATE.CHILD.LOCAL.LIST<CREATE.CHILD.COUNT> = LOCAL.CHILD
    CREATE.CHILD.DEFINED.LOCAL.LIST<CREATE.CHILD.COUNT> = DEFINED.LOCAL.CHILD

    CREATE.CHILD.LINE.LIST<CREATE.CHILD.COUNT> = CALLED.LOOP

* add comments
    CHILD.COMMENTS = @TRUE
    COMMENT.PTR = CALLED.LOOP
    GOSUB GET.PREVIOUS.COMMENTS

    CREATE.CHILD.COMMENT.LIST<CREATE.CHILD.COUNT> = LOWER(COMMENT.LIST)

* also add it to the object creation list
    IF UPDATE.OBJECT.CREATION.LIST THEN

* do we want to add this child object to the object creation list?
* we want it in the create.child tables so we know all child objects
* that are involved but the create.handle.list table is used to
* create all the keywords that may be involved in object method
* calls.  for local child objects we don't always want to do
* this
        ADD.CHILD.OBJECT = @TRUE

        BEGIN CASE
            CASE COMPILE.OBJECT AND THIS.CHILD.DEPTH > 1 AND LOCAL.CHILD
                ADD.CHILD.OBJECT = @FALSE
            CASE COMPILE.SUBROUTINE AND THIS.CHILD.DEPTH > 0 AND LOCAL.CHILD
                ADD.CHILD.OBJECT = @FALSE
        END CASE

        IF ADD.CHILD.OBJECT THEN

            CREATE.COUNT += 1

            CREATE.OBJECT.LIST<CREATE.COUNT> = THIS.CHILD.NAME
            CREATE.HANDLE.LIST<CREATE.COUNT> = USAGE.CHILD.HANDLE
            CREATE.KEYWORD.LIST<CREATE.COUNT> = CALLED.FIRST.WORD
            CREATE.CREATED.WITH.LIST<CREATE.COUNT> = THIS.CHILD.CREATED.WITH

            CREATE.VARIABLE.LIST<CREATE.COUNT> = USAGE.CHILD.VARIABLE
            CREATE.DIMENSIONED.LIST<CREATE.COUNT> = THIS.CHILD.DIMENSIONED
            CREATE.DIM.VAR.LIST<CREATE.COUNT> = THIS.CHILD.DIM

            CREATE.ADDITIONAL.LIST<CREATE.COUNT> = ADDITIONAL.PARAMETERS

            CREATE.LOCAL.LIST<CREATE.COUNT> = LOCAL.CHILD
            CREATE.DEFINED.LOCAL.LIST<CREATE.COUNT> = DEFINED.LOCAL.CHILD

            CREATE.TYPE.LIST<CREATE.COUNT> = "CHILD"
            CREATE.WITH.LIST<CREATE.COUNT> = CREATED.WITH

            CREATE.LINE.LIST<CREATE.COUNT> = PTR

            CREATE.LABEL.LIST<CREATE.COUNT> = ""
            CREATE.INDENT.LIST<CREATE.COUNT> = INDENT.COUNT

        END

    END

    RETURN

CHECK.NEW.KEYWORD: *******************************************************
* check for check.new.keyword in this.child.name.  if found returns      *
* this.child.name with only the object name and any parameters in the    *
* "new" expression, created.with with the keyword that created the       *
* object and found.new true                                              *
**************************************************************************
    FOUND.NEW = @FALSE

    LEN.CHECK.NEW.KEYWORD = LEN(CHECK.NEW.KEYWORD)

* check for the "new" keyword followed by an open parenthesis
    IF THIS.CHILD.NAME [1, LEN.CHECK.NEW.KEYWORD + 1] = CHECK.NEW.KEYWORD:"(" THEN

        THIS.CHILD.NAME = THIS.CHILD.NAME [LEN.CHECK.NEW.KEYWORD + 2, TO.THE.END]

        IF THIS.CHILD.NAME [1] = ")" THEN
            THIS.CHILD.NAME = TRIM(THIS.CHILD.NAME [1, LEN(THIS.CHILD.NAME) - 1])
        END

        CREATED.WITH = NEW.KEYWORD

        FOUND.NEW = @TRUE

        RETURN

    END

* check for the "new" keyword followed by a space and then a parenthesis
    IF THIS.CHILD.NAME [1, LEN.CHECK.NEW.KEYWORD + 2] = CHECK.NEW.KEYWORD:" (" THEN

        THIS.CHILD.NAME = THIS.CHILD.NAME [LEN.CHECK.NEW.KEYWORD + 3, TO.THE.END]

        IF THIS.CHILD.NAME [1] = ")" THEN
            THIS.CHILD.NAME = TRIM(THIS.CHILD.NAME [1, LEN(THIS.CHILD.NAME) - 1])
        END

        CREATED.WITH = NEW.KEYWORD

        FOUND.NEW = @TRUE

        RETURN

    END

    RETURN

ADD.CHILD: ***************************************************************
* add this.handle and this.name to the child handle list                 *
**************************************************************************
    THIS.DIM = ""

* if handle is dimensioned split name from dimension
    IF COUNT(THIS.HANDLE, "(") <> 0 THEN
        THIS.DIM = TRIM(THIS.HANDLE ["(", 2, 1] [")", 1, 1], " ", "A")
        THIS.DIM = CHANGE(THIS.DIM, ",", VM)
        THIS.HANDLE = TRIM(THIS.HANDLE ["(", 1, 1], " ", "A")
    END

    CHILD.COUNT += 1

    CHILD.NAME.LIST<CHILD.COUNT> = THIS.NAME
    CHILD.HANDLE.LIST<CHILD.COUNT> = THIS.HANDLE
    CHILD.KEYWORD.LIST<CHILD.COUNT> = CALLED.FIRST.WORD

    CHILD.VARIABLE.LIST<CHILD.COUNT> = THIS.VARIABLE
    CHILD.DIM.LIST<CHILD.COUNT> = THIS.DIM

    CHILD.ADDITIONAL.LIST = ""

    CHILD.LOCAL.LIST<CHILD.COUNT> = THIS.LOCAL
    CHILD.DEFINED.LOCAL.LIST<CHILD.COUNT> = THIS.LOCAL

    CHILD.LINE.LIST<CHILD.COUNT> = THIS.LINE

    CHILD.COMMENTS = @TRUE
    COMMENT.PTR = THIS.LINE
    GOSUB GET.PREVIOUS.COMMENTS

    CHILD.COMMENT.LIST<CHILD.COUNT> = ""

    CHILD.DEPTH.LIST<CHILD.COUNT> = THIS.CHILD.DEPTH

* update the master list of property lines
    IF THIS.CHILD.DEPTH = 1 AND NOT(THIS.LOCAL) THEN
        PROPERTY.LINE.TYPE = "CHILD"
        PROPERTY.LINE = THIS.LINE
        GOSUB UPDATE.PROPERTY.LINE.LIST
    END

    RETURN

PRINT.CHILD.OBJECT.LIST: *************************************************
* print the child object list for debugging                              *
**************************************************************************
    PRINT
    PRINT "Child Object created by ":PARENT.OBJECT.HANDLE:" (":PARENT.OBJECT.NAME:"):"
    PRINT "ChildHandle....................................... ChildObject.... ":
    PRINT "Variable.......................................... Dimension. ":
    PRINT "Depth Line......"

    FOR PTR = 1 TO CREATE.CHILD.COUNT

        BEGIN CASE
            CASE CREATE.CHILD.DEFINED.LOCAL.LIST<PTR>
                PRINT (CREATE.CHILD.HANDLE.LIST<PTR>:" (def local)") "L#50":" ":
            CASE CREATE.CHILD.LOCAL.LIST<PTR>
                PRINT (CREATE.CHILD.HANDLE.LIST<PTR>:" (parent local)") "L#50":" ":
            CASE 1
                PRINT CREATE.CHILD.HANDLE.LIST<PTR> "L#50":" ":
        END CASE

        PRINT CREATE.CHILD.NAME.LIST<PTR> "L#15":" ":
        PRINT CREATE.CHILD.VARIABLE.LIST<PTR> "L#50":" ":
        PRINT CHANGE(CREATE.CHILD.DIM.LIST<PTR>,VM,",") "R#10":" ":

        PRINT CREATE.CHILD.DEPTH.LIST<PTR> "R#5":" ":

        PRINT CREATE.CHILD.LINE.LIST<PTR> "R#10"

    NEXT PTR

    GOSUB WAIT

    RETURN

GET.PREVIOUS.COMMENTS: ***************************************************
* build comment.list and comment.count with a table of comments before   *
* comment.ptr until hitting a non-comment or blank line.  this is        *
* skipped if update.comment.table isn't set (to save time)               *
**************************************************************************
    COMMENT.LIST = ""
    COMMENT.COUNT = 0

    IF NOT(UPDATE.COMMENT.TABLE) THEN
        RETURN
    END

    LOOP

        COMMENT.PTR -= 1

        IF CHILD.COMMENTS THEN
            THIS.TEST.LINE = CALLED.CODE<COMMENT.PTR>
        END ELSE
            THIS.TEST.LINE = OBJECT.CODE<COMMENT.PTR>
        END

    UNTIL TRIM(THIS.TEST.LINE) = "" OR NOT(IS.COMMENT(THIS.TEST.LINE)) OR COMMENT.PTR <= 1

* remove asterisks and add THIS.TEST.LINE to comment.list
        IF THIS.TEST.LINE = STR("*", LEN(THIS.TEST.LINE)) THEN
            THIS.TEST.LINE = ""
        END

        LOOP UNTIL THIS.TEST.LINE [1, 1] <> "*"
            THIS.TEST.LINE = THIS.TEST.LINE [2, TO.THE.END]
        REPEAT

        LOOP UNTIL THIS.TEST.LINE [1] <> "*"
            THIS.TEST.LINE = THIS.TEST.LINE [1, LEN(THIS.TEST.LINE) - 1]
        REPEAT

        THIS.TEST.LINE = TRIM(THIS.TEST.LINE, " ", "B")

        COMMENT.COUNT += 1
        COMMENT.LIST<COMMENT.COUNT> = THIS.TEST.LINE

    REPEAT

    RETURN

UPDATE.PROPERTY.LINE.LIST: ***********************************************
* update the master list of property lines                               *
**************************************************************************
    LOCATE PROPERTY.LINE IN PROPERTY.LINE.LIST BY "AR" SETTING PROPERTY.LINE.PTR ELSE

        PROPERTY.LINE.COUNT += 1

        INS PROPERTY.LINE BEFORE PROPERTY.LINE.LIST<PROPERTY.LINE.PTR>
        INS PROPERTY.LINE.TYPE BEFORE PROPERTY.TYPE.LIST<PROPERTY.LINE.PTR>

    END

    RETURN

CLEAR.METHOD.LIST: *******************************************************
* clear all variables used to build the method list                      *
**************************************************************************
    METHOD.LIST = ""
    METHOD.TYPE.LIST = ""
    METHOD.LOCAL.LIST = ""

    METHOD.WRAPPER.LIST = ""
    METHOD.WRAPPER.PARM.LIST = ""
    METHOD.WRAPPER.BYREF.LIST = ""
    METHOD.WRAPPER.SPECIAL.LIST = ""
    METHOD.WRAPPER.OPTIONAL.LIST = ""
    METHOD.WRAPPER.DEFAULT.LIST = ""
    METHOD.WRAPPER.PARM.COUNT.LIST = ""

    METHOD.SECTION.LIST = ""

    METHOD.PARM.LIST = ""
    METHOD.PARM.COUNT.LIST = ""
    METHOD.PARM.OPTIONAL.LIST = ""
    METHOD.PARM.DEFAULT.LIST = ""
    METHOD.PARM.SET.LIST = ""
    METHOD.PARM.BYREF.LIST = ""
    METHOD.PARM.SPECIAL.LIST = ""

    METHOD.INHERIT.LIST = ""
    METHOD.INHERIT.OBJECT.LIST = ""
    METHOD.INHERIT.HANDLE.LIST = ""
    METHOD.INHERIT.METHOD.LIST = ""
    METHOD.INHERIT.DEFINITION.LIST = ""

    METHOD.START.LINE = ""
    METHOD.END.LINE = ""
    METHOD.PROGRAM.START.LINE = ""

    LAST.INHERIT.OBJECT = ""

    METHOD.COUNT = 0

    THIS.SECTION.NAME = ""

    RETURN

BUILD.METHOD.LIST: *******************************************************
* build table of all methods in the object being compiled                *
**************************************************************************
    METHOD.START.DATE = DATE()
    METHOD.START.TIME = TIME()

    GOSUB CLEAR.METHOD.LIST

    IF DETAILS THEN
        PRINT
        PRINT "Building Method List"
        PRINT
    END

    SETREM 0 ON OBJECT.CODE

    FOR PTR = 1 TO OBJECT.CODE.LINES

* look for method as the first word in the line
        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)

        FIRST.WORD = THIS.LINE [" ", 1, 1]
        DECODE.KEYWORD = FIRST.WORD
        GOSUB DECODE.METHOD

        NEXT.WORD = THIS.LINE [" ", 2, 1]
        NEXT.WORD.ALPHA = @FALSE

        IF UPCASE(NEXT.WORD [1, 1]) >= "A" AND UPCASE(NEXT.WORD [1, 1]) <= "Z" THEN
            NEXT.WORD.ALPHA = @TRUE
        END

        THIS.INHERITED = @FALSE
        THIS.LOCAL = IS.LOCAL.METHOD

* update the method tables.  we'll hardcode this.method.type since the wrapper
* keyword can be changed in the control record
        BEGIN CASE

* "inline.method" and "local.inline.method" keywords add a new inline method
            CASE IS.INLINE AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "INLINE"
                GOSUB ADD.METHOD

* "tcl.wrapper" keyword adds a new tcl-wrapper method
            CASE IS.TCL AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "TCL.WRAPPER"
                GOSUB ADD.METHOD

* "driver.wrapper" keywords adds a new driver method
            CASE IS.DRIVER AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "DRIVER.WRAPPER"
                GOSUB ADD.METHOD

* "phantom.wrapper" keyword adds a new phantom method
            CASE IS.PHANTOM AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "PHANTOM.WRAPPER"
                GOSUB ADD.METHOD

* "routine" keyword adds a new "routine" wrapper method
            CASE IS.ROUTINE AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "ROUTINE"
                GOSUB ADD.METHOD

* "wrapper" keyword adds a new (generic) wrapper method
            CASE IS.WRAPPER AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "WRAPPER"
                GOSUB ADD.METHOD

* "inherit" sets the inherited object for later "inherited" statements
            CASE IS.INHERITED.FROM AND NEXT.WORD.ALPHA AND ALLOW.INHERITS
                GOSUB ADD.INHERITED.OBJECT

* "inherited" adds a new inherited method
            CASE IS.INHERITED AND NEXT.WORD.ALPHA AND ALLOW.INHERITS
                THIS.METHOD.TYPE = "METHOD"
                THIS.INHERITED = @TRUE
                GOSUB ADD.INHERITED.METHOD

* "method" keyword adds a new method
            CASE IS.METHOD AND NEXT.WORD.ALPHA
                THIS.METHOD.TYPE = "METHOD"
                GOSUB ADD.METHOD

* "section" keyword adds a new section for listing methods
            CASE IS.SECTION
                GOSUB ADD.SECTION

        END CASE

    NEXT PTR

* for the last method set the end of the method as the end of the
* object code.  inherited methods already have this set properly so skip
* if the last method is inherited
    THIS.INHERITED = METHOD.INHERIT.LIST<METHOD.COUNT>

    IF METHOD.COUNT > 0 AND NOT(THIS.INHERITED) THEN
        METHOD.END.LINE<METHOD.COUNT> = OBJECT.CODE.LINES
    END

* for each method move the end line back to skip over any trailing
* blank lines or comments.  skip this for inherited methods
    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.END.LINE = METHOD.END.LINE<METHOD.LOOP>
        THIS.INHERITED = METHOD.INHERIT.LIST<METHOD.LOOP>

        IF NOT(THIS.INHERITED) THEN

            LOOP UNTIL IS.CODE(OBJECT.CODE<THIS.END.LINE>) OR THIS.END.LINE = 1
                THIS.END.LINE -= 1
            REPEAT

            METHOD.END.LINE<METHOD.LOOP> = THIS.END.LINE

        END

    NEXT METHOD.LOOP

* for each method find the first program (non-comment) line.  for inherited
* methods this is already set so we'll skip inherited methods
    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        START.LINE = METHOD.START.LINE<METHOD.LOOP>
        END.LINE = METHOD.END.LINE<METHOD.LOOP>
        THIS.INHERITED = METHOD.INHERIT.LIST<METHOD.LOOP>

        IF NOT(THIS.INHERITED) THEN

            FIRST.LINE = @FALSE
            FOR METHOD.LINE = START.LINE TO END.LINE UNTIL FIRST.LINE <> 0

                IF IS.CODE(OBJECT.CODE<METHOD.LINE>) THEN
                    FIRST.LINE = METHOD.LINE
                END

            NEXT METHOD.LINE

            IF FIRST.LINE = @FALSE THEN
                FIRST.LINE = END.LINE
            END

            METHOD.PROGRAM.START.LINE<METHOD.LOOP> = FIRST.LINE

        END

    NEXT METHOD.LOOP

    IF DETAILS THEN
        GOSUB PRINT.METHOD.LIST
    END

    METHOD.END.DATE = DATE()
    METHOD.END.TIME = TIME()
    METHOD.ELAPSED.TIME += TIME.ELAPSED (METHOD.START.DATE, METHOD.START.TIME)

    RETURN

ADD.METHOD: **************************************************************
* add a method given the method definition in this.line to the method    *
* list                                                                   *
**************************************************************************

* start after the "method" keyword
    METHOD.SOURCE = THIS.LINE [" ", 2, TO.THE.END]

    METHOD.DEF = ""
    IN.QUOTES = @FALSE
    THIS.QUOTE = ""
    PREN.DEPTH = 0

    CHAR.PTR = 0
    END.OF.DEFINITION = @FALSE

    LOOP

        CHAR.PTR += 1
        THIS.CHAR = METHOD.SOURCE [CHAR.PTR, 1]

        BEGIN CASE

* end of the line
            CASE THIS.CHAR = ""
                IN.QUOTES = @FALSE
                PREN.DEPTH = 0
                END.OF.DEFINITION = @TRUE

* process quotes
            CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                IN.QUOTES = @FALSE
                THIS.QUOTE = ""
            CASE IN.QUOTES
                NULL
            CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                IN.QUOTES = @TRUE
                THIS.QUOTE = THIS.CHAR

* parenthesis
            CASE THIS.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.CHAR = ")"
                PREN.DEPTH -= 1
                IF PREN.DEPTH < 0 THEN
                    PREN.DEPTH = 0
                END
            CASE PREN.DEPTH <> 0
                NULL

* colon that's the end of the definition
            CASE THIS.CHAR = ":"
                END.OF.DEFINITION = @TRUE
                CHAR.PTR -= 1

        END CASE
    
    UNTIL END.OF.DEFINITION
    REPEAT

    METHOD.DEF = METHOD.SOURCE [1, CHAR.PTR]

    THIS.METHOD.NAME = TRIM(METHOD.DEF ["(", 1, 1], " ", "A")

* if this.method.name has a comma in it the first field is the method
* name and the second field is the subroutine name if the method is a
* wrapper method
    THIS.WRAPPER.NAME = ""
    IF COUNT(THIS.METHOD.NAME, ",") = 1 THEN
        THIS.WRAPPER.NAME = THIS.METHOD.NAME [",", 2, 1]
        THIS.METHOD.NAME = THIS.METHOD.NAME [",", 1, 1]
    END

* does this method have parameters? extract everything after the open
* parenthesis immediately after the method name
    PARM.LIST.STRING = METHOD.DEF ["(", 2, TO.THE.END]

* check the parameter list for errors
    IF CHECK.IO.PARAMETERS THEN

* some wrappers won't have input vs output parameters.  for these
* method types we'll skip this check unless MandatoryWrapperIOParameters
* is set
        IF MANDATORY.WRAPPER.IO.PARAMETERS THEN
            SKIP.METHOD.TYPES = ""
        END ELSE
            SKIP.METHOD.TYPES = TCL.WRAPPER.METHOD.KEYWORD:@AM:DRIVER.WRAPPER.METHOD.KEYWORD:@AM
            SKIP.METHOD.TYPES := PHANTOM.WRAPPER.METHOD.KEYWORD
        END

        LOCATE THIS.METHOD.TYPE IN SKIP.METHOD.TYPES SETTING THROWAWAY ELSE

            IF MANDATORY.IO.PARAMETERS THEN
                PARAMETER.MODE = "MANDATORY.CHECK"
            END ELSE
                PARAMETER.MODE = "CHECK"
            END

            PARAMETER.ERROR = SPLIT.METHOD.PARAMETERS (PARM.LIST.STRING, PARAMETER.MODE)
    
            IF PARAMETER.ERROR <> "" THEN

                METHOD = THIS.METHOD.NAME
                SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
                OBJECT.ERROR.DESC = PARAMETER.ERROR
                OBJECT.ERROR.LINE = PTR
                SHOW.REFERENCE = @FALSE

                GOSUB PRINT.OBJECT.ERROR

            END

        END

    END

* some of the parameters may have parenthesis in them (ie, arrays or
* optional keywords) so this field statement keeps this in mind
    PARM.LIST = LOWER(SPLIT.METHOD.PARAMETERS (PARM.LIST.STRING, "LIST"))
    PARM.BYREF.LIST = ""
    PARM.SPECIAL.LIST = ""
    PARM.COUNT = DCOUNT(PARM.LIST, @VM)

* if there are any optional parameters pull out the default values
* and save them in the default value table.  if there are any "BYVAL"
* or "BYREF" keywords remove them from the parameter and save the
* parameter in the parameter list
    DEFAULT.LIST = ""
    DEFAULT.SET.LIST = ""
    OPTIONAL.LIST = ""

    FOR PARM.LOOP = 1 TO PARM.COUNT

        THIS.PARM = PARM.LIST<1, PARM.LOOP>
        FIRST.PARM.WORD = THIS.PARM [" ", 1, 1]
        THIS.PARM.OPTIONAL = @FALSE

        IF FIRST.PARM.WORD = OPTIONAL.KEYWORD THEN

            THIS.PARM.OPTIONAL = @TRUE

* if this parameter expression has an "=" sign in it then it's setting
* a default.  if it has an "==" sign then it's setting a default and the
* default variable should be set to whatever the result is.

* if we see the "==" sign then set the default.set.list flag and change
* the parameter to a normal "=" sign so that later code can process it
            IF INDEX(THIS.PARM, "==", 1) > 0 THEN
                DEFAULT.SET.LIST<1, PARM.LOOP> = 1
                THIS.PARM = CHANGE(THIS.PARM, "==", "=")
            END

* remove the "optional" keyword from the parameter
            THIS.PARM = TRIM(THIS.PARM [" ", 2, TO.THE.END], " ", "B")

* get the default value from the parameter
            THIS.DEFAULT = TRIM(THIS.PARM ["=", 2, TO.THE.END], " ", "B")

* remove default value from parameter
            THIS.PARM = TRIM(THIS.PARM ["=", 1, 1], " ", "B")

            DEFAULT.LIST<1, PARM.LOOP> = THIS.DEFAULT

        END

* if there's "BYVAL" modifier before the variable name remove it from the
* parameter list.  everything is normally byval anyway but we're allowing
* the keyword for the sake of being complete

* all calls in universe default to byref.  if there's no "byval" or
* "byref" we'll consider it "byref"
        FIRST.PARM.WORD = THIS.PARM [" ", 1, 1]

        BEGIN CASE

* this variable is passed byval
            CASE FIRST.PARM.WORD = BYVAL.KEYWORD
                THIS.PARM = THIS.PARM [" ", 2, TO.THE.END]
                THIS.PARM.BYREF = @FALSE
                THIS.PARM.SPECIAL = @FALSE

* this variable is passed byval special
            CASE FIRST.PARM.WORD = BYVAL.SPECIAL.KEYWORD
                THIS.PARM = THIS.PARM [" ", 2, TO.THE.END]
                THIS.PARM.BYREF = @FALSE
                THIS.PARM.SPECIAL = @TRUE

* any variables that aren't passed byval they're passed byref by default.
* so, the byref isn't necessary but we'll clean it out just in case anyone
* tries to use it
            CASE FIRST.PARM.WORD = BYREF.KEYWORD
                THIS.PARM = THIS.PARM [" ", 2, TO.THE.END]
                THIS.PARM.BYREF = @TRUE
                THIS.PARM.SPECIAL = @FALSE

* for anything else pass it byref as a default
            CASE 1
                THIS.PARM.BYREF = @TRUE
                THIS.PARM.SPECIAL = @FALSE

        END CASE

        PARM.LIST<1, PARM.LOOP> = TRIM(THIS.PARM, " ", "B")

        OPTIONAL.LIST<1, PARM.LOOP> = THIS.PARM.OPTIONAL

        PARM.BYREF.LIST<1, PARM.LOOP> = THIS.PARM.BYREF
        PARM.SPECIAL.LIST<1, PARM.LOOP> = THIS.PARM.SPECIAL

    NEXT PARM.LOOP

* if this method is already in the method table we have the same method
* defined twice.  kick out a warning
    LOCATE THIS.METHOD.NAME IN METHOD.LIST SETTING DUPLICATE.PTR THEN
        OBJECT.WARNING.DESC = "Method ":'"':THIS.METHOD.NAME:'"':" is defined more than once"
        OBJECT.WARNING.LINE = PTR
        GOSUB PRINT.OBJECT.WARNING
    END

* add to table.  if this method isn't inside a section use "NONE"
* for the section name
    METHOD.COUNT += 1

    METHOD.LIST<METHOD.COUNT> = THIS.METHOD.NAME
    METHOD.TYPE.LIST<METHOD.COUNT> = THIS.METHOD.TYPE
    METHOD.LOCAL.LIST<METHOD.COUNT> = THIS.LOCAL

    IF THIS.SECTION.NAME = "" THEN
        METHOD.SECTION.LIST<METHOD.COUNT> = "NONE"
    END ELSE
        METHOD.SECTION.LIST<METHOD.COUNT> = THIS.SECTION.NAME
    END

* update the method parameter table
    METHOD.PARM.LIST<METHOD.COUNT> = PARM.LIST
    METHOD.PARM.COUNT.LIST<METHOD.COUNT> = PARM.COUNT

    METHOD.PARM.OPTIONAL.LIST<METHOD.COUNT> = OPTIONAL.LIST
    METHOD.PARM.DEFAULT.LIST<METHOD.COUNT> = DEFAULT.LIST
    METHOD.PARM.SET.LIST<METHOD.COUNT> = DEFAULT.SET.LIST

    METHOD.PARM.BYREF.LIST<METHOD.COUNT> = PARM.BYREF.LIST
    METHOD.PARM.SPECIAL.LIST<METHOD.COUNT> = PARM.SPECIAL.LIST

    METHOD.START.LINE<METHOD.COUNT> = PTR + 1

* update the wrapper table if there is a wrapper name
    IF THIS.WRAPPER.NAME <> "" THEN

        METHOD.WRAPPER.LIST<METHOD.COUNT> = THIS.WRAPPER.NAME
        METHOD.WRAPPER.PARM.LIST<METHOD.COUNT> = PARM.LIST
        METHOD.WRAPPER.PARM.COUNT.LIST<METHOD.COUNT> = PARM.COUNT

        METHOD.WRAPPER.OPTIONAL.LIST<METHOD.COUNT> = OPTIONAL.LIST
        METHOD.WRAPPER.DEFAULT.LIST<METHOD.COUNT> = DEFAULT.LIST

        METHOD.WRAPPER.BYREF.LIST<METHOD.COUNT> = PARM.BYREF.LIST
        METHOD.WRAPPER.SPECIAL.LIST<METHOD.COUNT> = PARM.SPECIAL.LIST

    END

* set the "end" line of the previous method method to the line before
* this one
    IF METHOD.COUNT > 1 THEN
        IF METHOD.END.LINE<METHOD.COUNT - 1> = "" THEN
            METHOD.END.LINE<METHOD.COUNT - 1> = PTR - 1
        END
    END

    METHOD.INHERIT.LIST<METHOD.COUNT> = THIS.INHERITED

    IF THIS.INHERITED THEN

        METHOD.INHERIT.OBJECT.LIST<METHOD.COUNT> = INHERITED.CHILD.NAME
        METHOD.INHERIT.HANDLE.LIST<METHOD.COUNT> = INHERITED.CHILD
        METHOD.INHERIT.METHOD.LIST<METHOD.COUNT> = INHERITED.METHOD
        METHOD.INHERIT.DEFINITION.LIST<METHOD.COUNT> = INHERITED.DEFINITION

        METHOD.START.LINE<METHOD.COUNT> = INHERITED.START.PTR + INHERITED.DEFINITION.LINES
        METHOD.PROGRAM.START.LINE<METHOD.COUNT> = INHERITED.PROGRAM.START.PTR
        METHOD.END.LINE<METHOD.COUNT> = INHERITED.END.PTR

    END

    RETURN

ADD.INHERITED.OBJECT: ****************************************************
* set the "last" inherited object so that the next "inherited" statement *
* will use this object if the next "inherited" statement doesn't         *
* specify an object.  this inherited object name line will look like     *
* this:                                                                  *
*                                                                        *
*     INHERIT child.name                         subsequent statements   *
*                                                inherit from child.name *                    
*                                                                        *
**************************************************************************

* extract the child object name from the statement
    INHERITED.CHILD = TRIM(THIS.LINE [" ", 2, 1])

* set the "last" inherit object to this one
    LAST.INHERIT.OBJECT = INHERITED.CHILD

* the add.method subroutine adjusts the last line for the previous method
* added.  "inherit" statements, however, will not call add.method.  adjust
* the previous method now to make sure the method doesn't include the
* "inherit" statement in its code
    IF METHOD.COUNT > 0 THEN
        IF METHOD.END.LINE<METHOD.COUNT> = "" THEN
            METHOD.END.LINE<METHOD.COUNT> = PTR - 1
        END
    END
    
    RETURN

ADD.INHERITED.METHOD: ****************************************************
* add an inherited method given the inherited method definition in       *
* this.line.  inherited method definitions look like this:               *
*                                                                        *
*     INHERIT child.name                         subsequent statements   *
*                                                inherit from child.name *                    
*                                                                        *
*     INHERITED method.name = child.name::child.method                   *
*     INHERITED method.name = child.name         reuses method.name      *
*     INHERITED method.name = ::child.method     reuses last child.name  *
*     INHERITED method.name = ::                 reuses both             *
*     INHERITED method.name                      reuses both             *
*                                                                        *
**************************************************************************

* extract the method name, child object and child method name
    THIS.METHOD.NAME = THIS.LINE [" ", 2, 1] ["=", 1, 1]

* if this line has no equals sign and we have a last.inherit.object set
* the line to default to the last.inherit.object and copy the method name.
    IF COUNT(THIS.LINE, "=") = 0 THEN

        IF LAST.INHERIT.OBJECT = "" THEN

            METHOD = THIS.METHOD.NAME
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = "No previous ":INHERIT.KEYWORD:" or "
            OBJECT.ERROR.DESC := INHERIT.FROM.KEYWORD:" line to provide default child object"
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

        THIS.LINE := " = ":METHOD.DELIMITER

    END

* this line should have one equals sign in it
    IF COUNT(THIS.LINE, "=") <> 1 THEN

        METHOD = THIS.METHOD.NAME
        SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
        OBJECT.ERROR.DESC = "Inherited definitions must have one equals sign"
        OBJECT.ERROR.LINE = PTR
        SHOW.REFERENCE = @FALSE

        GOSUB PRINT.OBJECT.ERROR

        RETURN

    END

* extract the inherited references
    INHERITED.REFERENCE = TRIM(THIS.LINE ["=", 2, 1000])
    DELIMITED.PTR = INDEX(INHERITED.REFERENCE, METHOD.DELIMITER, 1)
    IF DELIMITED.PTR = 0 THEN
        DELIMITED.PTR = LEN(INHERITED.REFERENCE) + 1
    END

    INHERITED.CHILD = INHERITED.REFERENCE [1, DELIMITED.PTR - 1]
    INHERITED.METHOD = INHERITED.REFERENCE [DELIMITED.PTR + METHOD.DEL.LENGTH, 10000]

* if the inherited child and/or method are null use default values from
* the last inherit statement.  if we don't have any default values kick back
* an object error
    IF INHERITED.CHILD = "" THEN

        IF LAST.INHERIT.OBJECT = "" THEN

            METHOD = THIS.METHOD.NAME
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = "No previous ":INHERIT.KEYWORD:" or "
            OBJECT.ERROR.DESC := INHERIT.FROM.KEYWORD:" line to provide default child object"
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

        INHERITED.CHILD = LAST.INHERIT.OBJECT

    END

* set the "last" inherit object to this one.  if the next inherit statement
* has no object name it will use the one from this statement
    LAST.INHERIT.OBJECT = INHERITED.CHILD

* if no method was specified after the inherited object we'll use the same
* method name from the inherit statement
    IF INHERITED.METHOD = "" THEN
        INHERITED.METHOD = THIS.METHOD.NAME
    END

* make sure the inherited method we're calling exists in the inherited
* object
    BEGIN CASE
        CASE NOT(COMPILE.OBJECT)
            USE.HANDLE.LIST = @TRUE
        CASE 1
            USE.HANDLE.LIST = @FALSE
    END CASE
    GOSUB FIND.INHERITED.CODE

    IF NOT(INHERITED.METHOD.FOUND) THEN
        RETURN
    END

* build the method definition for the inherited method    
    GOSUB GET.INHERITED.METHOD.DEFINITION

* set this.line to the inherited definition as if the inherited definition
* was a line in this object and add the method to the method list
    ADD.INHERITED.DEFINITION = INHERITED.DEFINITION [" ", 3, TO.THE.END]

* if this inherited definition has parameters it will start with an open
* parenthesis.  then we can add the inherited definition to the method name.
* if not then the inherited definition has no parameters and we'll need to add
* a colon to end the created method definition
    IF ADD.INHERITED.DEFINITION [1, 1] = "(" THEN
        THIS.LINE = METHOD.KEYWORD:" ":THIS.METHOD.NAME:" ":ADD.INHERITED.DEFINITION
    END ELSE
        THIS.LINE = METHOD.KEYWORD:" ":THIS.METHOD.NAME:":"
    END

    GOSUB ADD.METHOD

    RETURN

ADD.SECTION: *************************************************************
* add a section given the section definition in this.line                *
**************************************************************************

* section definition also ends with a colon
    SECTION.DEF = THIS.LINE [":", 1, 1] [" ", 2, TO.THE.END]
    THIS.SECTION.NAME = SECTION.DEF

* set the "end" line of the method before this section name
    IF METHOD.COUNT >= 1 THEN
        IF METHOD.END.LINE<METHOD.COUNT> = "" THEN
            METHOD.END.LINE<METHOD.COUNT> = PTR - 1
        END
    END

    RETURN

CHECK.METHOD.PARAMETERS: *************************************************
* check the parameters of each method and make sure that none of them    *
* are properties or eclipse common variables                             *
**************************************************************************
    SAVE.SHOW.PROPERTY.PARAMETERS = SHOW.PROPERTY.PARAMETERS
    SHOW.PROPERTY.PARAMETERS = @FALSE

    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<METHOD.LOOP>
        THIS.METHOD.LINE = METHOD.START.LINE<METHOD.LOOP> - 1
        THIS.PARM.LIST = RAISE(METHOD.PARM.LIST<METHOD.LOOP>)
        THIS.PARM.COUNT = METHOD.PARM.COUNT.LIST<METHOD.LOOP>
        
        FOR PARM.LOOP = 1 TO THIS.PARM.COUNT

            CHECK.VARIABLE = THIS.PARM.LIST<PARM.LOOP>
            GOSUB CHECK.PROPERTY.PARAMETER

            IF VARIABLE.IS.PROPERTY THEN
                OBJECT.WARNING.DESC = 'Method parameter "':CHECK.VARIABLE:"' in method ":THIS.METHOD
                OBJECT.WARNING.DESC := " is a property or Eclipse common variable!"
                OBJECT.WARNING.LINE = THIS.METHOD.LINE
                METHOD = THIS.METHOD
                GOSUB PRINT.OBJECT.WARNING                    
            END

        NEXT PARM.LOOP

    NEXT METHOD.LOOP

    SHOW.PROPERTY.PARAMETERS = SAVE.SHOW.PROPERTY.PARAMETERS

    RETURN

CHECK.OBJECT.LISTS: ******************************************************
* check the method, property, constant and child object lists to make    *
* sure we don't have the same name in more than one list                 *
**************************************************************************

* test the method list against the property, constant and child lists
    CHECK.NAME.LIST = METHOD.LIST
    CHECK.NAME.COUNT = METHOD.COUNT
    CHECK.LINE.LIST = METHOD.START.LINE
    CHECK.DESCRIPTION = "method"

    AGAINST.NAME.LIST = PROP.NAME.LIST
    AGAINST.DESCRIPTION = "property"
    AGAINST.LINE.LIST = PROP.LINE.LIST
    GOSUB CHECK.LIST

    AGAINST.NAME.LIST = CONSTANT.NAME.LIST
    AGAINST.DESCRIPTION = "constant"
    AGAINST.LINE.LIST = CONSTANT.LINE.LIST
    GOSUB CHECK.LIST

    AGAINST.NAME.LIST = CHILD.NAME.LIST
    AGAINST.DESCRIPTION = "child object"
    AGAINST.LINE.LIST = CHILD.LINE.LIST
    GOSUB CHECK.LIST

* test the property name list against the constant and child lists
    CHECK.NAME.LIST = PROP.NAME.LIST
    CHECK.NAME.COUNT = PROP.COUNT
    CHECK.LINE.LIST = PROP.LINE.LIST
    CHECK.DESCRIPTION = "property"

    AGAINST.NAME.LIST = CONSTANT.NAME.LIST
    AGAINST.DESCRIPTION = "constant"
    AGAINST.LINE.LIST = CONSTANT.LINE.LIST
    GOSUB CHECK.LIST

    AGAINST.NAME.LIST = CHILD.NAME.LIST
    AGAINST.DESCRIPTION = "child object"
    AGAINST.LINE.LIST = CHILD.LINE.LIST
    GOSUB CHECK.LIST

* test the constant name list against the child list
    CHECK.NAME.LIST = CONSTANT.NAME.LIST
    CHECK.NAME.COUNT = CONSTANT.COUNT
    CHECK.LINE.LIST = CONSTANT.LINE.LIST
    CHECK.DESCRIPTION = "constant"

    AGAINST.NAME.LIST = CHILD.NAME.LIST
    AGAINST.DESCRIPTION = "child object"
    AGAINST.LINE.LIST = CHILD.LINE.LIST
    GOSUB CHECK.LIST

    RETURN

CHECK.LIST: **************************************************************
* check check.name.list against against.name.list.  if the same name     *
* exists in both lists print a warning                                   *
**************************************************************************

* throw an error for any names in check.name.list that appear in
* against.name.list
    FOR CHECK.LOOP = 1 TO CHECK.NAME.COUNT

        CHECK.NAME = CHECK.NAME.LIST<CHECK.LOOP>

        LOCATE CHECK.NAME IN AGAINST.NAME.LIST SETTING CHECK.PTR THEN

            OBJECT.ERROR.DESC = '"':CHECK.NAME:'"':" is used as both a "
            OBJECT.ERROR.DESC := CHECK.DESCRIPTION:" and ":AGAINST.DESCRIPTION
            OBJECT.ERROR.DESC := ".  Rename one."

            OBJECT.ERROR.LINE = CHECK.LINE.LIST<CHECK.LOOP>
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

        END

    NEXT CHECK.LOOP

* also throw an error for any duplicate names in check.list
    FOR CHECK.LOOP = 1 TO CHECK.NAME.COUNT - 1

        CHECK.NAME = CHECK.NAME.LIST<CHECK.LOOP>

        LOCATE CHECK.NAME IN CHECK.NAME.LIST, CHECK.LOOP + 1 SETTING CHECK.PTR THEN

            OBJECT.ERROR.DESC = 'Duplicate ':CHECK.DESCRIPTION:' "':CHECK.NAME:'"'

            OBJECT.ERROR.LINE = AGAINST.LINE.LIST<CHECK.LOOP>
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

        END


    NEXT CHECK.LOOP

    RETURN

PRINT.METHOD.LIST: *******************************************************
* print a list of methods for debugging                                  *
**************************************************************************
    PRINT
    PRINT "Method.............. Type...... Local Parameters.................... ":
    PRINT "ParameterDefault.............. Copy StartLne EndLine. FrstPgm."

    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        PRINT METHOD.LIST<METHOD.LOOP> "L#20":" ":
        PRINT METHOD.TYPE.LIST<METHOD.LOOP> "L#10":" ":
        PRINT METHOD.LOCAL.LIST<METHOD.TYPE> "L#5":" ":
        PRINT METHOD.PARM.LIST<METHOD.LOOP ,1> "L#30":" ":
        PRINT METHOD.PARM.DEFAULT.LIST<METHOD.LOOP ,1> "L#30":" ":
        PRINT METHOD.PARM.SET.LIST<METHOD.LOOP ,1> "L#4":" ":
        PRINT METHOD.START.LINE<METHOD.LOOP> "R#8":" ":
        PRINT METHOD.END.LINE<METHOD.LOOP> "R#8":" ":
        PRINT METHOD.PROGRAM.START.LINE<METHOD.LOOP> "R#8"

        THIS.PROP.COUNT = DCOUNT(METHOD.PARM.LIST<METHOD.LOOP>,@VM)
        FOR PROP.LOOP = 2 TO THIS.PROP.COUNT
            PRINT SPACE(20):" ":METHOD.PARM.LIST<METHOD.LOOP,PROP.LOOP> "L#30":" ":
            PRINT METHOD.PARM.DEFAULT.LIST<METHOD.LOOP,PROP.LOOP> "L#30":" ":
            PRINT METHOD.PARM.SET.LIST<METHOD.LOOP,PROP.LOOP> "L#4"
        NEXT PROP.LOOP

    NEXT METHOD.LOOP

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / inherited methods              **
**************************************************************************
**************************************************************************

GET.INHERITED.METHOD.DEFINITION: *****************************************
* after calling find.inherited.code return inherited.definition with     *
* the method definition line for the inherited method                    *
**************************************************************************
    INHERITED.DEFINITION.LINES = 1
    INHERITED.DEFINITION = TRIM(CALLED.INHERIT.CODE<INHERITED.START.PTR>, " ", "T")

* if the definition line ends with a comma, semi-colon or underscore then
* the line wraps to the next
    WRAPPED.PTR = INHERITED.START.PTR

    LOOP
        LAST.CHAR = INHERITED.DEFINITION [1]
    UNTIL LAST.CHAR <> "," AND LAST.CHAR <> ";" AND LAST.CHAR <> "_"
        WRAPPED.PTR += 1
        INHERITED.DEFINITION.LINES += 1
        NEXT.LINE = TRIM(CALLED.INHERIT.CODE<WRAPPED.PTR>, " ", "B")
        INHERITED.DEFINITION := " ":NEXT.LINE
    REPEAT 

    RETURN

FIND.INHERITED.CODE: *****************************************************
* given inherited.child and inherited.method return                      *
* inherited.method.found, inherited.source.name,                         *
* inherited.start.ptr, inherited.end.ptr                                 * 
*                                                                        *
* use.create.child.list must be defined.  see find.inherited.method for  *
* details                                                                *
**************************************************************************
    INHERITED.METHOD.FOUND = @FALSE

    INHERITED.SOURCE.NAME = ""
    INHERITED.DEFINITION.LINES = 0
    INHERITED.START.PTR = 0
    INHERITED.PROGRAM.START.PTR = 0
    INHERITED.END.PTR = 0

* find the starting line of the method referenced by the inherit line
    GOSUB FIND.INHERITED.METHOD
    IF NOT(INHERITED.METHOD.FOUND) THEN
        RETURN
    END

* find the start of the code and the last line of the method referenced by
* the inherit line.  CALLED.INHERIT.CODE will be returned from find.inherited.method
    NEXT.METHOD.FOUND = @FALSE
    HIT.FIRST.COMMENT = @FALSE
    IN.METHOD.DEFINITION = @TRUE
    INHERITED.DEFINITION.LINES = 1

    FOR CALLED.PTR = INHERITED.START.PTR + 1 TO CALLED.INHERIT.CODE.COUNT UNTIL NEXT.METHOD.FOUND

* if we're still in the method definition see if this line wraps to the next.
* if it doesn't then we aren't in the method definition any more
        IF IN.METHOD.DEFINITION THEN
            LAST.CHAR = TRIM(CALLED.LINE) [1]
            IF LAST.CHAR <> "_" AND LAST.CHAR <> "," AND LAST.CHAR <> ";" THEN
                IN.METHOD.DEFINITION = @FALSE
            END ELSE
                INHERITED.DEFINITION.LINES += 1
            END
        END

        REMOVE CALLED.LINE FROM CALLED.INHERIT.CODE SETTING THROWAWAY
        CALLED.LINE = TRIM(CALLED.LINE)
        FIRST.WORD = CALLED.LINE [" ", 1, 1]
        FIRST.CHAR = FIRST.WORD [1, 1]

* set things based on the first word in this program line
        BEGIN CASE

* we're still in the method definition.  keep looking
            CASE IN.METHOD.DEFINITION
                NULL

* first word is null.  ignore
            CASE FIRST.WORD = ""
                NULL

* this is a comment line and it's the first comment line we've hit
            CASE (FIRST.CHAR = "*" OR FIRST.CHAR = "!") AND NOT(HIT.FIRST.COMMENT)
                HIT.FIRST.COMMENT = @TRUE

* this is a comment line after the first one
            CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
                NULL

* first word is something else.  see if it's starting a new method.  if 
* so then the previous line is the end of the method we're scanning.
* if we haven't already found the start of program text in this method
* and we've already hit at least one comment then this line is the first
* program line
            CASE 1

                IF INHERITED.PROGRAM.START.PTR = 0 AND HIT.FIRST.COMMENT THEN
                    INHERITED.PROGRAM.START.PTR = CALLED.PTR
                END

                DECODE.KEYWORD = FIRST.WORD
                GOSUB DECODE.METHOD

                IF IS.METHOD THEN
                    INHERITED.END.PTR = CALLED.PTR - 1
                    NEXT.METHOD.FOUND = @TRUE
                END

        END CASE

    NEXT CALLED.PTR

    IF NOT(NEXT.METHOD.FOUND) THEN
        INHERITED.END.PTR = CALLED.INHERIT.CODE.COUNT
    END

* if the end ptr points to a blank line skip backwards until we find a
* line that's not blank
    LOOP
        LAST.LINE = TRIM(CALLED.INHERIT.CODE<INHERITED.END.PTR>)
    UNTIL LAST.LINE <> "" OR INHERITED.END.PTR = INHERITED.START.PTR
        INHERITED.END.PTR -= 1
    REPEAT

    RETURN

FIND.INHERITED.METHOD: ***************************************************
* given inherited.child and inherited.method find the object and         *
* starting line number for the inherited.method.  if the inherited       *
* method is another INHERIT definition skip to this inherited.object     *
* and keep looking until a proper method call is found.                  *
*                                                                        *
* inherited.child is a child handle and needs to be converted into an    *
* object name.  if use.create.child.list is true inherited.child will    *
* be converted through create.child.handle.list, created with child      *
* objects of the current object being scanned.  if false inherited.child *
* will be converted through child.handle.list, created from the          *
* current object being compiled                                          *
**************************************************************************
    INHERITED.METHOD.FOUND = @FALSE
    INHERITED.START.PTR = 0
    INHERITED.PROGRAM.START.PTR = 0
    INHERITED.END.PTR = 0
    INHERITED.CHILD.NAME = ""

* in case the calling program wants to know where the inherited chaining
* started.  the child / method we're pointing to may also be inherited.
* if so we'll keep digging until we hit the bottom and find a non-inherited
* method.  inherited.child and inherited.method will return with the child
* and method where the non-inherited code exists

* we'll also use this for any errors we find
    ORIGINAL.INHERITED.OBJECT = INHERITED.CHILD
    ORIGINAL.INHERITED.METHOD = INHERITED.METHOD

* the inherited statement will point to a method of a child object.  the
* target method could be a method in that object (easy) or it may also be
* an inherited method in the child object (harder).  if it's the latter
* case we need to follow the inherited method path until we get to a 
* non-inherited method so we can get the right parameter list

* this inherited-to-inherited chain can (possibly) be set up in a loop
* by accident.  to detect this we'll set a maximum number of links we'll
* follow before giving up
    MAX.INHERITED.SEARCH.DEPTH = 20
    INHERITED.SEARCH.DEPTH = 0

* if we're using the handle list we need to build the handle to the inherited
* handle as we descend through multiple chained inherited statements
    IF USE.HANDLE.LIST THEN
        INHERITED.HANDLE = THIS.HANDLE
    END

    LOOP UNTIL 0 

* find the object name for the inherited child handle
        INHERITED.CHILD.NAME = ""

        BEGIN CASE

* if we're scanning the child of a child (or deeper) first find the object
* name of the child object we're checking.  if we're looking in the handle
* list (of created objects, not the table of child objects) and we're compiling
* an object we'll need to prefix the handle with the parent object handle before
* looking for it in the created object table 
            CASE USE.HANDLE.LIST

                INHERITED.HANDLE := METHOD.DELIMITER:INHERITED.CHILD

*               IF COMPILE.OBJECT THEN
*                   INHERITED.HANDLE = THIS.HANDLE:METHOD.DELIMITER:INHERITED.CHILD
*               END ELSE
*                   INHERITED.HANDLE = INHERITED.CHILD
*               END

                LOCATE INHERITED.HANDLE IN CREATE.HANDLE.LIST SETTING CHILD.PTR THEN
                    INHERITED.CHILD.NAME = CREATE.OBJECT.LIST<CHILD.PTR>
                END

* if we're scanning the code of a child we look in the child.handle.list to find the
* inherited child name.  these child tables are only populated if we're compiling an
* object
            CASE 1

                LOCATE INHERITED.CHILD IN CHILD.HANDLE.LIST SETTING CHILD.PTR THEN
                    INHERITED.CHILD.NAME = CHILD.NAME.LIST<CHILD.PTR>
                END

        END CASE

* if we couldn't convert the child handle kick back an error
        IF INHERITED.CHILD.NAME = "" THEN

            METHOD = THIS.METHOD.NAME
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = 'Inherited child "':INHERITED.CHILD:'" does not exist in '
            OBJECT.ERROR.DESC := INHERITED.CHILD.NAME
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

        CALLED.LAST.INHERIT.OBJECT = ""
        FOUND.NESTED.INHERIT = @FALSE

* fetch the code from the called object
        READ CALLED.INHERIT.CODE FROM OBJFILE, INHERITED.CHILD.NAME ELSE

            METHOD = THIS.METHOD.NAME
            SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = 'Inherited object "':INHERITED.CHILD.NAME:'" does not exist'
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

* if we're upcasing code just upcase the entire record.  we're only
* searching for child objects so it doesn't matter if we upcase code
* in quotes
        IF UPCASE.CODE THEN
            CALLED.INHERIT.CODE = UPCASE(CALLED.INHERIT.CODE)
        END

* search through CALLED.INHERIT.CODE for a method statement for inherited.method
        CALLED.INHERIT.CODE.COUNT = DCOUNT(CALLED.INHERIT.CODE, @AM)

        FOR CALLED.PTR = 1 TO CALLED.INHERIT.CODE.COUNT UNTIL FOUND.NESTED.INHERIT

            REMOVE CALLED.LINE FROM CALLED.INHERIT.CODE SETTING THROWAWAY
            CALLED.LINE = TRIM(CALLED.LINE)
            FIRST.WORD = CALLED.LINE [" ", 1, 1]

* the first word is the method keyword.  get the method name.  if it
* matches inherited.method we found the target of the inherited method
* statement
            IF FIRST.WORD = METHOD.KEYWORD THEN

                CALLED.METHOD.NAME = CALLED.LINE [" ", 2, 10000] [",", 1, 1] ["(", 1, 1] [":", 1, 1]
                CALLED.METHOD.NAME = TRIM(CALLED.METHOD.NAME)

                IF CALLED.METHOD.NAME = INHERITED.METHOD THEN

                    INHERITED.START.PTR = CALLED.PTR
                    INHERITED.METHOD.FOUND = @TRUE

                    RETURN

                END

            END

* the first word is an inherited keyword.  get the method name.  if it 
* matches inherited method we found the reference but it's an inherited
* reference.  load inherited.child and inherited.method with the reference
* from the inherited statement and look in that object
            IF FIRST.WORD = INHERIT.KEYWORD THEN

* extract the method name, child object and child method name
                CALLED.METHOD.NAME = THIS.LINE [" ", 2, 1] ["=", 1, 1]

* extract the inherited references
                INHERITED.REFERENCE = TRIM(THIS.LINE ["=", 2, 1000])
                DELIMITER.PTR = INDEX(INHERITED.REFERENCE, METHOD.DELIMITER, 1)
                IF DELIMITED.PTR = 0 THEN
                    DELIMITED.PTR = LEN(INHERITED.REFERENCE) + 1
                END

                CALLED.INHERITED.CHILD = INHERITED.REFERENCE [1, DELIMITED.PTR - 1]
                CALLED.INHERITED.METHOD = INHERITED.REFERENCE [DELIMITED.PTR + METHOD.DEL.LENGTH + 1, 10000]

* if the object name in the called inherit statement is null use the
* object name from the last inherited statement
                IF CALLED.INHERITED.CHILD = "" THEN
                    CALLED.INHERITED.CHILD = CALLED.LAST.INHERIT.OBJECT
                END

* if the method name in the called inherit statement is null use the
* method name from the inherited statement
                IF CALLED.INHERITED.METHOD = "" THEN
                    CALLED.INHERITED.METHOD = CALLED.METHOD.NAME
                END

* set the "last" inherited object name to this one.  the next inherited
* statement will use this object name if one is not provided
                CALLED.LAST.INHERIT.OBJECT = CALLED.INHERITED.CHILD

* if the inherited method we're looking for is here load the inherited.child
* and inherited method with the target of this INHERIT statement and keep
* looking
                IF CALLED.METHOD.NAME = INHERITED.METHOD THEN

                    INHERITED.CHILD = CALLED.INHERITED.CHILD
                    INHERITED.METHOD = CALLED.INHERITED.METHOD

                    FOUND.NESTED.INHERIT = @TRUE

                END

            END

        NEXT CALLED.PTR

* if we got through all the code and didn't find a nested inherit statement 
* then we didn't find the inherited method.  show an error and return
        IF NOT(FOUND.NESTED.INHERIT) THEN

            METHOD = ORIGINAL.INHERITED.METHOD
            SUBROUTINE.NAME = ECLIPSE.PREFIX:ORIGINAL.INHERITED.OBJECT:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = 'Could not find target for inherited method "'
            OBJECT.ERROR.DESC := ORIGINAL.INHERITED.OBJECT:METHOD.DELIMITER:ORIGINAL.INHERITED.METHOD
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR
    
            RETURN

        END

* increment the inherited search depth and check it against the maximum
* search depth.  if we've gone over it we probably have a loop
        INHERITED.SEARCH.DEPTH += 1 
        IF INHERITED.SEARCH.DEPTH > MAX.INHERITED.SEARCH.DEPTH THEN

            METHOD = ORIGINAL.INHERITED.METHOD
            SUBROUTINE.NAME = ECLIPSE.PREFIX:ORIGINAL.INHERITED.OBJECT:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = 'Could not find target for inherited method "'
            OBJECT.ERROR.DESC := ORIGINAL.INHERITED.OBJECT:METHOD.DELIMITER:ORIGINAL.INHERITED.METHOD
            OBJECT.ERROR.DESC := " after following ":MAX.INHERITED.SEARCH.DEPTH:" links."
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR
        END

    REPEAT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / build usage tables                       **
**************************************************************************
**************************************************************************

BUILD.OBJECT.USAGE.TABLE: ************************************************
* build a table of all lines that create, name or destroy objects        *
* in program.code                                                        *
**************************************************************************
* syntax:    NEW objectname handle                                       *
*            OLD objectname handle                                       *
*            DESTROY handle                                              *
**************************************************************************
    USAGE.START.DATE = DATE()
    USAGE.START.TIME = TIME()

* if we're compiling an object we may be able to buffer the object-derived
* usage tables to save time.  if "buffer object usage tables" is set and
* we're compiling an object and the compiled object is the same as the
* last one we buffered restore the usage tables from the last saved
* usage tables.  otherwise clear them and we'll refigure everything from
* scratch
    IF BUFFER.OBJECT.USAGE.TABLE AND COMPILE.OBJECT AND OBJECT.NAME = BUFFERED.OBJECT.NAME THEN
        GOSUB RESTORE.USAGE.TABLES
        DO.FRESH.SCAN = @FALSE
    END ELSE
        GOSUB CLEAR.USAGE.TABLES
        DO.FRESH.SCAN = @TRUE
    END

* if we're able to restore buffered tables we don't need to rescan
* all this stuff that went into generating the buffered tables.  if
* we didn't restore a buffered table we need to do this scanning
    IF DO.FRESH.SCAN THEN

* if we're compiling an object add in the child object usage from the
* tables built from the object and save these tables (with only the
* object usage data) in the buffered tables
        IF COMPILE.OBJECT THEN
            START.OBJECT.CHILD.HANDLE.PTR = 1
            END.OBJECT.CHILD.HANDLE.PTR = CHILD.COUNT
            GOSUB ADD.OBJECT.CHILD.USAGE
        END

* if we aren't trying to buffer object usage then scan the current
* subroutine for usage now.  this will present the entire handle
* usage list to the later subroutines.

* if we are buffering object usage we don't want to scan the current
* subroutine yet.  we'll present the later routines with only the
* handle usage list that will be the same for all methods in the
* object so we can reuse this usage table
        IF NOT(BUFFER.OBJECT.USAGE.TABLE) THEN
            GOSUB ADD.NON.CHILD.USAGE
        END

* add usage for child objects
        START.CHILD.HANDLE.PTR = 1
        END.CHILD.HANDLE.PTR = CREATE.CHILD.COUNT
        GOSUB ADD.CHILD.USAGE

* do some clean up for the "destroy" methods
        START.DESTROY.LOOP = 1
        END.DESTROY.LOOP = CREATE.COUNT
        GOSUB UPDATE.DESTROY.METHODS

* add any inline objects
        GOSUB ADD.INLINE.OBJECTS

* build usage for each object handle
        START.USAGE.HANDLE.PTR = 1
        END.USAGE.HANDLE.PTR = HANDLE.COUNT

        GOSUB ADD.USAGE.KEYWORDS
        GOSUB ADD.HANDLE.KEYWORDS

* if we're scanning an object the tables built so far will be the
* same for all methods of the object.  save them in a hold space.
        IF BUFFER.OBJECT.USAGE.TABLE AND COMPILE.OBJECT THEN
            GOSUB SAVE.USAGE.TABLES
        END

    END

* save current count pointers for the different usage lists.
* we'll add the non-child usage and then finish building the other
* tables using these counts as starting pointers
    LAST.CHILD.COUNT = CHILD.COUNT
    LAST.CREATE.CHILD.COUNT = CREATE.CHILD.COUNT
    LAST.CREATE.COUNT = CREATE.COUNT
    LAST.HANDLE.COUNT = HANDLE.COUNT

* if we are buffering the object usage table then we haven't scanned
* the current subroutine yet.  add the current subroutine code's usage
* to the usage tables.  then do the additional updates but only for
* table entries added by the non-child usage
    IF BUFFER.OBJECT.USAGE.TABLE THEN

        GOSUB ADD.NON.CHILD.USAGE

        START.CHILD.HANDLE.PTR = LAST.CREATE.CHILD.COUNT + 1
        END.CHILD.HANDLE.PTR = CREATE.CHILD.COUNT
        GOSUB ADD.CHILD.USAGE

        START.DESTROY.LOOP = LAST.CREATE.COUNT + 1
        END.DESTROY.LOOP = CREATE.COUNT
        GOSUB UPDATE.DESTROY.METHODS

        START.USAGE.HANDLE.PTR = LAST.HANDLE.COUNT + 1
        END.USAGE.HANDLE.PTR = HANDLE.COUNT

        GOSUB ADD.USAGE.KEYWORDS
        GOSUB ADD.HANDLE.KEYWORDS

    END

    IF DETAILS THEN

        GOSUB PRINT.OBJECT.USAGE.TABLE

    END ELSE

* list objects if we're compiling an object-enabled subroutine or if we're
* compiling an object and "list objects only" is turned on
        IF COMPILE.SUBROUTINE OR (COMPILE.OBJECT AND LIST.OBJECTS.ONLY) THEN

            IF NOT(BRIEF) THEN
                GOSUB LIST.CREATED.OBJECTS
            END

        END

    END

    USAGE.END.DATE = DATE()
    USAGE.END.TIME = TIME()
    USAGE.ELAPSED.TIME += TIME.ELAPSED (USAGE.START.DATE, USAGE.START.TIME)

    RETURN

CLEAR.USAGE.TABLES: ******************************************************
* clear all variables used to build the object usage tables              *
**************************************************************************

* this table will have an entry for every NEW, OLD or DESTROY method in
* the code.  the same object handle will probably appear more than once
    CREATE.OBJECT.LIST = ""
    CREATE.HANDLE.LIST = ""
    CREATE.KEYWORD.LIST = ""
    CREATE.CREATED.WITH.LIST = ""

    CREATE.VARIABLE.LIST = ""
    CREATE.DIMENSIONED.LIST = ""
    CREATE.DIM.VAR.LIST = ""

    CREATE.ADDITIONAL.LIST = ""

    CREATE.LOCAL.LIST = ""
    CREATE.DEFINED.LOCAL.LIST = ""

    CREATE.LINE.LIST = ""
    CREATE.TYPE.LIST = ""
    CREATE.WITH.LIST = ""

    CREATE.LABEL.LIST = ""

    CREATE.INDENT.LIST = ""

    CREATE.COUNT = 0

* this table will be build from the object code of objects used by this
* program.  it will be all children of objects used by this program
    CREATE.CHILD.NAME.LIST = ""
    CREATE.CHILD.PARENT.HANDLE.LIST = ""
    CREATE.CHILD.HANDLE.LIST = ""
    CREATE.CHILD.KEYWORD.LIST = ""
    CREATE.CHILD.CREATED.WITH.LIST = ""

    CREATE.CHILD.VARIABLE.LIST = ""
    CREATE.CHILD.DIM.LIST = ""

    CREATE.CHILD.ADDITIONAL.LIST = ""

    CREATE.CHILD.LOCAL.LIST = ""
    CREATE.CHILD.DEFINED.LOCAL.LIST = ""

    CREATE.CHILD.LINE.LIST = ""

    CREATE.CHILD.COMMENT.LIST = ""

    CREATE.CHILD.COUNT = 0

* this table will be built from the above table.  it's keyed by the
* object handle and there will be only one entry for each object handle.
* there may be more than one entry for an object
    HANDLE.LIST = ""
    HANDLE.VARIABLE.LIST = ""
    HANDLE.OBJECT.LIST = ""

    HANDLE.METHOD.LIST = ""
    HANDLE.METHOD.CALLED.LIST = ""

    HANDLE.PARAMETER.LIST = ""
    HANDLE.PARAMETER.BYVAL.LIST = ""
    HANDLE.PARAMETER.SPECIAL.LIST = ""

    HANDLE.OUTPUT.PARAMETER.LIST = ""
    HANDLE.OUTPUT.COUNT.LIST = ""

    HANDLE.KEYWORD.LIST = ""
    HANDLE.TYPE.LIST = ""
    HANDLE.MULTI.THREADED.LIST = ""
    HANDLE.DIMENSIONS.LIST = ""

    HANDLE.COUNT = 0

    GOSUB CLEAR.INLINE.TABLE

    RETURN

SAVE.USAGE.TABLES: *******************************************************
* copy the usage table variables used to build the object usage tables   *
* to holding variables                                                   *
**************************************************************************

* save the current name of the object with the buffered data
    BUFFERED.OBJECT.NAME = OBJECT.NAME

* this table will have an entry for every NEW, OLD or DESTROY method in
* the code.  the same object handle will probably appear more than once
    BUFFER.CREATE.OBJECT.LIST = CREATE.OBJECT.LIST
    BUFFER.CREATE.HANDLE.LIST = CREATE.HANDLE.LIST
    BUFFER.CREATE.VARIABLE.LIST = CREATE.VARIABLE.LIST
    BUFFER.CREATE.KEYWORD.LIST = CREATE.KEYWORD.LIST
    BUFFER.CREATE.CREATED.WITH.LIST = CREATE.CREATED.WITH.LIST

    BUFFER.CREATE.DIMENSIONED.LIST = CREATE.DIMENSIONED.LIST
    BUFFER.CREATE.DIM.VAR.LIST = CREATE.DIM.VAR.LIST

    BUFFER.CREATE.ADDITIONAL.LIST = CREATE.ADDITIONAL.LIST

    BUFFER.CREATE.LOCAL.LIST = CREATE.LOCAL.LIST
    BUFFER.CREATE.DEFINED.LOCAL.LIST = CREATE.DEFINED.LOCAL.LIST

    BUFFER.CREATE.LINE.LIST = CREATE.LINE.LIST
    BUFFER.CREATE.TYPE.LIST = CREATE.TYPE.LIST
    BUFFER.CREATE.WITH.LIST = CREATE.WITH.LIST

    BUFFER.CREATE.LABEL.LIST = CREATE.LABEL.LIST

    BUFFER.CREATE.INDENT.LIST = CREATE.INDENT.LIST

    BUFFER.CREATE.COUNT = CREATE.COUNT

* this table will be build from the object code of objects used by this
* program.  it will be all children of objects used by this program
    BUFFER.CREATE.CHILD.NAME.LIST = CREATE.CHILD.NAME.LIST
    BUFFER.CREATE.CHILD.PARENT.HANDLE.LIST = CREATE.CHILD.PARENT.HANDLE.LIST
    BUFFER.CREATE.CHILD.HANDLE.LIST = CREATE.CHILD.HANDLE.LIST
    BUFFER.CREATE.CHILD.KEYWORD.LIST = CREATE.CHILD.KEYWORD.LIST
    BUFFER.CREATE.CHILD.CREATED.WITH.LIST = CREATE.CHILD.CREATED.WITH.LIST

    BUFFER.CREATE.CHILD.VARIABLE.LIST = CREATE.CHILD.VARIABLE.LIST
    BUFFER.CREATE.CHILD.DIM.LIST = CREATE.CHILD.DIM.LIST

    BUFFER.CREATE.CHILD.ADDITIONAL.LIST = CREATE.CHILD.ADDITIONAL.LIST

    BUFFER.CREATE.CHILD.LOCAL.LIST = CREATE.CHILD.LOCAL.LIST
    BUFFER.CREATE.CHILD.DEFINED.LOCAL.LIST = CREATE.CHILD.DEFINED.LOCAL.LIST

    BUFFER.CREATE.CHILD.LINE.LIST = CREATE.CHILD.LINE.LIST

    BUFFER.CREATE.CHILD.COMMENT.LIST = CREATE.CHILD.COMMENT.LIST

    BUFFER.CREATE.CHILD.COUNT = CREATE.CHILD.COUNT

* this table will be built from the above table.  it's keyed by the
* object handle and there will be only one entry for each object handle.
* there may be more than one entry for an object
    BUFFER.HANDLE.LIST = HANDLE.LIST
    BUFFER.HANDLE.VARIABLE.LIST = HANDLE.VARIABLE.LIST
    BUFFER.HANDLE.OBJECT.LIST = HANDLE.OBJECT.LIST

    BUFFER.HANDLE.METHOD.LIST = HANDLE.METHOD.LIST
    BUFFER.HANDLE.METHOD.CALLED.LIST = HANDLE.METHOD.CALLED.LIST

    BUFFER.HANDLE.PARAMETER.LIST = HANDLE.PARAMETER.LIST
    BUFFER.HANDLE.PARAMETER.BYVAL.LIST = HANDLE.PARAMETER.BYVAL.LIST
    BUFFER.HANDLE.PARAMETER.SPECIAL.LIST = HANDLE.PARAMETER.SPECIAL.LIST    

    BUFFER.HANDLE.OUTPUT.PARAMETER.LIST = HANDLE.OUTPUT.PARAMETER.LIST
    BUFFER.HANDLE.OUTPUT.COUNT.LIST = HANDLE.OUTPUT.COUNT.LIST

    BUFFER.HANDLE.KEYWORD.LIST = HANDLE.KEYWORD.LIST
    BUFFER.HANDLE.TYPE.LIST = HANDLE.TYPE.LIST
    BUFFER.HANDLE.MULTI.THREADED.LIST = HANDLE.MULTI.THREADED.LIST
    BUFFER.HANDLE.DIMENSIONS.LIST = HANDLE.DIMENSIONS.LIST

    BUFFER.HANDLE.COUNT = HANDLE.COUNT

    GOSUB BACKUP.INLINE.TABLE

    RETURN

RESTORE.USAGE.TABLES: ****************************************************
* copy the saved usage table variables to the live usage table           *
* variables                                                              *
**************************************************************************

* this table will have an entry for every NEW, OLD or DESTROY method in
* the code.  the same object handle will probably appear more than once
    CREATE.OBJECT.LIST = BUFFER.CREATE.OBJECT.LIST
    CREATE.HANDLE.LIST = BUFFER.CREATE.HANDLE.LIST
    CREATE.VARIABLE.LIST = BUFFER.CREATE.VARIABLE.LIST
    CREATE.KEYWORD.LIST = BUFFER.CREATE.KEYWORD.LIST
    CREATE.CREATED.WITH.LIST = BUFFER.CREATE.CREATED.WITH.LIST

    CREATE.DIMENSIONED.LIST = BUFFER.CREATE.DIMENSIONED.LIST
    CREATE.DIM.VAR.LIST = BUFFER.CREATE.DIM.VAR.LIST

    CREATE.ADDITIONAL.LIST = BUFFER.CREATE.ADDITIONAL.LIST

    CREATE.LOCAL.LIST = BUFFER.CREATE.LOCAL.LIST
    CREATE.DEFINED.LOCAL.LIST = BUFFER.CREATE.DEFINED.LOCAL.LIST

    CREATE.LINE.LIST = BUFFER.CREATE.LINE.LIST
    CREATE.TYPE.LIST = BUFFER.CREATE.TYPE.LIST
    CREATE.WITH.LIST = BUFFER.CREATE.WITH.LIST

    CREATE.LABEL.LIST = BUFFER.CREATE.LABEL.LIST

    CREATE.INDENT.LIST = BUFFER.CREATE.INDENT.LIST

    CREATE.COUNT = BUFFER.CREATE.COUNT

* this table will be build from the object code of objects used by this
* program.  it will be all children of objects used by this program
    CREATE.CHILD.NAME.LIST = BUFFER.CREATE.CHILD.NAME.LIST
    CREATE.CHILD.PARENT.HANDLE.LIST = BUFFER.CREATE.CHILD.PARENT.HANDLE.LIST
    CREATE.CHILD.HANDLE.LIST = BUFFER.CREATE.CHILD.HANDLE.LIST
    CREATE.CHILD.KEYWORD.LIST = BUFFER.CREATE.CHILD.KEYWORD.LIST
    CREATE.CHILD.CREATED.WITH.LIST = BUFFER.CREATE.CHILD.CREATED.WITH.LIST

    CREATE.CHILD.VARIABLE.LIST = BUFFER.CREATE.CHILD.VARIABLE.LIST
    CREATE.CHILD.DIM.LIST = BUFFER.CREATE.CHILD.DIM.LIST

    CREATE.CHILD.ADDITIONAL.LIST = BUFFER.CREATE.CHILD.ADDITIONAL.LIST

    CREATE.CHILD.LOCAL.LIST = BUFFER.CREATE.CHILD.LOCAL.LIST
    CREATE.CHILD.DEFINED.LOCAL.LIST = BUFFER.CREATE.CHILD.DEFINED.LOCAL.LIST

    CREATE.CHILD.LINE.LIST = BUFFER.CREATE.CHILD.LINE.LIST

    CREATE.CHILD.COMMENT.LIST = BUFFER.CREATE.CHILD.COMMENT.LIST

    CREATE.CHILD.COUNT = BUFFER.CREATE.CHILD.COUNT

* this table will be built from the above table.  it's keyed by the
* object handle and there will be only one entry for each object handle.
* there may be more than one entry for an object
    HANDLE.OBJECT.LIST = BUFFER.HANDLE.OBJECT.LIST
    HANDLE.LIST = BUFFER.HANDLE.LIST
    HANDLE.VARIABLE.LIST = BUFFER.HANDLE.VARIABLE.LIST

    HANDLE.METHOD.LIST = BUFFER.HANDLE.METHOD.LIST
*   HANDLE.METHOD.CALLED.LIST = BUFFER.HANDLE.METHOD.CALLED.LIST
    HANDLE.METHOD.CALLED.LIST = ""

    HANDLE.PARAMETER.LIST = BUFFER.HANDLE.PARAMETER.LIST
    HANDLE.PARAMETER.BYVAL.LIST = BUFFER.HANDLE.PARAMETER.BYVAL.LIST
    HANDLE.PARAMETER.SPECIAL.LIST = BUFFER.HANDLE.PARAMETER.SPECIAL.LIST

    HANDLE.OUTPUT.PARAMETER.LIST = BUFFER.HANDLE.OUTPUT.PARAMETER.LIST
    HANDLE.OUTPUT.COUNT.LIST = BUFFER.HANDLE.OUTPUT.COUNT.LIST

    HANDLE.KEYWORD.LIST = BUFFER.HANDLE.KEYWORD.LIST
    HANDLE.TYPE.LIST = BUFFER.HANDLE.TYPE.LIST
    HANDLE.MULTI.THREADED.LIST = BUFFER.HANDLE.MULTI.THREADED.LIST
    HANDLE.DIMENSIONS.LIST = BUFFER.HANDLE.DIMENSIONS.LIST

    HANDLE.COUNT = BUFFER.HANDLE.COUNT

    GOSUB RESTORE.INLINE.TABLE

    RETURN

ADD.NON.CHILD.USAGE: *****************************************************
* go through the program and look for object creation lines--lines with  *
* a NEW, OLD or DESTROY method in them that indicate an object being     *
* created in "normal" (not a child object) code                          *
**************************************************************************
    SETREM 0 ON PROGRAM.CODE
    FOR PTR = 1 TO PROGRAM.CODE.LINES

* look for object creation, naming or destroy as the first word in the line
*       THIS.LINE = PROGRAM.CODE<PTR>
        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

        GOSUB CHECK.FOR.OBJECT.CREATION

* update usage list if we have a new object
        IF OBJECT.CREATED THEN

* make sure this new object was created properly
            NEW.OBJECT.HANDLE = THIS.OBJECT.HANDLE
            NEW.OBJECT.NAME = THIS.OBJECT.NAME
            GOSUB CHECK.NEW.OBJECT

* update object creation table
            CREATE.COUNT += 1

            CREATE.OBJECT.LIST<CREATE.COUNT> = THIS.OBJECT.NAME
            CREATE.HANDLE.LIST<CREATE.COUNT> = THIS.OBJECT.HANDLE
            CREATE.VARIABLE.LIST<CREATE.COUNT> = THIS.OBJECT.HANDLE
            CREATE.KEYWORD.LIST<CREATE.COUNT> = KEY.WORD
            CREATE.CREATED.WITH.LIST<CREATE.COUNT> = OBJECT.CREATED.WITH

            CREATE.DIMENSIONED.LIST<CREATE.COUNT> = THIS.OBJECT.DIMENSIONED
            CREATE.DIM.VAR.LIST<CREATE.COUNT> = THIS.OBJECT.DIM.VAR

            CREATE.ADDITIONAL.LIST<CREATE.COUNT> = ADDITIONAL.PARAMETERS

            CREATE.TYPE.LIST<CREATE.COUNT> = KEY.WORD
            CREATE.WITH.LIST<CREATE.COUNT> = ""

            CREATE.LABEL.LIST<CREATE.COUNT> = CLEAN.LABEL

            CREATE.INDENT.LIST<CREATE.COUNT> = INDENT.COUNT

            CREATE.LINE.LIST<CREATE.COUNT> = PTR

* check this object for child objects
            SEARCH.SUBCHILDREN = @TRUE
            UPDATE.OBJECT.CREATION.LIST = @TRUE
            ADD.LOCAL.CHILD.OBJECTS = @FALSE
            THIS.CHILD.OBJECT.NAME = THIS.OBJECT.NAME
            THIS.CHILD.OBJECT.HANDLE = THIS.OBJECT.HANDLE

            GOSUB CHECK.FOR.CHILD.OBJECTS

        END

    NEXT PTR

* if we're compiling an object add an entry for local calls
    IF COMPILE.OBJECT THEN

        CREATE.COUNT += 1

        CREATE.OBJECT.LIST<CREATE.COUNT> = OBJECT.NAME
        CREATE.HANDLE.LIST<CREATE.COUNT> = LOCAL.OBJECT.HANDLE
        CREATE.VARIABLE.LIST<CREATE.COUNT> = LOCAL.OBJECT.VARIABLE
        CREATE.KEYWORD.LIST<CREATE.COUNT> = NEW.KEYWORD
        CREATE.CREATED.WITH.LIST<CREATE.COUNT> = NEW.KEYWORD

        CREATE.DIMENSIONED.LIST<CREATE.COUNT> = @FALSE
        CREATE.DIM.VAR.LIST<CREATE.COUNT> = ""

        CREATE.ADDITIONAL.LIST<CREATE.COUNT> = ""

        CREATE.LINE.LIST<CREATE.COUNT> = 0

        CREATE.TYPE.LIST<CREATE.COUNT> = LOCAL.KEYWORD
        CREATE.WITH.LIST<CREATE.COUNT> = ""

        CREATE.LABEL.LIST<CREATE.COUNT> = ""

    END

* for all objects used in this program create another table by unique
* object handle.  the create... table may see an object in more than one
* place.  we need a table with only one entry per object handle
    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        THIS.OBJECT.NAME = CREATE.OBJECT.LIST<CREATE.LOOP>
        THIS.OBJECT.HANDLE = CREATE.HANDLE.LIST<CREATE.LOOP>
        THIS.OBJECT.VARIABLE = CREATE.VARIABLE.LIST<CREATE.LOOP>
        THIS.OBJECT.KEYWORD = CREATE.KEYWORD.LIST<CREATE.LOOP>
        THIS.OBJECT.CREATED.WITH = CREATE.CREATED.WITH.LIST<CREATE.LOOP>

* is this object a multi-threaded object?
        BEGIN CASE
            CASE THIS.OBJECT.KEYWORD = NEW.MULTI.THREAD.KEYWORD
                THIS.OBJECT.MULTI.THREADED = @TRUE
            CASE THIS.OBJECT.KEYWORD = OLD.MULTI.THREAD.KEYWORD
                THIS.OBJECT.MULTI.THREADED = @TRUE
            CASE THIS.OBJECT.CREATED.WITH = NEW.MULTI.THREAD.KEYWORD
                THIS.OBJECT.MULTI.THREADED = @TRUE
            CASE THIS.OBJECT.CREATED.WITH = OLD.MULTI.THREAD.KEYWORD
                THIS.OBJECT.MULTI.THREADED = @TRUE
            CASE 1
                THIS.OBJECT.MULTI.THREADED = @FALSE
        END CASE

        IF THIS.OBJECT.NAME <> "" THEN

            LOCATE THIS.OBJECT.HANDLE IN HANDLE.LIST SETTING HANDLE.PTR ELSE

                HANDLE.COUNT += 1

                HANDLE.LIST<HANDLE.COUNT> = THIS.OBJECT.HANDLE
                HANDLE.OBJECT.LIST<HANDLE.COUNT> = THIS.OBJECT.NAME
                HANDLE.VARIABLE.LIST<HANDLE.COUNT> = THIS.OBJECT.VARIABLE
                HANDLE.KEYWORD.LIST<HANDLE.COUNT> = THIS.OBJECT.KEYWORD
                HANDLE.MULTI.THREADED.LIST<HANDLE.COUNT> = THIS.OBJECT.MULTI.THREADED

            END

        END

    NEXT CREATE.LOOP

    RETURN

ADD.OBJECT.CHILD.USAGE: **************************************************
* for objects if this object has any child objects add their handles     *
* into the unique handle list so that we can set up keywords for calls   *
* to them                                                                *
**************************************************************************
    FOR CHILD.LOOP = START.OBJECT.CHILD.HANDLE.PTR TO END.OBJECT.CHILD.HANDLE.PTR

        THIS.CHILD.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.CHILD.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.CHILD.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.CHILD.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.CHILD.CREATED.WITH = CHILD.CREATED.WITH.LIST<CHILD.LOOP>

        THIS.CHILD.DIM = CHILD.DIM.LIST<CHILD.LOOP>

        THIS.CHILD.ADDITIONAL = CHILD.ADDITIONAL.LIST<CHILD.LOOP>

        THIS.CHILD.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>
        THIS.CHILD.DEFINED.LOCAL = CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

        THIS.CHILD.LINE = CHILD.LINE.LIST<CHILD.LOOP>

        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>

        IF THIS.CHILD.DIM = "" THEN
            THIS.CHILD.DIMENSIONED = @FALSE
        END ELSE
            THIS.CHILD.DIMENSIONED = @TRUE
        END

* do we want to add this child handle to the handle list for object
* calls?
        ADD.CHILD.HANDLE = @TRUE
        BEGIN CASE

            CASE THIS.CHILD.NAME = ""
                ADD.CHILD.HANDLE = @FALSE

* when compiling objects we'll always add level 1 objects (objects defined
* in the object and not child objects of objects defined in the object) even
* if it's declared local
            CASE THIS.CHILD.DEPTH = 1
                NULL

* when compiling objects level 2 objects will be child objects of level
* 1 objects.  these will have this.child.local set if the parent object
* is a local object.  but, if the level 2 object isn't declared "local"
* in its object definition it should still be visible to our object even
* if the level 1 object is "local".  even if the level 1 object is "local"
* it will be visible to the object
            CASE THIS.CHILD.DEPTH = 2
                IF THIS.CHILD.DEFINED.LOCAL THEN
                    ADD.CHILD.HANDLE = @FALSE
                END

* when compiling level 3 or above objects don't include it if it's defined
* local.
            CASE THIS.CHILD.DEFINED.LOCAL
                ADD.CHILD.HANDLE = @FALSE

        END CASE

        IF ADD.CHILD.HANDLE THEN

* dimensioned handles go into the handle table with parenthesis after them.
* if this child handle is dimensioned add the parenthesies
            IF THIS.CHILD.DIM <> "" THEN
                THIS.CHILD.HANDLE := "()"
            END

            LOCATE THIS.CHILD.HANDLE IN HANDLE.LIST SETTING HANDLE.PTR ELSE

                HANDLE.COUNT += 1

* is this object a multi-threaded object?
                BEGIN CASE
                    CASE THIS.CHILD.CREATED.WITH = NEW.MULTI.THREAD.KEYWORD
                        THIS.CHILD.MULTI.THREADED = @TRUE
                    CASE THIS.CHILD.CREATED.WITH = OLD.MULTI.THREAD.KEYWORD
                        THIS.CHILD.MULTI.THREADED = @TRUE
                    CASE 1
                        THIS.CHILD.MULTI.THREADED = @FALSE
                END CASE

                HANDLE.OBJECT.LIST<HANDLE.COUNT> = THIS.CHILD.NAME
                HANDLE.LIST<HANDLE.COUNT> = THIS.CHILD.HANDLE
                HANDLE.VARIABLE.LIST<HANDLE.COUNT> = THIS.CHILD.VARIABLE
                HANDLE.MULTI.THREADED.LIST<HANDLE.COUNT> = THIS.CHILD.MULTI.THREADED
                
            END

* make sure this child object doesn't conflict with any others
            NEW.OBJECT.HANDLE = THIS.CHILD.VARIABLE
            NEW.OBJECT.NAME = THIS.CHILD.NAME
            PTR = ""
            GOSUB CHECK.NEW.OBJECT

* add this child object into the created objects list
            CREATE.COUNT += 1

            CREATE.OBJECT.LIST<CREATE.COUNT> = THIS.CHILD.NAME
            CREATE.HANDLE.LIST<CREATE.COUNT> = THIS.CHILD.HANDLE
            CREATE.VARIABLE.LIST<CREATE.COUNT> = THIS.CHILD.VARIABLE
            CREATE.KEYWORD.LIST<CREATE.COUNT> = THIS.CHILD.KEYWORD
            CREATE.CREATED.WITH.LIST<CREATE.COUNT> = THIS.CHILD.CREATED.WITH

            CREATE.DIMENSIONED.LIST<CREATE.COUNT> = THIS.CHILD.DIMENSIONED
            CREATE.DIM.VAR.LIST<CREATE.COUNT> = THIS.CHILD.DIM

            CREATE.ADDITIONAL.LIST<CREATE.COUNT> = THIS.CHILD.ADDITIONAL

            CREATE.LINE.LIST<CREATE.COUNT> = THIS.CHILD.LINE

            CREATE.TYPE.LIST<CREATE.COUNT> = "CHILD"
            CREATE.WITH.LIST<CREATE.COUNT> = THIS.CHILD.CREATED.WITH

            CREATE.LABEL.LIST<CREATE.COUNT> = ""

        END

    NEXT CHILD.LOOP

    RETURN

ADD.CHILD.USAGE: *********************************************************
* if the objects called have any child objects add them into the unique  *
* handle list as well                                                    *
**************************************************************************
    FOR CHILD.LOOP = START.CHILD.HANDLE.PTR TO END.CHILD.HANDLE.PTR

        THIS.CHILD.HANDLE = CREATE.CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.CHILD.NAME = CREATE.CHILD.NAME.LIST<CHILD.LOOP>
        THIS.CHILD.VARIABLE = THIS.CHILD.HANDLE
        THIS.CHILD.KEYWORD = CREATE.CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.CHILD.CREATED.WITH = CREATE.CHILD.CREATED.WITH.LIST<CHILD.LOOP>

        THIS.CHILD.DIM = CREATE.CHILD.DIM.LIST<CHILD.LOOP>
        THIS.CHILD.DIMENSIONS = DCOUNT(THIS.CHILD.DIM, @VM)

        THIS.CHILD.ADDITIONAL = CREATE.CHILD.ADDITIONAL.LIST

        THIS.CHILD.LOCAL = CREATE.CHILD.LOCAL.LIST<CHILD.LOOP>
        THIS.CHILD.DEFINED.LOCAL = CREATE.CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

        THIS.CHILD.DEPTH = CREATE.CHILD.DEPTH.LIST<CHILD.LOOP>

* do we want to add this child handle to the handle list for object
* calls?
        ADD.CHILD.HANDLE = @TRUE
        BEGIN CASE

            CASE THIS.CHILD.NAME = ""
                ADD.CHILD.HANDLE = @FALSE

* when compiling objects we'll always add level 1 objects (objects defined
* in the object and not child objects of objects defined in the object) even
* if it's declared local
            CASE COMPILE.OBJECT AND THIS.CHILD.DEPTH = 1
                NULL

* when compiling objects level 2 objects will be child objects of level
* 1 objects.  these will have this.child.local set if the parent object
* is a local object.  but, if the level 2 object isn't declared "local"
* in its object definition it should still be visible to our object even
* if the level 1 object is "local".  even if the level 1 object is "local"
* it will be visible to the object
            CASE COMPILE.OBJECT AND THIS.CHILD.DEPTH = 2
                IF THIS.CHILD.DEFINED.LOCAL THEN
                    ADD.CHILD.HANDLE = @FALSE
                END

* if we're compiling an object don't add any child objects deeper than
* 2 if it's declared local in its defining object code
            CASE COMPILE.OBJECT AND THIS.CHILD.DEFINED.LOCAL
                ADD.CHILD.HANDLE = @FALSE

* when compiling object-enabled subroutines only add the child object if it's not
* local to the object
            CASE COMPILE.SUBROUTINE AND THIS.CHILD.DEPTH > 0 AND THIS.CHILD.LOCAL
                ADD.CHILD.HANDLE = @FALSE

        END CASE

        IF ADD.CHILD.HANDLE THEN

            IF THIS.CHILD.DIMENSIONS > 0 THEN
                THIS.CHILD.HANDLE := "()"
            END

            LOCATE THIS.CHILD.HANDLE IN HANDLE.LIST SETTING HANDLE.PTR ELSE

                HANDLE.COUNT += 1

* is this object a multi-threaded object?
                BEGIN CASE
                    CASE THIS.CHILD.KEYWORD = NEW.MULTI.THREAD.KEYWORD
                        THIS.OBJECT.MULTI.THREADED = @TRUE
                    CASE THIS.CHILD.KEYWORD = OLD.MULTI.THREAD.KEYWORD
                        THIS.OBJECT.MULTI.THREADED = @TRUE
                    CASE THIS.CHILD.CREATED.WITH = NEW.MULTI.THREAD.KEYWORD
                        THIS.OBJECT.MULTI.THREADED = @TRUE
                    CASE THIS.CHILD.CREATED.WITH = OLD.MULTI.THREAD.KEYWORD
                        THIS.OBJECT.MULTI.THREADED = @TRUE
                    CASE 1
                        THIS.OBJECT.MULTI.VALUED = @FALSE
                END CASE

                HANDLE.LIST<HANDLE.COUNT> = THIS.CHILD.HANDLE
                HANDLE.OBJECT.LIST<HANDLE.COUNT> = THIS.CHILD.NAME
                HANDLE.VARIABLE.LIST<HANDLE.COUNT> = THIS.CHILD.VARIABLE
                HANDLE.MULTI.THREADED.LIST<HANDLE.COUNT> = THIS.OBJECT.MULTI.THREADED
                
            END

        END

    NEXT CHILD.LOOP

    RETURN

ADD.INLINE.OBJECTS: ******************************************************
* if there are inline references make sure the object exists in the      *
* handle tables.  if it doesn't we won't be able to merge the object's   *
* code so add it                                                         *
**************************************************************************
    FOR INLINE.LOOP = 1 TO INLINE.COUNT

        INLINE.OBJECT = INLINE.OBJECT.LIST<INLINE.LOOP>

* "local" should never be added.  "sub" won't do us any good yet because
* we don't know what subroutines are called yet.  if the object is "ALL",
* meaning add all keywords, skip that as well
        IF INLINE.OBJECT <> LOCAL.KEYWORD AND INLINE.OBJECT <> SUBROUTINE.CALL.KEYWORD THEN

            IF INLINE.OBJECT <> INLINE.ALL.OBJECTS.KEYWORD THEN

                LOCATE INLINE.OBJECT IN HANDLE.OBJECT.LIST SETTING INLINE.PTR ELSE

                    HANDLE.COUNT += 1

* add the inlined object to the list.  it isn't called so the handle and
* handle.variable won't be used.  make up dummy values for the handle and
* handle.variable just so we have someting in there
                    HANDLE.LIST<HANDLE.COUNT> = "INLINE.":INLINE.OBJECT
                    HANDLE.OBJECT.LIST<HANDLE.COUNT> = INLINE.OBJECT
                    HANDLE.VARIABLE.LIST<HANDLE.COUNT> = "INLINE.VAR.":INLINE.OBJECT
                    HANDLE.MULTITHREADED.LIST<HANDLE.COUNT> = @FALSE

                END

            END

        END

    NEXT INLINE.LOOP

    RETURN

UPDATE.DESTROY.METHODS: **************************************************
* lines in the create.object.list with "destroy" methods won't have the  *
* object name in them.  we couldn't determine the object name at the     *
* time we added "destroy"s to the table.  look the name up now and       *
* update the table so that every object handle has an object name        *
**************************************************************************
    FOR CREATE.LOOP = START.DESTROY.LOOP TO END.DESTROY.LOOP

        IF CREATE.OBJECT.LIST<CREATE.LOOP> = "" THEN
            LOCATE CREATE.HANDLE.LIST<CREATE.LOOP> IN HANDLE.LIST SETTING HANDLE.PTR THEN
                CREATE.OBJECT.LIST<CREATE.LOOP> = HANDLE.OBJECT.LIST<HANDLE.PTR>
            END
        END

    NEXT CREATE.LOOP

    RETURN

ADD.USAGE.KEYWORDS: ******************************************************
* for each unique object handle build a list of usage "keywords"--       *
* methods, properties, statics and constants--that may be used with the  *
* method name in the program code.  we'll type each "keyword" reference  *
* so we'll know how to deal with it later.                               *
**************************************************************************
    FOR HANDLE.LOOP = START.USAGE.HANDLE.PTR TO END.USAGE.HANDLE.PTR

* unload the handle and object name from the handle list
        THIS.HANDLE = HANDLE.LIST<HANDLE.LOOP>
        THIS.OBJECT = HANDLE.OBJECT.LIST<HANDLE.LOOP>
        THIS.KEYWORD = HANDLE.KEYWORD.LIST<HANDLE.LOOP>

* have we already scanned this object name?
        ALREADY.SCANNED = @FALSE

        LOCATE THIS.OBJECT IN HANDLE.OBJECT.LIST SETTING SCANNED.PTR THEN
            IF SCANNED.PTR < HANDLE.LOOP THEN
                ALREADY.SCANNED = @TRUE
            END
        END

* if we've already scanned this object name we can use the data from
* the previous scan to build the usage array for this handle.  otherwise
* we'll scan the source code for this object name
        IF NOT(ALREADY.SCANNED) OR ALWAYS.SCAN.OBJECT.SOURCE THEN
            GOSUB SCAN.OBJECT.CODE.FOR.USAGE
        END ELSE
            COPY.TO.PTR = HANDLE.LOOP
            GOSUB BUILD.USAGE.FROM.PREVIOUSLY.SCANNED
        END

    NEXT HANDLE.LOOP

    RETURN

SCAN.OBJECT.CODE.FOR.USAGE: **********************************************
* read and scan object source code for this.object and update the        *
* usage tables for this.handle                                           *
**************************************************************************
    SCAN.START.DATE = DATE()
    SCAN.START.TIME = TIME()

    SCAN.LAST.INHERIT.OBJECT = ""

* fetch the source code for the object name.  it will be in the OBJ file
    READ HANDLE.TEXT FROM OBJFILE, THIS.OBJECT ELSE

        OBJECT.WARNING.DESC = "Can't read ":THIS.OBJECT:" from the OBJ file!"
        OBJECT.WARNING.LINE = ""
        GOSUB PRINT.OBJECT.WARNING

        HANDLE.TEXT = ""

    END

* if we're upcasing code upcase the object code
    IF UPCASE.CODE THEN
        HANDLE.TEXT = UPCASE(HANDLE.TEXT)
    END

    HANDLE.TEXT.COUNT = DCOUNT(HANDLE.TEXT,AM)

* add default methods.  for the "sub" object, however, these are subroutine
* calls and they don't have these default methods
    IF THIS.OBJECT <> SUBROUTINE.CALL.KEYWORD THEN
        GOSUB ADD.DEFAULT.METHODS.TO.HANDLE.LIST
    END

* we're going to limit the line wrapping characters here.  we don't want
* to have to check every line to see if it's a comment or not as that
* will slow things down considerably.  without the comment check, if
* an asterisk is a wrapping character comments trigger a lot of wrapping
* we don't want.  so, just to be safe, we can't wrap on asterisks in
* method definitions
    METHOD.WRAP.CHARACTERS = CHANGE(LINE.WRAP.CHARACTERS, "*", "")

* add methods from the object's source code.  first we'll build the
* handle.method.list, handle.type.list, handle.dimensions.list,
* method.parameter.list and method.parameter.byval.list table entries.
* once that's built we'll use these entries to build the rest of the entries
    SETREM 0 ON HANDLE.TEXT

    FOR TEXT.LOOP = 1 TO HANDLE.TEXT.COUNT

        REMOVE THIS.LINE FROM HANDLE.TEXT SETTING THROWAWAY

        THIS.LINE = TRIM(THIS.LINE)
        FIRST.WORD = THIS.LINE [" ", 1, 1]

* if this line is a wrapped line
        WRAPPED.PTR = 0

        LOOP

            WRAPPED.PTR += 1
            LAST.WRAP.CHAR = THIS.LINE "R#1"

* is this line wrapped?  a line is wrapped if the last character is one
* of the method.wrapped characters or, special case, the first keyword
* in the line is "method" and it ends in a semicolon.  the semicolon
* is between parameters separating input from output values.  do the
* same thing for the "subroutine" keyword
            UP.FIRST.WORD = UPCASE(FIRST.WORD)
            DECODE.KEYWORD = UP.FIRST.WORD
            GOSUB DECODE.METHOD

            BEGIN CASE

                CASE COUNT(METHOD.WRAP.CHARACTERS, LAST.WRAP.CHAR) <> 0
                    THIS.LINE.WRAPPED = @TRUE

                CASE IS.METHOD AND LAST.WRAP.CHAR = ";"
                    THIS.LINE.WRAPPED = @TRUE

                CASE IS.SUBROUTINE AND LAST.WRAP.CHAR = ";"
                    THIS.LINE.WRAPPED = @TRUE

                CASE 1
                    THIS.LINE.WRAPPED = @FALSE

            END CASE

        UNTIL WRAPPED.PTR > HANDLE.TEXT.COUNT OR NOT(THIS.LINE.WRAPPED)

* if the character indicating the line wrap is a character that should
* be removed before the wrap then remove it from the line
            IF INDEX(LINE.WRAP.REMOVE.CHARACTERS, LAST.WRAP.CHAR, 1) > 0 THEN
                THIS.LINE = THIS.LINE [1, LEN(THIS.LINE) - 1]
            END

* concatenate the next line with this one, "unwrapping" the line
            TEXT.LOOP += 1
            REMOVE WRAPPED.LINE FROM HANDLE.TEXT SETTING THROWAWAY

            THIS.LINE := " ":TRIM(WRAPPED.LINE)

        REPEAT

* extract the first word on this line to see if it's a definition for this object
        FIRST.WORD = THIS.LINE [" ", 1, 1]

        DECODE.KEYWORD = FIRST.WORD
        GOSUB DECODE.PROPERTY
        GOSUB DECODE.METHOD

        BEGIN CASE

* skip any obvious lines that won't have any useful information
            CASE THIS.LINE = ""
                NULL
            CASE THIS.LINE [1, 1] = "*" OR THIS.LINE [1, 1] = "!"
                NULL

* add in an inherited method call
            CASE IS.INHERITED.FROM
                GOSUB ADD.SCANNED.INHERITED.OBJECT

            CASE IS.INHERITED
                GOSUB ADD.SCANNED.INHERITED.METHOD

* add in a method call.  if this is a local method only add it in if the
* object handle is "local"
            CASE IS.METHOD AND (NOT(IS.LOCAL.METHOD) OR THIS.HANDLE = LOCAL.KEYWORD)

* extract the method name from after the "method" keyword.  then add
* the method to the handle.method.list with a type of "METHOD".  wrapper
* methods may have a comma in them--we only want the method name, before
* the comma
                THIS.METHOD = TRIM(THIS.LINE [" ", 2, TO.THE.END] [":", 1, 1] ["(", 1, 1] [",", 1, 1])

                IF THIS.METHOD <> COMMON.ROUTINE.METHOD THEN
                    GOSUB ADD.SCANNED.METHOD
                END

* add in a property's "keywords," the names of properties, statics and 
* constants.  we'll add them into method.handle.list as if they were
* methods.  if we're adding keywords for local calls we don't need to do
* this, so if this.handle is an asterisk we'll skip the whole thing

* statics will be typed here as properties since, on this end, statics and
* properties look and work the same

* if this property is local we'll only add it if the handle for this object
* is "local"
            CASE (IS.PROPERTY OR IS.STATIC) AND (NOT(IS.LOCAL) OR THIS.HANDLE = LOCAL.KEYWORD)
                GOSUB ADD.SCANNED.PROPERTY

* add in constant keywords.  again, we'll skip if we're building for the "LOCAL"
* object handle.  if we aren't allowed to put constants (change constant values)
* don't bother

* if this is a local constant we'll only add it if the object handle is
* "local"
            CASE IS.CONSTANT AND (NOT(IS.LOCAL) OR THIS.HANDLE = LOCAL.KEYWORD)
                GOSUB ADD.SCANNED.CONSTANT

        END CASE

    NEXT TEXT.LOOP

    GOSUB ADD.SCANNED.DEFAULT.CONSTANTS

    SCAN.END.DATE = DATE()
    SCAN.END.TIME = TIME()
    SCAN.COUNT += 1
    SCAN.ELAPSED.TIME += TIME.ELAPSED (SCAN.START.DATE, SCAN.START.TIME)

    RETURN

ADD.DEFAULT.METHODS.TO.HANDLE.LIST: **************************************
* add all default methods to the handle table                            *
**************************************************************************
    IF THIS.OBJECT = SUBROUTINE.CALL.KEYWORD THEN
        RETURN
    END

* update the handle table with a list of the default methods
    HANDLE.METHOD.LIST<HANDLE.LOOP> = LOWER(DEFAULT.METHOD.LIST)
    HANDLE.METHOD.CALLED.LIST<HANDLE.LOOP> = "0"

* add parameters for each default method
    FOR SET.LOOP = 1 TO DEFAULT.METHOD.COUNT

        HANDLE.TYPE.LIST<HANDLE.LOOP, SET.LOOP> = "METHOD"

        THIS.DEFAULT.PARAMETER.LIST = CHANGE(DEFAULT.PARAMETER.LIST<SET.LOOP>, ",", AM)

* if this paramter list has a semi-colon in it we have output values in the call.  if there's
* no semi-colon assume that all parameters are output parameters
        SEMI.PTR = INDEX (THIS.DEFAULT.PARAMETER.LIST, ";", 1)

        IF SEMI.PTR > 0 THEN

* get a list of output parameters
            DEFAULT.OUTPUT.PARAMETER.LIST = THIS.DEFAULT.PARAMETER.LIST [1, SEMI.PTR - 1]

* if the parameter list starts off with a semi-colon remove it.  otherwise convert it to an
* attribute mark as if it was a comma
            IF THIS.DEFAULT.PARAMETER.LIST [1, 1] = ";" THEN
                THIS.DEFAULT.PARAMETER.LIST = THIS.DEFAULT.PARAMETER.LIST [2, TO.THE.END]
            END ELSE
                THIS.DEFAULT.PARAMETER.LIST = CHANGE(THIS.DEFAULT.PARAMETER.LIST, ";", AM)
            END

        END ELSE

* all parameters are output parameters
            DEFAULT.OUTPUT.PARAMETER.LIST = THIS.DEFAULT.PARAMETER.LIST

        END

* get a count of all parameters, output and passed parameters
        DEFAULT.PARAMETER.COUNT = DCOUNT(THIS.DEFAULT.PARAMETER.LIST, AM)
        DEFAULT.OUTPUT.PARAMETER.COUNT = DCOUNT (DEFAULT.OUTPUT.PARAMETER.LIST, AM)
        DEFAULT.PASSED.PARAMETER.COUNT = DEFAULT.PARAMETER.COUNT - DEFAULT.OUTPUT.PARAMETER.COUNT

* set the byval list for passed parameters
        IF DEFAULT.PASSED.PARAMETER.COUNT > 0 THEN
            FOR PARM.LOOP = DEFAULT.OUTPUT.PARAMETER.COUNT + 1 TO DEFAULT.PARAMETER.COUNT
                HANDLE.PARAMETER.BYVAL.LIST<HANDLE.LOOP, SET.LOOP, PARM.LOOP> = 1
            NEXT PARM.LOOP
        END

* set the output parameter list and count
        IF DEFAULT.OUTPUT.PARAMETER.COUNT > 0 THEN
            HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, SET.LOOP> = LOWER(LOWER(DEFAULT.OUTPUT.PARAMETER.LIST))
            HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, SET.LOOP> = DEFAULT.OUTPUT.PARAMETER.COUNT
        END

        HANDLE.PARAMETER.LIST<HANDLE.LOOP, SET.LOOP> = LOWER(LOWER(THIS.DEFAULT.PARAMETER.LIST))

    NEXT SET.LOOP

    RETURN

ADD.SCANNED.INHERITED.OBJECT: ********************************************
* update the "last" inherited object name for a scanned "inherit.from"   *
* statement                                                              *
**************************************************************************
    INHERITED.CHILD = TRIM(THIS.LINE [" ", 2, 1])

    SCAN.LAST.INHERIT.OBJECT = INHERITED.CHILD

    RETURN

ADD.SCANNED.INHERITED.METHOD: ********************************************
* add inherited method defined in this.line to the usage table           *
**************************************************************************

* extract the method name, child object and child method name
    THIS.METHOD = THIS.LINE [" ", 2, 1] ["=", 1, 1]
    THIS.METHOD.NAME = THIS.METHOD

* if this line has no equals sign and we have a last.inherit.object set
* the line to default to the last.inherit.object and copy the method name
    IF COUNT(THIS.LINE, "=") = 0 THEN

        IF SCAN.LAST.INHERIT.OBJECT = "" THEN

            METHOD = THIS.METHOD
            SUBROUTINE.NAME = ECLIPSE.PREFIX:THIS.OBJECT:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = "In ":DOWNCASE(THIS.OBJECT):", no previous ":INHERIT.KEYWORD:" or "
            OBJECT.ERROR.DESC := INHERIT.FROM.KEYWORD:" line to provide default child object"
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

        THIS.LINE := " = ":METHOD.DELIMITER

    END

* this line should have one equals sign in it
    IF COUNT(THIS.LINE, "=") <> 1 THEN

        METHOD = THIS.METHOD
        SUBROUTINE.NAME = ECLIPSE.PREFIX:THIS.OBJECT:ECLIPSE.DELIMITER:METHOD
        OBJECT.ERROR.DESC = "In ":DOWNCASE(THIS.OBJECT):", inherited definitions should have one equals sign"
        OBJECT.ERROR.LINE = PTR
        SHOW.REFERENCE = @FALSE

        GOSUB PRINT.OBJECT.ERROR

        RETURN

    END

* extract the inherited references
    INHERITED.REFERENCE = TRIM(THIS.LINE ["=", 2, 1000])
    DELIMITED.PTR = INDEX(INHERITED.REFERENCE, METHOD.DELIMITER, 1)
    IF DELIMITED.PTR = 0 THEN
        DELIMITED.PTR = LEN(INHERITED.REFERENCE) + 1
    END

    INHERITED.CHILD = INHERITED.REFERENCE [1, DELIMITED.PTR - 1]
    INHERITED.METHOD = INHERITED.REFERENCE [DELIMITED.PTR + METHOD.DEL.LENGTH, 10000]

* if the inherited child and/or method are null use default values
    IF INHERITED.CHILD = "" THEN

        IF SCAN.LAST.INHERIT.OBJECT = "" THEN

            METHOD = THIS.METHOD
            SUBROUTINE.NAME = ECLIPSE.PREFIX:THIS.OBJECT:ECLIPSE.DELIMITER:METHOD
            OBJECT.ERROR.DESC = "In ":DOWNCASE (THIS.OBJECT):", no previous ":INHERIT.KEYWORD:" or "
            OBJECT.ERROR.DESC := INHERIT.FROM.KEYWORD:" line to provide default child object"
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE

            GOSUB PRINT.OBJECT.ERROR

            RETURN

        END

        INHERITED.CHILD = SCAN.LAST.INHERIT.OBJECT

    END

    SCAN.LAST.INHERIT.OBJECT = INHERITED.CHILD

    IF INHERITED.METHOD = "" THEN
        INHERITED.METHOD = THIS.METHOD
    END

    BEGIN CASE
        CASE NOT(COMPILE.OBJECT)
            USE.HANDLE.LIST = @TRUE
        CASE THIS.HANDLE = LOCAL.KEYWORD
            USE.HANDLE.LIST = @FALSE 
        CASE 1
            USE.HANDLE.LIST = @TRUE
    END CASE
    GOSUB FIND.INHERITED.CODE

    IF NOT(INHERITED.METHOD.FOUND) THEN
        RETURN
    END
    
    GOSUB GET.INHERITED.METHOD.DEFINITION

* now we have the inherited method's definition from the source object.
* build a "method" statement as if the inherited method was defined as a 
* "normal" method in the current scanned object using the method name
* from the inherited method definition
    THIS.LINE = METHOD.KEYWORD:" ":THIS.METHOD:" ":INHERITED.DEFINITION [" ", 3, TO.THE.END]

* add to the scanned tables as if this had been created as a "normal"
* method
    GOSUB ADD.SCANNED.METHOD

    RETURN

ADD.SCANNED.METHOD: ******************************************************
* add method this.method from the code usage scanning.  this.line is     *
* the method definition                                                  *
**************************************************************************

* if we've already added this method to the handle table return
    LOCATE THIS.METHOD IN HANDLE.METHOD.LIST<HANDLE.LOOP> SETTING METHOD.PTR THEN
        RETURN
    END

* get parameter list from the method definition in the object code
* the parameter list starts after the first open parenthesis
    THIS.PARAMETER.STRING = THIS.LINE ["(", 2, TO.THE.END]

* get the complete parameter list in a dynamic array
    THIS.PARAMETER.LIST = SPLIT.METHOD.PARAMETERS (THIS.PARAMETER.STRING, "LIST")
    THIS.PARAMETER.COUNT = DCOUNT(THIS.PARAMETER.LIST, @AM)

* get only the output parameters in a dynamic array
    THIS.OUTPUT.LIST = SPLIT.METHOD.PARAMETERS (THIS.PARAMETER.STRING, "OUT")

* check through parameter list for any byval references.  also remove any optional, byval and/or
* byref references
    THIS.BYVAL.LIST = ""
    THIS.SPECIAL.LIST = ""

    FOR PARM.LOOP = 1 TO THIS.PARAMETER.COUNT

        THIS.PARAMETER = THIS.PARAMETER.LIST<PARM.LOOP>

* we don't care about default values in this case so remove anything after
* an equals sign
        THIS.PARAMETER = TRIM(THIS.PARAMETER ["=", 1, 1], " ", "B")

* we don't need to know about optional parameters here.  if we see the optional
* parameter remove it from this.parameter
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        IF FIRST.PARM.WORD = OPTIONAL.KEYWORD THEN
            THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
        END

* check for byval and byref keywords
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        BEGIN CASE

* byval
            CASE FIRST.PARM.WORD = BYVAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYVAL.LIST<PARM.LOOP> = @TRUE
                THIS.SPECIAL.LIST<PARM.LOOP> = @FALSE

* special byval
            CASE FIRST.PARM.WORD = BYVAL.SPECIAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYVAL.LIST<PARM.LOOP> = @TRUE
                THIS.SPECIAL.LIST<PARM.LOOP> = @TRUE

* byref
            CASE FIRST.PARM.WORD = BYREF.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
                THIS.BYVAL.LIST<PARM.LOOP> = @FALSE
                THIS.SPECIAL.LIST<PARM.LOOP> = @FALSE

* neither byref or byval.  default to byref
            CASE 1
                THIS.BYVAL.LIST<PARM.LOOP> = @FALSE
                THIS.SPECIAL.LIST<PARM.LOOP> = @FALSE

        END CASE

        THIS.PARAMETER.LIST<PARM.LOOP> = THIS.PARAMETER

    NEXT PARM.COUNT

* insert the method name and the method list
    HANDLE.METHOD.LIST<HANDLE.LOOP, METHOD.PTR> = THIS.METHOD
    HANDLE.METHOD.CALLED.LIST<HANDLE.LOOP, METHOD.PTR> = "0"

    HANDLE.TYPE.LIST<HANDLE.LOOP, METHOD.PTR> = "METHOD"
    HANDLE.DIMENSIONS.LIST<HANDLE.LOOP, METHOD.PTR> = ""

    HANDLE.PARAMETER.LIST<HANDLE.LOOP, METHOD.PTR> = LOWER(LOWER(THIS.PARAMETER.LIST))
    HANDLE.PARAMETER.BYVAL.LIST<HANDLE.LOOP, METHOD.PTR> = LOWER(LOWER(THIS.BYVAL.LIST))
    HANDLE.PARAMETER.SPECIAL.LIST<HANDLE.LOOP, METHOD.PTR> = LOWER(LOWER(THIS.SPECIAL.LIST))

    IF THIS.OUTPUT.LIST = "?" THEN
        HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, METHOD.PTR> = "?"
        HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, METHOD.PTR> = 0
    END ELSE
        HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, METHOD.PTR> = LOWER(LOWER(THIS.OUTPUT.LIST)) 
        HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, METHOD.PTR> = DCOUNT(THIS.OUTPUT.LIST, @AM)
    END

* if this method is an inline method (declared with "inline.method" or
* "local.inline.method" instead of "method") add it to the inlined methods list
    IF IS.INLINE THEN

        INLINE.OBJECT = THIS.OBJECT
        INLINE.METHOD = THIS.METHOD
        INLINE.ALWAYS = @FALSE
        INLINE.LINE = @FALSE
        GOSUB ADD.INLINE.ENTRY

    END

    RETURN

ADD.SCANNED.PROPERTY: ****************************************************
* add a property usage from scanned code to the usage tables             *
**************************************************************************
    THIS.PROPERTY.LIST = THIS.LINE [" ", 2, TO.THE.END]

* change any commas NOT inside parenthesis to @ams to separate properties
    PREN.DEPTH = 0
    THIS.LIST.LEN = LEN(THIS.PROPERTY.LIST)

    FOR COMMA.PTR = 1 TO THIS.LIST.LEN

        THIS.COMMA.CHAR = THIS.PROPERTY.LIST [COMMA.PTR, 1]
        BEGIN CASE
            CASE THIS.COMMA.CHAR = "("
                PREN.DEPTH += 1
            CASE THIS.COMMA.CHAR = ")"
                PREN.DEPTH -= 1
            CASE THIS.COMMA.CHAR = "," AND PREN.DEPTH <= 0
                THIS.PROPERTY.LIST = THIS.PROPERTY.LIST [1, COMMA.PTR - 1]:@AM:THIS.PROPERTY.LIST [COMMA.PTR + 1, TO.THE.END]
        END CASE

    NEXT COMMA.PTR

    THIS.PROPERTY.COUNT = DCOUNT(THIS.PROPERTY.LIST,@AM)

* pull each property out of the line and add it to our tables
    FOR PROP.LOOP = 1 TO THIS.PROPERTY.COUNT

        THIS.PROPERTY = TRIM(THIS.PROPERTY.LIST<PROP.LOOP> ["(", 1, 1])
        THIS.DIM = THIS.PROPERTY.LIST<PROP.LOOP> ["(",2,1] [")", 1, 1]
        THIS.DIM = TRIM(THIS.DIM, " ", "A")
        THIS.DIMENSIONS = DCOUNT(THIS.DIM, ",")

* set type based on number of dimensions
        IF THIS.DIMENSIONS = 0 THEN
            THIS.TYPE = "PROPERTY"
        END ELSE
            THIS.TYPE = "ARRAY"
        END

        LOCATE THIS.PROPERTY IN HANDLE.METHOD.LIST<HANDLE.LOOP> SETTING PROPERTY.PTR ELSE

            HANDLE.METHOD.LIST<HANDLE.LOOP, PROPERTY.PTR> = THIS.PROPERTY
            HANDLE.METHOD.CALLED.LIST<HANDLE.LOOP, PROPERTY.PTR> = "0"

            HANDLE.TYPE.LIST<HANDLE.LOOP, PROPERTY.PTR> = THIS.TYPE
            HANDLE.DIMENSIONS.LIST<HANDLE.LOOP, PROPERTY.PTR> = THIS.DIMENSIONS

            HANDLE.PARAMETER.LIST<HANDLE.LOOP, PROPERTY.PTR> = ""
            HANDLE.PARAMETER.BYVAL.LIST<HANDLE.LOOP, PROPERTY.PTR> = ""
            HANDLE.PARAMETER.SPECIAL.LIST<HANDLE.LOOP, PROPERTY.PTR> = ""

            HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, PROPERTY.PTR> = ""
            HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, PROPERTY.PTR> = 0

        END

    NEXT PROP.LOOP

    RETURN

ADD.SCANNED.CONSTANT: ****************************************************
* add constants from scanned code to the usage tables                    *
**************************************************************************
    THIS.CONSTANT.LIST = CHANGE(THIS.LINE [" ", 2, TO.THE.END], ",", @AM)
    THIS.CONSTANT.COUNT = DCOUNT(THIS.CONSTANT.LIST,@AM)

    FOR CONSTANT.LOOP = 1 TO THIS.CONSTANT.COUNT

        THIS.CONSTANT = TRIM(THIS.CONSTANT.LIST<CONSTANT.LOOP> ["=", 1, 1])
        THIS.VALUE = TRIM(THIS.CONSTANT.LIST<CONSTANT.LOOP> ["=", 2, 1], " ", "B")

        LOCATE THIS.CONSTANT IN HANDLE.METHOD.LIST<HANDLE.LOOP> SETTING CONSTANT.PTR ELSE

            HANDLE.METHOD.LIST<HANDLE.LOOP, CONSTANT.PTR> = THIS.CONSTANT
            HANDLE.METHOD.CALLED.LIST<HANDLE.LOOP, CONSTANT.PTR> = "0"

            HANDLE.TYPE.LIST<HANDLE.LOOP, CONSTANT.PTR> = "CONSTANT"
            HANDLE.DIMENSIONS.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""

            HANDLE.PARAMETER.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.PARAMETER.BYVAL.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.PARAMETER.SPECIAL.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""

            HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, CONSTANT.PTR> = 0

        END

    NEXT CONSTANT.LOOP

    RETURN

ADD.SCANNED.DEFAULT.CONSTANTS: *******************************************
* add default constants to the usage tables after scanning a program     *
**************************************************************************

* add default constants
    FOR CONSTANT.LOOP = 1 TO DEFAULT.CONSTANT.COUNT

        THIS.CONSTANT = DEFAULT.CONSTANT.LIST<CONSTANT.LOOP>
        THIS.VALUE = DEFAULT.CONSTANT.VALUE.LIST<CONSTANT.LOOP>

        LOCATE THIS.CONSTANT IN HANDLE.METHOD.LIST<HANDLE.LOOP> SETTING CONSTANT.PTR ELSE

            HANDLE.METHOD.LIST<HANDLE.LOOP, CONSTANT.PTR> = THIS.CONSTANT
            HANDLE.METHOD.CALLED.LIST<HANDLE.LOOP, CONSTANT.PTR> = "0"

            HANDLE.TYPE.LIST<HANDLE.LOOP, CONSTANT.PTR> = "CONSTANT"

            HANDLE.DIMENSIONS.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.PARAMETER.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.PARAMETER.BYVAL.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.PARAMETER.SPECIAL.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""

            HANDLE.OUTPUT.PARAMETER.LIST<HANDLE.LOOP, CONSTANT.PTR> = ""
            HANDLE.OUTPUT.COUNT.LIST<HANDLE.LOOP, CONSTANT.PTR> = 0

        END

    NEXT CONSTANT.LOOP

    RETURN

BUILD.USAGE.FROM.PREVIOUSLY.SCANNED: *************************************
* build usage table information for this.handle, this.object using       *
* previously scanned information in the handle table.  scanned.ptr       *
* pointers to the handle table entry to use as the source for the        *
* previously scanned information.  copy.to.ptr indicates the handle      *
* table entry where the information should be copied                     *
**************************************************************************

* these handle usage tables can be copied verbatum from the source object's
* table entries to the new object's entries
    HANDLE.METHOD.LIST<COPY.TO.PTR> = HANDLE.METHOD.LIST<SCANNED.PTR>
    HANDLE.METHOD.CALLED.LIST<COPY.TO.PTR> = HANDLE.METHOD.CALLED.LIST<SCANNED.PTR>

    HANDLE.TYPE.LIST<COPY.TO.PTR> = HANDLE.TYPE.LIST<SCANNED.PTR>
    HANDLE.DIMENSIONS.LIST<COPY.TO.PTR> = HANDLE.DIMENSIONS.LIST<SCANNED.PTR>

    HANDLE.PARAMETER.LIST<COPY.TO.PTR> = HANDLE.PARAMETER.LIST<SCANNED.PTR>
    HANDLE.PARAMETER.BYVAL.LIST<COPY.TO.PTR> = HANDLE.PARAMETER.BYVAL.LIST<SCANNED.PTR>
    HANDLE.PARAMETER.SPECIAL.LIST<COPY.TO.PTR> = HANDLE.PARAMETER.SPECIAL.LIST<SCANNED.PTR>

    HANDLE.OUTPUT.PARAMETER.LIST<COPY.TO.PTR> = HANDLE.OUTPUT.PARAMETER.LIST<SCANNED.PTR>
    HANDLE.OUTPUT.COUNT.LIST<COPY.TO.PTR> = HANDLE.OUTPUT.COUNT.LIST<SCANNED.PTR>

    RETURN

ADD.HANDLE.KEYWORDS: *****************************************************
* for each object handle create a list of handle.method keywords as      *
* they'll appear in the program.  for methods this will be               *
* "methodhandle::method".  for properties it will be                     *
* "methodhandle::property" and for constants it will be                  *
* "methodhandle::constant".                                              *
**************************************************************************

* for local calls, where an object is referencing its own methods the keyword
* will just "LOCAL::method".  for properties, statics and constants the keyword
* will just be the variable name.  "LOCAL" won't be needed
    FOR HANDLE.LOOP = START.USAGE.HANDLE.PTR TO END.USAGE.HANDLE.PTR

        THIS.HANDLE = HANDLE.LIST<HANDLE.LOOP>
        THIS.METHOD.LIST = RAISE(HANDLE.METHOD.LIST<HANDLE.LOOP>)
        THIS.TYPE.LIST = RAISE(HANDLE.TYPE.LIST<HANDLE.LOOP>)
        THIS.KEYWORD.LIST = ""

        USAGE.METHOD.COUNT = DCOUNT(THIS.METHOD.LIST, @AM)

        FOR METHOD.LOOP = 1 TO USAGE.METHOD.COUNT

* for local calls (calls within an object to other methods) the keyword
* will only be the method.  for calls outside the object the keyword
* will be objecthandle : method
            THIS.METHOD = THIS.METHOD.LIST<METHOD.LOOP>

* skip the "common" code "method".  the "common" method isn't a real method, it's
* just a way to include some code with all methods.  it will never be references
* in an object call
            IF THIS.METHOD <> COMMON.ROUTINE.METHOD THEN

                THIS.TYPE = THIS.TYPE.LIST<METHOD.LOOP>

                BEGIN CASE

* method calls:
*     remote (different object) method call, use handle:method
                    CASE THIS.TYPE = "METHOD"
                        THIS.KEYWORD = THIS.HANDLE:METHOD.DELIMITER:THIS.METHOD

* property references.  these should only be remote
*     non-array property
                    CASE THIS.TYPE = "PROPERTY"
                        THIS.KEYWORD = THIS.HANDLE:PROPERTY.DELIMITER:THIS.METHOD

*     array property
                    CASE THIS.TYPE = "ARRAY"
                        THIS.KEYWORD = THIS.HANDLE:PROPERTY.DELIMITER:THIS.METHOD

* constant reference
*     remote reference.  use handle:constant
                    CASE THIS.TYPE = "CONSTANT"
                        THIS.KEYWORD = THIS.HANDLE:CONSTANT.DELIMITER:THIS.METHOD

* shouldn't be anything else but if there is (?) we'll use handle:method
                    CASE 1
                        THIS.KEYWORD = THIS.HANDLE:METHOD.DELIMITER:THIS.METHOD

                END CASE

                THIS.KEYWORD.LIST<METHOD.LOOP> = THIS.KEYWORD

            END

        NEXT METHOD.LOOP

        HANDLE.KEYWORD.LIST<HANDLE.LOOP> = LOWER(THIS.KEYWORD.LIST)

    NEXT HANDLE.LOOP

    RETURN

CHECK.NEW.OBJECT: ********************************************************
* check new.object.handle against create.handle.list.  if found make     *
* sure that the existing object is the same object type as               *
* new.object.name.  if not then we have the same object handle used in   *
* two different places for two different object names and things will    *
* get confused                                                           *
**************************************************************************

* if the new object handle isn't already in create.handle.list there's
* nothing to check
    LOCATE NEW.OBJECT.HANDLE IN CREATE.HANDLE.LIST SETTING NEW.OBJECT.PTR ELSE
        RETURN
    END

* if the object name for the existing handle is the same as the one we're
* testing
    PREVIOUS.OBJECT.NAME = CREATE.OBJECT.LIST<NEW.OBJECT.PTR>
    IF NEW.OBJECT.NAME = PREVIOUS.OBJECT.NAME THEN
        RETURN
    END

* if we got this far then we're trying to create a new object with the same
* handle but for a different object name
    PREVIOUS.CREATE.LINE = CREATE.LINE.LIST<NEW.OBJECT.PTR>

    OBJECT.ERROR.DESC = '"':NEW.OBJECT.HANDLE:'"':" created as ":'"':NEW.OBJECT.NAME:'"'
    OBJECT.ERROR.DESC := " when previously created as ":'"':PREVIOUS.OBJECT.NAME:'"'
    IF PREVIOUS.CREATE.LINE <> "" THEN
        OBJECT.ERROR.DESC := " in line ":CREATE.LINE.LIST<NEW.OBJECT.PTR>
    END

    OBJECT.ERROR.LINE = PTR
    SHOW.REFERENCE = @FALSE

    GOSUB PRINT.OBJECT.ERROR

    RETURN

PRINT.OBJECT.USAGE.TABLE: ************************************************
* print out the object usage tables for debugging                        *
**************************************************************************
    PRINT
    PRINT "Method: ":METHOD
    PRINT "Objects Created / Named / Destroyed (CREATE.OBJECT):"
    PRINT "Handle........................ Object........................ ":
    PRINT "Variable................................ Type...... With...... ":
    PRINT "Line......"

    FOR PTR = 1 TO CREATE.COUNT

        PRINT CREATE.HANDLE.LIST<PTR> "L#30":" ":

        BEGIN CASE
            CASE CREATE.DEFINED.LOCAL.LIST<PTR>
                PRINT (CREATE.OBJECT.LIST<PTR>:" (def local)") "L#30":" ":
            CASE CREATE.LOCAL.LIST<PTR>
                PRINT (CREATE.OBJECT.LIST<PTR>:" (parent local)") "L#30":" ":
            CASE 1
                PRINT CREATE.OBJECT.LIST<PTR> "L#30":" ":
        END CASE

        PRINT CREATE.VARIABLE.LIST<PTR> "L#40":" ":
        PRINT CREATE.TYPE.LIST<PTR> "L#10":" ":
        PRINT CREATE.WITH.LIST<PTR> "L#10":" ":
        PRINT CREATE.LINE.LIST<PTR> "R#10"

    NEXT PTR

    GOSUB WAIT

    PRINT
    PRINT "Unique Handles (HANDLE.LIST):"
    PRINT "Handle........................ Variable................. Object......... Keyword...................................... Type...."

    FOR PTR = 1 TO HANDLE.COUNT

        THIS.METHOD.COUNT = DCOUNT(HANDLE.KEYWORD.LIST<PTR>,@VM)
        FOR METHOD.LOOP = 1 TO THIS.METHOD.COUNT

            PRINT HANDLE.LIST<PTR> "L#30":" ":
            PRINT HANDLE.VARIABLE.LIST<PTR> "L#25":" ":
            PRINT HANDLE.OBJECT.LIST<PTR> "L#15":" ":
            PRINT HANDLE.KEYWORD.LIST<PTR,METHOD.LOOP> "L#45":" ":
            PRINT HANDLE.TYPE.LIST<PTR,METHOD.LOOP> "L#8"

        NEXT METHOD.LOOP

    NEXT PTR

    GOSUB WAIT

    PRINT
    PRINT "Child Objects (CREATE.CHILD.HANDLE.LIST):"
    PRINT "ChildObject................... ParentHandle... Name........... Keyword....................... Dim..... Depth"

    FOR PTR = 1 TO CREATE.CHILD.COUNT

         BEGIN CASE
             CASE CREATE.CHILD.DEFINED.LOCAL.LIST<PTR>
                 PRINT (CREATE.CHILD.HANDLE.LIST<PTR>:" (def local)") "L#30":" ":
             CASE CREATE.CHILD.LOCAL.LIST<PTR>
                 PRINT (CREATE.CHILD.HANDLE.LIST<PTR>:" (parent local)") "L#30":" ":
             CASE 1
                 PRINT CREATE.CHILD.HANDLE.LIST<PTR> "L#30":" ":
         END CASE

         PRINT CREATE.CHILD.PARENT.HANDLE.LIST<PTR> "L#15":" ":
         PRINT CREATE.CHILD.NAME.LIST<PTR> "L#15":" ":
         PRINT CREATE.CHILD.VARIABLE.LIST<PTR> "L#30":" ":
         PRINT CREATE.CHILD.DIM.LIST<PTR> "L#8":" ":
         PRINT CREATE.CHILD.DEPTH.LIST<PTR> "L#5"

    NEXT PTR

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code conversion / defines                                            **
**************************************************************************
**************************************************************************

PROCESS.DEFINES: *********************************************************
* process program.code for $define, $undefine, $ifdef, $ifndef, $else,   *
* $endif                                                                 *
**************************************************************************

* see if we have any defines to process
    DEFINES.EXIST = 0

    BEGIN CASE
        CASE INDEX(OBJECT.CODE, "$DEFINE ", 1) <> 0
            DEFINES.EXIST = 1
        CASE INDEX(OBJECT.CODE, "$UNDEFINE ", 1) <> 0
            DEFINES.EXIST = 1
        CASE INDEX(OBJECT.CODE, "$IFDEF ", 1) <> 0
            DEFINES.EXIST = 1
        CASE INDEX(OBJECT.CODE, "$IFNDEF ", 1) <> 0
            DEFINES.EXIST = 1
    END CASE

    IF NOT(DEFINES.EXIST) THEN
        RETURN
    END

* process program for define code
    DEFINE.LIST = ""
    DEFINE.REPLACE.LIST = ""
    DEFINE.COUNT = 0

    CURRENT.IF.VALUE = 1
    DEFINE.IF.STACK = ""
    DEFINE.IF.DEPTH = 0

    NEW.OBJECT.CODE = ""
    SETREM 0 ON OBJECT.CODE

    FOR LINE.LOOP = 1 TO OBJECT.CODE.LINES

        REMOVE THIS.LINE FROM OBJECT.CODE SETTING THROWAWAY

        GOSUB PROCESS.DEFINES.ONE.LINE

        IF LINE.LOOP = 1 THEN
            NEW.OBJECT.CODE = THIS.LINE
        END ELSE
            NEW.OBJECT.CODE := @AM:THIS.LINE
        END

    NEXT LINE.LOOP

    OBJECT.CODE = NEW.OBJECT.CODE

    RETURN

PROCESS.DEFINES.ONE.LINE: ************************************************
* process this.line for defines                                          *
**************************************************************************
    CHECK.LINE = TRIM(THIS.LINE)

    KEYWORD = UPCASE(CHECK.LINE [" ", 1, 1])
    DEFINE.WORD = CHECK.LINE [" ", 2, 1]
    COMMENT.LINE = 0

    BEGIN CASE


* comment line, don't bother
        CASE KEYWORD [1, 1] = "*" OR KEYWORD [1, 1] = "!"
            NULL

* null line, don't bother
        CASE KEYWORD = ""
            NULL


* $define, add define word to define list
        CASE KEYWORD = "$DEFINE" AND DEFINE.WORD <> ""
            LOCATE DEFINE.WORD IN DEFINE.LIST SETTING DEFINE.PTR ELSE
                DEFINE.COUNT += 1
                DEFINE.LIST<DEFINE.COUNT> = DEFINE.WORD
            END
            COMMENT.LINE = 1

* $undefine, remove define word from define list
        CASE KEYWORD = "$UNDEFINE" AND DEFINE.WORD <> ""
            LOCATE DEFINE.WORD IN DEFINE.LIST SETTING DEFINE.PTR THEN
                DEFINE.COUNT -= 1
                DEL DEFINE.LIST<DEFINE.PTR>
            END
            COMMENT.LINE = 1

* $ifdef, start an if block
        CASE KEYWORD = "$IFDEF" AND DEFINE.WORD <> ""
            LOCATE DEFINE.WORD IN DEFINE.LIST SETTING DEFINE.PTR THEN
                DEFINE.EXISTS = 1
            END ELSE
                DEFINE.EXISTS = 0
            END
            CURRENT.IF.VALUE = DEFINE.EXISTS
            DEFINE.IF.DEPTH += 1
            DEFINE.IF.STACK<DEFINE.IF.DEPTH> = CURRENT.IF.VALUE
            COMMENT.LINE = 1

* $ifndef, start an ifnot block
        CASE KEYWORD = "$IFNDEF" AND DEFINE.WORD <> ""
            LOCATE DEFINE.WORD IN DEFINE.LIST SETTING DEFINE.PTR THEN
                DEFINE.EXISTS = 1
            END ELSE
                DEFINE.EXISTS = 0
            END
            CURRENT.IF.VALUE = NOT(DEFINE.EXISTS)
            DEFINE.IF.DEPTH += 1
            DEFINE.IF.STACK<DEFINE.IF.DEPTH> = CURRENT.IF.VALUE
            COMMENT.LINE = 1

* $else, reverse current if status 
        CASE KEYWORD = "$ELSE"
            CURRENT.IF.VALUE = NOT(CURRENT.IF.VALUE)
            DEFINE.IF.STACK<DEFINE.IF.DEPTH> = CURRENT.IF.VALUE
            COMMENT.LINE = 1

* $endif, end the current if block
        CASE KEYWORD = "$ENDIF" AND DEFINE.IF.DEPTH > 0
            DEL DEFINE.IF.STACK<DEFINE.IF.DEPTH>
            DEFINE.IF.DEPTH -= 1
            IF DEFINE.IF.DEPTH = 0 THEN
                CURRENT.IF.VALUE = 1
            END ELSE
                CURRENT.IF.VALUE = DEFINE.IF.STACK<DEFINE.IF.DEPTH>
            END
            COMMENT.LINE = 1


* any other program line.  comment out if the current.if.value is false
        CASE NOT(CURRENT.IF.VALUE)
            COMMENT.LINE = 1


    END CASE

* comment the code line if required
    IF COMMENT.LINE THEN

        IF THIS.LINE [1, 1] = " " THEN
            THIS.LINE = "*":THIS.LINE [2, TO.THE.END]
        END ELSE
            THIS.LINE = "* ":THIS.LINE
        END

    END

    RETURN


**************************************************************************
**************************************************************************
** eclipse / oc program routines                                        **
**************************************************************************
**************************************************************************

CONVERT.OC.CALLS: ********************************************************
* convert all "call" statements in program.code to sub-type method       *
* calls                                                                  *
**************************************************************************

    OLD.PROGRAM.CODE = PROGRAM.CODE
    SETREM 0 ON OLD.PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

        REMOVE THIS.LINE FROM OLD.PROGRAM.CODE SETTING THROWAWAY

* check any "CALL" strings found to see if they're subroutine calls
        CALL.INSTANCE = @FALSE
        CALL.KEYWORD = "CALL"

        LOOP

            CALL.INSTANCE += 1
            CALL.PTR = INDEX(THIS.LINE, CALL.KEYWORD, CALL.INSTANCE)

        UNTIL CALL.PTR < 1

            GOSUB PROCESS.ONE.OC.CALL

            IF CONVERTED.CALL THEN
                PROGRAM.CODE<LINE.LOOP> = NEW.LINE
                THIS.LINE = NEW.LINE
                CALL.INSTANCE -= 1
            END

        REPEAT

    NEXT LINE.LOOP

    RETURN

PROCESS.ONE.OC.CALL: *****************************************************
* check this.line starting at call.ptr to see if this is an external     *
* subroutine call.  if it is change it to a sub-type method call         *                                                          *
**************************************************************************
    NEW.LINE = ""
    CONVERTED.CALL = @FALSE

* the character after the "call" keyword has to be a space or this isn't
* a call
    IF THIS.LINE [CALL.PTR + LEN(CALL.KEYWORD), 1] <> " " THEN
        RETURN
    END

* extract the subroutine name.  skip over spaces until we hit something,
* extract the subroutine name and see if it's valid
    SUBROUTINE.PTR = CALL.PTR + LEN(CALL.KEYWORD) + 1

    LOOP
        THIS.CHAR = THIS.LINE [SUBROUTINE.PTR, 1]
    UNTIL THIS.CHAR <> " "
        SUBROUTINE.PTR += 1
    REPEAT

* if we ran out of program line we don't have a call statement
    IF THIS.CHAR = "" THEN
        RETURN
    END

* subroutine.ptr now points at the first non-blank character after the
* "CALL" keyword.  move forward until we hit an open parenthesis, a
* space or a semicolon to get the subroutine name
    PARAMETER.PTR = SUBROUTINE.PTR

    LOOP
        THIS.CHAR = THIS.LINE [PARAMETER.PTR, 1]
    UNTIL THIS.CHAR = "(" OR THIS.CHAR = " " OR THIS.CHAR = ";" OR THIS.CHAR = ""
        PARAMETER.PTR += 1
    REPEAT

* now parameter.ptr points to either the first character of the parameter
* list or the end of this code line
    CALL.NAME = THIS.LINE [SUBROUTINE.PTR, PARAMETER.PTR - SUBROUTINE.PTR]
    CALL.NAME = TRIM(CALL.NAME, " ", "B")

* if we don't find a subroutine name this isn't an external subroutine call
    IF CALL.NAME = "" THEN
        RETURN
    END

* if the subroutine is from an object method skip converting this call.  it
* was already checked when it was compiled against the object
    IF ECLIPSE.PREFIX <> "" THEN
        IF CALL.NAME [1, LEN(ECLIPSE.PREFIX)] = ECLIPSE.PREFIX THEN
            RETURN
        END
    END

* if this is an indirect subroutine call we can't check it
    IF CALL.NAME [1, 1] = "@" THEN
        RETURN
    END

* if this is really a subroutine call we should be able to find the
* subroutine in the oc file
    READV CALL.HEADER FROM OCFILE, CALL.NAME, 1 ELSE
        RETURN
    END

* if the last character tested was a space move ahead in the line until
* we hit either an open parenthesis, a semicolon or the end of the
* line
    IF THIS.CHAR = " " THEN

        PARAMETER.PTR += 1

        LOOP

            THIS.CHAR = THIS.LINE [PARAMETER.PTR, 1]

* if we hit something other than an open parenthesis, semicolon or the
* end of the line then this isn't an external subroutine call
            IF THIS.CHAR <> "(" AND THIS.CHAR <> ";" AND THIS.CHAR <> "" THEN
                RETURN
            END

        UNTIL THIS.CHAR = "(" OR THIS.CHAR = ";" OR THIS.CHAR = ""

            PARAMETER.PTR += 1

        REPEAT

    END

* depending on the last character we tested we have either a subroutine
* call with no parameters or a subroutine call with parameters
    BEGIN CASE

* open parenthesis.  there's a parameter list following the subroutine
* name
        CASE THIS.CHAR = "("

* search ahead to find the end of this code bit
            END.PTR = PARAMETER.PTR + 1

            IN.QUOTES = @FALSE
            THIS.QUOTE = ""

            LOOP

                THIS.CHAR = THIS.LINE [END.PTR, 1]

                BEGIN CASE

* end of the line
                    CASE THIS.CHAR = ""
                        IN.QUOTES = @FALSE

* process quotes
                    CASE IN.QUOTES AND THIS.CHAR = THIS.QUOTE
                        IN.QUOTES = @FALSE
                        THIS.QUOTE = ""
                    CASE IN.QUOTES
                        NULL
                    CASE THIS.CHAR = '"' OR THIS.CHAR = "'"
                        IN.QUOTES = @TRUE
                        THIS.QUOTE = THIS.CHAR

                END CASE

            UNTIL NOT(IN.QUOTES) AND (THIS.CHAR = ";" OR THIS.CHAR = "")

                END.PTR += 1

            REPEAT

* the last character of this code bit is back one character
            END.PTR -= 1

* extract the parameters
            CALL.PARAMETERS = THIS.LINE [PARAMETER.PTR, END.PTR - PARAMETER.PTR + 1]
            CALL.PARAMETERS = TRIM(CALL.PARAMETERS, " ", "B")

* semicolon.  there are no parameters and the end of this line is back
* one character
        CASE THIS.CHAR = ";"
            END.PTR = PARAMETER.PTR - 1
            CALL.PARAMETERS = ""

* null.  we hit the end of the line.  there are no parameters and the
* end of the line is back one character
        CASE THIS.CHAR = ""
            END.PTR = PARAMETER.PTR - 1
            CALL.PARAMETERS = ""

* we hit something else.  this isn't an external subroutine call
        CASE 1
            RETURN

    END CASE

* if the parameter list is there but doesn't start with an open
* parenthesis and end with a closed parenthesis then we don't have an
* external subroutine call
    IF CALL.PARAMETERS <> "" THEN
        IF CALL.PARAMETERS [1, 1] <> "(" OR CALL.PARAMETERS [1] <> ")" THEN
            RETURN
        END
    END

* if we survived this far then we have an external subroutine call.
* build a sub-style method call and replace the standard call in the
* program line with the sub-style call
    NEW.CALL = "SUB::":CALL.NAME
    IF CALL.PARAMETERS <> "" THEN
        NEW.CALL := " ":CALL.PARAMETERS
    END

    NEW.LINE = THIS.LINE [1, CALL.PTR - 1]:NEW.CALL:THIS.LINE [END.PTR + 1, TO.THE.END]

* flag that we converted the call
    CONVERTED.CALL = @TRUE

    RETURN

**************************************************************************
**************************************************************************
** code conversion / objects / utilities                                **
**************************************************************************
**************************************************************************

GET.CHILD.MAX.INSTANCES: *************************************************
* get child.max.instances for this.child.name                            *
**************************************************************************
    CHILD.MAX.INSTANCES = 0

* fetch first line of the child object
    READV DEFINITION.LINE FROM OBJFILE, THIS.CHILD.NAME, 1 ELSE
        DEFINITION.LINE = ""
    END

    DEFINITION.LINE = TRIM(UPCASE(DEFINITION.LINE))

* first look for a number in parenthesis
    OPEN.PREN.PTR = INDEX(DEFINITION.LINE, "(", 1)
    CLOSE.PREN.PTR = INDEX(DEFINITION.LINE, ")", 1)

    IF OPEN.PREN.PTR <> 0 AND CLOSE.PREN.PTR <> 0 THEN
        CHILD.MAX.INSTANCES = DEFINITION.LINE [OPEN.PREN.PTR + 1, CLOSE.PREN.PTR - OPEN.PREN.PTR - 1]
        RETURN
    END

* look for the "instances" keyword
    DEFINITION.LINE = CHANGE(DEFINITION.LINE, " ", @AM)
    LOCATE "INSTANCES" IN DEFINITION.LINE SETTING INSTANCE.PTR THEN
        CHILD.MAX.INSTANCES = DEFINITION.LINE<INSTANCE.PTR + 1>
        RETURN
    END

* check for "resident" objects
    LOCATE "RESIDENT" IN DEFINITION.LINE SETTING INSTANCE.PTR THEN
        CHILD.MAX.INSTANCES = 1
        RETURN
    END

* nothing in the definition line.  use the default max.instances value
    CHILD.MAX.INSTANCES = DEFAULT.MAX.INSTANCES

    RETURN


**************************************************************************
**************************************************************************
** listings / object listing                                            **
**************************************************************************
**************************************************************************

LIST.CREATED.OBJECTS: ****************************************************
* list objects created by the program currently being compiled sorted    *
* by the object names                                                    *
**************************************************************************

* if we've already listed used objects for this object don't list it
* again
    LOCATE OBJECT.NAME IN LISTED.OBJECTS.FOR.LIST SETTING USED.PTR THEN
        RETURN
    END

    INS OBJECT.NAME BEFORE LISTED.OBJECTS.FOR.LIST<USED.PTR>

* build a list of unique objects so we can show what objects are
* used in a short list
    OBJECT.USED.LIST = ""
    OBJECT.USED.INSTANCE.COUNT = ""
    OBJECT.USED.COUNT = 0

    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        THIS.OBJECT = CREATE.OBJECT.LIST<CREATE.LOOP>

* add this object to the object used list
        IF THIS.OBJECT <> LOCAL.KEYWORD THEN

            LOCATE THIS.OBJECT IN OBJECT.USED.LIST BY "AL" SETTING FOUND.PTR ELSE
                OBJECT.USED.COUNT += 1
                INS THIS.OBJECT BEFORE OBJECT.USED.LIST<FOUND.PTR>
                INS "" BEFORE OBJECT.USED.INSTANCE.COUNT<FOUND.PTR>
            END

* increment the count for this object
            OBJECT.USED.INSTANCE.COUNT<FOUND.PTR> += 1

        END

    NEXT CREATE.LOOP

* build a sorted list of object handles
    SORTED.HANDLE.LIST = ""
    SORTED.PTR.LIST = ""

    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        THIS.HANDLE = CREATE.HANDLE.LIST<CREATE.LOOP>
        LOCATE THIS.HANDLE IN SORTED.HANDLE.LIST BY "AL" SETTING SORT.PTR ELSE
            NULL
        END

        INS THIS.HANDLE BEFORE SORTED.HANDLE.LIST<SORT.PTR>
        INS CREATE.LOOP BEFORE SORTED.PTR.LIST<SORT.PTR>

    NEXT CREATE.LOOP

* build a table of method comments
    GOSUB BUILD.METHOD.COMMENTS

* if we're only printing objects this is a special listing that only displays
* the objects used without saving any cbp programs or compiling
    BEGIN CASE

        CASE LIST.OBJECTS.ONLY AND COMPILE.OBJECT
            GOSUB SHORT.OBJECT.LISTING
            GOSUB SHORT.END.LISTING
        CASE LIST.OBJECTS.ONLY AND COMPILE.SUBROUTINE
            GOSUB SHORT.SUB.LISTING
            GOSUB SHORT.END.LISTING
        CASE LIST.OBJECTS.ONLY
            NULL

        CASE LIST.OBJECTS.WITH.COMPILE
            GOSUB DETAILED.OBJECT.LISTING

    END CASE

    RETURN

SHORT.OBJECT.LISTING: ****************************************************
* print "short" object listing.  lists objects used on one line.  this   *
* is used by other programs that need to know which objects are used     *
* by this routine.  arrays are listed with am's changed to commas,       *
* vm's changed to semi-colons and sm's changed to slashes                *                                                      *
**************************************************************************

* method.wrapper.list is associated with method.list.  it has null entries
* for methods that have no wrappers.  remove the null entries for a
* cleaner display
    DISPLAY.WRAPPER.LIST = METHOD.WRAPPER.LIST
    DISPLAY.WRAPPER.PARM.LIST = METHOD.WRAPPER.PARM.LIST
    DISPLAY.WRAPPER.PARM.COUNT.LIST = METHOD.WRAPPER.PARM.COUNT.LIST

    DISPLAY.COUNT = DCOUNT(DISPLAY.WRAPPER.LIST, @AM)

    FOR DISPLAY.LOOP = DISPLAY.COUNT TO 1 STEP -1

        IF DISPLAY.WRAPPER.LIST<DISPLAY.LOOP> = "" THEN

            DEL DISPLAY.WRAPPER.LIST<DISPLAY.LOOP>
            DEL DISPLAY.WRAPPER.PARM.LIST<DISPLAY.LOOP>
            DEL DISPLAY.WRAPPER.PARM.COUNT.LIST<DISPLAY.LOOP>

        END

    NEXT DISPLAY.LOOP

    GOSUB SHORT.SUB.LISTING

* method table list
    PRINT
    PRINT "Methods:"
    PRINT FORMAT.ARRAY (METHOD.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.COUNT.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.DEFAULT.LIST)
    PRINT FORMAT.ARRAY (METHOD.START.LINE)
    PRINT FORMAT.ARRAY (METHOD.END.LINE)
    PRINT FORMAT.ARRAY (METHOD.PROGRAM.START.LINE)
    PRINT FORMAT.ARRAY (METHOD.SECTION.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.OPTIONAL.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.SET.LIST)
    PRINT FORMAT.ARRAY (METHOD.PARM.BYREF.LIST)
    PRINT FORMAT.ARRAY (METHOD.COMMENT.TABLE)
    
* wrapper table list
    PRINT
    PRINT "Wrappers:"
    PRINT FORMAT.ARRAY (DISPLAY.WRAPPER.LIST)
    PRINT FORMAT.ARRAY (DISPLAY.WRAPPER.PARM.LIST)
    PRINT FORMAT.ARRAY (DISPLAY.WRAPPER.PARM.COUNT.LIST)

* print out the property table
    PRINT
    PRINT "Properties:"
    PRINT FORMAT.ARRAY (PROP.NAME.LIST)
    PRINT FORMAT.ARRAY (PROP.DIM.LIST)
    PRINT FORMAT.ARRAY (PROP.TYPE.LIST)
    PRINT FORMAT.ARRAY (PROP.LINE.LIST)
    PRINT FORMAT.ARRAY (PROP.KEYWORD.LIST)

* print out the constant table
    PRINT
    PRINT "Constants:"
    PRINT FORMAT.ARRAY (CONSTANT.NAME.LIST)
    PRINT FORMAT.ARRAY (CONSTANT.VALUE.LIST)
    PRINT FORMAT.ARRAY (CONSTANT.LINE.LIST)

* print default methods
    PRINT
    PRINT "Default Methods:"
    PRINT FORMAT.ARRAY (DEFAULT.METHOD.LIST)

* label table
    PRINT
    PRINT "Labels:"
    PRINT FORMAT.ARRAY (LABEL.LIST)
    PRINT FORMAT.ARRAY (LABEL.LINE.LIST)

* eclipse common variables
    PRINT
    PRINT "Eclipse Common:"
    PRINT FORMAT.ARRAY (ECLIPSE.COMMON.NAME.LIST)

* eclipse constants
    PRINT
    PRINT "Eclipse Constant:"
    PRINT FORMAT.ARRAY (EQUATE.CONSTANT.LIST)

    RETURN

SHORT.SUB.LISTING: *******************************************************
* print out table data for an object-enabled subroutine.  this           *
* is used by other programs that need to know which objects are used     *
* by this routine.  arrays are listed with am's changed to commas,       *
* vm's changed to semi-colons and sm's changed to slashes                *                                                      *
**************************************************************************

* do not change this header!  it's used by other programs to find where
* the object list is in the compiler output
    PRINT "Objects Used:"
    PRINT FORMAT.ARRAY (OBJECT.USED.LIST)

    PRINT "Create Object List:"
    PRINT FORMAT.ARRAY (CREATE.HANDLE.LIST)
    PRINT FORMAT.ARRAY (CREATE.VARIABLE.LIST)
    PRINT FORMAT.ARRAY (CREATE.DIMENSIONED.LIST)
    PRINT FORMAT.ARRAY (CREATE.DIM.VAR.LIST)
    PRINT FORMAT.ARRAY (CREATE.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.DEFINED.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.LINE.LIST)
    PRINT FORMAT.ARRAY (CREATE.TYPE.LIST)
    PRINT FORMAT.ARRAY (CREATE.OBJECT.LIST)
    PRINT FORMAT.ARRAY (CREATE.LABEL.LIST)
    PRINT FORMAT.ARRAY (CREATE.INDENT.LIST)
    PRINT FORMAT.ARRAY (CREATE.WITH.LIST)
    PRINT FORMAT.ARRAY (CREATE.ADDITIONAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.KEYWORD.LIST)
    PRINT FORMAT.ARRAY (CREATE.CREATED.WITH.LIST)

    PRINT
    PRINT "Created Child Object List:"
    PRINT FORMAT.ARRAY (CREATE.CHILD.NAME.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.PARENT.HANDLE.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.HANDLE.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.VARIABLE.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.DIM.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.DEFINED.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.LINE.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.ADDITIONAL.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.KEYWORD.LIST)
    PRINT FORMAT.ARRAY (CREATE.CHILD.CREATED.WITH.LIST)

    PRINT
    PRINT "Child Object List:"
    PRINT FORMAT.ARRAY (CHILD.NAME.LIST)
    PRINT FORMAT.ARRAY ("")
    PRINT FORMAT.ARRAY (CHILD.HANDLE.LIST)
    PRINT FORMAT.ARRAY (CHILD.VARIABLE.LIST)
    PRINT FORMAT.ARRAY (CHILD.DIM.LIST)
    PRINT FORMAT.ARRAY (CHILD.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CHILD.DEFINED.LOCAL.LIST)
    PRINT FORMAT.ARRAY (CHILD.LINE.LIST)
    PRINT FORMAT.ARRAY (CHILD.ADDITIONAL.LIST)
    PRINT FORMAT.ARRAY (CHILD.KEYWORD.LIST)

    PRINT
    PRINT "Handle List:"
    PRINT FORMAT.ARRAY (HANDLE.LIST)
    PRINT FORMAT.ARRAY (HANDLE.VARIABLE.LIST)
    PRINT FORMAT.ARRAY (HANDLE.OBJECT.LIST)
    PRINT FORMAT.ARRAY (HANDLE.METHOD.LIST)
    PRINT FORMAT.ARRAY (HANDLE.PARAMETER.LIST)
    PRINT FORMAT.ARRAY (HANDLE.PARAMETER.BYVAL.LIST)
    PRINT FORMAT.ARRAY (HANDLE.KEYWORD.LIST)
    PRINT FORMAT.ARRAY (HANDLE.TYPE.LIST)
    PRINT FORMAT.ARRAY (HANDLE.DIMENSIONS.LIST)

    PRINT FORMAT.ARRAY (HANDLE.OUTPUT.PARAMETER.LIST)
    PRINT FORMAT.ARRAY (HANDLE.OUTPUT.COUNT.LIST)

* inlined routines
    PRINT
    PRINT "Inlined:"
    PRINT FORMAT.ARRAY (INLINE.OBJECT.LIST)
    PRINT FORMAT.ARRAY (INLINE.METHOD.LIST)
    PRINT FORMAT.ARRAY (INLINE.SUBROUTINE.LIST)

    RETURN

SHORT.END.LISTING: *******************************************************
* show and "end" line to mark the end of the short listing               *
**************************************************************************
    PRINT
    PRINT "End:"

    RETURN

DETAILED.OBJECT.LISTING: *************************************************
* print "detailed" object listing.  this is used during compiles to show *
* what objects are involved in the compile.  first lists the object      *
* instances used by object handles.  then it lists unique objects used   *
* and a count of instances for each object.                              *
**************************************************************************
    PRINT "Objects Used:"

    IF CREATE.COUNT = 0 THEN
        PRINT "    None"
        PRINT
        RETURN
    END

* find the longest object handle so we know how wide to make the first
* column
    CREATE.WIDTH = 20

    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        THIS.WIDTH = LEN(CREATE.HANDLE.LIST<CREATE.LOOP>)

        IF THIS.WIDTH > CREATE.WIDTH THEN
            CREATE.WIDTH = THIS.WIDTH
        END

    NEXT CRATE.LOOP

    OBJECT.MASK = "L#":CREATE.WIDTH

* heading for the object handle list
    TEXT = CREATE.COUNT:" Object Instance"
    IF CREATE.COUNT <> 1 THEN
        TEXT := "s"
    END

    PRINT "    ":
    PRINT TEXT OBJECT.MASK:" ":

    PRINT "Object Name":
    IF CREATE.COUNT <> 1 THEN
        PRINT "s":
    END
    PRINT

* list object handles and their object names
    FOR CREATE.LOOP = 1 TO CREATE.COUNT

        HANDLE.PTR = SORTED.PTR.LIST<CREATE.LOOP>

        PRINT "    ":
        PRINT CREATE.HANDLE.LIST<HANDLE.PTR> OBJECT.MASK:" ":
        PRINT CREATE.OBJECT.LIST<HANDLE.PTR>

    NEXT CREATE.LOOP

    PRINT

* heading for the object list
    TEXT = OBJECT.USED.COUNT:" Object"
    IF OBJECT.USED.COUNT <> 1 THEN
        TEXT := "s"
    END

    PRINT "    ":
    PRINT TEXT OBJECT.MASK:" ":
    PRINT "InstanceCount"

* list objects
    FOR CREATE.LOOP = 1 TO OBJECT.USED.COUNT

        PRINT "    ":
        PRINT OBJECT.USED.LIST<CREATE.LOOP> OBJECT.MASK:" ":

        THIS.INSTANCE.COUNT = OBJECT.USED.INSTANCE.COUNT<CREATE.LOOP>
        DISPLAY.COUNT = THIS.INSTANCE.COUNT "R#2":" Instance"
        IF THIS.INSTANCE.COUNT <> 1 THEN
            DISPLAY.COUNT := "s"
        END
        PRINT DISPLAY.COUNT "L#13"

    NEXT CREATE.LOOP

    PRINT

    RETURN

BUILD.METHOD.COMMENTS: ***************************************************
* build method.comment.table with a table of comments for each method    *
**************************************************************************
    METHOD.COMMENT.TABLE = ""

    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<METHOD.LOOP>
        GOSUB BUILD.ONE.METHOD.COMMENTS

        METHOD.COMMENT.TABLE<METHOD.LOOP> = LOWER(METHOD.COMMENTS)

    NEXT METHOD.LOOP

    RETURN

BUILD.ONE.METHOD.COMMENTS: ***********************************************
* build method.comments table with comments for this.method              *
**************************************************************************
    FOUND.COMMENTS = @FALSE 
    METHOD.COMMENTS = ""
    METHOD.COMMENT.COUNT = 0

    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* add method comment code into the .net method.  we'll start
* with the method's starting line and stop one line before the program
* code starts
    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR> - 1
    THIS.METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.PTR>

* if this is an inherited method fetch the called code from the object
* the method is inherited from
    IF THIS.METHOD.INHERITED THEN

        THIS.INHERIT.OBJECT = METHOD.INHERIT.OBJECT.LIST<METHOD.PTR>

        READ THIS.CALLED.CODE FROM OBJFILE, THIS.INHERIT.OBJECT ELSE
            THIS.CALLED.CODE = ""
        END

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = THIS.CALLED.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = ""
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = THIS.CALLED.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimiter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(THIS.CALLED.CODE, @AM, START.LINE - 1)
        END

        SETREM START.PTR ON THIS.CALLED.CODE
        FOR ADD.LINE.LOOP = START.LINE TO END.LINE

            REMOVE CODE FROM THIS.CALLED.CODE SETTING THROWAWAY

            IF TRIM(CODE) = "" THEN
                ADD.LINE.LOOP = END.LINE + 1
            END

        NEXT ADD.LINE.LOOP

    END ELSE

* start.ptr may be on an empty line.  if the "method" statement wrapped
* around object.code<start.line> may be null as the parameters were
* wrapped up to the "method" line.  if start.ptr is on an empty line skip
* ahead until we're on a line that's not null
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL TRIM(THIS.COMMENT) <> "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if start.ptr isn't on a comment move ahead until it is
        LOOP
            THIS.COMMENT = OBJECT.CODE<START.LINE>
        UNTIL THIS.COMMENT [1, 1] = "*" OR TRIM(THIS.COMMENT) = "" OR START.LINE >= END.LINE
            START.LINE += 1
        REPEAT

* if the first comment line is all stars skip it
        FIRST.COMMENT = OBJECT.CODE<START.LINE>
        IF TRIM(TRIM(FIRST.COMMENT), "*") = "" THEN
            START.LINE += 1
        END

* find the location of the character after the delimter before start.line
        IF START.LINE = 1 THEN
            START.PTR = 0
        END ELSE
            START.PTR = INDEX(OBJECT.CODE, @AM, START.LINE - 1)
        END

* add comments to the method.comments array
        SETREM START.PTR ON OBJECT.CODE

        FOR ADD.LINE.LOOP = START.LINE TO END.LINE
    
*           CODE = OBJECT.CODE<ADD.LINE.LOOP>
            REMOVE CODE FROM OBJECT.CODE SETTING THROWAWAY

* if we hit a null line stop adding comments.  if we hit a code line stop
* adding comments.  otherwise add the comment line to the dotnet code
            BEGIN CASE

                CASE TRIM(CODE) = ""
                    ADD.LINE.LOOP = END.LINE + 1

                CASE IS.CODE(CODE)
                    ADD.LINE.LOOP = END.LINE + 1
            
                CASE 1
                    CODE = TRIM(CODE, "*", "B")
                    METHOD.COMMENT.COUNT += 1
                    METHOD.COMMENTS<METHOD.COMMENT.COUNT> = CODE

            END CASE

        NEXT ADD.LINE.LOOP

    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / check for creation                       **
**************************************************************************
**************************************************************************

CHECK.FOR.OBJECT.CREATION: ***********************************************
* check this.line to see if it creates / destroys an object.  returns    *
* object.created true if it does                                         *
**************************************************************************
* i couldn't decide which syntax to use for creating objects so I        *
* supported all of them.  choose whichever one works for you:            *
*                                                                        *
*    NEW objectname objecthandle                                         *
*    objecthandle = NEW objectname                                       *
*    objecthandle = NEW(objectname)                                      *
*    objecthandle = NEW (objectname)                                     *
*                                                                        *
*    OLD can use all the same syntaxes as new                            *
*                                                                        *
* destroy is always done using this syntax:                              *
*                                                                        *
*    objecthandle::DESTROY                                               *
*                                                                        *
* although it will work with the other syntaxes it looks odd             *
**************************************************************************
    OBJECT.CREATED = @FALSE
    OBJECT.NAME.VALID = @FALSE

* skip lines that are blanks or obvious comments
    TRIM.THIS.LINE = TRIM(THIS.LINE)

    BEGIN CASE
        CASE TRIM.THIS.LINE = ""
            RETURN
        CASE TRIM.THIS.LINE [1, 1] = "*" OR TRIM.THIS.LINE [1, 1] = "!"
            RETURN
    END CASE

    CLEAN.LINE = THIS.LINE
    GOSUB CLEAN.LINE

* look for object creation, naming or destroy as the first word in the line

* if there's an assignment operator here we may have a handle = new object
* assignment.  i've supported a number of syntaxes for declaring a new item
* because I couldn't decide which one i liked best.  reparse.create.line
* takes all the different parsing options and reparses them into the same
* form of "NEW objectname objecthandle additional.parameters"
    GOSUB REPARSE.CREATE.LINE

* get first two words.  if this line is creating an object the first word
* will be a "NEW", "OLD" or "DESTROY" keyword and the next word will
* be the object name.  the third word will be the object handle
    KEY.WORD = CLEAN.LINE [" ", 1, 1]
    NEXT.WORD = CLEAN.LINE [" ", 2, 1]

* does this line start with one of our create / old / destroy keywords?
* if not we'll dump out
    IF KEY.WORD <> NEW.KEYWORD AND KEY.WORD <> NEW.MULTI.THREAD.KEYWORD THEN 
        IF KEY.WORD <> NEW.RESIDENT.KEYWORD AND KEY.WORD <> NEW.NOW.KEYWORD THEN
            IF KEY.WORD <> OLD.KEYWORD AND KEY.WORD <> OLD.MULTI.THREAD.KEYWORD THEN
                IF KEY.WORD <> DESTROY.KEYWORD THEN
                    RETURN
                END
            END
        END
    END

* this line is creating or destroying an object.  get the keyword, object
* name and object handle as well as the statement that created it
    OBJECT.CREATED = @TRUE
    THIS.OBJECT.NAME = ""
    THIS.OBJECT.HANDLE = ""
    OBJECT.CREATED.WITH = KEY.WORD

    BEGIN CASE

* name and keyword for "NEW" expressions
        CASE KEY.WORD = NEW.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = CLEAN.LINE [" ", 4, TO.THE.END]

* name and keyword for "NEW.THREAD" expressions
        CASE KEY.WORD = NEW.MULTI.THREAD.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = CLEAN.LINE [" ", 4, TO.THE.END]

* name and keyword the "NEW.RESIDENT" expressions
        CASE KEY.WORD = NEW.RESIDENT.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = CLEAN.LINE [" ", 4, TO.THE.END]

* name and keyword the "NEW.NOW" expressions
        CASE KEY.WORD = NEW.NOW.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = CLEAN.LINE [" ", 4, TO.THE.END]

* name and keyword for "OLD" expressions
        CASE KEY.WORD = OLD.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = ""

* name and keyword for "OLD.THREAD" expressions
        CASE KEY.WORD = OLD.MULTI.THREAD.KEYWORD
            THIS.OBJECT.NAME = CLEAN.LINE [" ", 2, 1]
            THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 3, 1]
            ADDITIONAL.PARAMETERS = ""

* "DESTROY" expressions
        CASE KEY.WORD = DESTROY.KEYWORD
            THIS.OBJECT.NAME = ""
            THIS.OBJECT.HANDLE = ""
            ADDITIONAL.PARAMETERS = ""

    END CASE

* how many spaces are in the program line after the label?
    INDENT.COUNT = FIND.INDENT.COUNT (CLEAN.LABEL, THIS.LINE)

* is this object handle dimensioned?  if it is then save the object handle
* as "handle()", without the dimensioned reference, so we can search
* for it more easily later
    PREN.PTR = INDEX(THIS.OBJECT.HANDLE,"(",1)

    IF PREN.PTR > 0 THEN
        THIS.OBJECT.DIMENSIONED = @TRUE
        THIS.OBJECT.DIM.VAR = THIS.OBJECT.HANDLE [PREN.PTR, TO.THE.END]
        THIS.OBJECT.HANDLE = TRIM(THIS.OBJECT.HANDLE [1, PREN.PTR - 1]):"()"
    END ELSE
        THIS.OBJECT.DIM.VAR = ""
        THIS.OBJECT.DIMENSIONED = @FALSE
    END

* does the object name point to a valid object code file in the obj file?
    IF THIS.OBJECT.NAME <> "" THEN

        READV TEST.REC FROM OBJFILE, THIS.OBJECT.NAME, 0 THEN
            OBJECT.NAME.VALID = @TRUE
        END ELSE
            OBJECT.ERROR.DESC = '"':THIS.OBJECT.NAME:'"':" is not a valid Object Name"
            OBJECT.ERROR.LINE = PTR
            SHOW.REFERENCE = @FALSE
            GOSUB PRINT.OBJECT.ERROR
        END

    END

    RETURN

REPARSE.CREATE.LINE: *****************************************************
* potentially reparse clean.line into a different syntax.                *
* check.for.object.creation looks for object creation with the synatx    *
* of "NEW objectname objecthandle".  this routine allows these other     *
* syntaxes:                                                              *
*                                                                        *
*    objecthandle = NEW objectname additional.parameters                 *
*    objecthandle = NEW(objectname, additional.parameters)               *
*    objecthandle = NEW (objectname, additional.parameters)              *
*    objecthandle::NEW(objectname, additional.parameters)                *
*    objecthandle::NEW (objectname, additional.parameters)               *
*                                                                        *
* additional.parameters is/are optional.  if defined they will be passed *
* as multivalues in the object handle in attribute 4                     *
*                                                                        *
* if one of these other syntaxes is detected then clean.line is          *
* reformatted with the "NEW objectname objecthandle" syntax              *
**************************************************************************
    ADDITIONAL.PARAMETERS = ""
    KEY.WORD = CLEAN.LINE [" ", 1, 1]
    NEXT.WORD = CLEAN.LINE [" ", 2, 1]
    CREATE.REPARSED = @FALSE

    DELIMITER.PTR = INDEX(KEY.WORD, METHOD.DELIMITER, 1)

* if there's a method delimiter in the key.word then we may have the
* form "objecthandle::NEW(objectname)"
    IF DELIMITER.PTR > 0 THEN

* get object handle from before the delimiter and the key.word and
* object name from after
        THIS.OBJECT.HANDLE = KEY.WORD [1, DELIMITER.PTR - 1]
        KEY.WORD = KEY.WORD [DELIMITER.PTR + METHOD.DEL.LENGTH, TO.THE.END]

* don't reparse destroy commands
        IF KEY.WORD = DESTROY.KEYWORD THEN
            RETURN
        END

* if key.word has an open parenthesis right after the keyword (NEW, OLD,
* etc) then we have the form "NEW(objectname)".  if not we might have the
* form "NEW (objectname)"
        IF COUNT(KEY.WORD, "(") > 0 THEN
            THIS.OBJECT.NAME = TRIM(KEY.WORD ["(", 2, TO.THE.END], " ", "B")
            THIS.OBJECT.NAME = THIS.OBJECT.NAME [1, LEN(THIS.OBJECT.NAME) - 1]
            KEY.WORD = TRIM(KEY.WORD ["(", 1, 1], " ", "B")
        END ELSE
            THIS.OBJECT.NAME = NEXT.WORD
        END

* if object name has parenthesis around it remove the parenthesis
        IF THIS.OBJECT.NAME [1, 1] = "(" AND THIS.OBJECT.NAME [1] = ")" THEN
            THIS.OBJECT.NAME = THIS.OBJECT.NAME [2, LEN(THIS.OBJECT.NAME) - 2]
        END

* if there are additional.parameters in the new statement there will be
* a comma object.name
        THIS.OBJECT.NAME = SMART.TRIM (THIS.OBJECT.NAME)

        IF COUNT(THIS.OBJECT.NAME, ",") <> 0 THEN
            ADDITIONAL.PARAMETERS = TRIM(THIS.OBJECT.NAME [",", 2, TO.THE.END], " ", "B")
            THIS.OBJECT.NAME = TRIM(THIS.OBJECT.NAME [",", 1, 1], " ", "B")
        END

        CREATE.REPARSED = @TRUE

* rebuild clean.line with the "NEW objectname objecthandle" synatx since
* it's easier to parse
        CLEAN.LINE = KEY.WORD:" ":THIS.OBJECT.NAME:" ":THIS.OBJECT.HANDLE
        IF ADDITIONAL.PARAMETERS <> "" THEN
            CLEAN.LINE := " ":ADDITIONAL.PARAMETERS
        END

        RETURN

    END

* if there's an assignment operator here we may have a handle = new object
* assignment.  if not don't reparse anything
    IF NEXT.WORD <> "=" THEN
        RETURN
    END

* we must have the form object.handle = new(object.name).  try to reparse 
* this line
    CREATE.REPARSED = @TRUE

* get the keyword after the equals sign
    KEY.WORD = CLEAN.LINE [" ", 3, TO.THE.END]

* if key.word has an open pren in it then it may be formed as
* objecthandle = NEW(objectname).  if we see the open open pull the object
* name from the key.word and remove the closing pren
    IF COUNT(KEY.WORD, "(") <> 0 THEN

        THIS.OBJECT.NAME = KEY.WORD ["(", 2, TO.THE.END]

        IF THIS.OBJECT.NAME [1] = ")" THEN
            THIS.OBJECT.NAME = THIS.OBJECT.NAME [1, LEN(THIS.OBJECT.NAME) - 1]
            THIS.OBJECT.NAME = TRIM(THIS.OBJECT.NAME, " ", "B")
        END

        KEY.WORD = TRIM(KEY.WORD ["(", 1, 1], " ", "B")

    END ELSE

* if there's no opening pren then the line is formatted as
* "objecthandle = NEW objectname" or "objecthandle = NEW (objectname)".
        THIS.OBJECT.NAME = CLEAN.LINE [" ", 4, 1]

* if the creation line is formatted as "objecthandle = NEW (objectname)"
* then this.object.name will have parenthesis around it.  remove them
* but only if there's a leading open parenthesis
        IF THIS.OBJECT.NAME [1, 1] = "(" AND THIS.OBJECT.NAME [1] = ")" THEN
            THIS.OBJECT.NAME = THIS.OBJECT.NAME [2, LEN(THIS.OBJECT.NAME) - 2]
        END

    END

* if there are any additional parameters this.object.name will have a comma
* in it
    THIS.OBJECT.NAME = SMART.TRIM(THIS.OBJECT.NAME)

    IF COUNT(THIS.OBJECT.NAME, ",") <> 0 THEN
        ADDITIONAL.PARAMETERS = TRIM(THIS.OBJECT.NAME [",", 2, TO.THE.END], " ", "B")
        THIS.OBJECT.NAME = TRIM(THIS.OBJECT.NAME [",", 1, 1], " ", "B")
    END

* in the "objecthandle = NEW objectname" syntax the object handle will be
* the first field
    THIS.OBJECT.HANDLE = CLEAN.LINE [" ", 1, 1]

* rebuild clean.line with the "NEW objectname objecthandle" synatx since
* it's easier to parse
    CLEAN.LINE = KEY.WORD:" ":THIS.OBJECT.NAME:" ":THIS.OBJECT.HANDLE

    IF ADDITIONAL.PARAMETERS <> "" THEN
        CLEAN.LINE := " ":ADDITIONAL.PARAMETERS
    END

    RETURN


**************************************************************************
**************************************************************************
** code analysis / build label table                                    **
**************************************************************************
**************************************************************************

BUILD.LABEL.TABLE: *******************************************************
* build a table of all labels in program.code.  also builds a list of    *
* any functions defined.  if include.instance.code.labels is false       *
* labels from the instance code will not be included                     *
**************************************************************************
    LABEL.LIST = ""
    LABEL.LINE.LIST = ""
    LABEL.COUNT = 0

    FUNCTION.LIST = ""
    FUNCTION.LINE.LIST = ""
    FUNCTION.COUNT = 0

    INVALID.LABEL.CHARS = "<>=();'":'"'

* add labels from the program code
    SETREM 0 ON PROGRAM.CODE

    FOR LINE.LOOP = 1 TO PROGRAM.CODE.LINES

*       THIS.LINE = PROGRAM.CODE<LINE.LOOP>
        REMOVE THIS.LINE FROM PROGRAM.CODE SETTING THROWAWAY

        DEFAULT.CALLED = @FALSE
        GOSUB ADD.LABEL

    NEXT LINE.LOOP

* add labels from the instance code if we're compiling an object
    IF COMPILE.OBJECT AND INCLUDE.INSTANCE.CODE.LABELS THEN

        SETREM 0 ON INSTANCE.CODE

        FOR LINE.LOOP = 1 TO INSTANCE.LINE.COUNT

            REMOVE THIS.LINE FROM INSTANCE.CODE SETTING THROWAWAY

            DEFAULT.CALLED = @TRUE
            GOSUB ADD.LABEL

        NEXT LINE.LOOP

    END

* if we're compiling a subroutine or an object method add in labels for 
* exit.if.error.message and exit.to.calling program if they're not already
* in there
    IF COMPILE.SUBROUTINE OR COMPILE.OBJECT THEN

        LOCATE EXIT.ON.ERROR.GOSUB.NAME IN LABEL.LIST SETTING THROWAWAY ELSE
            LABEL.COUNT += 1
            LABEL.LIST<LABEL.COUNT> = EXIT.ON.ERROR.GOSUB.NAME
            LABEL.CALLED.LIST<LABEL.COUNT> = @TRUE
            LABEL.LINE.LIST<LABEL.COUNT> = ""
        END

        LOCATE EXIT.OUT.GOSUB.NAME IN LABEL.LIST SETTING THROWAWAY ELSE
            LABEL.COUNT += 1
            LABEL.LIST<LABEL.COUNT> = EXIT.OUT.GOSUB.NAME
            LABEL.CALLED.LIST<LABEL.COUNT> = @TRUE
            LABEL.LINE.LIST<LABEL.COUNT> = ""
        END

        IF ENABLE.ERROR.THROWS THEN

            IF ADD.CATCH.ERROR.ROUTINE AND CATCH.ERROR.GOSUB.NAME <> "" THEN

                LOCATE CATCH.ERROR.GOSUB.NAME IN LABEL.LIST SETTING THROWAWAY ELSE
                    LABEL.COUNT += 1
                    LABEL.LIST<LABEL.COUNT> = CATCH.ERROR.GOSUB.NAME
                    LABEL.CALLED.LIST<LABEL.COUNT> = @TRUE
                    LABEL.LINE.LIST<LABEL.COUNT> = ""
                END

            END

        END

    END

    IF DETAILS THEN
        GOSUB PRINT.LABEL.LIST
    END

    RETURN

ADD.LABEL: ***************************************************************
* check this.line for a label and add it to the label table if there is  *
* a label                                                                *
**************************************************************************

* skip any obvious lines that won't have labels
    TRIM.THIS.LINE = TRIM(THIS.LINE)
    FIRST.CHAR = TRIM.THIS.LINE [1, 1]

    BEGIN CASE
        CASE TRIM.THIS.LINE = ""
            RETURN
        CASE FIRST.CHAR = "*" OR FIRST.CHAR = "!"
            RETURN
    END CASE

* if this line has a label add it to the label table
    THIS.LABEL = LINE.LABEL (THIS.LINE)

    IF THIS.LABEL <> "" THEN

* alpha labels will be followed by a colon, numeric labels will not.  if 
* the label ends with a colon remove it
        IF THIS.LABEL [1] = ":" THEN
            THIS.LABEL = THIS.LABEL [1, LEN(THIS.LABEL) - 1]
        END

* add the label to the label table
        LABEL.COUNT += 1

        LABEL.LIST<LABEL.COUNT> = THIS.LABEL
        LABEL.CALLED.LIST<LABEL.COUNT> = DEFAULT.CALLED
        LABEL.LINE.LIST<LABEL.COUNT> = LINE.LOOP

    END

* if this line starts a function add to the function table
    FIRST.KEYWORD = UPCASE(TRIM.THIS.LINE [" ", 1, 1])

    IF FIRST.KEYWORD = "FUNCTION" THEN

        FUNCTION.NAME = UPCASE(TRIM.THIS.LINE [" ", 2, 1] ["(", 1, 1])

        FUNCTION.COUNT += 1

        FUNCTION.LIST<FUNCTION.COUNT> = FUNCTION.NAME
        FUNCTION.LINE.LIST<FUNCTION.COUNT> = LINE.LOOP

    END

    RETURN

PRINT.LABEL.LIST: ********************************************************
* print out the label list for debugging                                 *
**************************************************************************
    PRINT
    PRINT "Label List:"
    PRINT "Label......................... Line...."

    FOR LABEL.LOOP = 1 TO LABEL.COUNT
        PRINT LABEL.LIST<LABEL.LOOP> "L#30":" ":
        PRINT LABEL.LINE.LIST<LABEL.LOOP> "R,#10"
    NEXT LABEL.LOOP

    GOSUB WAIT

    RETURN


**************************************************************************
**************************************************************************
** code analysis / compile table                                        **
**************************************************************************
**************************************************************************

CLEAR.COMPILE.TABLE: *****************************************************
* clear the compile tables                                               *
**************************************************************************
    COMPILE.METHOD.LIST = ""

    COMPILE.METHOD.PARAMETER.LIST = ""
    COMPILE.METHOD.DEFAULT.LIST = ""
    COMPILE.METHOD.SET.LIST = ""
    COMPILE.METHOD.IN.LIST = ""
    COMPILE.METHOD.OPTIONAL.LIST = ""
    COMPILE.METHOD.BYREF.LIST = ""
    COMPILE.METHOD.SPECIAL.LIST = ""

    COMPILE.METHOD.PROPERTY.LIST = ""
    COMPILE.METHOD.DIM.LIST = ""
    COMPILE.METHOD.TYPE.LIST = ""
    COMPILE.METHOD.LOCAL.LIST = ""

    COMPILE.METHOD.DATE.LIST = ""
    COMPILE.METHOD.TIME.LIST = ""
    COMPILE.METHOD.CHECKSUM.LIST = ""
    COMPILE.METHOD.USER.LIST = ""

    COMPILE.NEW.CHECKSUM.LIST = ""
    COMPILE.ECLIPSE.CHECKSUM.LIST = ""
    COMPILE.ECLIPSE.COMMON.CHECKSUM.LIST = ""

    COMPILE.CHANGED.LIST = ""

    COMPILE.VERSION = ""

    COMPILE.METHOD.COUNT = 0

    RETURN

BUILD.COMPILE.TABLE: *****************************************************
* build the compile table from the code or from ud.compile.dates         *
* depending on the compile settings                                      *
**************************************************************************
    IF USE.COMPILE.TABLE.IN.FILE AND UD.COMPILE.DATES.EXISTS THEN
        GOSUB BUILD.COMPILE.TABLE.FROM.FILE
    END ELSE
        GOSUB BUILD.COMPILE.TABLE.FROM.CODE
    END

    RETURN

BUILD.COMPILE.TABLE.FROM.CODE: *******************************************
* build a table from the end of the object code definition with a table  *
* of the last compile date and times and checksums for each method       *
**************************************************************************
    GOSUB GET.COMPILE.TABLE.PARAMETERS
    GOSUB CLEAR.COMPILE.TABLE

* find the compile table in the object code.  if we can't find both
* the start and end of the compile table we'll assume there isn't
* one
    LOCATE START.COMPILE.STRING IN OBJECT.CODE SETTING START.PTR ELSE
        RETURN
    END

    LOCATE END.COMPILE.STRING IN OBJECT.CODE SETTING END.PTR ELSE
        RETURN
    END

* loop between the start and end and build a table with the method
* data.  it will be listed method name, checksum, last change date,
* last change time, delimited by spaces
    FOR LINE.LOOP = START.PTR + 1 TO END.PTR - 1

        THIS.LINE = TRIM(OBJECT.CODE<LINE.LOOP>)

        THIS.METHOD = THIS.LINE [" ", 2, 1] 

        THIS.CHECKSUM = THIS.LINE [" ", 3, 1]
        THIS.DATE = ICONV(THIS.LINE [" ", 4, 1], "D")
        THIS.TIME = ICONV(THIS.LINE [" ", 5, 1], "MT")
        THIS.USER = THIS.LINE [" ", 6, 1]

        THIS.SUBROUTINE = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:THIS.METHOD

        GOSUB GET.METHOD.PARAMETERS

* add the method to our compile table.  the compile table has a heading
* row to label each column.  if we're on the heading row we won't update
* the compile table
        IF THIS.METHOD <> "" AND THIS.METHOD <> "Method" THEN
            GOSUB ADD.TO.COMPILE.TABLE
        END

    NEXT LINE.LOOP

    RETURN

BUILD.COMPILE.TABLE.FROM.FILE: *******************************************
* build the compile table using the ud.compile.dates file                *
**************************************************************************
    GOSUB GET.COMPILE.TABLE.PARAMETERS
    GOSUB CLEAR.COMPILE.TABLE

    GOSUB SELECT.COMPILE.DATES.DETAIL

    LOOP WHILE READNEXT COMPILE.ID FROM SLIST DO

        READ COMPILE.RECORD FROM COMPILEDATESFILE, COMPILE.ID THEN

            THIS.METHOD = COMPILE.RECORD<2>

            THIS.CHECKSUM = COMPILE.RECORD<6>
            THIS.DATE = COMPILE.RECORD<3>
            THIS.TIME = COMPILE.RECORD<4>
            THIS.USER = COMPILE.RECORD<5>

            THIS.SUBROUTINE = COMPILE.RECORD<7>

            GOSUB GET.METHOD.PARAMETERS

            GOSUB ADD.TO.COMPILE.TABLE

        END

    REPEAT

    RETURN

GET.METHOD.PARAMETERS: ***************************************************
* fetch method parameters for this.method for building the compile       *
* table                                                                  *
**************************************************************************
    THIS.PARAMETER = ""

    THIS.OPTIONAL = ""
    THIS.DEFAULT = ""
    THIS.SET = ""
    THIS.IN = ""

    THIS.BYREF = ""
    THIS.SPECIAL = ""

    THIS.PROPERTY.LIST = ""
    THIS.DIM.LIST = ""
    THIS.TYPE.LIST = ""
    THIS.LOCAL.LIST = ""

    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

    THIS.PARAMETER = METHOD.PARM.LIST<METHOD.PTR>

    THIS.OPTIONAL = METHOD.PARM.OPTIONAL.LIST<METHOD.PTR>
    THIS.DEFAULT = METHOD.PARM.DEFAULT.LIST<METHOD.PTR>
    THIS.SET = METHOD.PARM.SET.LIST<METHOD.PTR>
    THIS.IN = ""

    THIS.BYREF = METHOD.PARM.BYREF.LIST<METHOD.PTR>
    THIS.SPECIAL = METHOD.PARM.SPECIAL.LIST<METHOD.PTR>

    THIS.PROPERTY.LIST = PROP.NAME.LIST
    THIS.DIM.LIST = PROP.DIM.LIST
    THIS.TYPE.LIST = PROP.TYPE.LIST
    THIS.LOCAL.LIST = PROP.LOCAL.LIST

* convert logic flags to y/n
    THIS.PARAMETER.COUNT = DCOUNT(THIS.PARAMETER, @VM)

    FOR PARM.LOOP = 1 TO THIS.PARAMETER.COUNT

        IF THIS.BYREF<1, PARM.LOOP> THEN
            THIS.BYREF<1, PARM.LOOP> = "Y"
            THIS.IN<1, PARM.LOOP> = "OUT"
        END ELSE
            THIS.BYREF<1, PARM.LOOP> = "N"
            THIS.IN<1, PARM.LOOP> = "IN"
        END

        IF THIS.OPTIONAL<1, PARM.LOOP> THEN
            THIS.OPTIONAL<1, PARM.LOOP> = "Y"
        END ELSE
            THIS.OPTIONAL<1, PARM.LOOP> = "N"
        END

    NEXT PARM.LOOP

    THIS.PROPERTY.COUNT = DCOUNT(THIS.PROPERTY.LIST, @AM)

    FOR PROP.LOOP = 1 TO THIS.PROPERTY.COUNT

        IF THIS.LOCAL.LIST<PROP.LOOP> THEN
            THIS.LOCAL.LIST<PROP.LOOP> = "Y"
        END ELSE
            THIS.LOCAL.LIST<PROP.LOOP> = "N"
        END

    NEXT PROP.LOOP

    RETURN

ADD.TO.COMPILE.TABLE: ****************************************************
* add a new entry to the compile table                                   *
**************************************************************************
    GOSUB GET.ECLIPSE.CHECKSUM

    COMPILE.METHOD.COUNT += 1

    COMPILE.METHOD.LIST<COMPILE.METHOD.COUNT> = THIS.METHOD

* parameters
    COMPILE.METHOD.PARAMETER.LIST<COMPILE.METHOD.COUNT> = THIS.PARAMETER

    COMPILE.METHOD.DEFAULT.LIST<COMPILE.METHOD.COUNT> = THIS.DEFAULT
    COMPILE.METHOD.SET.LIST<COMPILE.METHOD.COUNT> = THIS.SET
    COMPILE.METHOD.IN.LIST<COMPILE.METHOD.COUNT> = THIS.IN 

    COMPILE.METHOD.OPTIONAL.LIST<COMPILE.METHOD.COUNT> = THIS.OPTIONAL
    COMPILE.METHOD.BYREF.LIST<COMPILE.METHOD.COUNT> = THIS.BYREF
    COMPILE.METHOD.SPECIAL.LIST<COMPILE.METHOD.COUNT> = THIS.SPECIAL

* properties
    COMPILE.METHOD.PROPERTY.LIST = THIS.PROPERTY.LIST
    COMPILE.METHOD.DIM.LIST = THIS.DIM.LIST
    COMPILE.METHOD.TYPE.LIST = THIS.TYPE.LIST
    COMPILE.METHOD.LOCAL.LIST = THIS.LOCAL.LIST

* time stamps
    COMPILE.METHOD.DATE.LIST<COMPILE.METHOD.COUNT> = THIS.DATE
    COMPILE.METHOD.TIME.LIST<COMPILE.METHOD.COUNT> = THIS.TIME

* subroutine data
    COMPILE.METHOD.CHECKSUM.LIST<COMPILE.METHOD.COUNT> = THIS.CHECKSUM

    COMPILE.ECLIPSE.CHECKSUM.LIST<COMPILE.METHOD.COUNT> = ECLIPSE.CHECKSUM
    COMPILE.ECLIPSE.COMMON.CHECKSUM.LIST<COMPILE.METHOD.COUNT> = ECLIPSE.COMMON.CHECKSUM

    COMPILE.METHOD.USER.LIST<COMPILE.METHOD.COUNT> = THIS.USER
    COMPILE.CHANGED.LIST<COMPILE.METHOD.COUNT> = @FALSE

    RETURN

GET.COMPILE.TABLE.PARAMETERS: ********************************************
* return parameters that define how the compile table looks and strings  *
* used to build it                                                       *
**************************************************************************

* define parameters for the compile table
    TABLE.WIDTH = 76
    START.TAG = "COMPILE HISTORY START"
    END.TAG = "COMPILE HISTORY END"

* these two strings are used to identify the first and last line of the
* compile table in the object code
    START.COMPILE.STRING = STR("*", (TABLE.WIDTH - LEN(START.TAG)) / 2 - 1)
    START.COMPILE.STRING := " ":START.TAG:" "
    START.COMPILE.STRING := STR("*", TABLE.WIDTH - LEN(START.COMPILE.STRING))

    END.COMPILE.STRING = STR("*", (TABLE.WIDTH - LEN(END.TAG)) / 2 - 1)
    END.COMPILE.STRING := " ":END.TAG:" "
    END.COMPILE.STRING := STR("*", TABLE.WIDTH - LEN(END.COMPILE.STRING))

    RETURN

CHECK.NEED.COMPILE: ******************************************************
* return NEED.COMPILE true or false for THIS.METHOD depending on the     *
* compile table.  if the method has changed or if the COMMON method has  *
* changed or if the shared common has changed then the method should     *
* be recompiled                                                          *
**************************************************************************
    NEED.COMPILE = @FALSE

* if we're always recompiling methods, whether they're changed or not,
* set the "need compile" flag and return
    IF ALWAYS.RECOMPILE.METHODS THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

* if we've deleted the cbp versions then we always need to recompile
    IF DELETE.CBP THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

* if a single method was defined in the command line compile whether the
* checksum says it needs to or not
    IF OBJECT.METHOD <> "" THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

* if the shared common has changed this changes every method in the object.
* every method needs to be recompiled.  if shared common isn't in the compile
* list something is awry and we'll recompile anyway
    LOCATE "SHARED.COMMON" IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
        NEED.COMPILE = @TRUE
        RETURN
    END

    IF COMPILE.CHANGED.LIST<CHECKSUM.PTR> THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

* if the "common" code method has changed this also changes every method
* in the object so everything needs to be recompiled.  if it's not in the
* list then this object has no "common" code method so it won't be ability
* factor in recompiling
    LOCATE COMMON.ROUTINE.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR THEN
        IF COMPILE.CHANGED.LIST<CHECKSUM.PTR> THEN
            NEED.COMPILE = @TRUE
            RETURN
        END
    END

* find the method in the compile list.  if it's not in the compile
* list then it's a new method and we should recompile it.  if it's one of
* the default methods then there isn't any additional code for that
* default method and we don't need to recompile it.  if we're checking for 
* the "redim" method recompile if the "new" method needs recompiling
    IF THIS.METHOD = REDIM.KEYWORD THEN

        LOCATE NEW.KEYWORD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
            NEED.COMPILE = @TRUE
            RETURN
        END

    END ELSE

        LOCATE THIS.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
            LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING DEFAULT.PTR ELSE
                NEED.COMPILE = @TRUE
                RETURN
            END
            RETURN
        END

    END

* if the method has changed it needs to be recompiled
    IF COMPILE.CHANGED.LIST<CHECKSUM.PTR> THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

* if this routine has been split we'll always recompile
    GOSUB CHECK.METHOD.SPLIT

    IF IS.SPLIT THEN
        NEED.COMPILE = @TRUE
        RETURN
    END

    RETURN


**************************************************************************
**************************************************************************
** code analysis / checksums                                            **
**************************************************************************
**************************************************************************

FIND.NEW.CHECKSUMS: ******************************************************
* find new checksums for all methods in the method.list and update the   *
* compile method table.  returns last.change.date and last.change.time   *
* iconverted.  returns object.version with a version number derived      *
* from the last date and time                                            *
**************************************************************************

* update checksums for each method
    FOR CHECK.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<CHECK.LOOP>
        GOSUB FIND.ONE.NEW.CHECKSUM

        IF NEW.CHECKSUM <> 0 THEN
            GOSUB UPDATE.NEW.CHECKSUM
        END

    NEXT CHECK.LOOP

* update checksum for the shared common code
    THIS.METHOD = "SHARED.COMMON"
    GOSUB UPDATE.NEW.CHECKSUM

* update for redimensioning code if we're building an external subroutine
* for redimensioning
    IF USE.EXTERNAL.REDIM THEN

        THIS.METHOD = REDIM.KEYWORD
        GOSUB FIND.ONE.NEW.CHECKSUM

        IF NEW.CHECKSUM <> 0 THEN
            GOSUB UPDATE.NEW.CHECKSUM
        END

    END

* create an object "version" based on the most recent change date
    LAST.CHANGE.DATE = ""
    LAST.CHANGE.TIME = ""

    FOR CHECK.LOOP = 1 TO METHOD.COUNT

        THIS.DATE = COMPILE.METHOD.DATE.LIST<CHECK.LOOP>
        THIS.TIME = COMPILE.METHOD.TIME.LIST<CHECK.LOOP>
        THIS.CHANGE = COMPILE.CHANGED.LIST<CHECK.LOOP>

        BEGIN CASE

* if this method changed the last change date / time will be now
            CASE THIS.CHANGE
                LAST.CHANGE.DATE = DATE()
                LAST.CHANGE.TIME = INT(TIME())

* we don't have a last change date / time yet
            CASE LAST.CHANGE.DATE = ""
                LAST.CHANGE.DATE = THIS.DATE
                LAST.CHANGE.TIME = THIS.TIME

* this method's last change date / time is later than our latest so far
            CASE THIS.DATE > LAST.CHANGE.DATE
                LAST.CHANGE.DATE = THIS.DATE
                LAST.CHANGE.TIME = THIS.TIME
            CASE THIS.DATE = LAST.CHANGE.DATE AND THIS.TIME > LAST.CHANGE.TIME
                LAST.CHANGE.DATE = THIS.DATE
                LAST.CHANGE.TIME = THIS.TIME

        END CASE

    NEXT CHECK.LOOP

* if we didn't find any last change dates / times use now
    IF LAST.CHANGE.DATE = "" THEN
        LAST.CHANGE.DATE = DATE()
        LAST.CHANGE.TIME = INT(TIME())
    END

* version number will be formed from the number of years after 01/15,
* days into the current year and the last change time in 5 minute breaks
    CURRENT.YEAR = OCONV(DATE(), "D4/") ["/", 3, 1]
    CURRENT.YEAR.START = ICONV("01/01/":CURRENT.YEAR, "D")
    OBJECT.TIME = INT(LAST.CHANGE.TIME / 300 + 1)

    OBJECT.YEARS = OCONV(LAST.CHANGE.DATE, "D4/") ["/", 3, 1] - 2015
    OBJECT.DAYS = LAST.CHANGE.DATE - CURRENT.YEAR.START + 1
    OBJECT.VERSION = OBJECT.YEARS:".":OBJECT.DAYS:"[":OBJECT.TIME:"]"

    IF DETAILS THEN
        GOSUB PRINT.CHECKSUM.LIST
    END

    RETURN

FIND.ONE.NEW.CHECKSUM: ***************************************************
* find new checksum for a method and update the compile method           *
* table                                                                  *
**************************************************************************
    NEW.CHECKSUM = 0

* find method in the method table
    LOCATE THIS.METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

* get the checksum for the shared memory code
    COMMON.NAME = "SHARED.COMMON"
    LOCATE COMMON.NAME IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR THEN
        COMMON.CHECKSUM = COMPILE.NEW.CHECKSUM.LIST<CHECKSUM.PTR>
    END ELSE
        COMMON.CHECKSUM = "NONE"
    END

* copy method code to a separate array so we can get a checksum on
* it.  method.start.line starts at the line after the method line so
* we'll start copying our code at the line before so that a change in
* the method line will also change the checksum
    START.LINE = METHOD.START.LINE<METHOD.PTR> - 1
    END.LINE = METHOD.END.LINE<METHOD.PTR>
    THIS.METHOD.INHERITED = METHOD.INHERIT.LIST<METHOD.PTR>

* copy this code into the checksum code
    CHECKSUM.CODE = ""
    CHECKSUM.CODE.COUNT = 0

    IF THIS.METHOD.INHERITED THEN

        THIS.INHERIT.OBJECT = METHOD.INHERIT.OBJECT.LIST<METHOD.PTR>

        READ THIS.CALLED.CODE FROM OBJFILE, THIS.INHERIT.OBJECT ELSE
            THIS.CALLED.CODE = ""
        END

        CHECKSUM.CODE.COUNT = END.LINE - START.LINE + 1
        CHECKSUM.CODE = THIS.CALLED.CODE [@AM, START.LINE, CHECKSUM.CODE.COUNT]

    END ELSE

        CHECKSUM.CODE.COUNT = END.LINE - START.LINE + 1
        CHECKSUM.CODE = OBJECT.CODE [@AM, START.LINE, CHECKSUM.CODE.COUNT]

    END

* get our checksum
    NEW.CHECKSUM = CHECKSUM(CHECKSUM.CODE)

    IF NEW.CHECKSUM = 0 THEN
        RETURN
    END

* update the compile table
    LOCATE THIS.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
        COMPILE.METHOD.COUNT += 1
        CHECKSUM.PTR = COMPILE.METHOD.COUNT
        COMPILE.METHOD.LIST<CHECKSUM.PTR> = THIS.METHOD
    END

    COMPILE.NEW.CHECKSUM.LIST<CHECKSUM.PTR> = NEW.CHECKSUM

* if we have a different checksum now flag it in the table
    OLD.CHECKSUM = COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR>
    ECLIPSE.CHECKSUM = COMPILE.ECLIPSE.CHECKSUM.LIST<CHECKSUM.PTR>
    ECLIPSE.COMMON.CHECKSUM = COMPILE.ECLIPSE.COMMON.CHECKSUM.LIST<CHECKSUM.PTR>

* if the new checksum differs from the old we want to recompile
    RECOMPILE = @FALSE

    IF NEW.CHECKSUM <> OLD.CHECKSUM OR OLD.CHECKSUM = "" THEN
        RECOMPILE = @TRUE
    END

* the "common" method won't have an eclipse checksum so skip these
* tests for "common"
    IF THIS.METHOD <> COMMON.ROUTINE.METHOD THEN

* if the new checksum differs from the eclipse checksum we want
* to recompile.  if there is no eclipse checksum (maybe the eclipse
* subroutine has never been created before) we want to recompile
        IF NEW.CHECKSUM <> ECLIPSE.CHECKSUM OR ECLIPSE.CHECKSUM = "" THEN
            RECOMPILE = @TRUE
        END

* if the eclipse routine's common checksum doesn't match the current
* common checksum we need to recompile
        IF COMMON.CHECKSUM <> ECLIPSE.COMMON.CHECKSUM THEN
            RECOMPILE = @TRUE
        END

    END

* set recompile flag in the table
    COMPILE.CHANGED.LIST<CHECKSUM.PTR> = RECOMPILE

    RETURN

UPDATE.COMMON.CHECKSUM: **************************************************
* update the compile table for the shared common code                    *
**************************************************************************
    COMMON.CHECKSUM = CHECKSUM(COMMON.CODE)
    COMMON.NAME = "SHARED.COMMON"

    IF COMMON.CHECKSUM = 0 THEN
        RETURN
    END

    LOCATE COMMON.NAME IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
        COMPILE.METHOD.COUNT += 1
        CHECKSUM.PTR = COMPILE.METHOD.COUNT
        COMPILE.METHOD.LIST<CHECKSUM.PTR> = COMMON.NAME
    END

    COMPILE.NEW.CHECKSUM.LIST<CHECKSUM.PTR> = COMMON.CHECKSUM

    IF COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR> <> COMMON.CHECKSUM THEN
        COMPILE.CHANGED.LIST<CHECKSUM.PTR> = @TRUE
    END

    RETURN

UPDATE.REDIM.CHECKSUM: ***************************************************
* update the compile table for the redimensioning code                   *
**************************************************************************
    REDIM.CHECKSUM = CHECKSUM(REDIM.CODE)
    REDIM.NAME = REDIM.KEYWORD

    IF REDIM.CHECKSUM = 0 THEN
        RETURN
    END

    LOCATE REDIM.NAME IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
        COMPILE.METHOD.COUNT += 1
        CHECKSUM.PTR = COMPILE.METHOD.COUNT
        COMPILE.METHOD.LIST<CHECKSUM.PTR> = REDIM.NAME
    END

    COMPILE.NEW.CHECKSUM.LIST<CHECKSUM.PTR> = REDIM.CHECKSUM

    IF COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR> <> REDIM.CHECKSUM THEN
        COMPILE.CHANGED.LIST<CHECKSUM.PTR> = @TRUE
    END

    RETURN

UPDATE.NEW.CHECKSUM: *****************************************************
* update compile table for this.method after a compile                   *
**************************************************************************

* find the method in the compile table and add it if it's not already there
    LOCATE THIS.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
        COMPILE.METHOD.COUNT += 1
        CHECKSUM.PTR = COMPILE.METHOD.COUNT
        COMPILE.METHOD.LIST<CHECKSUM.PTR> = THIS.METHOD
    END

* update the last changed date and time.  if last change stamp date/time 
* updates are turned off only update the date and time if it's (somehow?)
* empty.  this allows updating the last change date and time in dev and 
* preserve these last change dates and times as the code is pushed into
* other environments
    IF COMPILE.CHANGED.LIST<CHECKSUM.PTR> THEN

        IF UPDATE.LAST.CHANGE.STAMP OR COMPILE.METHOD.DATE.LIST<CHECKSUM.PTR> = "" THEN
            COMPILE.METHOD.DATE.LIST<CHECKSUM.PTR> = DATE()
            COMPILE.METHOD.TIME.LIST<CHECKSUM.PTR> = INT(TIME())
        END

        COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR> = COMPILE.NEW.CHECKSUM.LIST<CHECKSUM.PTR>
        COMPILE.METHOD.USER.LIST<CHECKSUM.PTR> = USER.ID

    END

    RETURN

GET.ECLIPSE.CHECKSUM: ****************************************************
* get the checksum from an eclipse.subroutine this.subroutine in cbp     *
**************************************************************************
    ECLIPSE.CHECKSUM = ""
    ECLIPSE.COMMON.CHECKSUM = ""

    READ SUB.CODE FROM CBPFILE, THIS.SUBROUTINE ELSE
        SUB.CODE = ""
    END

    LEN.PREFIX = LEN(CHECKSUM.PREFIX)
    SUB.LINES = DCOUNT(SUB.CODE,AM)

    FOR SUB.LINE = 1 TO SUB.LINES UNTIL ECLIPSE.CHECKSUM <> ""

        THIS.LINE = SUB.CODE<SUB.LINE>

        IF THIS.LINE [1, LEN.PREFIX] = CHECKSUM.PREFIX THEN
            THIS.LINE = THIS.LINE [LEN.PREFIX + 1, TO.THE.END]
            ECLIPSE.CHECKSUM = THIS.LINE [" ", 1, 1]
            ECLIPSE.COMMON.CHECKSUM = THIS.LINE [" ", 2, 1]
        END

    NEXT SUB.LINE

    RETURN

PRINT.CHECKSUM.LIST: *****************************************************
* print out the checksum list for debugging                              *
**************************************************************************
    PRINT
    PRINT "Method............................. Checksum.. EcChecksum ":
    PRINT "EcComChksm Date...... Time...... Change"

    FOR CHECK.LOOP = 1 TO COMPILE.METHOD.COUNT

        PRINT COMPILE.METHOD.LIST<CHECK.LOOP> "L#35":" ":

        PRINT COMPILE.METHOD.CHECKSUM.LIST<CHECK.LOOP> "L#10":" ":
        PRINT COMPILE.ECLIPSE.CHECKSUM.LIST<CHECK.LOOP> "L#10":" ":
        PRINT COMPILE.ECLIPSE.COMMON.CHECKSUM.LIST<CHECK.LOOP> "L#10":" ":

        PRINT OCONV(COMPILE.METHOD.DATE.LIST<CHECK.LOOP>, "D4/") "L#10":" ":
        PRINT OCONV(COMPILE.METHOD.TIME.LIST<CHECK.LOOP>, "MTHS") "L#10":" ":

        IF COMPILE.CHANGED.LIST<CHECK.LOOP> THEN
            PRINT "Yes" "L#5"
        END ELSE
            PRINT "No" "L#5"
        END

    NEXT CHECK.LOOP

    GOSUB WAIT

    RETURN

FIND.SUBROUTINE.CHECKSUM: ************************************************
* find the checksum for an object-enabled subroutine.  scans the         *
* cbp code, the cbp code from the last time the subroutine was compiled. *
* returns new.checksum with the checksum for the new code and            *
* old.checksum with the checksum from the previous compile, pulled from  *
* the cbp version.  returns last.change.date and last.change.time        *
* iconverted                                                             *
**************************************************************************
    GET.SUBROUTINE.CHECKSUM.FROM.CBP = @FALSE

* get the new checksum from the the subroutine code

* get the old checksum from the cbp code.  we'll also get the last change
* date and time here
    IF GET.SUBROUTINE.CHECKSUM.FROM.CBP THEN

        NEW.CHECKSUM = CHECKSUM(PROGRAM.CODE)

        READ SUB.CODE FROM CBPFILE, SUBROUTINE.NAME ELSE
            SUB.CODE = ""
        END

    END ELSE

        NEW.CHECKSUM = ""

        READ SUB.CODE FROM OBPFILE, SUBROUTINE.NAME ELSE
            SUB.CODE = ""
        END

    END

* search through the code for the comments containing the last checksum, last
* change date and time, and last compile date and time
    LEN.CHECKSUM.PREFIX = LEN(CHECKSUM.PREFIX)
    LEN.CHANGE.PREFIX = LEN(LAST.CHANGE.PREFIX)
    LEN.COMPILE.PREFIX = LEN(LAST.COMPILE.PREFIX)
    SUB.LINES = DCOUNT(SUB.CODE,AM)

    OLD.CHECKSUM = ""
    LAST.CHECKSUM.LINE = 0

    LAST.CHANGE.DATE = ""
    LAST.CHANGE.TIME = ""
    LAST.CHANGE.LINE = 0

    LAST.COMPILE.DATE = ""
    LAST.COMPILE.TIME = ""
    LAST.COMPILE.LINE = 0

    SETREM 0 ON SUB.CODE

    FOR SUB.LINE = 1 TO SUB.LINES UNTIL OLD.CHECKSUM <> "" AND LAST.CHANGE.DATE <> "" AND LAST.COMPILE.TIME <> ""

*       THIS.LINE = SUB.CODE<SUB.LINE>
        REMOVE THIS.LINE FROM SUB.CODE SETTING THROWAWAY

        BEGIN CASE

            CASE THIS.LINE [1, LEN.CHECKSUM.PREFIX] = CHECKSUM.PREFIX
                THIS.LINE = THIS.LINE [LEN.CHECKSUM.PREFIX + 1, TO.THE.END]
                OLD.CHECKSUM = THIS.LINE [" ", 1, 1]
                LAST.CHECKSUM.LINE = SUB.LINE

            CASE THIS.LINE [1, LEN.CHANGE.PREFIX] = LAST.CHANGE.PREFIX
                THIS.LINE = THIS.LINE [LEN.CHANGE.PREFIX + 1, TO.THE.END]
                LAST.CHANGE.DATE = ICONV(THIS.LINE [" ", 1, 1], "D")
                LAST.CHANGE.TIME = ICONV(THIS.LINE [" ", 2, 1], "MT")
                LAST.CHANGE.LINE = SUB.LINE

            CASE THIS.LINE [1, LEN.COMPILE.PREFIX] = LAST.COMPILE.PREFIX
                THIS.LINE = THIS.LINE [LEN.COMPILE.PREFIX + 1, TO.THE.END]
                LAST.COMPILE.DATE = ICONV(THIS.LINE [" ", 1, 1], "D")
                LAST.COMPILE.TIME = ICONV(THIS.LINE [" ", 2, 1], "MT")
                LAST.COMPILE.LINE = SUB.LINE

        END CASE

    NEXT SUB.LINE

* if we're getting the checksum from the obp code get it here after removing
* the stamp comment lines
    IF NOT(GET.SUBROUTINE.CHECKSUM.FROM.CBP) THEN
        GOSUB REMOVE.SUBROUTINE.STAMP.LINES
        NEW.CHECKSUM = CHECKSUM (SUB.CODE)
    END

    RETURN

REMOVE.SUBROUTINE.STAMPS: ************************************************
* find and remove subroutine stamps from sub.code.  finds                *
* last.checksum.line, last.change.line and last.compile.line and removes *
* these lines from sub.code.  adjusts sub.lines                          *
**************************************************************************
    LAST.CHECKSUM.LINE = 0
    LAST.CHANGE.LINE = 0
    LAST.COMPILE.LINE = 0

    LEN.CHECKSUM.PREFIX = LEN(CHECKSUM.PREFIX)
    LEN.CHANGE.PREFIX = LEN(LAST.CHANGE.PREFIX)
    LEN.COMPILE.PREFIX = LEN(LAST.COMPILE.PREFIX)

    SETREM 0 ON SUB.CODE

    FOR SUB.LINE = 1 TO SUB.LINES UNTIL LAST.CHECKSUM.LINE <> 0 AND LAST.CHANGE.LINE <> 0 AND LAST.COMPILE.LINE <> 0

*       THIS.LINE = SUB.CODE<SUB.LINE>
        REMOVE THIS.LINE FROM SUB.CODE SETTING THROWAWAY

        BEGIN CASE

            CASE THIS.LINE [1, LEN.CHECKSUM.PREFIX] = CHECKSUM.PREFIX
                THIS.LINE = THIS.LINE [LEN.CHECKSUM.PREFIX + 1, TO.THE.END]
                LAST.CHECKSUM.LINE = SUB.LINE

            CASE THIS.LINE [1, LEN.CHANGE.PREFIX] = LAST.CHANGE.PREFIX
                THIS.LINE = THIS.LINE [LEN.CHANGE.PREFIX + 1, TO.THE.END]
                LAST.CHANGE.LINE = SUB.LINE

            CASE THIS.LINE [1, LEN.COMPILE.PREFIX] = LAST.COMPILE.PREFIX
                THIS.LINE = THIS.LINE [LEN.COMPILE.PREFIX + 1, TO.THE.END]
                LAST.COMPILE.LINE = SUB.LINE

        END CASE

    NEXT SUB.LINE

    GOSUB REMOVE.SUBROUTINE.STAMP.LINES

    RETURN

REMOVE.SUBROUTINE.STAMP.LINES: *******************************************
* remove subroutine stamps from sub.code.  uses last.checksum.line,      *
* last.change.line and last.compile.line.  if any of these values are    *
* zero they'll be ignored otherwise the lines these values point to will *
* be removed from sub.code.  adjusts sub.lines                           *
**************************************************************************
    IF LAST.CHECKSUM.LINE <> 0 THEN

        DEL SUB.CODE<LAST.CHECKSUM.LINE>

        IF LAST.CHECKSUM.LINE < LAST.CHANGE.LINE THEN
            LAST.CHANGE.LINE -= 1
        END

        IF LAST.CHECKSUM.LINE < LAST.COMPILE.LINE THEN
            LAST.COMPILE.LINE -= 1
        END

        SUB.LINES -= 1
        
    END

    IF LAST.CHANGE.LINE <> 0 THEN

        DEL SUB.CODE<LAST.CHANGE.LINE>

        IF LAST.CHANGE.LINE < LAST.COMPILE.LINE THEN
            LAST.COMPILE.LINE -= 1
        END

        SUB.LINES -= 1

    END

    IF LAST.COMPILE.LINE <> 0 THEN

        DEL SUB.CODE<LAST.COMPILE.LINE>

        SUB.LINES -= 1

    END

* removing any empty lines from the end of the program.  they'll change
* the checksum when the program hasn't changed
    FINISHED.REMOVING = @FALSE

    FOR SUB.LINE = SUB.LINES TO 1 STEP -1 UNTIL FINISHED.REMOVING

        THIS.LINE = SUB.CODE<SUB.LINE>

        IF TRIM(THIS.LINE) = "" THEN
            DEL SUB.CODE<SUB.LINE>
            SUB.LINES -= 1
        END ELSE
            FINISHED.REMOVING = @TRUE
        END

    NEXT SUB.LINE


    RETURN


**************************************************************************
**************************************************************************
** compiling / ud.compile.dates file                                    **
**************************************************************************
**************************************************************************

SAVE.COMPILE.TABLE: ******************************************************
* save compile.method table as comments at the bottom of the object      *
* source code.  updates object.code.  returns the object source record   *
* in the obj file locked                                                 *
**************************************************************************

* compound lines will have been joined so the code in object.code probably
* won't be the same as the original object code read from the obj file.
* also, it's possible the object code in the obj file was changed due to
* someone editing it while the object was compiled.  if we add the compile
* table and then save the object code we may overwrite these changes

* to be safe we'll re-read the object code from the obj file with a lock,
* update the compile table and save that code

* if, for some bizarre reason, we can't read the object code we'll use the
* original object code read as a safety catch-all
    READU OBJECT.CODE FROM OBJFILE, OBJECT.NAME ELSE
        OBJECT.CODE = ORIGINAL.OBJECT.CODE
    END

    GOSUB GET.COMPILE.TABLE.PARAMETERS

* start at the end of the object code and work backwards until we find
* the start and end strings
    LOCATE START.COMPILE.STRING IN OBJECT.CODE SETTING START.PTR ELSE
        OBJECT.CODE.LINES += 3
        START.PTR = OBJECT.CODE.LINES
        OBJECT.CODE<START.PTR> = START.COMPILE.STRING
    END

    LOCATE END.COMPILE.STRING IN OBJECT.CODE SETTING END.PTR ELSE
        OBJECT.CODE.LINES += 1
        END.PTR = OBJECT.CODE.LINES
        OBJECT.CODE<END.PTR> = END.COMPILE.STRING
    END

* delete the old table
    LOOP UNTIL (END.PTR - START.PTR) <= 1
        DEL OBJECT.CODE<START.PTR + 1>
        END.PTR -= 1
    REPEAT

* build a sorted list of methods to keep things pretty
    SORT.METHOD.LIST = ""

    FOR SORT.LOOP = 1 TO COMPILE.METHOD.COUNT

        THIS.METHOD = COMPILE.METHOD.LIST<SORT.LOOP>
        LOCATE THIS.METHOD IN SORT.METHOD.LIST BY "AL" SETTING THIS.PTR ELSE NULL
        INS THIS.METHOD BEFORE SORT.METHOD.LIST<THIS.PTR>

    NEXT SORT.LOOP

* "common" and "shared.common" aren't "real" methods so we'll move them to
* the end
    LOCATE COMMON.ROUTINE.METHOD IN SORT.METHOD.LIST SETTING COMMON.PTR THEN
        DEL SORT.METHOD.LIST<COMMON.PTR>
        SORT.METHOD.LIST<COMPILE.METHOD.COUNT> = COMMON.ROUTINE.METHOD
    END

    LOCATE "SHARED.COMMON" IN SORT.METHOD.LIST SETTING COMMON.PTR THEN
        DEL SORT.METHOD.LIST<COMMON.PTR>
        SORT.METHOD.LIST<COMPILE.METHOD.COUNT> = "SHARED.COMMON"
    END

* insert the new table
    FOR CHECKSUM.LOOP = COMPILE.METHOD.COUNT TO 1 STEP -1

        THIS.METHOD = SORT.METHOD.LIST<CHECKSUM.LOOP>
        LOCATE THIS.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
            CHECKSUM.PTR = 1
        END

        THIS.CHECKSUM = COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR>
        THIS.DATE = COMPILE.METHOD.DATE.LIST<CHECKSUM.PTR>
        THIS.TIME = COMPILE.METHOD.TIME.LIST<CHECKSUM.PTR>
        THIS.USER = COMPILE.METHOD.USER.LIST<CHECKSUM.PTR>

        IF THIS.USER = "" THEN
            THIS.USER = USER.ID
        END

        IF NOT(NUM(THIS.CHECKSUM)) THEN
            THIS.CHECKSUM = 0
        END

* insert a line from the table into the code if this entry has a non-zero
* checksum.  if the checksum is zero then the method wasn't exported
        IF THIS.CHECKSUM+0 <> 0 THEN
            ADD.LINE = "* "
            ADD.LINE := THIS.METHOD "L#30":" ":THIS.CHECKSUM "R#8":" "
            ADD.LINE := OCONV(THIS.DATE, "D4/") "L#10":" ":OCONV(THIS.TIME,"MTHS") "L#10":" "
            ADD.LINE := THIS.USER "L#10":" *"
            INS ADD.LINE BEFORE OBJECT.CODE<START.PTR + 1>
        END

    NEXT CHECKSUM.LOOP

* insert the heading row
    HEADING.ROW = "* ":"Method" "L#30":" ":"Checksum" "L#8":" "
    HEADING.ROW := "ChangeDate" "L#10":" ":"ChangeTime" "L#10":" "
    HEADING.ROW := "ChangeBy" "L#10":" *"
    INS HEADING.ROW BEFORE OBJECT.CODE<START.PTR + 1>

* save the updated object code
    WRITE.ERROR = @FALSE
    WRITE OBJECT.CODE ON OBJFILE, OBJECT.NAME ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "OBJ"
        ERROR.ITEM = OBJECT.NAME
        GOSUB WRITE.ERROR
    END

    RETURN

SAVE.COMPILE.TABLE.IN.FILE: **********************************************
* save the compile table in the ud.compile.dates file                    *
**************************************************************************
    IF NOT(UD.COMPILE.DATES.EXISTS) THEN
        RETURN
    END

    GOSUB REMOVE.FROM.COMPILE.DATES

* build new entries
    FOR CHECKSUM.LOOP = 1 TO COMPILE.METHOD.COUNT

* build values for the compile dates file from the compile dates tables
        THIS.METHOD = SORT.METHOD.LIST<CHECKSUM.LOOP>

        LOCATE THIS.METHOD IN COMPILE.METHOD.LIST SETTING CHECKSUM.PTR ELSE
            CHECKSUM.PTR = 1
        END

* parameters
        THIS.PARAMETER = COMPILE.METHOD.PARAMETER.LIST<CHECKSUM.PTR>
        THIS.DEFAULT = COMPILE.METHOD.DEFAULT.LIST<CHECKSUM.PTR>
        THIS.SET = COMPILE.METHOD.SET.LIST<CHECKSUM.PTR>
        THIS.IN = COMPILE.METHOD.IN.LIST<CHECKSUM.PTR>

        THIS.OPTIONAL = COMPILE.METHOD.OPTIONAL.LIST<CHECKSUM.PTR>
        THIS.BYREF = COMPILE.METHOD.BYREF.LIST<CHECKSUM.PTR>
        THIS.SPECIAL = COMPILE.METHOD.SPECIAL.LIST<CHECKSUM.PTR>

* properties
        THIS.PROPERTY.LIST = COMPILE.METHOD.PROPERTY.LIST
        THIS.DIM.LIST = COMPILE.METHOD.DIM.LIST
        THIS.TYPE.LIST = COMPILE.METHOD.TYPE.LIST
        THIS.LOCAL.LIST = COMPILE.METHOD.LOCAL.LIST

        THIS.CHECKSUM = COMPILE.METHOD.CHECKSUM.LIST<CHECKSUM.PTR>
        THIS.DATE = COMPILE.METHOD.DATE.LIST<CHECKSUM.PTR>
        THIS.TIME = COMPILE.METHOD.TIME.LIST<CHECKSUM.PTR>
        THIS.USER = COMPILE.METHOD.USER.LIST<CHECKSUM.PTR>

* external flag
        IF EXTERNAL.OBJECT THEN
            THIS.EXTERNAL.OBJECT = "Y"
        END ELSE
            THIS.EXTERNAL.OBJECT = "N"
        END

        IF THIS.USER = "" THEN
            THIS.USER = USER.ID
        END

        IF NOT(NUM(THIS.CHECKSUM)) THEN
            THIS.CHECKSUM = 0
        END

* load the cbp subroutine for this method
        SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:THIS.METHOD

        READ CBP.RECORD FROM CBPFILE, SUBROUTINE.NAME ELSE
            CBP.RECORD = ""
        END

        GOSUB UPDATE.COMPILE.DETAIL
        GOSUB UPDATE.COMPILE.MASTER
        GOSUB UPDATE.COMPILE.ALL

    NEXT CHECKSUM.LOOP

    RETURN

REMOVE.FROM.COMPILE.DATES: ***********************************************
* remove the current object from the ud.compile.dates file               *
**************************************************************************
    IF NOT(UD.COMPILE.DATES.EXISTS) THEN
        RETURN
    END

* remove all ud.compile.dates entries for this object in case any methods
* had name changes or were removed
    GOSUB SELECT.COMPILE.DATES.DETAIL

    LOOP WHILE READNEXT OBJECT.ID FROM SLIST DO

        WRITE.ERROR = @FALSE
        DELETE COMPILEDATESFILE, OBJECT.ID ON ERROR WRITE.ERROR = @TRUE

        IF WRITE.ERROR THEN
            ERROR.FILE = "UD.COMPILE.DATES"
            ERROR.ITEM = OBJECT.ID
            GOSUB DELETE.ERROR
        END

    REPEAT

* remove the object's master record
    WRITE.ERROR = @FALSE
    DELETE COMPILEDATESFILE, OBJECT.NAME ON ERROR WRITE.ERROR = @TRUE

    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.COMPILE.DATES"
        ERROR.ITEM = OBJECT.NAME
        GOSUB DELETE.ERROR
    END

* remove this object from the "all" object entry in ud.compile.dates
    DATES.ID = "ALL"

    READU ALL.RECORD FROM COMPILEDATESFILE, DATES.ID ELSE
        RELEASE COMPILEDATESFILE, DATES.ID
        RETURN
    END

* the master record has all objects.  set a pointer for this object in
* the object table
    LOCATE OBJECT.NAME IN ALL.RECORD<1> SETTING OBJECT.PTR ELSE
        RELEASE COMPILEDATESFILE, DATES.ID
        RETURN
    END

* remove this object from the "all" table
    DEL ALL.RECORD<1, OBJECT.PTR>

    IF DETAIL.IN.ALL.COMPILE.DATES THEN

* method tables
        DEL ALL.RECORD<2, OBJECT.PTR>

        DEL ALL.RECORD<3, OBJECT.PTR>
        DEL ALL.RECORD<4, OBJECT.PTR>
        DEL ALL.RECORD<5, OBJECT.PTR>
        DEL ALL.RECORD<6, OBJECT.PTR>

        DEL ALL.RECORD<7, OBJECT.PTR>

        DEL ALL.RECORD<8, OBJECT.PTR>
        DEL ALL.RECORD<9, OBJECT.PTR>

        DEL ALL.RECORD<10, OBJECT.PTR>
        DEL ALL.RECORD<11, OBJECT.PTR>
        DEL ALL.RECORD<12, OBJECT.PTR>
        DEL ALL.RECORD<13, OBJECT.PTR>
        DEL ALL.RECORD<14, OBJECT.PTR>
        DEL ALL.RECORD<15, OBJECT.PTR>

        DEL ALL.RECORD<16, OBJECT.PTR>

* properties
        DEL ALL.RECORD<17, OBJECT.PTR>
        DEL ALL.RECORD<18, OBJECT.PTR>
        DEL ALL.RECORD<19, OBJECT.PTR>
        DEL ALL.RECORD<20, OBJECT.PTR>
        DEL ALL.RECORD<21, OBJECT.PTR>

* external object flag
        DEL ALL.RECORD<22, OBJECT.PTR>

    END

    WRITE.ERROR = @FALSE
    WRITE ALL.RECORD ON COMPILEDATESFILE, DATES.ID ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.COMPILE.DATES"
        ERROR.ITEM = DATES.ID
        GOSUB WRITE.ERROR
    END

    RETURN

UPDATE.COMPILE.DETAIL: ***************************************************
* update the ud.compile.dates detail record keyed by object and method   *
**************************************************************************
    IF NOT(UD.COMPILE.DATES.EXISTS) THEN
        RETURN
    END

* build the file id
    DATES.ID = OBJECT.NAME:METHOD.DELIMITER:THIS.METHOD

* build the data record
    DATES.RECORD = ""

* method data
    DATES.RECORD<1> = OBJECT.NAME
    DATES.RECORD<2> = THIS.METHOD

    DATES.RECORD<3> = THIS.DATE
    DATES.RECORD<4> = THIS.TIME
    DATES.RECORD<5> = THIS.USER
    DATES.RECORD<6> = THIS.CHECKSUM

    DATES.RECORD<7> = SUBROUTINE.NAME

    DATES.RECORD<8> = DCOUNT(CBP.RECORD, AM)
    DATES.RECORD<9> = LEN(CBP.RECORD)

* parameters
    DATES.RECORD<10> = THIS.PARAMETER
    DATES.RECORD<11> = THIS.BYREF
    DATES.RECORD<12> = THIS.DEFAULT 
    DATES.RECORD<13> = THIS.SET 
    DATES.RECORD<14> = THIS.IN 
    DATES.RECORD<15> = THIS.OPTIONAL

    DATES.RECORD<16> = DCOUNT(THIS.PARAMETER, @VM)

* properties
    DATES.RECORD<17> = LOWER(THIS.PROPERTY.LIST)
    DATES.RECORD<18> = LOWER(THIS.DIM.LIST)
    DATES.RECORD<19> = LOWER(THIS.TYPE.LIST)
    DATES.RECORD<20> = LOWER(THIS.LOCAL.LIST)
    DATES.RECORD<21> = DCOUNT(THIS.PROPERTY.LIST, @AM)

* external object flag
    DATES.RECORD<22> = THIS.EXTERNAL.OBJECT

* object version
    DATES.RECORD<23> = OBJECT.VERSION

    WRITE.ERROR = @FALSE
    WRITE DATES.RECORD ON COMPILEDATESFILE, DATES.ID ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.COMPILE.DATES"
        ERROR.ITEM = DATES.ID
        GOSUB WRITE.ERROR
    END

    RETURN

UPDATE.COMPILE.MASTER: ***************************************************
* update the ud.compile.dates master record keyed by object              *
**************************************************************************
    IF NOT(UD.COMPILE.DATES.EXISTS) THEN
        RETURN
    END

    DATES.ID = OBJECT.NAME

    READU MASTER.RECORD FROM COMPILEDATESFILE, DATES.ID ELSE
        MASTER.RECORD = OBJECT.NAME
    END

* the master record has a table with all methods for the object.  find 
* the location in the table for this method or create if it necessary
    LOCATE THIS.METHOD IN MASTER.RECORD<2> BY "AL" SETTING METHOD.PTR ELSE

        INS THIS.METHOD BEFORE MASTER.RECORD<2, METHOD.PTR>

        IF DETAIL.IN.ALL.COMPILE.DATES THEN

            INS "" BEFORE MASTER.RECORD<3, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<4, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<5, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<6, METHOD.PTR>

            INS "" BEFORE MASTER.RECORD<7, METHOD.PTR>

            INS "" BEFORE MASTER.RECORD<8, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<9, METHOD.PTR>

            INS "" BEFORE MASTER.RECORD<10, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<11, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<12, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<13, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<14, METHOD.PTR>
            INS "" BEFORE MASTER.RECORD<15, METHOD.PTR>

            INS "" BEFORE MASTER.RECORD<16, METHOD.PTR>

        END

    END

    IF DETAIL.IN.ALL.COMPILE.DATES THEN

        MASTER.RECORD<3, METHOD.PTR> = THIS.DATE
        MASTER.RECORD<4, METHOD.PTR> = THIS.TIME
        MASTER.RECORD<5, METHOD.PTR> = THIS.USER
        MASTER.RECORD<6, METHOD.PTR> = THIS.CHECKSUM

        MASTER.RECORD<7, METHOD.PTR> = SUBROUTINE.NAME

        MASTER.RECORD<8, METHOD.PTR> = DATES.RECORD<8>
        MASTER.RECORD<9, METHOD.PTR> = DATES.RECORD<9>

        MASTER.RECORD<10, METHOD.PTR> = LOWER(THIS.PARAMETER)
        MASTER.RECORD<11, METHOD.PTR> = LOWER(THIS.BYREF)
        MASTER.RECORD<12, METHOD.PTR> = LOWER(THIS.DEFAULT)
        MASTER.RECORD<13, METHOD.PTR> = LOWER(THIS.SET)
        MASTER.RECORD<14, METHOD.PTR> = LOWER(THIS.IN)
        MASTER.RECORD<15, METHOD.PTR> = LOWER(THIS.OPTIONAL)

        MASTER.RECORD<16, METHOD.PTR> = DATES.RECORD<16>

* properties
        MASTER.RECORD<17> = LOWER(THIS.PROPERTY.LIST)
        MASTER.RECORD<18> = LOWER(THIS.DIM.LIST)
        MASTER.RECORD<19> = LOWER(THIS.TYPE.LIST)
        MASTER.RECORD<20> = LOWER(THIS.LOCAL.LIST)
        MASTER.RECORD<21> = DCOUNT(THIS.PROPERTY.LIST, @AM)

* external object flag
        MASTER.RECORD<22> = THIS.EXTERNAL.OBJECT

    END

* object version
    MASTER.RECORD<23> = OBJECT.VERSION

    WRITE.ERROR = @FALSE
    WRITE MASTER.RECORD ON COMPILEDATESFILE, DATES.ID ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.COMPILE.DATES"
        ERROR.ITEM = DATES.ID
        GOSUB WRITE.ERROR
    END

    RETURN

UPDATE.COMPILE.ALL: ******************************************************
* update the "all" record with data for all objects and methods.         *
**************************************************************************
    IF NOT(UD.COMPILE.DATES.EXISTS) THEN
        RETURN
    END

    DATES.ID = "ALL"

    READU ALL.RECORD FROM COMPILEDATESFILE, DATES.ID ELSE
        ALL.RECORD = ""
    END

* the master record has all objects.  set a pointer for this object in
* the object table
    LOCATE OBJECT.NAME IN ALL.RECORD<1> SETTING OBJECT.PTR ELSE

        INS OBJECT.NAME BEFORE ALL.RECORD<1, OBJECT.PTR>

        IF DETAIL.IN.ALL.COMPILE.DATES THEN

* method tables
            INS "" BEFORE ALL.RECORD<2, OBJECT.PTR>

            INS "" BEFORE ALL.RECORD<3, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<4, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<5, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<6, OBJECT.PTR>

            INS "" BEFORE ALL.RECORD<7, OBJECT.PTR>

            INS "" BEFORE ALL.RECORD<8, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<9, OBJECT.PTR>

            INS "" BEFORE ALL.RECORD<10, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<11, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<12, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<13, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<14, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<15, OBJECT.PTR>

            INS "" BEFORE ALL.RECORD<16, OBJECT.PTR>

* properties
            INS "" BEFORE ALL.RECORD<17, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<18, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<19, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<20, OBJECT.PTR>
            INS "" BEFORE ALL.RECORD<21, OBJECT.PTR>

* external object flag
            INS "" BEFORE ALL.RECORD<22, OBJECT.PTR>

        END

    END

    IF DETAIL.IN.ALL.COMPILE.DATES THEN

* find the method for this object
        LOCATE THIS.METHOD IN ALL.RECORD<2, OBJECT.PTR> BY "AL" SETTING METHOD.PTR ELSE

            INS THIS.METHOD BEFORE ALL.RECORD<2, OBJECT.PTR, METHOD.PTR>

            INS "" BEFORE ALL.RECORD<3, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<4, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<5, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<6, OBJECT.PTR, METHOD.PTR>

            INS "" BEFORE ALL.RECORD<7, OBJECT.PTR, METHOD.PTR>

            INS "" BEFORE ALL.RECORD<8, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<9, OBJECT.PTR, METHOD.PTR>

            INS "" BEFORE ALL.RECORD<10, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<11, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<12, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<13, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<14, OBJECT.PTR, METHOD.PTR>
            INS "" BEFORE ALL.RECORD<15, OBJECT.PTR, METHOD.PTR>

            INS "" BEFORE ALL.RECORD<16, OBJECT.PTR, METHOD.PTR>

        END

        ALL.RECORD<3, OBJECT.PTR, METHOD.PTR> = THIS.DATE
        ALL.RECORD<4, OBJECT.PTR, METHOD.PTR> = THIS.TIME
        ALL.RECORD<5, OBJECT.PTR, METHOD.PTR> = THIS.USER
        ALL.RECORD<6, OBJECT.PTR, METHOD.PTR> = THIS.CHECKSUM

        ALL.RECORD<7, OBJECT.PTR, METHOD.PTR> = SUBROUTINE.NAME

        ALL.RECORD<8, OBJECT.PTR, METHOD.PTR> = DATES.RECORD<8>
        ALL.RECORD<9, OBJECT.PTR, METHOD.PTR> = DATES.RECORD<9>

        ALL.RECORD<10, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.PARAMETER))
        ALL.RECORD<11, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.BYREF))
        ALL.RECORD<12, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.DEFAULT))
        ALL.RECORD<13, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.SET))
        ALL.RECORD<14, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.IN))
        ALL.RECORD<15, OBJECT.PTR, METHOD.PTR> = LOWER(LOWER(THIS.OPTIONAL))

        ALL.RECORD<16, OBJECT.PTR, METHOD.PTR> = DATES.RECORD<16>

* properties
        ALL.RECORD<17, OBJECT.PTR> = LOWER(LOWER(THIS.PROPERTY.LIST))
        ALL.RECORD<18, OBJECT.PTR> = LOWER(LOWER(THIS.DIM.LIST))
        ALL.RECORD<19, OBJECT.PTR> = LOWER(LOWER(THIS.TYPE.LIST))
        ALL.RECORD<20, OBJECT.PTR> = LOWER(LOWER(THIS.LOCAL.LIST))
        ALL.RECORD<21, OBJECT.PTR> = DCOUNT(THIS.PROPERTY.LIST, @AM)

* external object flag
        ALL.RECORD<22, OBJECT.PTR> = THIS.EXTERNAL.OBJECT

* object version
        ALL.RECORD<23, OBJECT.PTR> = OBJECT.VERSION

    END

    WRITE.ERROR = @FALSE
    WRITE ALL.RECORD ON COMPILEDATESFILE, DATES.ID ON ERROR WRITE.ERROR = @TRUE

* if we couldn't write the compile subroutine something is amiss somewhere
    IF WRITE.ERROR THEN
        ERROR.FILE = "UD.COMPILE.DATES"
        ERROR.ITEM = DATES.ID
        GOSUB WRITE.ERROR
    END

    RETURN

SELECT.COMPILE.DATES.MASTER: *********************************************
* select all master records in ud.compile.dates.  returns select handle  *
* slist                                                                  *
**************************************************************************
    STATEMENT = 'SELECT UD.COMPILE.DATES'
    STATEMENT := ' WITH MASTER = "Y"'

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    RETURN

SELECT.COMPILE.DATES.DETAIL: *********************************************
* select all detail records in ud.compile.dates for object.name.         *
* returns select handle slist                                            *
**************************************************************************
    STATEMENT = 'SELECT UD.COMPILE.DATES WITH OBJECT = "':OBJECT.NAME:'"'
    STATEMENT := ' AND WITH DETAIL = "Y"'

    EXECUTE STATEMENT CAPTURING TEXT RTNLIST SLIST

    RETURN


**************************************************************************
**************************************************************************
** code conversion / build code blocks                                  **
**************************************************************************
**************************************************************************

BUILD.SHARED.COMMON.CODE: ************************************************
* build shared common block                                              *
**************************************************************************
    COMMON.CODE = ""
    COMMON.LINE.COUNT = 0

    COMMON.CODE.START = "    COMMON /":OBJECT.NAME:CURRENT.COMMON.SUFFIX:"/ "
    COMMON.EQUATE.START = "    EQUATE "

    IF ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES OR OBJECT.PICK.FLAVOR <> "NONE" THEN
        GOSUB ADD.CURRENT.FLAVOR.COMMON
    END

    GOSUB ADD.MAX.INSTANCES.COMMON
    IF ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES THEN
        GOSUB ADD.SET.MAX.INSTANCES.COMMON
    END

    IF MAX.INSTANCES > 1 THEN
        GOSUB ADD.MULTIPLE.INSTANCES.COMMON
    END

    GOSUB ADD.CURRENT.PROPERTY.COMMON
    GOSUB ADD.CURRENT.CONSTANT.COMMON
    GOSUB ADD.CURRENT.CHILD.COMMON

* add additional common variables for special object types
    BEGIN CASE
        CASE RESIDENT.OBJECT
            GOSUB ADD.RESIDENT.INSTANCE.COMMON
        CASE SINGLE.OBJECT
            GOSUB ADD.SINGLE.INSTANCE.COMMON
    END CASE

    GOSUB ADD.CURRENT.HANDLE.COMMON
    GOSUB ADD.OBJECT.DEBUG.COMMON

    IF DETAILS THEN
        GOSUB PRINT.SHARED.COMMON
    END

    RETURN

PRINT.SHARED.COMMON: *****************************************************
* print shared common code for debugging                                 *
**************************************************************************
    PRINT
    PRINT "Shared Common Area:"

    FOR PTR = 1 TO COMMON.LINE.COUNT
        PRINT PTR "R%4":" ":COMMON.CODE<PTR>
    NEXT PTR

    GOSUB WAIT

    RETURN

ADD.CURRENT.FLAVOR.COMMON: ***********************************************
* if "expanding instances" is turned on we need to be able to            *
* redimension arrays so we'll compile this routine using "ideal" options *
**************************************************************************

* build shared common area for properties.  these will be dimensioned
* by property handle so that multiple "objects" are all stored in the
* same named common area

* if the flavor isn't "DEFAULT", "INFORMATION" or "PIOPEN" change it
* to "DEFAULT".  we need a pick flavor where we can redimension arrays
* at run time
    USE.FLAVOR = OBJECT.PICK.FLAVOR
    IF ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES THEN
        IF USE.FLAVOR <> "DEFAULT" AND USE.FLAVOR <> "INFORMATION" AND USE.FLAVOR <> "PIOPEN" THEN
            USE.FLAVOR = "DEFAULT"
        END
    END

    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* compile in the IDEAL flavor to allow redimensioning of arrays"
    GOSUB COMMON.CODE

    CODE = "    $OPTIONS ":USE.FLAVOR
    IF OBJECT.PICK.OPTIONS <> "" AND OBJECT.PICK.OPTIONS <> "NONE" THEN
        CODE := ", ":OBJECT.PICK.OPTIONS
    END
    GOSUB COMMON.CODE

    RETURN

ADD.CURRENT.PROPERTY.COMMON: *********************************************
* add common statements to the common block for property values          *
**************************************************************************
    IF MAX.INSTANCES = 1 THEN
        ARRAY.PTR = 1
    END ELSE
        ARRAY.PTR = "OBJECT.PTR"
    END

* build shared common area for current property values.
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* storage area for the current property instance"
    GOSUB COMMON.CODE

* add multiple lines of common statements depending on props.per.line
    FOR PROP.LOOP = 1 TO PROP.COUNT STEP PROPS.PER.LINE

        CODE = COMMON.CODE.START
        EQUATE.CODE = COMMON.EQUATE.START

* add this common line's properties
        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = PROP.LOOP + FIELD.LOOP

            THIS.PROP = PROP.NAME.LIST<PTR>
            THIS.DIM = PROP.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
            THIS.TYPE = PROP.TYPE.LIST<PTR>

            IF THIS.PROP <> "" THEN

* if we're using equated properties then add to the equated property
* line if the property is not dimensioned.  otherwise add to the common
* line

* if max.instances is 1 (only one instance of this object) then we
* still need the common variables since there won't be any dimensioned
* object variables
                IF THIS.TYPE = "PROPERTY" AND USE.EQUATED.PROPERTIES AND THIS.DIMENSIONS = 0 AND MAX.INSTANCES > 1 THEN

                    LONG.VARIABLE = THIS.PROP:INSTANCE.SUFFIX
                    GOSUB CHECK.VARIABLE.NAME

                    IF EQUATE.CODE <> COMMON.EQUATE.START THEN
                        EQUATE.CODE := ", "
                    END

                    EQUATE.CODE := THIS.PROP:" TO ":SHORT.VARIABLE:"(":ARRAY.PTR:")"

                END ELSE

                    IF CODE <> COMMON.CODE.START THEN
                        CODE := ", "
                    END

                    CODE := THIS.PROP

                    IF THIS.DIMENSIONS > 0 THEN
                        CODE := "(":CHANGE(THIS.DIM, @VM, ","):")"
                    END

                END

            END

        NEXT FIELD

        IF CODE <> COMMON.CODE.START THEN
            GOSUB COMMON.CODE
        END

        IF EQUATE.CODE <> COMMON.EQUATE.START THEN
            CODE = EQUATE.CODE
            GOSUB COMMON.CODE
        END

    NEXT PROP.LOOP

    RETURN

ADD.CURRENT.CONSTANT.COMMON: *********************************************
* add current constant common values to the common code block            *
**************************************************************************

* add entries for current constants
    IF CONSTANT.COUNT > 0 THEN
        CODE = " "
        GOSUB COMMON.CODE
        CODE = "* storage area for constants"
        GOSUB COMMON.CODE
    END

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT STEP PROPS.PER.LINE

        CODE = COMMON.CODE.START

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = CONSTANT.LOOP + FIELD.LOOP

            THIS.CONSTANT = CONSTANT.NAME.LIST<PTR>

* don't add max.instances.  we'll take care of max.instances elsewhere
            IF THIS.CONSTANT <> "" AND THIS.CONSTANT <> "MAX.INSTANCES" THEN
                IF CODE <> COMMON.CODE.START THEN
                    CODE := ", "
                END
                CODE := THIS.CONSTANT
            END

        NEXT FIELD

        IF CODE <> COMMON.CODE.START THEN
            GOSUB COMMON.CODE
        END

    NEXT PROP.LOOP

    RETURN

ADD.CURRENT.CHILD.COMMON: ************************************************
* add entries for child objects to the current common block              *
**************************************************************************
    IF MAX.INSTANCES = 1 THEN
        ARRAY.PTR = 1
    END ELSE
        ARRAY.PTR = "OBJECT.PTR"
    END

    IF CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB COMMON.CODE
        CODE = "* storage area for child object handles"
        GOSUB COMMON.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT STEP PROPS.PER.LINE

        CODE = COMMON.CODE.START
        EQUATE.CODE = COMMON.EQUATE.START

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = CHILD.LOOP + FIELD.LOOP

            THIS.NAME = CHILD.NAME.LIST<PTR>
            THIS.HANDLE = CHILD.HANDLE.LIST<PTR>
            THIS.VARIABLE = CHILD.VARIABLE.LIST<PTR>
            THIS.DIM = CHILD.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
            THIS.KEYWORD = CHILD.KEYWORD.LIST<PTR>
            THIS.DEPTH = CHILD.DEPTH.LIST<PTR>

            DECODE.KEYWORD = THIS.KEYWORD
            GOSUB DECODE.PROPERTY

            IF THIS.NAME <> "" THEN

* if max.instances is 1 (only one instance of this object) then we
* still need the common variables since there won't be any dimensioned
* object variables
                IF USE.EQUATED.CHILD.OBJECTS AND THIS.DIMENSIONS = 0 AND MAX.INSTANCES > 1 THEN

                    LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                    GOSUB CHECK.VARIABLE.NAME
                    ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                    LONG.VARIABLE = THIS.VARIABLE
                    GOSUB CHECK.VARIABLE.NAME

                    IF EQUATE.CODE <> COMMON.EQUATE.START THEN
                        EQUATE.CODE := ", "
                    END

*                   EQUATE.CODE := THIS.VARIABLE:" TO ":THIS.VARIABLE:INSTANCE.SUFFIX:"(":ARRAY.PTR:")"
                    EQUATE.CODE := SHORT.VARIABLE:" TO ":ARRAY.VARIABLE.NAME:"(":ARRAY.PTR:")"

                END ELSE

                    IF CODE <> COMMON.CODE.START THEN
                        CODE := ", "
                    END

                    LONG.VARIABLE = THIS.VARIABLE
                    GOSUB CHECK.VARIABLE.NAME

                    CODE := SHORT.VARIABLE
                    IF THIS.DIM <> "" THEN
                        CODE := "(":CHANGE(THIS.DIM, VM, ","):")"
                    END

                END

            END

        NEXT FIELD

        IF CODE <> COMMON.CODE.START THEN
            GOSUB COMMON.CODE
        END

        IF EQUATE.CODE <> COMMON.EQUATE.START THEN
            CODE = EQUATE.CODE
            GOSUB COMMON.CODE
        END

    NEXT CHILD.LOOP

    RETURN

ADD.MAX.INSTANCES.COMMON: ************************************************
* add a common line for max.instances                                    *
**************************************************************************
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* maximum number of instances of this object"
    GOSUB COMMON.CODE
    CODE = COMMON.CODE.START:"MAX.INSTANCES"
    GOSUB COMMON.CODE

    RETURN

ADD.SET.MAX.INSTANCES.COMMON: ********************************************
* if we're allowing expanding instances then set max.instances to the    *
* default max.instance count but ONLY if it's not already set.           *
* max.instances may change as additional object instances are added and  *
* we need to dimension things to the last size to which they were        *
* redimensioned                                                          *
**************************************************************************
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* set max.instances count the first time only"
    GOSUB COMMON.CODE
    CODE = "    IF UNASSIGNED(MAX.INSTANCES) THEN"
    GOSUB COMMON.CODE
    CODE = "        MAX.INSTANCES = ":MAX.INSTANCES
    GOSUB COMMON.CODE
    CODE = "    END"
    GOSUB COMMON.CODE

    RETURN

ADD.RESIDENT.INSTANCE.COMMON: ********************************************
* add common code for resident objects                                   *
**************************************************************************

* for resident object we keep a common flag for whether the object has
* been initialized or not.  for resident objects we want to initialize it
* once when it's first created but not when later programs "create" the
* resident instance again
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* resident object common"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:CURRENT.COMMON.SUFFIX:"/ "
    CODE := RESIDENT.INITIALIZE.VARIABLE
    GOSUB COMMON.CODE

    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* initialize flags if necessary"
    GOSUB COMMON.CODE
    CODE = "    IF UNASSIGNED(":RESIDENT.INITIALIZE.VARIABLE:") THEN"
    GOSUB COMMON.CODE
    CODE = "        ":RESIDENT.INITIALIZE.VARIABLE:" = @FALSE"
    GOSUB COMMON.CODE
    CODE = "    END"
    GOSUB COMMON.CODE

    RETURN

ADD.SINGLE.INSTANCE.COMMON: **********************************************
* add common code for objects with a single instance                     *
**************************************************************************

* if this object has only a single instance add a "single instance create"
* counter common variable.  each time a call to create this instance is done
* we'll increment this counter so we know how many times a "create" was done
* each time a "destroy" is done we'll decrement the counter.  we'll only
* truly destroy this instance when the counter gets to zero.  that way if
* multiple objects "create" this one instance it will only disappear when all
* of the multiple objects have destroyed it
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* single instance creation counter"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:CURRENT.COMMON.SUFFIX:"/ "
    CODE := SINGLE.INSTANCE.COUNT.VARIABLE:", ":SINGLE.INSTANCE.LIST.VARIABLE
    GOSUB COMMON.CODE

    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* initialize single instance creation counter if necessary"
    GOSUB COMMON.CODE
    CODE = "    IF UNASSIGNED(":SINGLE.INSTANCE.COUNT.VARIABLE:") THEN"
    GOSUB COMMON.CODE
    CODE = "        ":SINGLE.INSTANCE.COUNT.VARIABLE:" = 0"
    GOSUB COMMON.CODE
    CODE = "    END"
    GOSUB COMMON.CODE
    CODE = "    IF UNASSIGNED(":SINGLE.INSTANCE.LIST.VARIABLE:") THEN"
    GOSUB COMMON.CODE
    CODE = "        ":SINGLE.INSTANCE.LIST.VARIABLE:' = ""'
    GOSUB COMMON.CODE
    CODE = "    END"
    GOSUB COMMON.CODE

    RETURN

ADD.MULTIPLE.INSTANCES.COMMON: *******************************************
* add common variables to handle multiple instances of an object         *
**************************************************************************

* if we're allowing expanding instances then we'll dimension the
* multiple-instances arrays using "MAX.INSTANCES" as the first dimension
* index.  if not we'll use the actual max.instances value
    IF ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES THEN
        INSTANCE.INDEX = "MAX.INSTANCES"
    END ELSE
        INSTANCE.INDEX = MAX.INSTANCES
    END

    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* storage area for all property instances"
    GOSUB COMMON.CODE

    FOR PROP.LOOP = 1 TO PROP.COUNT STEP PROPS.PER.LINE

        CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ "
        FIRST.ON.LINE = @TRUE

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = PROP.LOOP + FIELD.LOOP
            THIS.PROP = PROP.NAME.LIST<PTR>
            THIS.DIM = PROP.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
            THIS.TYPE = PROP.TYPE.LIST<PTR>

* static properties don't need an entry in the multiple instance
* common since they aren't loaded and unloaded
            IF THIS.TYPE <> "STATIC" AND THIS.TYPE <> "STATICARRAY" AND THIS.PROP <> "" THEN

                IF NOT(FIRST.ON.LINE) THEN
                    CODE := ", "
                END
                FIRST.ON.LINE = @FALSE

                LONG.VARIABLE = THIS.PROP:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE := SHORT.VARIABLE

* dimensioned variables.  we need the first dimension for the instance.
* we only get variables dimensioned up to two dimensions and we need
* three to include the instance.  for two-dimensional arrays we'll fold
* the two dimensions into one
                BEGIN CASE

* properties and arrays
                    CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0
                        CODE := "(":INSTANCE.INDEX:")"
                    CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 1
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM:")"
                    CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 2
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM<1,1> * THIS.DIM<1,2>:")"

* statics
                    CASE THIS.TYPE = "STATIC" AND THIS.DIMENSIONS = 0
                        NULL
                    CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 1
                        CODE := "(":THIS.DIM:")"
                    CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 2
                        CODE := "(":THIS.DIM<1,1>:",":THIS.DIM<1,2>:")"

* catch-all
                    CASE 1
                        CODE := "(":INSTANCE.INDEX:")"

                END CASE

            END

        NEXT FIELD

        IF NOT(FIRST.ON.LINE) THEN
            GOSUB COMMON.CODE
        END

    NEXT PROP.LOOP

* add storage area for the registry source id used to create this object
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* storage area for registry source ids for all instances"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ "
    CODE := "INSTANCE.REGISTRY.SOURCE.ID.TABLE(":INSTANCE.INDEX:")"
    GOSUB COMMON.CODE

    CODE = " "
    GOSUB COMMON.CODE

* add entries for child objects
    IF CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB COMMON.CODE
        CODE = "* storage area for child object handles"
        GOSUB COMMON.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT STEP PROPS.PER.LINE

        CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ "

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = CHILD.LOOP + FIELD.LOOP
            THIS.NAME = CHILD.NAME.LIST<PTR>
            THIS.HANDLE = CHILD.HANDLE.LIST<PTR>
            THIS.VARIABLE = CHILD.VARIABLE.LIST<PTR>
            THIS.DIM = CHILD.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

            IF THIS.NAME <> "" THEN

                IF FIELD.LOOP > 0 THEN
                    CODE := ", "
                END

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE := SHORT.VARIABLE

                BEGIN CASE
                    CASE THIS.DIMENSIONS = 0
                        CODE := "(":INSTANCE.INDEX:")"
                    CASE THIS.DIMENSIONS = 1
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM:")"
                    CASE THIS.DIMENSIONS = 2
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM<1,1> * THIS.DIM<1,2>:")"
                END CASE

            END

        NEXT FIELD

        GOSUB COMMON.CODE

    NEXT CHILD.LOOP

    RETURN

ADD.CURRENT.HANDLE.COMMON: ***********************************************
* add shared common variables for current handle                         *
**************************************************************************
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* storage area for current and last object handles"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ LAST.OBJECT.HANDLE"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ ACTIVE.OBJECT.HANDLE"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.NAME:INSTANCE.COMMON.SUFFIX:"/ INSTANCE.REGISTRY.SOURCE.ID"
    GOSUB COMMON.CODE

    RETURN

ADD.OBJECT.DEBUG.COMMON: *************************************************
* add common statements for the object common area                       *
**************************************************************************
    CODE = " "
    GOSUB COMMON.CODE
    CODE = "* storage area for object debug, available in all objects"
    GOSUB COMMON.CODE
    CODE = "    COMMON /":OBJECT.COMMON.NAME:"/ OBJECT.DEBUGGING.ENABLED"
    GOSUB COMMON.CODE
    CODE = "    IF UNASSIGNED(OBJECT.DEBUGGING.ENABLED) THEN"
    GOSUB COMMON.CODE
    CODE = "        OBJECT.DEBUGGING.ENABLED = @FALSE"
    GOSUB COMMON.CODE
    CODE = "    END"
    GOSUB COMMON.CODE

    RETURN

COMMON.CODE: *************************************************************
* add code to common.code                                                *
**************************************************************************
    COMMON.LINE.COUNT += 1

*   COMMON.CODE<COMMON.LINE.COUNT> = CODE
    IF COMMON.LINE.COUNT = 1 THEN
        COMMON.CODE = CODE
    END ELSE
        COMMON.CODE := @AM:CODE
    END

    RETURN

BUILD.REDIM.CODE: ********************************************************
* build routine to redimension multiple instance arrays for a new        *
* max.instances value                                                    *
**************************************************************************
    INSTANCE.INDEX = "MAX.INSTANCES"

    REDIM.CODE = ""
    REDIM.LINE.COUNT = 0

* build routine to redimension arrays
    CODE = "REDIM.PROPERTY.ARRAYS: ***************************************************"
    GOSUB REDIM.CODE
    CODE = "* redimension property arrays based on max.instances.  adds              *"
    GOSUB REDIM.CODE
    CODE = "* add.instance.count additional instances to the property.               *"
    GOSUB REDIM.CODE
    CODE = "* if add.instance.count is negative will remove instances and            *"
    GOSUB REDIM.CODE
    CODE = "* return memory to the system                                            *"
    GOSUB REDIM.CODE
    CODE = "**************************************************************************"
    GOSUB REDIM.CODE

* increase max.instances
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* add / remove an additional block of instances."
    GOSUB REDIM.CODE
    CODE = "    NEW.MAX.INSTANCES = MAX.INSTANCES + ADD.INSTANCE.COUNT"
    GOSUB REDIM.CODE

* max.instances can never go below the initial max.instances setting
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* if the new instance count is less than the initial instance count"
    GOSUB REDIM.CODE
    CODE = "* keep it at the initial instance count"
    GOSUB REDIM.CODE
    CODE = "    IF NEW.MAX.INSTANCES < ":MAX.INSTANCES:" THEN"
    GOSUB REDIM.CODE
    CODE = "        NEW.MAX.INSTANCES = ":MAX.INSTANCES
    GOSUB REDIM.CODE
    CODE = "    END"
    GOSUB REDIM.CODE

* if the new max.instances is the same as the old then dump out
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* if the instance count didn't change then exit"
    GOSUB REDIM.CODE
    CODE = "    IF NEW.MAX.INSTANCES = MAX.INSTANCES THEN"
    GOSUB REDIM.CODE
    CODE = "        RETURN"
    GOSUB REDIM.CODE
    CODE = "    END"
    GOSUB REDIM.CODE

* if there are any active instances above the new instance count
* then reisizing would throw away these instances.  dump out
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* if we're reducing max.instances make sure that resetting max.instances"
    GOSUB REDIM.CODE
    CODE = "* won't destroy any active instances"
    GOSUB REDIM.CODE
    CODE = "    IF NEW.MAX.INSTANCES < MAX.INSTANCES THEN"
    GOSUB REDIM.CODE
    CODE = "        FOR INSTANCE.LOOP = NEW.MAX.INSTANCES + 1 TO MAX.INSTANCES"
    GOSUB REDIM.CODE
    CODE = "            IF ACTIVE.OBJECT.HANDLE<INSTANCE.LOOP> THEN"
    GOSUB REDIM.CODE
    CODE = "                RETURN"
    GOSUB REDIM.CODE
    CODE = "            END"
    GOSUB REDIM.CODE
    CODE = "        NEXT INSTANCE.LOOP"
    GOSUB REDIM.CODE
    CODE = "    END"
    GOSUB REDIM.CODE

* reset the max.instances count and available instances
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* reset max.instances and available instances"
    GOSUB REDIM.CODE
    CODE = "    MAX.INSTANCES = NEW.MAX.INSTANCES"
    GOSUB REDIM.CODE
    CODE = "    USED.INSTANCES = SUM(ACTIVE.OBJECT.HANDLE)"
    GOSUB REDIM.CODE
    CODE = "    AVAIL.INSTANCES = MAX.INSTANCES - USED.INSTANCES"
    GOSUB REDIM.CODE

* code to redimension property arrays to the new max.instances size
    IF PROP.COUNT > 0 THEN
        CODE = " "
        GOSUB REDIM.CODE
        CODE = "* redimension arrays to add / remove the additional instances"
        GOSUB REDIM.CODE
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        CODE = "    DIM "
        FIRST.ON.LINE = @TRUE

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = PROP.LOOP + FIELD.LOOP
            THIS.PROP = PROP.NAME.LIST<PTR>
            THIS.DIM = PROP.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
            THIS.TYPE = PROP.TYPE.LIST<PTR>

* static properties don't need an entry in the multiple instance
* common since they aren't loaded and unloaded.  TH
            IF THIS.TYPE <> "STATIC" AND THIS.TYPE <> "STATICARRAY" AND THIS.PROP <> "" THEN

                IF NOT(FIRST.ON.LINE) THEN
                    CODE := ", "
                END

                FIRST.ON.LINE = @FALSE

                LONG.VARIABLE = THIS.PROP:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE := SHORT.VARIABLE

* redimension dimensioned variables.  we need the first dimension for the instance.
* we only get variables dimensioned up to two dimensions and we need
* three to include the instance.  for two-dimensional arrays we'll fold
* the two dimensions into one
                BEGIN CASE

* properties and arrays
                    CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0
                        CODE := "(":INSTANCE.INDEX:")"

                    CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 1
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM:")"

                    CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 2
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM<1, 1> * THIS.DIM<1, 2>:")"

                END CASE

            END

        NEXT FIELD

* save the code line if we have at least one array on it
        IF NOT(FIRST.ON.LINE) THEN
            GOSUB REDIM.CODE
        END

    NEXT PROP.LOOP

* redim child objects
    IF CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB REDIM.CODE
        CODE = "* redimension child object arrays to add / remove the additional instances"
        GOSUB REDIM.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT STEP PROPS.PER.LINE

        CODE = "    DIM "

        FOR FIELD.LOOP = 0 TO PROPS.PER.LINE - 1

            PTR = CHILD.LOOP + FIELD.LOOP
            THIS.NAME = CHILD.NAME.LIST<PTR>
            THIS.HANDLE = CHILD.HANDLE.LIST<PTR>
            THIS.VARIABLE = CHILD.VARIABLE.LIST<PTR>
            THIS.DIM = CHILD.DIM.LIST<PTR>
            THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

            IF THIS.NAME <> "" THEN

                IF FIELD.LOOP > 0 THEN
                    CODE := ", "
                END

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE := SHORT.VARIABLE
                BEGIN CASE
                    CASE THIS.DIMENSIONS = 0
                        CODE := "(":INSTANCE.INDEX:")"
                    CASE THIS.DIMENSIONS = 1
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM:")"
                    CASE THIS.DIMENSIONS = 2
                        CODE := "(":INSTANCE.INDEX:",":THIS.DIM<1,1> * THIS.DIM<1,2>:")"
                END CASE

            END

        NEXT FIELD

        GOSUB REDIM.CODE

    NEXT CHILD.LOOP

* redim the instance.registry.source.id.table
    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* redimension the instance.registry.source.id.table"
    GOSUB REDIM.CODE
    CODE = "    DIM INSTANCE.REGISTRY.SOURCE.ID.TABLE(":INSTANCE.INDEX:")"
    GOSUB REDIM.CODE

    CODE = " "
    GOSUB REDIM.CODE
    CODE = "* update active instance table to match the new max.instances"
    GOSUB REDIM.CODE
    CODE = "    INSTANCE.TABLE.COUNT = DCOUNT(ACTIVE.OBJECT.HANDLE, @AM)"
    GOSUB REDIM.CODE
    CODE = "    IF INSTANCE.TABLE.COUNT > MAX.INSTANCES THEN"
    GOSUB REDIM.CODE
    CODE = "        INSTANCE.TABLE.COUNT = INSTANCE.TABLE.COUNT [@AM, 1, MAX.INSTANCES]"
    GOSUB REDIM.CODE
    CODE = "    END ELSE"
    GOSUB REDIM.CODE
    CODE = "        FOR ACTIVE.LOOP = INSTANCE.TABLE.COUNT + 1 TO MAX.INSTANCES"
    GOSUB REDIM.CODE
    CODE = "            INSTANCE.TABLE.COUNT<ACTIVE.LOOP> = 0"
    GOSUB REDIM.CODE
    CODE = "        NEXT ACTIVE.LOOP"
    GOSUB REDIM.CODE
    CODE = "    END"
    GOSUB REDIM.CODE

    CODE = " "
    GOSUB REDIM.CODE
    CODE = "    RETURN"
    GOSUB REDIM.CODE

    IF DETAILS THEN
        GOSUB PRINT.REDIM.CODE
    END

    RETURN

REDIM.CODE: **************************************************************
* add code to REDIM.CODE                                                 *
**************************************************************************
    REDIM.LINE.COUNT += 1

    IF REDIM.LINE.COUNT = 1 THEN
        REDIM.CODE = CODE
    END ELSE
        REDIM.CODE := @AM:CODE
    END

    RETURN

PRINT.REDIM.CODE: ********************************************************
* print out the redimensioning code for debugging                        *
**************************************************************************
    PRINT
    PRINT "Redimensioning Code:"

    IF REDIM.LINE.COUNT = 0 THEN
        PRINT
        PRINT "No Redimensioning Code"
    END

    FOR PTR = 1 TO REDIM.LINE.COUNT
        PRINT PTR "R%4":" ":REDIM.CODE<PTR>
    NEXT PTR

    GOSUB WAIT

    RETURN

CLEAR.INSTANCE.CODE: *****************************************************
* initialize the instance.code table                                     *
**************************************************************************
    INSTANCE.CODE = ""
    INSTANCE.LINE.COUNT = 0

    RETURN

BUILD.INSTANCE.CODE: *****************************************************
* build subroutines to handle object instance swapping                   *
**************************************************************************
    INSTANCE.START.DATE = DATE()
    INSTANCE.START.TIME = TIME()

    GOSUB CLEAR.INSTANCE.CODE

* decide which subroutines to add
    CHECK.OBJECT.INSTANCE = @FALSE
    CHECK.OBJECT.INSTANCE.SHORT = @FALSE

    INIT.CURRENT.OBJECT.INSTANCE = @FALSE

    SET.OBJECT.INSTANCE = @FALSE
    SET.OBJECT.INSTANCE.SHORT = @FALSE

    SAVE.CURRENT.OBJECT.INSTANCE = @FALSE
    LOAD.CURRENT.OBJECT.INSTANCE = @FALSE
    GET.NEW.OBJECT.HANDLE = @FALSE
    INIT.ALL.OBJECT.INSTANCES = @FALSE
    DESTROY.CURRENT.OBJECT.INSTANCE = @FALSE

    CLEAR.CHILD.OBJECTS = @TRUE

* decide which subroutines to add depending on the method
    BEGIN CASE

* null methood.  add all subroutines for testing
        CASE METHOD = "" OR ALL.SUBROUTINES
            CHECK.OBJECT.INSTANCE = @TRUE
            INIT.CURRENT.OBJECT.INSTANCE = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            LOAD.CURRENT.OBJECT.INSTANCE = @TRUE
            GET.NEW.OBJECT.HANDLE = @TRUE
            INIT.ALL.OBJECT.INSTANCES = @TRUE
            DESTROY.CURRENT.OBJECT.INSTANCE = @TRUE

* RESET method
        CASE METHOD = RESET.KEYWORD AND MAX.INSTANCES = 1
            CHECK.OBJECT.INSTANCE = @TRUE
            INIT.CURRENT.OBJECT.INSTANCE = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            CLEAR.CHILD.OBJECTS = @FALSE
        CASE METHOD = RESET.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE
            INIT.ALL.OBJECT.INSTANCES = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            CLEAR.CHILD.OBJECTS = @FALSE

* NEW method
        CASE METHOD = NEW.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE
            INIT.CURRENT.OBJECT.INSTANCE = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            LOAD.CURRENT.OBJECT.INSTANCE = @TRUE
            GET.NEW.OBJECT.HANDLE = @TRUE
        CASE METHOD = NEW.SHORT.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE
            CHECK.OBJECT.INSTANCE.SHORT = @TRUE
            SET.OBJECT.INSTANCE = @TRUE
            SET.OBJECT.INSTANCE.SHORT = @TRUE

* GET.PROPERTY method
        CASE METHOD = GET.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE

* PUT.PROPERTY method
        CASE METHOD = PUT.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE

* COPY.OBJECT method
        CASE METHOD = COPY.OBJECT.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE
            INIT.CURRENT.OBJECT.INSTANCE = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            LOAD.CURRENT.OBJECT.INSTANCE = @TRUE

* DESTROY method
        CASE METHOD = DESTROY.KEYWORD
            CHECK.OBJECT.INSTANCE = @TRUE
            SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
            LOAD.CURRENT.OBJECT.INSTANCE = @TRUE
            DESTROY.CURRENT.OBJECT.INSTANCE = @TRUE

* user-created method
        CASE 1
            CHECK.OBJECT.INSTANCE = @TRUE

    END CASE

* some subroutines call other routines.  if a routine is flagged to be
* added make sure the routines it calls are also added
    IF CHECK.OBJECT.INSTANCE AND NOT(CHECK.OBJECT.INSTANCE.SHORT) THEN
        SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
        LOAD.CURRENT.OBJECT.INSTANCE = @TRUE
    END
    IF GET.NEW.OBJECT.HANDLE THEN
        INIT.CURRENT.OBJECT.INSTANCE = @TRUE
        SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
    END
    IF INIT.ALL.OBJECT.INSTANCES THEN
        DESTROY.CURRENT.OBJECT.INSTANCE = @TRUE
    END
    IF DESTROY.CURRENT.OBJECT.INSTANCE THEN
        INIT.CURRENT.OBJECT.INSTANCE = @TRUE
        SAVE.CURRENT.OBJECT.INSTANCE = @TRUE
    END
    IF SAVE.CURRENT.OBJECT.INSTANCE AND LOAD.CURRENT.OBJECT.INSTANCE THEN
        SET.OBJECT.INSTANCE = @TRUE
    END

* if we only have one instance we don't need some of these routines
    IF MAX.INSTANCES = 1 THEN
        SAVE.CURRENT.OBJECT.INSTANCE = @FALSE
        LOAD.CURRENT.OBJECT.INSTANCE = @FALSE
        INIT.ALL.OBJECT.INSTANCES = @FALSE
        SET.OBJECT.INSTANCE = @FALSE
    END

* do we need any instance code?
    NEED.INSTANCE.CODE = @FALSE

    IF CHECK.OBJECT.INSTANCE OR INIT.CURRENT.OBJECT.INSTANCE OR SAVE.CURRENT.OBJECT.INSTANCE THEN
        NEED.INSTANCE.CODE = @TRUE
    END

    IF LOAD.CURRENT.OBJECT.INSTANCE OR GET.NEW.OBJECT.HANDLE OR INIT.ALL.OBJECT.INSTANCES THEN
        NEED.INSTANCE.CODE = @TRUE
    END

    IF SET.OBJECT.INSTANCE OR DESTROY.CURRENT.OBJECT.INSTANCE THEN
        NEED.INSTANCE.CODE = @TRUE
    END

* pretty comment block
    IF NEED.INSTANCE.CODE THEN

        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = "*** Instance Handling Routines                                         ***"
        GOSUB INSTANCE.CODE
        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    END

* add selected subroutines
    IF CHECK.OBJECT.INSTANCE THEN
        GOSUB ADD.CHECK.OBJECT.INSTANCE
    END

    IF INIT.CURRENT.OBJECT.INSTANCE THEN
        GOSUB ADD.INIT.CURRENT.OBJECT.INSTANCE
    END

    IF SET.OBJECT.INSTANCE THEN
        GOSUB ADD.SET.OBJECT.INSTANCE
    END

    IF SAVE.CURRENT.OBJECT.INSTANCE THEN
        GOSUB ADD.SAVE.CURRENT.OBJECT.INSTANCE
    END

    IF LOAD.CURRENT.OBJECT.INSTANCE THEN
        GOSUB ADD.LOAD.CURRENT.OBJECT.INSTANCE
    END

    IF GET.NEW.OBJECT.HANDLE THEN
        GOSUB ADD.GET.NEW.OBJECT.HANDLE
    END

    IF INIT.ALL.OBJECT.INSTANCES THEN
        GOSUB ADD.INIT.ALL.OBJECT.INSTANCES
    END

    IF DESTROY.CURRENT.OBJECT.INSTANCE THEN
        GOSUB ADD.DESTROY.CURRENT.OBJECT.INSTANCE
    END

    IF DETAILS THEN
        GOSUB PRINT.INSTANCE.CODE
    END

    INSTANCE.END.DATE = DATE()
    INSTANCE.END.TIME = TIME()
    INSTANCE.ELAPSED.TIME += TIME.ELAPSED (INSTANCE.START.DATE, INSTANCE.START.TIME)

    RETURN

PRINT.INSTANCE.CODE: *****************************************************
* print out instance code for debugging                                  *
**************************************************************************
    PRINT
    PRINT "Instance Code:"

    IF NOT(NEED.INSTANCE.CODE) THEN
        PRINT
        PRINT "No Instance Code needed"
    END

    FOR PTR = 1 TO INSTANCE.LINE.COUNT
        PRINT PTR "R%4":" ":INSTANCE.CODE<PTR>
    NEXT PTR

    GOSUB WAIT

    RETURN

BUILD.OBJECT.SUB.CODE: ***************************************************
* build instance.code for an object-enabled subroutine                   *
**************************************************************************
    GOSUB CLEAR.INSTANCE.CODE
    GOSUB ADD.UTILITY.ROUTINES

    RETURN

ADD.CHECK.OBJECT.INSTANCE: ***********************************************
* create check.object.instance subroutine.  this routine checks to see if*
* the current instance handle is different from the one used during the  *
* last method call.  if it is different then the current properties are  *
* saved and the new ones are loaded                                      *
**************************************************************************
    CODE = "CHECK.OBJECT.INSTANCE: ***************************************************"
    GOSUB INSTANCE.CODE
    CODE = "* load current object instance into subroutine variables                 *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

* make sure we have a good object handle.  the "new" method will be creating
* a new handle so we'll skip this check for "new"
    IF VALIDATE.OBJECT.HANDLE AND METHOD <> NEW.KEYWORD AND METHOD <> NEW.SHORT.KEYWORD THEN

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* validate the object handle"
        GOSUB INSTANCE.CODE
        CODE = "    ":ERROR.MESSAGE.VARIABLE:' = ""'
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "    BEGIN CASE"
        GOSUB INSTANCE.CODE
        CODE = '        CASE UNASSIGNED(OBJECT.HANDLE)'
        GOSUB INSTANCE.CODE
        CODE = "            ":ERROR.MESSAGE.VARIABLE:' = "Object handle is unassigned.  Object has not been created or has been destroyed."'
        GOSUB INSTANCE.CODE
        CODE = '        CASE OBJECT.HANDLE = ""'
        GOSUB INSTANCE.CODE
        CODE = "            ":ERROR.MESSAGE.VARIABLE:' = "Object handle is null.  Object has not been created or has been destroyed."'
        GOSUB INSTANCE.CODE
        CODE = '        CASE OBJECT.HANDLE = "0"'
        GOSUB INSTANCE.CODE
        CODE = "            ":ERROR.MESSAGE.VARIABLE:' = "Object handle is zero.  Object has not been created or has been destroyed."'
        GOSUB INSTANCE.CODE
        CODE = "        CASE NOT(NUM(OBJECT.HANDLE<1>))"
        GOSUB INSTANCE.CODE
        CODE = "            ":ERROR.MESSAGE.VARIABLE:' = "Invalid object handle ptr."'
        GOSUB INSTANCE.CODE
        CODE = '        CASE OBJECT.HANDLE<2> = ""'
        GOSUB INSTANCE.CODE
        CODE = "            ":ERROR.MESSAGE.VARIABLE:' = "Invalid object handle ptr."'
        GOSUB INSTANCE.CODE
        CODE = "    END CASE"
        GOSUB INSTANCE.CODE

        CODE = "    IF ":ERROR.MESSAGE.VARIABLE:' <> "" THEN'
        GOSUB INSTANCE.CODE
        CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
        GOSUB INSTANCE.CODE
        CODE = "    END"
        GOSUB INSTANCE.CODE

    END

* for resident objects and single-instance objects there's only one
* instance so we'll never have to switch out the current property values
    IF RESIDENT.OBJECT OR SINGLE.OBJECT THEN

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* this object has only one instance.  this wrong instance properties"
        GOSUB INSTANCE.CODE
        CODE = "*  will never loaded"
        GOSUB INSTANCE.CODE
        CODE = "    OBJECT.PTR = OBJECT.HANDLE<1>"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

* if the local call variable is different than object.handle set it here
        IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
            CODE = "    ":LOCAL.OBJECT.VARIABLE:" = OBJECT.HANDLE"
            GOSUB INSTANCE.CODE
        END
    
        CODE = " "
        GOSUB INSTANCE.CODE

    END ELSE

        CODE = '    IF UNASSIGNED(LAST.OBJECT.HANDLE) THEN LAST.OBJECT.HANDLE = ""'
        GOSUB INSTANCE.CODE

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* if this handle is different from the current handle loaded then"
        GOSUB INSTANCE.CODE
        CODE = "* save the current handle and load the new one"
        GOSUB INSTANCE.CODE
        CODE = "    IF LAST.OBJECT.HANDLE<1> <> OBJECT.HANDLE<1> THEN"
        GOSUB INSTANCE.CODE
        CODE = "        GOSUB SET.OBJECT.INSTANCE"
        GOSUB INSTANCE.CODE
        CODE = "    END"
        GOSUB INSTANCE.CODE

* if the local call variable is different than object.handle set it here
        IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
            CODE = "    ":LOCAL.OBJECT.VARIABLE:" = OBJECT.HANDLE"
            GOSUB INSTANCE.CODE
        END
    
        CODE = "    OBJECT.PTR = OBJECT.HANDLE<1>"
        GOSUB INSTANCE.CODE

    END

    GOSUB INSTANCE.RETURN

    RETURN

ADD.INIT.CURRENT.OBJECT.INSTANCE: ****************************************
* create init.current.instance.  this routine clears all the current     *
* property values.  if clear.child.objects is set child object handles   *
* will be cleared as well                                                *
**************************************************************************
    CODE = "INIT.CURRENT.OBJECT.INSTANCE: ********************************************"
    GOSUB INSTANCE.CODE
    CODE = "* initialize variables in current instance                               *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

* clear properties
    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>

* clear all properties
        BEGIN CASE

* clear a static property's value.  we only want to clear a static's
* value if it's unassigned
            CASE THIS.TYPE = "STATIC" AND THIS.DIMENSIONS = 0
                CODE = "    IF UNASSIGNED(":THIS.NAME:") THEN"
                GOSUB INSTANCE.CODE
                CODE = "        ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 1
                CODE = "    IF UNASSIGNED(":THIS.NAME:"(1)) THEN"
                GOSUB INSTANCE.CODE
                CODE = "        MAT ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 2
                CODE = "    IF UNASSIGNED(":THIS.NAME:"(1,1) THEN"
                GOSUB INSTANCE.CODE
                CODE = "        MAT ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE

* clear a property's value
            CASE THIS.DIMENSIONS = 0
                CODE = "    ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE

            CASE THIS.DIMENSIONS = 1
                CODE = "    MAT ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE

            CASE THIS.DIMENSIONS = 2
                CODE = "    MAT ":THIS.NAME:" = ":'""'
                GOSUB INSTANCE.CODE

* clear elements individually.  probably don't want to it this way.  the
* above case statements will take care of it but leaving this code in
* in case we change our mind
            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>
                CODE = "    FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE
                CODE = "        "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                CODE := " = "
                CODE := '""'
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE
                CODE = "            "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := " = ":'""'
                GOSUB INSTANCE.CODE
                CODE = "        NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

* clear a static array individually
            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>
                CODE = "    FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE
                CODE = "        "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                CODE := " = "
                CODE := '""'
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE
                CODE = "            "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := " = ":'""'
                GOSUB INSTANCE.CODE
                CODE = "        NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

        END CASE

    NEXT PROP.LOOP

* clear child handles
    IF CLEAR.CHILD.OBJECTS THEN

        FOR CHILD.LOOP = 1 TO CHILD.COUNT

            THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
            THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
            THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
            THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>

            LONG.VARIABLE = THIS.VARIABLE
            GOSUB CHECK.VARIABLE.NAME

            IF THIS.DIM = "" THEN
                CODE = "    ":SHORT.VARIABLE:' = ""'
                GOSUB INSTANCE.CODE
            END ELSE
                CODE = "    MAT ":SHORT.VARIABLE:' = ""'
                GOSUB INSTANCE.CODE
            END

        NEXT CHILD.LOOP

    END

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* set the handle of the last object loaded"
    GOSUB INSTANCE.CODE
    CODE = "    LAST.OBJECT.HANDLE = OBJECT.HANDLE"
    GOSUB INSTANCE.CODE

    GOSUB INSTANCE.RETURN

    RETURN

ADD.SET.OBJECT.INSTANCE: *************************************************
* create set.object.instance.  this is a wrapper for calling             *
* save.current.object.instance and then load.current.object.instance to  *
* make things a little easier                                            *
**************************************************************************
    CODE = "SET.OBJECT.INSTANCE: *****************************************************"
    GOSUB INSTANCE.CODE
    CODE = "* save whatever object instance is currently loaded into the             *"
    GOSUB INSTANCE.CODE
    CODE = "* object tables and load the curren object instance                      *"
    GOSUB INSTANCE.CODE
    CODE = "* this routine is also called if an object call is made for a            *"
    GOSUB INSTANCE.CODE
    CODE = "* different instance of this same object.  calls like this will          *"
    GOSUB INSTANCE.CODE
    CODE = "* return property values still set for the other instance of the         *"
    GOSUB INSTANCE.CODE
    CODE = "* object.  calling this routine reloads properties for this              *"
    GOSUB INSTANCE.CODE
    CODE = "* instance                                                               *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

* if we're creating the "short" set.object.instance don't save / load any
* instances.  this is done for the new.short method that is called for the
* dotnet calls
    IF NOT(SET.OBJECT.INSTANCE.SHORT) THEN
        CODE = "    GOSUB SAVE.CURRENT.OBJECT.INSTANCE"
        GOSUB INSTANCE.CODE
        CODE = "    GOSUB LOAD.CURRENT.OBJECT.INSTANCE"
        GOSUB INSTANCE.CODE
    END

    GOSUB INSTANCE.RETURN

    RETURN

ADD.SAVE.CURRENT.OBJECT.INSTANCE: ****************************************
* create save.current.object.instance.  this routine saves the current   *
* properties in the property table for the last object handle used.      *
**************************************************************************
    CODE = "SAVE.CURRENT.OBJECT.INSTANCE: ********************************************"
    GOSUB INSTANCE.CODE
    CODE = "* save currently loaded instance into object tables                      *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

    CODE = "    LAST.OBJECT.PTR = LAST.OBJECT.HANDLE<1>"
    GOSUB INSTANCE.CODE
    CODE = '    IF LAST.OBJECT.PTR <> "" AND LAST.OBJECT.PTR > 0 AND LAST.OBJECT.PTR <= MAX.INSTANCES THEN'
    GOSUB INSTANCE.CODE

    IF PROP.COUNT > 0 AND MAX.INSTANCES > 1 THEN
        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* save properties into the multiple instance arrays"
        GOSUB INSTANCE.CODE
    END

    IF MAX.INSTANCES = 1 THEN
        CODE = "* this object has only one instance.  there are no value arrays"
        GOSUB INSTANCE.CODE
        ARRAY.PTR = "1"
    END ELSE
        ARRAY.PTR = "LAST.OBJECT.PTR"
    END

* update properties
    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM, @VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>

        BEGIN CASE

* if there is only one instance there are no value arrays to update
            CASE MAX.INSTANCES = 1
                NULL

* we don't need to assign statics and static arrays
            CASE THIS.TYPE = "STATIC"
                NULL
            CASE THIS.TYPE = "STATICARRAY"
                NULL

* non-dimensioned property and we're using equated properties.  no
* need to save it as the equated variable already updated the object's
* save array
            CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0 AND USE.EQUATED.PROPERTIES
                NULL

* non-dimensioned properties.  save it into the object's save array.
* each element is for an object instance
            CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := SHORT.VARIABLE:"(":ARRAY.PTR:")"
                CODE := " = "
                CODE := THIS.NAME
                GOSUB INSTANCE.CODE

* dimensioned properties.  again we're saving it into an object's
* save array.  if the property array has only one dimension then the save
* property's first array dimension will by for the object handle and the
* second will be for the property array's dimension
            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>

                CODE = "        FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := SHORT.VARIABLE:"(":ARRAY.PTR:", ARRAY.PTR)"
                CODE := " = "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

* if the dimensioned property has two dimensions we have to work harder.
* we can't have a three dimensional array so we'll use the first
* dimension of the save array for the object handle.  we'll calculate
* a single-dimensioned pointer from the dimensions of the property and the
* dimension sizes so we can fit the entire two-dimensional array into
* one dimension of the save array
            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>

                CODE = "        FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "            FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "                "
                CODE := SHORT.VARIABLE
                CODE := "(":ARRAY.PTR:", (ARRAY.PTR1 - 1) * ":MAX.ARRAY2:" + ARRAY.PTR2)"
                CODE := " = "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "            NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "        NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

* non-dimensioned static variable with no dimensions and we're using equated
* properties.  no need to update the object array since the equated variable
* already has
            CASE THIS.TYPE = "STATIC" AND THIS.DIMENSIONS = 0 AND USE.EQUATED.PROPERTIES
                NULL

* non-dimensioned statics
            CASE THIS.TYPE = "STATIC" AND THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := SHORT.VARIABLE
                CODE := " = "
                CODE := THIS.NAME
                GOSUB INSTANCE.CODE

* dimensioned statics.  this is done in a similar fashion to dimensioned properties.
            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>

                CODE = "        FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR)"
                CODE := " = "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

* again, converting the two-dimensional array to one dimension of the saved
* static array
            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>

                CODE = "        FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "            FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "                "
                CODE := SHORT.VARIABLE
                CODE := "(ARRAY.PTR1,ARRAY.PTR2)"
                CODE := " = "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "            NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "        NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

        END CASE

    NEXT PROP.LOOP

* update child objects
    IF CHILD.COUNT > 0 AND MAX.INSTANCES > 1 THEN
        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* save child handles"
        GOSUB INSTANCE.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        BEGIN CASE

* if there is only one instance there are no value arrays to update
            CASE MAX.INSTANCES = 1
                NULL

* normal handle but we're using equated property values.  the child handle
* has been equated to the object array so we don't need to copy it
            CASE THIS.DIMENSIONS = 0 AND USE.EQUATED.CHILD.OBJECTS
                NULL

* normal handle
            CASE THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := ARRAY.VARIABLE.NAME:"(":ARRAY.PTR:")"
                CODE := " = "
                CODE := SHORT.VARIABLE
                GOSUB INSTANCE.CODE

* dimensioned handle, one dimension
            CASE THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM

                CODE = "        FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := ARRAY.VARIABLE.NAME:"(":ARRAY.PTR:",ARRAY.PTR)"
                CODE := " = "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

* two dimensional array
            CASE THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>

                CODE = "        FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "            FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "                "
                CODE := ARRAY.VARIABLE.NAME
                CODE := "(":ARRAY.PTR:", (ARRAY.PTR1 - 1) * ":MAX.ARRAY2:" + ARRAY.PTR2)"
                CODE := " = "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR1, ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "            NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "        NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

        END CASE

    NEXT CHILD.LOOP

* save the instance.registry.source.id for the current object instance
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* save instance.registry.source.id for the current instance"
    GOSUB INSTANCE.CODE
    CODE = "        INSTANCE.REGISTRY.SOURCE.ID.TABLE(":ARRAY.PTR:") = "
    CODE := "INSTANCE.REGISTRY.SOURCE.ID"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

    GOSUB INSTANCE.RETURN

    RETURN

ADD.LOAD.CURRENT.OBJECT.INSTANCE: ****************************************
* create load.current.object.instance.  this routine loads the current   *
* property values with the ones from the property tables for the current *
* instance                                                               *
**************************************************************************
    CODE = "LOAD.CURRENT.OBJECT.INSTANCE: ********************************************"
    GOSUB INSTANCE.CODE
    CODE = "* load new instance from object tables                                   *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

    CODE = "    OBJECT.PTR = OBJECT.HANDLE<1>"
    GOSUB INSTANCE.CODE
    CODE = '    IF OBJECT.PTR = "*" THEN RETURN'
    GOSUB INSTANCE.CODE
    CODE = '    IF OBJECT.PTR = "0" OR OBJECT.PTR = "" OR OBJECT.PTR > MAX.INSTANCES THEN'
    GOSUB INSTANCE.CODE

* new code--handle the error
    CODE = "        ":ERROR.MESSAGE.VARIABLE:' = CURRENT.COMPLETE.NAME:": ":'
    CODE := '"Invalid Object Handle!"'
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB ":ERROR.LOG.GOSUB.NAME
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB INSTANCE.CODE

    CODE = "    END"
    GOSUB INSTANCE.CODE

* load properties
    IF PROP.COUNT > 0 AND MAX.INSTANCES > 1 THEN
        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* load properties from the multiple instance arrays"
        GOSUB INSTANCE.CODE
    END

    IF MAX.INSTANCES = 1 THEN
        CODE = "* this object has only one instance.  there are no value arrays"
        GOSUB INSTANCE.CODE
        ARRAY.PTR = 1
    END ELSE
        ARRAY.PTR = "OBJECT.PTR"
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>

        BEGIN CASE

* if there is one instance there are no value arrays to get values from
            CASE MAX.INSTANCES = 1
                NULL

* we don't need to load statics and static arrays
            CASE THIS.TYPE = "STATIC"
                NULL
            CASE THIS.TYPE = "STATICARRAY"
                NULL

* non-dimensioned property and we're using equated property variables.
* no need to load the property variable with the equate
            CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0 AND USE.EQUATED.PROPERTIES
                NULL

* non-dimensioned properties.  unload the property value from the saved
* property array
            CASE THIS.TYPE = "PROPERTY" AND THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "    ":THIS.NAME
                CODE := " = "
                CODE := SHORT.VARIABLE:"(":ARRAY.PTR:")"
                GOSUB INSTANCE.CODE

* dimensioned properties
            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>
                CODE = "    FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                CODE := " = "
                CODE := SHORT.VARIABLE:"(":ARRAY.PTR:",ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "    NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "ARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := " = "
                CODE := SHORT.VARIABLE
                CODE := "(":ARRAY.PTR:", (ARRAY.PTR1 - 1) * ":MAX.ARRAY2:" + ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

* non-dimensioned statics
            CASE THIS.TYPE = "STATIC" AND THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "    ":THIS.NAME:" = ":SHORT.VARIABLE
                GOSUB INSTANCE.CODE

* dimensioned statics
            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM<1,1>
                CODE = "    FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := THIS.NAME:"(ARRAY.PTR)"
                CODE := " = "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "    NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

            CASE THIS.TYPE = "STATICARRAY" AND THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.NAME:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := THIS.NAME:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := " = "
                CODE := SHORT.VARIABLE
                CODE := "(ARRAY.PTR1,ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

        END CASE

    NEXT PROP.LOOP

* load child objects
    IF CHILD.COUNT > 0 AND MAX.INSTANCES > 1 THEN
        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* load child handles"
        GOSUB INSTANCE.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        BEGIN CASE

* if there is only one instance there are no value arrays
            CASE MAX.INSTANCES = 1
                NULL

* normal handle but we're using equated property values.  the child handle
* has been equated to the object array so we don't need to copy it
            CASE THIS.DIMENSIONS = 0 AND USE.EQUATED.CHILD.OBJECTS
                NULL

* normal handle
            CASE THIS.DIMENSIONS = 0
                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "    ":SHORT.VARIABLE
                CODE := " = "
                CODE := ARRAY.VARIABLE.NAME:"(":ARRAY.PTR:")"
                GOSUB INSTANCE.CODE

* dimensioned handle, one dimension
            CASE THIS.DIMENSIONS = 1
                MAX.ARRAY = THIS.DIM
                CODE = "    FOR ARRAY.PTR = 1 TO ":MAX.ARRAY
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "        "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR)"
                CODE := " = "
                CODE := ARRAY.VARIABLE.NAME:"(":ARRAY.PTR:",ARRAY.PTR)"
                GOSUB INSTANCE.CODE

                CODE = "    NEXT ARRAY.PTR"
                GOSUB INSTANCE.CODE

* two dimensional array
            CASE THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB INSTANCE.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB INSTANCE.CODE

                LONG.VARIABLE = THIS.VARIABLE:INSTANCE.SUFFIX
                GOSUB CHECK.VARIABLE.NAME
                ARRAY.VARIABLE.NAME = SHORT.VARIABLE

                LONG.VARIABLE = THIS.VARIABLE
                GOSUB CHECK.VARIABLE.NAME

                CODE = "            "
                CODE := SHORT.VARIABLE:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := " = "
                CODE := ARRAY.VARIABLE.NAME
                CODE := "(":ARRAY.PTR:", (ARRAY.PTR1 - 1) * ":MAX.ARRAY2:" + ARRAY.PTR2)"
                GOSUB INSTANCE.CODE

                CODE = "        NEXT ARRAY.PTR2"
                GOSUB INSTANCE.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB INSTANCE.CODE

        END CASE

    NEXT CHILD.LOOP

* load the instance.registry.source.id for the current object instance
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* load instance.registry.source.id for the current instance"
    GOSUB INSTANCE.CODE
    CODE = "    INSTANCE.REGISTRY.SOURCE.ID = "
    CODE := "INSTANCE.REGISTRY.SOURCE.ID.TABLE(":ARRAY.PTR:")"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* set handle for last object loaded"
    GOSUB INSTANCE.CODE
    CODE = "    LAST.OBJECT.HANDLE = OBJECT.HANDLE"
    GOSUB INSTANCE.CODE

    GOSUB INSTANCE.RETURN

    RETURN

ADD.GET.NEW.OBJECT.HANDLE: ***********************************************
* create get.new.object.handle.  this routine looks for an empty handle  *
* and assigns the current object handle there.  it then initializes the  *
* property values and clears the property values in the property table   *
* for the new instance.  if the instance table is full a message is      *
* printed and the object handle is returned zero                         *
**************************************************************************

* to find an available object pointer we're going to loop through the
* active.object.handle array and use the first spot that is null.  set the
* ending value for that loop
    BEGIN CASE

* if this object has a single instance loop to any value.  each calling
* routine will get a different value for the object.handle but, internally,
* everything is treated as if the object.ptr is one
        CASE MAX.INSTANCES = 1
            INSTANCE.INDEX = 100000

* if we're allowed to expand instanced by redimensioning loop to the present
* value for max.instances
        CASE ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES
            INSTANCE.INDEX = "MAX.INSTANCES"

* otherwise loop to the fixed value for max.instances
        CASE 1
            INSTANCE.INDEX = MAX.INSTANCES

    END CASE

    CODE = "GET.NEW.OBJECT.HANDLE: ***************************************************"
    GOSUB INSTANCE.CODE
    CODE = "* set object handle to next available handle and initialize              *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* if the active.object.handle table is unassigned initialize it"
    GOSUB INSTANCE.CODE
    CODE = "    IF UNASSIGNED(ACTIVE.OBJECT.HANDLE) THEN"
    GOSUB INSTANCE.CODE
    CODE = '        ACTIVE.OBJECT.HANDLE = ""'
    GOSUB INSTANCE.CODE
    CODE = "        FOR ACTIVE.LOOP = 1 TO MAX.INSTANCES"
    GOSUB INSTANCE.CODE
    CODE = "            ACTIVE.OBJECT.HANDLE<ACTIVE.LOOP> = @FALSE"
    GOSUB INSTANCE.CODE
    CODE = "        NEXT ACTIVE.LOOP"
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* if this object only has one instance then the object handle will always
* be "1" no matter what.  this lets objects like the Objects object be
* "created" with a "new" without destroying their properties
    BEGIN CASE

        CASE RESIDENT.OBJECT
            GOSUB ADD.RESIDENT.FIND.CODE

        CASE MAX.INSTANCES = 1
            GOSUB ADD.SINGLE.INSTANCE.FIND.CODE

        CASE 1
            GOSUB ADD.NORMAL.FIND.CODE

    END CASE

    CODE = " "
    GOSUB INSTANCE.CODE

* if the local call variable is different than object.handle set it here
    IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
        CODE = "    ":LOCAL.OBJECT.VARIABLE:" = OBJECT.HANDLE"
        GOSUB INSTANCE.CODE
    END

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* set the available instances constant"
    GOSUB INSTANCE.CODE

    IF MAX.INSTANCES = 1 THEN
        CODE = "    USED.INSTANCES = 1"
        GOSUB INSTANCE.CODE
        CODE = "    AVAIL.INSTANCES = 1"
        GOSUB INSTANCE.CODE
    END ELSE
        CODE = "    USED.INSTANCES = SUM(ACTIVE.OBJECT.HANDLE)"
        GOSUB INSTANCE.CODE
        CODE = "    AVAIL.INSTANCES = MAX.INSTANCES - USED.INSTANCES"
        GOSUB INSTANCE.CODE
    END

    GOSUB INSTANCE.RETURN

    RETURN

ADD.RESIDENT.FIND.CODE: **************************************************
* add code to find a new object handle for resident objects              *
**************************************************************************
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* for resident objects the object pointer is always 1"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.PTR = 1"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* flag this instance as active"
    GOSUB INSTANCE.CODE
    CODE = "    ACTIVE.OBJECT.HANDLE<OBJECT.PTR> = @TRUE"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* create the new object handle, setting the handle as a 'resident'"
    GOSUB INSTANCE.CODE
    CODE = "* handle.  preserve any passed parameters as the reset method may need them"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE = OBJECT.PTR"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<2> = ":'"':OBJECT.NAME:'"'
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<5> = NEW.HANDLE<5>"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<6> = @TRUE"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* this object has only one instance.  only initialize the instance if"
    GOSUB INSTANCE.CODE
    CODE = "* it's not already initialized"
    GOSUB INSTANCE.CODE
    CODE = "    IF ":RESIDENT.INITIALIZE.VARIABLE:" <> @TRUE THEN"
    GOSUB INSTANCE.CODE
    CODE = "        ":RESIDENT.INITIALIZE.VARIABLE:" = @TRUE"
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB INIT.CURRENT.OBJECT.INSTANCE"
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

    RETURN

ADD.SINGLE.INSTANCE.FIND.CODE: *******************************************
* add code to find a new object handle for single-instance objects       *
**************************************************************************
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* find the lowest available object pointer"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.PTR = 0"
    GOSUB INSTANCE.CODE
    CODE = '    ACTIVE.OBJECT.HANDLE := ""'
    GOSUB INSTANCE.CODE
    CODE = "    FOR CHECK.OBJECT = 1 TO ":INSTANCE.INDEX:" UNTIL OBJECT.PTR <> 0"
    GOSUB INSTANCE.CODE
    CODE = "        REMOVE THIS.ACTIVE.OBJECT FROM ACTIVE.OBJECT.HANDLE SETTING THROWAWAY"
    GOSUB INSTANCE.CODE
    CODE = '        IF THIS.ACTIVE.OBJECT <> 1 THEN'
    GOSUB INSTANCE.CODE
    CODE = "            OBJECT.PTR = CHECK.OBJECT"
    GOSUB INSTANCE.CODE
    CODE = "        END"
    GOSUB INSTANCE.CODE
    CODE = "    NEXT CHECK.OBJECT"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* create the new object handle, setting the handle as a 'single'"
    GOSUB INSTANCE.CODE
    CODE = "* handle.  preserve any passed parameters as the reset method may need them"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE = OBJECT.PTR"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<2> = ":'"':OBJECT.NAME:'"'
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<5> = NEW.HANDLE<5>"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.HANDLE<7> = @TRUE"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* this object has only one instance.  only initialize the instance if"
    GOSUB INSTANCE.CODE
    CODE = "* this is the first 'instance' that's been created"
    GOSUB INSTANCE.CODE
    CODE = "    IF ACTIVE.OBJECT.HANDLE<OBJECT.PTR> <> @TRUE THEN"
    GOSUB INSTANCE.CODE
    CODE = "        ACTIVE.OBJECT.HANDLE<OBJECT.PTR> = @TRUE"
    GOSUB INSTANCE.CODE
    CODE = "        IF INITIALIZE.OBJECT THEN"
    GOSUB INSTANCE.CODE
    CODE = "            GOSUB INIT.CURRENT.OBJECT.INSTANCE"
    GOSUB INSTANCE.CODE
    CODE = "        END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

    RETURN

ADD.NORMAL.FIND.CODE: ****************************************************
* add code to find a new object handle for normal objects                *
**************************************************************************
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* find the lowest available object pointer"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.PTR = 0"
    GOSUB INSTANCE.CODE
    CODE = '    ACTIVE.OBJECT.HANDLE := ""'
    GOSUB INSTANCE.CODE
    CODE = "    FOR CHECK.OBJECT = 1 TO ":INSTANCE.INDEX:" UNTIL OBJECT.PTR <> 0"
    GOSUB INSTANCE.CODE
    CODE = "        REMOVE THIS.ACTIVE.OBJECT FROM ACTIVE.OBJECT.HANDLE SETTING THROWAWAY"
    GOSUB INSTANCE.CODE
    CODE = '        IF THIS.ACTIVE.OBJECT <> 1 THEN'
    GOSUB INSTANCE.CODE
    CODE = "            OBJECT.PTR = CHECK.OBJECT"
    GOSUB INSTANCE.CODE
    CODE = "        END"
    GOSUB INSTANCE.CODE
    CODE = "    NEXT CHECK.OBJECT"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* if object.ptr is 0 then we're out of instances.  if not we have a"
    GOSUB INSTANCE.CODE
    CODE = "* new instance handle"
    GOSUB INSTANCE.CODE

* if we're allowing expanding instances and object.ptr is zero then
* redimension the multiple instance arrays so we have more instances
    IF ALLOW.EXPANDING.INSTANCES AND MAX.INSTANCES > 1 THEN

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "* if we're out of instances create more instances"
        GOSUB INSTANCE.CODE
        CODE = "    IF OBJECT.PTR = 0 THEN"
        GOSUB INSTANCE.CODE
        CODE = "        OBJECT.PTR = MAX.INSTANCES + 1"
        GOSUB INSTANCE.CODE

        IF USE.EXTERNAL.REDIM THEN
            CODE = "        ":ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:REDIM.KEYWORD:" ":MAX.INSTANCES
            GOSUB INSTANCE.CODE
        END ELSE
            CODE = "        ADD.INSTANCE.COUNT = ":MAX.INSTANCES
            GOSUB INSTANCE.CODE
            CODE = "        GOSUB REDIM.PROPERTY.ARRAYS"
            GOSUB INSTANCE.CODE
        END

        CODE = "    END"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    END

* if absolute max instances is set make sure that this new instance pointer
* is less than the absolute max.  this is to prevent runaway processes from
* creating new instances until everything crashes
    IF ABSOLUTE.MAX.INSTANCES > 0 THEN

        CODE = "* make sure we haven't exceeded absolute max instances"
        GOSUB INSTANCE.CODE
        CODE = "* this is to prevent runaway processes from going forever"
        GOSUB INSTANCE.CODE
        CODE = "    IF OBJECT.PTR >= ":ABSOLUTE.MAX.INSTANCES:" THEN"
        GOSUB INSTANCE.CODE
        CODE = "        OBJECT.PTR = 0"
        GOSUB INSTANCE.CODE
        CODE = "    END"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    END

    CODE = "* if object.ptr is nonzero then we can create a new instance of"
    GOSUB INSTANCE.CODE
    CODE = "* this object.  create a new object pointer for it.  otherwise we've"
    GOSUB INSTANCE.CODE
    CODE = "* run out of available instances so we'll show an error"
    GOSUB INSTANCE.CODE
    CODE = "    IF OBJECT.PTR > 0 THEN"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* flag this instance as active"
    GOSUB INSTANCE.CODE
    CODE = "        ACTIVE.OBJECT.HANDLE<OBJECT.PTR> = @TRUE"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* create the new object handle.  preserve any passed parameters as"
    GOSUB INSTANCE.CODE
    CODE = "* the reset method may need them"
    GOSUB INSTANCE.CODE
    CODE = "        OBJECT.HANDLE = OBJECT.PTR"
    GOSUB INSTANCE.CODE
    CODE = "        OBJECT.HANDLE<2> = ":'"':OBJECT.NAME:'"'
    GOSUB INSTANCE.CODE
    CODE = "        OBJECT.HANDLE<5> = NEW.HANDLE<5>"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB INIT.CURRENT.OBJECT.INSTANCE"
    GOSUB INSTANCE.CODE
    CODE = "        LAST.OBJECT.HANDLE = OBJECT.HANDLE"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    CODE = "    END ELSE"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = '        MESSAGE = "':OUT.OF.INSTANCES.ERROR:'"'
    GOSUB INSTANCE.CODE
    CODE = '        MESSAGE<3> = "Object: ':OBJECT.NAME:'"'
    GOSUB INSTANCE.CODE
    CODE = '        MESSAGE<5> = "':OUT.OF.INSTANCES.RECOVERY:'"'
    GOSUB INSTANCE.CODE
    CODE = '        UD.MESSAGE "Fatal Error", ABORT.PROCESS, MESSAGE'
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    BEGIN CASE

        CASE OUT.OF.INSTANCES.ACTION = "STOP"
            CODE = '        STOP'
            GOSUB INSTANCE.CODE

        CASE 1
            CODE = '        CHAIN "':OUT.OF.INSTANCES.ACTION:'"'
            GOSUB INSTANCE.CODE

    END CASE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

    RETURN

ADD.INIT.ALL.OBJECT.INSTANCES: *******************************************
* create init.all.instances.  this routine clears all instance values    *
* in the properties table                                                *
**************************************************************************
    CODE = "INIT.ALL.OBJECT.INSTANCES: ***********************************************"
    GOSUB INSTANCE.CODE
    CODE = "* initialize variables in all instances                                  *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE

    CODE = "    FOR OBJECT.PTR = 1 TO ":MAX.INSTANCES
    GOSUB INSTANCE.CODE
    CODE = "        OBJECT.HANDLE = OBJECT.PTR:@AM:":'"':OBJECT.NAME:'"'
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB DESTROY.CURRENT.OBJECT.INSTANCE"
    GOSUB INSTANCE.CODE
    CODE = "    NEXT OBJECT.HANDLE"
    GOSUB INSTANCE.CODE

    GOSUB INSTANCE.RETURN

    RETURN

ADD.DESTROY.CURRENT.OBJECT.INSTANCE: *************************************
* create destroy.current.instance.  this routine clears the current      *
* property values, clears the property table for the current instance    *
* and makes the current instance available                               *
**************************************************************************
    CODE = "DESTROY.CURRENT.OBJECT.INSTANCE: *****************************************"
    GOSUB INSTANCE.CODE
    CODE = "* throw away current instance and make the handle avaiable               *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE
    
    CODE = "    IF UNASSIGNED(ACTIVE.OBJECT.HANDLE) THEN"
    GOSUB INSTANCE.CODE
    CODE = '        ACTIVE.OBJECT.HANDLE = ""'
    GOSUB INSTANCE.CODE
    CODE = "        FOR ACTIVE.LOOP = 1 TO MAX.INSTANCES"
    GOSUB INSTANCE.CODE
    CODE = "            ACTIVE.OBJECT.HANDLE<ACTIVE.LOOP> = @FALSE"
    GOSUB INSTANCE.CODE
    CODE = "        NEXT ACTIVE.LOOP"
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = '    IF OBJECT.HANDLE = "" THEN RETURN'
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* clear this instance in the instance tables"
    GOSUB INSTANCE.CODE
    CODE = "    GOSUB INIT.CURRENT.OBJECT.INSTANCE"
    GOSUB INSTANCE.CODE

    IF MAX.INSTANCES > 1 THEN
        CODE = "    GOSUB SAVE.CURRENT.OBJECT.INSTANCE"
        GOSUB INSTANCE.CODE
    END

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* clear this instance in memory"
    GOSUB INSTANCE.CODE
    CODE = "    OBJECT.PTR = OBJECT.HANDLE<1>"
    GOSUB INSTANCE.CODE

    CODE = '    ACTIVE.OBJECT.HANDLE<OBJECT.PTR> = @FALSE'
    GOSUB INSTANCE.CODE

    CODE = '    LAST.OBJECT.HANDLE = ""'
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* set the available instances constant"
    GOSUB INSTANCE.CODE

* set used instances and available instances based on the object type
    BEGIN CASE

        CASE RESIDENT.OBJECT
            CODE = "    USED.INSTANCES = 1"
            GOSUB INSTANCE.CODE
            CODE = "    AVAIL.INSTANCES = 1"
            GOSUB INSTANCE.CODE

        CASE SINGLE.OBJECT
            CODE = "    USED.INSTANCES = 0"
            GOSUB INSTANCE.CODE
            CODE = "    AVAIL.INSTANCES = 1"
            GOSUB INSTANCE.CODE

        CASE 1
            CODE = "    USED.INSTANCES = SUM(ACTIVE.OBJECT.HANDLE)"
            GOSUB INSTANCE.CODE
            CODE = "    AVAIL.INSTANCES = MAX.INSTANCES - USED.INSTANCES"
            GOSUB INSTANCE.CODE

    END CASE

    GOSUB INSTANCE.RETURN

    RETURN

ADD.AUTO.STRING.DEFINITION: **********************************************
* if auto.add.string.object is set add a line to create the string       *
* object if we're compiling the string object, however, don't do this    *
**************************************************************************
    IF AUTO.ADD.STRING.OBJECT AND (NOT(COMPILE.OBJECT) OR OBJECT.NAME <> STRING.OBJECT.NAME) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* auto-create string pseudo-object"
        GOSUB ADD.CODE
        CODE = "    ":STRING.OBJECT.HANDLE:" = NEW(":STRING.OBJECT.NAME:")"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    RETURN

ADD.UTILITY.ROUTINES: ****************************************************
* add utility subroutines that go out with every method and object-      *
* enabled subroutine                                                     *
**************************************************************************
    CODE = " "
    GOSUB INSTANCE.CODE

    GOSUB ADD.EXIT.ERROR.ROUTINE
    GOSUB ADD.EXIT.METHOD.ROUTINE
    GOSUB ADD.CATCH.ERROR.ROUTINE
    GOSUB ADD.ERROR.LOG.ROUTINE

* all methods and subroutines should have a "label.gosub" routine in case
* there is user custom code that calls it.  for some methods, though, we
* don't want to bother with the whole routine.  a place holder subroutine
* will do
    IF METHOD <> NEW.SHORT.KEYWORD THEN
        GOSUB ADD.LABEL.GOSUB.ROUTINE
    END ELSE
        GOSUB ADD.FILLER.LABEL.GOSUB.ROUTINE
    END

    RETURN

ADD.EXIT.ERROR.ROUTINE: **************************************************
* add the routine to the utility subroutines to handle exits when        *
* there's an error                                                       *
**************************************************************************
    CODE = EXIT.ON.ERROR.GOSUB.NAME:": ":STR("*", 72 - LEN(EXIT.ON.ERROR.GOSUB.NAME))
    GOSUB INSTANCE.CODE
    CODE = "* exit method if there has been an error                                 *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE
    CODE = "    IF UNASSIGNED(":ERROR.MESSAGE.VARIABLE:") THEN"
    GOSUB INSTANCE.CODE
    CODE = "        ":ERROR.MESSAGE.VARIABLE:' = ""'
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

    CODE = " "
    GOSUB INSTANCE.CODE

    CODE = "    IF ":ERROR.MESSAGE.VARIABLE:' <> "" THEN'
    GOSUB INSTANCE.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = ""
    GOSUB INSTANCE.CODE
    CODE = "    RETURN"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    RETURN

ADD.EXIT.METHOD.ROUTINE: *************************************************
* add the routine to the utility subroutines to exit the method or       *
* subroutine entirely                                                    *
**************************************************************************
    CODE = EXIT.OUT.GOSUB.NAME:": ":STR("*", 72 - LEN(EXIT.OUT.GOSUB.NAME))
    GOSUB INSTANCE.CODE
    CODE = "* exit the method entirely.  pops return stack until a return is         *"
    GOSUB INSTANCE.CODE
    CODE = "* done to the calling subroutine.  this subroutine allows exit.method    *"
    GOSUB INSTANCE.CODE
    CODE = "* and exit.sub to cleanly exit a subroutine or method even from inside   *"
    GOSUB INSTANCE.CODE
    CODE = "* a subroutine called with a gosub                                       *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* if we're compiling a subroutine and use.first.install is true add a
* line with an $ifndef in it so that this code will be skipped if
* this program is compiled for a initial install into a new environment
    IF COMPILE.SUBROUTINE AND USE.FIRST.INSTALL THEN
        CODE = "    $IFNDEF FIRST.INSTALL"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE
    END

* if the object debugging is turned on update the ud.object.debug file
* with this object's current properties.  we can turn off this option in
* the "object" line with the "no.debug" keyword.  this is necessary for
* some objects, like the object.debug object.  this object does the update
* so if it tried to update ud.object.debug it ends up calling its update
* method that then tries to update ud.object.debug and calls its update
* method.  this loops infinitely until it crashes

* we also don't want to call when we're building the "get.property"
* method.  since the update calls the "get.property" method to get the
* property.array this will create another infinite series of nested calls
* and everything crashes
    IF COMPILE.OBJECT THEN

* "update origin" string.  this is used by the object debugger to pause
* the executing application.  it's in the form "object.name::method,object.ptr"
        UPDATE.ORIGIN = DOWNCASE(OBJECT.NAME):METHOD.DELIMITER:DOWNCASE(METHOD)

        BEGIN CASE

* if this object isn't supposed to updated the object debug file don't
* add any updating code
            CASE NOT(UPDATE.OBJECT.DEBUG)
                NULL

* if this object has no properties we don't need any object debug code
            CASE NOT(PROPERTIES.EXIST)
                NULL

* for the "get.properties" method don't add any code for the object
* debugging
            CASE METHOD = GET.KEYWORD
                NULL

* "destroy" method for resident objects.  leave the object debug
* information there since we aren't actually going to destroy the
* object
            CASE METHOD = DESTROY.KEYWORD AND RESIDENT.OBJECT
                NULL

* "destroy" method for single-instance objects.  remove the object debug
* information if the single instance create count went to zero only
            CASE METHOD = DESTROY.KEYWORD AND SINGLE.OBJECT
                CODE = " "
                GOSUB INSTANCE.CODE

                GOSUB ADD.OBJECT.DEBUGGING.COMMENTS

                CODE = "    IF OBJECT.DEBUGGING.ENABLED AND ":SINGLE.INSTANCE.COUNT.VARIABLE:" = 0 THEN"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "        IF ASSIGNED(DESTROYED.OBJECT.HANDLE) THEN"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "            DESTROYED.OBJECT.PTR = DESTROYED.OBJECT.HANDLE<1>"
                GOSUB INSTANCE.CODE
                CODE = "            METHOD.ERROR.MESSAGE = ":ERROR.MESSAGE.VARIABLE
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = '            IF DESTROYED.OBJECT.PTR <> "" THEN'
                GOSUB INSTANCE.CODE
                CODE = '                UD.DELETE.OBJECT.DEBUG DESTROYED.OBJECT.HANDLE, "':UPDATE.ORIGIN:',":DESTROYED.OBJECT.PTR, METHOD.ERROR.MESSAGE'
                GOSUB INSTANCE.CODE
                CODE = "            END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "        END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE

* for the "destroy" method we'll delete the object debugging information
            CASE METHOD = DESTROY.KEYWORD
                CODE = " "
                GOSUB INSTANCE.CODE

                GOSUB ADD.OBJECT.DEBUGGING.COMMENTS

                CODE = "    IF OBJECT.DEBUGGING.ENABLED THEN"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "        IF ASSIGNED(DESTROYED.OBJECT.HANDLE) THEN"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "            DESTROYED.OBJECT.PTR = DESTROYED.OBJECT.HANDLE<1>"
                GOSUB INSTANCE.CODE
                CODE = "            METHOD.ERROR.MESSAGE = ":ERROR.MESSAGE.VARIABLE
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = '            IF DESTROYED.OBJECT.PTR <> "" THEN'
                GOSUB INSTANCE.CODE
                CODE = '                UD.DELETE.OBJECT.DEBUG DESTROYED.OBJECT.HANDLE, "':UPDATE.ORIGIN:',":DESTROYED.OBJECT.PTR, METHOD.ERROR.MESSAGE'
                GOSUB INSTANCE.CODE
                CODE = "            END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "        END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE

* for single objects there may be different object instance pointers floating
* around but it should really always be 1
            CASE SINGLE.OBJECT
                CODE = " "
                GOSUB INSTANCE.CODE

                GOSUB ADD.OBJECT.DEBUGGING.COMMENTS

                CODE = "    IF OBJECT.DEBUGGING.ENABLED THEN"
                GOSUB INSTANCE.CODE

                GOSUB BUILD.UPDATE.OBJECT.PARAMETERS

                CODE = '        UD.UPDATE.OBJECT.DEBUG OBJECT.HANDLE, "':UPDATE.ORIGIN:',1", '
                CODE := 'METHOD.ERROR.MESSAGE, PARAMETER.NAME.LIST, PARAMETER.BYREF.LIST, '
                CODE := 'PARAMETER.VALUE.LIST'
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE

* for anything else call ud.update.object.debug to update the object debug
* information for this object instance
            CASE 1
                CODE = " "
                GOSUB INSTANCE.CODE

                GOSUB ADD.OBJECT.DEBUGGING.COMMENTS

                CODE = "    IF OBJECT.DEBUGGING.ENABLED THEN"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE

                GOSUB BUILD.UPDATE.OBJECT.PARAMETERS

                CODE = '        UD.UPDATE.OBJECT.DEBUG OBJECT.HANDLE, "':UPDATE.ORIGIN:',":OBJECT.PTR, '
                CODE := 'METHOD.ERROR.MESSAGE, PARAMETER.NAME.LIST, PARAMETER.BYREF.LIST, '
                CODE := 'PARAMETER.VALUE.LIST'
                GOSUB INSTANCE.CODE

                CODE = " "
                GOSUB INSTANCE.CODE
                CODE = "    END"
                GOSUB INSTANCE.CODE
                CODE = " "
                GOSUB INSTANCE.CODE

        END CASE

    END

* at this point we can't know if we want to call ud.object.registry to
* auto-destroy this routine's object.  add the call to ud.object.registry
* anyway, preceeded by a unique.command so we can find it later.  if 
* it turns out that we don't want to use auto-destroy we'll comment out
* this code

* we'll call ud.object.registry using the "normal" (not child object)
* registry source id.  for objects this will destroy objects created in
* the method's normal code but will not destroy child objects.  for object-
* enable subroutines this will destroy any objects created in the subroutine
    AUTO.DESTROY.COMMENT = "* auto-destroy object call"
    AUTO.DESTROY.START = 1
    AUTO.DESTROY.LINES = 3

    CODE = AUTO.DESTROY.COMMENT
    GOSUB INSTANCE.CODE
    CODE = "    IF ASSIGNED(":REGISTRY.SOURCE.VARIABLE:") THEN"
    GOSUB INSTANCE.CODE

    RESTORE.OBJECT.INSTANCE = @FALSE

* note:  the object handle passed to ud.object.registry isn't used with the
* "destroy.mine" command.  the below code creates a separate object handle just
* for the ud.object.registry call with the object and method in the object name
* (if possible).  this is for debugging, in case we need to see the object and 
* method that is calling ud.object.registry to do the "destroy.mine" cleanup
    BEGIN CASE

* if it's a subroutine making the call build the "object handle" with the
* subroutine name
        CASE COMPILE.SUBROUTINE

            CODE = '        OBJECT.DESTROY.MINE.HANDLE = @AM:"':SUBROUTINE.NAME:'"'
            GOSUB INSTANCE.CODE

            AUTO.DESTROY.LINES += 1

* if we're compiling an object pass the current object's handle so we know
* which object is requesting the "destroy mine".  
        CASE COMPILE.OBJECT AND PROPERTIES.EXIST

            CODE = '        OBJECT.DESTROY.MINE.HANDLE = OBJECT.HANDLE<1>:@AM:CURRENT.OBJECT.NAME'
            CODE := ':"':METHOD.DELIMITER:'":CURRENT.METHOD.NAME'
            GOSUB INSTANCE.CODE
    
            AUTO.DESTROY.LINES += 1

            RESTORE.OBJECT.INSTANCE = @TRUE

* if we're compiling an object with no properties the current.object.name
* and current.method name won't be defined so we'll use object.name and
* this.method
        CASE COMPILE.OBJECT

            CODE = '        OBJECT.DESTROY.MINE.HANDLE = OBJECT.HANDLE<1>:@AM:"':OBJECT.NAME
            CODE := METHOD.DELIMITER:THIS.METHOD:'"'
            GOSUB INSTANCE.CODE

            AUTO.DESTROY.LINES += 1


    END CASE

* call ud.object.registry to clean out the registry of any objects created in this
* method or subroutine.

* if an object the same type as the object being compiled was added in the
* method "destroy mine" will mess up our object's pointers.  we'll gosub
* check.object.instance to fix our object's pointers just in case
    CODE = '        UD.OBJECT.REGISTRY "", "DESTROY.MINE", OBJECT.DESTROY.MINE.HANDLE, "", ':REGISTRY.SOURCE.VARIABLE
    GOSUB INSTANCE.CODE

    IF RESTORE.OBJECT.INSTANCE THEN
        CODE = "        GOSUB CHECK.OBJECT.INSTANCE"
        GOSUB INSTANCE.CODE
        AUTO.DESTROY.LINES += 1
    END

    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* if we're compiling a subroutine and use.first.install is true end
* the $ifndef
    IF COMPILE.SUBROUTINE AND USE.FIRST.INSTALL THEN
        CODE = "    $ENDIF"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE
    END

    CODE = EXIT.OUT.GOSUB.NAME:".POP.RETURN.STACK:"
    GOSUB INSTANCE.CODE
    CODE = "    RETURN TO ":EXIT.OUT.GOSUB.NAME:".POP.RETURN.STACK"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* if error throws are not enabled these are all the routines we need.
* if error throws are enabled but there are no labels in the entire program
* then we can't have any error throwing and we're done
    IF NOT(ENABLE.ERROR.THROWS) OR LABEL.COUNT = 0 THEN
        RETURN
    END

    RETURN

ADD.OBJECT.DEBUGGING.COMMENTS: *******************************************
* add comments before the object debugging code in the "exit to calling  *
* program" subroutine                                                    *
**************************************************************************
    CODE = "* if object debugging is turned on build a table of the object's"
    GOSUB INSTANCE.CODE
    CODE = "* properties and call ud.update.object.debug.  this updates the"
    GOSUB INSTANCE.CODE
    CODE = "* UD.OBJECT.DEBUG file so that the current property values may be"
    GOSUB INSTANCE.CODE
    CODE = "* from the object debugger"
    GOSUB INSTANCE.CODE

    RETURN

ADD.CATCH.ERROR.ROUTINE: *************************************************
* add "catch error" gosub routine.  if this routine is called and an     *
* error is set it will display the error, clean up the program and exit  *
**************************************************************************
    IF ADD.CATCH.ERROR.ROUTINE AND CATCH.ERROR.GOSUB.NAME <> "" THEN

        CODE = CATCH.ERROR.GOSUB.NAME:": ":STR("*", 72 - LEN(CATCH.ERROR.GOSUB.NAME))
        GOSUB INSTANCE.CODE
        CODE = "* if there is an error display the error, clean up and exit              *"
        GOSUB INSTANCE.CODE
        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

        CODE = "* if there's no error return"
        GOSUB INSTANCE.CODE
        CODE = "    IF UNASSIGNED(":ERROR.MESSAGE.VARIABLE:") THEN"
        GOSUB INSTANCE.CODE
        CODE = "        ":ERROR.MESSAGE.VARIABLE:' = ""'
        GOSUB INSTANCE.CODE
        CODE = "    END"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE
        
        CODE = '    IF ':ERROR.MESSAGE.VARIABLE:' = "" THEN'
        GOSUB INSTANCE.CODE
        CODE = "        RETURN"
        GOSUB INSTANCE.CODE
        CODE = "    END"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "    UD.SHOW.OBJECT.ERROR ":ERROR.MESSAGE.VARIABLE:", 1, ":SHOW.OBJECT.ERROR.DETAILS
        GOSUB INSTANCE.CODE
        CODE = "    PRINT"
        GOSUB INSTANCE.CODE

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "    GOSUB ":EXIT.OUT.GOSUB.NAME
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

        CODE = " "
        GOSUB INSTANCE.CODE
        CODE = "    RETURN"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    END

    RETURN

ADD.ERROR.LOG.ROUTINE: ***************************************************
* add the "object.error.logging" subroutine.  if update.object.error.log *
* is turned off add a dummy routine in case any shortcuts or macros      *
* try to call the error logging routine                                  *
**************************************************************************
    IF ERROR.LOG.ROUTINE <> "" AND ERROR.LOG.GOSUB.NAME <> "" THEN

        CODE = ERROR.LOG.GOSUB.NAME:": ":STR("*", 72 - LEN(ERROR.LOG.GOSUB.NAME))
        GOSUB INSTANCE.CODE
        CODE = "* object errror logging                                                  *"
        GOSUB INSTANCE.CODE
        CODE = "**************************************************************************"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

        IF UPDATE.OBJECT.ERROR.LOG THEN

            CODE = "* if there's no error return"
            GOSUB INSTANCE.CODE
            CODE = "    IF UNASSIGNED(":ERROR.MESSAGE.VARIABLE:") THEN"
            GOSUB INSTANCE.CODE
            CODE = "        ":ERROR.MESSAGE.VARIABLE:' = ""'
            GOSUB INSTANCE.CODE
            CODE = "    END"
            GOSUB INSTANCE.CODE
            CODE = " "
            GOSUB INSTANCE.CODE

            CODE = '    IF ':ERROR.MESSAGE.VARIABLE:' = "" THEN'
            GOSUB INSTANCE.CODE
            CODE = "        RETURN"
            GOSUB INSTANCE.CODE
            CODE = "    END"
            GOSUB INSTANCE.CODE
            CODE = " "
            GOSUB INSTANCE.CODE

            CODE = "* update the ud.object.error file if there's an error"
            GOSUB INSTANCE.CODE
            CODE = "    LOG.ERROR.MESSAGE = ":ERROR.MESSAGE.VARIABLE
            GOSUB INSTANCE.CODE

* for objects we'll pass the object handle and current method name.  for
* object-enabled subroutines we'll pass "sub" as the object name and the
* program name as the method
            IF COMPILE.OBJECT THEN

                CODE = "    ":ERROR.LOG.ROUTINE:" OBJECT.HANDLE, CURRENT.METHOD.NAME, LOG.ERROR.MESSAGE"
                GOSUB INSTANCE.CODE

            END ELSE

                CODE = '    LOG.ERROR.OBJECT.HANDLE = 1:@AM:"':SUBROUTINE.CALL.KEYWORD:'"'
                GOSUB INSTANCE.CODE

                CODE = "    ":ERROR.LOG.ROUTINE:" LOG.ERROR.OBJECT.HANDLE, CURRENT.SUBROUTINE.NAME, LOG.ERROR.MESSAGE"
                GOSUB INSTANCE.CODE

            END

            CODE = " "
            GOSUB INSTANCE.CODE

* if we're compiling an object add code to check the current object
* instance and reload it if the object error logging subroutine changed
* it
            IF COMPILE.OBJECT THEN

                IF (CHECK.OBJECT.INSTANCE OR SET.OBJECT.INSTANCE) AND PROPERTIES.EXIST THEN

                    CODE = "* ":ERROR.LOG.ROUTINE:" may have changed the current object instance.  restore"
                    GOSUB INSTANCE.CODE
                    CODE = "* the current instance if this happened"
                    GOSUB INSTANCE.CODE

                    IF SET.OBJECT.INSTANCE THEN
                        CODE = "    GOSUB SET.OBJECT.INSTANCE"
                    END ELSE
                        CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
                    END

                    GOSUB INSTANCE.CODE

                    CODE = " "
                    GOSUB INSTANCE.CODE

                END

            END

        END

        CODE = "    RETURN"
        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    END

    RETURN

ADD.FILLER.LABEL.GOSUB.ROUTINE: ******************************************
* add a label gosub routine that doesn't do anything.  this is a filler  *
* in case there is some user custom code that calls the                  *
* label.gosub.routine                                                    *
**************************************************************************
    CODE = LABEL.GOSUB.NAME:": ":STR("*", 72 - LEN(LABEL.GOSUB.NAME))
    GOSUB INSTANCE.CODE
    CODE = "* place-holding empty subroutine to take care of any error throw calls   *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    RETURN"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    RETURN

ADD.LABEL.GOSUB.ROUTINE: *************************************************
* add label gosub routine                                                *
**************************************************************************
    GOSUB PURGE.NO.PROPERTY.LABELS

    CODE = LABEL.GOSUB.NAME:": ":STR("*", 72 - LEN(LABEL.GOSUB.NAME))
    GOSUB INSTANCE.CODE
    CODE = "* gosub to a label based on the error throw variable                     *"
    GOSUB INSTANCE.CODE
    CODE = "**************************************************************************"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* make sure both error.message and the error throw variable have values.
* if it turns out error.message is never returned in a call (which would be
* odd . . . why is your program in OBP?) it will never be assigned so this
* will keep the compiler happy
    CODE = "* initialize error throw variables"
    GOSUB INSTANCE.CODE
    CODE = "    IF UNASSIGNED(":ERROR.MESSAGE.VARIABLE:") THEN"
    GOSUB INSTANCE.CODE
    CODE = "        ":ERROR.MESSAGE.VARIABLE:' = ""'
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    CODE = "    IF UNASSIGNED(":ERROR.THROW.VARIABLE:") THEN"
    GOSUB INSTANCE.CODE
    CODE = "        ":ERROR.THROW.VARIABLE:' = ""'
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* if the error throw variable is null we aren't throwing errors so return
    CODE = "* if the error throw isn't active return"
    GOSUB INSTANCE.CODE
    CODE = "    IF ":ERROR.THROW.VARIABLE:' = "" THEN'
    GOSUB INSTANCE.CODE
    CODE = "        RETURN"
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* build a list of program labels so we can index our error throw label
* against the list.  if there are a lot of labels this can get awfully
* long so we'll break it up as it gets too long
    CODE = "* if the program label list isn't defined build it"
    GOSUB INSTANCE.CODE
    CODE = "    IF UNASSIGNED(PROGRAM.LABEL.LIST) THEN"
    GOSUB INSTANCE.CODE

* build a dynamic array with all the program labels in it.  this can get
* huge so we'll set a limit to how long each line can be that's building
* the array.  we'll build the array with comma delimiters so that we can
* do it with a string assignment.  then we'll change the commas to
* attribute marks to get our dynamic array
    MAX.LINE.WIDTH = 130

    CODE = '        PROGRAM.LABEL.LIST = ':'"'

    FOR LABEL.LOOP = 1 TO LABEL.COUNT

        CODE := LABEL.LIST<LABEL.LOOP>
        IF LABEL.LOOP <> LABEL.COUNT THEN
            CODE := ","
        END

        IF LEN(CODE) > MAX.LINE.WIDTH OR LABEL.LOOP = LABEL.COUNT THEN

            CODE := '"'
            GOSUB INSTANCE.CODE

            CODE = '        PROGRAM.LABEL.LIST := "'

        END

    NEXT LABEL.LOOP

    CODE = '        PROGRAM.LABEL.LIST = CHANGE(PROGRAM.LABEL.LIST,",",@AM)'
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE

* find the throw label in the dynamic array of program labels.  if it's not
* found we can't go there so show a runtime error and return
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "* find the pointer to the error throw routine in the label index"
    GOSUB INSTANCE.CODE
    CODE = "    LOCATE ":ERROR.THROW.VARIABLE:" IN PROGRAM.LABEL.LIST SETTING ERROR.THROW.PTR ELSE"
    GOSUB INSTANCE.CODE
    CODE = '        CRT "ERROR: Throw to Invalid label ':"'":'":':ERROR.THROW.VARIABLE:':"':"'":'"'
    GOSUB INSTANCE.CODE
    CODE = '        CRT "Error Message: ":':ERROR.MESSAGE.VARIABLE
    GOSUB INSTANCE.CODE
    CODE = "        RETURN"
    GOSUB INSTANCE.CODE
    CODE = "    END"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* now that we have the index to our program label we can do an indexed
* gosub.  these line can also get very long so we'll probably have to break
* them up, too
    CODE = "* do a gosub to the associated label"
    GOSUB INSTANCE.CODE

    ON.GOSUB.CODE = "ON ERROR.THROW.PTR GOSUB "
    START.PTR = 1
    LABELS.THIS.GOSUB = @FALSE

    FOR LABEL.LOOP = 1 TO LABEL.COUNT

        LABELS.THIS.GOSUB += 1

        IF LABELS.THIS.GOSUB > 1 THEN
            ON.GOSUB.CODE := ","
        END

        ON.GOSUB.CODE := LABEL.LIST<LABEL.LOOP>
        IF LEN(ON.GOSUB.CODE) > MAX.LINE.WIDTH OR LABEL.LOOP = LABEL.COUNT THEN

            END.PTR = START.PTR + LABELS.THIS.GOSUB - 1

            CODE = "    IF ERROR.THROW.PTR >= ":START.PTR:" AND ERROR.THROW.PTR"
            CODE := " <= ":END.PTR:" THEN"
            GOSUB INSTANCE.CODE
            CODE = "        ":ON.GOSUB.CODE
            GOSUB INSTANCE.CODE
            CODE = "    END"
            GOSUB INSTANCE.CODE

            ON.GOSUB.CODE = "ON ERROR.THROW.PTR - ":END.PTR:" GOSUB "

            LABELS.THIS.GOSUB = @FALSE
            START.PTR = END.PTR + 1

        END

    NEXT LABEL.LOOP

    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    RETURN"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    RETURN

PURGE.NO.PROPERTY.LABELS: ************************************************
* if this object has no properties purge the label list of some names    *
**************************************************************************
    IF NOT(COMPILE.OBJECT) THEN
        RETURN
    END
    IF PROPERTIES.EXIST THEN
        RETURN
    END

    LOCATE "INIT.CURRENT.OBJECT.INSTANCE" IN LABEL.LIST SETTING LABEL.PTR THEN
        DEL LABEL.LIST<LABEL.PTR>
        LABEL.COUNT -= 1
    END

    LOCATE "CHECK.OBJECT.INSTANCE" IN LABEL.LIST SETTING LABEL.PTR THEN
        DEL LABEL.LIST<LABEL.PTR>
        LABEL.COUNT -= 1
    END

    LOCATE "GET.NEW.OBJECT.HANDLE" IN LABEL.LIST SETTING LABEL.PTR THEN
        DEL LABEL.LIST<LABEL.PTR>
        LABEL.COUNT -= 1
    END

    LOCATE "DESTROY.CURRENT.OBJECT.INSTANCE" IN LABEL.LIST SETTING LABEL.PTR THEN
        DEL LABEL.LIST<LABEL.PTR>
        LABEL.COUNT -= 1
    END

    RETURN

BUILD.UPDATE.OBJECT.PARAMETERS: ******************************************
* add code to build the ud.update.object.debug parameters                *
**************************************************************************

* add code to pass the error message back under a different variable name
    CODE = "        METHOD.ERROR.MESSAGE = ":ERROR.MESSAGE.VARIABLE
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

* table of parameter names
    CODE = '        PARAMETER.NAME.LIST = ""'

    FOR ADD.LOOP = 1 TO PARAMETER.COUNT

        THIS.PARM.NAME = DOWNCASE(PARAMETER.LIST<ADD.LOOP>)

        IF ADD.LOOP > 1 THEN
            CODE := ":@AM"
        END

        CODE := ':"':THIS.PARM.NAME:'"'

    NEXT ADD.LOOP

    GOSUB INSTANCE.CODE

* build a table of byref flags
    CODE = '        PARAMETER.BYREF.LIST = ""'

    FOR ADD.LOOP = 1 TO PARAMETER.COUNT

        THIS.BYREF = PARAMETER.BYREF.LIST<ADD.LOOP>
        THIS.SPECIAL = PARAMETER.SPECIAL.LIST<ADD.LOOP>

        IF THIS.BYREF = "" THEN
            THIS.BYREF = "0"
        END
        IF THIS.SPECIAL = "" THEN
            THIS.SPECIAL = "0"
        END

        IF ADD.LOOP > 1 THEN
            CODE := ":@AM"
        END

        CODE := ':"':THIS.BYREF:'"'

    NEXT ADD.LOOP

    GOSUB INSTANCE.CODE

* build a table of lowered return parameter values.  each variable will
* be tested to make sure it's not a file handle as file handles can't be
* saved in dynamic arrays
    CODE = '        PARAMETER.VALUE.LIST = ""'
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    FOR ADD.LOOP = 1 TO PARAMETER.COUNT

        THIS.PARM.NAME = UPCASE(PARAMETER.LIST<ADD.LOOP>)

        CODE = '        BEGIN CASE'
        GOSUB INSTANCE.CODE
        CODE = '            CASE UNASSIGNED(':THIS.PARM.NAME:')'
        GOSUB INSTANCE.CODE
        CODE = '                THIS.PARAMETER = "<unassigned>"'
        GOSUB INSTANCE.CODE
        CODE = '            CASE FILEINFO(':THIS.PARM.NAME:', 0) = 1'
        GOSUB INSTANCE.CODE
        CODE = '                THIS.PARAMETER = "<FileHandle>"'
        GOSUB INSTANCE.CODE
        CODE = '            CASE ':THIS.PARM.NAME:' = @NULL'
        GOSUB INSTANCE.CODE
        CODE = '                THIS.PARAMETER = "<@null>"'
        GOSUB INSTANCE.CODE
        CODE = '            CASE 1'
        GOSUB INSTANCE.CODE
        CODE = '                THIS.PARAMETER = LOWER(':THIS.PARM.NAME:')'
        GOSUB INSTANCE.CODE
        CODE = '            END CASE'
        GOSUB INSTANCE.CODE

        CODE = '        PARAMETER.VALUE.LIST := '

        IF ADD.LOOP > 1 THEN
            CODE := "@AM:"
        END

        CODE := 'THIS.PARAMETER'

        GOSUB INSTANCE.CODE
        CODE = " "
        GOSUB INSTANCE.CODE

    NEXT ADD.LOOP

    RETURN

INSTANCE.RETURN: *********************************************************
* add a "return" to an instance-handling subroutine                      *
**************************************************************************
    CODE = " "
    GOSUB INSTANCE.CODE
    CODE = "    RETURN"
    GOSUB INSTANCE.CODE
    CODE = " "
    GOSUB INSTANCE.CODE

    RETURN

INSTANCE.CODE: ***********************************************************
* add code to instance.code                                              *
**************************************************************************
    INSTANCE.LINE.COUNT += 1

    IF INSTANCE.LINE.COUNT = 1 THEN
        INSTANCE.CODE = CODE
    END ELSE
        INSTANCE.CODE := @AM:CODE
    END

    RETURN

ADD.ALL.PROPERTY.LIST.ROUTINE: *******************************************
* add a subroutine to build an array of all properties in the object.    *
* this is added to the get.property routines                             *
**************************************************************************

* add a subroutine to restore the original object.handle.  we'll use this
* after fetching property lists so that the object.handle is left in its
* original condition
    
* single instance objects don't need this since they only have one object
    CODE = " "
    GOSUB ADD.CODE

    CODE = "RESTORE.ORIGINAL.OBJECT.HANDLE: ******************************************"
    GOSUB ADD.CODE
    CODE = "* restore the original object.handle                                     *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    BEGIN CASE

        CASE SINGLE.OBJECT
            CODE = " "
            GOSUB ADD.CODE
            CODE = "* this is a single instance object.  no restoring is needed"
            GOSUB ADD.CODE

        CASE RESIDENT.OBJECT
            CODE = " "
            GOSUB ADD.CODE
            CODE = "* this is a resident object.  no restoring is needed"
            GOSUB ADD.CODE

        CASE 1
            CODE = " "
            GOSUB ADD.CODE
            CODE = "* if the object pointer hasn't changed we're good"
            GOSUB ADD.CODE
            CODE = "    IF ORIGINAL.OBJECT.HANDLE<1> = OBJECT.HANDLE<1> THEN"
            GOSUB ADD.CODE
            CODE = "        RETURN"
            GOSUB ADD.CODE
            CODE = "    END"
            GOSUB ADD.CODE
            CODE = " "
            GOSUB ADD.CODE

            CODE = "* the object pointer changed.  restore the original instance"
            GOSUB ADD.CODE
            CODE = "    OBJECT.HANDLE = ORIGINAL.OBJECT.HANDLE"
            GOSUB ADD.CODE
            CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
            GOSUB ADD.CODE

    END CASE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    CODE = "BUILD.ALL.PROPERTY.LISTS: ************************************************"
    GOSUB ADD.CODE
    CODE = "* build arrays with all property values                                  *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

* build arrays for each attribute we'll return in property.value.  for child objects
* we'll only add it if the child object variable is the same as the handle.  this
* is only true for local child objects and that's all we want to display

*     object type
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* object type"
    GOSUB ADD.CODE 

    BEGIN CASE
        CASE RESIDENT.OBJECT
            CODE = '    ':DEBUG.PREFIX:'OBJECT.TYPE.LIST = "RESIDENT"'
        CASE SINGLE.OBJECT
            CODE = '    ':DEBUG.PREFIX:'OBJECT.TYPE.LIST = "SINGLE"'
        CASE 1
            CODE = '    ':DEBUG.PREFIX:'OBJECT.TYPE.LIST = ""'
    END CASE
    GOSUB ADD.CODE

*     property name list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* property names"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.NAME.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        GOSUB ADD.NAME
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        GOSUB ADD.NAME
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.NAME = THIS.VARIABLE
        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.NAME
        END
    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     static (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* static variable (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"STATIC.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.STATIC
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.STATIC
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.STATIC
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     child (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* child object handle (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"CHILD.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.CHILD
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.CHILD
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
            GOSUB ADD.IS.CHILD
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     constant (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* constant variable (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"CONSTANT.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.CONSTANT
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.CONSTANT
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.CONSTANT
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     local (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* local variable (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"LOCAL.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.LOCAL
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.LOCAL
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.LOCAL
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     file (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* file variable (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"FILE.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.FILE
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.FILE
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.FILE
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     list (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* list variable (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"LIST.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.IS.LIST
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.IS.LIST
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.LIST
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     keyword list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* creating keyword"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"KEYWORD.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.KEYWORD
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<CONSTANT.LOOP>
        GOSUB ADD.KEYWORD
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.KEYWORD
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     dimensioned (t/f) list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* dimensioned list (t/f)"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"DIMENSIONED.FLAG.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        GOSUB ADD.IS.DIM
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.DIM = ""
        GOSUB ADD.IS.DIM
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.IS.DIM
        END

    NEXT CHILD.LOOP
    
    GOSUB ADD.CODE

*     dimensions list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* dimensions list"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"DIMENSIONS.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = CHANGE(PROP.DIM.LIST<PROP.LOOP>, @VM, ",")
        GOSUB ADD.DIMENSIONS
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.DIM = ""
        GOSUB ADD.DIMENSIONS
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.DIM = CHANGE(CHILD.DIM.LIST<CHILD.LOOP>, @VM, ",")
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.DIMENSIONS
        END

    NEXT CHILD.LOOP

    GOSUB ADD.CODE

*     value list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* value list"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"VALUE.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.NAME.OBJECT = ""
        THIS.DIM = CHANGE(PROP.DIM.LIST<PROP.LOOP>, @VM, ",")
        DECODE.KEYWORD = PROP.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.PROPERTY.VALUE
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.NAME.OBJECT = ""
        THIS.DIM = ""
        DECODE.KEYWORD = CONSTANT.KEYWORD.LIST<PROP.LOOP>
        GOSUB ADD.PROPERTY.VALUE
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.NAME.OBJECT = CHILD.NAME.LIST<CHILD.LOOP>
        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.PROPERTY.VALUE
        END

    NEXT CHILD.LOOP

    GOSUB ADD.CODE

*     comment list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* comment list"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"COMMENT.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.COMMENT = PROP.COMMENT.LIST<PROP.LOOP>
        GOSUB ADD.COMMENT
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.COMMENT = CONSTANT.COMMENT.LIST<CONSTANT.LOOP>
        GOSUB ADD.COMMENT
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.COMMENT = CHILD.COMMENT.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.COMMENT
        END

    NEXT CHILD.LOOP

    GOSUB ADD.CODE

*     line number:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* line numbers"
    GOSUB ADD.CODE

    PROPERTY.LINE.XREF = ""
    DISPLAY.LINE.XREF = ""
    PROPERTY.XREF.COUNT = 0

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"LINE.NUMBER.LIST = ''"

    FOR PROP.LOOP = 1 TO PROP.COUNT
        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.LINE = PROP.LINE.LIST<PROP.LOOP>
        GOSUB ADD.LINE.NUMBER
    NEXT PROP.LOOP

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT
        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.LINE = CONSTANT.LINE.LIST<CONSTANT.LOOP>
        GOSUB ADD.LINE.NUMBER
    NEXT CONSTANT.LOOP

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.LINE = CHILD.LINE.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF THIS.HANDLE = THIS.VARIABLE THEN
            GOSUB ADD.LINE.NUMBER
        END

    NEXT CHILD.LOOP

    GOSUB ADD.CODE

*     line number xref list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* line number xref"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"LINE.XREF.LIST = ''"

    FOR XREF.LOOP = 1 TO PROPERTY.XREF.COUNT

        GOSUB ADD.AN.AM

        CODE := ':"':PROPERTY.LINE.XREF<XREF.LOOP>:'"'

    NEXT XREF.LOOP

    GOSUB ADD.CODE

*     display pointer xref list:
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* display pointer xref"
    GOSUB ADD.CODE

    AM.ADDED = @FALSE
    CODE = "    ":DEBUG.PREFIX:"DISPLAY.XREF.LIST = ''"

    DISPLAY.LINE.XREF = CHANGE(DISPLAY.LINE.XREF, @VM, @AM)
    DISPLAY.LINE.COUNT = DCOUNT(DISPLAY.LINE.XREF, @AM)

    FOR XREF.LOOP = 1 TO DISPLAY.LINE.COUNT

        GOSUB ADD.AN.AM

        CODE := ':"':DISPLAY.LINE.XREF<XREF.LOOP>:'"'

    NEXT XREF.LOOP

    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

* code to put everything together into property.array
    CODE = " "
    GOSUB ADD.CODE

    CODE = "BUILD.PROPERTY.ARRAY: ****************************************************"
    GOSUB ADD.CODE
    CODE = "* build property array with all property arrays                          *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY = ''"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* build property array with all values and flags"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<1> = LOWER(":DEBUG.PREFIX:"PROPERTY.NAME.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<2> = LOWER(":DEBUG.PREFIX:"STATIC.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<3> = LOWER(":DEBUG.PREFIX:"CHILD.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<4> = LOWER(":DEBUG.PREFIX:"CONSTANT.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<5> = LOWER(":DEBUG.PREFIX:"LOCAL.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<6> = LOWER(":DEBUG.PREFIX:"FILE.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<7> = LOWER(":DEBUG.PREFIX:"LIST.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<8> = LOWER(":DEBUG.PREFIX:"KEYWORD.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<9> = LOWER(":DEBUG.PREFIX:"DIMENSIONED.FLAG.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<10> = LOWER(":DEBUG.PREFIX:"DIMENSIONS.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<11> = LOWER(":DEBUG.PREFIX:"VALUE.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<12> = LOWER(":DEBUG.PREFIX:"COMMENT.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<13> = LOWER(":DEBUG.PREFIX:"OBJECT.TYPE.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<14> = LOWER(":DEBUG.PREFIX:"LINE.NUMBER.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<15> = LOWER(":DEBUG.PREFIX:"LINE.XREF.LIST)"
    GOSUB ADD.CODE
    CODE = "    ":DEBUG.PREFIX:"PROPERTY.ARRAY<16> = LOWER(":DEBUG.PREFIX:"DISPLAY.XREF.LIST)"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    RETURN"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.AN.AM: ***************************************************************
* add an attribute mark to code if am.added is false.  set am.added      *
**************************************************************************
    IF AM.ADDED THEN
        CODE := ":@AM"
        AM.PTR += 1
    END ELSE
        AM.PTR = 1
    END

    AM.ADDED = @TRUE

    RETURN

ADD.NAME: ****************************************************************
* add this.name to code                                                  *
**************************************************************************
    GOSUB ADD.AN.AM

    IF UPCASE.CODE THEN
        CODE := ':"':DOWNCASE(THIS.NAME):'"'
    END ELSE
        CODE := ':"':THIS.NAME:'"'
    END

    RETURN

ADD.IS.STATIC: ***********************************************************
* add the static flag for decode.keyword to code                         *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.STATIC THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.IS.CHILD: ************************************************************
* add the child flag for decode.keyword to code                          *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.CHILD THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.IS.CONSTANT: *********************************************************
* add the constant flag for decode.keyword to code                       *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.CONSTANT THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.IS.LOCAL: ************************************************************
* add the local flag for decode.keyword to code                          *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.LOCAL THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.IS.FILE: *************************************************************
* add the file flag for decode.keyword to code                           *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.FILE THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.IS.LIST: *************************************************************
* add the list flag for decode.keyword to code                           *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF IS.LIST THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.KEYWORD: *************************************************************
* add decode.keyword to code                                             *
**************************************************************************
    GOSUB ADD.AN.AM

    IF UPCASE.CODE THEN
        CODE := ':"':DOWNCASE(DECODE.KEYWORD):'"'
    END ELSE
        CODE := ':"':DECODE.KEYWORD:'"'
    END

    RETURN

ADD.IS.DIM: **************************************************************
* add a flag to code for if the property is dimensioned                  *
**************************************************************************
    GOSUB ADD.AN.AM
 
    IF THIS.DIM <> "" THEN
        CODE := ":@TRUE"
    END ELSE
        CODE := ":@FALSE"
    END

    RETURN

ADD.DIMENSIONS: **********************************************************
* add dimensioned size to code                                           *
**************************************************************************
    GOSUB ADD.AN.AM
 
    IF THIS.DIM <> "" THEN
        CODE := ':"':CHANGE(THIS.DIM, @VM, ","):'"'
    END

    RETURN

ADD.COMMENT: *************************************************************
* add comments to code                                                   *
**************************************************************************
    GOSUB ADD.AN.AM

    IF THIS.COMMENT <> "" THEN

        COMMENT.VM.COUNT = DCOUNT(THIS.COMMENT, @VM)
        FOR COMMENT.LOOP = 1 TO COMMENT.VM.COUNT

            THIS.COMMENT.LINE = THIS.COMMENT<1, COMMENT.LOOP>
            THIS.COMMENT.LINE = CHANGE(THIS.COMMENT.LINE, '"', "")

            IF COMMENT.LOOP > 1 THEN
                CODE := ":@VM"
            END

            IF THIS.COMMENT.LINE <> "" THEN
                CODE := ':"':THIS.COMMENT.LINE:'"'
            END

        NEXT COMMENT.LOOP

    END

    RETURN

ADD.PROPERTY.VALUE: ******************************************************
* add a property value to code for this.name given this.dim and          *
* decode.keyword                                                         *
**************************************************************************
    GOSUB DECODE.PROPERTY
    GOSUB ADD.AN.AM

    IF THIS.DIM <> "" THEN
        IS.DIM = @TRUE
    END ELSE
        IS.DIM = @FALSE
    END

    THIS.NAME.OBJECT = UPCASE(THIS.NAME.OBJECT [1, 1]):DOWNCASE(THIS.NAME.OBJECT [2, TO.THE.END])

    DOT.COUNT = COUNT(THIS.NAME.OBJECT, ".")

    FOR DOT.LOOP = 1 TO DOT.COUNT
        DOT.PTR = INDEX(THIS.NAME.OBJECT, ".", DOT.LOOP)
        THIS.NAME.OBJECT [DOT.PTR + 1, 1] = UPCASE(THIS.NAME.OBJECT [DOT.PTR + 1, 1])
    NEXT DOT.LOOP

    BEGIN CASE

* if the variable is a file handle, list handle, or child object there
* is no displayable value to add
        CASE IS.FILE AND IS.LOCAL AND IS.DIM
            CODE := ':"<DimLocalFileHandle>"'
        CASE IS.FILE AND IS.LOCAL
            CODE := ':"<LocalFileHandle>"'
        CASE IS.FILE AND IS.DIM
            CODE := ':"<DimFileHandle>"'
        CASE IS.FILE
            CODE := ':"<FileHandle>"'

        CASE IS.LIST AND IS.LOCAL AND IS.DIM
            CODE := ':"<DimLocalListHandle>"'
        CASE IS.LIST AND IS.LOCAL
            CODE := ':"<LocalListHandle>"'
        CASE IS.LIST AND IS.DIM
            CODE := ':"<DimListHandle>"'
        CASE IS.LIST
            CODE := ':"<ListHandle>"'

        CASE IS.CHILD AND IS.LOCAL AND IS.DIM
            CODE := ':"<':THIS.NAME.OBJECT:',":OBJECT.PTR:">"'
        CASE IS.CHILD AND IS.LOCAL
            CODE := ':"<':THIS.NAME.OBJECT:',":OBJECT.PTR:">"'
        CASE IS.CHILD AND IS.DIM
            CODE := ':"<':THIS.NAME.OBJECT:',":OBJECT.PTR:">"'
        CASE IS.CHILD
            CODE := ':"<':THIS.NAME.OBJECT:',":OBJECT.PTR:">"'

* nothing for dimensioned variables at the moment
        CASE IS.DIM
            CODE := ':"<DimVariable>"'

* "normal" value that can be displayed
        CASE 1
            CODE := ":LOWER(":THIS.NAME:")"

    END CASE

    RETURN

ADD.LINE.NUMBER: *********************************************************
* add this.line to code.  builds property.line.xref with an entry with   *
* an entry for each unique program line number and display.line.xref     *
* that has vm-delimited entries with the am.ptr for all entries in that  *
* program line number                                                    *
**************************************************************************
    GOSUB ADD.AN.AM

    CODE := ':"':THIS.LINE:'"'

* update the property line xref
    LOCATE THIS.LINE IN PROPERTY.LINE.XREF BY "AR" SETTING PROPERTY.LINE.PTR THEN
        DISPLAY.LINE.XREF<PROPERTY.LINE.PTR, -1> = AM.PTR
    END ELSE
        INS THIS.LINE BEFORE PROPERTY.LINE.XREF<PROPERTY.LINE.PTR>
        INS AM.PTR BEFORE DISPLAY.LINE.XREF<PROPERTY.LINE.PTR>
        PROPERTY.XREF.COUNT += 1
    END

    RETURN

SET.AUTO.DESTROY: ********************************************************
* find the auto.object.destroy call to ud.object.registry in the         *
* converted code.  if we want to auto-destroy then leave it there.  if   *
* not comment it the auto-destroy code                                   *
**************************************************************************

* find the auto-destroy call to ud.object.registry.  if we can't find it
* we'll dump out
    LOCATE AUTO.DESTROY.COMMENT IN PROGRAM.CODE SETTING AUTO.DESTROY.COMMENT.PTR ELSE
        RETURN
    END

    AUTO.DESTROY.PTR = AUTO.DESTROY.COMMENT.PTR + AUTO.DESTROY.START

* were any objects created that weren't child objects of a method?
    NON.CHILD.OBJECT.COUNT = CREATE.COUNT - CHILD.COUNT

* build a count of objects that are not child objects
    NON.CHILD.OBJECT.COUNT = 0

    FOR CHILD.LOOP = 1 TO CREATE.COUNT

        CHECK.HANDLE = CREATE.HANDLE.LIST<CHILD.LOOP>
        GOSUB FIND.CREATED.OBJECT.TYPE

        BEGIN CASE
            CASE HANDLE.CREATE.TYPE = LOCAL.KEYWORD
                NULL
            CASE HANDLE.CREATE.TYPE = "CHILD"
                NULL
            CASE 1
                NON.CHILD.OBJECT.COUNT += 1
        END CASE

    NEXT CHILD.LOOP

* decide if we should leave the auto-destroy code or comment it out
    BEGIN CASE

* if we're building the "new.short" method then we don't want to auto-destroy.
* since the code built for "new.short" creates the object using a "new"
* command auto-destroy would destroy the object we just created
        CASE METHOD = NEW.SHORT.KEYWORD
            DO.AUTO.DESTROY = @FALSE

* not updating the object registry under any circumstances
        CASE NOT(UPDATE.OBJECT.REGISTRY)
            DO.AUTO.DESTROY = @FALSE

* if we don't auto-destroy unless there are non-child objects and we don't
* have any non-child objects don't auto-destroy
        CASE NON.CHILD.OBJECT.COUNT = 0 AND NOT(AUTO.DESTROY.IF.NO.OBJECTS)
            DO.AUTO.DESTROY = @FALSE

* if this is a subroutine and we're auto destroying objects then leave the
* auto-destroy
        CASE COMPILE.SUBROUTINE AND NOT(AUTO.DESTROY.OBJECTS)
            DO.AUTO.DESTROY = @FALSE

* if this is a method and we're auto destroying method objects leave the
* auto-destroy
        CASE COMPILE.OBJECT AND NOT(AUTO.DESTROY.METHOD.OBJECTS)
            DO.AUTO.DESTROY = @FALSE

* anything else, do the auto destroy
        CASE 1
            DO.AUTO.DESTROY = @TRUE

    END CASE

* if we aren't auto-destroying comment out the auto-destroy code
    IF NOT(DO.AUTO.DESTROY) THEN

        FOR COMMENT.LOOP = 1 TO AUTO.DESTROY.LINES
            AUTO.PTR = AUTO.DESTROY.PTR + (COMMENT.LOOP - 1)
            PROGRAM.CODE<AUTO.PTR> = "* ":PROGRAM.CODE<AUTO.PTR>
        NEXT COMMENT.LOOP

    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / user methods          **
**************************************************************************
**************************************************************************

CREATE.METHOD: ***********************************************************
* create a user-designed method.  if the method is a wrapper method      *
* also create the wrapper subroutine                                     *
**************************************************************************
    GOSUB START.CREATE.TIME

    METHOD.CREATED = @FALSE
    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

* default methods are created elsewhere
    LOCATE METHOD IN DEFAULT.METHOD.LIST SETTING DEFAULT.PTR THEN
        RETURN
    END

* the "common" method isn't really a method
    IF METHOD = COMMON.ROUTINE.METHOD THEN
        RETURN
    END

* pull method parameters from table
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        RETURN
    END

    METHOD.CREATED = @TRUE

    GOSUB INIT.LINE.XREF

* unload method and parameter information
    METHOD.TYPE = METHOD.TYPE.LIST<METHOD.PTR>

    PARAMETER.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)
    PARAMETER.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
    PARAMETER.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)

    PARAMETER.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
    PARAMETER.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

    PARAMETER.COUNT = DCOUNT(PARAMETER.LIST,@AM)

* build the eclipse subroutine name for this method
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

* unload wrapper information, if there is any
    WRAPPER.SUBROUTINE.NAME = METHOD.WRAPPER.LIST<METHOD.PTR>
    WRAPPER.PARAMETER.LIST = RAISE(METHOD.WRAPPER.PARM.LIST<METHOD.PTR>)
    WRAPPER.DEFAULT.LIST = RAISE(METHOD.WRAPPER.DEFAULT.LIST<METHOD.PTR>)

    WRAPPER.OPTIONAL.LIST = RAISE(METHOD.WRAPPER.OPTIONAL.LIST<METHOD.PTR>)
    WRAPPER.BYREF.LIST = RAISE(METHOD.WRAPPER.BYREF.LIST<METHOD.PTR>)
    WRAPPER.SPECIAL.LIST = RAISE(METHOD.WRAPPER.SPECIAL.LIST<METHOD.PTR>)

    WRAPPER.PARAMETER.COUNT = METHOD.WRAPPER.PARM.COUNT.LIST<METHOD.PTR>

    IF DETAILS THEN
        PRINT
        PRINT "Creating ":METHOD:" Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

* if the parameter count exceeds the maximum parameter count generate
* an error.  when the method call is converted to a subroutine call there
* will be two additional parameters, one for the object handle and one
* for error.message so we'll subtract 2 from max.call.parameters before
* comparing
    IF MAX.CALL.PARAMETERS <> 0 AND PARAMETER.COUNT > MAX.CALL.PARAMETERS - 2 THEN

        OBJECT.WARNING.DESC = "Method ":THIS.METHOD.NAME:" has ":PARAMETER.COUNT
        OBJECT.WARNING.DESC := " parameters, ":"only ":MAX.CALL.PARAMETERS - 2:" allowed"
        OBJECT.WARNING.LINE = ""

        GOSUB PRINT.OBJECT.WARNING

    END

* find code in the object test
    START.LINE = METHOD.START.LINE<METHOD.PTR>
    END.LINE = METHOD.END.LINE<METHOD.PTR>

    GOSUB INITIALIZE.PROGRAM.CODE

    WRAPPER.CREATED = @FALSE
    WRAPPER.CODE = ""
    WRAPPER.CODE.LINES = ""

* start building subroutine.
    GOSUB BEFORE.ADD

* build the "subroutine" statement.  the first parameter is our object handle.
* the second is the error message return variable.  then the parameters
* from the method definition. 
    CODE = "    SUBROUTINE ":SUBROUTINE.NAME:" (OBJECT.HANDLE, "
    CODE := ERROR.MESSAGE.VARIABLE

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT
        CODE := BETWEEN.PARAMETERS:PARAMETER.LIST<PARAMETER.LOOP>
    NEXT PARAMETER.LOOP

    CODE := ")"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

* add compilation stamp and checksum comment
    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB ADD.BLANK

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB BEFORE.ADD

* if there are no properties we don't need a lot of this
    IF PROPERTIES.EXIST THEN

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
        IF PROPERTY.COMMON.CODE.AT.END THEN
            CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
            GOSUB ADD.CODE
        END ELSE
            GOSUB ADD.COMMON.CODE
        END
    END

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

* define object variables
    GOSUB ADD.SPECIAL.CODE

    IF PROPERTIES.EXIST THEN

*       GOSUB ADD.SPECIAL.CODE

* get properties for the correct instance
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* set properties for the correct object instance"
        GOSUB ADD.CODE
        CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
        GOSUB ADD.CODE

    END

* if any passed parameters have default values set up add code to
* set them
    DEFAULTS.EXIST = @FALSE

    IF TRIM(PARAMETER.DEFAULT.LIST,@AM) <> "" THEN
        DEFAULTS.EXIST = @TRUE
    END

    IF DEFAULTS.EXIST THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* set defaults for passed parameters"
        GOSUB ADD.CODE
    END

* for each parameter that has a default value (from the "optional"
* keyword in the call statement) generate code to set the parameter
* to the default value if it's passed in empty.

* since passing "" for a parameters sets it to the default value we
* need a way to set the parameter to "".  we'll use the @NULL variable
* for this.  if it's passed in null (ie, using the @NULL variable)
* then we'll set the parameter to ""

* this isn't done for inherited methods
    IF NOT(THIS.INHERITED) THEN

        FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT 

            THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>
            THIS.DEFAULT = PARAMETER.DEFAULT.LIST<PARAMETER.LOOP>
            THIS.SET = PARAMETER.SET.LIST<PARAMETER.LOOP>

            IF THIS.DEFAULT <> "" THEN

                CODE = "    BEGIN CASE"
                GOSUB ADD.CODE

* we can't directly compare to @null so if @null is used here we'll use 
* the ISNULL() function to check for it
                IF OPTIONAL.NULL.VALUE = "@NULL" THEN
                    CODE = "        CASE ISNULL(":THIS.PARAMETER:")"
                    GOSUB ADD.CODE
                END ELSE
                    CODE = "        CASE ":THIS.PARAMETER:" = ":OPTIONAL.NULL.VALUE
                    GOSUB ADD.CODE
                END

                CODE = '            ':THIS.PARAMETER:' = ""'
                GOSUB ADD.CODE

                CODE = '        CASE ':THIS.PARAMETER:' = ""'
                GOSUB ADD.CODE
                CODE = '            ':THIS.PARAMETER
                CODE := " = "
                CODE := THIS.DEFAULT
                GOSUB ADD.CODE

                CODE = "    END CASE"
                GOSUB ADD.CODE

            END

        NEXT PARAMETER.LOOP

    END

* if the "set" flag is set for this default set the variable from the
* default value to the parameter's new value.  we won't need this if
* there are no parameters or if this is an inherited method
    IF PROPERTIES.EXIST AND NOT(THIS.INHERITED) THEN

        FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT

            THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>
            THIS.DEFAULT = PARAMETER.DEFAULT.LIST<PARAMETER.LOOP>
            THIS.SET = PARAMETER.SET.LIST<PARAMETER.LOOP>

            IF THIS.DEFAULT <> "" THEN

                IF THIS.SET THEN
                    CODE = "    ":THIS.DEFAULT:" = ":THIS.PARAMETER
                    GOSUB ADD.CODE
                END

            END

        NEXT PARAMETER.LOOP

    END

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.AUTO.STRING.DEFINITION

    GOSUB ADD.AUTO.DEBUG.CODE

* add user code
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = BEFORE.USER.CODE
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    USER.CODE.START.PTR = PROGRAM.CODE.LINES

    GOSUB AFTER.ADD

    IF THIS.INHERITED THEN

        ADD.RETURN = @TRUE
        INDENT = ""
        GOSUB ADD.INHERITED.METHOD.CODE

    END ELSE

        ADD.RETURN = @TRUE
        ADD.FINAL.ERROR.CHECK = @TRUE
        INDENT = ""
        GOSUB ADD.METHOD.CODE

    END

    USER.CODE.END.PTR = PROGRAM.CODE.LINES

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = AFTER.USER.CODE
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.COMMON.METHOD.CODE
    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTIES.EXIST THEN

        IF PROPERTY.COMMON.CODE.AT.END THEN
            GOSUB ADD.COMMON.CODE.SUBROUTINE
        END

* rebuild the instance code specifically for this method
        GOSUB BUILD.INSTANCE.CODE

    END

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

* if this method has a method wrapper name create the wrapper
    IF ENABLE.WRAPPER.SUBROUTINES AND WRAPPER.SUBROUTINE.NAME <> "" THEN

        WRAPPER.TYPE = METHOD.TYPE
        GOSUB CREATE.WRAPPER
        GOSUB ADD.WRAPPER.OBP.STAMP

        IF NOT(LIST.OBJECTS.ONLY) THEN
            GOSUB SAVE.OBP.WRAPPER
        END

    END

    GOSUB END.CREATE.TIME

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / reset method          **
**************************************************************************
**************************************************************************

CREATE.RESET.METHOD: *****************************************************
* create a method to reset an object instance                            *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = RESET.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating RESET Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME:" (OBJECT.HANDLE"
    CODE := ")"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* initialize an instance for ":OBJECT.NAME "L#30":"            *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

* if we have no properties we won't need a lot of this
    IF PROPERTIES.EXIST THEN

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
        IF PROPERTY.COMMON.CODE.AT.END THEN

            GOSUB BEFORE.ADD

            CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
            GOSUB ADD.CODE

            GOSUB AFTER.ADD

        END ELSE
            GOSUB ADD.COMMON.CODE
        END

    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    IF PROPERTIES.EXIST THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
        GOSUB ADD.CODE

    END

    GOSUB AFTER.ADD

    GOSUB ADD.AUTO.STRING.DEFINITION

    GOSUB ADD.AUTO.DEBUG.CODE

* define object variables
    GOSUB ADD.SPECIAL.CODE

    IF PROPERTIES.EXIST THEN

*       GOSUB ADD.SPECIAL.CODE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* method code"
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* reset all properties in the current object instance"
        GOSUB ADD.CODE
        CODE = "    GOSUB INIT.CURRENT.OBJECT.INSTANCE"
        GOSUB ADD.CODE

* save the reset parameters.  if there's only one instance for this object
* there's no need to save them and this would result in a subroutine not
* found error
        IF MAX.INSTANCES > 1 THEN
            CODE = "    GOSUB SAVE.CURRENT.OBJECT.INSTANCE"
            GOSUB ADD.CODE
        END

    END

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* reset this instance so that all property value are the same"
    GOSUB ADD.CODE
    CODE = "* as when the instance was newly created."
    GOSUB ADD.CODE
    CODE = '    INITIALIZE.VALUE = RAISE(OBJECT.HANDLE<5>)'
    GOSUB ADD.CODE
    CODE = "    NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "    INITIALIZE.OBJECT = @TRUE"
    GOSUB ADD.CODE

* was the "new" method written with any passed parameters?  if there are load
* them into initialize.assign to be processed the same as an "assign"
* statement
    INITIALIZE.VALUE.COUNT = 0
    INITIALIZE.ASSIGN.COUNT = 0
    INITIALIZE.METHOD.COUNT = 0

    INITIALIZE.ASSIGN = ""
    INITIALIZE.ASSIGN.DEFAULT = ""

    PASS.ASSIGN.OPTION.USED = @FALSE
    ASSIGN.OPTION.USED = @FALSE

    LOCATE NEW.KEYWORD IN METHOD.LIST SETTING NEW.METHOD.PTR THEN

        NEW.PARAMETER.LIST = RAISE (METHOD.PARM.LIST<NEW.METHOD.PTR>)
        NEW.PARAMETER.DEFAULT.LIST = RAISE (METHOD.PARM.DEFAULT.LIST<NEW.METHOD.PTR>)
        NEW.PARAMETER.COUNT = DCOUNT (NEW.PARAMETER.LIST, @AM)

        IF NEW.PARAMETER.COUNT > 0 THEN
            INITIALIZE.ASSIGN = NEW.PARAMETER.LIST
            INITIALIZE.ASSIGN.DEFAULT = NEW.PARAMETER.DEFAULT.LIST
            INITIALIZE.VALUE.COUNT = NEW.PARAMETER.COUNT
            PASS.ASSIGN.OPTION.USED = @TRUE
        END

    END

    GOSUB AFTER.ADD

    GOSUB ADD.RESET.CHILD.CODE

* add in the user code from the "new" method
    METHOD = NEW.KEYWORD
    ADD.RETURN = @FALSE
    INDENT = ""

    GOSUB ADD.ASSIGNED.CODE.BEFORE
    GOSUB ADD.NEW.METHOD.USER.CODE
    GOSUB ADD.ASSIGNED.CODE.AFTER

    METHOD = RESET.KEYWORD

* there could be user code for the "reset" method so we'll check for it
* as well
    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @FALSE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTIES.EXIST THEN

        IF PROPERTY.COMMON.CODE.AT.END THEN
            GOSUB ADD.COMMON.CODE.SUBROUTINE
        END

    END

    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if there
* are no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

    GOSUB ADD.FINAL.END

    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN

ADD.RESET.CHILD.CODE: ****************************************************
* add code to the reset method to reset child objects                    *
**************************************************************************
    IF CHILD.COUNT = 0 THEN
        RETURN
    END

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* reset child objects that are not resident object instances"
    GOSUB ADD.CODE
    CODE = "* or single-instance objects and have been instantiated"
    GOSUB ADD.CODE

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.CHILD.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.CHILD.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        IF INDEX (THIS.CHILD.HANDLE, METHOD.DELIMITER, 1) > 0 THEN
            THIS.CHILD.LOCAL = @FALSE
        END ELSE
            THIS.CHILD.LOCAL = @TRUE
        END

        THIS.CHILD.DIM = CHANGE (CHILD.DIM.LIST<CHILD.LOOP>, ",", @AM)
        THIS.DIM.COUNT = DCOUNT (THIS.CHILD.DIM, @AM)

        BEGIN CASE

* only reset child objects, not the child object of the child objects.  if the
* child handle has a method delimiter in it the child is a child of another child
* of this object and will be reset when the parent child is reset
            CASE NOT (THIS.CHILD.LOCAL)
                NULL

* child object that isn't dimensioned
            CASE THIS.DIM.COUNT = 0

                CODE = "    IF ":THIS.CHILD.VARIABLE:' <> "" AND '
                CODE := THIS.CHILD.VARIABLE:' <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "        IF NOT(":THIS.CHILD.VARIABLE:"<6>) AND "
                CODE := "NOT(":THIS.CHILD.VARIABLE:"<7>) THEN"
                GOSUB ADD.CODE
                CODE = "            ":THIS.CHILD.HANDLE:METHOD.DELIMITER:RESET.KEYWORD
                GOSUB ADD.CODE
                CODE = "        END"
                GOSUB ADD.CODE
                CODE = "    END"
                GOSUB ADD.CODE

* child object that's dimensioned with one dimension
            CASE THIS.DIM.COUNT = 1

                CODE = "    FOR ARRAY.PTR = 1 TO ":THIS.CHILD.DIM
                GOSUB ADD.CODE

                CODE = "        IF ":THIS.CHILD.VARIABLE:'(ARRAY.PTR) <> "" AND '
                CODE := THIS.CHILD.VARIABLE:'(ARRAY.PTR) <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "            IF NOT(":THIS.CHILD.VARIABLE:"(ARRAY.PTR)<6>) AND "
                CODE := "NOT(":THIS.CHILD.VARIABLE:"(ARRAY.PTR)<7>) THEN"
                GOSUB ADD.CODE
                CODE = "                ":THIS.CHILD.HANDLE:"(ARRAY.PTR)"
                CODE := METHOD.DELIMITER:RESET.KEYWORD
                GOSUB ADD.CODE
                CODE = "            END"
                GOSUB ADD.CODE
                CODE = "        END"
                GOSUB ADD.CODE

                CODE = "    NEXT ARRAY.PTR"
                GOSUB ADD.CODE

* child object dimensioned with two dimensions
            CASE THIS.DIM.COUNT = 2

                CODE = "    FOR ARRAY.PTR1 = 1 TO ":THIS.CHILD.DIM<1>
                GOSUB ADD.CODE
                CODE = "        FOR ARRAY.PTR2 = 2 TO ":THIS.CHILD.DIM<2>
                GOSUB ADD.CODE    

                CODE = "            IF ":THIS.CHILD.VARIABLE:'(ARRAY.PTR1, ARRAY.PTR2) <> "" AND '
                CODE := THIS.CHILD.VARIABLE:'(ARRAY.PTR1, ARRAY.PTR2) <> "0" THEN'
                GOSUB ADD.CODE
                CODE = "                IF NOT(":THIS.CHILD.VARIABLE:"(ARRAY.PTR1, ARRAY.PTRT2)<6>) AND "
                CODE := "NOT(":THIS.CHILD.VARIABLE:"(ARRAY.PTR1, ARRAY.PTRT2)<7>) THEN"
                GOSUB ADD.CODE
                CODE = "                    ":THIS.CHILD.HANDLE:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := METHOD.DELIMITER:RESET.KEYWORD
                GOSUB ADD.CODE
                CODE = "                END"
                GOSUB ADD.CODE
                CODE = "            END"
                GOSUB ADD.CODE

                CODE = "        NEXT ARRAY.PTR2"
                GOSUB ADD.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB ADD.CODE

        END CASE

    NEXT CHILD.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / new method            **
**************************************************************************
**************************************************************************

CREATE.NEW.METHOD: *******************************************************
* create initialize method for an object instance                        *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = NEW.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating NEW Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

* create the "subroutine" statement for the "new" subroutine.  if the object
* has any child objects we'll pass the handles for them back as well as
* the handle to this one

* new.handle may have up to 3 attributes:
*    new.handle<1>      instance number if this is an "old" object call or
*                       null if this is a "new" object call.  for "new" object
*                       calls the new instance number will be returned here
*    new.handle<2>      object name for "old" object calls or null for "new"
*                       calls.
*    new.handle<3>      may have a child object validation string

* the "new" routine returns the registry source id for objects created in
* the "new" routine.  child objects in the "new" routine are created using
* the "child object" source id--child.registry.source.variable.  objects
* created in code (not as child objects) are created using the "normal object"
* source.id--registry.source.variable.

* child objects are created first.  if there are both child objects and
* "normal" objects, then, the child object source id will be less than the
* "normal" object source.id.  

* if the destroy method does an auto-destroy of all objects (calling the
* registry with "destroy.mine") using the child object source id the "normal"
* object will also be destroyed if any are (somehow) left over.  there
* shouldn't be as the "normal" objects will be auto-destroyed (using the
* "normal" source.id) but who knows what evil lurks in the hearts of
* programs

* if an auto-destroy is done using the "normal" source id only the "normal"
* objects will be destroyed.  the child objects will be left alone

* was the new method written with any passed parameters?  if there are load
* them into initialize.assign to be processed the same as an "assign"
* statement
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR THEN

        PARAMETER.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)

        PARAMETER.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
        PARAMETER.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)

        PARAMETER.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
        PARAMETER.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

        PARAMETER.COUNT = DCOUNT(PARAMETER.LIST,@AM)

        IF PARAMETER.COUNT > 0 THEN
            INITIALIZE.ASSIGN = PARAMETER.LIST
            INITIALIZE.ASSIGN.DEFAULT = PARAMETER.DEFAULT.LIST
            PASS.ASSIGN.OPTION.USED = @TRUE
        END

    END ELSE

        PARAMETER.LIST = ""

        PARAMETER.DEFAULT.LIST = ""
        PARAMETER.SET.LIST = ""

        PARAMETER.BYREF.LIST = ""
        PARAMETER.SPECIAL.LIST = ""

        PARAMETER.COUNT = 0

    END

* create the "subroutine" statement at the top of the new converted code
    INCLUDE.CHILD.VARIABLES = @TRUE
    INCLUDE.PARAMETERS = @FALSE
    GOSUB ADD.NEW.SUBROUTINE.CODE

    GOSUB ADD.BLANK

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* initialize a new instance for ":OBJECT.NAME "L#30":"           *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB BEFORE.ADD

* if we don't have any properties then this object is just a function-
* holding object.  skip the following code so that the routine stays fast
* enough to be useful
    IF PROPERTIES.EXIST THEN

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
        IF PROPERTY.COMMON.CODE.AT.END THEN

            GOSUB BEFORE.ADD

            CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
            GOSUB ADD.CODE

            GOSUB AFTER.ADD

        END ELSE

            GOSUB ADD.COMMON.CODE

        END

    END

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

* define object variables
    GOSUB ADD.SPECIAL.CODE

    IF PROPERTIES.EXIST THEN

*       GOSUB ADD.SPECIAL.CODE

* if set to do so in compile.setup create the "child.object.definition.string".
* if we aren't checking child object mismatches we'll put the variable out there
* anyway (with a null value) in case anyone's code is looking for it

        IF CHECK.MISMATCHED.CHILD.OBJECTS THEN

            CODE = " "
            GOSUB ADD.CODE
            CODE = "* check mismatched child objects"
            GOSUB ADD.CODE
            CODE = "    GOSUB ":CHECK.MISMATCHED.CHILD.NAME
            GOSUB ADD.CODE

        END ELSE

            CODE = " "
            GOSUB ADD.CODE
            CODE = "* mismatched child validation is not on.  clean up mismatch"
            GOSUB ADD.CODE
            CODE = "* checking variables in case the calling program passed in"
            GOSUB ADD.CODE
            CODE = "* child mismatch parameters"
            GOSUB ADD.CODE
            CODE = "    IF UNASSIGNED(NEW.HANDLE) THEN NEW.HANDLE = ":'""'
            GOSUB ADD.CODE
            CODE = "    CHILD.OBJECT.DEFINITION.STRING = ":'""'
            GOSUB ADD.CODE

        END

        GOSUB AFTER.ADD

        IF CONSTANT.COUNT > 0 THEN

            GOSUB BEFORE.ADD

            CODE = " "
            GOSUB ADD.CODE
            CODE = "* set constants"
            GOSUB ADD.CODE

            FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT

                THIS.CONSTANT = CONSTANT.NAME.LIST<CONSTANT.LOOP>
                THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>

* if we're allowing expanding instances then don't set the "max.instances"
* constant.  it's already been set
                IF NOT(ALLOW.EXPANDING.INSTANCES OR ALLOW.REDUCING.INSTANCES) OR THIS.CONSTANT <> "MAX.INSTANCES" THEN
                    CODE = "    ":THIS.CONSTANT:" = ":THIS.VALUE
                    GOSUB ADD.CODE
                END

            NEXT CONSTANT.LOOP

        END

        GOSUB ADD.CREATE.METHOD.TABLE.CODE

    END

    GOSUB AFTER.ADD

    GOSUB BEFORE.ADD

* if we're using dimensioned child variables dimension the child array
    IF USE.DIMENSIONED.CHILD.HANDLES THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "    DIM ":CHILD.HANDLE.ARRAY.NAME:" (":CHILD.HANDLE.ARRAY.SIZE:")"
        GOSUB ADD.CODE
        CODE = "    MAT ":CHILD.HANDLE.ARRAY.NAME:" = ":'""'
        GOSUB ADD.CODE
    END

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

* initialize the new handle.  if we have no properties, however, we don't
* need to keep properties so we can skip this
    IF PROPERTIES.EXIST THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* method code"
        GOSUB ADD.CODE
        CODE = '    IF UNASSIGNED(NEW.HANDLE) THEN NEW.HANDLE = ""'
        GOSUB ADD.CODE
        CODE = '    IF UNASSIGNED(LAST.OBJECT.HANDLE) THEN LAST.OBJECT.HANDLE = ""'
        GOSUB ADD.CODE

        END

    GOSUB AFTER.ADD

    GOSUB ADD.DIMENSION.RETURN.VARIABLES.CODE

    GOSUB ADD.CREATE.NEW.INSTANCE.CODE

* if this object has no properties its just a place to stash subroutines,
* like the string pseudo-object.  if it does have properties add the object
* method code.  if it doesn't only add a minimum of code
    IF PROPERTIES.EXIST THEN

        GOSUB ADD.CREATE.CHILD.OBJECTS.CODE
        GOSUB ADD.COPY.CHILD.HANDLES.CODE
        GOSUB ADD.UPDATE.REGISTRY.CODE
        GOSUB ADD.ASSIGNED.CODE.BEFORE
        GOSUB ADD.NEW.METHOD.USER.CODE
        GOSUB ADD.ASSIGNED.CODE.AFTER

* it's possible that the newly created object handle may have changed.
* ie, if the object is matching instances the user code may have called
* another method that matched this instance to another and changed
* object.handle to match the matching instance.  we need to pass the correct
* object handle back to the calling program wrap it up with a return
        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* pass the final value for object.handle back to the calling program"
        GOSUB ADD.CODE
        CODE = "    NEW.HANDLE = OBJECT.HANDLE"
        GOSUB ADD.CODE

* wrap up the "new" method with a return to the calling program
        IF NOT(ENDS.WITH.RETURN) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE
        END

        GOSUB AFTER.ADD

        GOSUB ADD.COMMON.METHOD.CODE

        GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
        IF PROPERTY.COMMON.CODE.AT.END THEN
            GOSUB ADD.COMMON.CODE.SUBROUTINE
        END

* rebuild the instance code specifically for this method
        GOSUB BUILD.INSTANCE.CODE

* if we're checking child objects add the check.child.objects subroutine
        GOSUB ADD.CHECK.MISMATCHED.CHILD.CODE

    END ELSE

* this object has no properties
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* this object has no properties.  it's just a parking place"
        GOSUB ADD.CODE
        CODE = "* for subroutines"
        GOSUB ADD.CODE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* pass the final value for object.handle back to the calling program"
        GOSUB ADD.CODE
        CODE = '    NEW.HANDLE = ""'
        GOSUB ADD.CODE
        CODE = "    NEW.OBJECT = @TRUE"
        GOSUB ADD.CODE
        CODE = "    INITIALIZE.OBJECT = @TRUE"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

        GOSUB ADD.NEW.METHOD.USER.CODE

* wrap up the "new" method with a return to the calling program
        IF NOT(ENDS.WITH.RETURN) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE
        END

        GOSUB AFTER.ADD

        GOSUB ADD.COMMON.METHOD.CODE

    END

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

* if there are no properties add a return to close things up
    IF NOT(PROPERTIES.EXIST) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    RETURN"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* if we're allowing expanding instances add the redim subroutine
    IF PROPERTIES.EXIST THEN
        IF NOT(USE.EXTERNAL.REDIM) AND ALLOW.EXPANDING.INSTANCES AND MAX.INSTANCES > 1 THEN
            GOSUB ADD.REDIM.CODE
        END
    END

    GOSUB ADD.FINAL.END
    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB SET.AUTO.DESTROY

    GOSUB END.CREATE.TIME

    RETURN

CREATE.NEW.SHORT.METHOD: *************************************************
* create "short" initialize method for an object instance.  the          *
* is sort of an "invisible" method that the dotnet classes call to       *
* create a new object instance.  it won't normally be used on the        *
* universe side of things.                                               *
*                                                                        *
* this "new.short" method creates the object but does not return a list  *
* of variables for the current object's child objects.  this the calling *
* routine to create the object without knowing the object's child        *
* objects.                                                               *
*                                                                        *
* this also means that dotnet can't call any child object methods at the *
* current time.  maybe that will change in the future but, for now,      *
* dotnet can only call this object's methods.  use "inherited" methods   *
* to add methods from the chilc object(s) that dotnet needs to call      *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = NEW.SHORT.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating NEW.SHORT Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

* create the "subroutine" statement for the short "new" subroutine

* new.handle may have up to 3 attributes:
*    new.handle<1>      instance number if this is an "old" object call or
*                       null if this is a "new" object call.  for "new" object
*                       calls the new instance number will be returned here
*    new.handle<2>      object name for "old" object calls or null for "new"
*                       calls.
*    new.handle<3>      may have a child object validation string

* the "new" routine returns the registry source id for objects created in
* the "new" routine.  child objects in the "new" routine are created using
* the "child object" source id--child.registry.source.variable.  objects
* created in code (not as child objects) are created using the "normal object"
* source.id--registry.source.variable.

* child objects are created first.  if there are both child objects and
* "normal" objects, then, the child object source id will be less than the
* "normal" object source.id. 

* the short "new" routine still creates the child objects (it calls the
* "normal" "new" routine) but the child object handle variables aren't passed
* back to the calling program 

* if the destroy method does an auto-destroy of all objects (calling the
* registry with "destroy.mine") using the child object source id the "normal"
* object will also be destroyed if any are (somehow) left over.  there
* shouldn't be as the "normal" objects will be auto-destroyed (using the
* "normal" source.id) but who knows what evil lurks in the hearts of
* programs

* if an auto-destroy is done using the "normal" source id only the "normal"
* objects will be destroyed.  the child objects will be left alone

* was the new method written with any passed parameters?  if there are load
* them into initialize.assign to be processed the same as an "assign"
* statement.

* we'll first search for the short new keyword, in case the short new method
* has a different parameter list than the "normal" new method.  if that's not
* found we'll use the same parameter list as in the "normal" new method
    LOCATE METHOD IN METHOD.LIST SETTING METHOD.PTR ELSE
        LOCATE NEW.SHORT.KEYWORD IN METHOD.LIST SETTING METHOD.PTR ELSE
            METHOD.PTR = 0
        END
    END

    IF METHOD.PTR <> 0 THEN

        PARAMETER.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)

        PARAMETER.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
        PARAMETER.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)

        PARAMETER.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
        PARAMETER.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

        PARAMETER.COUNT = DCOUNT(PARAMETER.LIST,@AM)

        IF PARAMETER.COUNT > 0 THEN
            INITIALIZE.ASSIGN = PARAMETER.LIST
            INITIALIZE.ASSIGN.DEFAULT = PARAMETER.DEFAULT.LIST
            PASS.ASSIGN.OPTION.USED = @TRUE
        END

    END ELSE

        PARAMETER.LIST = ""

        PARAMETER.DEFAULT.LIST = ""
        PARAMETER.SET.LIST = ""

        PARAMETER.BYREF.LIST = ""
        PARAMETER.SPECIAL.LIST = ""

        PARAMETER.COUNT = 0

    END

* create the "subroutine" statement at the top of the new converted code
    INCLUDE.CHILD.VARIABLES = @FALSE
    INCLUDE.PARAMETERS = @TRUE
    GOSUB ADD.NEW.SUBROUTINE.CODE

    GOSUB ADD.BLANK

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* initialize a new instance for ":OBJECT.NAME "L#30":"           *"
    GOSUB ADD.CODE
    CODE = "* without returning a list of child object variables.  this keeps the    *"
    GOSUB ADD.CODE
    CODE = "* parameter list a fixed length for calling routines that don't know     *"
    GOSUB ADD.CODE
    CODE = "* the number of child handle parameters to use                           *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB BEFORE.ADD

* if we don't have any properties then this object is just a function-
* holding object.  skip the following code so that the routine stays fast
* enough to be useful
    IF PROPERTIES.EXIST THEN

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
        IF PROPERTY.COMMON.CODE.AT.END THEN

            CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
            GOSUB ADD.CODE

        END ELSE

            GOSUB ADD.COMMON.CODE

        END

    END

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

* define object variables
    GOSUB ADD.SPECIAL.CODE

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

* if this object has no properties its just a place to stash subroutines,
* like the string pseudo-object.  if it does have properties add the object
* method code.  if it doesn't only add a minimum of code
    IF PROPERTIES.EXIST THEN

*       GOSUB ADD.SPECIAL.CODE

* add a "new" statement to create the object
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* call the complete 'new' method to create the object"
        GOSUB ADD.CODE

        CODE = '    OBJECT.HANDLE = ""'
        GOSUB ADD.CODE

        CODE = "    OBJECT.HANDLE = ":NEW.KEYWORD:" (":OBJECT.NAME

* add any parameters for "new"
        FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT
            CODE := ", ":PARAMETER.LIST<PARAMETER.LOOP>
        NEXT PARAMETER.LOOP

        CODE := ")"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* pass the final value for object.handle back to the calling program"
        GOSUB ADD.CODE
        CODE = "    NEW.HANDLE = OBJECT.HANDLE"
        GOSUB ADD.CODE

* wrap up the "new" method with a return to the calling program
        IF NOT(ENDS.WITH.RETURN) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE
        END

        GOSUB AFTER.ADD

*       GOSUB ADD.COMMON.METHOD.CODE

* if common code goes at the end add a subroutine for it
        IF PROPERTY.COMMON.CODE.AT.END THEN
            GOSUB ADD.COMMON.CODE.SUBROUTINE
        END

    END ELSE

* this object has no properties
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* this object has no properties.  it's just a parking place"
        GOSUB ADD.CODE
        CODE = "* for subroutines"
        GOSUB ADD.CODE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* pass the final value for object.handle back to the calling program"
        GOSUB ADD.CODE
        CODE = '    NEW.HANDLE = ""'
        GOSUB ADD.CODE

* wrap up the "new" method with a return to the calling program
        IF NOT(ENDS.WITH.RETURN) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = "    ":EXIT.METHOD.KEYWORD
            GOSUB ADD.CODE
        END

        GOSUB AFTER.ADD

    END

    GOSUB AFTER.ADD

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code and then add the
* instance code to the subroutine.  if we have no properties null out the
* instance code and start over so we only add the utility routines
    IF PROPERTIES.EXIST THEN
        GOSUB BUILD.INSTANCE.CODE 
    END ELSE
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

* if there are no properties add a return to close things up
    IF NOT(PROPERTIES.EXIST) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    RETURN"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

    GOSUB ADD.FINAL.END
    GOSUB ADD.INLINE.CODE
    GOSUB ADD.FUNCTION.CODE

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB SET.AUTO.DESTROY

    GOSUB END.CREATE.TIME

    RETURN

ADD.NEW.SUBROUTINE.CODE: *************************************************
* add the "subroutine" line for the "new" method                         *
**************************************************************************
    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME:" (NEW.HANDLE":BETWEEN.PARAMETERS:"ERROR.MESSAGE":BETWEEN.PARAMETERS
    CODE := CHILD.REGISTRY.SOURCE.VARIABLE

    IF INCLUDE.CHILD.VARIABLES THEN
        GOSUB ADD.NEW.SUBROUTINE.CODE.CHILDREN
    END

    IF INCLUDE.PARAMETERS THEN
        GOSUB ADD.NEW.SUBROUTINE.PARAMETERS
    END

    CODE := ")"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.NEW.SUBROUTINE.CODE.CHILDREN: ****************************************
* add the child object variables to add.code.  this adds the child       *
* object variable list to the subroutine statement to return child       *
* object handles to the calling program                                  *
**************************************************************************

* we'll build a "child object" string as we create the subroutine statement.
* this "child object" string can be compared to a similar string build in
* the calling program to make sure all child objects are inclued and in
* the correct places.  if a child object was added here in this object and
* the calling program was not recompiled then we could get a mismatch.  this
* would result in the calling program getting the wrong object handles in the
* wrong places.  if CheckMismatchedChildObjects is turned on (which is a good
* idea) we can use the string to test for this condition
    CHILD.OBJECT.STRING = ""

* we'll also keep a list of the child file variables we put in the subroutine
* statement.
    RETURNED.CHILD.LIST = ""
    RETURNED.CHILD.DIM.LIST = ""
    RETURNED.CHILD.COUNT = 0

    ALL.CHILD.LIST = ""
    ALL.CHILD.DIM.LIST = ""
    ALL.CHILD.COUNT = 0

* add child handles to the subroutine statement.  the child handles will
* be common so we can't return them by name.  we'll return them as
* "NEW.":child.handle so we don't have a problem

* if we're padding out the "NEW" calls we can run out of room for
* child handles as more and more child objects are added to this one.
* if we have more child handles than will fit in max.child.objects
* print a warning and truncate at max.child.objects
    CHILD.ADD.COUNT = CHILD.COUNT

* keep a count of non-local child objects
    NON.LOCAL.CHILD.COUNT = 0

* if we're using dimensioned child handles this points to the last array
* value used
    CHILD.ARRAY.PTR = 0

    FOR CHILD.LOOP = 1 TO CHILD.ADD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        THIS.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>
        THIS.DEFINED.LOCAL = CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>

* do we want to pass this child handle object to the program creating
* the object?
        ADD.CHILD = @TRUE

        BEGIN CASE

* the "new" subroutine should only pass items down to a set child depth
            CASE THIS.CHILD.DEPTH > BUILD.CHILD.DEPTH
                ADD.CHILD = @FALSE

* if this child object is a "local" child we won't pass the child
* object handle to the calling program
            CASE THIS.LOCAL
                ADD.CHILD = @FALSE

        END CASE

* update a list of all child objects in the "new" method
        ALL.CHILD.COUNT += 1
        ALL.CHILD.LIST<ALL.CHILD.COUNT> = CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")
        ALL.CHILD.DIM.LIST<RETURNED.CHILD.COUNT> = THIS.DIMENSIONS

        IF ADD.CHILD THEN

* update the list of child variables in the subroutine statement
            RETURNED.CHILD.COUNT += 1
            RETURNED.CHILD.LIST<RETURNED.CHILD.COUNT> = CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")
            RETURNED.CHILD.DIM.LIST<RETURNED.CHILD.COUNT> = THIS.DIMENSIONS

* add "NEW.variable" to the subroutine call.  variable will be common so
* we don't want to take the chance of an aliasing problem by returning a
* common value through the subroutine statement.  we'll pass them back
* with the variable name "NEW.variable"
            BEGIN CASE

* non-dimensioned child handle, using dimensioned child handles
                CASE THIS.DIMENSIONS = 0 AND USE.DIMENSIONED.CHILD.HANDLES
                    CHILD.ARRAY.PTR += 1

* non-dimensioned child handle
                CASE THIS.DIMENSIONS = 0
                    CODE := ", NEW.":THIS.VARIABLE

* dimensioned child handle
                CASE 1
                    CODE := ", MAT NEW.":THIS.VARIABLE

            END CASE

* add to the child object string
            IF CHILD.OBJECT.STRING = "" THEN
                CHILD.OBJECT.STRING = THIS.HANDLE:";":THIS.NAME
            END ELSE
                CHILD.OBJECT.STRING := ",":THIS.HANDLE:";":THIS.NAME
            END

            NON.LOCAL.CHILD.COUNT += 1

        END

    NEXT CHILD.LOOP

    RETURNED.CHILD.LIST.BUILT = @TRUE
    ALL.CHILD.LIST.BUILT = @TRUE

* if we're using dimensioned child handles, after adding any dimensioned
* child handles to the call if we have any child handles in the passed array
* add the child handle array to the call
    IF USE.DIMENSIONED.CHILD.HANDLES THEN
        CODE := ", MAT ":CHILD.HANDLE.ARRAY.NAME
    END

* if we have more non-local child objects than our max.child.objects
* setting some child object handles won't be passed to the calling
* program.  print a warning that we've exceeded max.child.objects
    IF NON.LOCAL.CHILD.COUNT > MAX.CHILD.OBJECTS AND MAX.CHILD.OBJECTS > 0 THEN

        PRINT
        PRINT "Warning:  Objects has ":NON.LOCAL.CHILD.COUNT:" public objects and"
        PRINT "MaxChildObjects is set to ":MAX.CHILD.OBJECTS
        PRINT

        CHILD.ADD.COUNT = MAX.CHILD.OBJECTS

    END

* pad parameter list based on max.child.objects.  this keeps all of the
* subroutine calls to the "NEW" method subroutines at the same number of
* parameters, even if a new child object is added to this object
    IF MAX.CHILD.OBJECTS <> "" AND MAX.CHILD.OBJECTS <> 0 THEN
        FOR PAD.LOOP = NON.LOCAL.CHILD.COUNT + 1 TO MAX.CHILD.OBJECTS
            CODE := ', PAD.CHILD':PAD.LOOP
        NEXT PAD.LOOP
    END

    RETURN

ADD.NEW.SUBROUTINE.PARAMETERS: *******************************************
* add parameters from the "new" method to a "new" subroutine call        *
**************************************************************************

* pull the parameter list for the "new" method even if we're building the
* "new.short" subroutine.  "new.short" will pass the "new" parameters when it
* calls the "new" subroutine
    LOCATE NEW.KEYWORD IN METHOD.LIST SETTING METHOD.PTR THEN

        PARAMETER.LIST = RAISE(METHOD.PARM.LIST<METHOD.PTR>)

        PARAMETER.DEFAULT.LIST = RAISE(METHOD.PARM.DEFAULT.LIST<METHOD.PTR>)
        PARAMETER.SET.LIST = RAISE(METHOD.PARM.SET.LIST<METHOD.PTR>)

        PARAMETER.BYREF.LIST = RAISE(METHOD.PARM.BYREF.LIST<METHOD.PTR>)
        PARAMETER.SPECIAL.LIST = RAISE(METHOD.PARM.SPECIAL.LIST<METHOD.PTR>)

        PARAMETER.COUNT = DCOUNT(PARAMETER.LIST,@AM)

        IF PARAMETER.COUNT > 0 THEN
            INITIALIZE.ASSIGN = PARAMETER.LIST
            INITIALIZE.ASSIGN.DEFAULT = PARAMETER.DEFAULT.LIST
            PASS.ASSIGN.OPTION.USED = @TRUE
        END

    END ELSE

        PARAMETER.LIST = ""

        PARAMETER.DEFAULT.LIST = ""
        PARAMETER.SET.LIST = ""

        PARAMETER.BYREF.LIST = ""
        PARAMETER.SPECIAL.LIST = ""

        PARAMETER.COUNT = 0

    END

    IF PARAMETER.COUNT = 0 THEN
        RETURN
    END

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    FOR PARAMETER.LOOP = 1 TO PARAMETER.COUNT

        THIS.PARAMETER = PARAMETER.LIST<PARAMETER.LOOP>

* we don't care about default values in this case so remove anything after
* an equals sign
        THIS.PARAMETER = TRIM(THIS.PARAMETER ["=", 1, 1], " ", "B")

* we don't need to know about optional parameters here.  if we see the optional
* parameter remove it from this.parameter
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        IF FIRST.PARM.WORD = OPTIONAL.KEYWORD THEN
            THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]
        END

* check for byval and byref keywords
        FIRST.PARM.WORD = THIS.PARAMETER [" ", 1, 1]

        BEGIN CASE

* byval
            CASE FIRST.PARM.WORD = BYVAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]

* byval special
            CASE FIRST.PARM.WORD = BYVAL.SPECIAL.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]

* byref
            CASE FIRST.PARM.WORD = BYREF.KEYWORD
                THIS.PARAMETER = THIS.PARAMETER [" ", 2, TO.THE.END]

        END CASE

* save the parameter (without optional or byvals) in the parameter.list for
* later
        PARAMETER.LIST<PARAMETER.LOOP> = THIS.PARAMETER

        CODE := BETWEEN.PARAMETERS:THIS.PARAMETER

    NEXT PARAMETER.LOOP

    RETURN

ADD.DIMENSION.RETURN.VARIABLES.CODE: *************************************
* if we have any dimensioned child objects to pass back dimension        *
* the return variables                                                   *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = ""
    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>

        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>

        IF THIS.CHILD.DEPTH <= BUILD.CHILD.DEPTH THEN

            IF THIS.DIMENSIONS > 0 THEN

                IF CODE = "" THEN
                    CODE = " "
                    GOSUB ADD.CODE
                    CODE = "* dimension return variables for child objects"
                    GOSUB ADD.CODE
                    CODE = "    DIM "
                END ELSE
                    CODE := ", "
                END

                CODE := "NEW.":THIS.HANDLE:"(":CHANGE(THIS.DIM,VM,","):")"

            END

        END

    NEXT CHILD.LOOP

    IF CODE <> "" THEN
        GOSUB ADD.CODE
    END

    GOSUB AFTER.ADD

    RETURN

ADD.CREATE.CHILD.OBJECTS.CODE: *******************************************
* if we have a new object handle create all new child objects            *
**************************************************************************
    IF CHILD.COUNT = 0 THEN
        RETURN
    END

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* create child objects"
    GOSUB ADD.CODE

    CODE = "    IF NEW.OBJECT AND INITIALIZE.OBJECT THEN"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

* if this object is a resident object and it has child objects the child
* objects should all be created with a registry source id of -1 so that
* they won't be deleted by a destroy or auto destroy just like the parent
* object
    IF RESIDENT.OBJECT THEN
        CODE = "* this object is a resident object.  create child objects with a source.id"
        GOSUB ADD.CODE
        CODE = "* of -1 so that the child objects will also remain resident"
        GOSUB ADD.CODE
        CODE = "        SAVE.":CHILD.REGISTRY.SOURCE.VARIABLE:" = ":CHILD.REGISTRY.SOURCE.VARIABLE
        GOSUB ADD.CODE
        CODE = "        ":CHILD.REGISTRY.SOURCE.VARIABLE:" = -1"
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE
    END

    NEW.CHILD.COUNT = 0
    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>
        THIS.CREATED.WITH = CHILD.CREATED.WITH.LIST<CHILD.LOOP>

        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        THIS.ADDITIONAL = CHILD.ADDITIONAL.LIST<CHILD.LOOP>

        THIS.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>
        THIS.DEFINED.LOCAL = CHILD.DEFINED.LOCAL.LIST<CHILD.LOOP>

        THIS.CHILD.LINE = CHILD.LINE.LIST<CHILD.LOOP>

        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>
        THIS.CHILD.CREATE.WITH = ""

        DECODE.KEYWORD = CHILD.KEYWORD.LIST<CHILD.LOOP>

        GOSUB DECODE.PROPERTY

* start the object creation statement depending on the object type
        IS.MULTI.THREADED = @FALSE

        BEGIN CASE

* "new" child objects created when the object is initialized
            CASE THIS.CREATED.WITH = NEW.KEYWORD
                CREATE.KEYWORD = NEW.KEYWORD:"("
            CASE THIS.CREATED.WITH = NEW.MULTI.THREAD.KEYWORD
                CREATE.KEYWORD = NEW.MULTI.THREAD.KEYWORD:"("
                IS.MULTI.THREADED = @TRUE

* "old" child objects that aren't created during initialization
            CASE THIS.CREATED.WITH = OLD.KEYWORD
                CREATE.KEYWORD = OLD.KEYWORD:"("
            CASE THIS.CREATED.WITH = OLD.MULTI.THREAD.KEYWORD
                CREATE.KEYWORD = OLD.MULTI.THREAD.KEYWORD:"("
            CASE IS.INTIME
                CREATE.KEYWORD = OLD.KEYWORD:"("

* if any other keyword is used create as a new object
            CASE 1
                CREATE.KEYWORD = NEW.KEYWORD:"("

        END CASE

* if we have initializing values and they aren't allowed throw an error
        IF THIS.ADDITIONAL <> "" THEN

            IF NOT(ALLOW.NEW.PARAMETERS) OR NOT(ALLOW.NEW.CHILD.PARAMETERS) THEN

                METHOD = NEW.KEYWORD
                OBJECT.ERROR.DESC = "Initializing parameters in child object "
                OBJECT.ERROR.DESC := THIS.NAME:" not allowed"
                OBJECT.ERROR.LINE = THIS.CHILD.LINE "R%6":" ":OBJECT.CODE<THIS.CHILD.LINE>
                SHOW.REFERENCE = @FALSE
                GOSUB PRINT.OBJECT.ERROR

                THIS.ADDITIONAL = ""

            END

            IF IS.INTIME THEN

                METHOD = NEW.KEYWORD
                OBJECT.ERROR.DESC = "Initializing parameters in intime child object "
                OBJECT.ERROR.DESC := THIS.NAME:" not allowed"
                OBJECT.ERROR.LINE = THIS.CHILD.LINE "R%6":" ":OBJECT.CODE<THIS.CHILD.LINE>
                SHOW.REFERENCE = @FALSE
                GOSUB PRINT.OBJECT.ERROR

                THIS.ADDITIONAL = ""

            END

            IF IS.MULTI.THREADED THEN

                METHOD = NEW.KEYWORD
                OBJECT.ERROR.DESC = "Initializing parameters in multi-threaded child object "
                OBJECT.ERROR.DESC := THIS.NAME:" not allowed"
                OBJECT.ERROR.LINE = THIS.CHILD.LINE "R%6":" ":OBJECT.CODE<THIS.CHILD.LINE>
                SHOW.REFERENCE = @FALSE
                GOSUB PRINT.OBJECT.ERROR

                THIS.ADDITIONAL = ""

            END

        END

        BEGIN CASE

* child depth is deeper than we want to worry about
            CASE THIS.CHILD.DEPTH > BUILD.CHILD.DEPTH
                NULL

* for any child references that are the child of a child will be returned in
* the "NEW" statement for the parent.  for those we just need to return the
* object handle to the return variable.  we'll get that later in this routine
            CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0
                NULL

* creating an intime child.  we won't create the child here in the "new"
* method.  we'll set the object handle null and it will be created the first
* time the object is used
            CASE THIS.DIMENSIONS = 0 AND IS.INTIME

                CODE = "        ":THIS.HANDLE:' = ""'
                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

* normal child handle create
            CASE THIS.DIMENSIONS = 0

                CODE = "        ":THIS.HANDLE
                CODE := " = "
                CODE := CREATE.KEYWORD
                CODE := THIS.NAME

                IF THIS.ADDITIONAL <> "" THEN
                    CODE := ",":THIS.ADDITIONAL
                END

                CODE := ")"
                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

* dimensionsed handle, one dimension, created intime
            CASE THIS.DIMENSIONS = 1 AND IS.INTIME
                
                CODE = "        MAT ":THIS.HANDLE:' = ""'
                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

* dimensioned handle, one dimension
            CASE THIS.DIMENSIONS = 1

                MAX.ARRAY = THIS.DIM

                CODE = "        "
                CODE := THIS.HANDLE:"(":MAX.ARRAY:")"
                CODE := " = "
                CODE := CREATE.KEYWORD
                CODE := THIS.NAME
                CODE := ")"

                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

* two dimensional handle, one dimension, created intime
            CASE THIS.DIMENSIONS = 2 AND IS.INTIME
                
                CODE = "        MAT ":THIS.HANDLE:' = ""'
                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

* two dimensional array
            CASE THIS.DIMENSIONS = 2

                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>

                CODE = "        "
                CODE := THIS.HANDLE":(":MAX.ARRAY1:", ":MAX.ARRAY2:")"
                CODE := " = "
                CODE := CREATE.KEYWORD
                CODE := THIS.NAME
                CODE := ")"
                GOSUB ADD.CODE

                NEW.CHILD.COUNT += 1

        END CASE

    NEXT CHILD.LOOP

* if this is a resident object with child objects restore the original
* source.id
    IF RESIDENT.OBJECT THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "        ":CHILD.REGISTRY.SOURCE.VARIABLE:" = SAVE.":CHILD.REGISTRY.SOURCE.VARIABLE
        GOSUB ADD.CODE
    END

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.CREATE.NEW.INSTANCE.CODE: ********************************************
* build code to either use the existing object handle (old()) or build a *
* new one (new()).  if we have no properties, however, we don't need     *
* to keep track of the object                                            *
**************************************************************************
    IF NOT(PROPERTIES.EXIST) THEN
        RETURN
    END

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if the instance handle is passed in null create a new instance along with"
    GOSUB ADD.CODE
    CODE = "* any child objects and return everything to the calling program"
    GOSUB ADD.CODE

* if this is "normal" object we'll create a new instance any time that
* new.handle is passed in null.  if this is a resident object, however, we
* have only one instance and we only want to create a new instance if that
* one instance has not been created.  since a resident object is never
* destroyed this one instance may have been created by another program.

* if last.object.handle is null then we've never created an instance for
* this resident object.  so, we only want to create a new instance for a
* resident object if new.handle and last.object.handle are BOTH null.

* we'll accomplish this by setting new.handle equal to last.object handle
* for resident objects
    IF RESIDENT.OBJECT THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* this is a resident object.  once it's created it won't be destroyed"
        GOSUB ADD.CODE
    END

    CODE = '    IF LAST.OBJECT.HANDLE = "0" THEN LAST.OBJECT.HANDLE = ""'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    CODE = "    BEGIN CASE"
    GOSUB ADD.CODE

* if new.handle is not null then we don't have a "new" object instance.
* we have an "old" one
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* a handle was passed in that's an 'old' handle"
    GOSUB ADD.CODE
    CODE = '        CASE NEW.HANDLE<1> <> ""'
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @FALSE"
    GOSUB ADD.CODE
    CODE = "            OBJECT.HANDLE = NEW.HANDLE"
    GOSUB ADD.CODE

* if this isn't a new object there won't be any initialize.value parameters.
    CODE = '            INITIALIZE.VALUE = ""'
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.OBJECT = @FALSE"
    GOSUB ADD.CODE
    CODE = "            GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

* if this object has more than one instance save the current one and
* load the new one
    IF MAX.INSTANCES > 1 THEN
        CODE = "            GOSUB SET.OBJECT.INSTANCE"
        GOSUB ADD.CODE
    END

    CODE = "            NEW.HANDLE = OBJECT.HANDLE"
    GOSUB ADD.CODE

* if we're using a different variable for local call handles set it here
    IF LOCAL.OBJECT.VARIABLE <> "OBJECT.HANDLE" THEN
        CODE = "            ":LOCAL.OBJECT.VARIABLE:" = OBJECT.HANDLE"
        GOSUB ADD.CODE
    END

    CODE = " "
    GOSUB ADD.CODE

* for single-instance object only we'll check the instance count.  IF THE
* instance count is zero we're creating a single-instance object for the
* first time

* if this is a resident object we'll only have one instance and it will never
* be destroyed.  set the single instance count variable to 1.  there's only
* an initialize.value if we're creating the initial new instance
    BEGIN CASE
        CASE RESIDENT.OBJECT
            GOSUB ADD.RESIDENT.NEW.INSTANCE.CODE
        CASE SINGLE.OBJECT
            GOSUB ADD.SINGLE.NEW.INSTANCE.CODE
        CASE 1
            GOSUB ADD.NORMAL.NEW.INSTANCE.CODE
    END CASE

    CODE = "    END CASE"
    GOSUB ADD.CODE

* continue with initializing the object
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if we're creating a new object create a new object handle"
    GOSUB ADD.CODE
    CODE = "    IF NEW.OBJECT THEN"
    GOSUB ADD.CODE
    CODE = "        GOSUB GET.NEW.OBJECT.HANDLE"
    GOSUB ADD.CODE
    CODE = "        NEW.HANDLE = OBJECT.HANDLE"
    GOSUB ADD.CODE

* for single-instance objects update the single instance list table and
* instance count
    IF SINGLE.OBJECT THEN
        CODE = "        LOCATE OBJECT.PTR IN ":SINGLE.INSTANCE.LIST.VARIABLE:' BY "AR" SETTING SINGLE.INSTANCE.LIST.PTR ELSE'
        GOSUB ADD.CODE
        CODE = "            INS OBJECT.PTR BEFORE ":SINGLE.INSTANCE.LIST.VARIABLE:"<SINGLE.INSTANCE.LIST.PTR>"
        GOSUB ADD.CODE
        CODE = "        END"
        GOSUB ADD.CODE
        CODE = "        ":SINGLE.INSTANCE.COUNT.VARIABLE:" = SUM(ACTIVE.OBJECT.HANDLE)"
        GOSUB ADD.CODE
    END

    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.NORMAL.NEW.INSTANCE.CODE: ********************************************
* add code for normal methods to decide if this is a new object and if   *
* the instance should be initialized                                     *
**************************************************************************
    CODE = "* this is a new instance of an object"
    GOSUB ADD.CODE
    CODE = "        CASE 1"
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.VALUE = RAISE(NEW.HANDLE<5>)"
    GOSUB ADD.CODE
    CODE = "            GOSUB SAVE.CURRENT.OBJECT.INSTANCE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.SINGLE.NEW.INSTANCE.CODE: ********************************************
* add code for single-instance methods to decide if this is a new        *
* object and if the instance should be initialized                       *
**************************************************************************
    CODE = "* this is a single-instance object and this is the first instance to be"
    GOSUB ADD.CODE
    CODE = "* created"
    GOSUB ADD.CODE
    CODE = "        CASE ":SINGLE.INSTANCE.COUNT.VARIABLE:" = 0"
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.VALUE = RAISE(NEW.HANDLE<5>)"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    CODE = "* this is a single-instance object and this is the second+ instance to be"
    GOSUB ADD.CODE
    CODE = "* created"
    GOSUB ADD.CODE
    CODE = "        CASE ":SINGLE.INSTANCE.COUNT.VARIABLE:" > 0"
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.OBJECT = @FALSE"
    GOSUB ADD.CODE
    CODE = '            INITIALIZE.VALUE = ""'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.RESIDENT.NEW.INSTANCE.CODE: ******************************************
* add code for resident methods to decide if this is a new  object and   *
* if the instance should be initialized                                  *
**************************************************************************
    CODE = "* this is a resident object and this is the first time the instance"
    GOSUB ADD.CODE
    CODE = "* has been created"
    GOSUB ADD.CODE
    CODE = "        CASE ":RESIDENT.INITIALIZE.VARIABLE:" = @FALSE"
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE 
    CODE = "            INITIALIZE.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.VALUE = RAISE(NEW.HANDLE<5>)"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    CODE = "* this is a single-instance object and this is the second+ instance to be"
    GOSUB ADD.CODE
    CODE = "* created"
    GOSUB ADD.CODE
    CODE = "        CASE ":RESIDENT.INITIALIZE.VARIABLE
    GOSUB ADD.CODE
    CODE = "            NEW.OBJECT = @TRUE"
    GOSUB ADD.CODE
    CODE = "            INITIALIZE.OBJECT = @FALSE"
    GOSUB ADD.CODE
    CODE = '            INITIALIZE.VALUE = ""'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    RETURN

ADD.CREATE.METHOD.TABLE.CODE: ********************************************
* if set to do so in the compile.setup create the "method table".  this  *
* is a dynamic array with a list of all methods, subroutine names and    *
* parameter lists for this objects.  this would allow a "generic"        *
* method-calling routine as it could look up the methods for this        *
* object, get the subroutine to call, and also get a list (and count) of *
* parameters involved.  this wouldn't be very fast but, if needed, it    *
* could be a handy thing                                                 *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* create method table for object"
    GOSUB ADD.CODE
    CODE = '    METHOD.TABLE = ""'
    GOSUB ADD.CODE

    IF BUILD.METHOD.TABLES THEN

        FOR METHOD.TABLE.LOOP = 1 TO METHOD.COUNT

            METHOD.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD.LIST<METHOD.TABLE.LOOP>

            IF BUILD.METHOD.TABLE.METHOD = "Slow" THEN

                CODE = '    METHOD.TABLE<':METHOD.TABLE.LOOP:',1> = "':METHOD.LIST<METHOD.TABLE.LOOP>:'"'
                GOSUB ADD.CODE
                CODE = '    METHOD.TABLE<':METHOD.TABLE.LOOP:',2> = "':METHOD.SUBROUTINE.NAME:'"'
                GOSUB ADD.CODE
                CODE = '    METHOD.TABLE<':METHOD.TABLE.LOOP:',3> = "':METHOD.PARM.COUNT.LIST<METHOD.TABLE.LOOP>:'"'
                GOSUB ADD.CODE

            END ELSE

                CODE = '    METHOD.TABLE<':METHOD.TABLE.LOOP:'> = "':METHOD.LIST<METHOD.TABLE.LOOP>:'"'
                CODE := ':@VM:"':METHOD.SUBROUTINE.NAME:'"'
                CODE := ':@VM:"':METHOD.PARM.COUNT.LIST<METHOD.TABLE.LOOP>:'"'
                GOSUB ADD.CODE

            END

        NEXT METHOD.TABLE

    END

    GOSUB AFTER.ADD

    RETURN

ADD.COPY.CHILD.HANDLES.CODE: *********************************************
* copy all child objects to the returned variables so they're passed to  *
* the calling program                                                    *
**************************************************************************
    GOSUB BEFORE.ADD

    IF RETURNED.CHILD.COUNT > 0 THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* copy child handles to the return variables"
        GOSUB ADD.CODE

* if we're using dimensioned child handles keep a pointer for the last
* array element used
        CHILD.ARRAY.PTR = 0

    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM, @VM)
        THIS.ADDITIONAL = CHILD.ADDITIONAL.LIST<CHILD.LOOP>
        THIS.CHILD.DEPTH = CHILD.DEPTH.LIST<CHILD.LOOP>

        TEST.VARIABLE = CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")
        LOCATE TEST.VARIABLE IN RETURNED.CHILD.LIST SETTING CHILD.FOUND.PTR THEN
            COPY.THIS.CHILD = @TRUE
        END ELSE
            COPY.THIS.CHILD = @FALSE
        END

* only copy this variable to the "new" one if it is passed back to the calling
* program in the subroutine statement
        IF COPY.THIS.CHILD THEN

            BEGIN CASE

* child of a child, not dimensioned, using dimensioned child handles
                CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0 AND THIS.DIMENSIONS = 0 AND USE.DIMENSIONED.CHILD.HANDLES
                    CHILD.ARRAY.PTR += 1
                    USE.CHILD.VARIABLE = CHILD.VARIABLE.PREFIX:CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")

                    LONG.VARIABLE = USE.CHILD.VARIABLE
                    GOSUB CHECK.VARIABLE.NAME
                    USE.CHILD.VARIABLE = SHORT.VARIABLE

                    CODE = "    ":CHILD.HANDLE.ARRAY.NAME:"(":CHILD.ARRAY.PTR:") = ":USE.CHILD.VARIABLE

* child of a child, not dimensioned
                CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0 AND THIS.DIMENSIONS = 0
                    USE.CHILD.VARIABLE = CHILD.VARIABLE.PREFIX:CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")

                    LONG.VARIABLE = USE.CHILD.VARIABLE
                    GOSUB CHECK.VARIABLE.NAME
                    USE.CHILD.VARIABLE = SHORT.VARIABLE

                    CODE = "    NEW.":USE.CHILD.VARIABLE:" = ":USE.CHILD.VARIABLE

* child of a child, dimensioned
                CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0
                    USE.CHILD.VARIABLE = CHILD.VARIABLE.PREFIX:".":CHANGE(THIS.HANDLE, CHILD.DELIMITER, ".")

                    LONG.VARIABLE = USE.CHILD.VARIABLE
                    GOSUB CHECK.VARIABLE.NAME
                    USE.CHILD.VARIABLE = SHORT.VARIABLE

                    CODE = "    MAT NEW.":USE.CHILD.VARIABLE:" = MAT ":USE.CHILD.VARIABLE

* child, not dimensioned, using dimensioned child handles
                CASE THIS.DIMENSIONS = 0 AND USE.DIMENSIONED.CHILD.HANDLES
                    CHILD.ARRAY.PTR += 1
                    CODE = "    ":CHILD.HANDLE.ARRAY.NAME:"(":CHILD.ARRAY.PTR:") = ":THIS.HANDLE

* child, not dimensioned
                CASE THIS.DIMENSIONS = 0
                    CODE = "    NEW.":THIS.HANDLE:" = ":THIS.HANDLE

* child, dimensioned
                CASE 1
                    CODE = "    MAT NEW.":THIS.HANDLE:" = MAT ":THIS.HANDLE

            END CASE

            GOSUB ADD.CODE

        END

    NEXT CHILD.LOOP

    GOSUB AFTER.ADD

    RETURN

ADD.UPDATE.REGISTRY.CODE: ************************************************
* add the code to update the object registry                             *
**************************************************************************
    GOSUB BEFORE.ADD

* do an "add" to the object registry.  registry.source.id is passed
* in without initializing on purpose so that ud.object.registry will
* generate a new, unqiue registry.source.id
    IF UPDATE.OBJECT.REGISTRY THEN

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* add to object registry and copy the registry source id to common"
        GOSUB ADD.CODE

    END

    BEGIN CASE

        CASE RESIDENT.OBJECT
            CODE = "    IF NEW.OBJECT AND INITIALIZE.OBJECT THEN"
            GOSUB ADD.CODE

        CASE SINGLE.OBJECT
            CODE = "    IF NEW.OBJECT THEN"
            GOSUB ADD.CODE

        CASE 1
            CODE = "    IF NEW.OBJECT THEN"
            GOSUB ADD.CODE

    END CASE

* build the ud.object.registry call to add the object.  if the registry source
* id (child.registry.source.variable) isn't set ud.object.registry will set it.
* if this object is a resident object add it to the object registry with a
* source of -1.  this will prevent the object from being destroyed
    BEGIN CASE


* updating code for resident objects
        CASE RESIDENT.OBJECT AND UPDATE.OBJECT.REGISTRY

*     add new instance to the object registry
            CODE = '        REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("ADD", '

            IF PASS.REGISTRY.HANDLES.BYVAL THEN
                CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            END ELSE
                CODE := "OBJECT.HANDLE, "
            END

            CODE := '"':ECLIPSE.PREFIX:'", ':(-1):", "
            CODE := "METHOD.TABLE, REGISTRY.ERROR)"
            GOSUB ADD.CODE

*     update object registry "resident" status for this object
            CODE = '        REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("RESIDENT", '

            IF PASS.REGISTRY.HANDLES.BYVAL THEN
                CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            END ELSE
                CODE := "OBJECT.HANDLE, "
            END
        
            CODE := '"':ECLIPSE.PREFIX:'", "", "", REGISTRY.ERROR)'
            GOSUB ADD.CODE


* updating code for single-instance objects
        CASE MAX.INSTANCES = 1 AND UPDATE.OBJECT.REGISTRY

*     add new instance to the object registry
            CODE = '        REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("ADD", '

            IF PASS.REGISTRY.HANDLES.BYVAL THEN
                CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            END ELSE
                CODE := "OBJECT.HANDLE, "
            END

            CODE := '"':ECLIPSE.PREFIX:'", ':CHILD.REGISTRY.SOURCE.VARIABLE:", "
            CODE := "METHOD.TABLE, REGISTRY.ERROR)"
            GOSUB ADD.CODE

*     update object registry "single-instance" status for this object
            CODE = '        REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("SINGLE", '

            IF PASS.REGISTRY.HANDLES.BYVAL THEN
                CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            END ELSE
                CODE := "OBJECT.HANDLE, "
            END
        
            CODE := '"':ECLIPSE.PREFIX:'", "", "", REGISTRY.ERROR)'
            GOSUB ADD.CODE


* "normal" objects.  not resident, not single-instance
        CASE UPDATE.OBJECT.REGISTRY

*     add new instance to the object registry
            CODE = '        REGISTRY.RESPONSE = UD.OBJECT.REGISTRY("ADD", '

            IF PASS.REGISTRY.HANDLES.BYVAL THEN
                CODE := CONVERT.BYVAL("OBJECT.HANDLE", ONLY.BYVAL.NON.EXPRESSIONS):", "
            END ELSE
                CODE := "OBJECT.HANDLE, "
            END

            CODE := '"':ECLIPSE.PREFIX:'", ':CHILD.REGISTRY.SOURCE.VARIABLE:", "
            CODE := "METHOD.TABLE, REGISTRY.ERROR)"
            GOSUB ADD.CODE

* "normal" object but we aren't updating the registry
        CASE 1
            CODE = "    ":REGISTRY.SOURCE.VARIABLE:" = 0"
            GOSUB ADD.CODE


    END CASE

    CODE = "        INSTANCE.REGISTRY.SOURCE.ID = ":CHILD.REGISTRY.SOURCE.VARIABLE
    GOSUB ADD.CODE

    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

* unload values passed in the initializing values.  if an assignment was declared
* in the "object" line with a "assign" statement assign the initial value to the
* assigned variable.  if the assigned value ends in "()" then this is a reference
* to a method.  make a call to that method, passing the initializing value

* this is before whatever custom code the user may have written.  we'll do the
* initialize.value assignments but we won't do the method calls.  it's possible
* the method calls may need the custom code to be run to initialize things--it
* may not run properly until the user's custom code has run.  we'll do the method
* calls after
    INITIALIZE.VALUE.COUNT = DCOUNT(INITIALIZE.ASSIGN, @AM)

* how many of the initial values are a variable name and how many are a method
* call?
    INITIALIZE.METHOD.COUNT = 0
    INITIALIZE.ASSIGN.COUNT = 0

    FOR INIT.LOOP = 1 TO INITIALIZE.VALUE.COUNT

        THIS.ASSIGN = INITIALIZE.ASSIGN<INIT.LOOP>

        IF THIS.ASSIGN [2] = "()" THEN
            INITIALIZE.METHOD.COUNT += 1
        END ELSE
            INITIALIZE.ASSIGN.COUNT += 1
        END

    NEXT INIT.LOOP

    GOSUB AFTER.ADD

    RETURN

ADD.ASSIGNED.CODE.BEFORE: ************************************************
* if the assign option was used do any assignments to "ASSIGN"ed         *
* variables                                                              *
**************************************************************************
    IF (PASS.ASSIGN.OPTION.USED OR ASSIGN.OPTION.USED) AND INITIALIZE.VALUE.COUNT > 0 THEN

        GOSUB BEFORE.ADD

* if initializing values were defined by an assign option extract individual
* values from the initialize.value variable
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* unload up to ":INITIALIZE.VALUE.COUNT:" initializing values"
        GOSUB ADD.CODE
        CODE = "* defined in the 'assign' option"
        GOSUB ADD.CODE

        FOR INIT.LOOP = 1 TO INITIALIZE.VALUE.COUNT
            CODE = "    INITIALIZE.VALUE.":INIT.LOOP:" = RAISE(INITIALIZE.VALUE<":INIT.LOOP:">)"
            GOSUB ADD.CODE
        NEXT INIT.LOOP

        CODE = " "
        GOSUB ADD.CODE

        IF ASSIGN.OPTION.USED THEN
            CODE = "* assign initial values defined by the 'assign' option and"
            GOSUB ADD.CODE 
            CODE = "* passed from the calling program to assigned variables"
            GOSUB ADD.CODE
        END ELSE
            CODE = "* assign initial values passed in via the 'new' method"
            GOSUB ADD.CODE 
        END

        CODE = "    IF NEW.OBJECT AND INITIALIZE.OBJECT THEN"
        GOSUB ADD.CODE

        FOR INIT.LOOP = 1 TO INITIALIZE.VALUE.COUNT

            THIS.ASSIGN = INITIALIZE.ASSIGN<INIT.LOOP>
            THIS.ASSIGN.DEFAULT = INITIALIZE.ASSIGN.DEFAULT<INIT.LOOP>

            BEGIN CASE

                CASE THIS.ASSIGN = ""
                    NULL

                CASE THIS.ASSIGN [2] = "()"
                    NULL

                CASE THIS.ASSIGN.DEFAULT <> ""
                    CODE = " "
                    GOSUB ADD.CODE
                    CODE = "        IF INITIALIZE.VALUE.":INIT.LOOP:' <> "" THEN'
                    GOSUB ADD.CODE
                    CODE = "            ":THIS.ASSIGN:" = INITIALIZE.VALUE.":INIT.LOOP
                    GOSUB ADD.CODE
                    CODE = "        END ELSE"
                    GOSUB ADD.CODE
                    CODE = "            ":THIS.ASSIGN:" = ":THIS.ASSIGN.DEFAULT
                    GOSUB ADD.CODE
                    CODE = "        END"
                    GOSUB ADD.CODE

                CASE 1
                    CODE = " "
                    GOSUB ADD.CODE
                    CODE = "        ":THIS.ASSIGN:" = INITIALIZE.VALUE.":INIT.LOOP
                    GOSUB ADD.CODE

            END CASE

        NEXT INIT.LOOP

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    RETURN

ADD.NEW.METHOD.USER.CODE: ************************************************
* add whatever method code might be in the object definition.  we only   *
* want to execute it for new object creation, though                     *
**************************************************************************
    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* custom user code from the object definition"
    GOSUB ADD.CODE

    CODE = "    IF NEW.OBJECT AND INITIALIZE.OBJECT THEN"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.AUTO.STRING.DEFINITION
    GOSUB ADD.AUTO.DEBUG.CODE

* add user code if there is any
    GOSUB GET.METHOD.CODE.LINES

    IF METHOD.CODE.LINES > 0 THEN

        GOSUB BEFORE.ADD

        CODE = BEFORE.USER.CODE
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE

        USER.CODE.START.PTR = PROGRAM.CODE.LINES

        GOSUB AFTER.ADD

        ADD.RETURN = @FALSE
        ADD.FINAL.ERROR.CHECK = @TRUE
        INDENT = "    "
        GOSUB ADD.METHOD.CODE

        USER.CODE.END.PTR = PROGRAM.CODE.LINES

        GOSUB BEFORE.ADD

        CODE = AFTER.USER.CODE
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE

        USER.CODE.START.PTR = PROGRAM.CODE.LINES

        CODE = NO.USER.CODE
        GOSUB ADD.CODE

        USER.CODE.END.PTR = PROGRAM.CODE.LINES

        GOSUB AFTER.ADD

    END

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    RETURN

ADD.ASSIGNED.CODE.AFTER: *************************************************
* if the assign option was used now add any calls from the               *
* initialize.value variables                                             *
**************************************************************************
    IF (PASS.ASSIGN.OPTION.USED OR ASSIGN.OPTION.USED) AND INITIALIZE.METHOD.COUNT > 0 THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* do any method calls defined by the 'assign' option based"
        GOSUB ADD.CODE
        CODE = "* on the initialize.value fields"
        GOSUB ADD.CODE

        CODE = "    IF NEW.OBJECT AND INITIALIZE.OBJECT THEN"
        GOSUB ADD.CODE

        FOR INIT.LOOP = 1 TO INITIALIZE.VALUE.COUNT

            THIS.ASSIGN = INITIALIZE.ASSIGN<INIT.LOOP>

            BEGIN CASE

                CASE THIS.ASSIGN = ""

                    NULL

                CASE THIS.ASSIGN [2] = "()"

                    INITIALIZE.METHOD = THIS.ASSIGN [1, LEN(THIS.ASSIGN) - 2]

                    CODE = "        IF INITIALIZE.VALUE.":INIT.LOOP:' <> "" THEN'
                    GOSUB ADD.CODE
                    CODE = "            ":LOCAL.KEYWORD:"::":INITIALIZE.METHOD:" (INITIALIZE.VALUE.":INIT.LOOP:")"
                    GOSUB ADD.CODE
                    CODE = "            GOSUB CHECK.OBJECT.INSTANCE"
                    GOSUB ADD.CODE
                    CODE = "        END"
                    GOSUB ADD.CODE

                CASE 1

                    NULL

            END CASE

        NEXT INIT.LOOP

        CODE = "    END"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    RETURN

ADD.CHECK.MISMATCHED.CHILD.CODE: *****************************************
* add code to check and make sure that the child objects match for       *
* this "new" method vs the call from the calling program                 *
**************************************************************************
    IF CHECK.MISMATCHED.CHILD.OBJECTS THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = CHECK.MISMATCHED.CHILD.NAME:": ":STR("*", 73 - LEN(CHECK.MISMATCHED.CHILD.NAME))
        GOSUB ADD.CODE
        CODE = ("* check for mismatches in the child object list") "L#74":"*"
        GOSUB ADD.CODE
        CODE = STR("*", 75)
        GOSUB ADD.CODE

        CODE = "    IF UNASSIGNED(NEW.HANDLE) THEN NEW.HANDLE = ":'""'
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* create the child object definition string to verify returned"
        GOSUB ADD.CODE
        CODE = "* child objects are correct"
        GOSUB ADD.CODE
        CODE = "    CHILD.OBJECT.DEFINITION.STRING = ":'"':CHILD.OBJECT.STRING:'"'
        GOSUB ADD.CODE
        CODE = "    VERIFY.CHILD.OBJECT.STRING = NEW.HANDLE<3>"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* if the passed child verification string is null it may be"
        GOSUB ADD.CODE
        CODE = "* an old subroutine or it may not be looking for any child objects"
        GOSUB ADD.CODE
        CODE = "* either way we don't need to verify"
        GOSUB ADD.CODE
        CODE = "    IF VERIFY.CHILD.OBJECT.STRING = ":'""':" THEN"
        GOSUB ADD.CODE
        CODE = "        RETURN"
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* we only need to verify the child objects that the calling program"
        GOSUB ADD.CODE
        CODE = "* is looking for.  if there are extra child objects in the object"
        GOSUB ADD.CODE
        CODE = "* but the calling program isn't using them we're still okay if the"
        GOSUB ADD.CODE
        CODE = "* objects the calling program uses are in the correct parameter"
        GOSUB ADD.CODE
        CODE = "* locations"
        GOSUB ADD.CODE
        CODE = "    VERIFY.LEN = LEN (VERIFY.CHILD.OBJECT.STRING)"
        GOSUB ADD.CODE
        CODE = "    CHILD.LEN = LEN (CHILD.OBJECT.DEFINITION.STRING)"
        GOSUB ADD.CODE
        CODE = "    IF VERIFY.CHILD.OBJECT.STRING = CHILD.OBJECT.DEFINITION.STRING [1, VERIFY.LEN] THEN"
        GOSUB ADD.CODE
        CODE = "        RETURN"
        GOSUB ADD.CODE
        CODE = "    END"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    DIFFERENT.PTR = 0"
        GOSUB ADD.CODE
        CODE = "    FOR CHECK.PTR = 1 TO VERIFY.LEN UNTIL DIFFERENT.PTR <> 0"
        GOSUB ADD.CODE
        CODE = "        IF VERIFY.CHILD.OBJECT.STRING [CHECK.PTR, 1] <> CHILD.OBJECT.DEFINITION.STRING [CHECK.PTR, 1] THEN"
        GOSUB ADD.CODE
        CODE = "            DIFFERENT.PTR = CHECK.PTR"
        GOSUB ADD.CODE
        CODE = "        END"
        GOSUB ADD.CODE
        CODE = "    NEXT CHECK.PTR"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = '    MESSAGE = "Fatal Error in ":CURRENT.COMPLETE.NAME:":"'
        GOSUB ADD.CODE
        CODE = '    MESSAGE<3> = "Calling program attempted to create object ":CURRENT.OBJECT.NAME:" with a"'
        GOSUB ADD.CODE
        CODE = '    MESSAGE<4> = "mismatched child object list.  Difference starts at ":DIFFERENT.PTR:":"'
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "* show where the difference starts"
        GOSUB ADD.CODE
        CODE = '    DIFFERENCE.INDICATOR = " -> "'
        GOSUB ADD.CODE
        CODE = "    VERIFY.CHILD.OBJECT.STRING = VERIFY.CHILD.OBJECT.STRING [1, DIFFERENT.PTR - 1]"
        CODE := ":DIFFERENCE.INDICATOR:VERIFY.CHILD.OBJECT.STRING [DIFFERENT.PTR, VERIFY.LEN]"
        GOSUB ADD.CODE
        CODE = "    CHILD.OBJECT.DEFINITION.STRING = CHILD.OBJECT.DEFINITION.STRING [1, DIFFERENT.PTR - 1]"
        CODE := ":DIFFERENCE.INDICATOR:CHILD.OBJECT.DEFINITION.STRING [DIFFERENT.PTR, CHILD.LEN]"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = '    DEFINITION.LENGTH = CHILD.LEN'
        GOSUB ADD.CODE
        CODE = '    IF VERIFY.LEN > DEFINITION.LENGTH THEN'
        GOSUB ADD.CODE
        CODE = '        DEFINITION.LENGTH = VERIFY.LEN'
        GOSUB ADD.CODE
        CODE = '    END'
        GOSUB ADD.CODE
        CODE = "    DEFINITION.DISPLAY.WIDTH = 65"
        GOSUB ADD.CODE
        CODE = '    IF DEFINITION.LENGTH > DEFINITION.DISPLAY.WIDTH THEN'
        GOSUB ADD.CODE
        CODE = '        DEFINITION.LENGTH = DEFINITION.DISPLAY.WIDTH'
        GOSUB ADD.CODE
        CODE = '    END'
        GOSUB ADD.CODE
        CODE = '    DEFINITION.MASK = "L#":DEFINITION.LENGTH'
        GOSUB ADD.CODE
        CODE = "    MESSAGE.PTR = 6"
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = '    MESSAGE<MESSAGE.PTR> = "Object: ":CHILD.OBJECT.DEFINITION.STRING DEFINITION.MASK'
        GOSUB ADD.CODE
        CODE = "    MESSAGE.PTR += 1"
        GOSUB ADD.CODE
        CODE = "    ADDITIONAL.MESSAGE.LINES = INT ((CHILD.LEN - 1) / DEFINITION.DISPLAY.WIDTH)"
        GOSUB ADD.CODE
        CODE = "    FOR ADDITIONAL = 1 TO ADDITIONAL.MESSAGE.LINES"
        GOSUB ADD.CODE
        CODE = '        MESSAGE<MESSAGE.PTR> = "        ":CHILD.OBJECT.DEFINITION.STRING'
        CODE := " [DEFINITION.LENGTH * ADDITIONAL + 1, DEFINITION.LENGTH]"
        GOSUB ADD.CODE
        CODE = "        MESSAGE.PTR += 1"
        GOSUB ADD.CODE
        CODE = '    NEXT ADDITIONAL'
        GOSUB ADD.CODE

        CODE = '    MESSAGE<MESSAGE.PTR> = "Call:   ":VERIFY.CHILD.OBJECT.STRING DEFINITION.MASK'
        GOSUB ADD.CODE
        CODE = "    MESSAGE.PTR += 1"
        GOSUB ADD.CODE
        CODE = "    ADDITIONAL.MESSAGE.LINES = INT ((VERIFY.LEN - 1) / DEFINITION.DISPLAY.WIDTH)"
        GOSUB ADD.CODE
        CODE = "    FOR ADDITIONAL = 1 TO ADDITIONAL.MESSAGE.LINES"
        GOSUB ADD.CODE
        CODE = '        MESSAGE<MESSAGE.PTR> = "        ":VERIFY.CHILD.OBJECT.STRING'
        CODE := " [DEFINITION.LENGTH * ADDITIONAL + 1, DEFINITION.LENGTH]"
        GOSUB ADD.CODE
        CODE = "        MESSAGE.PTR += 1"
        GOSUB ADD.CODE
        CODE = '    NEXT ADDITIONAL'
        GOSUB ADD.CODE

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    MESSAGE.PTR += 1"
        GOSUB ADD.CODE
        CODE = '    MESSAGE<MESSAGE.PTR> = "Calling program must be recompiled"'
        GOSUB ADD.CODE
        CODE = '    UD.SHOW.OBJECT.ERROR MESSAGE, 1'
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE
        CODE = "    GOSUB ":EXIT.OUT.GOSUB.NAME
        GOSUB ADD.CODE
        CODE = " "
        GOSUB ADD.CODE

        CODE = "    RETURN"
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / get.property method   **
**************************************************************************
**************************************************************************

CREATE.GET.PROPERTY.METHOD: **********************************************
* create a method to fetch a property value and return to calling        *
* program                                                                *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = GET.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating ":GET.KEYWORD:" Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

* subroutine definition line
    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS
    CODE := "PROPERTY.NAME":BETWEEN.PARAMETERS:"PROPERTY.VALUE":BETWEEN.PARAMETERS:"MAT DIM.PROPERTY.VALUE"
    CODE := BETWEEN.PARAMETERS:"DIM.PTR1":BETWEEN.PARAMETERS:"DIM.PTR2":BETWEEN.PARAMETERS:"DIM.PTR3"
    CODE := BETWEEN.PARAMETERS:"ATTR.PTR":BETWEEN.PARAMETERS:"VAL.PTR":BETWEEN.PARAMETERS:"SUBVAL.PTR"
    CODE := ")"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* get a property for ":OBJECT.NAME "L#30":"                      *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    ORIGINAL.OBJECT.HANDLE = LAST.OBJECT.HANDLE"
    GOSUB ADD.CODE
    CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE
    CODE = "    PROPERTY.NAME = UPCASE(PROPERTY.NAME)"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* method code"
    GOSUB ADD.CODE

    CODE = "* extract property value based on property name"
    GOSUB ADD.CODE
    CODE = '    PROPERTY.VALUE = ""'
*   GOSUB ADD.CODE
*   CODE = '    MAT DIM.PROPERTY.VALUE = ""'
    GOSUB ADD.CODE

* build case statement to return properties
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    BEGIN CASE"
    GOSUB ADD.CODE

* if we're coding multivalued extracts add a blank line for readability
    IF MULTIVALUE.PROPERTIES THEN
        CODE = " "
        GOSUB ADD.CODE
    END

* add up how many non-local properties we have
    NON.LOCAL.PROP.COUNT = 0
    FOR PROP.LOOP = 1 TO PROP.COUNT
        IF NOT(PROP.LOCAL.LIST<PROP.LOOP>) THEN
            NON.LOCAL.PROP.COUNT += 1
        END
    NEXT PROP.LOOP

    IF NON.LOCAL.PROP.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* properties / statics"
        GOSUB ADD.CODE
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT UNTIL NON.LOCAL.PROP.COUNT = 0

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>
        THIS.LOCAL = PROP.LOCAL.LIST<PROP.LOOP>

* if wrapping property gets and puts is turned on build the method name for the
* method that would be the "get" for this property name.  if this method
* exists we'll call this method instead of writing the code to return the
* property value
        PROPERTY.WRAPPED = @FALSE
        DIM.PROPERTY.WRAPPED = @FALSE

        PROPERTY.WRAPPER.SUBROUTINE.NAME = ""
        PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME = ""

        IF ALLOW.WRAPPED.PROPERTY.CALLS THEN

            IF THIS.DIMENSIONS = 0 THEN

* see if there's a routine for wrapping the property.  if there is build the
* cbp subroutine name to call the wrapping method
                WRAPPER.METHOD.NAME = GET.WRAPPED.PROPERTY.PREFIX:THIS.NAME
                LOCATE WRAPPER.METHOD.NAME IN METHOD.LIST SETTING WRAPPER.PTR THEN
                    PROPERTY.WRAPPED = @TRUE
                    PROPERTY.WRAPPER.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME
                    PROPERTY.WRAPPER.SUBROUTINE.NAME := ECLIPSE.DELIMITER:WRAPPER.METHOD.NAME
                END

            END ELSE

* if this property is dimensioned see if dimensioned property calls for this
* property are wrapped.  if so build the cbp subroutine name to call this
* method
                WRAPPER.DIM.METHOD.NAME = GET.WRAPPED.DIM.PREFIX:THIS.NAME
                LOCATE WRAPPER.DIM.METHOD.NAME IN METHOD.LIST SETTING DIM.WRAPPER.PTR THEN
                    DIM.PROPERTY.WRAPPED = @TRUE
                    PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME
                    PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME := ECLIPSE.DELIMITER:WRAPPER.DIM.METHOD.NAME
                END

            END

        END

* if multivalue.properties is turned on add code for when the
* multivalued pointer(s) is/are passed in
        BEGIN CASE

* cases where we won't add code to fetch a value:
*     if this is a local property don't add
            CASE THIS.LOCAL
                NULL

*     if this is the child of a child don't add
            CASE INDEX(THIS.NAME, CHILD.DELIMITER, 1) > 0
                NULL


* wrapped properties and we have multivalue property pointers enabled:
*     property is not dimensioned
            CASE PROPERTY.WRAPPED
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE

*     property is a 1 dimensional array and we have both the array pointer
*     and multivalue pointers
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE

*     property is a 2 dimensional array and we have both the array pointers
*     and multivalue pointers
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, DIM.PTR2, ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE


*     if multivalued.properties is turned off don't add anything
            CASE NOT(MULTIVALUE.PROPERTIES)
                NULL


* properties that aren't wrapped and we have multivalue property pointers
* enabled:
*     property is not dimensioned
            CASE THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            PROPERTY.VALUE = ':THIS.NAME
                CODE := "<ATTR.PTR,VAL.PTR,SUBVAL.PTR>"
                GOSUB ADD.CODE

*     property is a 1 dimensional array and we have both the array pointer
*     and multivalue pointers
            CASE THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> "" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME
                CODE := "(DIM.PTR1)<ATTR.PTR,VAL.PTR,SUBVAL.PTR>"
                GOSUB ADD.CODE

*     property is a 2 dimensional array and we have both the array pointers
*     and multivalue pointers
            CASE THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> "" AND DIM.PTR2 <> "" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME
                CODE := "(DIM.PTR1, DIM.PTR2)<ATTR.PTR,VAL.PTR,SUBVAL.PTR>"
                GOSUB ADD.CODE

        END CASE

* if this is a dimensioned variable add case statements for pulling a
* single array element.  for non-dimensioned variables add statement
* for pulling a multivalue
        BEGIN CASE

* cases where we don't want to return a value:
*     if this is a local property don't add anything
            CASE THIS.LOCAL
                NULL

*     if this is the child of a child don't add
            CASE INDEX(THIS.NAME, CHILD.DELIMITER, 1) > 0
                NULL


* properties that are wrapped:
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1"
                GOSUB ADD.CODE

*     property is a 2 dimensional array
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, DIM.PTR2"
                GOSUB ADD.CODE


* properties that aren't wrapped:
*     property is a 1 dimensional array
            CASE THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME
                CODE := "(DIM.PTR1)"
                GOSUB ADD.CODE

*     property is a 2 dimensional array
            CASE THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME
                CODE := "(DIM.PTR1, DIM.PTR2)"
                GOSUB ADD.CODE


        END CASE

* "normal" parameter pulls
        BEGIN CASE

* cases where we don't want to add any code:
*     if this is a local property don't add anything
            CASE THIS.LOCAL
                NULL

*     if this is the child of a child don't add
            CASE INDEX(THIS.NAME, CHILD.DELIMITER, 1) > 0
                NULL


* normal property extract and the property is wrapped:
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE"
                GOSUB ADD.CODE

* dimensioned property extract and the property is wrapped
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS > 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, MAT DIM.PROPERTY.VALUE"
                GOSUB ADD.CODE


* normal property extract, where neither an array nor multivalue pointer is
* passed in:
*     property is not dimensioned:
            CASE THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME
                GOSUB ADD.CODE

*     property is dimensioned
            CASE THIS.DIMENSIONS > 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            MAT DIM.PROPERTY.VALUE = MAT ":THIS.NAME
                GOSUB ADD.CODE


        END CASE

* if we're coding multivalued extracts add a blank line for readability
        IF NOT(THIS.LOCAL) AND MULTIVALUE.PROPERTIES THEN
            CODE = " "
            GOSUB ADD.CODE
        END

    NEXT PROP.LOOP

* add up how many non-local child objects we have
    NON.LOCAL.CHILD.COUNT = 0

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        IF NOT(CHILD.LOCAL.LIST<CHILD.LOOP>) THEN
            NON.LOCAL.CHILD.COUNT += 1
        END

    NEXT CHILD.LOOP

* add in cases for child objects
    IF NON.LOCAL.CHILD.COUNT > 0 AND ALLOW.GET.CHILD.HANDLES THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* child object handles"
        GOSUB ADD.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT UNTIL NON.LOCAL.CHILD.COUNT = 0 OR NOT(ALLOW.GET.CHILD.HANDLES)

        THIS.NAME = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.LOCAL = CHILD.LOCAL.LIST<CHILD.LOOP>

* if this is a dimensioned variable add case statements for pulling a
* single array element.  for non-dimensioned variables add statement
* for pulling a multivalue
        BEGIN CASE

* if this is a local property don't add anything
            CASE THIS.LOCAL
                NULL

* if this is the child of a child don't add
            CASE INDEX(THIS.NAME, CHILD.DELIMITER, 1) > 0
                NULL

* property is a 1 dimensional array
            CASE THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME:"(DIM.PTR1)"
                GOSUB ADD.CODE

* property is a 2 dimensional array
            CASE THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                GOSUB ADD.CODE
                CODE = "            PROPERTY.VALUE = ":THIS.NAME:"(DIM.PTR1,DIM.PTR2)"
                GOSUB ADD.CODE

        END CASE

        BEGIN CASE

* if this is a local property don't add anything
            CASE THIS.LOCAL
                NULL

* if this is the child of a child don't add
            CASE INDEX(THIS.NAME, CHILD.DELIMITER, 1) > 0
                NULL

* normal property extract, where neither an array nor multivalue pointer is
* passed in
            CASE 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                IF THIS.DIMENSIONS = 0 THEN
                    CODE = "            PROPERTY.VALUE = ":THIS.NAME
                END ELSE
                    CODE = "            MAT DIM.PROPERTY.VALUE = MAT ":THIS.NAME
                END
                GOSUB ADD.CODE

        END CASE

    NEXT CHILD.LOOP

* add up how many non-local constants we have
    NON.LOCAL.CONSTANT.COUNT = 0

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT

        IF NOT(CONSTANT.LOCAL.LIST<CONSTANT.LOOP>) THEN
            NON.LOCAL.CONSTANT.COUNT += 1
        END

    NEXT CONSTANT.LOOP

* add in cases for constants
    IF ALLOW.GET.CONSTANTS AND NON.LOCAL.CONSTANT.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* constants"
        GOSUB ADD.CODE
    END

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT UNTIL NOT(ALLOW.GET.CONSTANTS)

        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>
        THIS.LOCAL = CONSTANT.LOCAL.LIST<CONSTANT.LOOP>

        IF NOT(THIS.LOCAL) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
            GOSUB ADD.CODE
            CODE = "            PROPERTY.VALUE = ":THIS.NAME
            GOSUB ADD.CODE
        END

    NEXT CONSTANT.LOOP

* add "special" variables that can return arrays of properties
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* return the table of object instances that are being used"
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$USED.INSTANCE.TABLE$"'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ACTIVE.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* property lists.  these 'properties' are usually polled by the object"
    GOSUB ADD.CODE
    CODE = "* debugging routines.  after the values have been pulled the object.handle"
    GOSUB ADD.CODE
    CODE = "* will be returned it its original state and the object instance properties"
    GOSUB ADD.CODE
    CODE = "* will be returned to their original states as well"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$ALL.PROPERTIES$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.PROPERTY.ARRAY'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"PROPERTY.ARRAY"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$NAME.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"PROPERTY.NAME.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$STATIC.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"STATIC.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$CHILD.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"CHILD.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$CONSTANT.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"CONSTANT.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$LOCAL.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"LOCAL.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$FILE.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"FILE.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$LIST.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"LIST.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$KEYWORD.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"KEYWORD.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$NAMES$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"PROPERTY.NAME.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$DIMMED.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"DIMENSIONED.FLAG.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$DIM.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"DIMENSIONS.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE PROPERTY.NAME = "$OBJECT.TYPE.LIST$"'
    GOSUB ADD.CODE
    CODE = '            GOSUB BUILD.ALL.PROPERTY.LISTS'
    GOSUB ADD.CODE
    CODE = "            PROPERTY.VALUE = ":DEBUG.PREFIX:"OBJECT.TYPE.LIST"
    GOSUB ADD.CODE
    CODE = "            GOSUB RESTORE.ORIGINAL.OBJECT.HANDLE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    END CASE"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @FALSE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB ADD.ALL.PROPERTY.LIST.ROUTINE
    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

    GOSUB ADD.FINAL.END
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / put.property method   **
**************************************************************************
**************************************************************************

CREATE.PUT.PROPERTY.METHOD: **********************************************
* create a method to update a property value from the calling program    *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = PUT.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating PUT.PROPERTY Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS
    CODE := "PROPERTY.NAME":BETWEEN.PARAMETERS:"PROPERTY.VALUE":BETWEEN.PARAMETERS:"MAT DIM.PROPERTY.VALUE"
    CODE := BETWEEN.PARAMETERS:"DIM.PTR1":BETWEEN.PARAMETERS:"DIM.PTR2":BETWEEN.PARAMETERS:"DIM.PTR3"
    CODE := BETWEEN.PARAMETERS:"ATTR.PTR":BETWEEN.PARAMETERS:"VAL.PTR":BETWEEN.PARAMETERS:"SUBVAL.PTR"
    CODE := ")"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* update a property for ":OBJECT.NAME "L#30":"                   *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE
    CODE = "    PROPERTY.NAME = UPCASE(PROPERTY.NAME)"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* method code"
    GOSUB ADD.CODE
    CODE = "* update property value based on property name"
    GOSUB ADD.CODE

    CODE = "    BEGIN CASE"
    GOSUB ADD.CODE

* if we're coding multivalued extracts add a blank line for readability
    IF MULTIVALUE.PROPERTIES THEN
        CODE = " "
        GOSUB ADD.CODE
    END

* add up how many non-local properties we have
    NON.LOCAL.PROP.COUNT = 0

    FOR PROP.LOOP = 1 TO PROP.COUNT

        IF NOT(PROP.LOCAL.LIST<PROP.LOOP>) THEN
            NON.LOCAL.PROP.COUNT += 1
        END

    NEXT PROP.LOOP

    IF NON.LOCAL.PROP.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* properties / statics"
        GOSUB ADD.CODE
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT UNTIL NON.LOCAL.PROP.COUNT = 0

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>
        THIS.LOCAL = PROP.LOCAL.LIST<PROP.LOOP>

* if wrapping property gets and puts is turned on build the method name for the
* method that would be the "get" for this property name.  if this method
* exists we'll call this method instead of writing the code to return the
* property value
        PROPERTY.WRAPPED = @FALSE
        DIM.PROPERTY.WRAPPED = @FALSE

        PROPERTY.WRAPPER.SUBROUTINE.NAME = ""
        PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME = ""

        IF ALLOW.WRAPPED.PROPERTY.CALLS THEN


            IF THIS.DIMENSIONS = 0 THEN

* see if there's a routine for wrapping the property.  if there is build the
* cbp subroutine name to call the wrapping method
                WRAPPER.METHOD.NAME = PUT.WRAPPED.PROPERTY.PREFIX:THIS.NAME
                LOCATE WRAPPER.METHOD.NAME IN METHOD.LIST SETTING WRAPPER.PTR THEN
                    PROPERTY.WRAPPED = @TRUE
                    PROPERTY.WRAPPER.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME
                    PROPERTY.WRAPPER.SUBROUTINE.NAME := ECLIPSE.DELIMITER:WRAPPER.METHOD.NAME
                END

            END ELSE

* if this property is dimensioned see if dimensioned property calls for this
* property are wrapped.  if so build the cbp subroutine name to call this
* method
                WRAPPER.DIM.METHOD.NAME = PUT.WRAPPED.DIM.PREFIX:THIS.NAME
                LOCATE WRAPPER.DIM.METHOD.NAME IN METHOD.LIST SETTING DIM.WRAPPER.PTR THEN
                    DIM.PROPERTY.WRAPPED = @TRUE
                    PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME
                    PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME := ECLIPSE.DELIMITER:WRAPPER.DIM.METHOD.NAME
                END

            END

        END

* if multivalued pointers are passed in and multivalue.properties
* is turned on put out code for inserting multivalues
        BEGIN CASE


* cases where we don't want to add anything:
*     if property is local don't add it
            CASE THIS.LOCAL
                NULL


* wrapped properties and we have multivalue property pointers enabled:
*     property is not dimensioned
            CASE PROPERTY.WRAPPED
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE

*     property is a 1 dimensional array and we have both the array pointer
*     and multivalue pointers
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE

*     property is a 2 dimensional array and we have both the array pointers
*     and multivalue pointers
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = "* ":THIS.NAME:" is a wrapped property"
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND ATTR.PTR <> ""'
                GOSUB ADD.CODE
                CODE = '            ':PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, DIM.PTR2, ATTR.PTR, VAL.PTR, SUBVAL.PTR"
                GOSUB ADD.CODE


*     multivalue.properties is turned off
            CASE NOT(MULTIVALUE.PROPERTIES)
                NULL


* parameters that aren't wrapped:
*     multivalue pointer(s) passed in for a non-dimensioned variable
            CASE THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = '            ':THIS.NAME:"<DIM.PTR1,DIM.PTR2,DIM.PTR3> = PROPERTY.VALUE"
                GOSUB ADD.CODE

*     dimensioned variable, 1 dimension, multivalue and array pointer(s)
*     passed in
            CASE THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":THIS.NAME:"(DIM.PTR1)<ATTR.PTR,VAL.PTR,SUBVAL.PTR> = PROPERTY.VALUE"
                GOSUB ADD.CODE

*     dimensioned variable, 2 dimensions, multivalue and array pointer(s)
*     passed in
            CASE THIS.DIMENSIONS = 2
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                CODE = " "
                GOSUB ADD.CODE
                GOSUB ADD.CODE
                CODE = "            ":THIS.NAME:"(DIM.PTR1,DIM.PTR2)<ATTR.PTR,VAL.PTR,SUBVAL.PTR> = PROPERTY.VALUE"
                GOSUB ADD.CODE


        END CASE

* if this is a dimensioned variable add case statements for setting a
* single array element.  for non-dimensioned variables add code for
* setting a multivalue
        BEGIN CASE


* cases where we don't want to add anything:
*     if property is local don't add it
            CASE THIS.LOCAL
                NULL


* wrapped properties
*     properties that are wrapped:
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1"
                GOSUB ADD.CODE

*     property is a 2 dimensional array
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME
                CODE := '" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE, "
                CODE := "DIM.PTR1, DIM.PTR2"
                GOSUB ADD.CODE


* unwrapped properties
*     1 dimension variable
            CASE THIS.DIMENSIONS = 1
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":THIS.NAME:"(DIM.PTR1) = PROPERTY.VALUE"
                GOSUB ADD.CODE

*     2 dimensional variable
            CASE THIS.DIMENSIONS = 2
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'" AND DIM.PTR1 <> "" AND DIM.PTR2 <> ""'
                GOSUB ADD.CODE
                CODE = "            ":THIS.NAME:"(DIM.PTR1,DIM.PTR2) = PROPERTY.VALUE"
                GOSUB ADD.CODE


        END CASE

* "normal" property setting, where the array and multivalue pointers
* are not set
        BEGIN CASE

* cases where we don't want to add anything:
*     if this is a local property don't add code to update it
            CASE THIS.LOCAL
                NULL


* normal property update and the property is wrapped:
            CASE PROPERTY.WRAPPED AND THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, PROPERTY.VALUE"
                GOSUB ADD.CODE

* dimensioned property update and the property is wrapped
            CASE DIM.PROPERTY.WRAPPED AND THIS.DIMENSIONS > 0
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                CODE = " "
                GOSUB ADD.CODE
                GOSUB ADD.CODE
                CODE = "            ":PROPERTY.WRAPPER.DIM.SUBROUTINE.NAME
                CODE := " OBJECT.HANDLE, ERROR.MESSAGE, MAT DIM.PROPERTY.VALUE"
                GOSUB ADD.CODE


*     normal extract for a property that's not dimensioned
            CASE THIS.DIMENSIONS = 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            ":THIS.NAME:" = PROPERTY.VALUE"
                GOSUB ADD.CODE

*     normal extract for a dimensioned property
            CASE THIS.DIMENSIONS > 0
                CODE = " "
                GOSUB ADD.CODE
                CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
                GOSUB ADD.CODE
                CODE = "            MAT ":THIS.NAME:" = MAT DIM.PROPERTY.VALUE"
                GOSUB ADD.CODE


        END CASE

* if we're coding multivalued extracts add a blank line for readability
        IF MULTIVALUE.PROPERTIES THEN
            CODE = " "
            GOSUB ADD.CODE
        END

    NEXT PROP.LOOP

* add up how many non-local constants we have
    NON.LOCAL.CONSTANT.COUNT = 0

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT

        IF NOT(CONSTANT.LOCAL.LIST<CONSTANT.LOOP>) THEN
            NON.LOCAL.CONSTANT.COUNT += 1
        END

    NEXT CONSTANT.LOOP

* add in cases for constants.  yes, we wouldn't normally allow setting
* constants but somewhere someone is going to try it so we might as well
* make it work
    IF ALLOW.PUT.CONSTANTS AND NON.LOCAL.CONSTANT.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* constants"
        GOSUB ADD.CODE
    END

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT UNTIL NOT(ALLOW.PUT.CONSTANTS)

        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>
        THIS.LOCAL = CONSTANT.LOCAL.LIST<CONSTANT.LOOP>

        IF NOT(THIS.LOCAL) THEN
            CODE = " "
            GOSUB ADD.CODE
            CODE = '        CASE PROPERTY.NAME = "':THIS.NAME:'"'
            GOSUB ADD.CODE
            CODE = "            PROPERTY.VALUE = ":THIS.NAME
            GOSUB ADD.CODE
        END

    NEXT CONSTANT.LOOP

    CODE = " "
    GOSUB ADD.CODE
    CODE = "    END CASE"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @FALSE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB AFTER.ADD

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / copy.object method    **
**************************************************************************
**************************************************************************

CREATE.COPY.OBJECT.METHOD: ***********************************************
* create a method to copy properties from one object instance to         *
* another                                                                *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = COPY.OBJECT.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating COPY.OBJECT Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS:"ERROR.MESSAGE":BETWEEN.PARAMETERS:"TARGET.HANDLE"
    CODE := ")"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* copy instance ":OBJECT.NAME "L#30":"                           *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

* if this object has no properties don't create any copying routines.
* this routine will be here so that calls to it won't fail.  if it's a
* single instance object there's no need for a copy
    IF PROPERTIES.EXIST AND NOT(SINGLE.OBJECT) THEN
        GOSUB ADD.COPY.OBJECT.COPIES
    END

* all copies complete
    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @TRUE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code
* and then add the instance code to the subroutine.  if we
* have no properties null out the instance code and start over
* so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB AFTER.ADD

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN

ADD.COPY.OBJECT.COPIES: **************************************************
* add code to the copy.object method to copy properties                  *
**************************************************************************
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

* save the source handle for later
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    SOURCE.HANDLE = OBJECT.HANDLE"
    GOSUB ADD.CODE

* validate the object handles
    OBJECT.ERROR.METHOD = UPCASE (OBJECT.NAME):METHOD.DELIMITER:"COPY.OBJECT: "

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* make sure the target object is valid"
    GOSUB ADD.CODE
    CODE = "    BEGIN CASE"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE SOURCE.HANDLE = ""'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Source Handle of object copy is null"'
    GOSUB ADD.CODE
    CODE = '        CASE NOT(NUM(SOURCE.HANDLE<1>))'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Source Handle of object copy is not valid"'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE TARGET.HANDLE = ""'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Target Handle of object copy is null"'
    GOSUB ADD.CODE
    CODE = '        CASE NOT(NUM(TARGET.HANDLE<1>))'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Target Handle of object copy is not valid"'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = '        CASE SOURCE.HANDLE<2> <> TARGET.HANDLE<2>'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Target Handle of object copy is not the same type as the Source"'
    GOSUB ADD.CODE
    CODE = '        CASE SOURCE.HANDLE<1> = TARGET.HANDLE<1>'
    GOSUB ADD.CODE
    CODE = '            ERROR.MESSAGE = "':OBJECT.ERROR.METHOD:'Cannot copy an object to itself"'
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE
    CODE = "    END CASE"
    GOSUB ADD.CODE

    CODE = '    IF ERROR.MESSAGE <> "" THEN'
    GOSUB ADD.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* if copying from an instance to the same instance skip the copy"
    GOSUB ADD.CODE
    CODE = "    IF SOURCE.HANDLE<1> = TARGET.HANDLE<1> THEN"
    GOSUB ADD.CODE
    CODE = "        GOSUB ":EXIT.OUT.GOSUB.NAME
    GOSUB ADD.CODE
    CODE = "    END" 
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* method code"
    GOSUB ADD.CODE
    CODE = "* update property value based on property name"
    GOSUB ADD.CODE

* copy current properties to temporary variables
    IF PROP.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* copy properties / statics"
        GOSUB ADD.CODE
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>

        BEGIN CASE

*     copy to temporary value for a property that's not dimensioned
            CASE THIS.DIMENSIONS = 0
                CODE = "    PROPERTY.COPY.":THIS.NAME:" = ":THIS.NAME
                GOSUB ADD.CODE

*     copy to temporary value for a dimensioned property
            CASE THIS.DIMENSIONS > 0
                CODE = "    DIM PROPERTY.COPY.":THIS.NAME:" (":CHANGE(THIS.DIM, @VM, ","):")"
                GOSUB ADD.CODE
                CODE = "    MAT PROPERTY.COPY.":THIS.NAME:" = MAT ":THIS.NAME
                GOSUB ADD.CODE

        END CASE

    NEXT PROP.LOOP

* add in cases for constants.  yes, we wouldn't normally allow setting
* constants but somewhere someone is going to try it so we might as well
* make it work
    IF ALLOW.PUT.CONSTANTS AND CONSTANT.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* constants"
        GOSUB ADD.CODE
    END

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT UNTIL NOT(ALLOW.PUT.CONSTANTS)

        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>

        CODE = "    CONSTANT.COPY.":THIS.NAME:" = ":THIS.NAME
        GOSUB ADD.CODE

    NEXT CONSTANT.LOOP

* save the current object instance and load the target instance for the copy
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* save the current instance and load the target instance"
    GOSUB ADD.CODE
    CODE = "    OBJECT.HANDLE = TARGET.HANDLE"
    GOSUB ADD.CODE
    CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

* copy temporary variables to properties for the target instance
    IF PROP.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* copy properties / statics to the target instance"
        GOSUB ADD.CODE
    END

    FOR PROP.LOOP = 1 TO PROP.COUNT

        THIS.NAME = PROP.NAME.LIST<PROP.LOOP>
        THIS.DIM = PROP.DIM.LIST<PROP.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)
        THIS.TYPE = PROP.TYPE.LIST<PROP.LOOP>

        BEGIN CASE

*     copy to temporary value for a property that's not dimensioned
            CASE THIS.DIMENSIONS = 0
                CODE = "    ":THIS.NAME:" = PROPERTY.COPY.":THIS.NAME
                GOSUB ADD.CODE

*     copy to temporary value for a dimensioned property
            CASE THIS.DIMENSIONS > 0
                CODE = "    MAT ":THIS.NAME:" = MAT PROPERTY.COPY.":THIS.NAME
                GOSUB ADD.CODE

        END CASE

    NEXT PROP.LOOP

* add in cases for constants.  yes, we wouldn't normally allow setting
* constants but somewhere someone is going to try it so we might as well
* make it work
    IF ALLOW.PUT.CONSTANTS AND CONSTANT.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* constants"
        GOSUB ADD.CODE
    END

    FOR CONSTANT.LOOP = 1 TO CONSTANT.COUNT UNTIL NOT(ALLOW.PUT.CONSTANTS)

        THIS.NAME = CONSTANT.NAME.LIST<CONSTANT.LOOP>
        THIS.VALUE = CONSTANT.VALUE.LIST<CONSTANT.LOOP>

        CODE = "    ":THIS.NAME:" = CONSTANT.COPY.":THIS.NAME
        GOSUB ADD.CODE

    NEXT CONSTANT.LOOP

* copy child object handles for the target of the copy to temporary variables
    IF CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* child object handles"
        GOSUB ADD.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        BEGIN CASE

* child depth is deeper than we want to worry about
            CASE THIS.CHILD.DEPTH > BUILD.CHILD.DEPTH 
                NULL

* if this is a child of a child we don't need to worry about it.  the senior
* child will take care of it's copy
            CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0
                NULL

* dimensioned child variable
            CASE THIS.DIM <> ""
                CODE = "    DIM CHILD.COPY.":THIS.VARIABLE:" (":CHANGE(THIS.DIM, VM, ","):")"
                GOSUB ADD.CODE
                CODE = "    MAT CHILD.COPY.":THIS.VARIABLE:" = MAT ":THIS.VARIABLE
                GOSUB ADD.CODE

* child variable
            CASE 1
                CODE = "    CHILD.COPY.":THIS.VARIABLE:" = ":THIS.VARIABLE
                GOSUB ADD.CODE

        END CASE

    NEXT CHILD.LOOP

* save the target instance and restore the source instance
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* save the target instance and load the original instance"
    GOSUB ADD.CODE
    CODE = "    OBJECT.HANDLE = SOURCE.HANDLE"
    GOSUB ADD.CODE
    CODE = "    GOSUB CHECK.OBJECT.INSTANCE"
    GOSUB ADD.CODE

* if there are any child objects of this object add code to copy them
    IF CHILD.COUNT > 0 THEN
        CODE = " "
        GOSUB ADD.CODE
        CODE = "* copy child object properties"
        GOSUB ADD.CODE
    END

    FOR CHILD.LOOP = 1 TO CHILD.COUNT

        THIS.NAME = CHILD.NAME.LIST<CHILD.LOOP>
        THIS.HANDLE = CHILD.HANDLE.LIST<CHILD.LOOP>
        THIS.VARIABLE = CHILD.VARIABLE.LIST<CHILD.LOOP>

        THIS.DIM = CHILD.DIM.LIST<CHILD.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,VM)

        BEGIN CASE

* child depth is deeper than we want to worry about
            CASE THIS.CHILD.DEPTH > BUILD.CHILD.DEPTH
                NULL

* if this is a child of a child we don't need to worry about it.  the senior
* child will take care of it's copy
            CASE INDEX(THIS.HANDLE, CHILD.DELIMITER, 1) > 0
                NULL

* two dimensional dimensioned child variable
            CASE THIS.DIMENSIONS = 2
                MAX.ARRAY1 = THIS.DIM<1,1>
                MAX.ARRAY2 = THIS.DIM<1,2>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB ADD.CODE
                CODE = "        FOR ARRAY.PTR2 = 1 TO ":MAX.ARRAY2
                GOSUB ADD.CODE
                CODE = "            "
                CODE := THIS.VARIABLE:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := METHOD.DELIMITER:COPY.OBJECT.KEYWORD
                CODE := " (CHILD.COPY."
                CODE := THIS.VARIABLE:"(ARRAY.PTR1, ARRAY.PTR2)"
                CODE := ")"
                GOSUB ADD.CODE
                CODE = "        NEXT ARRAY.PTR2"
                GOSUB ADD.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB ADD.CODE

* one dimensional dimensioned child variable
            CASE THIS.DIMENSIONS = 1
                MAX.ARRAY1 = THIS.DIM<1,1>
                CODE = "    FOR ARRAY.PTR1 = 1 TO ":MAX.ARRAY1
                GOSUB ADD.CODE
                CODE = "        "
                CODE := THIS.VARIABLE:"(ARRAY.PTR1)"
                CODE := METHOD.DELIMITER:COPY.OBJECT.KEYWORD
                CODE := " (CHILD.COPY."
                CODE := THIS.VARIABLE:"(ARRAY.PTR1)"
                CODE := ")"
                GOSUB ADD.CODE
                CODE = "    NEXT ARRAY.PTR1"
                GOSUB ADD.CODE

* child variable
            CASE 1
                CODE = "    "
                CODE := THIS.VARIABLE
                CODE := METHOD.DELIMITER:COPY.OBJECT.KEYWORD
                CODE := " (CHILD.COPY."
                CODE := THIS.VARIABLE
                CODE := ")"
                GOSUB ADD.CODE

        END CASE

    NEXT CHILD.LOOP

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / get.property.list     **
**************************************************************************
**************************************************************************

CREATE.GET.PROPERTY.LIST.METHOD: *****************************************
* create a method to return a list of property names                     *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = GET.PROPERTY.LIST.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating GET.PROPERTY.LIST Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS:"ERROR.MESSAGE"
    CODE := BETWEEN.PARAMETERS:"PROPERTY.LIST":BETWEEN.PARAMETERS:"PROPERTY.COUNT"
    CODE := BETWEEN.PARAMETERS:"INCLUDE.LOCAL":BETWEEN.PARAMETERS:"INCLUDE.HANDLES"
    CODE := BETWEEN.PARAMETERS:"INCLUDE.DIM"
    CODE := ")"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* return a list of properties for ":OBJECT.NAME "L#30":"         *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize returned values"
    GOSUB ADD.CODE
    CODE = '    PROPERTY.LIST = ""'
    GOSUB ADD.CODE
    CODE = "    PROPERTY.COUNT = 0"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* default passed parameters"
    GOSUB ADD.CODE
    CODE = '    IF INCLUDE.LOCAL = "" THEN'
    GOSUB ADD.CODE
    CODE = "        INCLUDE.LOCAL = @FALSE"
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '    IF INCLUDE.HANDLES = "" THEN'
    GOSUB ADD.CODE
    CODE = "        INCLUDE.HANDLES = @FALSE"
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = '    IF INCLUDE.DIM = "" THEN'
    GOSUB ADD.CODE
    CODE = "        INCLUDE.DIM = @FALSE"
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

* build a list of property names
    CODE = " "
    GOSUB ADD.CODE

    FOR PROPERTY.LOOP = 1 TO PROP.COUNT

        THIS.PROP = PROP.NAME.LIST<PROPERTY.LOOP>

        THIS.DIM = PROP.DIM.LIST<PROPERTY.LOOP>
        THIS.DIMENSIONS = DCOUNT(THIS.DIM,@VM)

        THIS.TYPE = PROP.TYPE.LIST<PROPERTY.LOOP>
        THIS.KEYWORD = PROP.KEYWORD.LIST<PROPERTY.LOOP>

        IF UPCASE.CODE THEN
            THIS.PROP = DOWNCASE (THIS.PROP)
        END

* get is.local, is.handle and is.dim flags that describe this property
* value for no.handles
        IF THIS.DIMENSIONS > 0 THEN
            IS.DIM = @TRUE
        END ELSE
            IS.DIM = @FALSE
        END

        DECODE.KEYWORD = THIS.KEYWORD
        GOSUB IS.PROPERTY.KEYWORD

* build a boolean statement based on is.local, is.handle, is.dim
        FILTER.EXPRESSION = ""

* if this property is a local property test the include.local parameter
        IF IS.LOCAL THEN
            FILTER.EXPRESSION = "INCLUDE.LOCAL"
        END

* if this property is a handle property test the include.handles parameter
        IF IS.HANDLE THEN

            IF FILTER.EXPRESSION <> "" THEN
                FILTER.EXPRESSION := " AND "
            END

            FILTER.EXPRESSION := "INCLUDE.HANDLES"

        END

* if this property is a dimensioned property test the include.dim parameter
        IF IS.DIM THEN

            IF FILTER.EXPRESSION <> "" THEN
                FILTER.EXPRESSION := " AND "
            END

            FILTER.EXPRESSION := "INCLUDE.DIM"

        END

* if we have a boolean statement to filter based on is.local, is.handle and
* is dim add the name conditionally.  otherwise just add it
        CODE = " "
        GOSUB ADD.CODE

        IF FILTER.EXPRESSION <> "" THEN

            CODE = "    IF ":FILTER.EXPRESSION:" THEN"
            GOSUB ADD.CODE
            CODE = "        PROPERTY.COUNT += 1"
            GOSUB ADD.CODE
            CODE = '        PROPERTY.LIST<PROPERTY.COUNT> = "':THIS.PROP:'"'
            GOSUB ADD.CODE
            CODE = "    END"
            GOSUB ADD.CODE

        END ELSE

            CODE = "    PROPERTY.COUNT += 1"
            GOSUB ADD.CODE
            CODE = '    PROPERTY.LIST<PROPERTY.COUNT> = "':THIS.PROP:'"'
            GOSUB ADD.CODE

        END

    NEXT PROPERTY.LOOP

* all copies complete
    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @TRUE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code and then add the
* instance code to the subroutine.  if we have no properties null out the
* instance code and start over so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB AFTER.ADD

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

* if this object has no properties we need some dummy subroutines for the
* instance-handling code
    IF NOT (PROPERTIES.EXIST) THEN
        GOSUB ADD.DUMMY.INSTANCE.CODE
    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / get.method.list       **
**************************************************************************
**************************************************************************

CREATE.GET.METHOD.LIST.METHOD: *******************************************
* create a method to return a list of method names                       *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = GET.METHOD.LIST.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating GET.METHOD.LIST Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS:"ERROR.MESSAGE"
    CODE := BETWEEN.PARAMETERS:"OBJECT.METHOD.LIST":BETWEEN.PARAMETERS:"OBJECT.METHOD.COUNT"
    CODE := BETWEEN.PARAMETERS:"INCLUDE.LOCAL"
    CODE := ")"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* return a list of methods for ":OBJECT.NAME "L#30":"            *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize returned values"
    GOSUB ADD.CODE
    CODE = '    OBJECT.METHOD.LIST = ""'
    GOSUB ADD.CODE
    CODE = "    OBJECT.METHOD.COUNT = 0"
    GOSUB ADD.CODE
    CODE = '    IF INCLUDE.LOCAL = "" THEN'
    GOSUB ADD.CODE
    CODE = "        INCLUDE.LOCAL = @FALSE"
    GOSUB ADD.CODE
    CODE = "    END"
    GOSUB ADD.CODE

* build a list of method names
* start with the default methods
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* default methods"
    GOSUB ADD.CODE

    FOR METHOD.LOOP = 1 TO DEFAULT.METHOD.COUNT

        THIS.METHOD = DEFAULT.METHOD.LIST<METHOD.LOOP>

        IF UPCASE.CODE THEN
            THIS.METHOD = DOWNCASE (THIS.METHOD)
        END

        CODE = "    OBJECT.METHOD.COUNT += 1"
        GOSUB ADD.CODE
        CODE = '    OBJECT.METHOD.LIST<OBJECT.METHOD.COUNT> = "':THIS.METHOD:'"'
        GOSUB ADD.CODE

    NEXT METHOD.LOOP

* now add in any methods that aren't in the default method list
    CODE = " "
    GOSUB ADD.CODE
    CODE = "* custom methods"
    GOSUB ADD.CODE

    FOR METHOD.LOOP = 1 TO METHOD.COUNT

        THIS.METHOD = METHOD.LIST<METHOD.LOOP>
        THIS.TYPE = METHOD.TYPE.LIST<METHOD.LOOP>
        THIS.LOCAL = METHOD.LOCAL.LIST<METHOD.LOOP>

        IF UPCASE.CODE THEN
            THIS.METHOD = DOWNCASE (THIS.METHOD)
        END

        LOCATE THIS.METHOD IN DEFAULT.METHOD.LIST SETTING THROWAWAY ELSE

* add this method to the property list based on the method type and passed
* value for include.local
            BEGIN CASE

                CASE THIS.METHOD = "COMMON"
                    NULL

                CASE NOT(THIS.LOCAL)
                    CODE = "    OBJECT.METHOD.COUNT += 1"
                    GOSUB ADD.CODE
                    CODE = '    OBJECT.METHOD.LIST<OBJECT.METHOD.COUNT> = "':THIS.METHOD:'"'
                    GOSUB ADD.CODE

                CASE 1
                    CODE = "    IF INCLUDE.LOCAL THEN"
                    GOSUB ADD.CODE
                    CODE = "        OBJECT.METHOD.COUNT += 1"
                    GOSUB ADD.CODE
                    CODE = '        OBJECT.METHOD.LIST<OBJECT.METHOD.COUNT> = "':THIS.METHOD:'"'
                    GOSUB ADD.CODE
                    CODE = "    END"
                    GOSUB ADD.CODE

            END CASE

        END

    NEXT METHOD.LOOP

* all copies complete
    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @TRUE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code and then add the
* instance code to the subroutine.  if we have no properties null out the
* instance code and start over so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB AFTER.ADD

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

* if this object has no properties we need some dummy subroutines for the
* instance-handling code
    IF NOT (PROPERTIES.EXIST) THEN
        GOSUB ADD.DUMMY.INSTANCE.CODE
    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN


**************************************************************************
**************************************************************************
** code conversion / objects / methods / create / get.property.by.name  **
**************************************************************************
**************************************************************************

CREATE.GET.PROPERTY.BY.NAME.METHOD: **************************************
* create a method to return a property value given the property name in  *
* a variable                                                             *
**************************************************************************
    GOSUB START.CREATE.TIME

    SOURCE.START = ""
    TARGET.START = ""
    SOURCE.LINE.COUNT = 0

    TARGET.COMMON.START = ""
    SOURCE.COMMON.START = ""
    SOURCE.COMMON.COUNT = 0

    PARAMETER.LIST = ""
    PARAMETER.BYREF.LIST = ""
    PARAMETER.SPECIAL.LIST = ""
    PARAMETER.COUNT = 0

    METHOD = GET.PROPERTY.BY.NAME.KEYWORD
    SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:METHOD

    IF DETAILS THEN
        PRINT
        PRINT "Creating GET.PROPERTY.BY.NAME Method Subroutine ":SUBROUTINE.NAME
    END

* display what we're compiling
    GOSUB SHOW.METHOD

    GOSUB INITIALIZE.PROGRAM.CODE

    GOSUB INIT.LINE.XREF

    GOSUB BEFORE.ADD

    IF NO.SPACES.IN.SUB.DEFINITION THEN
        BETWEEN.PARAMETERS = ","
    END ELSE
        BETWEEN.PARAMETERS = ", "
    END

    CODE = "    SUBROUTINE ":SUBROUTINE.NAME
    CODE := " ("
    CODE := "OBJECT.HANDLE":BETWEEN.PARAMETERS:"ERROR.MESSAGE"
    CODE := BETWEEN.PARAMETERS:"PROPERTY.VALUE":BETWEEN.PARAMETERS:"PROPERTY.NAME"
    CODE := ")"
    GOSUB ADD.CODE
    CODE = " "
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.STAMP
    GOSUB ADD.CHECKSUM.STAMP
    GOSUB ADD.LAST.STAMP

    GOSUB BEFORE.ADD

    CODE = " "
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE
    CODE = "* get a property value for a property name for ":OBJECT.NAME "L#26":" *"
    GOSUB ADD.CODE
    CODE = "**************************************************************************"
    GOSUB ADD.CODE

    GOSUB AFTER.ADD

    GOSUB ADD.METHOD.COMMENT.CODE

    GOSUB ADD.SPECIAL.CODE

* if we're adding common code at the top of the program add it now.  if
* not add a subroutine call for it
    IF PROPERTY.COMMON.CODE.AT.END THEN

        GOSUB BEFORE.ADD

        CODE = "    GOSUB ":PROPERTY.COMMON.CODE.SUBROUTINE.NAME
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END ELSE
        GOSUB ADD.COMMON.CODE
    END

    GOSUB BEFORE.ADD

* code splitting
    GOSUB CHECK.METHOD.SPLIT 
    GOSUB ADD.METHOD.SPLITTING.CODE

    CODE = " "
    GOSUB ADD.CODE
    CODE = "* initialize error return variable"
    GOSUB ADD.CODE
    CODE = "    ":ERROR.MESSAGE.VARIABLE:" = ":'""'
    GOSUB ADD.CODE

    CODE = "    PROPERTY.VALUE = ":'""'
    GOSUB ADD.CODE

* call the usual get.property subroutine to get the property value
    CODE = " "
    GOSUB ADD.CODE
    
    IF PROPERTIES.EXIST THEN

        GET.SUBROUTINE.NAME = ECLIPSE.PREFIX:OBJECT.NAME:ECLIPSE.DELIMITER:GET.KEYWORD
        CODE = "    ":GET.SUBROUTINE.NAME:" OBJECT.HANDLE, PROPERTY.NAME, PROPERTY.VALUE"
        GOSUB ADD.CODE

    END

* all copies complete
    GOSUB AFTER.ADD

    ADD.RETURN = @TRUE
    ADD.FINAL.ERROR.CHECK = @TRUE
    INDENT = ""
    GOSUB ADD.METHOD.CODE

    IF NOT(ENDS.WITH.RETURN) THEN

        GOSUB BEFORE.ADD

        CODE = " "
        GOSUB ADD.CODE
        CODE = "    ":EXIT.METHOD.KEYWORD
        GOSUB ADD.CODE

        GOSUB AFTER.ADD

    END

    GOSUB ADD.COMMON.METHOD.CODE

    GOSUB ADD.INTIME.OBJECT.CODE

* if common code goes at the end add a subroutine for it
    IF PROPERTY.COMMON.CODE.AT.END THEN
        GOSUB ADD.COMMON.CODE.SUBROUTINE
    END

* rebuild the instance code specifically for this method
    GOSUB BUILD.INSTANCE.CODE

    INCLUDE.INSTANCE.CODE.LABELS = @TRUE
    GOSUB PROCESS.GOSUBS

* add utility and error throw routines to the instance code and then add the
* instance code to the subroutine.  if we have no properties null out the
* instance code and start over so we only add the utility routines
    IF NOT(PROPERTIES.EXIST) THEN
        GOSUB CLEAR.INSTANCE.CODE
    END

    GOSUB AFTER.ADD

    GOSUB ADD.UTILITY.ROUTINES
    GOSUB ADD.INSTANCE.CODE

* if this object has no properties we need some dummy subroutines for the
* instance-handling code
    IF NOT (PROPERTIES.EXIST) THEN
        GOSUB ADD.DUMMY.INSTANCE.CODE
    END

    GOSUB END.CREATE.TIME

    PRE.CONVERT.CODE = PROGRAM.CODE
    PRE.CONVERT.CODE.LINES = PROGRAM.CODE.LINES

    GOSUB CONVERT.ROUTINE

    GOSUB START.CREATE.TIME

* handle auto-destroy changes
    GOSUB SET.AUTO.DESTROY

    IF DETAILS AND LIST.WITH.DETAILS THEN
        GOSUB LIST.SUBROUTINE
    END

    GOSUB END.CREATE.TIME

    RETURN


