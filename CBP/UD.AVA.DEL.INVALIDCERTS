        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, ENABLED, "Enabled", 0, 1 ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, SV.GL.BR, "DefaultBranch", "1000" ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, RUN.LIMIT, "PartSyncRunLimit", 3600 ; SETTING = CALL.TEMP.OBJECT.HANDLE
        CALL.TEMP.OBJECT.HANDLE = SETTING ; UD.MTH.SETTING.GET CALL.TEMP.OBJECT.HANDLE, ERROR.MESSAGE, RUNCTRLREC, "RunCtrlRec" ; SETTING = CALL.TEMP.OBJECT.HANDLE
*   END.WITH
    
    TEMP.HANDLE = "" ; UD.MTH.FILE.MANAGER.NEW TEMP.HANDLE, ERROR.MESSAGE, REGISTRY.SOURCE.ID ; MANAGER = TEMP.HANDLE ; * new FILE.MANAGER object
        
    * Get my process id for tracking.
    UNIX.PID.GET MYPID
    
    * Run one at a time.  Do not let another Sync begin while one is running.
    READV RUN.PID FROM CTRLFILE, (RUNCTRLREC), (2) ELSE RUN.PID = ''
    
    IF RUN.PID THEN 
        * Check that the Process is still active.  This could result in a false positive.
        * Better safe than sorry... If we track our own PID, it'll get cleaned up on exit.
        UT.PIDS.GET RUNNING.PIDS
        LOCATE RUN.PID IN RUNNING.PIDS SETTING IS.RUNNING ELSE IS.RUNNING = @FALSE
        IF IS.RUNNING AND (RUN.PID # MYPID) THEN 
            PHST.MSG = "Sync already running!  ":RUN.PID
            SEND.MESSAGE 'Phantom',USER.ID, PHST.MSG
            GOSUB LOG.MSG
            SLEEP 12
            *  Exit immediately without writing last action record.  Keep previous entry.
            GOSUB EXIT.TO.CALLING.PROGRAM
        END 
        * Not actually running... clean up the Ctrl Rec.
        DELETE CTRLFILE, RUNCTRLREC
    END 
    *  This process is running... write control record with PID.
    WRITEV (MYPID) ON CTRLFILE, (RUNCTRLREC), (2)
    
    IF NOT( ENABLED ) THEN 
        RUN.MSG = "Interface not enabled!" 
        GOSUB LOG.MSG
        GOSUB FINISH
    END 

* last run
    * read last date and time of last sync.
    READ.LAST.ACTION LAST.DATE, PGM.NAME, @FALSE, 1
    READ.LAST.ACTION LAST.TIME, PGM.NAME, 0, 2
    
    IF LAST.DATE AND LAST.TIME THEN 
        LAST.DATE = ICONV (LAST.DATE, "D4/")
        LAST.TIME = ICONV (LAST.TIME, "MTHS")
    END 
    
* variables    
    REC.CT = @FALSE
    RESP = ''
    CMD = ''
    CN = ''
    DEL.CNT = @FALSE
    DEL.CERT.CNT = @FALSE
    PORTAL.CUST.LST = ''
    PORTAL.CUID.LST = ''
    PORTAL.CERT.LST = ''
    PCN.CERT.LST = ''
    CUS.POS = @FALSE
    PCN = ''
    PCN.ID = ''
    
* variables for api calls and caching.
    GL.BR = ''
    COMPID = @FALSE

    RUN.MSG = "Initialized  ":MYPID
    GOSUB LOG.MSG
    RUN.MSG = ""
    GOSUB LOG.MSG
    
* files
    GOSUB PREP.FILES

    LAST.RUN.REC<1> = OCONV (DATE(), 'D4/')
    LAST.RUN.REC<2> = OCONV (TIME(), 'MTHS')
    WRITE (LAST.RUN.REC) ON AVAIDFILE, ('LAST.DEL')
    
