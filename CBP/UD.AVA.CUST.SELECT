***************************************************************************
    ERROR.MESSAGE = ""
    CURRENT.OBJECT.NAME = "UD.AVA.CUST.SELECT"
    CURRENT.METHOD.NAME = "MAIN"
    CURRENT.COMPLETE.NAME = "UD.AVA.CUST.SELECT"
    CURRENT.SUBROUTINE.NAME = "UD.AVA.CUST.SELECT"
 
    RETURN
