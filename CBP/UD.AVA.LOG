***       Subroutine:  UD.AVA.LOG
***
**************************************************************************
***  Program to select a record, and view the change log for it in
***  MAINT.LOG
**************************************************************************
***

    GOSUB LOAD.OBJECT.SUBROUTINE.VARIABLES
 
    REC.LIST = ''
    RECS = ''
    IF UNASSIGNED (PASSER) THEN 
        RETURN
    END 
    IF INDEX (PASSER,'~',1) THEN 
        REC.ID = PASSER
        GOSUB DISPLAY.LOG
    END ELSE 
        CN    =   PASSER
        GOSUB GET.ALL.RECS
    END 
FINISH:        
 GOSUB EXIT.TO.CALLING.PROGRAM
***************************************************************************
DISPLAY.LOG:
    MAINT.LOG.VIEW 'AVALARA_DATA':AM:REC.ID:AM:REC.ID
    
  RETURN
***************************************************************************
GET.ALL.RECS:  *** GET ALL THE TAX CERT RECS FOR THIS CUSTOMER.          

    CMD   =   'SELECT AVALARA_DATA WITH CN = "':CN:'"'
    EXECUTE (CMD) CAPTURING MSG RTNLIST REC.LIST

    LOOP
        READNEXT REC.ID FROM REC.LIST ELSE 
            EXIT
        END 
     
        LOCATE REC.ID IN RECS BY "AL" SETTING POS ELSE 
            RECS    =   INSERT(RECS, POS; REC.ID)
            IF POS > 8 THEN 
                GOSUB FINISH
            END 
        END 
        GOSUB DISPLAY.LOG
    REPEAT 

    RETURN
***************************************************************************          

