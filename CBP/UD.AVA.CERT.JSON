PARSE.CERTIFICATE:
    
    C.DATA = ''
    CI.CT = @FALSE
    UT.PARSE.JSON RESP, CERT.ITEMS, CERT.VALUES
    CI.CT = DCOUNT (CERT.ITEMS,AM)
    ADD.OUTPUT.TEXT = ("parsing ":CI.CT:" json items from the cert.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    
    FOR CITEM = 1 TO CI.CT 
        IT.NAME = UPCASE(CERT.ITEMS<CITEM>)
        IT.VAL  = CERT.VALUES<CITEM>
        BEGIN CASE 
            CASE IT.NAME = "ID"
                C.DATA<1>  =   IT.VAL
                ADD.OUTPUT.TEXT = ("ID: ":IT.VAL) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
            CASE IT.NAME = "SIGNEDDATE" 
                C.DATA<7>  =   IT.VAL
            CASE IT.NAME = "EXPIRATIONDATE"
                C.DATA<8>  =   IT.VAL
            CASE IT.NAME = "EXEMPTIONNUMBER"
                C.DATA<5>  =   IT.VAL
                ADD.OUTPUT.TEXT = ("Exemption Number: ":IT.VAL) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
            CASE IT.NAME = "EXEMPTIONREASON"
                GOSUB PARSE.EXEMPTION.REASON
            CASE IT.NAME = "TAXNUMBERTYPE"
                C.DATA<6>  =   IT.VAL
            CASE IT.NAME = "BUSINESSNUMBERTYPE"
                IF NUM(IT.VAL) THEN 
                    C.DATA<13> =   IT.VAL
                    C.DATA<14> = ''
                END ELSE 
                    C.DATA<13> =   "20"
                    C.DATA<14> =   IT.VAL
                END 
            CASE IT.NAME = "EXPOSUREZONE"
                GOSUB PARSE.EXPOSURE.ZONE
            CASE OTHERWISE
                * Do nothing.
        END CASE 
    NEXT CITEM 
        
 RETURN
***************************************************************************
PARSE.EXEMPTION.REASON:
    UT.PARSE.JSON IT.VAL, EX.ITEMS, EX.VALUES
*    sub::ut.parse.json (ex.data, ex.items, ex.values)
    EITEM.CT = DCOUNT (EX.ITEMS,AM)
    FOR EITEM = 1 TO EITEM.CT 
        EIT.NAME    = UPCASE (EX.ITEMS<EITEM>)
        EIT.VAL     = EX.VALUES<EITEM>
        IF EIT.NAME = "NAME" THEN 
            IF EIT.VAL = "RESALE" THEN 
                C.DATA<15> =   "G"
            END ELSE 
                IF EIT.VAL = "INDUSTRIAL PROD/MANUFACTURERS" THEN 
                    C.DATA<15> = "I"
                END 
            END 
        END 
    NEXT EITEM 

 RETURN
**************************************************************************
PARSE.EXPOSURE.ZONE:
    VALID.EZONES = ''
    UT.PARSE.JSON IT.VAL, EX.ITEMS, EX.VALUES
*    sub::ut.parse.json (ex.data, ex.items, ex.values)
    EITEM.CT = DCOUNT (EX.ITEMS,AM)

    IF EITEM.CT AND NOT( VALID.EZONES ) THEN 
        UD.AVA.EZONES VALID.EZONES
    END 
    FOR EITEM = 1 TO EITEM.CT 
        EIT.NAME    = EX.ITEMS<EITEM>
        EIT.VAL     = EX.VALUES<EITEM>
        
        IF UPCASE(EIT.NAME) = "NAME" THEN 
            LOCATE EIT.VAL IN VALID.EZONES<2> SETTING VAL THEN 
                C.DATA<4>  =   VALID.EZONES<1,VAL>
                C.DATA<3>  =   "US"
            END 
        END 
    NEXT EITEM 
    
 RETURN
