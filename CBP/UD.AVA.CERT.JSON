PROC.CERT:
    FOUND.CERT = @FALSE
    EXEMPT.SEARCH = @FALSE
    CERT.REG = ''
    CERT.NUM = ''
    IF NOT(NUM( CERT.ID )) THEN 
        EXEMPT.SEARCH = @TRUE
        GOTO SKIP.SELECT
    END 

    CMD = 'SELECT UD.AVALARA WITH AVACERT_ID = "':CERT.ID:'"'
    EXECUTE CMD CAPTURING MSG 
    LOOP WHILE READNEXT AID DO 
        READV AID.CERT.ID FROM AVAIFILE,AID,1 THEN 
            IF FOUND.CERT THEN 
                ADD.OUTPUT.TEXT = ('Cert with Duplicate Cert ID found in UD.AVALARA: ':AID) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                * Sticking with first match.
                CONTINUE
            END 
        END ELSE 
            CONTINUE
        END 
        FOUND.CERT = (AID = CERT.ID)
        IF FOUND.CERT THEN 
            ADD.OUTPUT.TEXT = (('Cert found:':SPACE(2)):AID) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        END 
    REPEAT 

SKIP.SELECT:
    IF FOUND.CERT THEN 
        * Build cert json from Customer Record if matched.
        CERT.REG    =   FIELD (AID,'~',2)[1,2]
        CERT.NUM    =   TRIM (FIELD (AID,'~',2)[3,99])
    END ELSE 
        IF NOT( EXEMPT.SEARCH ) THEN 
            * Get Cert from API Call, to match on.
            ADD.OUTPUT.TEXT = ((SPACE(2):'Attempting match on portal certificate.')) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
            UD.AVA.GET.CERTIFICATE COMP.ID, CERT.ID, , RESP, ERROR.MESSAGE
            IF (ERROR.MESSAGE <> '') THEN 
                ADD.OUTPUT.TEXT = ("Error getting cert from API. UD.AVA.GET.CERTIFICATE") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
            END ELSE 
                ADD.OUTPUT.TEXT = ((SPACE(2):('No error accessing Portal.':SPACE(2):'Parsing Cert.'))) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                GOSUB PARSE.CERTIFICATE
                IF C.DATA<1> THEN 
                    ADD.OUTPUT.TEXT = ("API Cert ID: ":C.DATA<1>) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                    CERT.REG    =   C.DATA<4>
                    ADD.OUTPUT.TEXT = ("cert.reg: ":CERT.REG) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                    CERT.NUM    =   C.DATA<5>
                    ADD.OUTPUT.TEXT = ("cert.num: ":CERT.NUM) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                END 
            END 
        END ELSE 
            * If a Region:ExemptNumber ID was provided.  Look in AVALARA_DATA.
            IF CERT.ID THEN 
                ADD.OUTPUT.TEXT = (("Region:ExemptNumber provided for lookup.":SPACE(2)):CERT.ID) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                CERT.REG    =   CERT.ID[1,2]
                CERT.NUM    =   TRIM (CERT.ID[3,99])
                
            END ELSE 
                *No data to look up.  Exit.
                ADD.OUTPUT.TEXT = (("No data to lookup.":SPACE(2):"Exiting.")) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
                GOSUB FINISH
            END 
        END 

    END 
    C.CERT.CNT = DCOUNT(CUS.REC<33>,VM)
    IF C.CERT.CNT = 0 THEN 
        ADD.OUTPUT.TEXT = ("No certificates on customer record.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RETURN
    END 
    
    * get all certificates for customer.
    FOR C.CERT.NO =   1 TO C.CERT.CNT    
        * find the one cert we need to process.  Process it.
        C.CERT.REG = CUS.REC<33,C.CERT.NO>
        C.CERT.NUM = UPCASE(TRIM(CUS.REC<34,C.CERT.NO>))
        * match Region first... no region match move on.
        IF CERT.REG # C.CERT.REG THEN CONTINUE
        * Correct for any case issues
        IF C.CERT.NUM # CUS.REC<34,C.CERT.NO> THEN 
            * Write back upcased, and trimmed Exemption number.
            READVU C.CERT.NUM.TEMP.RECORD FROM CUSFILE, (CN), (34) THEN C.CERT.NUM.TEMP.RECORD<1,C.CERT.NO> = (C.CERT.NUM) ; WRITEV C.CERT.NUM.TEMP.RECORD ON CUSFILE, (CN), (34) ELSE C.CERT.NUM.TEMP.RECORD = '' ; C.CERT.NUM.TEMP.RECORD<1,(C.CERT.NO)> = (C.CERT.NUM) ; WRITEV C.CERT.NUM.TEMP.RECORD ON CUSFILE, (CN), (34)
        END 
        * match on exemption number
        IF (UPCASE(TRIM(CERT.NUM))) = C.CERT.NUM THEN 
            *Found
            FOUND.CERT = @TRUE
            EXIT
        END 
    NEXT C.CERT.NO 
    
    IF NOT( FOUND.CERT ) THEN 
        *  Not found.  Return with no JSON.
        ADD.OUTPUT.TEXT = (('Cert:':SPACE(2):'"'):CERT.NUM:('"':SPACE(2):'"'):CUS.REC<34>:'"') ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        ADD.OUTPUT.TEXT = ("Unable to locate matching certificate in customer certificates.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RETURN
    END 
    
    * Once we find a match in the above For Loop, c.cert.no is set to the position of that match.
    * At this point we are not in a loop.
    
    C.CERT.REGION       =  (UPCASE(TRIM(CUS.REC<33,C.CERT.NO>)))
    C.CERT.NUMBER       =  (UPCASE(TRIM(CUS.REC<34,C.CERT.NO>)))

    AID =   CN:"~":C.CERT.REGION:C.CERT.NUMBER
    READV EFF.DATE FROM AVAIFILE, (AID), (2) ELSE EFF.DATE = ''
    IF NOT( EFF.DATE ) THEN 
        EFF.DATE    =   DEF.EFF.DATE
    END 
    
    * Skip any deleted or expired certificates.
    *exp.date    =   cus.rec<172,c.cert.no>
    * Expiring all certificates to clear portal.
    EXP.DATE    =  20821
    EXP.DATE   +=  0
    IF NOT( EXP.DATE ) THEN 
        ADD.OUTPUT.TEXT = ("No valid expiration date on customer rec.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        REALDATE DEFAULTEXPIRE, VAR.EXP.DATE
        READV EXP.DATE FROM AVAIFILE, (AID), (3) ELSE EXP.DATE = (DEFAULTEXPIRE)
        IF EXP.DATE = DEFAULTEXPIRE THEN 
            ADD.OUTPUT.TEXT = ("No expiration recorded in UD.AVALARA.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        END 
        * No expiration date on customer cert record, set it to match portal or default.
        CUS.REC<172,C.CERT.NO> = EXP.DATE
        READ NOTHING FROM AVAIFILE,AID THEN 
            WRITEV (EXP.DATE) ON AVAIFILE, (AID), (3)
        END 
        * Write evaluated expiration date to customer.
        READVU EXP.DATE.TEMP.RECORD FROM CUSFILE, (CN), (172) THEN EXP.DATE.TEMP.RECORD<1,C.CERT.NO> = (EXP.DATE) ; WRITEV EXP.DATE.TEMP.RECORD ON CUSFILE, (CN), (172) ELSE EXP.DATE.TEMP.RECORD = '' ; EXP.DATE.TEMP.RECORD<1,(C.CERT.NO)> = (EXP.DATE) ; WRITEV EXP.DATE.TEMP.RECORD ON CUSFILE, (CN), (172)

    END 
    IF INDEX(EFF.DATE,"/",1) THEN 
        CEFD        =   ICONV(EFF.DATE,"D4/")
    END ELSE 
        CEFD        =   EFF.DATE
    END 
    IF INDEX(EXP.DATE,"/",1) THEN 
        CEXD        =   ICONV(EXP.DATE,"D4/")
    END ELSE 
        CEXD        =   EXP.DATE
    END 
    
    IF (CEXD <DATE()) OR (CEFD >CEXD) THEN 
        ADD.OUTPUT.TEXT = ("Expired or invalid effective date on cert.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        * Return with no JSON.
        RETURN
    END 
        
    CUR.CERT = ''
    
    CUR.CERT<2>       =  OCONV(CEFD,"D-YMD[Z4,2,2]"):"T00:00:00"
    CUR.CERT<3>       =  OCONV(CEXD,"D-YMD[Z4,2,2]"):"T00:00:00"
    
    * Is cert blank?  Use for future checking.
    CERT.BLANK        =  LEN(TRIM(C.CERT.NUMBER)) = 0
    UD.AVA.TAXCERT.IMG CN, CERT.NUMBER, CERT.FILENAME
    CUR.CERT<4>       =  CERT.FILENAME
    CERT.FILENAME     =  ""
    CUR.CERT<5>       =  "true"
    CUR.CERT<6>       =  C.CERT.NUMBER
    EXEMPT.REASON     =  FIELD(CUS.REC<105,C.CERT.NO>,'=',1)
    *Test for a Type other than G or I, Resale or Inducstrial/mfg
    WRNG.REAS = (EXEMPT.REASON # "G") AND (EXEMPT.REASON # "I")
    *Test for DEN Type.  DEN is allowed here.
    WRNG.REAS = (WRNG.REAS) AND (EXEMPT.REASON # "DEN")
    *Skip if Blank, NOT G, NOT I, NOT DEN.
    SKIP.CERT = (CERT.BLANK OR WRNG.REAS)
    IF C.CERT.REGION = "CO" AND EXEMPT.REASON = "DEN" THEN 
    *Skip if DEN, but a City of Denver exemption exists.
        SKIP.CERT = SKIP.CERT AND (CUS.REC<175,C.CERT.NO,1> = "DENVER")
    END 
    IF SKIP.CERT THEN 
        ADD.OUTPUT.TEXT = ("Skipping cert based on skip criteria.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
        RETURN
    END 
    
    BEGIN CASE 
        CASE EXEMPT.REASON    =  "I"
            CERT.REASON = "INDUSTRIAL PROD/MANUFACTURERS"

        CASE EXEMPT.REASON    =  "G"
            CERT.REASON = "RESALE"
    END CASE 
    CUR.CERT<7, 2> =  CERT.REASON
      
    CUR.CERT<8>      =  "TIN"
    CUR.CERT<9>      =  BUS.NUM.TYPE
    
    * exposure zones.
    LOCATE C.CERT.REGION IN E.REG<1> SETTING POS THEN 
    END 
    EXP.ZONE.NAME        =  E.NAMES<1, POS>
        
    CUR.CERT<10, 2> =  EXP.ZONE.NAME
        
START.JSON:
    ADD.OUTPUT.TEXT = ("Starting JSON.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT

    UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, "", "", 1
    CERT.AM.COUNT = DCOUNT (CUR.CERT, AM)
    FOR CERT.AM   =  1 TO CERT.AM.COUNT 
        LAST.AM = (CERT.AM = CERT.AM.COUNT)
        MV.CT = DCOUNT (CUR.CERT<CERT.AM>, VM)
        IF MV.CT = 2 THEN 
            IF (CUR.CERT<CERT.AM, 2>) THEN 
                UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, CERT.HEAD<CERT.AM, 1>, "", 6
                UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, CERT.HEAD<CERT.AM, 2>, CUR.CERT<CERT.AM, 2>, "", YES
                UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, "", "", 2, LAST.AM
            END 
        END ELSE 
            IF (CUR.CERT<CERT.AM>) THEN 
                UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, CERT.HEAD<CERT.AM>, CUR.CERT<CERT.AM>, "", LAST.AM
            END 
        END 
    NEXT CERT.AM 

    UT.ADD.JSON NRJ.LEVEL, CERTREC.JSON, "", "", 2, YES

END.JSON:
    MSG.OUT = LOWER(CERTREC.JSON)
    ADD.OUTPUT.TEXT = (MSG.OUT) ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT
    ADD.OUTPUT.TEXT = ("JSON Ended.") ; OUTPUT.BUFFER.COUNT += 1 ; IF OUTPUT.BUFFER = '' THEN OUTPUT.BUFFER = ADD.OUTPUT.TEXT ELSE OUTPUT.BUFFER := @AM:ADD.OUTPUT.TEXT

 RETURN
